@startuml
package "FlutterCleanArchitecture" {
    
    package "Core Layer" {
        class "Http Client"
        class "Http Retrier"
        class "Device Connection"
        class "Push Notification Handler"
        class "Failure Handling"
        class "Exception Handling"
        class "Sentry Exceptions"
    }

    package "Data Layer" {
        class "Remote Data Sources"
        class "Local Data Sources"
        class "Models"
        class "Repository Implementations"
    }

    package "Domain Layer" {
        class "Entities"
        class "Use Cases"
        class "Repository Interfaces"
    }

    package "Presentation Layer" {
        class "UI Components"
        class "Screens"
        class "BLoCs"
    }

    package "Dependency Injection" {
        class "Injection Container"
    }

    package "Firebase Messaging" {
        class "Push Notifications"
    }

    package "Localization" {
        class "Language Constants"
        class "Localization Delegates"
    }

    package "Shared Preferences" {
        class "Theme Settings"
        class "Language Settings"
    }

    ' Layer Interactions
    "Core Layer" -> "Data Layer" : "Uses"
    "Data Layer" -> "Domain Layer" : "Implements"
    "Domain Layer" -> "Presentation Layer" : "Interacts"
    "Presentation Layer" -> "Core Layer" : "Utilizes"
    "Presentation Layer" -> "Dependency Injection" : "Uses"
    "Presentation Layer" -> "Firebase Messaging" : "Integrates"
    "Presentation Layer" -> "Localization" : "Adapts"
    "Core Layer" <- "Shared Preferences" : "Persists"

}
@enduml