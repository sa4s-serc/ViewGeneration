@startuml
package "hyeonsangjeon/youtube-dl-nas" {
  
  node "Web Interface" {
    [Static Files]
    [HTML Templates]
    [JavaScript Logic]
  }
  
  node "API Server" {
    [youtube-dl-server.py]
    [Bottle Framework]
    [REST API]
    [WebSockets]
  }

  node "Authentication" {
    [Auth.json]
    [Basic Authentication]
  }

  node "Download Management" {
    [Download Queue]
    [Download Worker]
  }
  
  node "Update Scheduler" {
    [upd_schedule.py]
    [apscheduler]
  }
  
  node "Containerization" {
    [Dockerfile]
    [run.sh]
  }
  
  node "Volume Storage" {
    [downfolder]
  }
  
  package "Third-party Tools" {
    [yt-dlp / youtube-dl]
  }
  
}

[Web Interface] --> [API Server] : "HTTP / WebSockets"
[API Server] --> [Download Management] : "API Calls"
[API Server] --> [Authentication] : "Secured API"
[API Server] --> [Update Scheduler] : "Invoke Scheduler"
[API Server] --> [Volume Storage] : "File Storage"
[Download Management] --> [Third-party Tools] : "Execute Download"
[Containerization] --> [API Server] : "Container Host"
[Containerization] --> [Volume Storage] : "Bind Mount"

@enduml