@startuml
package "Java-Web System" {
    package "Backend" {
        [Java Servlets]
        [Spring Boot]
    }

    package "Frontend" {
        [HTML]
        [CSS]
        [JavaScript]
        [jQuery]
    }

    package "Data Storage" {
        [Redis]
        [MySQL]
    }

    package "Security" {
        [Shiro]
        [OAuth2]
    }

    package "Dubbo Framework" {
        [Dubbo Registry]
        [Dubbo RPC]
    }

    package "Tomcat Server" {
        [Tomcat Connectors]
        [Tomcat Containers]
    }

    package "Online Visitor Tracking" {
        [Visitor Tracking Service]
    }
}

[Java Servlets] --> [Spring Boot] : Control Flow
[Spring Boot] --> [MySQL] : API Calls
[Spring Boot] --> [Redis] : API Calls
[Spring Boot] --> [Shiro] : API Calls
[Spring Boot] --> [OAuth2] : API Calls

[HTML] --> [JavaScript] : Control Flow
[JavaScript] --> [jQuery] : Control Flow
[jQuery] --> [AJAX] : Control Flow

[Dubbo Registry] --> [Dubbo RPC] : Service Discovery
[Dubbo RPC] --> [Tomcat Connectors] : RPC
[Tomcat Connectors] --> [Tomcat Containers] : Request Processing

[Visitor Tracking Service] --> [Java Servlets] : Control Flow

note right of [Dubbo Registry]
    Publish-Subscribe:
    Service Registration
    and Discovery
end note

note right of [Tomcat Containers]
    Chain of Responsibility:
    Request Processing
end note

@enduml