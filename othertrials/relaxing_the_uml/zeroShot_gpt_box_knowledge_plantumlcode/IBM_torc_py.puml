@startuml
package "IBM_torc_py Scheduling" {
    actor User

    component "Main Process" as mainProcess {
        control "init()" as initFunc
        control "start()" as startFunc
        control "shutdown()" as shutdownFunc
        control "launch()" as launchFunc
    }

    control "Task Management" as taskMgmt {
        control "submit()" as submitFunc
        control "map()" as mapFunc
        control "wait()" as waitFunc
        control "as_completed()" as asCompletedFunc
    }

    component "Worker Process" as workerProcess {
        control "Task Queue" as torcQueue
        control "Server Thread" as serverThread
    }

    User --> mainProcess: Uses
    mainProcess --> initFunc
    mainProcess --> startFunc
    mainProcess --> shutdownFunc
    mainProcess --> launchFunc
    mainProcess --> taskMgmt

    taskMgmt --> submitFunc
    taskMgmt --> mapFunc
    taskMgmt --> waitFunc
    taskMgmt --> asCompletedFunc

    mainProcess --> workerProcess
    workerProcess --> torcQueue
    workerProcess --> serverThread

    component "Load Balancing" as loadBalancing {
        control "Round Robin" as roundRobin
        control "Task Stealing" as taskStealing
    }

    mainProcess --> loadBalancing
    loadBalancing --> roundRobin
    loadBalancing --> taskStealing
}
@enduml