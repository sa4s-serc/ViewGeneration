@startuml
package "Frontend (Public Directory)" {
  [index.html] --> [main.js]
  [main.js] --> [main.css]
}

package "Backend (Src Directory)" {
  [server.js] --> [router.js]
  [router.js] --> [handler.js]
  [handler.js] --> [algorithm.js]
  [algorithm.js] --> [data.json]
}

package "Testing (Test Directory)" {
  [qunit.html] --> [frontendTests.js]
  [backendTests.js]
}

package "Documentation" {
  [README.md]
}

[main.js] --> [server.js] : "API Call"
[frontendTests.js] --> [main.js] : "Function Call"
[backendTests.js] --> [algorithm.js] : "Function Call"

@enduml