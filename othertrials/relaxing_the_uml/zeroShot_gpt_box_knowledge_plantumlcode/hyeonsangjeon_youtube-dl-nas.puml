@startuml
!define ICONS
package "hyeonsangjeon/youtube-dl-nas" {
    package "Web Server" {
        [Bottle Framework] --> [REST API]
        [Bottle Framework] --> [Web Interface]
        [WebSockets] --> [Web Interface]
        [WebSockets] --> [Download Progress]
        [REST API] --> [Download Requests]
    }
    
    package "Authentication" {
        [Auth.json] --> [Web Server]
        [Basic Auth] --> [Web Server]
    }
    
    package "Download Management" {
        [Download Queue] --> [Download Worker]
        [Download Worker] --> [yt-dlp / youtube-dl]
        [Queue Management] --> [Download Queue]
        [Queue Management] --> [Download Worker]
    }
    
    package "Containerization" {
        [Docker Image] --> [Web Server]
        [Docker Image] --> [Download Management]
    }
    
    package "Update Management" {
        [apscheduler] --> [Auto Updates]
        [Auto Updates] --> [yt-dlp / youtube-dl]
    }
    
    package "Storage" {
        [downfolder] --> [Downloaded Files]
    }
    
    package "Static Files" {
        [HTML Templates] --> [Web Interface]
        [JavaScript] --> [WebSockets]
        [CSS] --> [Web Interface]
    }
}

rectangle "Security" as security {
    [Basic Auth] --> [REST API]
    [Basic Auth] --> [Web Interface]
    [Firewall] --> [Web Server]
}

rectangle "Control Flow" as control_flow {
    [REST API] --> [Download Requests]
    [Download Requests] --> [Download Queue]
    [Download Queue] --> [Download Worker]
    [Download Worker] --> [yt-dlp / youtube-dl]
}

rectangle "Connectivity" as connectivity {
    [Web Interface] --> [Download Progress]
    [WebSockets] --> [Download Progress]
}

rectangle "Network Components" as network_components {
    [Docker Image] --> [Web Server]
    [Docker Image] --> [Download Management]
    [Docker Image] --> [Update Management]
}

@enduml