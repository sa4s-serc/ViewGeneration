@startuml
!define AWS_LAMBDA(icon) component "<&lambda>\nicon" as icon
!define AWS_API_GATEWAY(icon) component "<&apiGateway>\nicon" as icon
!define AWS_S3(icon) storage "<&s3>\nicon" as icon
!define AWS_DYNAMODB(icon) database "<&dynamodb>\nicon" as icon
!define AWS_SNS(icon) component "<&sns>\nicon" as icon
!define AWS_SQS(icon) queue "<&sqs>\nicon" as icon
!define AWS_SAGEMAKER(icon) component "<&sagemaker>\nicon" as icon
!define AWS_COGNITO(icon) component "<&cognito>\nicon" as icon
!define AWS_ELASTICSEARCH(icon) storage "<&elasticsearch>\nicon" as icon
!define AWS_EC2(icon) node "<&ec2>\nicon" as icon
!define AWS_KAFKA(icon) component "<&kafka>\nicon" as icon
!define AWS_LEX(icon) component "<&lex>\nicon" as icon

actor User

User -> AWS_API_GATEWAY(APIGateway) : Interacts via API Calls
AWS_API_GATEWAY(APIGateway) -> AWS_LAMBDA(LF1) : Handles Chatbot Requests
AWS_API_GATEWAY(APIGateway) -> AWS_LAMBDA(getFixtures) : Fetch Fixtures
AWS_API_GATEWAY(APIGateway) -> AWS_LAMBDA(getLiveScores) : Get Live Scores
AWS_API_GATEWAY(APIGateway) -> AWS_LAMBDA(predictions) : Get Predictions

AWS_LAMBDA(LF1) -> AWS_LEX(Lex) : Chatbot Interaction
AWS_LAMBDA(getFixtures) -> AWS_ELASTICSEARCH(ElasticSearch) : Query Fixtures
AWS_LAMBDA(getLiveScores) -> AWS_DYNAMODB(DynamoDB) : Query Scores
AWS_LAMBDA(predictions) -> AWS_SAGEMAKER(SageMaker) : Predict Outcomes

AWS_LAMBDA(LF2) -> AWS_SQS(SQS) : Process Chatbot Requests
AWS_LAMBDA(LF2) -> AWS_ELASTICSEARCH(ElasticSearch) : Fetch Fixtures
AWS_LAMBDA(LF2) -> AWS_SNS(SNS) : Send Notifications

AWS_S3(S3) -> AWS_LAMBDA(scrapeMatchData) : Trigger on Event
AWS_LAMBDA(scrapeMatchData) -> AWS_DYNAMODB(DynamoDB) : Store Data

AWS_KAFKA(Kafka) -> AWS_EC2(EC2) : Hosted Infrastructure
AWS_KAFKA(Kafka) -> AWS_DYNAMODB(DynamoDB) : Store/Update Data

AWS_COGNITO(Cognito) -> User : Authentication

@enduml