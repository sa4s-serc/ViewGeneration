@startuml
actor User

package "Frontend" {
  [React UI]  
}

package "Backend" {
  [FastAPI Backend]
  [LyricsGenius API]
  [CNN Model]
  [Preprocessing]
}

package "Database" {
  [Elasticsearch]
}

User -> [React UI] : input song/artist
[React UI] -> [FastAPI Backend] : API Request
[FastAPI Backend] -> [Elasticsearch] : Query lyrics
[FastAPI Backend] -> [LyricsGenius API] : Fetch lyrics (if not in Elasticsearch)
[FastAPI Backend] -> [Preprocessing] : Normalize, Tokenize
[Preprocessing] -> [CNN Model] : Classify mood
[CNN Model] -> [FastAPI Backend] : Return classification
[FastAPI Backend] -> [Elasticsearch] : Store lyrics and mood
[FastAPI Backend] -> [Elasticsearch] : Query similar songs
[Elasticsearch] -> [FastAPI Backend] : Return similar songs
[FastAPI Backend] -> [React UI] : Recommend songs
@enduml