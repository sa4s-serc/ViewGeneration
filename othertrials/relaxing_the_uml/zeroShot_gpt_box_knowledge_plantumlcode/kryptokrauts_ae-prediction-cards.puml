@startuml
actor User

package "Frontend" {
  component ReactApp {
    [App.tsx]
    [state.ts]
    [WalletClient.ts]
    [PredictionCards.api.ts]
  }
}

package "Backend Services" {
  component OracleService {
    [oracle-service/src/...]
  }

  component ProcessPredictionService {
    [process-prediction-service/src/...]
  }
}

package "Smart Contract" {
  component PredictionCardsContract {
    [PredictionCards.aes]
    [PredictionCardsInterface.aes]
  }
}

package "Aeternity Blockchain" {
  database Aeternity {
    [AENS]
  }
}

User --> ReactApp : interacts 
ReactApp --> PredictionCardsContract : call PredictionCards.api.ts
ReactApp --> OracleService : call to query oracle
OracleService --> Aeternity : registers oracle
OracleService --> PredictionCardsContract : call ask_for_winning_option
ProcessPredictionService --> Aeternity : monitors for prediction events
ProcessPredictionService --> OracleService : triggers oracle queries
ProcessPredictionService --> PredictionCardsContract : call process_oracle_response

PredictionCardsContract --> Aeternity : store data
PredictionCardsContract <--> Aeternity : executes logic

User --> ReactApp : claim rewards
ReactApp --> PredictionCardsContract : call claim

@enduml