@startuml
package "org.jseats" {
    package "core" {
        class "SeatAllocatorProcessor" {
            +applyFilters()
            +executeAllocationMethod()
            +applyDecorators()
        }
        class "ProcessorConfig" {
            +loadConfig()
            +saveConfig()
        }
        class "SeatAllocatorResolver" {
            +resolveMethod()
            +resolveFilter()
            +resolveDecorator()
            +resolveTieBreaker()
        }
        class "SeatAllocatorDefaultResolver"
    }

    package "model" {
        class "Candidate"
        class "Tally" {
            +addCandidate()
            +getVotes()
        }
        class "Result"
        class "ResultDecorator"
        class "TallyFilter"
        class "SeatAllocationMethod"
        class "TieBreaker"
        
        package "methods" {
            class "MajorityMethod"
            class "LargestRemainderMethod"
            class "HighestAveragesMethod"
            class "EqualProportionsMethod"
        }
        
        package "tally" {
            class "TallyFilterImplementation"
        }
        
        package "result" {
            class "ResultDecoratorImplementation"
        }
        
        package "tie" {
            class "TieBreakerImplementation"
        }
    }

    package "cli" {
        class "SeatAllocatorLauncher" {
            +main()
        }
    }
}

SeatAllocatorProcessor *- "1" ProcessorConfig
SeatAllocatorProcessor *- "1" SeatAllocatorResolver
SeatAllocatorProcessor --> "1..*" Tally
SeatAllocatorProcessor --> "1..*" SeatAllocationMethod
SeatAllocatorProcessor --> "0..*" TallyFilter
SeatAllocatorProcessor --> "0..*" ResultDecorator
SeatAllocatorProcessor --> "0..*" TieBreaker

SeatAllocatorResolver --> SeatAllocationMethod
SeatAllocatorResolver --> TallyFilter
SeatAllocatorResolver --> ResultDecorator
SeatAllocatorResolver --> TieBreaker

SeatAllocatorLauncher --> SeatAllocatorProcessor
ProcessorConfig --> Tally
ProcessorConfig --> SeatAllocationMethod

SeatAllocationMethod <|-- MajorityMethod
SeatAllocationMethod <|-- LargestRemainderMethod
SeatAllocationMethod <|-- HighestAveragesMethod
SeatAllocationMethod <|-- EqualProportionsMethod

TallyFilter <|-- TallyFilterImplementation
ResultDecorator <|-- ResultDecoratorImplementation
TieBreaker <|-- TieBreakerImplementation
@enduml