@startuml
package "Flutter Clean Architecture" {
    package "Core Layer" {
        [Networking]
        [Device Management]
        [Error Handling]
        [Use Case Abstractions]
    }
    
    package "Data Layer" {
        [Data Sources]
        [Models]
        [Repository Implementations]
    }
    
    package "Domain Layer" {
        [Entities]
        [Use Cases]
        [Repository Interfaces]
    }
    
    package "Presentation Layer" {
        [UI Components]
        [Screens]
        [BLoCs]
    }
}

[Networking] --> [Data Sources] : "Handles Network Requests"
[Data Sources] --> [Models] : "Fetches Data"
[Data Sources] --> [Repository Implementations] : "Implements"
[Repository Implementations] --> [Repository Interfaces] : "Implements"
[Repository Interfaces] --> [Use Cases] : "Interacts with"
[Use Cases] --> [Entities] : "Defines Business Logic"
[Entities] --> [UI Components] : "Used in"
[UI Components] --> [Screens] : "Displays"
[Screens] --> [BLoCs] : "Manages State"

[Device Management] --> [Error Handling] : "Uses"
[Error Handling] --> [Use Case Abstractions] : "Reports"

@enduml