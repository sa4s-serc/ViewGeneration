@startuml
package "HTTP Proxy Service" {
  class HttpProxyServer <<Main>> {
    +setupServer()
    +initializePipeline()
  }
  class ClientToProxyHandler {
    +handleClientRequest()
    +forwardRequest()
  }
  class ProxyToServerInboundHandler {
    +handleBackendResponse()
    +applyResponseFilters()
  }
  class EntitysManager <<Singleton>> {
    +loadProxyEntities()
    +reloadConfiguration()
  }
  class GlobalExceptionHandler <<Interceptor>> {
    +catchExceptions()
    +buildErrorResponse()
  }
  class entitys.json {
    +getRoutingConfigurations()
  }
  class log4j2.xml {
    +configureLogging()
  }

  HttpProxyServer --> ClientToProxyHandler : function_calls
  ClientToProxyHandler --> ProxyToServerInboundHandler : function_calls
  ClientToProxyHandler --> EntitysManager : function_calls
  EntitysManager --> entitys.json : data_flow
  ProxyToServerInboundHandler --> GlobalExceptionHandler : function_calls
  GlobalExceptionHandler --> log4j2.xml : data_flow
}

package "Request/Response Filtering" {
  class ProxyRequestFilter <<Filter>> {
    +modifyRequest()
  }
  class ProxyResponseFilter <<Filter>> {
    +modifyResponse()
  }
  class AttackRequestFilter {
    +securityChecks()
  }
  class DefaultProxyResponseFilter {
    +logging()
  }

  ProxyRequestFilter <|-- AttackRequestFilter
  ProxyResponseFilter <|-- DefaultProxyResponseFilter
  ClientToProxyHandler --> ProxyRequestFilter : function_calls
  ProxyToServerInboundHandler --> ProxyResponseFilter : function_calls
}

package "Testing Module" {
  class TestClientApp {
    +loadTesting()
  }
  class TestServerMain {
    +startTestServer()
  }
  class TestResource {
    +implementRESTEndpoints()
  }

  HttpProxyServer ..> TestClientApp : function_calls
  HttpProxyServer ..> TestServerMain : function_calls
  TestServerMain --> TestResource : function_calls
}
@enduml