@startuml
title HTTP Proxy Service - Architectural View

package "HTTP Proxy Service" {
    package "proxy-server" {
        component "HttpProxyServer" as HttpProxyServer
        component "ClientToProxyHandler" as ClientToProxyHandler
        component "ProxyToServerInboundHandler" as ProxyToServerInboundHandler
        component "EntitysManager" as EntitysManager
        component "GlobalExceptionHandler" as GlobalExceptionHandler
    }

    package "proxy-sdk" {
        component "ProxyRequestFilter" as ProxyRequestFilter
        component "ProxyResponseFilter" as ProxyResponseFilter
    }

    package "test-client" {
        component "TestClientApp" as TestClientApp
    }

    package "test-server" {
        component "TestServerMain" as TestServerMain
        component "TestResource" as TestResource
    }

    database "entitys.json" as EntitysJson

    [HttpProxyServer] -> [ClientToProxyHandler] : Initializes
    [ClientToProxyHandler] -> [ProxyRequestFilter] : Applies filters
    [ClientToProxyHandler] -> [EntitysManager] : Fetches proxy rules
    [EntitysManager] --> [EntitysJson] : Loads configuration
    [ProxyToServerInboundHandler] -> [ProxyResponseFilter] : Applies filters
    [ProxyToServerInboundHandler] -> [GlobalExceptionHandler] : Handles exceptions
    [TestClientApp] -> [HttpProxyServer] : Sends requests
    [TestServerMain] -> [TestResource] : Starts server
    [TestResource] <--> [TestClientApp] : Interacts
}

note right of HttpProxyServer
    Main class that sets up
    the Netty server and initializes
    the channel pipeline.
end note

note right of ClientToProxyHandler
    Handles client requests,
    modifies requests, and
    forwards them using a Bootstrap.
end note

note right of ProxyToServerInboundHandler
    Handles backend responses,
    applies response filters, 
    and sends modified response
    to the client.
end note

note right of EntitysManager
    Loads and manages proxy
    entities from entitys.json,
    enabling dynamic configuration
    reloading.
end note

note right of GlobalExceptionHandler
    Provides centralized error handling.
end note

@enduml