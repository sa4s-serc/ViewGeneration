@startuml
!include <tupadr3/common>

package "Bunny Code Platform" {
    
    package "Backend" {
        [Node.js/Express/Socket.IO] --> [RESTful API]
        [Node.js/Express/Socket.IO] --> [JWT Authentication]
        [Node.js/Express/Socket.IO] --> [Socket.IO]
    }

    package "Database Layer" {
        [MySQL] --> [Node.js/Express/Socket.IO]
        [InfluxDB] --> [Node.js/Express/Socket.IO]
        [Redis] --> [Node.js/Express/Socket.IO]
    }

    package "Sandbox" {
        [Docker] --> [Node.js/Express/Socket.IO]
    }

    package "Cloud Services" {
        [S3] --> [Node.js/Express/Socket.IO]
        [CloudFront] --> [Node.js/Express/Socket.IO]
        [CloudWatch] --> [Node.js/Express/Socket.IO]
    }

    package "Reverse Proxy" {
        [Nginx] --> [Node.js/Express/Socket.IO]
    }
}

package "Development Environment" {
    [Docker Compose] --> [Bunny Code Platform]
}

[MySQL] --> [Persistent Data]
[InfluxDB] --> [Time-Series Data]
[Redis] --> [Cache/State Management]
[S3] --> [Storage]
[CloudFront] --> [Content Delivery]
[CloudWatch] --> [Monitoring/Logging]
[Docker] --> [Code Execution]
[Nginx] --> [SSL/Load Balancing]

@enduml