@startuml
package "Google Cloud Platform" {
    [Google Cloud Pub/Sub] as pubsub

    cloud "Kubernetes Engine" as gke {
        namespace "gke-pubsub-websocket-adapter" {
            node "Pod" {
                component "pulltop" as pulltop
                component "websocketd" as websocketd
            }
            [Ephemeral POSIX Storage] as storage
        }
    }
}

cloud "Client" {
    [WebSocket Client] as client
}

package "Infrastructure" {
    [Terraform] as terraform
    [Skaffold] as skaffold
    [Cloud Build] as cloudbuild
}

package "Configuration Management" {
    [kpt] as kpt
}

package "Deployment" {
    [Cron Job] as cron
}

pubsub --> pulltop : "Subscribe & Pull Messages"
pulltop --> websocketd : "Forward Messages"
websocketd --> client : "Expose WebSocket Endpoint"
websocketd --> storage : "Buffer Messages"

terraform --> gke : "Provision Infrastructure"
skaffold --> gke : "Automate Deployment"
cloudbuild --> terraform : "Trigger Deployment"
kpt --> gke : "Manage Manifests"
cron --> storage : "Rotate JSON Files"

@enduml