@startuml
!define COMPONENT(name, description) component name as description

database "MongoDB" as mongodb
database "Redis" as redis
component "Kubernetes" as k8s
component "RabbitMQ" as rabbitmq
component "Jaeger" as jaeger

component "Auth Service" as auth
component "Frontend Service" as frontend
component "Problems Service" as problems
component "Submissions Service" as submissions
component "Executor Service" as executor

k8s -> auth
k8s -> frontend
k8s -> problems
k8s -> submissions
k8s -> executor

auth --> redis : "Session Management"
frontend --> auth : "User Authentication"
frontend --> submissions : "User Submissions"
frontend --> problems : "Problem Details"

submissions --> rabbitmq : "Publish Submission"
executor --> rabbitmq : "Consume Submission"
executor --> rabbitmq : "Publish Results"
submissions --> rabbitmq : "Consume Results"
submissions --> frontend : "Real-time Feedback (WebSockets)"

problems --> mongodb : "Problem Storage"
submissions --> mongodb : "Submission Results Storage"
auth --> mongodb : "User Accounts"

submissions --> jaeger : "Distributed Tracing"
executor --> jaeger : "Distributed Tracing"

note right of k8s
    Kubernetes is the deployment environment
    providing orchestration and scaling.
end note

note right of rabbitmq
    RabbitMQ handles asynchronous 
    communication between services.
end note

note right of jaeger
    Jaeger provides distributed tracing for 
    monitoring and debugging.
end note
@enduml