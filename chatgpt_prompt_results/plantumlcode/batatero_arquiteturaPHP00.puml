@startuml
@startuml
package "Root Directory" {
  [index.php]
  [composer.json]
  [.htaccess]
}
package "src" {
  [App.php]
  [autoload.php]
  [routes.php]
  [Controller.php]
  
  package "controllers" {
    [HomeController.php]
    [TaskController.php]
  }
  
  package "models" {
    [Task.php]
  }
}

[index.php] ..> [composer.json]
[index.php] ..> [.htaccess]
[index.php] ..> [autoload.php] : includes
[index.php] ..> [routes.php] : includes
[index.php] ..> [App.php] : runs

[App.php] ..> [routes.php] : uses
[App.php] ..> [autoload.php] : uses

[autoload.php] ..> [Controller.php] : loads
[autoload.php] ..> [HomeController.php] : loads
[autoload.php] ..> [TaskController.php] : loads
[autoload.php] ..> [Task.php] : loads

[routes.php] ..> [HomeController.php] : uses
[routes.php] ..> [TaskController.php] : uses

[HomeController.php] --|> [Controller.php]
[TaskController.php] --|> [Controller.php]

[TaskController.php] ..> [Task.php] : uses
@enduml
@enduml