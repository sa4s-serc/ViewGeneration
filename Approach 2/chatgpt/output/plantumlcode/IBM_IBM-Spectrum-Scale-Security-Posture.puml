@startuml
@startuml IBM-Spectrum-Scale-Security-Posture
package "IBM-Spectrum-Scale-Security-Posture" {
    [README.md]
    [LICENSE]
    [spectrum-scale-audit.py]
    [spectrum-scale-audit.conf]
    [.github/workflows]
}

database "Spectrum Scale system" as SS
actor "User" as user

user --> [spectrum-scale-audit.py] : Executes
[spectrum-scale-audit.py] --> [spectrum-scale-audit.conf] : Reads parameters
[spectrum-scale-audit.py] --> SS : Performs security checks
[spectrum-scale-audit.py] --> user : Returns audit results
[spectrum-scale-audit.py] ..> [README.md] : Described in
[spectrum-scale-audit.py] ..> [LICENSE] : Governed by
user --> [.github/workflows] : Triggers GitHub Actions

@enduml
@enduml