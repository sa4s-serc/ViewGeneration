@startuml
@startuml
title Zswag Repository Component Diagram

package "Zswag Repository" {
  [CMakeLists.txt]
  [conanfile.py]
  [deploy.sh]
  [LICENSE]
  [README.md]
  [requirements.txt]
  [setup.py]
  folder "doc" {
    [zswag-architecture.mdj]
    [zswag-architecture.png]
  }
  package "libs" {
    [httpcl]
    [pyzswagcl]
    [zswag]
    [zswagcl]
  }
}

[CMakeLists.txt] ..> [libs] : includes
[conanfile.py] ..> [libs] : manages dependencies
[deploy.sh] ..> [libs] : deploys
[requirements.txt] ..> [setup.py] : lists dependencies
[setup.py] ..> [libs] : builds

@enduml
@enduml