        Component(client_handler, "ClientToProxyHandler", "Handles client requests\nApplies request filters")
        Component(server_handler, "ProxyToServerInboundHandler", "Handles backend responses\nApplies response filters")
        Component(entity_manager, "EntitysManager", "Manages proxy routing rules\nDynamic configuration")
        Component(exception_handler, "GlobalExceptionHandler", "Centralized error handling")

        Component(proxy_filters, "Proxy Filters", "Request/response processing")
