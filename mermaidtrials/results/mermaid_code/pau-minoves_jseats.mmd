C4Component
    title Control Flow in pau-minoves_jseats System

    Container_Boundary(b1, "pau-minoves_jseats") {
        Component(launcher, "SeatAllocatorLauncher", "CLI Entry Point", "Handles command-line arguments and initiates seat allocation")
        Component(processor, "SeatAllocatorProcessor", "Orchestration Controller", "Manages the seat allocation workflow")
        Component(resolver, "SeatAllocatorResolver", "Component Factory", "Resolves implementations for methods, filters, decorators")
        Component(config, "ProcessorConfig", "Configuration Manager", "Handles XML serialization/deserialization of settings")
        
        Component(methods, "SeatAllocationMethods", "Algorithm Implementations", "Various seat calculation algorithms (D'Hondt, Sainte-Laguë, etc.)")
        Component(filters, "TallyFilters", "Pre-processors", "Filters candidates before allocation")
        Component(decorators, "ResultDecorators", "Post-processors", "Modifies allocation results")
        Component(breakers, "TieBreakers", "Conflict Resolvers", "Handles tie-breaking scenarios")

        Component(model, "Data Model", "Core Entities", "Candidate, Tally, Result classes")
        Component(xml, "XML Handler", "Data Serialization", "JAXB-based XML processing")

        Rel(launcher, processor, "triggers")
        Rel(processor, resolver, "requests components")
        Rel(processor, config, "loads configuration")
        Rel(processor, methods, "executes")
        Rel(processor, filters, "applies")
        Rel(processor, decorators, "applies")
        Rel(processor, breakers, "uses")
        Rel(processor, model, "processes")
        Rel(config, xml, "uses for serialization")
    }

    System_Ext(cli, "Command Line", "User input/output")
    System_Ext(files, "XML Files", "Configuration and tally data")

    Rel(cli, launcher, "provides arguments")
    Rel(launcher, cli, "outputs results")
    Rel(files, config, "provides input")
    Rel(config, files, "saves output")