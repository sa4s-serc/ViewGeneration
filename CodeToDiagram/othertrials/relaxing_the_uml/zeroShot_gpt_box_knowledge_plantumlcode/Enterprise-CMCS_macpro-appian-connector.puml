@startuml
title Enterprise-CMCS_macpro-appian-connector Dynamic Control Flow

actor Developer

package "GitHub Repository" {
    [GitOps]
    [GitHub Actions]
    [Code Climate]
}

package "AWS Components" {
    [ECS]
    [SNS]
    [IAM]
    [CloudWatch]
    [SSM Parameter Store]
    [Secrets Manager]
}

package "Serverless Framework" {
    [serverless-compose.yml]
    [src/services/]
    [src/run.ts]
}

package "CI/CD" {
    [pre-commit checks]
    [unit tests]
    [dependency updates]
    [deploy workflow]
}

package "Security" {
    [detect-secrets]
    [cfn-nag]
    [Security Hub]
}

package "Documentation" {
    [README.md]
    [docs/]
    [Jira Integration]
}

Developer --> [GitOps] : Push Changes
[GitOps] -> [GitHub Actions] : Trigger CI/CD
[GitHub Actions] -> [pre-commit checks] : Execute
[GitHub Actions] -> [unit tests] : Run
[GitHub Actions] -> [dependency updates] : Check
[GitHub Actions] -> [deploy workflow] : Deploy

[deploy workflow] -> [ECS] : Deploy Services
[ECS] -> [SNS] : Notify on Failures
[SNS] -> Developer : Alert

[GitHub Actions] -> [cfn-nag] : Analyze CloudFormation
[GitHub Actions] -> [detect-secrets] : Scan for Secrets
[Security Hub] -> [Jira Integration] : Create Issues

[serverless-compose.yml] --> [src/services/] : Define Services
[src/run.ts] -> [ECS] : Execute Commands

[SSM Parameter Store] --> [src/services/] : Load Configurations
[Secrets Manager] --> [src/services/] : Load Secrets
[CloudWatch] --> Developer : Monitor Logs

[Code Climate] -> Developer : Report Maintainability

[README.md] --> Developer : Provide Overview
[docs/] --> Developer : Access Documentation

@enduml