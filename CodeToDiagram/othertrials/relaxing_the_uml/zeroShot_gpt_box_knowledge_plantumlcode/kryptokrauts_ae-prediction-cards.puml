@startuml
title Kryptokrauts AE Prediction Cards - Control Flow (Dynamic View)

package "Frontend" {
  component "App.tsx" as frontendApp
  component "State Management (Redux)" as frontendState
  component "WalletClient.ts" as walletClient
  component "PredictionCards.api.ts" as apiFacade
}

package "Backend Services" {
  component "Oracle Service" as oracleService
  component "Process Prediction Service" as processService
}

package "Smart Contract Layer" {
  component "PredictionCards.aes" as smartContract
  interface "PredictionCards Interface" as smartContractInterface
}

database "Aeternity Blockchain" as blockchain

frontendApp --> frontendState : "Manage state"
frontendApp --> walletClient : "Interact with wallet"
frontendApp --> apiFacade : "Use API facade"
apiFacade --> smartContractInterface : "Call contract functions"
smartContractInterface --> smartContract : "Invoke methods"

oracleService --> blockchain : "Register & Query"
processService --> blockchain : "Monitor & Process"
smartContract --> blockchain : "Execute & Store"

processService --> oracleService : "Trigger oracle queries"
oracleService --> processService : "Return oracle responses"

note right of frontendApp
  React-based interface for users
  to create predictions, rent NFTs,
  and claim rewards.
end note

note left of oracleService
  Service to handle oracle registration
  and querying on the blockchain.
end note

note bottom of processService
  Monitors blockchain for predictions,
  triggers oracle queries, and processes
  prediction results.
end note

note right of smartContract
  Governs prediction creation, NFT renting,
  oracle interactions, and reward distribution.
end note

cloud "Aeternity Blockchain Storage" {
  storage "Predictions and NFT ownership"
}

@enduml