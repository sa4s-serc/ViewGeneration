@startuml
package "Soundzone Web Application" {
    component "Frontend" {
        [React] --> [Redux]
        [React] --> [Components]
        [Components] --> [Auth Components]
        [Components] --> [Sound Components]
        [Components] --> [Upload Components]
    }
    
    component "Backend" {
        [Node.js] --> [Express]
        [Express] --> [PostgreSQL]
        [Express] --> [Cloudinary]
    }
    
    component "Database" {
        [PostgreSQL]
    }
    
    component "Storage" {
        [Cloudinary]
    }
    
    [React] --> [Node.js] : API Calls
    [Redux] --> [React] : State Management
    [Components] --> [React] : UI Composition
    [Express] --> [Node.js] : Server Logic
    [PostgreSQL] --> [Express] : Data Storage
    [Cloudinary] --> [Express] : Media Storage
}

package "Control Flow" {
    [User] --> [App.js] : Login/Register
    [App.js] --> [Home.js] : Route to Home
    [Home.js] --> [LoginForm.js] : User Login
    [Home.js] --> [RegistrationForm.js] : User Registration
    [App.js] --> [Profile.js] : Access Profile
    [Profile.js] --> [SoundDetail.js] : View Sound Details
    [Profile.js] --> [Dashboard.js] : View Sound Feed
    [Dashboard.js] --> [SoundBar.js] : Play Sound
    [SoundBar.js] --> [Sound.js] : Control Sound
    [App.js] --> [Upload.js] : Upload Sound
    [NavBar.js] --> [Search] : Search Users
}

package "Quality Attributes" {
    [Maintainability] --> [Component-Based Design]
    [Maintainability] --> [Redux State Management]
    [Maintainability] --> [Cloudinary Integration]
    [Maintainability] --> [Modular Architecture]
}
@enduml