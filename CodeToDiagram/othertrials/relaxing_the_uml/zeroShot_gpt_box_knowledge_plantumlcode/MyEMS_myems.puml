@startuml
package "MyEMS Architecture" {
    
    node "Frontend Layer" {
        [AngularJS UI]
    }

    package "API Layer" {
        [Falcon API] --> [Data Acquisition]
        [Data Acquisition] --> [Data Cleaning]
        [Data Cleaning] --> [Normalization]
        [Normalization] --> [Aggregation]
        [Aggregation] --> [Reporting]
        [Reporting] --> [User Management]
        [User Management] --> [Fault Detection]
        [Fault Detection] --> [Billing]
    }

    package "Data Layer" {
        [MySQL Databases] --> [System]
        [MySQL Databases] --> [Energy]
        [MySQL Databases] --> [Billing]
        [MySQL Databases] --> [Historical]
        [MySQL Databases] --> [Carbon]
    }

    [Falcon API] -[hidden]--> [Frontend Layer]
    [Billing] --> [Frontend Layer]

    node "Deployment" {
        [Docker Containers]
        [Environment Variables]
    }

    [AngularJS UI] --> [Docker Containers]
    [Docker Containers] --> [Falcon API]

    [Environment Variables] --> [Data Layer]
    [Environment Variables] --> [API Layer]

    [MySQL Databases] --> [Data Layer]
}

note right of [AngularJS UI]
    - AngularJS 1.x
    - UI-Router
    - Customizable Themes
    - i18n Support
end note

note right of [Falcon API]
    - RESTful API
    - CRUD Operations
    - API Centric Design
end note

note right of [User Management]
    - Authentication
    - Authorization
    - Session Management
    - API Keys
end note

note right of [Billing]
    - Dynamic Tariffs
    - Tenant Lease System
end note

note right of [Data Layer]
    - Multi-Database Support
    - Eventual Consistency
end note

note right of [Deployment]
    - Dockerized
    - Systemd Service Files
    - Shell Scripts
end note

note right of [Environment Variables]
    - Configuration Driven
end note

@enduml