@startuml
package "Frontend" {
    [React UI] as React_UI
}

package "Backend" {
    [FastAPI] as FastAPI
    [LyricsGenius API] as LyricsGenius_API
    [CNN Model] as CNN_Model
    [Elasticsearch Functions] as Elasticsearch_Functions
    [Utils] as Utils
}

package "Database" {
    [Elasticsearch] as Elasticsearch
}

package "Data Exploration" {
    [Jupyter Notebooks] as Jupyter_Notebooks
}

React_UI --> FastAPI : API Calls
FastAPI --> LyricsGenius_API : Fetch Lyrics
FastAPI --> Utils : Preprocess Lyrics
FastAPI --> CNN_Model : Classify Sentiment
FastAPI --> Elasticsearch_Functions : Query/Store Data
Elasticsearch_Functions --> Elasticsearch : Manage Index
FastAPI --> Elasticsearch : Retrieve/Store Lyrics
Jupyter_Notebooks --> Elasticsearch : Data Analysis

@enduml