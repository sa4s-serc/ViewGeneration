@startuml
package "HypnoLog System" {
    node "Server (Node.js/Express)" {
        [HTTP Request Handler]
        [Data Processor]
        [Real-time Communicator (Socket.IO)]
        [Route Manager]
    }

    node "Web UI" {
        [User Interface (HTML, JS, CSS)]
        [VisualizerDispatcher]
        [WindowsDispatcher]
        [ConfigFactory]
        [WindowsFilter]
    }

    package "Visualizers" {
        [String Visualizer]
        [Number Visualizer]
        [Object Visualizer]
        [Image Visualizer]
        [Heatmap Visualizer]
        [Code Visualizer]
    }

    node "Socket.IO" {
        [Real-time Data Broadcast]
    }

    node "Ajv" {
        [JSON Schema Validator]
    }
}

[HTTP Request Handler] --> [Data Processor] : processes data
[Data Processor] --> [Real-time Communicator (Socket.IO)] : broadcasts data
[Real-time Communicator (Socket.IO)] --> [User Interface (HTML, JS, CSS)] : updates UI
[VisualizerDispatcher] --> [User Interface (HTML, JS, CSS)] : manages visualizers
[WindowsDispatcher] --> [User Interface (HTML, JS, CSS)] : manages windows
[ConfigFactory] --> [VisualizerDispatcher] : loads configurations
[WindowsFilter] --> [WindowsDispatcher] : filters data by tags
[Real-time Data Broadcast] --> [User Interface (HTML, JS, CSS)]
[JSON Schema Validator] --> [HTTP Request Handler] : validates data

note top of [Server (Node.js/Express)]
    Handles HTTP requests, processes data
    and manages real-time communication
end note

note top of [Web UI]
    Displays data with various visualizers
    and manages user interface
end note

note right of [Visualizers]
    Graphically display data
    using different modules
end note

note bottom of [Socket.IO]
    Enables real-time communication
    between server and client UI
end note

note bottom of [Ajv]
    Validates incoming data
    against predefined schemas
end note
@enduml