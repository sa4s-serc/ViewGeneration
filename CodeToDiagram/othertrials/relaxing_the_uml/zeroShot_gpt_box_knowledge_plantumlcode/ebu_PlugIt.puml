@startuml
package "GitHub Repository Analysis System" {
    [GitHub Repository] as repo
    [Rate Limit Handler Service] as rlhService
    [Gemini API Service] as geminiAPI
    [Monitoring Service] as monitoringService
    [Error Handling Service] as errorHandlingService
    [Retry Logic Service] as retryLogicService
    [Token Optimization Service] as tokenOptimizationService
}

repo --> rlhService : analyze()
rlhService --> geminiAPI : requestAnalysis()
geminiAPI --> errorHandlingService : 429 Error
errorHandlingService --> retryLogicService : retry()
rlhService --> tokenOptimizationService : optimizeTokens()
repo --> monitoringService : trackUsage()
monitoringService --> geminiAPI : usageData()

@enduml