@startuml
package "hAFL2 System" {
    node "Linux Host" {
        node "QEMU" {
            node "Root Partition VM (Windows)" {
                component "VMSwitch (vmswitch.sys)"
                component "CrashMonitoringDriver.sys"
                node "Child Partition VM (Windows)" {
                    component "CPHarness.sys"
                }
            }
        }
    }

    package "KVM Modifications" {
        component "Intel PT Integration"
        component "Hypercall Handling"
    }

    package "Core Fuzzing" {
        component "kAFL Fuzzer" {
            component "kafl_fuzz.py"
            component "kafl_gui.py"
        }
        component "Master-Slave Architecture" {
            component "master.py"
            component "slave.py"
        }
    }

    package "Redqueen Instrumentation" {
        component "handle_hook"
        component "Symbolic Execution"
    }
}

"CPHarness.sys" -> "VMSwitch (vmswitch.sys)" : RNDIS Packets
"CrashMonitoringDriver.sys" -> "kAFL Fuzzer" : Crash Reports
"Master-Slave Architecture" -> "kAFL Fuzzer" : Task Distribution
"Redqueen Instrumentation" -> "kAFL Fuzzer" : Feedback
"Intel PT Integration" -> "kAFL Fuzzer" : Coverage Data
"Hypercall Handling" -> "VMSwitch (vmswitch.sys)" : Guest-Host Communication

@enduml