@startuml
title Neighbor-Army/help-with-covid Control Flow

package "Neighbor-Army/help-with-covid" {
    package "Frontend (Next.js)" {
        [index.js] --> [offer-help.js]
        [index.js] --> [request-help.js]
        [index.js] --> [auth.js]
        [offer-help.js] --> [VolunteerConfirmation]
        [request-help.js] --> [RequestHelp]
        [auth.js] --> [FirebaseAuth]
        [index.js] --> [Nav]
        [offer-help.js] --> [AddressInput]
    }

    package "Backend (Firebase Functions)" {
        [functions/index.js] --> [functions/routes/index.js]
        [functions/routes/index.js] --> [Task Management (Onfleet)]
        [functions/routes/index.js] --> [Team Management (Firebase Firestore)]
        [functions/routes/index.js] --> [Worker Management (Onfleet, Sendgrid)]
        [functions/routes/index.js] --> [Phone/Zipcode Verification (Twilio)]
    }

    package "Task Management" {
        [Task Management (Onfleet)] --> [Onfleet API]
    }

    package "Authentication" {
        [auth.js] --> [FirebaseAuth]
        [FirebaseAuth] --> [Firebase Authentication]
        [FirebaseAuth] --> [cookie-session middleware]
    }

    package "Email Communication" {
        [functions/services/sendgrid/index.js] --> [Sendgrid API]
    }

    package "Address Autocomplete" {
        [AddressInput] --> [Google Maps API]
    }

    package "Middleware" {
        [functions/index.js] --> [CORS Middleware]
        [functions/index.js] --> [URL Encoding Middleware]
        [functions/index.js] --> [JSON Parsing Middleware]
        [functions/index.js] --> [Logging Middleware]
        [functions/index.js] --> [Session Management Middleware]
    }

    [Frontend (Next.js)] --> [Backend (Firebase Functions)] : API calls
    [Backend (Firebase Functions)] --> [Task Management (Onfleet)] : API calls
    [Backend (Firebase Functions)] --> [Team Management (Firebase Firestore)] : API calls
    [Backend (Firebase Functions)] --> [Worker Management (Onfleet, Sendgrid)] : API calls
    [Backend (Firebase Functions)] --> [Phone/Zipcode Verification (Twilio)] : API calls
}

note right of [FirebaseAuth]
  Higher-Order Components (HOCs):
  - withAuthUser
  - withAuthUserInfo
end note

note right of [Middleware]
  Utilizes Express middleware
  for various functionalities
end note

@enduml