@startuml
package "Kubescape Host Scanner" {
  package "Main Entry" {
    class SensorGo {
      - Logger
      - HTTP Router
      - Signal Handling
      - OpenTelemetry
    }
  }

  package "HTTP Handlers" {
    class HTTPHandlersGo {
      + /healthz
      + /readyz
      + /osrelease
      + /kubeletinfo
    }
  }

  package "Sensor" {
    class OsReleaseGo
    class KubeletGo
    class ControlPlaneGo
    class CNIGo
  }

  package "Utilities" {
    class ContainerRuntimeGo
  }

  package "Deployment" {
    class K8sDeploymentYaml
  }

  package "Build" {
    class Dockerfile
  }

  package "E2E Testing" {
    class E2ETestGo
    class E2ESuiteTestGo
    class KindTestGo
  }
}

SensorGo --> HTTPHandlersGo
HTTPHandlersGo --> OsReleaseGo
HTTPHandlersGo --> KubeletGo
HTTPHandlersGo --> ControlPlaneGo
HTTPHandlersGo --> CNIGo
CNIGo --> ContainerRuntimeGo
K8sDeploymentYaml --> SensorGo
Dockerfile --> SensorGo
E2ETestGo --> HTTPHandlersGo
E2ESuiteTestGo --> E2ETestGo
KindTestGo --> HTTPHandlersGo

@enduml