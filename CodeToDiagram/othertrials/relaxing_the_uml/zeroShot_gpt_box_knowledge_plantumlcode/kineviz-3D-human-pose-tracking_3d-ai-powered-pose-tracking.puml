@startuml

title 3D Human Pose Tracking System: Control Flow and Data Interaction

actor WebcamClient1 as WC1
actor WebcamClient2 as WC2
actor ReceiverApplication as RA

node NodeJSServer {
    component "Express.js Server" as ExpressServer
    component "Socket.IO" as SocketIO
    component "PoseNet/MoveNet Models" as PoseModels
    component "Kineviz GraphXR" as GraphXR
}

package "External Webcams" {
    WC1 -> ExpressServer : Send 2D Pose Data
    WC2 -> ExpressServer : Send 2D Pose Data
}

ExpressServer -> PoseModels : Process 2D Poses
PoseModels -> ExpressServer : Return 3D Pose Estimation

ExpressServer -> SocketIO : Broadcast 3D Pose Data
SocketIO -> RA : Send 3D Pose Data

RA -> GraphXR : Visualize 3D Skeleton

note left of ExpressServer
    - Handles incoming data
    - Broadcasts 3D poses
end note

note right of PoseModels
    - Utilizes TensorFlow.js
    - Processes in real-time
end note

note bottom of GraphXR
    - Displays 3D Skeleton
    - Configured using skel.grove and skelly.graphxr
end note

@enduml