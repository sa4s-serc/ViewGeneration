@startuml
package "SocialGouv_archifiltre-docs" {
    component "Archifiltre Application" {
        package "File System Processing" {
            component "File Loading" as fileLoading
            component "Duplicate Detection" as duplicateDetection
            component "Metadata Snapshot" as metadataSnapshot
            component "Virtual File System" as vfs
        }
        
        package "Data Export" {
            component "CSV Export" as csvExport
            component "Excel Export" as excelExport
            component "RESIP Export" as resipExport
            component "Audit Report Generation" as auditReport
        }
        
        package "State Management" {
            component "Redux" as redux
            component "Zustand (planned)" as zustand
        }
        
        package "Asynchronous Processing" {
            component "Async Worker" as asyncWorker
            component "Node.js Child Processes" as nodeChildProcesses
        }
        
        package "Tracking and Monitoring" {
            component "Sentry" as sentry
            component "Matomo" as matomo
            component "Posthog (planned)" as posthog
        }
        
        package "User Configuration" {
            component "Configuration Settings" as configSettings
        }
        
        package "Internationalization" {
            component "i18next" as i18next
        }
        
        package "Automated Updates" {
            component "electron-updater" as electronUpdater
        }
        
        package "CI/CD" {
            component "GitHub Actions" as githubActions
        }
        
        package "Installer Customization" {
            component "NSIS" as nsis
        }
    }
    
    [fileLoading] --> [vfs] : loads into
    [duplicateDetection] --> [vfs] : checks with
    [metadataSnapshot] --> [vfs] : stores in
    [vfs] --> [csvExport] : exports data to
    [vfs] --> [excelExport] : exports data to
    [vfs] --> [resipExport] : exports data to
    [vfs] --> [auditReport] : generates
    [asyncWorker] --> [nodeChildProcesses] : uses
    [redux] --> [zustand] : migrates to
    [sentry] --> [matomo] : logs with
    [matomo] --> [posthog] : migrates to
    [configSettings] --> [electronUpdater] : updates through
    [githubActions] --> [nsis] : customizes with
    [i18next] --> [vfs] : supports i18n
}
@enduml