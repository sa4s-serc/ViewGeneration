@startuml
package "veinmind-tools" {
    [veinmind-runner] <<container>> 
    [libveinmind] <<sub-system>>

    package "Plugins" {
        [Malicious File Detection] <<container>>
        [Weak Password Identification] <<container>>
        [Unsafe Mount Detection] <<container>>
        [CVE Vulnerability Detection] <<container>>
        [Intrusion Trace Detection] <<container>>
        [Sensitive Info Detection] <<container>>
        [Git Repository Cloning] <<container>>
    }
    
    package "Configuration" {
        [TOML Config Files] <<sub-system>>
    }
    
    package "Build System" {
        [Multi-Stage Docker Build] <<sub-system>>
        [CI/CD Pipeline] <<sub-system>>
    }
}

[veinmind-runner] --> [Plugins]
[veinmind-runner] --> [Configuration]
[Plugins] --> [libveinmind]
[libveinmind] --> [veinmind-runner]
[Build System] --> [veinmind-runner]
[Build System] --> [Plugins]
[Build System] --> [Configuration]
@enduml