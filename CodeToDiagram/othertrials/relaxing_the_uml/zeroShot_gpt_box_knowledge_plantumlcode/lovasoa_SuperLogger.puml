@startuml
package "System Monitoring with ELK Stack" {

  component "Java Agent" <<Server>> #lightblue {
    note right: Collects System Info\n(Implemented in Java)
  }
  
  component "Logstash" <<Server>> #lightgreen {
    note right: Processes & Enriches Data\n(Receives TCP data, adds timestamps)
  }
  
  component "Elasticsearch" <<Server>> #lightyellow {
    note right: Stores & Indexes Data\n(Data Storage Engine)
  }
  
  component "Kibana" <<Server>> #lightcoral {
    note right: Visualizes Data\n(Creates Dashboards)
  }

  [Java Agent] -> [Logstash] : TCP Communication
  [Logstash] -> [Elasticsearch] : Enriched Data
  [Elasticsearch] -> [Kibana] : Indexed Data
  
}
@enduml