@startuml

package "Frontend (React)" {
    [User Input Interface]
}

package "Backend (FastAPI)" {
    [API Gateway] --> [Lyrics Retrieval]
    [Lyrics Retrieval] --> [Lyrics Preprocessing]
    [Lyrics Preprocessing] --> [Sentiment Classification]
    [Lyrics Preprocessing] --> [Similar Songs Query]
    [Sentiment Classification] --> [Lyrics Storage]
    [Similar Songs Query] --> [Cosine Similarity Calculation]
    [Cosine Similarity Calculation] --> [Recommendation Results]
}

package "Elasticsearch" {
    [Lyrics Storage] --> [Song Lyrics Index]
    [Song Lyrics Index] <--> [Similar Songs Query]
}

package "CNN Model" {
    [Sentiment Classification] --> [Mood Classification]
}

package "LyricsGenius API" {
    [Lyrics Retrieval] --> [Lyrics API Call]
}

package "Data Exploration" {
    [Preprocessing Steps] --> [Dataset Exploration]
}

rectangle Docker {
    [Frontend Container]
    [Backend Container]
    [Elasticsearch Container]
}

[Frontend Container] --> [User Input Interface]
[Backend Container] --> [API Gateway]
[Backend Container] --> [Lyrics Retrieval]
[Backend Container] --> [Lyrics Preprocessing]
[Backend Container] --> [Sentiment Classification]
[Backend Container] --> [Similar Songs Query]
[Backend Container] --> [Cosine Similarity Calculation]
[Elasticsearch Container] --> [Song Lyrics Index]

[User Input Interface] --> [API Gateway] : API Call
[Recommendation Results] --> [User Input Interface] : Recommendations

@enduml