@startuml
title 2WAY_Design Architecture

package "2WAY_Design" {
    
    /' Sub-systems '/
    package "Trust Network" {
        component "Trust Management" as TM
        component "Authorization & Authentication" as AA
    }

    /' APIs '/
    component "Data Exchange API" as DE_API
    component "Privacy API" as P_API

    /' Databases '/
    database "Trust DB" as TrustDB
    database "Private Data DB" as PrivateDB

    /' External Systems '/
    actor "Trusted Parties" as TP
    actor "Identifi Project" as Identifi

    /' Connectors and Interactions '/
    TP --|> TM : establish trust
    TP --|> AA : authenticate & authorize

    DE_API --> TrustDB : fetch trust data
    DE_API --> P_API : invoke privacy techniques
    P_API --> PrivateDB : access private data

    TM <--> TrustDB : manage trust records
    AA <--> TrustDB : manage authentication records

    Identifi --> DE_API : foundation concepts

    /' Quality Attributes '/
    note right of DE_API
        - Maintainability
        - Security
    end note
}

@enduml