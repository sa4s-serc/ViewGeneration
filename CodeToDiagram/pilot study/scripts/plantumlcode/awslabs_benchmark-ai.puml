title Benchmark AI Component Diagram

package "Fetcher Service" {
  [Fetcher Dispatcher] 
  [Download Manager] 
  [Kafka Service] 
  [HTTP Estimator] 
  [S3 Estimator] 

  [Fetcher Dispatcher] --> [Download Manager] : manages download tasks
  [Download Manager] --> [Kafka Service] : sends status messages
  [Fetcher Dispatcher] --> [HTTP Estimator] : estimates file sizes
  [Fetcher Dispatcher] --> [S3 Estimator] : estimates file sizes
}

node "Other Components" {
  [wait_for_job.sh] 
  [mock-fetcher-job] 
}

[Fetcher Dispatcher] ..> [wait_for_job.sh] : monitors
[Fetcher Dispatcher] ..> [mock-fetcher-job] : mocks fetching

