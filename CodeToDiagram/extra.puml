@startuml
  title Lyrics Sentiment Classification — Deployment & Control-Flow View
  skinparam backgroundColor #FFFFFF
  skinparam componentStyle rectangle
  skinparam shadowing false
  skinparam wrapWidth 200
  skinparam maxMessageSize 200
  skinparam ArrowColor #444444
  skinparam ArrowThickness 1
  skinparam defaultFontName Arial
  skinparam RectangleBorderColor #333333
  skinparam NodeBorderColor #333333
  skinparam DatabaseBorderColor #333333
  skinparam usecaseBorderColor #333333
  actor "User" as user #FFFFFF
  cloud "LyricsGenius API\n(external)" as genius #DDDDDD
  rectangle "Docker Host" as host #FFFFFF {
    node "Docker Engine" as docker #F5F5F5 {
      frame "Docker Bridge Network: app_network" as net #EEF7FF {
        node "frontend\n(service: react)" <<container>> as fe #CFE8FF {
          component "React UI\n(mood_classification)" as react #E7F2FF
        }
        node "backend\n(service: fastapi)" <<container>> as be #D6F5D6 {
          package "Service Layer" #E9FBE9 {
            component "FastAPI\n(REST API, routing)" as api #CFF5CF
          }
          package "ML Layer" #E9FBE9 {
            component "Preprocessing Pipeline\n(normalize, tokenize, stopwords)" as prep #DFFCDF
            component "CNN Model Service\n(TensorFlow/Keras)" as cnn #DFFCDF
            component "Similarity Engine\n(TF‑IDF + Cosine)" as sim #DFFCDF
          }
          package "Config & Artifacts" #FFFBEA {
            folder "Model Variables\nbackend/fastapi/cnn/cnn_model_v3/\nvariables/variables.index" as modelvars #FFF2CC
          }
        }
        node "elasticsearch\n(service: elasticsearch)" <<container>> as es #FFE6CC {
          database "Lyrics Index\n(docs: song, artist, lyrics, mood, vectors)" as indexdb #FFEFD6
        }
        node "kibana\n(service: kibana)" <<container>> as kib #FFF0F5 {
          component "Kibana UI\n(dashboard, query, inspect)" as kibui #FFF7FB
        }
        node "data_exploration\n(service: jupyter)" <<container>> as de #EDE7FF {
          component "Jupyter Notebooks\n(data exploration, training)" as nb #F2EFFF
        }
        node "es_tools\n(service: es-tools)" <<container>> as estools #F6F0C0 {
          artifact "create_load_save_es_index.py\n(index create/load/save)" as script #FFF7CC
          folder "Datasets\n(CSV/JSON dumps)" as ds #FFF7CC
        }
      }
      ' Persistent volumes
      database "ES Data Volume" as esvol #EEEEEE
      folder "Backend Model Volume" as bevol #EEEEEE
    }
  }
  '========================
  ' Deployment dependencies (docker-compose)
  '========================
  fe ..> be : depends_on
  be ..> es : depends_on
  kib ..> es : depends_on
  estools ..> es : depends_on
  ' Volume mounts
  esvol .. es : persists index data
  bevol .. modelvars : mounted model variables
  '========================
  ' Control flow (runtime)
  '========================
  user -down-> react : enter song & artist\nview results
  react -down-> api : HTTP REST requests\n(search, classify, recommend)
  api -down-> es : search lyrics/mood\n(index read)
  api -right-> genius : fetch lyrics\n(if cache miss)
  api -down-> prep : preprocess lyrics\n(clean, tokenize, remove stopwords)
  prep -down-> cnn : vectorize and predict\n(mood classification)
  cnn -left-> modelvars : load weights/embeddings
  api -down-> sim : compute TF‑IDF vectors\ncosine similarity
  sim -down-> es : query similar songs\n(vector/text search)
  es -down-> api : return matches
  api -up-> react : results + recommendations
  kibui -left-> es : visualize index\nand query logs
  nb -down-> es : explore/query data\n(optional writes)
  script -down-> es : create index, load data\n(save to JSON via elasticdump)
  script -left-> ds : read source data
  '========================
  ' Technology notes
  '========================
  note right of api
  FastAPI (Python)
  • Orchestrates preprocessing, CNN inference, similarity
  • Serves REST endpoints to React
  • Reads/writes Elasticsearch

  end note
  note bottom of es
  Elasticsearch
  • Stores lyrics, mood labels, vectors
  • Powers fast retrieval & similarity

  end note
  note right of cnn
  CNN (TensorFlow/Keras)
  • Embeddings-based convolutional model
  • Parameters loaded from variables.index

  end note
  note left of react
  React Frontend
  • Input forms, results, recommendations
  • Talks to FastAPI over HTTP

  end note
  note right of estools
  Index Management
  • create_load_save_es_index.py
  • Initializes mappings; bulk loads CSV/JSON
  • Exports via elasticdump

  end note
  @enduml