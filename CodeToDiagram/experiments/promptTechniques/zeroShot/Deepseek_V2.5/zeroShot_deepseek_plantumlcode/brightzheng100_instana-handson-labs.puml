```plantuml
@startuml brightzheng100_instana-handson-labs

skinparam monochrome true
skinparam shadowing false
skinparam nodesep 20
skinparam ranksep 20

!define K8s #FFD700
!define VM #87CEEB
!define Instana #FF6347
!define App #98FB98
!define Storage #D3D3D3

node "Kubernetes Cluster" as k8s_cluster {
    component "Instana Backend" as instana_backend #Instana
    component "Instana Agent" as instana_agent_k8s #Instana
    component "Robot Shop App" as robot_shop #App
}

node "Virtual Machines" as vms {
    component "Instana Agent" as instana_agent_vm #Instana
    component "Sample Application" as app_vm #App
}

cloud "Instana SaaS" as instana_saas {
    component "Instana Dashboard" as dashboard #Instana
}

database "Persistent Storage" as storage {
    component "PostgreSQL" as postgres #Storage
    component "Elasticsearch" as elastic #Storage
}

instana_backend -[dashed]-> instana_saas : "Data Sync"
instana_agent_k8s --> instana_backend : "Metrics"
instana_agent_vm --> instana_backend : "Metrics"
robot_shop --> instana_agent_k8s : "Monitoring"
app_vm --> instana_agent_vm : "Monitoring"
instana_backend --> storage : "Data Storage"

@enduml
```