Here's the PlantUML component diagram for the mxaviersmp_spotify-tracker system:

```plantuml
@startuml mxaviersmp_spotify-tracker

package "Spotify Tracker System" {
    [Spotify API] as spotify
    [User Browser] as browser

    component "FastAPI Application" as api {
        component "Authentication" as auth
        component "API Endpoints" as endpoints
        component "Data Processing" as processing
    }

    component "ETL Pipeline" as etl {
        component "Airflow Scheduler" as scheduler
        component "Data Extraction" as extraction
        component "Data Transformation" as transform
        component "Data Loading" as loading
    }

    component "Database" as db {
        component "PostgreSQL" as postgres
        component "Migrations" as migrations
    }

    component "Streamlit UI" as ui {
        component "Visualization" as viz
        component "User Interface" as interface
    }

    component "Deployment" as deploy {
        component "AWS Lambda" as lambda
        component "API Gateway" as gateway
    }

    component "CI/CD" as cicd {
        component "GitHub Actions" as actions
        component "Serverless Framework" as serverless
    }

    spotify --> extraction : Fetch data
    browser --> api : HTTP requests
    api --> db : CRUD operations
    etl --> db : Load data
    ui --> api : API calls
    api --> deploy : Hosted on
    deploy --> gateway : Exposed via
    cicd --> deploy : Manages
    cicd --> db : Migrates
    actions --> serverless : Triggers
}

@enduml
```