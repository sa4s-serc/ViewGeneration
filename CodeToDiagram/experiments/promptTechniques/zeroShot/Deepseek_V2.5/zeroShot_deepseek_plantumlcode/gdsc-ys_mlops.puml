```plantuml
@startuml gdsc-ys_mlops

actor "ML Developer" as dev
participant "Client Application" as client
participant "Nginx" as nginx
participant "MLflow Server" as mlflow
participant "MySQL" as mysql
participant "AWS S3" as s3

dev -> client: Start ML experiment
client -> mlflow: POST /api/2.0/mlflow/runs/create (via nginx)
nginx -> mlflow: Forward request
mlflow -> mysql: Store run metadata
mysql --> mlflow: Return success
mlflow --> nginx: Return run ID
nginx --> client: Return run ID

client -> mlflow: POST /api/2.0/mlflow/runs/log-parameter (via nginx)
nginx -> mlflow: Forward request
mlflow -> mysql: Store parameter
mysql --> mlflow: Return success
mlflow --> nginx: Return success
nginx --> client: Return success

client -> mlflow: POST /api/2.0/mlflow/runs/log-metric (via nginx)
nginx -> mlflow: Forward request
mlflow -> mysql: Store metric
mysql --> mlflow: Return success
mlflow --> nginx: Return success
nginx --> client: Return success

client -> mlflow: POST /api/2.0/mlflow/runs/log-artifact (via nginx)
nginx -> mlflow: Forward request
mlflow -> s3: Upload artifact
s3 --> mlflow: Return success
mlflow --> nginx: Return success
nginx --> client: Return success

dev -> client: Register model
client -> mlflow: POST /api/2.0/mlflow/model-versions/create (via nginx)
nginx -> mlflow: Forward request
mlflow -> mysql: Store model version
mysql --> mlflow: Return success
mlflow --> nginx: Return model URI
nginx --> client: Return model URI

@enduml
```