```plantuml
@startuml googleinterns_typescript-flag-upgrade

package "TypeScript Flag Upgrade Tool" {
    [CLI] as cli
    [Runner] as runner
    [Parser] as parser
    [ErrorDetector] as errorDetector
    [Manipulators] as manipulators
    [Emitter] as emitter
    [Logger] as logger
    [Types] as types
    [Utils] as utils

    cli --> runner : "initiates"
    runner --> parser : "uses"
    runner --> errorDetector : "uses"
    runner --> manipulators : "uses"
    runner --> emitter : "uses"
    runner --> logger : "uses"
    runner --> types : "references"
    parser --> types : "references"
    errorDetector --> types : "references"
    manipulators --> types : "references"
    emitter --> types : "references"
    logger --> types : "references"
    utils --> types : "references"

    package "Manipulators" {
        [NoImplicitReturnsManipulator] as noImplicitReturns
        [StrictNullChecksManipulator] as strictNullChecks
        [StrictPropertyInitializationManipulator] as strictPropertyInit
        [NoImplicitAnyManipulator] as noImplicitAny
    }

    manipulators --> noImplicitReturns
    manipulators --> strictNullChecks
    manipulators --> strictPropertyInit
    manipulators --> noImplicitAny

    package "ErrorDetectors" {
        [ProdErrorDetector] as prodErrorDetector
        [TestErrorDetector] as testErrorDetector
    }

    errorDetector --> prodErrorDetector
    errorDetector --> testErrorDetector

    package "Emitters" {
        [InPlaceEmitter] as inPlaceEmitter
        [OutOfPlaceEmitter] as outOfPlaceEmitter
    }

    emitter --> inPlaceEmitter
    emitter --> outOfPlaceEmitter

    package "Loggers" {
        [ConsoleLogger] as consoleLogger
        [StubLogger] as stubLogger
    }

    logger --> consoleLogger
    logger --> stubLogger
}

@enduml
```