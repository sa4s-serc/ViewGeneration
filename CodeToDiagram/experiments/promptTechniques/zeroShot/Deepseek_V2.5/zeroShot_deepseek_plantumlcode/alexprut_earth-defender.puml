```plantuml
@startuml alexprut_earth-defender

package "Client Side" {
    [Game] as ClientGame
    [GameClient] as ClientGameClient
    [GameDOMHandler] as ClientDOM
    [GameElements] as ClientElements
    [TextureLoader] as ClientTextures
    [Three.js] as ThreeJS

    ClientGame --> ThreeJS
    ClientGame --> ClientGameClient
    ClientGame --> ClientDOM
    ClientGame --> ClientElements
    ClientElements --> ClientTextures
    ClientElements --> ThreeJS
}

package "Server Side" {
    [websocket_handler] as ServerWS
    [player] as ServerPlayer
    [room] as ServerRoom
    [local_rooms_state] as ServerRoomsState
    [earth_defender_sup] as ServerSupervisor
    [monitor_mesh] as ServerMonitor
    [Cowboy] as Cowboy

    ServerWS --> Cowboy
    ServerWS --> ServerPlayer
    ServerWS --> ServerRoom
    ServerRoom --> ServerRoomsState
    ServerSupervisor --> ServerWS
    ServerSupervisor --> ServerMonitor
    ServerSupervisor --> ServerRoom
}

ClientGameClient --[WebSocket]--> ServerWS

note right of ServerSupervisor
    Erlang/OTP supervision tree
    provides fault tolerance
end note

note bottom of ClientGame
    Three.js handles 3D rendering
    and client-side game logic
end note

@enduml
```