```plantuml
@startuml Scientific-Computing-Lab-NRCN_compar

package "ComPar System" {
    [GUI Framework] as gui
    [Compiler Abstraction] as compiler
    [Parallelization Tools] as parallel
    [Compilation Parameter Generator] as params
    [Code Instrumentation] as instrument
    [Runtime Analysis] as runtime
    [Slurm Job Management] as slurm
    [Output Validation] as validation
    [Database (MongoDB)] as db
}

package "CodeMirror Integration" {
    [CodeMirror Editor] as editor
    [Syntax Highlighting] as syntax
    [Code Completion] as completion
    [Linting] as linting
}

gui --> compiler : "compiler selection"
gui --> parallel : "parallelizer selection"
gui --> editor : "embeds"
gui --> params : "parameter configuration"
gui --> slurm : "job submission"

compiler --> parallel : "source-to-source\nparallelization"
compiler --> instrument : "code instrumentation"
compiler --> params : "uses parameters"

parallel --> compiler : "generates parallel code"
params --> compiler : "provides flag combinations"

instrument --> runtime : "provides timing data"
runtime --> slurm : "executes benchmarks"
runtime --> db : "stores results"

slurm --> validation : "validates output"
validation --> db : "stores validation results"

editor --> syntax : "applies language modes"
editor --> completion : "shows hints"
editor --> linting : "error checking"

@enduml
```