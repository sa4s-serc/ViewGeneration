```plantuml
@startuml llvm_torch-mlir

package "Torch-MLIR System" {
    [PyTorch Frontend] as pytorch
    [TorchScript Importer] as torchscript
    [FX Graph Importer] as fx
    [LTC (Lazy Tensor Core)] as ltc

    package "MLIR Dialects" {
        [Torch Dialect] as torch_dialect
        [TMTensor Dialect] as tmtensor
        [TorchConversion Dialect] as torch_conv
        [Linalg Dialect] as linalg
        [TOSA Dialect] as tosa
        [StableHLO Dialect] as stablehlo
    }

    [Shape/Dtype Inference] as shape_infer
    [Backend Contract] as backend_contract
    [Pass Manager] as pass_mgr

    package "Backend Targets" {
        [Linalg-on-Tensors] as linalg_backend
        [TOSA Backend] as tosa_backend
        [StableHLO Backend] as stablehlo_backend
        [ONNX Importer] as onnx
    }

    [E2E Testing] as e2e
    [RefBackend] as ref_backend
}

pytorch --> torchscript
pytorch --> fx
pytorch --> ltc

torchscript --> torch_dialect
fx --> torch_dialect
ltc --> torch_dialect

torch_dialect --> shape_infer
shape_infer --> backend_contract
backend_contract --> pass_mgr

pass_mgr --> torch_conv
torch_conv --> tmtensor
tmtensor --> linalg
tmtensor --> tosa
tmtensor --> stablehlo

linalg --> linalg_backend
tosa --> tosa_backend
stablehlo --> stablehlo_backend
onnx --> torch_dialect

linalg_backend --> e2e
tosa_backend --> e2e
stablehlo_backend --> e2e
e2e --> ref_backend

@enduml
