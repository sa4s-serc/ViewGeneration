Here's the PlantUML component diagram focusing on data flow for the `serverdevcamp_camp4_quadcore` system:

```plantuml
@startuml serverdevcamp_camp4_quadcore

skinparam componentStyle uml2
skinparam monochrome false

package "External Systems" {
    component "Twitter API" as twitterAPI #lightblue
}

package "Frontend" {
    component "React Frontend" as frontend #violet
    component "Infinite Scroll" as scroll #violet
    component "Column Views" as columns #violet
}

package "Gateway" {
    component "APIGateway" as apiGateway #pink {
        component "JWT Validator" as jwtValidator #pink
    }
}

package "Authentication" {
    component "AuthServer" as authServer #peach {
        component "JWT Filter" as jwtFilter #peach
    }
    component "AuthFront" as authFront #peach
    database "Redis" as redis #lightgray
}

package "Data Services" {
    component "DataPipeline" as dataPipeline #lightgreen
    queue "Kafka" as kafka #lightgray
    component "DataProcessing" as dataProcessing #lightgreen {
        component "Spark Analytics" as spark #lightgreen
    }
    component "DataSending" as dataSending #lightgreen {
        component "WebSocket" as websocket #lightgreen
    }
}

package "User Services" {
    component "UserActivity" as userActivity #lightgreen
}

package "Data Stores" {
    database "Cassandra" as cassandra #lightgray
}

' Data Flow Relationships
twitterAPI --> dataPipeline : "Streams tweets"
frontend --> apiGateway : "HTTP requests"
apiGateway --> jwtValidator : "Validates tokens"
apiGateway --> authServer : "Auth requests"
apiGateway --> dataSending : "Data requests"
apiGateway --> userActivity : "Activity requests"

authServer --> redis : "Refresh tokens"
authServer --> cassandra : "User data"
authServer --> jwtFilter : "Auth validation"
authServer --> authFront : "Auth responses"
authFront --> frontend : "Auth UI"

dataPipeline --> kafka : "Raw tweets"
kafka --> dataProcessing : "Consumes"
dataProcessing --> spark : "Trend analysis"
spark --> cassandra : "Processed data"
dataSending --> cassandra : "Reads data"
dataSending --> websocket : "Real-time updates"
websocket --> frontend : "Push notifications"

userActivity --> cassandra : "Activity data"
userActivity --> frontend : "Activity updates"

scroll --> frontend : "UI component"
columns --> frontend : "UI component"

note right of dataPipeline
  Data flow from Twitter API through Kafka,
  processed by Spark, stored in Cassandra,
  and delivered via WebSocket
end note

@enduml
```

Key features shown:
1. Detailed data flow from Twitter API to frontend
2. Authentication flow with JWT validation
3. Real-time data pipeline with Kafka and WebSocket
4. Spark analytics component for trend analysis
5. Frontend components for infinite scroll and column views
6. Clear separation of services and data stores