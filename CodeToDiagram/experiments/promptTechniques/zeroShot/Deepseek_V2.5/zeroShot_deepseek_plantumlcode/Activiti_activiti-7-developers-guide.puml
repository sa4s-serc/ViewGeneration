```plantuml
@startuml Activiti_activiti-7-developers-guide

component "Kubernetes Cluster" as k8s {
    component "Activiti Cloud Runtime Bundle" as runtimeBundle {
        component "Activiti Core" as core
    }

    component "Activiti Cloud Connectors" as connectors

    component "Activiti Cloud Query Service" as queryService

    component "Activiti Cloud Audit Service" as auditService

    component "Activiti Cloud Notification Service" as notificationService

    component "Gateway" as gateway {
        component "Spring Cloud Gateway" as scg
    }

    component "Identity Management" as identity {
        component "Keycloak" as keycloak
    }

    component "BPMN Modeling Application" as modeler

    component "Jenkins X" as jenkinsx
}

cloud "External Systems" as external

runtimeBundle --> connectors : uses
runtimeBundle --> core : contains
runtimeBundle --> queryService : sends events
runtimeBundle --> auditService : sends events
runtimeBundle --> notificationService : sends events

gateway --> runtimeBundle : routes to
gateway --> queryService : routes to
gateway --> auditService : routes to
gateway --> notificationService : routes to

identity --> gateway : authenticates
identity --> runtimeBundle : authenticates

connectors --> external : integrates with

jenkinsx --> k8s : deploys to

modeler --> k8s : deploys to

@enduml
```