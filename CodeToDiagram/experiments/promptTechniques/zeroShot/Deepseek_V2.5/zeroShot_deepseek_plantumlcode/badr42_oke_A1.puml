```plantuml
@startuml badr42_oke_A1

!define OCI #FF7F00
!define K8S #326CE5
!define NET #4CAF50
!define APP #9C27B0

skinparam component {
    BackgroundColor<<OCI>> OCI
    BackgroundColor<<K8S>> K8S
    BackgroundColor<<NET>> NET
    BackgroundColor<<APP>> APP
    FontSize 14
    ArrowColor #666666
}

component "OKE Cluster" <<K8S>> {
    component "Control Plane" <<K8S>> as control_plane
    component "Worker Nodes" <<K8S>> as worker_nodes {
        component "Node Pool (A1.Flex)" <<K8S>> as node_pool
    }
}

component "Networking" <<NET>> {
    component "VCN" <<NET>> as vcn
    component "Subnets" <<NET>> as subnets {
        component "Worker Subnet" <<NET>> as worker_subnet
        component "LB Subnet" <<NET>> as lb_subnet
        component "API Subnet" <<NET>> as api_subnet
    }
    component "Internet Gateway" <<NET>> as igw
    component "NAT Gateway" <<NET>> as nat
    component "Service Gateway" <<NET>> as sgw
    component "Route Tables" <<NET>> as routes
    component "Security Lists" <<NET>> as sec_lists
}

component "Application" <<APP>> {
    component "Nginx Deployment" <<APP>> as nginx
    component "Load Balancer" <<APP>> as lb
}

component "Terraform" <<OCI>> as tf {
    component "main.tf" <<OCI>> as main
    component "variables.tf" <<OCI>> as vars
}

control_plane --> worker_nodes : manages
worker_nodes --> node_pool : contains
node_pool --> worker_subnet : uses
node_pool --> sec_lists : enforces

vcn --> subnets : contains
subnets --> worker_subnet
subnets --> lb_subnet
subnets --> api_subnet

igw --> routes : provides\ninternet access
nat --> routes : provides\nprivate access
sgw --> routes : provides\nservice access

nginx --> lb : exposed via
lb --> lb_subnet : uses

main --> vars : references
main --> vcn : provisions
main --> control_plane : provisions
main --> node_pool : provisions

@enduml
```