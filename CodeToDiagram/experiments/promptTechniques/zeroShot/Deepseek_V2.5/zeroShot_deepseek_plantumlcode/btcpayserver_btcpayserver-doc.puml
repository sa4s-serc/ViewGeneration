```plantuml
@startuml btcpayserver_btcpayserver-doc

skinparam componentStyle uml2
skinparam monochrome true
skinparam nodesep 10
skinparam ranksep 20

package "BTCPay Server Documentation System" {
    [VuePress] as vuepress
    [Documentation Content] as content
    [Theme System] as theme
    [Build System] as build
    [Deployment Scripts] as deploy

    component "GitHub Pages" as githubpages #lightgray
    component "Docker Container" as docker #lightgray
    component "Manual Server" as manual #lightgray
}

vuepress --> content : Renders
vuepress --> theme : Uses
theme --> content : Styles
build --> content : Processes
build --> vuepress : Builds
deploy --> build : Executes after

githubpages <-- deploy : Deploys to
docker <-- deploy : Creates image for
manual <-- deploy : Configures for

note right of vuepress
Built with VuePress static site generator
Supports Markdown content
end note

note left of deploy
Includes:
- btcpay-setup.sh
- btcpayserver-rpi4-install.sh
- GitHub Actions workflows
end note

@enduml
```