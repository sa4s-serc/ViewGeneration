```plantuml
@startuml zeropaper_visual-fiha

package "VS Code Extension" {
    [VFExtension] as VFExtension
    [WebServer] as WebServer
    [Redux Store] as ReduxStore
    [Commands] as Commands
}

package "WebViews" {
    [AudioView] as AudioView
    [ControlView] as ControlView
    [DisplaysView] as DisplaysView
    [TimelineView] as TimelineView
}

package "Display Workers" {
    [DisplayWorker] as DisplayWorker
    [ScriptRunner] as ScriptRunner
    [Scriptable] as Scriptable
}

package "Layers" {
    [Canvas2DLayer] as Canvas2DLayer
    [ThreeJSLayer] as ThreeJSLayer
}

package "Capture" {
    [AudioCapture] as AudioCapture
    [MIDICapture] as MIDICapture
}

package "Utils" {
    [Com] as Com
    [MathTools] as MathTools
    [MiscTools] as MiscTools
}

VFExtension --> WebServer : manages
VFExtension --> ReduxStore : updates
VFExtension --> Commands : executes
VFExtension --> WebViews : controls

WebServer --> DisplayWorker : serves
WebServer --> Capture : serves
WebServer --> Com : uses

DisplayWorker --> ScriptRunner : executes
DisplayWorker --> Scriptable : manages
DisplayWorker --> Layers : renders

Canvas2DLayer --> MathTools : uses
ThreeJSLayer --> MathTools : uses

AudioView --> AudioCapture : interacts
ControlView --> MIDICapture : interacts

Com --> WebViews : notifies
Com --> DisplayWorker : communicates
Com --> Capture : communicates

ReduxStore --> WebViews : provides state
ReduxStore --> DisplayWorker : provides state

@enduml
```