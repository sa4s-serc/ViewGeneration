```plantuml
@startuml linhao1998_ChatGPTClient

package "ChatGPTClient" {
    [Chat Interface] as ChatUI
    [Settings] as SettingsUI
    [ChatViewModel] as ChatVM
    [ChatListViewModel] as ChatListVM
    [MsgListViewModel] as MsgListVM
    [Repository] as Repo
    [ChatDao] as ChatDAO
    [MsgDao] as MsgDAO
    [AppDatabase] as Database
    [OpenAI API] as OpenAI

    ChatUI --> ChatVM
    ChatUI --> MsgListVM
    SettingsUI --> ChatListVM
    ChatVM --> Repo
    ChatListVM --> Repo
    MsgListVM --> Repo
    Repo --> ChatDAO
    Repo --> MsgDAO
    Repo --> OpenAI
    ChatDAO --> Database
    MsgDAO --> Database

    note right of ChatUI: Handles user input\nand displays responses
    note right of SettingsUI: Manages app\nconfigurations
    note right of ChatVM: Manages chat\nsession state
    note right of Repo: Abstracts data access\nfrom ViewModels
    note right of Database: Room database for\nlocal storage
}

@enduml
```