```plantuml
@startuml zoolhelmy_ESP8266-Weather-Station

actor User
participant "ESP8266 NodeMCU" as ESP
participant "OpenWRT Router" as Router
participant "ThingSpeak IoT" as ThingSpeak
participant "GitHub Repo" as GitHub

group Sensor Data Collection & Publishing
    ESP -> ESP : Read sensors (temp, humidity, etc.)
    ESP -> ThingSpeak : Publish data via MQTT
    ESP -> Router : Publish data via MQTT
end

group Local Data Processing
    Router -> Router : mosquitto-subscribe.sh\n(saves to temp files)
    Router -> Router : collectd-rrdtool-publish.sh\n(updates RRD database)
end

group Web Interface
    User -> ESP : HTTP request\n(local web server)
    ESP -> User : Return current sensor readings
end

group Automated Graph Generation
    Router -> Router : rrdtool-graph-github.sh\n(daily cron job)
    Router -> GitHub : Commit & push generated graphs
end

@enduml
```