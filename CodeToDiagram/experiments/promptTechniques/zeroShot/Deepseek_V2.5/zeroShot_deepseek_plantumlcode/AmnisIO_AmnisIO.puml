```plantuml
@startuml AmnisIO_AmnisIO

package "AmnisIO" {
    [AmnisIO CLI] as CLI
    [TypeScript Code] as TSCode
    [typewriter Transpiler] as Typewriter
    [PlatformIO] as PlatformIO
    [rivulet Stream Library] as Rivulet
    [gyrus Board Abstraction] as Gyrus
    [Configuration Files] as Configs
}

[Arduino UNO] as Arduino

CLI --> TSCode : "manages"
CLI --> Typewriter : "invokes"
CLI --> PlatformIO : "invokes"
TSCode --> Typewriter : "transpiles to"
Typewriter --> Rivulet : "generates C using"
Typewriter --> Gyrus : "generates C using"
PlatformIO --> Arduino : "deploys to"
Gyrus --> Arduino : "abstracts"
Configs --> CLI : "configures"
Configs --> Typewriter : "configures"
Configs --> Gyrus : "configures"

@enduml
```