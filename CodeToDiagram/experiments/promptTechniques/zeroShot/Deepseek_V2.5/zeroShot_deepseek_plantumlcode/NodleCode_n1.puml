```plantuml
@startuml NodleCode_n1_Deployment_Diagram

skinparam componentStyle uml2
skinparam monochrome true
skinparam shadowing false

node "Device Tier" {
  component "Dialog DA14531 Dev Kit" as device {
    component "iBeacon Firmware" as firmware
    component "SPI Flash Memory" as flash
  }
}

node "Application Tier" {
  component "Nodle Mobile App" as mobile {
    component "Beacon Detector" as detector
    component "Data Relay" as relay
  }
}

node "Data Tier" {
  component "Nodle Cloud" as cloud {
    component "API Gateway" as api
    component "Beacon Database" as db
  }
}

device --> mobile : BLE Advertising
mobile --> cloud : HTTPS API Calls
flash --> firmware : Reads config
firmware --> device : Controls hardware
detector --> relay : Passes beacon data
relay --> api : Sends beacon info
api --> db : Stores/retrieves data

@enduml
```