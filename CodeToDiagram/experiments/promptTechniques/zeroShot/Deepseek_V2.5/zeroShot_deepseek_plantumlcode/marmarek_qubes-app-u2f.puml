```plantuml
@startuml marmarek_qubes-app-u2f

package "Browser VM" {
    component "Browser" as browser
    component "CTAP HID Emulator" as hid_emu {
        component "CTAPHIDDevice" as hid_device
        component "HID Packet Handler" as hid_packet
    }
    component "Qrexec Client" as qrexec_client
}

package "sys-usb VM" {
    component "Qrexec Server" as qrexec_server
    component "CTAP Proxy" as ctap_proxy {
        component "CTAP1/U2F Handler" as ctap1
        component "CTAP2 Handler" as ctap2
        component "Policy Engine" as policy
    }
    component "USB HID Device" as usb_hid
}

database "Policy Files" as policies {
    component "/etc/qubes/policy.d/*" as qubes_policy
    component "/etc/udev/rules.d/*" as udev_rules
}

browser --> hid_emu : "HID emulation"
hid_emu --> qrexec_client : "Secure CTAP requests"
qrexec_client --> qrexec_server : "qrexec IPC"
qrexec_server --> ctap_proxy : "Process requests"
ctap_proxy --> usb_hid : "USB communication"

ctap_proxy --> policies : "Reads"
policies --> ctap_proxy : "Enforces"

hid_device <|-- hid_packet
ctap_proxy <|-- ctap1
ctap_proxy <|-- ctap2
ctap_proxy <|-- policy

note top of browser
    Runs in isolated Qubes domain
    No direct USB access
end note

note top of usb_hid
    Physical security token
    Only accessible in sys-usb VM
end note

note right of policies
    Security policies control:
    - Which VMs can access token
    - Device permissions
    - Protocol versions allowed
end note

@enduml
```