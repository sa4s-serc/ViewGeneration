```plantuml
@startuml mbotarro_unijobs

package "Frontend (React Native)" {
    [App.js] as App
    [AppNavigator] as Navigator
    [FeedNavigator] as FeedNav
    [LoginScreen] as Login
    [RegisterScreen] as Register
    [FeedScreen] as Feed
    [ProfileScreen] as Profile
    [OfferRequestCreation] as Creation
    [FeedCard] as Card
    [Button] as Button
    [UniStyles] as Styles
    [UniText] as Text
    [UniColors] as Colors
    [UniData] as Data
    [LoginActions] as LoginActions
    [FeedActions] as FeedActions
}

package "Backend (Go)" {
    [main.go] as Main
    [migrations] as Migrations
    [UserHandler] as UserHandler
    [OfferHandler] as OfferHandler
    [RequestHandler] as RequestHandler
    [CategoryHandler] as CategoryHandler
    [UserCases] as UserCases
    [OfferCases] as OfferCases
    [RequestCases] as RequestCases
    [CategoryCases] as CategoryCases
    [UserDAL] as UserDAL
    [OfferDAL] as OfferDAL
    [RequestDAL] as RequestDAL
    [CategoryDAL] as CategoryDAL
    [UserModel] as UserModel
    [OfferModel] as OfferModel
    [RequestModel] as RequestModel
    [CategoryModel] as CategoryModel
    [Elasticsearch] as Elastic
}

database "PostgreSQL" as Postgres
database "Elasticsearch" as ES

' Frontend connections
App --> Navigator
Navigator --> FeedNav
FeedNav --> Login
FeedNav --> Register
FeedNav --> Feed
FeedNav --> Profile
FeedNav --> Creation
Feed --> Card
Creation --> Button
Login --> LoginActions
Feed --> FeedActions
Login --> Styles
Login --> Text
Login --> Colors
Login --> Data

' Backend connections
Main --> Migrations
Main --> UserHandler
Main --> OfferHandler
Main --> RequestHandler
Main --> CategoryHandler
UserHandler --> UserCases
OfferHandler --> OfferCases
RequestHandler --> RequestCases
CategoryHandler --> CategoryCases
UserCases --> UserDAL
OfferCases --> OfferDAL
RequestCases --> RequestDAL
CategoryCases --> CategoryDAL
UserDAL --> UserModel
OfferDAL --> OfferModel
RequestDAL --> RequestModel
CategoryDAL --> CategoryModel
UserDAL --> Postgres
OfferDAL --> Postgres
RequestDAL --> Postgres
CategoryDAL --> Postgres
OfferCases --> Elastic
RequestCases --> Elastic

' External connections
Elastic --> ES
Main --> Postgres

' Frontend-Backend communication
LoginActions --> UserHandler
FeedActions --> OfferHandler
FeedActions --> RequestHandler

@enduml
```