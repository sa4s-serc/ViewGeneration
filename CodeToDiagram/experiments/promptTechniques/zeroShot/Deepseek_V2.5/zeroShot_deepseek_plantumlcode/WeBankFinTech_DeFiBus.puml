```plantuml
@startuml WeBankFinTech_DeFiBus

component "DeFiBrokerController" as brokerController {
    component "DeFiProducerManager"
    component "DeFiConsumerManager"
    component "ConsumeQueueManager"
    component "DeFiSendMessageProcessor"
    component "DeFiReplyMessageProcessor"
    component "DeFiAdminBrokerProcessor"
    component "DeFiPullMessageProcessor"
    component "DeFiTopicConfigManager"
    component "DeFiBusBroker2Client"
}

component "Apache RocketMQ Core" as rocketmq {
    component "BrokerController"
    component "MessageStore"
}

component "DeFiPluginMessageStore" as pluginStore {
    component "Cluster/Broker Info"
    component "Offset Management"
    component "Stats Collection"
}

component "Supporting Components" as support {
    component "QueueListeningMonitor"
    component "AdjustQueueNumStrategy"
    component "MessageRedirectManager"
    component "ClientRebalanceResultManager"
}

component "External Clients" as clients {
    component "Producers"
    component "Consumers"
}

brokerController --> rocketmq : extends
pluginStore --> rocketmq : decorates\n(MessageStore)
brokerController --> pluginStore : uses

brokerController --> support : manages

clients --> brokerController : connect to
brokerController --> clients : push messages

DeFiSendMessageProcessor --> ConsumeQueueManager : checks\nqueue depth
DeFiConsumerManager --> AdjustQueueNumStrategy : applies\nqueue adjustment
DeFiPullMessageProcessor --> MessageRedirectManager : applies\nredirection rules
DeFiTopicConfigManager --> DeFiBusBroker2Client : notifies\nconfig changes

@enduml
```