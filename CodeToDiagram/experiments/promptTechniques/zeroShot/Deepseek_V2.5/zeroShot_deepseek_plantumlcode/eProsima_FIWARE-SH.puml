```plantuml
@startuml eProsima_FIWARE-SH

participant "Integration Service" as IS
participant "SystemHandle" as SH
participant "NGSIV2Connector" as Connector
participant "Listener" as Listener
participant "Publisher" as Publisher
participant "Subscriber" as Subscriber
participant "FIWARE Context Broker" as FIWARE

IS -> SH : initialize()
SH -> Connector : configure()
SH -> Listener : start()
SH -> Publisher : create()
SH -> Subscriber : create()

group Publish Data to FIWARE
    IS -> SH : publish(topic, data)
    SH -> Publisher : publish(data)
    Publisher -> Connector : convertToFiware(data)
    Connector -> FIWARE : POST /v2/entities (NGSIv2)
    FIWARE --> Connector : 201 Created
    Connector --> Publisher : success
    Publisher --> SH : success
    SH --> IS : success
end

group Subscribe to FIWARE Data
    IS -> SH : subscribe(topic)
    SH -> Subscriber : subscribe(topic)
    Subscriber -> Connector : registerSubscription(topic)
    Connector -> FIWARE : POST /v2/subscriptions (NGSIv2)
    FIWARE --> Connector : 201 Created
    Connector --> Subscriber : success
    Subscriber --> SH : success
    SH --> IS : success

    loop Notification Handling
        FIWARE -> Listener : HTTP POST (notification)
        Listener -> Connector : handleNotification(data)
        Connector -> Subscriber : convertToXTypes(data)
        Subscriber -> SH : onDataReceived(topic, data)
        SH -> IS : pushData(topic, data)
    end
end

@enduml
```