```plantuml
@startuml EMERIC237_Restaurant-reservation-app

skinparam monochrome true
skinparam defaultFontName Arial
skinparam componentStyle uml2

title Restaurant Reservation App - Deployment and Data Flow

node "Client Browser" {
  component "React Frontend" as frontend {
    [Dashboard]
    [Reservation Form]
    [Table Management]
  }
}

node "Server" {
  component "Node.js/Express" as backend {
    [API Router] as router
    [Reservations Controller]
    [Tables Controller]
    [Error Handler]
  }

  database "PostgreSQL" as db {
    [Reservations Table]
    [Tables Table]
  }
}

frontend -> router : HTTP Requests (REST API)
router -> "Reservations Controller" : /reservations
router -> "Tables Controller" : /tables
"Reservations Controller" -> db : CRUD Operations
"Tables Controller" -> db : CRUD Operations
db --> "Reservations Controller" : Data
db --> "Tables Controller" : Data
"Reservations Controller" --> router : JSON Response
"Tables Controller" --> router : JSON Response
router --> frontend : JSON Response

@enduml
```