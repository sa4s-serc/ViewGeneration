```plantuml
@startuml aliyun_packagist-mirror

package "aliyun_packagist-mirror" {
    [Main Application] as main
    [Packagist API Client] as packagist
    [GitHub API Client] as github
    [Alibaba Cloud OSS] as oss
    [Redis Cache] as redis
    [CDN Warm-up] as cdn
    [Status Monitor] as status

    main --> packagist : Syncs package metadata
    main --> github : Downloads distributions
    main --> oss : Stores packages/metadata
    main --> redis : Caches sync status/queues
    main --> cdn : Triggers CDN warm-up
    main --> status : Generates status.json

    package "Synchronization Workers" {
        [Provider Sync] as provider
        [Package V1 Sync] as pkgv1
        [Package V2 Sync] as pkgv2
        [Distribution Sync] as dist
        [Composer.phar Sync] as composer

        provider --> redis : Uses queues
        pkgv1 --> redis : Uses queues
        pkgv2 --> redis : Uses queues
        dist --> redis : Uses queues
        composer --> redis : Uses queues
    }

    main --> SynchronizationWorkers : Manages workers
}

[Packagist.org] as upstream
[GitHub] as github_source
[Alibaba Cloud CDN] as aliyun_cdn

upstream --> packagist : Provides metadata
github_source --> github : Provides packages
oss --> aliyun_cdn : Serves cached content

@enduml
```