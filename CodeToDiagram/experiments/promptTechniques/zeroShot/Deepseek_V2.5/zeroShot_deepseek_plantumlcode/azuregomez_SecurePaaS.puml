```plantuml
@startuml azuregomez_SecurePaaS

skinparam monochrome true
skinparam componentStyle uml2

component "Client" as client #white

rectangle "Azure Cloud" {
    component "Web Application Firewall (WAF)" as waf #lightgrey
    component "Azure App Service" as appService #lightgrey
    component "Azure Firewall" as firewall #lightgrey
    component "Azure SQL Database" as sqlDb #lightgrey
    component "Private Endpoint" as privateEndpoint #lightgrey
    component "Key Vault" as keyVault #lightgrey
    component "Virtual Network" as vnet #lightgrey {
        component "App Service Subnet" as appSubnet #white
        component "Firewall Subnet" as fwSubnet #white
    }
}

client --> waf : HTTPS (443)
waf --> appService : Secure traffic
appService --> keyVault : Get secrets
appService -[hidden]-> firewall
firewall --> sqlDb : Inspected traffic\n(Private Link)
appService --> privateEndpoint : Private connection
privateEndpoint --> sqlDb : Secure access

note top of appService
    Injected into VNet
    Uses UDRs for firewall routing
end note

note right of sqlDb
    No public endpoints
    Private Link only
end note

note left of keyVault
    Secure secret management
    Connection strings, keys
end note

@enduml
```