```plantuml
@startuml dich1_bookshelf-web

component "Web Browser" as browser {
    [HTML/JS Frontend]
}

component "Nginx" as nginx {
    [Reverse Proxy]
    [Static Files]
}

component "Rails Application" as rails {
    [Controllers]
    [Models]
    [Views]
}

component "Database" as db {
    [MySQL]
}

component "External Services" as external {
    [Google Books API]
    [Facebook OAuth]
}

browser --> nginx : HTTP/HTTPS
nginx --> rails : HTTP/HTTPS
rails --> db : SQL
rails --> external : API calls

@enduml
