```plantuml
@startuml rinkako_CStoreDBMS

package "DBInterface Layer" {
    [DBController] as DBController
    [DBConnectionPool] as DBConnectionPool
}

package "DBCompiler Layer" {
    [LexicalAnalyzer] as LexicalAnalyzer
    [SyntaxParser] as SyntaxParser
    [Pile] as Pile
    [CSDatabase] as CSDatabase
    [DBBridge] as DBBridge
}

package "DBEngine Layer" {
    [FileManager] as FileManager
    [TableManager] as TableManager
    [DBAllocator] as DBAllocator
    [DBLock] as DBLock
    [DBTransaction] as DBTransaction
}

package "Utilities" {
    [DBCommonUtils] as DBCommonUtils
    [DBObject] as DBObject
}

DBController --> DBConnectionPool
DBConnectionPool --> DBBridge
DBBridge --> CSDatabase
DBBridge --> LexicalAnalyzer
DBBridge --> SyntaxParser
DBBridge --> Pile

CSDatabase --> FileManager
CSDatabase --> TableManager
CSDatabase --> DBAllocator
CSDatabase --> DBLock
CSDatabase --> DBTransaction

LexicalAnalyzer --> SyntaxParser
SyntaxParser --> Pile
Pile --> CSDatabase

FileManager --> DBAllocator
TableManager --> DBLock
TableManager --> DBTransaction
TableManager --> FileManager

DBObject <|-- DBTransaction
DBObject <|-- DBLock
DBObject <|-- TableManager
DBCommonUtils ..> FileManager
DBCommonUtils ..> TableManager

note top of CSDatabase: Core execution engine\nhandles intermediate code\nand database operations
note right of FileManager: Manages columnar storage,\nfile I/O, sorting, compression
note left of DBConnectionPool: Handles concurrent queries\nvia connection pool

@enduml
```