```plantuml
@startuml bluekiri_mlab

package "MLAB System" {
    component "Dashboard" as dashboard {
        component "Flask Application" as flask
        component "API Endpoints" as api
        component "Interactors" as interactors
        component "Repositories" as repos
        component "Frontend" as frontend
    }

    component "Worker Service" as worker {
        component "Model Loader" as loader
        component "ZooKeeper Client" as zk_client
        component "HTTP API" as http_api
        component "Error Handler" as error_handler
    }

    component "ZooKeeper" as zookeeper {
        component "Configuration" as config
        component "Service Registry" as registry
    }

    component "MongoDB" as mongodb {
        component "Model Metadata" as metadata
        component "Logs" as logs
        component "Messages" as messages
    }

    component "External Systems" as external {
        component "Email Service" as email
        component "LDAP" as ldap
    }
}

dashboard --> zookeeper : "Reads/Writes\nconfiguration"
dashboard --> mongodb : "Stores/retrieves\nmodel metadata"
dashboard --> external : "Sends emails\nAuthenticates users"

worker --> zookeeper : "Registers service\nListens for changes"
worker --> mongodb : "Loads models\nStores logs"
worker --> external : "Sends error alerts"

flask --> api : "Routes requests"
api --> interactors : "Executes use cases"
interactors --> repos : "Data access"
flask --> frontend : "Serves UI"

loader --> zk_client : "Checks model updates"
zk_client --> registry : "Service discovery"
http_api --> loader : "Gets current model"
error_handler --> email : "Sends alerts"

@enduml
```