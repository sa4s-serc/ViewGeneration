```plantuml
@startuml iceland2k14_Kangrand

component "Client" as client {
    component "Kangaroo" as kangaroo
    component "Network" as network
    component "HashTable" as hashtable
    component "Backup" as backup
    component "Thread" as thread
}

component "Server" as server {
    component "Network" as server_network
    component "WorkFileManager" as workfile
}

component "GPU" as gpu {
    component "GPUEngine" as gpuengine
}

component "SECP256K1" as secp {
    component "PointOps" as pointops
    component "IntArithmetic" as intmath
}

client --> server : "TCP/IP"
client --> gpu : "CUDA"
kangaroo --> secp : "Uses"
kangaroo --> gpuengine : "Launches kernels"
kangaroo --> hashtable : "Stores DPs"
kangaroo --> backup : "Saves/Loads work"
kangaroo --> thread : "Manages threads"
server_network --> workfile : "Manages workfiles"
secp --> pointops : "EC operations"
secp --> intmath : "Modular arithmetic"

@enduml
