```plantuml
@startuml heli-os_member-invitation-java-springboot

package "Member Invitation System" {
    [MemberInvitationApplication] as App
    [GlobalExceptionHandler] as ExceptionHandler
}

package "Interface Layer" {
    [InvitationRestController] as InvitationAPI
    [MemberRestController] as MemberAPI
    [InvitationDto\nMemberDto] as DTOs
    [InvitationMapper\nMemberMapper] as Mappers
}

package "Domain Layer" {
    interface "InvitationUseCase" as InvitationUC
    interface "MemberUseCase" as MemberUC
    [InvitationService] as InvitationService
    [MemberService] as MemberService
    [Member] as MemberDomain
    [Invitation] as InvitationDomain
}

package "Infrastructure Layer" {
    package "Database" {
        [MemberJpaRepository] as MemberRepo
        [MemberJpaEntity] as MemberEntity
    }
    
    package "Redis" {
        [InvitationRedisRepository] as InvitationRepo
    }
}

package "Commons" {
    [CommonModel] as Models
    [CommonUtil] as Utils
}

