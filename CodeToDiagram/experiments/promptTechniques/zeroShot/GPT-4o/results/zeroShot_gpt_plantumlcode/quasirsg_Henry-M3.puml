```plantuml
@startuml quasirsg_Henry-M3

actor User
participant "Custom $Promise Library" as Pledge
participant "Node.js Server" as NodeServer
participant "Express.js App" as ExpressApp
participant "Middleware" as Middleware
participant "Test Suite" as TestSuite

User -> NodeServer: Send HTTP Request
NodeServer -> ExpressApp: Route Request
ExpressApp -> Middleware: Process Middleware

alt Promise Handling
    ExpressApp -> Pledge: Create Promise
    Pledge -> Pledge: Handle State (Pending/Fulfilled/Rejected)
    Pledge -> ExpressApp: Resolve/Reject Promise
end

ExpressApp -> ExpressApp: Handle Route
ExpressApp -> User: Send HTTP Response

alt Testing Phase
    TestSuite -> Pledge: Test $Promise Implementation
    TestSuite -> NodeServer: Test Server Responses
    TestSuite -> ExpressApp: Test Express Routes
    TestSuite -> TestSuite: Validate Results
end

@enduml
```