```plantuml
@startuml alextanhongpin_node-rest

package "NodeJS REST API" {
    component "Express App" as Express {
        [Routing]
        [Middleware]
    }
    
    component "Food Service" as FoodService {
        [Route] --> [Model]
        [Model] --> [Store]
    }
    
    component "Store" as Store {
        [CRUD Operations]
    }
    
    component "Configuration" as Config {
        [convict]
    }
    
    component "Schema Validation" as Schema {
        [ajv]
    }
    
    component "Database" as Database {
        [MySQL (mysql2/promise)]
    }
    
    component "Docker Integration" as Docker {
        [docker-compose.yml]
    }
    
    component "Testing" as Testing {
        [mocha]
        [chai]
    }
    
    component "Error Handling" as ErrorHandler {
        ["Err" Helper]
    }

    Express --> FoodService
    FoodService --> Database
    FoodService --> Config
    FoodService --> Schema
    FoodService --> ErrorHandler
    Config --> Database
    Docker --> Database
    Testing --> FoodService
    
    Database --> Store
}

@enduml
```