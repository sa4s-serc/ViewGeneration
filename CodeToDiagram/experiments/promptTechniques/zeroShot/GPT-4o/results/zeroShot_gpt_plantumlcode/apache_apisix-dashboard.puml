```plantuml
@startuml apache_apisix-dashboard

package "Client" {
    [React App] <<Component>>
    [React-Router] <<Library>>
    [TanStack Query] <<Library>>
    [MobX] <<Library>>
    [Mantine UI] <<Library>>
    [Ant Design Pro Components] <<Library>>
}

package "APISIX Admin API" {
    [API Server] <<Component>>
}

package "Data Flow" {
    [API Request] <<Data Flow>>
    [API Response] <<Data Flow>>
}

package "Deployment" {
    [Browser] <<Environment>>
    [Web Server] <<Environment>>
}

[React App] --> [React-Router] : "Handles Routing"
[React App] --> [TanStack Query] : "Data Fetching"
[React App] --> [MobX] : "State Management"
[React App] --> [Mantine UI] : "UI Components"
[React App] --> [Ant Design Pro Components] : "Advanced Tables"

[React App] -down-> [API Request] : "Fetches Data"
[API Request] -right-> [API Server] 
[API Server] -left-> [API Response] 
[API Response] -up-> [React App] : "Updates UI"

[React App] --> [Browser] : "Deployment Environment"
[API Server] --> [Web Server] : "Deployment Environment"

@enduml
```