```plantuml
@startuml blentle_hikarikeeper

package "HikariKeeper System" {
    component "hikarikeeper-core" {
        component "Raft Consensus" as Raft
        component "Metadata Storage" as Storage
        component "RPC Interface" as Rpc
    }

    component "hikarikeeper-client" as Client
    component "hikarikeeper-server" as Server
    component "hikarikeeper-discovery" as Discovery
    component "hikarikeeper-springboot-starter" as SpringBootStarter
    component "hikarikeeper-benchmark" as Benchmark

    Raft --> Storage : "Uses"
    Raft --> Rpc : "Communicates via"
    Client --> Rpc : "Sends requests"
    Rpc --> Server : "Handles requests"
    Discovery --> Server : "Discovers services"
    SpringBootStarter --> Server : "Integrates with"
    Benchmark --> Server : "Tests performance"
}

package "Deployment" {
    node "Client Node" {
        [Client Application] --> [RPC Interface]
    }

    node "Server Node" {
        [HikariKeeper Server] --> [Metadata Storage]
    }

    node "Discovery Node" {
        [Discovery Service] --> [HikariKeeper Server]
    }

    [Client Application] --> [HikariKeeper Server] : "API Calls"
    [HikariKeeper Server] --> [Discovery Service] : "Service Registration"
}

@enduml
```