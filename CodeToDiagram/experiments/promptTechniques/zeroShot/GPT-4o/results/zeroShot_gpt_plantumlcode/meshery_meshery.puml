```plantuml
@startuml meshery_meshery

cloud "Cloud Environment" {
    component "Kubernetes Cluster" {
        component "Meshery Server" {
            [GraphQL API Layer] --> [Meshery UI]
            [Meshery UI] --> [mesheryctl]
            [GraphQL API Layer] --> [Meshery Operator]
            [Meshery Operator] --> [MeshSync]
            [Meshery Operator] --> [Event Broker]
            [Meshery Server] --> [GraphQL API Layer]
            [Meshery Server] --> [Event Broker]
        }

        component "Adapters" {
            [Istio Adapter] --> [Meshery Server]
            [Linkerd Adapter] --> [Meshery Server]
            [Consul Adapter] --> [Meshery Server]
            [Kuma Adapter] --> [Meshery Server]
            [NGINX Adapter] --> [Meshery Server]
            [AWS App Mesh Adapter] --> [Meshery Server]
        }

        component "Providers" {
            [DefaultLocalProvider] --> [Meshery Server]
            [RemoteProvider] --> [Meshery Server]
        }

        component "Meshery Broker" {
            [NATS (Message Broker)] --> [Meshery Server]
            [NATS (Message Broker)] --> [MeshSync]
            [NATS (Message Broker)] --> [Event Broker]
        }
    }
}

cloud "Cloud Providers" {
    [AWS Cloud] --> [Meshery Server]
    [Azure Cloud] --> [Meshery Server]
    [GCP Cloud] --> [Meshery Server]
}

component "MeshKit" {
    [MeshKit] --> [Meshery Server]
    [MeshKit] --> [Adapters]
}

@enduml
```