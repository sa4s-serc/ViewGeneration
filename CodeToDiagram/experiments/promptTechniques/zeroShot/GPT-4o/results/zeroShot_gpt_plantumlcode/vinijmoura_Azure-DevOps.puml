```plantuml
@startuml vinijmoura_Azure-DevOps

package "Azure DevOps Reporting System" {
    component "Data Extraction" as DE {
        [PowerShell Scripts]
    }
    
    component "Data Transformation" as DT {
        [PowerShell Scripts]
    }
    
    component "Data Storage" as DS {
        [Azure SQL Database]
    }
    
    component "Data Visualization" as DV {
        [Power BI]
    }
    
    component "Custom Visuals" as CV {
        [JavaScript & CSS]
    }
    
    DE --> DT : extracts data
    DT --> DS : transforms and loads data
    DS --> DV : provides data for visualization
    DV --> CV : uses custom visuals
}

package "Configuration & Governance" {
    component "GitHub Actions" as GA {
        [powershell-analysis.yml]
    }
    
    component "Documentation" as DOC {
        [README.md, LICENSE]
    }
    
    GA --> DE : static code analysis
    DOC --> DE : usage instructions
}

@enduml
```