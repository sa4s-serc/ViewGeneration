```plantuml
@startuml kpantos_Azure-How-To

skinparam componentStyle rectangle

package "Azure Cloud" {
    [Azure App Service] as appService
    [Azure Application Gateway] as appGateway
    [Web Application Firewall (WAF)] as waf
    [Azure API Management (APIM)] as apim
    [Azure AD Application Proxy] as appProxy
    [Azure AD Connect] as adConnect
    [Let's Encrypt] as letsEncrypt
}

package "On-Premises Infrastructure" {
    [On-Premises API] as onPremAPI
    [Service Principal Name (SPN)] as spn
}

package "Bot Application" {
    [Bot Application (Microsoft Bot Framework)] as botApp
}

botApp --> appService
appService --> appGateway
appGateway --> waf
waf --> letsEncrypt

onPremAPI --> appProxy
appProxy --> apim
apim --> adConnect
adConnect --> spn

@enduml
```