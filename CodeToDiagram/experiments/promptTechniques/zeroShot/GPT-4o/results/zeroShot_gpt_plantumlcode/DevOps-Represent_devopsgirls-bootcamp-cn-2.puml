```plantuml
@startuml DevOps-Represent_devopsgirls-bootcamp-cn-2

package "AWS Cloud" {
  
  component "S3 Bucket" <<AWS S3>> {
    [Static Website Hosting]
  }

  component "API Gateway" <<AWS API Gateway>> {
    [Routes HTTP Requests]
  }

  component "Lambda Function" <<AWS Lambda>> {
    [CRUD Logic for Todo Application]
  }

  component "DynamoDB" <<AWS DynamoDB>> {
    [Stores Todo Data]
  }
  
}

package "Frontend" {
  component "UI" <<React>> {
    [User Interface]
    [App.js, TodoList.js, NewTodoForm.js]
  }
}

' Relationships
[UI] --> [S3 Bucket] : "Static files deployment"
[UI] ..> [API Gateway] : "Invokes API"

[API Gateway] --> [Lambda Function] : "Proxies Requests"
[Lambda Function] --> [DynamoDB] : "Data Storage Operations"

@enduml
```