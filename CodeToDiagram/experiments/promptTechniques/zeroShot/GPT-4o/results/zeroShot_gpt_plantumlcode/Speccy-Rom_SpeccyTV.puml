    component "movies_streaming_etl" as ETL
    component "movies_admin" as Admin
    component "movies_streaming_admin" as StreamingAdmin
    component "movies_ugc" as UGC

    User --> Auth
    User --> Billing
    User --> AsyncAPI
    User --> Admin
    User --> StreamingAdmin

    Auth --> AsyncAPI
    Billing --> Auth
    AsyncAPI --> Converter
    Converter --> ETL
    ETL --> StreamingAdmin
    UGC --> AsyncAPI
    UGC --> Converter
}

package "External Services" {
    component "Stripe" as Stripe
    component "Elasticsearch" as Elasticsearch
    component "Redis" as Redis
    component "Kafka" as Kafka
    component "ClickHouse" as ClickHouse
    component "MinIO" as MinIO
}

Auth --> Stripe
AsyncAPI --> Elasticsearch
AsyncAPI --> Redis
UGC --> Kafka
UGC --> ClickHouse
ETL --> MinIO

@enduml
