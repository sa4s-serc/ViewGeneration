```plantuml
@startuml lowes_auditor

package "Auditor Framework" {
    
    [Client Library] <<Spring Boot Starter>> 
    
    package "Application Server" {
        [Application] <<Deployable>>
        [ConsumerService] 
        [AuditEventRepositoryService]
    }

    package "/core" {
        [AuditEventDTOMapper]
        [AuditEventMapper]
        [JsonObject]
    }
    
    package "/specs" {
        [OpenAPI Specs]
    }
}

node "Kafka" {
    [Kafka Broker]
}

node "Elasticsearch" {
    [Elasticsearch Cluster]
}

[Client Library] --> [Kafka Broker] : "Sends Events"
[Kafka Broker] --> [ConsumerService] : "Consumes Events"
[ConsumerService] --> [AuditEventRepositoryService] : "Processes & Stores"
[AuditEventRepositoryService] --> [Elasticsearch Cluster] : "Stores Events"

[OpenAPI Specs] ..> [AuditEventDTOMapper] : "Generates Code"

@enduml
```