```plantuml
@startuml anjuchamantha_EMonitor

package "EMonitor ESP32 Device" {
    component "main.cpp" as Main
    component "config.h" as Config
    component "wifi_con" as WiFiCon
    component "http" as Http
    component "mail_client" as MailClient
    component "readings" as Readings
    component "utils" as Utils
    component "xml" as XML
    component "OLED Display" as OLED
}

Config --> WiFiCon : "Provides WiFi Credentials"
