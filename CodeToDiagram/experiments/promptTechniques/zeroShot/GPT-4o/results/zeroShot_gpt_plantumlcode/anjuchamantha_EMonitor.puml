Config --> MailClient : "Provides Email Credentials"

Main --> Readings : "Collects Sensor Data"
Main --> WiFiCon : "Manages WiFi Connection"
Main --> Http : "Sends Data to Server"
Main --> MailClient : "Sends Email Alerts"
Main --> OLED : "Updates Display"

WiFiCon --> Main : "WiFi Status"
Http --> Main : "Server Response"
MailClient --> Main : "Email Status"
Readings --> Main : "Sensor Readings"

Main --> XML : "Formats Data as XML"
XML --> Http : "Provides XML Data"

Main --> Utils : "Calculates Mean/StdDev"
Utils ..> Readings : "Analyzes Data"

Main --> "NTP Server" : "Sync Time"

@enduml
