```plantuml
@startuml mincloud1501_MSA_miniProject

package "Cloud Providers" {
  component "Google Kubernetes Engine (GKE)"
  component "AWS"
  component "Azure"
}

package "Microservices Infrastructure" {
  component "Kubernetes Cluster" {
    component "Master Node" {
      component "API Server"
      component "Controller Manager"
      component "Scheduler"
      component "etcd"
    }
    component "Worker Node" {
      component "Kubelet"
      component "Kube Proxy"
      component "Docker"
    }
  }
  
  component "Istio Service Mesh" {
    component "Envoy Proxy"
    component "Istio Control Plane"
  }
}

package "Application Components" {
  component "Nginx Web Server" {
    component "Docker Container" {
      component "Custom index.html"
    }
  }
}

package "Deployment Scripts" {
  component "kubernetes/kubProvisioning.sh"
  component "docker/build.sh"
  component "docker/push.sh"
}

package "Monitoring Tools" {
  component "Prometheus"
  component "Kubernetes Dashboard"
}

package "Version Control" {
  component "GitHub Repository"
}

[Docker Container] --> [Docker]
[Nginx Web Server] --> [Docker Container]
[Docker Container] --> [Istio Service Mesh]
[Istio Service Mesh] --> [Kubernetes Cluster]
[Kubernetes Cluster] --> [Google Kubernetes Engine (GKE)]
[Kubernetes Cluster] --> [AWS]
[Kubernetes Cluster] --> [Azure]
[kubernetes/kubProvisioning.sh] ..> [Kubernetes Cluster]
[docker/build.sh] ..> [Docker]
[docker/push.sh] ..> [Docker]
[GitHub Repository] --> [Deployment Scripts]
[Istio Service Mesh] --> [Envoy Proxy]
[Istio Service Mesh] --> [Istio Control Plane]
[Monitoring Tools] --> [Kubernetes Cluster]

@enduml
```