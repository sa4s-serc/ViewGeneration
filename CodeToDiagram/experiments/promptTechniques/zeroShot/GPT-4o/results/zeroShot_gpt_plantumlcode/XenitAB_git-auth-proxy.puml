```plantuml
@startuml XenitAB_git-auth-proxy

actor GitClient as GC
participant GitAuthProxy as GAP
participant Authorizer as Auth
participant TokenWriter as TW
participant KubernetesAPI as K8sAPI
participant GitProvider as GP

GC -> GAP: Clone or API Request
GAP -> Auth: Validate Token
Auth -> TW: Check Token Validity
TW -> K8sAPI: Retrieve Secret
K8sAPI -> TW: Return Secret
TW -> Auth: Return Validation Result

alt Token Valid
    Auth -> GAP: Authorization Success
    GAP -> GP: Forward Request
    GP -> GAP: Return Response
    GAP -> GC: Return Response
else Token Invalid
    Auth -> GAP: Authorization Failure
    GAP -> GC: Return Error
end

== Deployment and Configuration ==

participant ConfigLoader as CL

GAP -> CL: Load Configuration
CL -> K8sAPI: Apply Configuration
K8sAPI -> GAP: Configuration Applied

== Metrics Collection ==

participant Prometheus as PM

PM -> GAP: Scrape Metrics
GAP -> PM: Return Metrics

@enduml
```