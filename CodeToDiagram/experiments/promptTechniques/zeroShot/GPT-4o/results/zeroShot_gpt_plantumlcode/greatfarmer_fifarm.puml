```plantuml
@startuml greatfarmer_fifarm

!define SPRING_BOOT_COMPONENT <<Spring Boot>>
!define MONGODB_COMPONENT <<MongoDB>>
!define THYMELEAF_COMPONENT <<Thymeleaf>>

package "FIFArm Application" {
  
  component SpiderApplication <<SPRING_BOOT_COMPONENT>> {
    component "HttpRequestService" as HttpRequestService
    component "MongoService" as MongoService
    component "LogService" as LogService
    component "Scheduler" as Scheduler
    component "RequestLoggingFilterConfig" as RequestLoggingFilterConfig
  }
  
  component "Controllers" {
    component "IndexController" as IndexController
    component "PathController" as PathController
    component "JsonController" as JsonController
  }
  
  component "Configuration" {
    component "application.yml" as applicationYml
    component "logback.xml" as logbackXml
  }
  
  component "Web Interface" <<THYMELEAF_COMPONENT>> {
    component "Thymeleaf Templates" as ThymeleafTemplates
  }
}

package "External Systems" {
  component "EA Sports FUT API" as FUT_API
  component "MongoDB" <<MONGODB_COMPONENT>> as MongoDB
}

package "Resources" {
  component "Static Assets" as StaticAssets
}

SpiderApplication --> FUT_API : Fetches Player Data
SpiderApplication --> MongoDB : Stores/Fetched Player Data
MongoService --> MongoDB : Executes Queries
IndexController --> ThymeleafTemplates : Renders Views
JsonController --> MongoDB : RESTful API Access
Scheduler --> FUT_API : Regular Updates
RequestLoggingFilterConfig --> logbackXml : Configures Logging
ThymeleafTemplates --> StaticAssets : Uses CSS/JS/Images
applicationYml --> SpiderApplication : Configures Settings
logbackXml --> SpiderApplication : Configures Logging

@enduml
```