```plantuml
@startuml qunarcorp_m_adr_qapm_open_source

actor Developer
participant "QBuildPlugin" as QBuildPlugin
participant "AspectJAppTransform" as AspectJAppTransform
participant "Application" as Application
participant "QAPM" as QAPM
participant "QConfigManager" as QConfigManager
participant "TracePlugin" as TracePlugin
participant "WatchMan" as WatchMan
participant "Storage" as Storage
participant "network.instrumentation" as NetworkInstrumentation
participant "network.sender" as NetworkSender

Developer -> QBuildPlugin: apply()
QBuildPlugin -> AspectJAppTransform: registerTransform()

Application -> QAPM: initialize()
QAPM -> QConfigManager: configure()

QAPM -> TracePlugin: startTracing()
TracePlugin -> WatchMan: monitorLifecycle()

WatchMan -> Storage: storeData()
WatchMan -> NetworkInstrumentation: instrumentHTTP()

NetworkInstrumentation -> NetworkSender: sendData()
@enduml
```