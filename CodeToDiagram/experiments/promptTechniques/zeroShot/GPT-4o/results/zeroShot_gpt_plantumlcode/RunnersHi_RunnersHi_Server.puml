```plantuml
@startuml RunnersHi_RunnersHi_Server

actor User
participant "Socket.IO Client" as SocketClient
participant "Socket.IO Server" as SocketServer
participant "Matching Controller" as MatchingController
participant "Matching Model" as MatchingModel
participant "MySQL Database" as Database

User -> SocketClient: Initiates match request
SocketClient -> SocketServer: Emit match request event
SocketServer -> MatchingController: Handle match request
MatchingController -> MatchingModel: Find opponent
MatchingModel -> Database: Query for matching criteria
Database --> MatchingModel: Return match data
MatchingModel --> MatchingController: Return matched opponent
MatchingController -> SocketServer: Emit match found event
SocketServer -> SocketClient: Notify match found

User -> SocketClient: Sends running data
SocketClient -> SocketServer: Emit running data event
SocketServer -> MatchingController: Handle running data
MatchingController -> MatchingModel: Store running data
MatchingModel -> Database: Insert running data
Database --> MatchingModel: Confirm data storage
MatchingModel --> MatchingController: Confirm data handling
MatchingController -> SocketServer: Emit data update event
SocketServer -> SocketClient: Send data confirmation

User -> SocketClient: Completes run
SocketClient -> SocketServer: Emit run complete event
SocketServer -> MatchingController: Handle run completion
MatchingController -> MatchingModel: Determine result
MatchingModel -> Database: Update run result
Database --> MatchingModel: Confirm result update
MatchingModel --> MatchingController: Return final result
MatchingController -> SocketServer: Emit result event
SocketServer -> SocketClient: Notify run result

@enduml
```