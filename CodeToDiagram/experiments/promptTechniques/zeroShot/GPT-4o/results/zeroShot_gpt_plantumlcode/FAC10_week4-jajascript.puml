```plantuml
@startuml FAC10_week4-jajascript

package "Front-end" {
  component "index.html" as index
  component "main.css" as css
  component "main.js" as js
}

package "Back-end" {
  component "server.js" as server
  component "router.js" as router
  component "handler.js" as handler
  component "algorithm.js" as algorithm
  component "data.json" as data
}

package "Testing" {
  component "qunit.html" as qunit
  component "frontendTests.js" as frontendTests
  component "backendTests.js" as backendTests
}

index --> js
js --> server : "Fetch Data"
server --> router : "Route Request"
router --> handler : "Handle Static Files"
router --> algorithm : "Autocomplete Request"
algorithm --> data : "Query Data"
algorithm --> router : "Return Suggestions"
handler --> index : "Serve HTML/CSS/JS"

qunit --> frontendTests : "Run Front-end Tests"
backendTests --> server : "Run Back-end Tests"

@enduml
```