```plantuml
@startuml onprem_foundry

package "Foundry Analysis" {

    component "Furnace" {
        [Furnace] --> [Package Management]
        [Furnace] --> [Metrics and Health Checks]
        [Furnace] --> [Object Storage Integration]
        [Furnace] --> [Builder Interface]
    }

    component "Package Management" {
        [pkgMap] --> [Furnace]
    }

    component "Metrics and Health Checks" {
        [Metrics (Prometheus)] --> [Furnace]
        [Health Checks] --> [Furnace]
    }

    component "Object Storage Integration" {
        [Object Storage] --> [Furnace]
    }

    component "Builder Interface" {
        interface "Builder" as IBuilder
        [MakepkgBuilder] ..|> IBuilder
        [BuilderWithMetrics] --> [MakepkgBuilder]
    }

    component "gRPC Service" {
        [BuildRequest] --> [BuildResponse]
        [Furnace] --> [gRPC Service]
    }

    package "Core Application" {
        [main.go] --> [Furnace]
        [config.go] --> [Furnace]
        [furnace.go] --> [Furnace]
    }

    package "Furnace Logic" {
        [furnace.go] --> [Furnace]
        [map.go] --> [Package Management]
        [schedule.go] --> [Furnace]
        [builder.go] --> [Builder Interface]
    }

    package "gRPC Definition" {
        [furnace.proto] --> [gRPC Service]
    }

    package "Build Automation & Configuration" {
        [go.mod] --> [Core Application]
        [Dockerfile] --> [Core Application]
        [Makefile] --> [Core Application]
    }

    package "GitHub Actions" {
        [.github/workflows/test.yaml] --> [Build Automation & Configuration]
        [.github/workflows/upload_assets.yaml] --> [Build Automation & Configuration]
        [.github/workflows/codeql.yaml] --> [Build Automation & Configuration]
    }

    package "Documentation" {
        [README.md] --> [Core Application]
        [CHANGELOG.md] --> [Core Application]
    }
}

@enduml
```