```plantuml
@startuml 2WAY_Design

package "2WAY_Design System" {
    component "Trust Network" {
        component "Trusted Entity A"
        component "Trusted Entity B"
        component "Trusted Entity C"
    }
    
    component "Authorization & Authentication" {
        component "User Authentication"
        component "Access Control"
    }
    
    component "Data Exchange"
}

"Trust Network" --> "Data Exchange"
"Authorization & Authentication" --> "Data Exchange"

"Trusted Entity A" -- "Trust Network"
"Trusted Entity B" -- "Trust Network"
"Trusted Entity C" -- "Trust Network"

"User Authentication" --> "Authorization & Authentication"
"Access Control" --> "Authorization & Authentication"

@enduml
