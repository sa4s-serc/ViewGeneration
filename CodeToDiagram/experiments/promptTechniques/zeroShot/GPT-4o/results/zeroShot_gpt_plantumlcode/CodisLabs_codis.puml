```plantuml
@startuml CodisLabs_codis

package "Codis System" {
    node "Codis Proxy" {
        [Codis Proxy]
    }
    
    node "Redis Cluster" {
        [Redis Node 1]
        [Redis Node 2]
        [Redis Node 3]
        
