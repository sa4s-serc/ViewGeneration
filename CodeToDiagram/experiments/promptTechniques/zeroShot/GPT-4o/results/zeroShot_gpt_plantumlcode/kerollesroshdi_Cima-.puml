@startuml kerollesroshdi_Cima-

package "Cima+ iOS Application" {
    [App] -down-> [Scenes]
    [App] -down-> [Core]
    [App] -down-> [Assets/Design System]
    [App] -down-> [Utilities]

    package "Scenes" {
        [NowPlayingVC]
        [TopRatedVC]
        [SearchVC]
        [MovieDetailsVC]
        [GenreCell]
        [MovieCell]
        [BrowseVM]
        [SearchVM]
        [MovieDetailsVM]
    }

    package "Core" {
        [BaseViewController]
        [ViewModel]
        [TextyTabBar]
        [StateView]
    }

    package "Domain" {
        [Entities]
        [Repositories]
        [UseCases]
    }

    package "Data" {
        [RemoteDataSources]
        [RepositoriesImplementations]
    }

    [AppCoordinator] --> [Scenes]
    [AppCoordinator] --> [Core]
    [AppCoordinator] --> [Domain]
    [AppDelegate] --> [AppCoordinator]

    [RemoteDataSources] .up.> [RepositoriesImplementations]
    [RepositoriesImplementations] .up.> [Repositories]
    [Repositories] .up.> [UseCases]
    [Entities] .up.> [UseCases]

    [UseCases] ..> [BrowseVM] : "Use"
    [UseCases] ..> [SearchVM] : "Use"
    [UseCases] ..> [MovieDetailsVM] : "Use"

    [BrowseVM] --> [NowPlayingVC]
    [BrowseVM] --> [TopRatedVC]
    [SearchVM] --> [SearchVC]
    [MovieDetailsVM] --> [MovieDetailsVC]

    [TextyTabBar] ..> [Scenes]
    [StateView] ..> [Scenes]

    [Utilities] ..> [Core] : "Extensions"
}

@enduml
