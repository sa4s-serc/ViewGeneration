```plantuml
@startuml DehengYang_APRConfig

actor User

participant "Run_d4j_1.py" as RunD4J
participant "Dataset/Defects4j.py" as Dataset
participant "Localization/Gzoltar.py" as Localization
participant "Apr/Tool" as APRTool
participant "Config.py" as Config
participant "Main_parse.py" as MainParse

User -> RunD4J: Execute script
RunD4J -> Config: Load configuration
Config --> RunD4J: Configuration data

RunD4J -> Dataset: Initialize dataset
Dataset --> RunD4J: Dataset instance

RunD4J -> Localization: Perform fault localization
Localization --> RunD4J: Fault data

RunD4J -> APRTool: Generate patch
APRTool --> RunD4J: Patch data

RunD4J -> MainParse: Parse repair data
MainParse -> RunD4J: Return results in CSV

User <- RunD4J: Display results

@enduml
```