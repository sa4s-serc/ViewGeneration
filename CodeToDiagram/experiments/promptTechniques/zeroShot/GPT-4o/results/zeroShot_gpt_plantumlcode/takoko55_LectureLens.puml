```plantuml
@startuml takoko55_LectureLens

package "Frontend (React)" {
  component "App.jsx" as App
  component "SyllabusSearch.jsx" as SyllabusSearch
  component "GlassCard.jsx" as GlassCard
  component "LecturePage.jsx" as LecturePage
  component "ReviewItem.jsx" as ReviewItem
  component "Auth.jsx" as Auth
  component "ReviewPost.jsx" as ReviewPost
  component "useQueryReviews.jsx" as useQueryReviews
  component "useMutateReview.jsx" as useMutateReview
  component "store/index.jsx" as ZustandStore
}

package "Backend (Go)" {
  component "main.go" as Main
  component "router/router.go" as Router
  component "controller/" as Controller
  component "usecase/" as Usecase
  component "repository/" as Repository
  component "model/" as Model
  component "db/db.go" as DatabaseConnection
  component "migrate/migrate.go" as Migrations
}

package "Database (PostgreSQL)" {
  component "User Table" as UserTable
  component "Lecture Table" as LectureTable
  component "Review Table" as ReviewTable
}

App --> SyllabusSearch
SyllabusSearch --> GlassCard
LecturePage --> ReviewItem
ReviewPost --> useMutateReview
useQueryReviews --> LecturePage
useMutateReview --> ReviewPost
ZustandStore --> ReviewPost

Main --> Router
Router --> Controller
Controller --> Usecase
Usecase --> Repository
Repository --> Model
DatabaseConnection --> PostgreSQL

Repository --> UserTable
Repository --> LectureTable
Repository --> ReviewTable

Model --> UserTable
Model --> LectureTable
Model --> ReviewTable

component ".env" as Env
component "docker-compose.yml" as DockerCompose

Env -[hidden]-> Main
DockerCompose --> PostgreSQL

@enduml
```