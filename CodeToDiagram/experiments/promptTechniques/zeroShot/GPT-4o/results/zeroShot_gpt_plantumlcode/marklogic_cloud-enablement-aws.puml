```plantuml
@startuml marklogic_cloud-enablement-aws

!define AWS EC2
!define AWS VPC
!define AWS Lambda
!define AWS CloudFormation
!define AWS DynamoDB
!define AWS ALB
!define AWS AutoScaling
!define AWS EBS
!define AWS SNS

package "AWS Cloud Environment" {
    [VPC] <<VPC>> 
    [EC2 Instances] <<EC2>> 
    [Lambda Functions] <<Lambda>> 
    [CloudFormation Templates] <<CloudFormation>> 
    [DynamoDB Table] <<DynamoDB>> 
    [Application Load Balancer] <<ALB>> 
    [Auto Scaling Group] <<AutoScaling>> 
    [EBS Volumes] <<EBS>> 
    [SNS] <<SNS>> 
}

package "CloudFormation Templates" {
    [mlcluster.template]
    [mlcluster-vpc.template]
    [ml-managedeni.template]
    [ml-nodemanager.template]
}

package "Lambda Functions" {
    [managedeni.py]
    [nodemanager.py]
    [utils.py]
}

[CloudFormation Templates] --> [VPC]
[CloudFormation Templates] --> [EC2 Instances]
[CloudFormation Templates] --> [EBS Volumes]
[CloudFormation Templates] --> [DynamoDB Table]
[CloudFormation Templates] --> [Application Load Balancer]
[CloudFormation Templates] --> [Auto Scaling Group]
[CloudFormation Templates] --> [SNS]

[managedeni.py] --> [EC2 Instances]
[nodemanager.py] --> [Auto Scaling Group]
[utils.py] --> [Lambda Functions]

[EC2 Instances] --> [EBS Volumes]
[EC2 Instances] --> [Application Load Balancer]
[EC2 Instances] --> [DynamoDB Table]

[Auto Scaling Group] --> [EC2 Instances]
[Auto Scaling Group] --> [Application Load Balancer]

@enduml
```