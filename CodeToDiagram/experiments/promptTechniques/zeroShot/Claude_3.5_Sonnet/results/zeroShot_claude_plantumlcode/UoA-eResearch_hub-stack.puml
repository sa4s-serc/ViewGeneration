```plantuml
@startuml UoA-eResearch_hub-stack

participant "User" as user
participant "CloudFront CDN" as cdn
participant "ResearchHub Website\n(Angular)" as frontend
participant "Cognito" as cognito
participant "GraphQL API\n(cer-graphql)" as graphql
participant "Search Proxy\n(Lambda)" as searchproxy
participant "Contentful" as contentful
participant "ElasticSearch" as elasticsearch
participant "Jenkins CI/CD" as jenkins
participant "AWS S3" as s3
participant "Terraform" as terraform

user -> cdn : Access ResearchHub
cdn -> frontend : Serve static assets

frontend -> cognito : Authenticate user
cognito --> frontend : Auth token

frontend -> graphql : GraphQL query
graphql -> contentful : Proxy request
contentful --> graphql : Content data
graphql --> frontend : Query results

frontend -> searchproxy : Search request
searchproxy -> elasticsearch : Query index
elasticsearch --> searchproxy : Search results
searchproxy --> frontend : Formatted results

jenkins -> s3 : Deploy frontend assets
jenkins -> terraform : Apply infrastructure changes

terraform -> aws : Provision/update resources

searchproxy -> elasticsearch : Scheduled index update
searchproxy -> contentful : Fetch updated content
contentful --> searchproxy : Updated content
searchproxy -> elasticsearch : Update index

@enduml
```