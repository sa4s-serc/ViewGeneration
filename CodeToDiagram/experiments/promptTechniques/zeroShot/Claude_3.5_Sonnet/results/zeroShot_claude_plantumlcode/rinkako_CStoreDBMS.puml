@startuml rinkako_CStoreDBMS

!define RECTANGLE class

package "DBInterface" {
    RECTANGLE DBController
    RECTANGLE DBConnectionPool
}

package "DBCompiler" {
    RECTANGLE LexicalAnalyzer
    RECTANGLE SyntaxParser
    RECTANGLE Pile
    RECTANGLE CSDatabase
    RECTANGLE DBBridge
}

package "DBEngine" {
    RECTANGLE FileManager
    RECTANGLE TableManager
    RECTANGLE DBAllocator
    RECTANGLE DBLock
    RECTANGLE DBTransaction
}

DBController --> DBConnectionPool
DBConnectionPool --> DBBridge
DBBridge --> CSDatabase
DBBridge --> LexicalAnalyzer
DBBridge --> SyntaxParser
DBBridge --> Pile

CSDatabase --> FileManager
CSDatabase --> TableManager
CSDatabase --> DBAllocator
CSDatabase --> DBLock
CSDatabase --> DBTransaction

FileManager --> DBAllocator
TableManager --> DBAllocator
DBTransaction --> DBLock

note "Singleton Pattern" as N1
N1 .. FileManager
N1 .. DBAllocator
N1 .. DBConnectionPool
N1 .. TableManager

note "Bridge Pattern" as N2
N2 .. DBBridge

@enduml