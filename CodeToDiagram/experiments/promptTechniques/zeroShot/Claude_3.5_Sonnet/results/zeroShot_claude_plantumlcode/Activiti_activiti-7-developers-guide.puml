@startuml Activiti_activiti-7-developers-guide

!define RECTANGLE component

cloud "Kubernetes" {
  RECTANGLE "Activiti Cloud Platform" {
    [Gateway]
    [Identity Management / SSO]
    package "Activiti Cloud Services" {
      [Runtime Bundle]
      [Query Service]
      [Audit Service]
      [Notification Service]
    }
    [Cloud Connectors]
    [BPMN Modeling Application]
  }
  
  database "Database"
  [Helm Charts]
}

node "CI/CD" {
  [Jenkins X]
}

[Git Repository]

[Gateway] --> [Runtime Bundle]
[Gateway] --> [Query Service]
[Gateway] --> [Audit Service]
[Gateway] --> [Notification Service]

[Runtime Bundle] --> [Cloud Connectors]
[Runtime Bundle] --> Database
[Query Service] --> Database
[Audit Service] --> Database
[Notification Service] --> Database

[Identity Management / SSO] --> [Gateway]

[Helm Charts] ..> [Activiti Cloud Platform] : deploys
[Jenkins X] ..> [Helm Charts] : uses
[Jenkins X] ..> [Git Repository] : pulls from

@enduml