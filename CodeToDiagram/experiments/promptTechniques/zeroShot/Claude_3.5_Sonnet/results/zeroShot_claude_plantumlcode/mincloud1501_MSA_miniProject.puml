@startuml

!define RECTANGLE class

skinparam component {
    BackgroundColor<<application>> LightBlue
    BackgroundColor<<infrastructure>> LightGreen
    BackgroundColor<<platform>> LightYellow
}

rectangle "Docker Hub" as dockerhub <<infrastructure>>

cloud "Kubernetes Cluster" {
    component "Nginx Pod" as nginxpod <<application>> {
        [Nginx Container]
    }
    
    component "Kubernetes Service" as kubservice <<platform>>
    
    component "Istio Service Mesh" as istio <<platform>> {
        [Envoy Proxy]
    }
    
    component "Kubernetes Dashboard" as kubdashboard <<platform>>
    
    component "Prometheus" as prometheus <<platform>>
}

cloud "Cloud Provider (GKE/AWS/Azure)" as cloudprovider <<infrastructure>>

[Docker Image] as dockerimage <<application>>

dockerimage --> dockerhub : push
dockerhub --> nginxpod : pull

nginxpod --> kubservice : exposes
istio --> nginxpod : manages traffic
kubdashboard --> cloudprovider : monitors
prometheus --> cloudprovider : monitors

cloudprovider --> [Kubernetes Cluster] : hosts

@enduml