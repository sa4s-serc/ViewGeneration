@startuml

[ArgaelForm] as GUI
[IOManager] as IO
[DataManager] as DM
[ArgumentModel] as AM
[ReportFormatter] as RF
[InitParams] as IP
[FileUtils] as FU
[StringUtils] as SU

database "JSONL Files" as DB
file "params.json" as PJ
file "users.txt" as UT
folder "HTML Templates" as HT

GUI --> IO : reads/writes data
GUI --> DM : manages data
GUI --> AM : uses
GUI --> RF : generates reports
GUI --> IP : initializes from

IO --> DB : reads/writes
IO --> UT : reads

DM --> AM : uses
DM --> DB : persists data

RF --> HT : uses

IP --> PJ : reads

GUI ..> FU : uses
GUI ..> SU : uses

@enduml