@startuml ibm-hyperknowledge_hklib

package "Core Entities" {
  [HKEntity] <<abstract>>
  [Node]
  [Context]
  [Link]
  [Connector]
  [Reference]
  [Trail]
}

package "Virtual Entities" {
  [VirtualNode]
  [VirtualContext]
  [VirtualLink]
}

package "Data Access" {
  [HKDatasource]
}

package "Fragment Identifiers" {
  [FI]
  [FIAnchor]
  [FIOperator]
}

package "Observer Pattern" {
  [HKObserverFactory]
  [ObserverClient]
}

package "Utilities" {
  [Serialization]
  [Deserialization]
  [Hyperify]
  [GraphBuilder]
}

package "External Data Sources" {
  [Wordnet]
  [DBpedia]
}

HKEntity <|-- Node
HKEntity <|-- Context
HKEntity <|-- Link
HKEntity <|-- Connector
HKEntity <|-- Reference
HKEntity <|-- Trail

Node <|-- VirtualNode
Context <|-- VirtualContext
Link <|-- VirtualLink

HKDatasource --> HKEntity : manages
HKDatasource --> ObserverClient : uses

HKObserverFactory ..> ObserverClient : creates

VirtualNode --> "External Data Sources" : interacts with
VirtualContext --> "External Data Sources" : interacts with
VirtualLink --> "External Data Sources" : interacts with

Utilities --> HKEntity : supports
"Fragment Identifiers" --> HKEntity : enhances

@enduml