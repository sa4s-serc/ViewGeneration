@startuml IceFireDB_IceFireDB

[IceFireDB Core] as core
[Uhaha] as uhaha
[LevelDB] as leveldb
[IceFireDB-SQLProxy] as sqlproxy
[MySQL Backend] as mysql
[LibP2P] as libp2p
[Protocol Buffers] as protobuf
[gRPC] as grpc
[Crypto Libraries] as crypto
[OpenTelemetry] as otel

core --> uhaha : uses for consensus
core --> leveldb : uses as storage
core --> protobuf : uses for serialization
core --> grpc : uses for communication
core --> crypto : uses for security

sqlproxy --> mysql : proxies
sqlproxy --> libp2p : uses for P2P networking
sqlproxy --> protobuf : uses for serialization
sqlproxy --> grpc : uses for communication

core --> otel : uses for telemetry
sqlproxy --> otel : uses for telemetry

@enduml
