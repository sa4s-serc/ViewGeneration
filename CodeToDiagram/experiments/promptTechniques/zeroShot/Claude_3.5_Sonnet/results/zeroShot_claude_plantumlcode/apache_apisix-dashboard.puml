```plantuml
@startuml apache_apisix-dashboard

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<Database>> LightYellow
}

rectangle "Client Browser" as client

component "Apache APISIX Dashboard" <<Frontend>> {
  [React Application] as react
  [React Router] as router
  [MobX Store] as mobx
  [TanStack Query] as query
  [i18n] as i18n
}

component "Apache APISIX" <<Backend>> {
  [Admin API] as api
  [Core] as core
  [Plugins] as plugins
}

database "ETCD" <<Database>> as etcd

client --> react : HTTP/HTTPS

react --> router : Uses
react --> mobx : State Management
react --> query : Data Fetching
react --> i18n : Internationalization

query --> api : REST API Calls

api --> core : Configures
api --> plugins : Manages

core --> etcd : Stores Configuration
plugins --> etcd : Stores Plugin Data

@enduml
```