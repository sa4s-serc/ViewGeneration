@startuml
participant "Sample Node.js App" as App
participant "Prometheus Client" as PromClient
participant "Prometheus Server" as Prometheus
participant "Alertmanager" as Alertmanager
participant "Grafana" as Grafana

loop Every scrape interval
    Prometheus -> App: Scrape metrics
    activate App
    App -> PromClient: Collect metrics
    PromClient --> App: Return metrics
    App --> Prometheus: Return metrics in Prometheus format
    deactivate App
    
    Prometheus -> Prometheus: Store metrics
    Prometheus -> Prometheus: Evaluate alert rules
    
    alt Alert triggered
        Prometheus -> Alertmanager: Send alert
        Alertmanager -> Alertmanager: Process alert (deduplicate, group, route)
    end
end

loop Continuous
    Grafana -> Prometheus: Query metrics
    Prometheus --> Grafana: Return query results
    Grafana -> Grafana: Update dashboards
end
@enduml