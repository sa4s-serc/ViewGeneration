@startuml Speccy-Rom_SpeccyTV

!define RECTANGLE class

RECTANGLE "Movies Streaming Converter" as converter
RECTANGLE "Movies Streaming ETL" as etl
RECTANGLE "Movies Auth" as auth
RECTANGLE "Movies Billing" as billing
RECTANGLE "Movies Async API" as api
RECTANGLE "Movies Admin" as admin
RECTANGLE "Movies Streaming Admin" as streamingAdmin
RECTANGLE "Movies UGC" as ugc
RECTANGLE "Elasticsearch" as es
RECTANGLE "Redis" as redis
RECTANGLE "PostgreSQL" as postgres
RECTANGLE "ClickHouse" as clickhouse
RECTANGLE "Kafka" as kafka
RECTANGLE "MinIO" as minio

converter --> minio : Stores converted videos
etl --> converter : Triggers conversion
etl --> minio : Reads/Writes video files
auth --> postgres : Stores user data
billing --> postgres : Stores billing info
api --> es : Searches content
api --> redis : Caches data
api --> postgres : Retrieves data
admin --> postgres : Manages content
streamingAdmin --> postgres : Manages streaming content
ugc --> kafka : Streams user events
ugc --> clickhouse : Stores user activity
kafka --> clickhouse : Feeds user events

@enduml