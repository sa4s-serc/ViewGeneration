```plantuml
@startuml open-risk_Open_Risk_API

cloud "Open Risk API" {
    [Model Server] as MS
    [Data Server] as DS
    database "MongoDB" as DB
}

node "Client Machine" {
    [API Explorer] as AE
}

node "OpenCPM Server" {
    [NPL Concentration Model] as NCM
}

MS -[hidden]right- DS
DS -[hidden]down- DB

AE --> MS : HTTP/REST
AE --> DS : HTTP/REST
MS --> DS : HTTP/REST
DS --> DB : Stores/Retrieves data

MS --> NCM : Executes calculations
NCM --> MS : Returns results

@enduml
```