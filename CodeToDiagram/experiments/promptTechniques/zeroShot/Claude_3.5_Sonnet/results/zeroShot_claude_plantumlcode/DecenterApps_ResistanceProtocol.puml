@startuml DecenterApps_ResistanceProtocol

skinparam component {
  BackgroundColor<<Smart Contract>> LightBlue
  BackgroundColor<<Simulation>> LightGreen
  BackgroundColor<<Frontend>> LightYellow
  BackgroundColor<<Backend>> LightPink
}

component "NOI Stablecoin Protocol" {
  [Smart Contracts]<<Smart Contract>> as SC
  [CDPManager]<<Smart Contract>> as CDPM
  [MultiSigWallet]<<Smart Contract>> as MSW
  [PriceStabilizationMechanism]<<Smart Contract>> as PSM
}

component "Simulation Engine" {
  [Python Simulation]<<Simulation>> as PS
  [Agent Modeling]<<Simulation>> as AM
}

component "Frontend" {
  [React Application]<<Frontend>> as RA
  [Web3 Connectors]<<Frontend>> as W3C
}

component "Backend" {
  [Deployment Scripts]<<Backend>> as DS
  [Monitoring Services]<<Backend>> as MS
  [Liquidation Bot]<<Backend>> as LB
}

component "External Services" {
  [Uniswap V2]
  [Price Oracles]
  [CPI Data Feed]
}

SC --> CDPM : manages
SC --> MSW : controls
SC --> PSM : stabilizes

PS --> AM : uses
PS --> SC : simulates

RA --> W3C : uses
W3C --> SC : interacts

DS --> SC : deploys
MS --> SC : monitors
LB --> CDPM : liquidates

SC --> [Uniswap V2] : integrates
PSM --> [Price Oracles] : fetches data
PSM --> [CPI Data Feed] : fetches data

@enduml