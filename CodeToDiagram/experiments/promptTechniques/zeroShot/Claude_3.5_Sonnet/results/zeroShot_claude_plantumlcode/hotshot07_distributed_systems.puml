@startuml

node "Kubernetes Cluster" {
  [React UI] as ui
  [Authentication Service] as auth
  [Account Management Service] as account
  [Athlete Availability Service] as availability
  [Test Scheduling Service] as scheduling
  [Results Reporting Service] as reporting
}

database "DynamoDB" as dynamodb

cloud "AWS" {
  [EKS] as eks
}

cloud "CI/CD" {
  [GitHub Actions] as ghactions
}

ui -down-> auth : HTTPS
ui -down-> account : HTTPS
ui -down-> availability : HTTPS
ui -down-> scheduling : HTTPS
ui -down-> reporting : HTTPS

auth --> dynamodb : Read/Write
account --> dynamodb : Read/Write
availability --> dynamodb : Read/Write
scheduling --> dynamodb : Read/Write
reporting --> dynamodb : Read/Write

eks -up-> [Kubernetes Cluster] : Manages

ghactions -right-> eks : Deploys to

@enduml