@startuml Scientific-Computing-Lab-NRCN_compar

component "ComPar System" {
    [GUI Framework] as GUI
    [Compiler Abstraction] as CA
    [Parallelization Tools] as PT
    [Code Instrumentation] as CI
    [Runtime Analysis] as RA
    [Slurm Job Management] as SJM
    [Output Validation] as OV
    [Database Interaction] as DI
    [Combination Generator] as CG
    [Subprocess Handler] as SH
}

[CodeMirror] as CM

GUI --> CA : configures
GUI --> PT : selects
GUI --> CG : sets parameters
GUI --> CM : integrates

CA --> PT : uses
CA --> CI : applies
CA --> SH : executes

PT --> CI : modifies code

CI --> RA : enables measurement
CI --> OV : adds checkpoints

RA --> SJM : submits jobs
RA --> DI : stores results

SJM --> OV : triggers

CG --> CA : provides combinations
CG --> DI : stores combinations

@enduml