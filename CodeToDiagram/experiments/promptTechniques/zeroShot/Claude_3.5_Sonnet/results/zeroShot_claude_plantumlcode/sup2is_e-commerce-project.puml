Here's a PlantUML component diagram that captures the static architecture of the e-commerce project, focusing on deployment and connectivity:

```plantuml
@startuml sup2is_e-commerce-project

!define RECTANGLE class

skinparam component {
  BackgroundColor<<external>> LightGray
  BorderColor<<external>> Gray
}

cloud "E-Commerce Platform" {
  [API Gateway] as gateway
  [Config Server] as config
  [Eureka Server] as eureka
  
  package "Microservices" {
    [Member Service] as member
    [Order Service] as order
    [Product Service] as product
    [Authentication Service] as auth
  }
  
  database "MySQL" as mysql
  database "Redis" as redis
  queue "Kafka" as kafka <<external>>
  
  [Zipkin] as zipkin <<external>>
}

[External Clients] as clients <<external>>

clients --> gateway : HTTPS

gateway --> member
gateway --> order
gateway --> product
gateway --> auth

member --> eureka : register/discover
order --> eureka : register/discover
product --> eureka : register/discover
auth --> eureka : register/discover

member --> config : fetch config
order --> config : fetch config
product --> config : fetch config
auth --> config : fetch config

member --> mysql : persist data
order --> mysql : persist data
product --> mysql : persist data
auth --> mysql : persist data

member --> redis : cache data
product --> redis : cache data

product --> kafka : publish events

order ..> product : Feign Client

gateway --> zipkin : send traces
member --> zipkin : send traces
order --> zipkin : send traces
product --> zipkin : send traces
auth --> zipkin : send traces

@enduml
```