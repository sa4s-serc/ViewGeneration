@startuml oracle-quickstart_oci-jenkins

!define RECTANGLE class

skinparam component {
  BackgroundColor<<OCI>> LightBlue
  BorderColor<<OCI>> Blue
}

rectangle "Oracle Cloud Infrastructure" {
  [VCN] <<OCI>>
  [Public Subnet] <<OCI>>
  [Private Subnet] <<OCI>>
  [Load Balancer] <<OCI>>
  [Internet Gateway] <<OCI>>
  [NAT Gateway] <<OCI>>
  [Bastion Service/Host] <<OCI>>
  
  component "Jenkins Controller" {
    [Jenkins Master Instance] <<OCI>>
  }
  
  component "Jenkins Agents" {
    [Agent Instance 1] <<OCI>>
    [Agent Instance 2] <<OCI>>
    [Agent Instance N] <<OCI>>
  }
}

cloud Internet

[Terraform] --> [VCN] : provisions
[Terraform] --> [Public Subnet] : provisions
[Terraform] --> [Private Subnet] : provisions
[Terraform] --> [Load Balancer] : provisions
[Terraform] --> [Internet Gateway] : provisions
[Terraform] --> [NAT Gateway] : provisions
[Terraform] --> [Bastion Service/Host] : provisions
[Terraform] --> [Jenkins Master Instance] : provisions
[Terraform] --> [Agent Instance 1] : provisions
[Terraform] --> [Agent Instance 2] : provisions
[Terraform] --> [Agent Instance N] : provisions

Internet --> [Load Balancer] : HTTPS
[Load Balancer] --> [Jenkins Master Instance] : routes traffic
[Jenkins Master Instance] --> [Agent Instance 1] : manages
[Jenkins Master Instance] --> [Agent Instance 2] : manages
[Jenkins Master Instance] --> [Agent Instance N] : manages

[Bastion Service/Host] --> [Jenkins Master Instance] : SSH access
[Bastion Service/Host] --> [Agent Instance 1] : SSH access
[Bastion Service/Host] --> [Agent Instance 2] : SSH access
[Bastion Service/Host] --> [Agent Instance N] : SSH access

[Jenkins Master Instance] --> [NAT Gateway] : outbound traffic
[Agent Instance 1] --> [NAT Gateway] : outbound traffic
[Agent Instance 2] --> [NAT Gateway] : outbound traffic
[Agent Instance N] --> [NAT Gateway] : outbound traffic

[NAT Gateway] --> Internet : outbound traffic

@enduml
