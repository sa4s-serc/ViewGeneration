@startuml serverdevcamp_camp4_quadcore

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<Database>> Yellow
  BackgroundColor<<MessageBroker>> Orange
}

component "React Frontend" <<Frontend>> as Frontend
component "API Gateway" as APIGateway
component "Auth Front" as AuthFront
component "Auth Server" as AuthServer
component "Data Pipeline" as DataPipeline
component "Data Processing" as DataProcessing
component "Data Sending" as DataSending
component "User Activity" as UserActivity
component "Kafka" <<MessageBroker>> as Kafka
component "Cassandra" <<Database>> as Cassandra
component "Redis" <<Database>> as Redis
component "Spark" as Spark
component "Twitter API" as TwitterAPI

Frontend --> APIGateway : HTTP/WebSocket
APIGateway --> AuthFront : Route auth requests
APIGateway --> AuthServer : Validate JWT
APIGateway --> DataSending : Route data requests
APIGateway --> UserActivity : Route user activity

AuthServer --> Redis : Store refresh tokens
AuthServer --> Cassandra : Store user data

DataPipeline --> TwitterAPI : Fetch real-time data
DataPipeline --> Kafka : Publish tweet data

Kafka --> DataProcessing : Consume tweet data
DataProcessing --> Spark : Process data
Spark --> Cassandra : Store processed data

DataSending --> Cassandra : Fetch processed data
DataSending --> Frontend : Send real-time updates (WebSocket)

UserActivity --> Cassandra : Store/retrieve user activity

@enduml