@startuml bianjieai_tibc

!define RECTANGLE class

RECTANGLE "TIBC Core Protocol" as Core {
    [Client Semantics]
    [Port & Packet Semantics]
    [Host Environments]
    [Packet Routing]
}

RECTANGLE "Client Implementations" as Clients {
    [Tendermint Client]
    [BSC Client]
    [Ethereum Client]
}

RECTANGLE "Relayer Algorithms" as Relayer

RECTANGLE "NFT Transfer Application" as NFTApp

RECTANGLE "Routing Module" as Router

Core --> Clients : uses
Core --> Relayer : facilitates
Core --> NFTApp : supports
Core --> Router : integrates

Relayer --> Clients : updates
Relayer --> Router : interacts with

NFTApp --> Router : uses for packet routing

Router --> Clients : routes to appropriate client

@enduml