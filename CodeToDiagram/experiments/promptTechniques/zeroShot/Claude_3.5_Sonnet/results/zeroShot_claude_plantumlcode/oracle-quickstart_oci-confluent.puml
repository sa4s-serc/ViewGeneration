@startuml oracle-quickstart_oci-confluent

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Security>> LightYellow
  BorderColor<<Security>> Orange
}

cloud "Oracle Cloud Infrastructure" {
  [Virtual Cloud Network] as VCN
  
  package "Confluent Platform" {
    [Kafka Brokers] as Brokers
    [Zookeeper]
    [Schema Registry]
    [REST Proxy]
    [Kafka Connect] as Connect
    [KSQL]
    [Control Center]
  }
  
  database "Oracle Object Storage" as OOS
  database "Autonomous Database" as ADB
  
  RECTANGLE "Security Components" <<Security>> {
    [IAM]
    [Security Lists]
    [Network Security Groups]
  }
}

node "Terraform" {
  [OCI Provider]
  [Resource Modules]
}

Terraform --> VCN : deploys
Terraform --> Brokers : deploys
Terraform --> Zookeeper : deploys
Terraform --> [Schema Registry] : deploys
Terraform --> [REST Proxy] : deploys
Terraform --> Connect : deploys
Terraform --> KSQL : deploys
Terraform --> [Control Center] : deploys

VCN --> [Security Lists] : configures
VCN --> [Network Security Groups] : configures

Connect --> OOS : writes data to
Connect --> ADB : writes data to

IAM --> Brokers : manages access
IAM --> Zookeeper : manages access
IAM --> [Schema Registry] : manages access
IAM --> [REST Proxy] : manages access
IAM --> Connect : manages access
IAM --> KSQL : manages access
IAM --> [Control Center] : manages access

note right of ADB
  Secure connection
  using wallet files
end note

note bottom of [Security Components]
  Ensures secure deployment
  and communication
end note

@enduml