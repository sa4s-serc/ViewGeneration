@startuml
participant "S3" as S3
participant "CSV Ingestion Lambda" as IngestLambda
participant "SQS" as SQS
participant "Data Processing Lambda" as ProcessLambda
participant "DynamoDB" as DynamoDB
participant "API Gateway" as APIGateway

S3 -> IngestLambda : Trigger (New CSV file)
activate IngestLambda
IngestLambda -> IngestLambda : Read CSV file
IngestLambda -> IngestLambda : Split into messages
loop for each message
    IngestLambda -> SQS : Send message
end
deactivate IngestLambda

SQS -> ProcessLambda : Trigger (New message)
activate ProcessLambda
ProcessLambda -> ProcessLambda : Process BIN data
ProcessLambda -> DynamoDB : Store processed data
deactivate ProcessLambda

APIGateway -> DynamoDB : Query BIN data
DynamoDB --> APIGateway : Return BIN data
@enduml