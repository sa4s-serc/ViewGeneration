@startuml kryptokrauts_ae-prediction-cards

actor User
participant Frontend
participant WalletClient
participant PredictionCardsApi
participant AeternityBlockchain
participant SmartContract
participant OracleService
participant ProcessPredictionService

User -> Frontend: Create prediction
Frontend -> WalletClient: Connect wallet
WalletClient -> AeternityBlockchain: Authenticate
Frontend -> PredictionCardsApi: Call create_prediction
PredictionCardsApi -> SmartContract: Execute create_prediction
SmartContract -> AeternityBlockchain: Store prediction data

User -> Frontend: Rent NFT
Frontend -> PredictionCardsApi: Call rent_nft
PredictionCardsApi -> SmartContract: Execute rent_nft
SmartContract -> AeternityBlockchain: Update NFT rental status

loop Scheduled task
    ProcessPredictionService -> AeternityBlockchain: Check for closed predictions
    alt Prediction closed
        ProcessPredictionService -> OracleService: Request asset price
        OracleService -> AeternityBlockchain: Query external data source
        AeternityBlockchain --> OracleService: Return asset price
        OracleService --> ProcessPredictionService: Provide asset price
        ProcessPredictionService -> SmartContract: Call process_oracle_response
        SmartContract -> AeternityBlockchain: Update prediction outcome
    end
end

User -> Frontend: Claim reward
Frontend -> PredictionCardsApi: Call claim
PredictionCardsApi -> SmartContract: Execute claim
SmartContract -> AeternityBlockchain: Transfer rewards
AeternityBlockchain --> User: Receive rewards

@enduml