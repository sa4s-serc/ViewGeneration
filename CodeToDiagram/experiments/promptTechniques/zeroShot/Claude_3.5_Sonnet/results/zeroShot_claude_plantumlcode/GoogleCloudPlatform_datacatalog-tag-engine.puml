@startuml GoogleCloudPlatform_datacatalog-tag-engine

!define GCP https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

!includeurl GCP

node "Google Cloud Platform" {
    component "Cloud Run" {
        [API Service] as api
        [UI Service] as ui
    }
    
    database "Firestore" as firestore
    database "Cloud Storage" as gcs
    database "BigQuery" as bigquery
    queue "Cloud Tasks" as tasks
    
    component "Data Catalog" as datacatalog
    component "Dataplex" as dataplex
}

api --> firestore : Reads/writes configurations
api --> gcs : Reads CSV files
api --> bigquery : Writes tag history
api --> tasks : Creates tasks
api --> datacatalog : Manages tags
api --> dataplex : Manages aspects

ui --> firestore : Reads configurations
ui --> tasks : Checks job status

tasks --> api : Triggers tag operations

@enduml