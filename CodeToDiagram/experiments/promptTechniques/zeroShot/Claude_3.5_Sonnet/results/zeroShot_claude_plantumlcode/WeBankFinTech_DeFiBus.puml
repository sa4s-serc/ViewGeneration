Here's a PlantUML component diagram for the DeFiBus system, focusing on deployment and connectivity:

```plantuml
@startuml WeBankFinTech_DeFiBus

!define RECTANGLE class

skinparam component {
  BackgroundColor<<external>> LightGray
  BorderColor<<external>> Gray
}

rectangle "DeFiBus Broker" {
  [DeFiBrokerController] as controller
  [DeFiSendMessageProcessor] as sendProcessor
  [DeFiReplyMessageProcessor] as replyProcessor
  [DeFiPullMessageProcessor] as pullProcessor
  [ConsumeQueueManager] as queueManager
  [MessageRedirectManager] as redirectManager
  [DeFiPluginMessageStore] as messageStore
  [DeFiConsumerManager] as consumerManager
  [DeFiProducerManager] as producerManager
}

rectangle "External Components" {
  [Apache RocketMQ]<<external>>
  [Client Applications]<<external>>
}

cloud "Network" {
  [Load Balancer]
}

controller -down-> sendProcessor
controller -down-> replyProcessor
controller -down-> pullProcessor
controller -down-> queueManager
controller -down-> redirectManager
controller -down-> messageStore
controller -down-> consumerManager
controller -down-> producerManager

sendProcessor -down-> messageStore
replyProcessor -down-> messageStore
pullProcessor -down-> messageStore

queueManager -right-> messageStore
redirectManager -left-> messageStore

consumerManager -up-> controller
producerManager -up-> controller

[Apache RocketMQ] -up-> controller : extends

[Load Balancer] -down-> controller : routes requests

[Client Applications] -down-> [Load Balancer] : connects

@enduml
```