@startuml

participant "Frontend (React)" as FE
participant "Backend (FastAPI)" as BE
participant "Elasticsearch" as ES
participant "LyricsGenius API" as LG
participant "CNN Model" as CNN

FE -> BE: User inputs song and artist
BE -> ES: Check if lyrics exist
alt Lyrics not found in Elasticsearch
    BE -> LG: Request lyrics
    LG --> BE: Return lyrics
    BE -> BE: Preprocess lyrics
    BE -> CNN: Classify sentiment
    BE -> ES: Store lyrics and sentiment
else Lyrics found in Elasticsearch
    ES --> BE: Return lyrics and sentiment
end
BE -> ES: Query for similar songs
ES --> BE: Return potential similar songs
BE -> BE: Calculate cosine similarity
BE --> FE: Return sentiment and similar songs
FE -> FE: Display results to user

@enduml