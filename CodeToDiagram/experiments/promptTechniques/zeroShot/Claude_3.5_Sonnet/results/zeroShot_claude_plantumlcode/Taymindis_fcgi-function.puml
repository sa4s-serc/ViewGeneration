@startuml Taymindis_fcgi-function

!define RECTANGLE class

RECTANGLE "FastCGI Server" as FCGI
RECTANGLE "ffunc Framework" as FFUNC {
    RECTANGLE "Function Mapping" as MAPPING
    RECTANGLE "Request Handler" as HANDLER
    RECTANGLE "Memory Pool" as POOL
    RECTANGLE "Thread Management" as THREAD
}
RECTANGLE "User-Defined Functions" as UDF

FCGI --> FFUNC : HTTP Requests
FFUNC --> UDF : Invoke

MAPPING --> HANDLER : Select Handler
HANDLER --> POOL : Allocate/Deallocate
HANDLER --> THREAD : Manage Threads
HANDLER --> UDF : Execute

note right of MAPPING
  Maps FN_HANDLER
  to C/C++ functions
end note

note right of HANDLER
  Processes requests
  Manages control flow
end note

note right of POOL
  Efficient memory
  management
end note

note right of THREAD
  Concurrent request
  handling
end note

@enduml