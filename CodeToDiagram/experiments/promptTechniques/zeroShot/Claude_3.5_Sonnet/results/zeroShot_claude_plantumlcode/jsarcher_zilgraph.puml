```plantuml
@startuml jsarcher_zilgraph

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<Database>> Yellow
  BackgroundColor<<External>> LightGray
}

cloud "Zilliqa Blockchain" as blockchain

component "Zilcrawler" as crawler <<Backend>>
component "Data Aggregator" as aggregator <<Backend>>
component "Zilgraph Oracle" as oracle <<Backend>>
component "Bokeh Server" as bokeh <<Frontend>>
component "Kibana" as kibana <<Frontend>>

database "Elasticsearch" as elastic <<Database>>
database "MongoDB" as mongo <<Database>>

[Nginx Reverse Proxy] as nginx <<Backend>>

blockchain --> crawler : Fetch transaction data
crawler --> elastic : Store raw data
elastic --> aggregator : Query data
aggregator --> mongo : Store aggregated data
mongo --> bokeh : Fetch data for visualization
elastic --> kibana : Query for analytics
oracle --> blockchain : Provide aggregated data

nginx --> bokeh : Route requests
nginx --> kibana : Route requests

note right of nginx
  SSL termination
  Load balancing
  Security
end note

note bottom of elastic
  Data lake for
  flexible querying
end note

note bottom of mongo
  Data warehouse for
  optimized access
end note

@enduml
```