@startuml
participant "EventBridge" as EB
participant "index-transaction-ids Lambda" as ITI
participant "SNS Topic" as SNS
participant "SQS Queue" as SQS
participant "download-raw-transaction Lambda" as DRT
participant "Raw Transactions DynamoDB" as RawDB
participant "DynamoDB Stream" as Stream
participant "normalize-raw-transaction Lambda" as NRT
participant "Normalized Transactions DynamoDB" as NormDB

EB -> ITI : Trigger (Scheduled)
activate ITI
ITI -> ITI : Fetch transaction IDs from Solscan
ITI -> SNS : Publish transaction hashes
deactivate ITI

SNS -> SQS : Fan-out transaction hashes

SQS -> DRT : Consume transaction hash
activate DRT
DRT -> DRT : Fetch raw transaction from Solscan
DRT -> RawDB : Store raw transaction
deactivate DRT

RawDB -> Stream : Trigger stream event
Stream -> NRT : Invoke
activate NRT
NRT -> RawDB : Fetch raw transaction
NRT -> NRT : Normalize transaction data
NRT -> NormDB : Store normalized transaction
deactivate NRT
@enduml