@startuml alexandredev3_nodejs-clean-architeture

!define RECTANGLE class

RECTANGLE "API Layer" as API {
    [Express Router]
    [Controllers]
    [Middleware]
}

RECTANGLE "Business Logic" as BL {
    [User Services]
    [Authentication Service]
}

RECTANGLE "Data Access" as DA {
    [User Repository]
    [TypeORM]
}

RECTANGLE "Infrastructure" as INFRA {
    [Redis Cache]
    [Postgres Database]
}

RECTANGLE "Shared" as SHARED {
    [Error Handling]
    [Dependency Injection]
    [Config]
}

API --> BL : uses
BL --> DA : uses
DA --> INFRA : interacts with
BL ..> INFRA : caches data
API ..> SHARED : utilizes
BL ..> SHARED : utilizes
DA ..> SHARED : utilizes

@enduml