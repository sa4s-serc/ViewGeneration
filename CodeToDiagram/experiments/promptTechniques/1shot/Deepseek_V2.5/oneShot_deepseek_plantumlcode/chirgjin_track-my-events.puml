@startuml chirgjin_track-my-events
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as User
actor "Client Application" as ClientApp

rectangle "Frontend" as Frontend {
}

rectangle "Gateway Service" as Gateway #lightblue

rectangle "User Service" as UserService #palegreen

rectangle "Tracking Service" as TrackingService #lightyellow

rectangle "Redis" as Redis #mistyrose

rectangle "PostgreSQL" as DB #aliceblue

' ========== Connections ==========
User --> Frontend : Login/Register\nView Dashboard
ClientApp --> Frontend : Integrate SDK

Frontend --> Gateway : API Requests\n(with auth tokens)
Gateway --> UserService : Forward auth/user requests
Gateway --> TrackingService : Forward event requests
Gateway <--> Redis : Publish events (async)

TrackingService <--> Redis : Subscribe to events
TrackingService --> DB : Store event data
UserService --> DB : Store user data

ClientApp --> TrackingService : Send events (via SDK)
@enduml