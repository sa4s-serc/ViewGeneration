@startuml UoA-eResearch_hub-stack
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Developer" as Dev

rectangle "Git Repository" as Git

rectangle "Jenkins CI/CD" as Jenkins

rectangle "Terraform" as Terraform

rectangle "AWS" as AWS {
  rectangle "S3" as S3
  rectangle "CloudFront" as CloudFront
  rectangle "Lambda" as Lambda
  rectangle "ECS/ECR" as ECR
  rectangle "ElasticSearch" as ES
}

rectangle "Contentful" as Contentful

rectangle "ResearchHub Frontend" as Frontend

rectangle "Users" as Users

' ========== Connections ==========
Dev --> Git : Push code changes
Git --> Jenkins : Trigger pipeline
Jenkins --> Terraform : Apply infrastructure changes
Terraform --> AWS : Provision resources
Jenkins --> Frontend : Build & deploy Angular app
Frontend --> CloudFront : Serve static assets
Frontend --> Lambda : Search requests
Lambda --> ES : Query search index
Frontend --> ECR : API requests
ECR --> Contentful : Fetch content via GraphQL
Frontend --> Users : User interaction
@enduml