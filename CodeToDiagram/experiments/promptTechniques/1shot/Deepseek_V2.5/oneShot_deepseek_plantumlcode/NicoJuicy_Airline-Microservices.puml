@startuml NicoJuicy_Airline-Microservices
skinparam rectangle {
  BackgroundColor<<gateway>> #d9e7fd
  BackgroundColor<<service>> #d8f5d3
  BackgroundColor<<shared>> #fff1c9
  BackgroundColor<<infra>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "API Gateway (YARP)" <<gateway>> as Gateway

package "Microservices" <<service>> {
  rectangle "Identity Service" as Identity
  rectangle "Flight Service" as Flight
  rectangle "Passenger Service" as Passenger
  rectangle "Reservation Service" as Reservation
}

package "Shared Components" <<shared>> {
  rectangle "Building Blocks" as Blocks
  rectangle "Domain Models" as Models
  rectangle "CQRS" as CQRS
  rectangle "MediatR" as MediatR
}

package "Infrastructure" <<infra>> {
  rectangle "RabbitMQ" as RabbitMQ
  rectangle "MassTransit" as MassTransit
  rectangle "Docker" as Docker
  rectangle "Kubernetes" as Kubernetes
}

Gateway --> Identity
Gateway --> Flight
Gateway --> Passenger
Gateway --> Reservation

Identity --> Blocks
Flight --> Blocks
Passenger --> Blocks
Reservation --> Blocks

Blocks --> Models
Blocks --> CQRS
Blocks --> MediatR

Identity --> RabbitMQ
Flight --> RabbitMQ
Passenger --> RabbitMQ
Reservation --> RabbitMQ

RabbitMQ --> MassTransit

Identity --> Docker
Flight --> Docker
Passenger --> Docker
Reservation --> Docker
Docker --> Kubernetes
@enduml