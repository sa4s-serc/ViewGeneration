@startuml philipplackner_IvyWallet-PL_Version
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "UI Layer (Jetpack Compose)" <<ui>> {
  rectangle "Compose Screens" as Screens
  rectangle "ViewModels" as ViewModels
  rectangle "Design System" as DesignSystem
  Screens --> ViewModels
  ViewModels --> DesignSystem
}

package "Domain Layer" <<domain>> {
  rectangle "Actions" as Actions
  rectangle "Flows" as Flows
  rectangle "Use Cases" as UseCases
  Actions --> Flows
  Flows --> UseCases
}

package "Data Layer" <<data>> {
  rectangle "Repositories" as Repos
  rectangle "DTOs" as DTOs
  rectangle "Room DB" as RoomDB
  Repos --> DTOs
  DTOs --> RoomDB
}

package "External Services" <<external>> {
  rectangle "Google Drive" as Drive
  rectangle "Exchange Rate API" as ExchangeAPI
  rectangle "File System" as FileSystem
}

ViewModels --> Actions
UseCases --> Repos
Repos --> Drive
Repos --> ExchangeAPI
Repos --> FileSystem

@enduml