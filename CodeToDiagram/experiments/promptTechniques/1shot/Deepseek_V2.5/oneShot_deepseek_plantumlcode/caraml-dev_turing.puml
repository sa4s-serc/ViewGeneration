@startuml caraml-dev_turing
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Python SDK" as SDK {
}

rectangle "Turing API" as API {
}

rectangle "Router Engine" as Router {
}

rectangle "Experiment Engine" as Experiment {
}

rectangle "Batch Ensembler" as Batch {
}

rectangle "Kubernetes" as K8s {
  rectangle "Spark" as Spark
  rectangle "Monitoring" as Monitoring
}

rectangle "External Services" as External {
  rectangle "Merlin" as Merlin
  rectangle "MLP" as MLP
  rectangle "Prometheus" as Prometheus
}

' ========== Connections ==========
User --> SDK : Submit ML experiment\nManage routers/ensemblers\nMonitor jobs

SDK --> API : REST API calls\n(OpenAPI spec)

API --> Router : Create/update/deploy\nrouter configurations
API --> Experiment : Register/retrieve\nexperiment runners
API --> Batch : Submit batch jobs\nMonitor status

Router --> Experiment : Get experiment\nconfiguration
Router --> K8s : Deploy router\nservices

Experiment --> External : Integrate with\nexperiment engines

Batch --> K8s : Submit Spark jobs\nMonitor progress
Batch --> External : Access data sources

K8s --> Monitoring : Collect metrics\nand logs
Monitoring --> Prometheus : Store and\nquery metrics

External --> Merlin : Model deployment\nand serving
External --> MLP : Project management\nand metadata
@enduml