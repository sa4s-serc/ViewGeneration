@startuml exmgr_GatewayXM
skinparam rectangle {
  BackgroundColor<<gateway>> #d9e7fd
  BackgroundColor<<sensor>> #d8f5d3
  BackgroundColor<<platform>> #fddddd
  BackgroundColor<<cloud>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "GatewayXM" <<gateway>> {
  rectangle "Eclipse Kura" as Kura
  rectangle "Agile-Stack" as AgileStack
  rectangle "Kura-TB Bundle" as KuraTB
  rectangle "Artemis MQTT" as MQTT
  rectangle "Docker Container" as Docker
  Kura --> AgileStack
  Kura --> KuraTB
  KuraTB --> MQTT
  Kura --> Docker
}

package "Sensor Nodes" <<sensor>> {
  rectangle "ESP8266/ESP32" as ESP
  rectangle "ModBus Devices" as ModBus
  rectangle "Mesh Network" as Mesh
  ESP --> Mesh
  ModBus --> Mesh
}

package "Cloud Platform" <<cloud>> {
  rectangle "Thingsboard" as TB
  rectangle "Resin.io" as Resin
  rectangle "OTA Updates" as OTA
  TB --> OTA
  Resin --> OTA
}

Mesh --> MQTT
MQTT --> TB
Docker --> Resin
@enduml