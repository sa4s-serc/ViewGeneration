@startuml RunnersHi_RunnersHi_Server
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Mobile Client" as Client

rectangle "Express Server" as Server {
  rectangle "Routes" as Routes
  rectangle "Controllers" as Controllers
  rectangle "Middleware" as Middleware
  rectangle "Socket.IO" as SocketIO
}

rectangle "MySQL Database" as DB

rectangle "External Services" as External {
  rectangle "JWT Auth" as JWT
  rectangle "bcrypt" as Bcrypt
}

' ========== Connections ==========
Client -> Routes : HTTP Requests (REST API)
Client <-> SocketIO : WebSocket (Real-time)

Routes -> Controllers : Route requests
Controllers -> Middleware : Auth/Error handling
Middleware -> JWT : Token verification
Middleware -> Bcrypt : Password hashing

Controllers -> DB : CRUD Operations\n(User, Records, Rankings)
Controllers <-> SocketIO : Match requests/results

SocketIO -> DB : Store running data
SocketIO -> Controllers : Match updates

DB --> Controllers : Query results
DB --> SocketIO : Match data
@enduml