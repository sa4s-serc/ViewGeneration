@startuml gustavung_Graphrec
skinparam rectangle {
  BackgroundColor<<mobile>> #d9e7fd
  BackgroundColor<<server>> #d8f5d3
  BackgroundColor<<ml>> #fddddd
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Mobile Client (Android)" <<mobile>> {
  rectangle "MainActivity" as Main
  rectangle "CameraActivity" as Camera
  rectangle "ResultActivity" as Result
  rectangle "ImageUploadTask" as Upload
  rectangle "CameraPreview" as Preview
  rectangle "UI Layouts" as UI
  
  Main --> Camera
  Camera --> Preview
  Camera --> Upload
  Upload --> Result
  Result --> UI
}

package "Flask Server" <<server>> {
  rectangle "server.py" as FlaskServer
  rectangle "graph_classifier.py" as Classifier
  rectangle "graph_images.py" as ImageProcessor
  
  FlaskServer --> Classifier
  Classifier --> ImageProcessor
}

package "Machine Learning" <<ml>> {
  rectangle "CNN Model" as CNN
  rectangle "Training Pipeline" as Training
  
  Classifier --> CNN
  CNN --> Training
}

package "Data Generation" <<data>> {
  rectangle "generate_data.py" as DataGen
  rectangle "Synthetic Graphs" as SyntheticData
  
  Training --> DataGen
  DataGen --> SyntheticData
}

Main --> FlaskServer : HTTP POST
FlaskServer --> Result : JSON Response
@enduml