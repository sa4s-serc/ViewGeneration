@startuml adityajain10_foot365-live-streaming-chatbot-prediction-app-on-aws
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
}

rectangle "API Gateway" as APIGW #lightblue

rectangle "Lambda Functions" as Lambda #palegreen {
  rectangle "standings.py" as Standings
  rectangle "predictions.py" as Predictions
  rectangle "LF2.py" as LF2
  rectangle "getFixtures.py" as GetFixtures
  rectangle "scrapeMatchData.py" as ScrapeMatch
  rectangle "getScore.py" as GetScore
  rectangle "LF1.py" as LF1
  rectangle "getLiveScores.py" as GetLiveScores
}

rectangle "AWS Services" as AWS {
  rectangle "DynamoDB" as DynamoDB #lightyellow
  rectangle "ElasticSearch" as ES #aliceblue
  rectangle "SageMaker" as SageMaker #mistyrose
  rectangle "SQS" as SQS #peachpuff
  rectangle "SNS" as SNS #lavender
  rectangle "Lex" as Lex #wheat
}

rectangle "Kafka" as Kafka #lightsteelblue {
  rectangle "producer.js" as Producer
  rectangle "consumer.js" as Consumer
}

rectangle "External Football API" as FootballAPI #palegoldenrod

' ========== Connections ==========
User --> FE : Interacts with UI
FE --> APIGW : API calls
APIGW --> Lambda : Triggers functions

' Lambda interactions
Standings --> DynamoDB : Query standings
Predictions --> SageMaker : Get predictions
LF2 --> SQS : Process queue
LF2 --> SNS : Send SMS
GetFixtures --> ES : Query fixtures
ScrapeMatch --> DynamoDB : Store match data
GetScore --> ES : Query match data
GetScore --> DynamoDB : Get details
LF1 --> Lex : Handle intents
GetLiveScores --> DynamoDB : Query scores

' Kafka flow
FootballAPI --> Producer : Fetch data
Producer --> Kafka : Publish messages
Kafka --> Consumer : Consume messages
Consumer --> DynamoDB : Update data

' Event triggers
ScrapeMatch <-- S3 : JSON upload event
@enduml