@startuml anjuchamantha_EMonitor
skinparam rectangle {
  BackgroundColor<<sensors>> #d9e7fd
  BackgroundColor<<processing>> #d8f5d3
  BackgroundColor<<communication>> #fddddd
  BackgroundColor<<display>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Sensors" <<sensors>> {
  rectangle "DHT11\n(Temp/Humidity)" as DHT
  rectangle "BMP180/BMP085\n(Pressure)" as BMP
  rectangle "LDR\n(Light)" as LDR
}

package "Data Processing" <<processing>> {
  rectangle "Readings Module" as Readings
  rectangle "Utils Module\n(Mean/StdDev)" as Utils
  rectangle "XML Generator" as XML
  rectangle "Data Buffer" as Buffer
  Readings --> Utils
  Readings --> Buffer
  Utils --> XML
}

package "Communication" <<communication>> {
  rectangle "WiFi Module" as WiFi
  rectangle "HTTP Client" as HTTP
  rectangle "Email Client" as Email
  rectangle "NTP Client" as NTP
  WiFi --> HTTP
  WiFi --> NTP
  HTTP --> Email
}

package "Display" <<display>> {
  rectangle "OLED Module" as OLED
}

DHT --> Readings
BMP --> Readings
LDR --> Readings
Buffer --> HTTP
XML --> HTTP
WiFi --> OLED
HTTP --> OLED
Readings --> OLED
Email --> OLED
@enduml