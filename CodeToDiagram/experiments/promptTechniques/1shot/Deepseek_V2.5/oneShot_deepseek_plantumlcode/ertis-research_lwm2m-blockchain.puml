@startuml ertis-research_lwm2m-blockchain
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<blockchain>> #fddddd
  BackgroundColor<<lwm2m>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Angular)" <<frontend>> {
  rectangle "Anomaly Detection UI" as AnomalyUI
  rectangle "Client Management UI" as ClientUI
  rectangle "Login Component" as LoginUI
  rectangle "Auth Service" as AuthService
  AnomalyUI --> AuthService
  ClientUI --> AuthService
  LoginUI --> AuthService
}

package "Backend (Spring Boot)" <<backend>> {
  rectangle "REST Controllers" as Controllers
  rectangle "Business Services" as Services
  rectangle "Web3j Wrappers" as Web3j
  rectangle "JWT Middleware" as JWT
  Controllers --> Services
  Services --> Web3j
  Controllers --> JWT
}

package "Blockchain (Ethereum)" <<blockchain>> {
  rectangle "AnomalyStore" as AnomalyStore
  rectangle "UserStore" as UserStore
  rectangle "ClientStore" as ClientStore
  Web3j --> AnomalyStore
  Web3j --> UserStore
  Web3j --> ClientStore
}

package "LwM2M Components" <<lwm2m>> {
  rectangle "LwM2M Server" as LwM2MServer
  rectangle "Bootstrap Server" as BootstrapServer
  rectangle "LwM2M Client" as LwM2MClient
  LwM2MServer --> BootstrapServer
  BootstrapServer --> ClientStore
  LwM2MClient --> LwM2MServer
}

AnomalyUI --> Controllers
ClientUI --> Controllers
LoginUI --> Controllers
Services --> LwM2MServer
@enduml