@startuml solenya-group_solenya
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Browser" as Browser {
  rectangle "Component" as Component #palegreen
  rectangle "Virtual DOM" as VDOM #lightsteelblue
  rectangle "DOM" as DOM #lightyellow
}

rectangle "App" as App #mistyrose {
  rectangle "Router" as Router
  rectangle "Storage" as Storage
  rectangle "TimeTravel" as TimeTravel
}

rectangle "External Services" as Services #aliceblue {
  rectangle "Local Storage" as LocalStorage
  rectangle "Validation Service" as Validation
}

' ========== Connections ==========
User --> Browser : Interacts with UI

' Component interactions
Component --> VDOM : Generates\nvirtual DOM
VDOM --> DOM : Patches\nreal DOM
DOM --> User : Renders UI

' App interactions
Component <--> App : State management\nLifecycle events
App --> Router : Handles navigation
App --> Storage : Serialization\nDeserialization
App --> TimeTravel : Debugging\nState history

' External services
Storage --> LocalStorage : Persists state
Component --> Validation : Validates data

' Update cycle
Component -> Component : update()\nupdated event
@enduml