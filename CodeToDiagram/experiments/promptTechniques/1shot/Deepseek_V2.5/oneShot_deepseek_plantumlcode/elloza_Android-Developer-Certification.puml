@startuml elloza_Android-Developer-Certification
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<presentation>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<domain>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "UI Layer" <<ui>> {
  rectangle "MainActivity" as MainActivity
  rectangle "RibotsAdapter" as RibotsAdapter
}

package "Presentation Layer" <<presentation>> {
  rectangle "MainPresenter" as MainPresenter
}

package "Data Layer" <<data>> {
  rectangle "DataManager" as DataManager
  rectangle "SyncService" as SyncService
  rectangle "DatabaseHelper" as DatabaseHelper
  rectangle "RibotsService" as RibotsService
}

package "Domain Layer" <<domain>> {
  rectangle "Ribot Model" as RibotModel
  rectangle "Profile Model" as ProfileModel
}

MainActivity --> MainPresenter
MainPresenter --> DataManager
DataManager --> DatabaseHelper
DataManager --> RibotsService
DataManager --> SyncService
DatabaseHelper --> RibotModel
RibotsService --> RibotModel
RibotModel --> ProfileModel
MainActivity --> RibotsAdapter
RibotsAdapter --> RibotModel

note right of DataManager
  Uses Dagger 2 for DI
  RxJava for async operations
end note

note right of RibotsService
  Retrofit API interface
  for remote data
end note

note right of DatabaseHelper
  SQLite with SqlBrite
  for reactive DB
end note
@enduml