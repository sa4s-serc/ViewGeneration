@startuml alextanhongpin_node-rest
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<infra>> #d8f5d3
  BackgroundColor<<api>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "API Layer" <<api>> {
  rectangle "Express App" as Express
  rectangle "Routes" as Routes
  rectangle "Middleware" as Middleware
  Express --> Routes
  Express --> Middleware
}

package "Core Layer" <<core>> {
  rectangle "Food Service" as FoodService
  rectangle "Model" as Model
  rectangle "Helper" as Helper
  FoodService --> Model
  Model --> Helper
}

package "Infrastructure Layer" <<infra>> {
  rectangle "Store" as Store
  rectangle "Database" as Database
  rectangle "Config" as Config
  rectangle "Schema" as Schema
  Store --> Database
  Store --> Config
  Store --> Schema
}

database "MySQL" <<db>> as MySQL
Database --> MySQL

Routes --> FoodService
FoodService --> Store
Middleware --> Helper
Config --> Express
@enduml