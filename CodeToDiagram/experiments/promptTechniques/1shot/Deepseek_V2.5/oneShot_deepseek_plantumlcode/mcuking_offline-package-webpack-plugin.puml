@startuml mcuking_offline-package-webpack-plugin
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Webpack Compiler" as Webpack {
}

rectangle "OfflinePackagePlugin" as Plugin #palegreen {
}

rectangle "JSZip" as JSZip #lightsteelblue

rectangle "File System" as FS #aliceblue

' ========== Connections ==========
Webpack -> Plugin : emit phase
Plugin -> JSZip : create zip archive
Plugin -> FS : read assets
Plugin -> FS : write index.json
Plugin -> FS : write offline-package.zip
JSZip -> Plugin : zip buffer
@enduml