@startuml gaiax_fLibra
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (Nuxt.js)" as FE {
}

rectangle "Libra Network" as Libra #mistyrose {
}

rectangle "Ethereum Network" as Ethereum #palegreen {
  rectangle "Flibra.sol" as Contract
}

rectangle "Firestore" as Firestore #lightsteelblue

rectangle "Elasticsearch" as Elasticsearch #lightyellow

rectangle "IPFS" as IPFS #aliceblue

rectangle "Elasticsearch\nIntegration (Node.js)" as ESIntegration #lavender

' ========== Connections ==========
User --> FE

' Frontend interactions
FE <--> Libra : Transfer Libra coins\nCreate wallets
FE <--> Ethereum : Interact with smart contracts\n(create/edit items, reviews)
FE <--> Firestore : Store/retrieve user profiles\nitem details, reviews
FE <--> IPFS : Upload/download item images\nprofile pictures
FE <--> Elasticsearch : Search items by keyword/category

' Elasticsearch integration
ESIntegration --> Firestore : Listen for changes via onSnapshot
ESIntegration --> Elasticsearch : Update search index

' Blockchain interactions
Contract --> Firestore : (Optional) Store item/user data
@enduml