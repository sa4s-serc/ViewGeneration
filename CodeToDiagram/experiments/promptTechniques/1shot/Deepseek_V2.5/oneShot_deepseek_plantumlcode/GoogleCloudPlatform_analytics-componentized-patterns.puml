@startuml GoogleCloudPlatform_analytics-componentized-patterns
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Data Scientist" as DS

rectangle "Kubeflow Pipeline" as KFP {
}

rectangle "BigQuery ML" as BQML {
}

rectangle "Vertex AI" as Vertex {
  rectangle "Model Serving" as Serving
}

rectangle "Cloud Storage" as GCS {
}

rectangle "Dataflow" as DF {
}

rectangle "Custom ScaNN Service" as ScaNN {
}

rectangle "Google Ads API" as Ads {
}

rectangle "Datastore" as DS {
}

rectangle "Data Studio" as Viz {
}

' ========== Connections ==========
DS --> KFP : Triggers\nML Pipeline

KFP --> BQML : Trains model\n(Matrix Factorization,\nTime Series, etc.)
KFP --> DF : Processes data
KFP --> GCS : Stores model artifacts

BQML --> GCS : Exports embeddings
BQML --> Vertex : Deploys model

DF --> GCS : Writes processed data
DF --> DS : Stores metadata

GCS --> ScaNN : Provides embeddings
GCS --> Vertex : Provides model artifacts

Vertex --> Serving : Hosts model
Serving --> Ads : Activates lookalike audiences
Serving --> Viz : Visualizes results
Serving --> ScaNN : Queries real-time\nrecommendations

ScaNN --> DS : Retrieves item metadata
@enduml