@startuml abel-gr_warehouse-robot
skinparam rectangle {
  BackgroundColor<<unity>> #d9e7fd
  BackgroundColor<<coppelia>> #d8f5d3
  BackgroundColor<<web>> #fddddd
  BackgroundColor<<cloud>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Unity Simulation" <<unity>> {
  rectangle "Warehouse Prefabs" as Prefabs
  rectangle "Game Objects" as GameObjects
  rectangle "Unity Scripts" as UnityScripts
  Prefabs --> GameObjects
  GameObjects --> UnityScripts
}

package "CoppeliaSim" <<coppelia>> {
  rectangle "Robot Controller" as RobotController
  rectangle "Inverse Kinematics" as IK
  rectangle "OCR Pipeline" as OCR
  rectangle "Remote API" as RemoteAPI
  RobotController --> IK
  RobotController --> OCR
  RobotController --> RemoteAPI
}

package "Web Interface" <<web>> {
  rectangle "User Interface" as UI
  rectangle "Speech-to-Text" as STT
  rectangle "Audio Recorder" as Recorder
  UI --> STT
  STT --> Recorder
}

package "Cloud Services" <<cloud>> {
  rectangle "Google Cloud Functions" as GCF
  rectangle "Speech Processing" as SpeechProcessing
  GCF --> SpeechProcessing
}

UnityScripts --> RemoteAPI
STT --> GCF
@enduml