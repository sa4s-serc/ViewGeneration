@startuml ruoccofabrizio_azure-open-ai-embeddings-qna
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Streamlit Web App" as WebApp {
}

rectangle "Azure OpenAI Service" as OpenAI #lightblue {
  rectangle "Embeddings" as Embeddings #palegreen
  rectangle "GPT-3" as GPT3 #palegreen
}

rectangle "Vector Store" as VectorStore #mistyrose {
  rectangle "Azure Search" as AzureSearch #lightyellow
  rectangle "Redis" as Redis #lightyellow
  rectangle "PGVector" as PGVector #lightyellow
}

rectangle "Azure Functions" as Functions #lightsteelblue {
  rectangle "BatchStartProcessing" as BatchStart #aliceblue
  rectangle "BatchPushResults" as BatchPush #aliceblue
}

rectangle "Azure Storage" as Storage #aliceblue {
  rectangle "Blob Storage" as Blob #lightyellow
  rectangle "Queue" as Queue #lightyellow
}

' ========== Connections ==========
User --> WebApp : Ask question

' WebApp interactions
WebApp --> OpenAI : Generate embeddings for query
WebApp --> VectorStore : Search for similar documents
VectorStore --> WebApp : Return relevant chunks
WebApp --> GPT3 : Generate answer with context
GPT3 --> WebApp : Return generated answer

' Batch processing flow
BatchStart --> Queue : Add document processing message
Queue --> BatchPush : Trigger processing
BatchPush --> Blob : Read document
BatchPush --> OpenAI : Generate embeddings
BatchPush --> VectorStore : Store embeddings

' Vector store options
WebApp -[hidden]-> AzureSearch
WebApp -[hidden]-> Redis
WebApp -[hidden]-> PGVector
@enduml