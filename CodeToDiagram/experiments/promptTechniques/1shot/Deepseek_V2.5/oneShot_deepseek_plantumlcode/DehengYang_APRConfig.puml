@startuml DehengYang_APRConfig
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Developer" as Dev

rectangle "APRConfig Framework" as APR {
  rectangle "Dataset Handler" as Dataset
  rectangle "Fault Localizer\n(Gzoltar)" as Localizer
  rectangle "Patch Generator" as PatchGen
  rectangle "Patch Validator" as Validator
}

rectangle "Defects4J Benchmark" as Defects4J

rectangle "Java Program" as JavaProg

rectangle "Test Suite" as Tests

' ========== Connections ==========
Dev --> APR : Configure\nparameters

APR -> Defects4J : Load buggy\nprograms
APR -> JavaProg : Analyze\nsource code
APR -> Tests : Run test cases

Dataset -> Localizer : Provide bug\ndata
Localizer -> PatchGen : Report\nfault locations
PatchGen -> Validator : Generate\ncandidate patches
Validator -> Tests : Validate\npatches
Validator --> APR : Report\nvalid patches

Tests --> Localizer : Provide test\nresults
Tests --> Validator : Provide test\nresults

Defects4J --> Dataset : Provide\nbenchmark data
@enduml