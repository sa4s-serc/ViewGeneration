@startuml kansiris_Angular-Interview-Questions-Answers
skinparam rectangle {
  BackgroundColor<<content>> #d9e7fd
  BackgroundColor<<navigation>> #d8f5d3
  BackgroundColor<<examples>> #fddddd
  BackgroundColor<<legal>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Content" <<content>> {
  rectangle "Interview Questions" as Questions
  rectangle "Detailed Answers" as Answers
  Questions --> Answers
}

package "Supporting Elements" <<examples>> {
  rectangle "Code Examples" as Code
  rectangle "Practical Illustrations" as Illustrations
  Answers --> Code
  Code --> Illustrations
}

package "Navigation" <<navigation>> {
  rectangle "Table of Contents" as TOC
  rectangle "README Structure" as README
  rectangle "External Links" as Links
  TOC --> README
  README --> Links
}

package "Legal" <<legal>> {
  rectangle "Apache 2.0 License" as License
  rectangle "Usage Terms" as Terms
  License --> Terms
}

@enduml