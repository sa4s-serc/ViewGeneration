@startuml marmarek_qubes-app-u2f
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<protocol>> #fddddd
  BackgroundColor<<infra>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Browser VM (Frontend)" <<frontend>> {
  rectangle "CTAPHID Emulation" as HIDEmu
  rectangle "Qrexec Client" as QrexecClient
  HIDEmu --> QrexecClient
}

package "sys-usb VM (Backend)" <<backend>> {
  rectangle "Qrexec Server" as QrexecServer
  rectangle "USB Device Access" as USBAccess
  rectangle "Policy Enforcement" as Policy
  QrexecServer --> USBAccess
  QrexecServer --> Policy
}

package "Protocol Handlers" <<protocol>> {
  rectangle "CTAP1/U2F" as CTAP1
  rectangle "CTAP2" as CTAP2
  USBAccess --> CTAP1
  USBAccess --> CTAP2
}

package "Infrastructure" <<infra>> {
  rectangle "Systemd Services" as Systemd
  rectangle "Udev Rules" as Udev
  rectangle "Qrexec Policies" as QrexecPolicy
  Systemd --> QrexecServer
  Udev --> HIDEmu
  QrexecPolicy --> Policy
}

QrexecClient --[hidden]--> QrexecServer
@enduml