@startuml securesecrets_shadeswap
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<shared>> #d8f5d3
  BackgroundColor<<utility>> #fddddd
  BackgroundColor<<testing>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Contracts" <<core>> {
  rectangle "LP Token (SNIP-20)" as LPToken
  rectangle "Staking" as Staking
  rectangle "AMM Pair" as AMMPair
  rectangle "Factory" as Factory
  rectangle "Router" as Router
  rectangle "Admin" as Admin

  LPToken --> Staking
  Factory --> AMMPair
  Factory --> LPToken
  Router --> AMMPair
  Admin --> LPToken
  Admin --> Staking
  Admin --> AMMPair
  Admin --> Factory
  Admin --> Router
}

package "Shared Utilities" <<shared>> {
  rectangle "shadeswap-shared" as Shared
  Shared --> LPToken
  Shared --> Staking
  Shared --> AMMPair
  Shared --> Factory
  Shared --> Router
  Shared --> Admin
}

package "Utility" <<utility>> {
  rectangle "secret-toolkit" as Toolkit
  Toolkit --> LPToken
  Toolkit --> Staking
  Toolkit --> AMMPair
  Toolkit --> Factory
  Toolkit --> Router
}

package "Testing" <<testing>> {
  rectangle "multi_test" as MultiTest
  rectangle "network_integration" as Integration
  MultiTest --> LPToken
  MultiTest --> Staking
  MultiTest --> AMMPair
  Integration --> LPToken
  Integration --> Staking
  Integration --> AMMPair
}

note right of LPToken: Implements SNIP-20 standard\nwith deposit/redeem/transfer
note right of Staking: Manages LP token staking\nand reward distribution
note right of AMMPair: Handles token swaps\nand liquidity management
note right of Factory: Deploys/manages\nAMM Pairs & LP tokens
note right of Router: Facilitates\nmulti-hop swaps
@enduml