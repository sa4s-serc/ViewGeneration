@startuml libremfg_getting-started
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<database>> #fff1c9
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<monitoring>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "Libre Admin UI" as AdminUI
  rectangle "Grafana Dashboards" as Grafana
}

package "Backend Services" <<backend>> {
  rectangle "Libre Core" as Core
  rectangle "GraphQL Gateway" as Gateway
  rectangle "Workflow Engine" as Workflow
  rectangle "Data Providers" as DataProviders
  rectangle "GraphQL PubSub" as PubSub
}

package "Databases" <<database>> {
  database "Dgraph" as Dgraph
  database "InfluxDB" as InfluxDB
}

package "Integration" <<integration>> {
  rectangle "MQTT Broker (EMQX)" as MQTT
  rectangle "PackML Simulator" as PackML
}

package "Monitoring" <<monitoring>> {
  rectangle "Grafana Service" as GrafanaService
}

node "Docker Compose Deployment" {
  Core
  Gateway
  Workflow
  DataProviders
  PubSub
  Dgraph
  InfluxDB
  MQTT
  PackML
  GrafanaService
}

AdminUI --> Gateway
Grafana --> GrafanaService
GrafanaService --> InfluxDB

Core --> Gateway
Gateway --> Dgraph
Workflow --> Gateway
DataProviders --> MQTT
PubSub --> MQTT
MQTT --> PackML
@enduml