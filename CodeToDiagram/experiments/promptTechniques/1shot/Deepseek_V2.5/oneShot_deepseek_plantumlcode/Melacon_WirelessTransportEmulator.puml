@startuml Melacon_WirelessTransportEmulator
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<netconf>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Emulator" <<core>> {
  rectangle "Topology Manager" as Topology
  rectangle "Configuration Manager" as Config
  rectangle "Scripting Engine" as Scripting
  rectangle "CLI Interface (yangcli)" as CLI
  rectangle "Notification Handler" as Notifications
  Topology --> Config
  Config --> Scripting
  Scripting --> CLI
  CLI --> Notifications
}

package "NETCONF Server" <<netconf>> {
  rectangle "Session Manager" as Session
  rectangle "YANG Processor" as YANG
  rectangle "Data Validator" as Validator
  rectangle "SIL Callback" as SIL
  rectangle "XML Processor" as XML
  Session --> YANG
  YANG --> Validator
  Validator --> SIL
  SIL --> XML
  XML --> Session
}

package "Data Models" <<data>> {
  rectangle "YANG Models" as YANGModels
  rectangle "XML Configs" as XMLConfigs
  rectangle "MIB Definitions" as MIB
  YANGModels --> XMLConfigs
  XMLConfigs --> MIB
}

package "External Systems" <<external>> {
  rectangle "Docker Containers (NEs)" as Docker
  rectangle "SDN Controller" as SDN
  rectangle "SNMP Agent" as SNMP
  rectangle "Test Framework" as Tests
  Docker --> SDN
  SDN --> SNMP
  SNMP --> Tests
}

Topology --> Docker
Config --> YANGModels
YANG --> YANGModels
Validator --> XMLConfigs
SIL --> MIB
Notifications --> SNMP
CLI --> Session
Scripting --> XML
@enduml