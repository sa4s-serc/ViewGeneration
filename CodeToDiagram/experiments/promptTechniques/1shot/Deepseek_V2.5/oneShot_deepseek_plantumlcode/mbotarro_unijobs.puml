@startuml mbotarro_unijobs
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React Native)" <<frontend>> {
  rectangle "App Navigation\n(React Navigation)" as Navigation
  rectangle "Screens\n(Login, Feed, Profile)" as Screens
  rectangle "Components\n(Buttons, Cards)" as Components
  rectangle "Actions\n(API Calls)" as Actions
  rectangle "Constants\n(Styles, Colors)" as Constants
  Navigation --> Screens
  Screens --> Components
  Screens --> Actions
  Components --> Constants
}

package "Backend (Go)" <<backend>> {
  rectangle "Handlers\n(HTTP Request/Response)" as Handlers
  rectangle "Use Cases\n(Business Logic)" as UseCases
  rectangle "Data Access Layer\n(DAL)" as DAL
  rectangle "Models\n(Data Structures)" as Models
  Handlers --> UseCases
  UseCases --> DAL
  DAL --> Models
}

package "Integrations" <<integration>> {
  rectangle "Elasticsearch\n(Full-text Search)" as Elasticsearch
  rectangle "Docker\n(Containerization)" as Docker
  DAL --> Elasticsearch
  Handlers --> Docker
}

database "PostgreSQL" <<db>> as PostgreSQL
DAL --> PostgreSQL

database "External Auth Providers" <<db>> as AuthProviders
Actions --> AuthProviders
@enduml