@startuml mateuseap_apache-airflow
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<orchestration>> #d8f5d3
  BackgroundColor<<storage>> #fddddd
  BackgroundColor<<monitoring>> #fff1c9
  BackgroundColor<<deployment>> #e7d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Airflow" <<core>> {
  rectangle "Web Server" as Webserver
  rectangle "Scheduler" as Scheduler
  rectangle "Workers" as Workers
  rectangle "Metadata DB\n(PostgreSQL)" as MetadataDB
  Webserver --> MetadataDB
  Scheduler --> MetadataDB
  Workers --> MetadataDB
}

package "Orchestration" <<orchestration>> {
  rectangle "DAGs" as DAGs
  rectangle "Operators\n(Python, Bash, etc)" as Operators
  rectangle "Sensors\n(File, HTTP)" as Sensors
  rectangle "Task Instances" as Tasks
  DAGs --> Operators
  DAGs --> Sensors
  Operators --> Tasks
  Sensors --> Tasks
}

package "Data Storage" <<storage>> {
  rectangle "HDFS" as HDFS
  rectangle "Hive" as Hive
  rectangle "Spark" as Spark
  HDFS --> Hive
  Hive --> Spark
}

package "Monitoring" <<monitoring>> {
  rectangle "TIG Stack\n(Telegraf, InfluxDB, Grafana)" as TIG
  rectangle "ELK Stack\n(Elasticsearch, Logstash, Kibana)" as ELK
}

package "Deployment" <<deployment>> {
  rectangle "Docker\n(Compose, Images)" as Docker
  rectangle "Kubernetes\n(Manifests)" as Kubernetes
}

Workers --> HDFS
Workers --> Hive
Workers --> Spark
DAGs --> Workers
Tasks --> Workers
Webserver --> TIG
Webserver --> ELK
Docker --> Webserver
Docker --> Scheduler
Docker --> Workers
Kubernetes --> Webserver
Kubernetes --> Scheduler
Kubernetes --> Workers
@enduml