@startuml IBM_vpc-flowlogs-log-analysis
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "IBM Cloud Object Storage (COS)" as COS #aliceblue {
}

rectangle "Serverless Function" as Function #lightsteelblue {
  rectangle "handler.js" as Handler #palegreen
  rectangle "index.js" as Index #lightyellow
}

rectangle "IBM Log Analysis" as LogAnalysis #mistyrose

rectangle "Archive COS Bucket" as Archive #aliceblue

' ========== Connections ==========
COS -> Function : COS trigger (new log file)
Function -> COS : Get compressed logs
Function -> Function : Decompress & parse logs
Function -> Function : Transform data
Function -> LogAnalysis : Forward processed logs
Function -> Archive : Copy processed logs
Function -> COS : Delete original logs

' HTTP endpoint for testing
Index -> Handler : Invoke handler
@enduml