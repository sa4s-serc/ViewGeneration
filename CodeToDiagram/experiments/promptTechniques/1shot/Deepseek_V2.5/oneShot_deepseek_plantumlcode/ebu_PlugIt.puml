@startuml ebu_PlugIt
skinparam rectangle {
  BackgroundColor<<client>> #d9e7fd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<error>> #fddddd
  BackgroundColor<<mitigation>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "GitHub Repository" as GitHub
rectangle "Analysis Client" as Client <<client>>
rectangle "Gemini API" as API <<api>>
rectangle "Rate Limiter" as RateLimiter <<error>>
rectangle "Error Handler" as ErrorHandler <<mitigation>>

GitHub --> Client : "Repository Data"
Client --> API : "API Requests"
API --> RateLimiter : "429 Error"
RateLimiter --> ErrorHandler : "Retry Delay"
ErrorHandler --> Client : "Retry Logic"

package "Mitigation Strategies" <<mitigation>> {
  rectangle "Reduce Input Size"
  rectangle "Retry with Backoff"
  rectangle "Upgrade API Plan"
  rectangle "Optimize Tokens"
  rectangle "Caching"
}

ErrorHandler --> "Retry with Backoff"
Client --> "Reduce Input Size"
Client --> "Optimize Tokens"
Client --> "Caching"
Client --> "Upgrade API Plan"
@enduml