@startuml dowjones_hammer
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Security Engineer" as User

rectangle "Slack" as Slack #lightblue
rectangle "JIRA" as JIRA #palegreen

rectangle "AWS Environment" as AWS {
  rectangle "Initiation Lambda" as InitLambda #lightyellow
  rectangle "Identification Lambdas" as IdLambdas #lightyellow
  rectangle "DynamoDB" as DynamoDB #mistyrose
  rectangle "S3" as S3 #aliceblue
  rectangle "SNS" as SNS #lightsteelblue
  rectangle "EC2 Instance" as EC2 #peachpuff
}

' ========== Connections ==========
User --> Slack : Interact via Slack bot
User --> JIRA : View/Manage tickets

' Initiation flow
InitLambda --> SNS : Publish scan event
SNS --> IdLambdas : Trigger security checks

' Identification flow
IdLambdas --> AWS : Scan resources
IdLambdas --> DynamoDB : Store findings
IdLambdas --> S3 : Backup configurations

' Reporting flow
EC2 --> DynamoDB : Poll for new findings
EC2 --> JIRA : Create/update tickets
EC2 --> Slack : Send notifications
EC2 --> S3 : Generate reports

' Remediation flow
EC2 --> AWS : Execute remediation actions
EC2 --> DynamoDB : Update issue status

' API interactions
User --> EC2 : REST API requests
EC2 --> DynamoDB : Query findings
@enduml