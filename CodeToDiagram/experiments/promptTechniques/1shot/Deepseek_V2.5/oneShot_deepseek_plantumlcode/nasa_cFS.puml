@startuml nasa_cFS
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<osal>> #d8f5d3
  BackgroundColor<<psp>> #fddddd
  BackgroundColor<<apps>> #fff1c9
  BackgroundColor<<tools>> #e6d9ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Flight Executive (cFE)" <<core>> {
  rectangle "Executive Services" as ES
  rectangle "Software Bus" as SB
  rectangle "Table Services" as TS
  rectangle "Time Services" as TIME
  rectangle "Event Services" as EVS
}

package "OS Abstraction Layer (OSAL)" <<osal>> {
  rectangle "File System" as FS
  rectangle "Task Management" as TASK
  rectangle "Message Queues" as MSGQ
  rectangle "Semaphores" as SEM
  rectangle "Timers" as TIMER
}

package "Platform Support Package (PSP)" <<psp>> {
  rectangle "BSP" as BSP
  rectangle "HW Drivers" as HW
  rectangle "Bootloader" as BOOT
}

package "Applications" <<apps>> {
  rectangle "Lab Apps" as LAB
  rectangle "Custom Apps" as CUSTOM
}

package "Tools" <<tools>> {
  rectangle "Build Tools" as BUILD
  rectangle "Test Tools" as TEST
  rectangle "Telemetry Tools" as TM
}

ES --> SB
ES --> TS
ES --> TIME
ES --> EVS

SB --> TASK
SB --> MSGQ
SB --> SEM

TASK --> BSP
MSGQ --> BSP
SEM --> BSP
FS --> BSP
TIMER --> BSP

BSP --> HW
BSP --> BOOT

LAB --> ES
CUSTOM --> ES

BUILD --> ES
TEST --> ES
TM --> SB
@enduml