@startuml sfujiwara_terraform-google-ai-platform-notification
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Google AI Platform" as AI_Platform #mistyrose

rectangle "Google Cloud Logging" as Logging #lightsteelblue

rectangle "Pub/Sub\n(ai_platform_log)" as LogTopic #palegreen

rectangle "Cloud Function" as CloudFunction #lightyellow

rectangle "Pub/Sub\n(notification)" as NotificationTopic #aliceblue

rectangle "Subscriber" as Subscriber #lavender

' ========== Connections ==========
AI_Platform -> Logging : emits job state logs
Logging -> LogTopic : forwards logs via sink
LogTopic -> CloudFunction : triggers on new message
CloudFunction -> NotificationTopic : publishes notification
NotificationTopic -> Subscriber : delivers notification
@enduml