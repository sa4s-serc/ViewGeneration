@startuml Azure_AzureStack-QuickStart-Templates
skinparam rectangle {
  BackgroundColor<<templates>> #d9e7fd
  BackgroundColor<<scripts>> #d8f5d3
  BackgroundColor<<config>> #fddddd
  BackgroundColor<<validation>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "ARM Templates" <<templates>> {
  rectangle "azuredeploy.json" as ARM
  rectangle "nestedTemplates" as Nested
  rectangle "parameters.json" as Params
  ARM --> Nested
  ARM --> Params
}

package "Scripts" <<scripts>> {
  rectangle "PowerShell (.ps1)" as PS
  rectangle "Shell (.sh)" as SH
  rectangle "DSC Configs" as DSC
  PS --> DSC
}

package "Configuration" <<config>> {
  rectangle "XML/YAML" as XML
  rectangle "Geth.cfg" as Geth
  rectangle "Sources.txt" as Sources
}

package "Validation" <<validation>> {
  rectangle "Test Scripts" as Tests
  rectangle "Parameter Files" as TestParams
  Tests --> TestParams
}

ARM --> PS
ARM --> SH
PS --> XML
SH --> Geth
ARM --> Tests
PS --> Tests
SH --> Tests

database "Azure Stack" as AzureStack
ARM --> AzureStack
PS --> AzureStack
SH --> AzureStack

database "Public Azure" as PublicAzure
ARM --> PublicAzure
PS --> PublicAzure
SH --> PublicAzure
@enduml