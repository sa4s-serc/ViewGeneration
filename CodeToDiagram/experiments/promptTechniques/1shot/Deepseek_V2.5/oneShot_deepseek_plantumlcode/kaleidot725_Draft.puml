@startuml kaleidot725_Draft
skinparam rectangle {
  BackgroundColor<<presentation>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Presentation Layer" <<presentation>> {
  rectangle "ComposeMainActivity" as Activity
  rectangle "UI Composables" as UI
  rectangle "ViewModels" as VM
  rectangle "Navigation" as Nav
  Activity --> UI
  UI --> VM
  VM --> Nav
}

package "Domain Layer" <<domain>> {
  rectangle "Use Cases" as UseCases
  rectangle "MVI State" as MVI
  rectangle "Orbit-MVI" as Orbit
  UseCases --> MVI
  MVI --> Orbit
}

package "Data Layer" <<data>> {
  rectangle "Repositories" as Repo
  rectangle "Room Database" as Room
  rectangle "Entities/DAOs" as Entities
  Repo --> Room
  Room --> Entities
}

package "External" <<external>> {
  rectangle "Koin DI" as Koin
  rectangle "Coroutines/Flow" as Coroutines
  rectangle "TextEditor" as Editor
}

VM --> UseCases
UseCases --> Repo
Entities --> Koin
UI --> Editor
VM --> Coroutines
@enduml