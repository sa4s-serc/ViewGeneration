@startuml freenowtech_AndroidCI
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Developer" as Dev

rectangle "Local Machine" as Local {
  rectangle "Git Client" as Git
  rectangle "Docker CLI" as DockerCLI
}

rectangle "CI Infrastructure" as CI {
  rectangle "Jenkins Server" as Jenkins {
    rectangle "Docker Plugin" as DockerPlugin
    rectangle "Android Lint Plugin" as AndroidLint
  }
  
  rectangle "Docker Host" as DockerHost {
    rectangle "Android SDK Image" as AndroidSDK
    rectangle "Build Container" as BuildContainer
  }
}

rectangle "Version Control" as VCS {
  rectangle "Git Repository" as GitRepo
}

rectangle "Artifact Storage" as Artifacts {
  rectangle "Build Outputs" as BuildOutputs
}

' ========== Connections ==========
Dev --> Git : Commit/Push code
Git --> GitRepo : Sync changes

Dev --> DockerCLI : Manage containers
DockerCLI --> DockerHost : Pull images\nRun containers

Jenkins --> GitRepo : Poll for changes
Jenkins --> DockerPlugin : Manage build agents
DockerPlugin --> DockerHost : Spin up containers
DockerHost --> BuildContainer : Execute build
BuildContainer --> AndroidSDK : Use SDK tools
BuildContainer --> GitRepo : Checkout code
BuildContainer --> Artifacts : Store outputs

Jenkins --> AndroidLint : Run static analysis
AndroidLint --> BuildContainer : Analyze code
@enduml