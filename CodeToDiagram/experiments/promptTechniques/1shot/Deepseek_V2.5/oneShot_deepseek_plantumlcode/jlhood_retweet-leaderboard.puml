@startuml jlhood_retweet-leaderboard
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor TwitterUser

rectangle "Twitter API" as TwitterAPI #aliceblue

rectangle "AWS Lambda" as Lambda {
  rectangle "TweetProcessor\nHandler" as TweetProcessor #palegreen
  rectangle "GetLeaderboard\nHandler" as GetLeaderboard #lightsteelblue
}

rectangle "API Gateway" as APIGateway #mistyrose

rectangle "DynamoDB" as DynamoDB #lightyellow

rectangle "UI" as UI #lavender

' ========== Connections ==========
TwitterUser --> TwitterAPI : Posts tweet
TwitterAPI --> TweetProcessor : Triggers with tweet JSON
TweetProcessor --> DynamoDB : Updates leaderboard data
UI --> APIGateway : GET /leaderboard?limit=N
APIGateway --> GetLeaderboard : Invokes handler
GetLeaderboard --> DynamoDB : Queries leaderboard data
GetLeaderboard --> APIGateway : Returns JSON response
APIGateway --> UI : Displays leaderboard
@enduml