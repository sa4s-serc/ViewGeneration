@startuml ndsev_zswag
skinparam rectangle {
  BackgroundColor<<generator>> #d9e7fd
  BackgroundColor<<server>> #d8f5d3
  BackgroundColor<<client>> #fddddd
  BackgroundColor<<library>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "OpenAPI Generator" <<generator>> {
  rectangle "zswag.gen CLI" as GenCLI
  rectangle "OpenAPI YAML Generator" as YAMLGen
  rectangle "Zserio Schema Parser" as ZserioParser
  GenCLI --> YAMLGen
  YAMLGen --> ZserioParser
}

package "Python Server" <<server>> {
  rectangle "OAServer (Flask/Connexion)" as OAServer
  rectangle "Request Parser" as Parser
  rectangle "Response Serializer" as Serializer
  rectangle "Controller Modules" as Controllers
  OAServer --> Parser
  OAServer --> Serializer
  OAServer --> Controllers
}

package "Client Libraries" <<client>> {
  rectangle "Python OAClient" as PyClient
  rectangle "C++ OAClient (zswagcl)" as CppClient
  rectangle "HTTP Client (httpcl)" as HTTPClient
  PyClient --> HTTPClient
  CppClient --> HTTPClient
}

package "Supporting Libraries" <<library>> {
  rectangle "Zserio Runtime" as Zserio
  rectangle "cpp-httplib" as cpphttplib
  HTTPClient --> cpphttplib
}

YAMLGen --> OAServer
YAMLGen --> PyClient
YAMLGen --> CppClient
ZserioParser --> Zserio
Controllers --> Zserio
PyClient --> Zserio
CppClient --> Zserio
@enduml