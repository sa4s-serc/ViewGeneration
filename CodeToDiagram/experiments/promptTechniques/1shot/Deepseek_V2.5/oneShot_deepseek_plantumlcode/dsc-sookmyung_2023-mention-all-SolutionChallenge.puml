@startuml dsc-sookmyung_2023-mention-all-SolutionChallenge
skinparam rectangle {
  BackgroundColor<<android>> #d9e7fd
  BackgroundColor<<ios>> #e7d9fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<services>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Android App (Kotlin)" <<android>> {
  rectangle "UI Components" as AndroidUI
  rectangle "ViewModels" as AndroidVM
  rectangle "Data Layer\n(Repositories, Models)" as AndroidData
  rectangle "ML Kit\n(TensorFlow Lite)" as AndroidML
  AndroidUI --> AndroidVM
  AndroidVM --> AndroidData
  AndroidData --> AndroidML
}

package "iOS App (Swift)" <<ios>> {
  rectangle "Views\n(CameraOverlay, Notice)" as iOSViews
  rectangle "ViewModels\n(Education, Call)" as iOSVM
  rectangle "Combine Framework" as iOSCombine
  rectangle "TensorFlow Lite" as iOSML
  iOSViews --> iOSVM
  iOSVM --> iOSCombine
  iOSVM --> iOSML
}

package "Backend (Spring Boot)" <<backend>> {
  rectangle "Controllers\n(Auth, Education, CPR)" as BackendControllers
  rectangle "Services\n(Dispatch, FCM, Address)" as BackendServices
  rectangle "Repositories" as BackendRepos
  rectangle "JWT Auth" as BackendAuth
  BackendControllers --> BackendServices
  BackendServices --> BackendRepos
  BackendControllers --> BackendAuth
}

package "External Services" <<services>> {
  rectangle "Firebase\n(Auth, FCM, DB)" as Firebase
  rectangle "Google Maps API" as Maps
  rectangle "GCP Deployment" as GCP
}

database "Database" <<db>> as DB

AndroidData --> BackendControllers
iOSVM --> BackendControllers
BackendRepos --> DB
BackendServices --> Firebase
BackendServices --> Maps
BackendControllers --> GCP
@enduml