@startuml linhao1998_ChatGPTClient
skinparam rectangle {
  BackgroundColor<<view>> #d9e7fd
  BackgroundColor<<viewmodel>> #d8f5d3
  BackgroundColor<<model>> #fddddd
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<external>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "View Layer" <<view>> {
  rectangle "ChatActivity" as ChatActivity
  rectangle "SettingsActivity" as SettingsActivity
  rectangle "ChatAdapter" as ChatAdapter
  rectangle "MsgAdapter" as MsgAdapter
}

package "ViewModel Layer" <<viewmodel>> {
  rectangle "ChatViewModel" as ChatViewModel
  rectangle "ChatListViewModel" as ChatListViewModel
  rectangle "MsgListViewModel" as MsgListViewModel
}

package "Model Layer" <<model>> {
  rectangle "Repository" as Repository
  rectangle "Chat" as Chat
  rectangle "Msg" as Msg
}

package "Storage Layer" <<storage>> {
  rectangle "AppDatabase" as AppDatabase
  rectangle "ChatDao" as ChatDao
  rectangle "MsgDao" as MsgDao
}

package "External Services" <<external>> {
  rectangle "OpenAI API" as OpenAI
  rectangle "Markwon Library" as Markwon
}

ChatActivity --> ChatViewModel
SettingsActivity --> ChatViewModel
ChatAdapter --> ChatListViewModel
MsgAdapter --> MsgListViewModel

ChatViewModel --> Repository
ChatListViewModel --> Repository
MsgListViewModel --> Repository

Repository --> ChatDao
Repository --> MsgDao
Repository --> OpenAI

ChatDao --> AppDatabase
MsgDao --> AppDatabase

Chat --> AppDatabase
Msg --> AppDatabase

ChatActivity ..> Markwon
@enduml