@startuml imamabdulazis_FlutterCleanArchitecture
skinparam rectangle {
  BackgroundColor<<presentation>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<core>> #fff1c9
  BackgroundColor<<external>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Presentation Layer" <<presentation>> {
  rectangle "UI Components" as UI
  rectangle "Screens" as Screens
  rectangle "BLoCs" as BLoC
  UI --> Screens
  Screens --> BLoC
}

package "Domain Layer" <<domain>> {
  rectangle "Entities" as Entities
  rectangle "Use Cases" as UseCases
  rectangle "Repository Interfaces" as RepoInterfaces
  UseCases --> Entities
  UseCases --> RepoInterfaces
}

package "Data Layer" <<data>> {
  rectangle "Repositories" as Repositories
  rectangle "Data Sources" as DataSources
  rectangle "Models" as Models
  Repositories --> DataSources
  DataSources --> Models
}

package "Core Layer" <<core>> {
  rectangle "Networking" as Networking
  rectangle "Error Handling" as ErrorHandling
  rectangle "DI (get_it)" as DI
  rectangle "Localization" as Localization
  rectangle "Theming" as Theming
}

package "External Services" <<external>> {
  rectangle "Firebase Messaging" as Firebase
  rectangle "Shared Preferences" as SharedPrefs
  rectangle "Sentry" as Sentry
  rectangle "Dio" as Dio
}

BLoC --> UseCases
RepoInterfaces --> Repositories
Models --> Entities
Networking --> Dio
ErrorHandling --> Sentry
DataSources --> SharedPrefs
Theming --> SharedPrefs
Localization --> SharedPrefs
DI --> Repositories
DI --> UseCases
DI --> BLoC
Repositories --> Networking
@enduml