@startuml rubenbupe_proyectos-data
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<metrics>> #fddddd
  BackgroundColor<<infra>> #fff1c9
  BackgroundColor<<external>> #e6e6fa
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Frontend (Next.js)" <<frontend>> as Frontend {
  rectangle "React Components" as Components
  rectangle "TensorFlow.js" as TFJS
  rectangle "API Client" as APIClient
  Components --> TFJS
  Components --> APIClient
}

rectangle "API (Python Flask)" <<api>> as API {
  rectangle "Image Segmentation" as Segmentation
  rectangle "Location Search" as Search
  rectangle "WebSocket Handler" as WS
  rectangle "RabbitMQ Publisher" as RMQPub
  Segmentation --> RMQPub
  Search --> RMQPub
  WS --> RMQPub
}

rectangle "Metrics API (Node.js)" <<metrics>> as Metrics {
  rectangle "RabbitMQ Consumer" as RMQCon
  rectangle "Metrics Processor" as Processor
  rectangle "Grafana Exporter" as Grafana
  RMQCon --> Processor
  Processor --> Grafana
}

rectangle "Infrastructure" <<infra>> as Infra {
  rectangle "RabbitMQ" as RabbitMQ
  rectangle "MongoDB" as MongoDB
  rectangle "Kubernetes" as K8s
  rectangle "Nginx Ingress" as Ingress
  rectangle "cert-manager" as CertManager
  K8s --> Ingress
  K8s --> CertManager
}

rectangle "External Services" <<external>> as External {
  rectangle "Positionstack API" as Positionstack
  rectangle "Let's Encrypt" as LetsEncrypt
}

Frontend --> API : HTTP/WebSocket
API --> RabbitMQ : Publish Events
Metrics --> RabbitMQ : Consume Events
API --> MongoDB : CRUD
Metrics --> MongoDB : Store Metrics
API --> Positionstack : Geocoding
CertManager --> LetsEncrypt : ACME
Ingress --> Frontend
Ingress --> API
Ingress --> Metrics
@enduml