@startuml GoogleCloudPlatform_gke-pubsub-websocket-adapter
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Web Client" as Client

rectangle "GKE Cluster" as GKE {
  rectangle "pulltop" as Pulltop #palegreen
  rectangle "websocketd" as Websocketd #lightsteelblue
  rectangle "Ephemeral Storage" as Storage #lightyellow
  rectangle "Cron Job" as Cron #aliceblue
}

rectangle "Google Cloud Pub/Sub" as PubSub #mistyrose

' ========== Connections ==========
Client --> Websocketd : WebSocket connection\n(real-time messages)

Pulltop --> PubSub : Pull messages\nfrom subscription
Pulltop --> Storage : Write messages\nto buffer

Websocketd --> Storage : Read messages\nfrom buffer
Websocketd --> Client : Push messages\nvia WebSocket

Cron --> Storage : Rotate JSON file\n(cleanup)

note right of PubSub
  Uses Workload Identity
  for authentication
end note
@enduml