@startuml codestates_BEB-05-LeeSea
skinparam rectangle {
  BackgroundColor<<contracts>> #d9e7fd
  BackgroundColor<<frontend>> #d8f5d3
  BackgroundColor<<blockchain>> #fddddd
  BackgroundColor<<state>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Smart Contracts" <<contracts>> {
  rectangle "LeeSeaNFT.sol" as NFTContract
  rectangle "LeeSeaMarket.sol" as MarketContract
  rectangle "#utility.yul" as YulUtils
  NFTContract --> YulUtils
  MarketContract --> YulUtils
}

package "Frontend (React)" <<frontend>> {
  rectangle "Web3.js" as Web3
  rectangle "React Components" as Components
  rectangle "Routing" as Routing
  Components --> Routing
  Components --> Web3
}

package "State Management" <<state>> {
  rectangle "Redux Store" as Redux
  rectangle "Account Slice" as Account
  rectangle "Token Slice" as Token
  Redux --> Account
  Redux --> Token
  Components --> Redux
}

node "Blockchain Network" <<blockchain>> as Blockchain
Web3 --> Blockchain
NFTContract --> Blockchain
MarketContract --> Blockchain

rectangle "MetaMask" as Wallet
Wallet --> Web3
@enduml