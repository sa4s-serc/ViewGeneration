@startuml unnmdnwb3_dora
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "DevOps User" as User

rectangle "DORA API" as API {
  rectangle "API Router" as Router
  rectangle "Metrics Handler" as Handler
  rectangle "Metrics Service" as MetricsService
}

rectangle "Connectors" as Connectors {
  rectangle "GitLab Client" as GitLabClient
  rectangle "Prometheus Client" as PrometheusClient
}

rectangle "Database" as DB {
  rectangle "MongoDB" as MongoDB
}

rectangle "External Systems" as External {
  rectangle "GitLab" as GitLab
  rectangle "Prometheus" as Prometheus
}

' ========== Connections ==========
User -> Router : HTTP Requests (GET/POST)
Router -> Handler : Route requests
Handler -> MetricsService : Calculate metrics
MetricsService -> GitLabClient : Fetch repo/pipeline data
MetricsService -> PrometheusClient : Fetch alert data
GitLabClient -> GitLab : API Calls
PrometheusClient -> Prometheus : API Queries
MetricsService -> MongoDB : Store/Retrieve metrics
Handler -> MongoDB : CRUD operations

' Background processes
MetricsService -> MetricsService : Aggregate daily data
MetricsService -> MetricsService : Calculate DORA metrics
@enduml