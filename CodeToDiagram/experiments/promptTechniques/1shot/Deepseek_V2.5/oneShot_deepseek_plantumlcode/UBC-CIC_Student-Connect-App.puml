@startuml UBC-CIC_Student-Connect-App
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "React PWA" as Frontend {
}

rectangle "AWS Cognito" as Cognito #mistyrose

rectangle "AWS Lambda" as Lambda #lightsteelblue {
  rectangle "Data Aggregators" as Aggregators
  rectangle "ES Sync" as ESSync
  rectangle "Document Handler" as DocHandler
}

rectangle "DynamoDB" as DynamoDB #palegreen

rectangle "Elasticsearch" as Elasticsearch #lightyellow

rectangle "External Sources" as Sources #aliceblue {
  rectangle "UBCO Events"
  rectangle "News"
  rectangle "Blogs"
  rectangle "Athletics"
  rectangle "Clubs"
}

' ========== User Flow ==========
User -> Frontend : Signs in via Cognito
Frontend <-> Cognito : Authentication

User -> Frontend : Completes survey
Frontend -> Lambda : Stores preferences

User -> Frontend : Requests content
Frontend -> Lambda : Queries ES
Lambda -> Elasticsearch : Gets personalized results
Elasticsearch -> Frontend : Returns content

' ========== Data Flow ==========
Aggregators -> Sources : Fetches data
Aggregators -> DynamoDB : Stores raw data
DynamoDB -> DocHandler : Streams changes
DocHandler -> Elasticsearch : Syncs updates

' ========== Admin Flow ==========
Elasticsearch <-> Kibana : Admin console
DynamoDB <-> S3 : Data lake archiving
@enduml