@startuml tarhses_esp-alarm-clock
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "ESP32" as ESP32 {
  rectangle "Main Task" as Main
  rectangle "Alarm Task" as Alarm
  rectangle "Network Task" as Network
  rectangle "Display Task" as Display
  rectangle "Sound Task" as Sound
  rectangle "Potentiometer Task" as Pot
  rectangle "Storage" as Storage
}

rectangle "External" as External {
  rectangle "WiFi" as WiFi
  rectangle "NTP Server" as NTP
  rectangle "SD Card" as SDCard
}

' ========== Connections ==========
User --> Pot : Adjust potentiometers
User --> Alarm : Press buttons/flip switch

Main --> Network : Initialize
Main --> Alarm : Initialize
Main --> Display : Initialize
Main --> Sound : Initialize
Main --> Pot : Initialize
Main --> Storage : Initialize

Network --> WiFi : Connect
Network --> NTP : Sync time
Network --> Alarm : Time update event
Network --> Display : WiFi status event

Alarm --> Display : Alarm status update
Alarm --> Sound : Trigger alarm sound
Alarm --> Storage : Read config

Pot --> Alarm : Set alarm time
Pot --> Storage : Save calibration

Display --> SDCard : Load display assets
Sound --> SDCard : Load audio files
Storage --> SDCard : Read config.json

' Event loop communications
Alarm -[hidden]-> Network
Alarm -[hidden]-> Display
Alarm -[hidden]-> Sound
@enduml