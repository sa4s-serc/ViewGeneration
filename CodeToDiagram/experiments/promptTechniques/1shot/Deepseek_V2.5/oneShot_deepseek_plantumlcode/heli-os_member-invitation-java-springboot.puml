@startuml heli-os_member-invitation-java-springboot
skinparam rectangle {
  BackgroundColor<<interface>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<infra>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Interface Layer" <<interface>> {
  rectangle "MemberInvitationApplication" as App
  rectangle "InvitationRestController" as InvitationAPI
  rectangle "MemberRestController" as MemberAPI
  rectangle "DTOs" as DTOs
  rectangle "Mappers" as Mappers
  rectangle "ExceptionHandler" as ExceptionHandler
  App --> InvitationAPI
  App --> MemberAPI
  InvitationAPI --> DTOs
  MemberAPI --> DTOs
  DTOs --> Mappers
  ExceptionHandler --> InvitationAPI
  ExceptionHandler --> MemberAPI
}

package "Domain Layer" <<domain>> {
  rectangle "Member" as Member
  rectangle "Invitation" as Invitation
  rectangle "UseCase Interfaces" as UseCases
  rectangle "Domain Services" as Services
  Member --> UseCases
  Invitation --> UseCases
  UseCases --> Services
}

package "Infrastructure Layer" <<infra>> {
  rectangle "Database Adapter" as DBAdapter
  rectangle "Redis Adapter" as RedisAdapter
  rectangle "JPA Repositories" as Repositories
  DBAdapter --> Repositories
  RedisAdapter --> Repositories
}

database "Relational DB" <<db>> as RDB
database "Redis" <<db>> as Redis

Services --> DBAdapter
Services --> RedisAdapter
Repositories --> RDB
Repositories --> Redis

Mappers --> Member
Mappers --> Invitation
@enduml