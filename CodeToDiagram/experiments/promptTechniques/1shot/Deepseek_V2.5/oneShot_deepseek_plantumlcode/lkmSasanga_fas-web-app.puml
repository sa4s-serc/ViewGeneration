@startuml lkmSasanga_fas-web-app
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<deployment>> #fddddd
  BackgroundColor<<auth>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "App.js (Router)" as App
  rectangle "Containers" as Containers {
    rectangle "Login/Signup" as Auth
    rectangle "InputControl (Search)" as Search
    rectangle "RequestData (API)" as API
    rectangle "Layout (HOC)" as Layout
  }
  rectangle "Components" as Components {
    rectangle "Charts" as Charts
    rectangle "UI Elements" as UI
  }
  App --> Containers
  Containers --> Components
}

package "Backend API" <<backend>> {
  rectangle "Sentiment Analysis" as SentimentAPI
}

package "Authentication" <<auth>> {
  rectangle "Firebase Auth" as FirebaseAuth
}

package "Deployment" <<deployment>> {
  rectangle "Firebase Hosting" as FirebaseHost
}

API --> SentimentAPI : axios GET/POST
Auth --> FirebaseAuth : Login/Signup
App --> FirebaseHost : Deployed via

note right of API
  API URL: https://malindu-fas.herokuapp.com/sentiment
  Uses axios for HTTP requests
end note

note right of FirebaseHost
  Configured in .firebaserc
  Deployed UI components
end note
@enduml