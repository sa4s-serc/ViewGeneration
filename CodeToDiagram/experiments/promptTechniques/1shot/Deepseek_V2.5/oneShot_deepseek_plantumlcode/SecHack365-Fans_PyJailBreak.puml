@startuml SecHack365-Fans_PyJailBreak
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<state>> #fddddd
  BackgroundColor<<api>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Next.js/React)" <<frontend>> {
  rectangle "Pages" as Pages {
    rectangle "index.tsx" as Index
    rectangle "openapi.tsx" as OpenAPI
  }
  rectangle "Components" as Components {
    rectangle "RequestForm.tsx" as RequestForm
    rectangle "ExecuteAttack.tsx" as ExecuteAttack
    rectangle "DialogEditor.tsx" as DialogEditor
    rectangle "DataGridFooters.tsx" as DataGrid
    rectangle "importFile.tsx" as ImportFile
  }
  rectangle "Layout" as Layout
  rectangle "StatusChip.tsx" as StatusChip
}

package "State Management" <<state>> {
  rectangle "Redux Store" as Store
  rectangle "Slices" as Slices {
    rectangle "payloadsSlice.ts" as PayloadSlice
    rectangle "emulateSlice.ts" as EmulateSlice
    rectangle "endPointsSlice.ts" as EndpointSlice
    rectangle "dialogSlice.ts" as DialogSlice
  }
  rectangle "PayloadsT.ts" as PayloadTypes
}

package "Backend API" <<api>> {
  rectangle "API Endpoint" as API
  rectangle "Swagger Docs" as Swagger
}

Pages --> Components
Components --> Store
Store --> Slices
Slices --> PayloadTypes
RequestForm --> ExecuteAttack
ExecuteAttack --> API
OpenAPI --> Swagger
DataGrid --> ImportFile
@enduml