@startuml nikmis_xentrace-analysis
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<handler>> #d8f5d3
  BackgroundColor<<analysis>> #fddddd
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Components" <<core>> {
  rectangle "xentrace-analysis.c" as Main
  rectangle "Reader.c" as Reader
  rectangle "EventHandler.c" as EventHandler
  rectangle "Event.c" as EventParser
  rectangle "Trace.h" as TraceDefs
  rectangle "list.h" as ListLib
}

package "Analysis Modules" <<analysis>> {
  rectangle "cpu_time_sharing" as CPUUtil
  rectangle "cpu_wait" as CPULatency
  rectangle "xen_dom_time_sharing" as XenTime
  rectangle "blk_io_queues" as DiskIO
  rectangle "xen_stats" as XenStats
  rectangle "trap" as TrapCount
}

database "xentrace output" <<external>> as XentraceOut
cloud "xentrace process" <<external>> as XentraceProc

Main --> Reader : manages
Main --> XentraceProc : spawns
XentraceProc --> XentraceOut : writes
Reader --> XentraceOut : reads
Reader --> EventParser : uses
Reader --> EventHandler : dispatches
EventHandler --> TraceDefs : references
EventHandler --> ListLib : uses
EventHandler --> CPUUtil : notifies
EventHandler --> CPULatency : notifies
EventHandler --> XenTime : notifies
EventHandler --> DiskIO : notifies
EventHandler --> XenStats : notifies
EventHandler --> TrapCount : notifies
@enduml