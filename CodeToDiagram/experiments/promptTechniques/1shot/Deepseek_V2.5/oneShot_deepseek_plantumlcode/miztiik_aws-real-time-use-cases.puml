@startuml miztiik_aws-real-time-use-cases
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Developer/Architect" as User

rectangle "GitHub Repository" as Repo {
  rectangle "README.md" as Readme
  rectangle "Use Case Template" as Template
  rectangle "Use Case READMEs" as UseCases
  rectangle "Images" as Images
}

rectangle "AWS Services" as AWS {
  rectangle "Compute" as Compute
  rectangle "Storage" as Storage
  rectangle "Security" as Security
  rectangle "Messaging" as Messaging
}

rectangle "External Resources" as ExtResources {
  rectangle "AWS Docs" as AWSDocs
  rectangle "Udemy Courses" as Udemy
  rectangle "Blog Posts" as Blogs
}

' ========== Connections ==========
User --> Repo : Clone/Contribute
User --> AWS : Deploy Solutions

Repo --> ExtResources : Links to
Repo --> AWS : References

UseCases --> Images : Contains
Template --> UseCases : Guides creation

User --> Template : Follows for new use cases
User --> UseCases : Implements solutions
User --> Readme : Consumes guidelines

AWS --> Compute : EC2/Lambda
AWS --> Storage : S3/EBS
AWS --> Security : IAM/KMS
AWS --> Messaging : SQS/SNS
@enduml