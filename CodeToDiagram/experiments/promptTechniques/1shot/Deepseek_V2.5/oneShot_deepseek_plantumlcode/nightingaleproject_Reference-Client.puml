@startuml nightingaleproject_Reference-Client
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Jurisdiction User" as User

rectangle "React UI" as UI {
}

rectangle "Reference Client API" as API {
  rectangle "RecordController" as Controller
  rectangle "TimedHostedService" as Service
  rectangle "AppDbContext" as Db
}

rectangle "NVSS API Server" as NVSS

rectangle "PostgreSQL" as DB

' ========== Security Interactions ==========
User -> UI : Authenticates (JWT/OAuth)
UI -> API : API requests with auth token
API -> Controller : Validates token
Controller -> Db : Secure DB access
Service -> NVSS : Authenticated API calls
NVSS -> Service : Returns secured responses
Service -> Db : Secure response storage
Db -> API : Encrypted data storage
@enduml