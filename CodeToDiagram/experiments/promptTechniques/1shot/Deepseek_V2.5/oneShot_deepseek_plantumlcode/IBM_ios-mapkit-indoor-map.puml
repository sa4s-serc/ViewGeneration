@startuml IBM_ios-mapkit-indoor-map
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "iOS App" as iOS {
  rectangle "ViewController" as VC
  rectangle "FloorplanOverlay" as FO
  rectangle "FloorplanOverlayRenderer" as FOR
  rectangle "CoordinateConverter" as CC
  rectangle "VisibleMapRegionDelegate" as VMRD
}

rectangle "Node.js Backend" as Backend #mistyrose {
  rectangle "REST API" as API
  rectangle "PDF Generator" as PDF
  rectangle "MongoDB" as DB #palegreen
}

' ========== Connections ==========
User --> VC : Interacts with map

' iOS App internal interactions
VC --> FO : Load floorplan
VC --> FOR : Render overlay
VC --> CC : Coordinate conversion
VC --> VMRD : Camera control

' iOS to Backend interactions
VC --> API : GET /floorplan (PDF)
VC --> API : GET /events (heatmap data)
VC --> API : POST /trigger (event)

' Backend internal interactions
API --> PDF : Generate floorplan PDF
API --> DB : Query/update beacons, booths, events
PDF --> DB : Fetch map data

@enduml