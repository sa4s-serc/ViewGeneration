@startuml open-risk_Open_Risk_API
skinparam rectangle {
  BackgroundColor<<api>> #d9e7fd
  BackgroundColor<<server>> #d8f5d3
  BackgroundColor<<client>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<library>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Open Risk API" <<api>> {
  rectangle "RESTful Endpoints" as API
}

package "Model Server" <<server>> {
  rectangle "Flask Server" as Flask
  rectangle "Model Descriptions\n(RDF/JSON-LD)" as Models
  rectangle "Calculation Services" as Calc
  rectangle "Concentration Metrics\n(HHI, Gini, Shannon)" as Metrics
  Flask --> Models
  Flask --> Calc
  Calc --> Metrics
}

package "Data Server" <<server>> {
  rectangle "Python-Eve Server" as Eve
  rectangle "Portfolio Data" as Data
  Eve --> Data
}

database "MongoDB" <<db>> as MongoDB
Data --> MongoDB

rectangle "API Explorer" <<client>> as Explorer
Explorer --> API
API --> Flask
API --> Eve

package "OpenCPM" <<library>> {
  rectangle "NPL Concentration\nMetrics" as NPL
  rectangle "Model Definitions\n(RDF)" as RDF
  rectangle "Calculation Tools" as Tools
  NPL --> RDF
  NPL --> Tools
}

Flask --> NPL
@enduml