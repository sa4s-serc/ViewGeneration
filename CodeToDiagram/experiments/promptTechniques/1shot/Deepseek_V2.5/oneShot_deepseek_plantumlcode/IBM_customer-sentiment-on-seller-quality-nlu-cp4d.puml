@startuml IBM_customer-sentiment-on-seller-quality-nlu-cp4d
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as User

rectangle "Jupyter Notebook" as Notebook #palegreen {
}

rectangle "Watson NLU" as NLU #lightsteelblue

rectangle "Db2 Database" as Db2 #lightyellow

rectangle "Embedded Dashboard" as Dashboard #aliceblue

' ========== Connections ==========
User --> Notebook : Execute notebook
User --> Dashboard : View/interact with results

Notebook --> Db2 : Load refined customer data
Notebook --> NLU : Submit text for sentiment/emotion analysis
NLU --> Notebook : Return sentiment scores

Notebook --> Dashboard : Push processed data for visualization
Dashboard --> Notebook : Request updated data (optional)
@enduml