@startuml xinsongyan_talos_pal_locomotion_slmc
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Operator

rectangle "ROS Master" as ROS {
}

rectangle "Locomotion Controller" as Controller #palegreen {
  rectangle "DCM Controller" as DCM
  rectangle "WBC Plugin" as WBC
  rectangle "State Estimator" as Estimator
  rectangle "Safety Monitor" as Safety
}

rectangle "TALOS Robot" as Robot #mistyrose {
  rectangle "Actuators" as Actuators
  rectangle "Sensors" as Sensors
}

rectangle "Simulation" as Sim #lightsteelblue {
  rectangle "Gazebo/PAL" as Physics
}

' ========== Connections ==========
Operator --> ROS : Start/Stop/Configure

ROS --> Controller : Parameters/Commands
Controller --> ROS : State/Status

DCM --> WBC : Reference Trajectory
WBC --> DCM : Feedback
Estimator --> WBC : Robot State
Safety --> WBC : Constraints/Violations

Controller --> Robot : Joint Commands
Robot --> Controller : Sensor Data

Controller --> Sim : Simulation Mode
Sim --> Controller : Simulated Sensor Data

' Dynamic plugin loading
ROS --> WBC : Load WBC Plugin
WBC --> ROS : Plugin Status

' Safety monitoring loop
Sensors --> Safety : Raw Data
Safety --> ROS : Safety Events
@enduml