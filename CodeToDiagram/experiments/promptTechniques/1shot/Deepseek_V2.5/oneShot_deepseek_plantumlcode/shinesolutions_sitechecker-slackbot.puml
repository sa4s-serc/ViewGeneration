@startuml shinesolutions_sitechecker-slackbot
skinparam rectangle {
  BackgroundColor<<slack>> #d9e7fd
  BackgroundColor<<master>> #d8f5d3
  BackgroundColor<<worker>> #fddddd
  BackgroundColor<<aws>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Slack" <<slack>> as Slack

package "Master Lambda" <<master>> {
  rectangle "API Gateway" as APIGateway
  rectangle "Bot Handler" as BotHandler
  rectangle "Slack Facade" as SlackFacade
  rectangle "URL Parser" as URLParser
  rectangle "Result Aggregator" as Aggregator
  APIGateway --> BotHandler
  BotHandler --> SlackFacade
  BotHandler --> URLParser
  BotHandler --> Aggregator
}

package "Worker Lambdas" <<worker>> {
  rectangle "US-East-1 Worker" as USWorker
  rectangle "EU-West-1 Worker" as EUWorker
  rectangle "AP-South-1 Worker" as APWorker
}

package "AWS Services" <<aws>> {
  rectangle "Lambda" as Lambda
  rectangle "IAM" as IAM
  rectangle "CloudWatch" as CloudWatch
}

Slack --> APIGateway
BotHandler --> USWorker
BotHandler --> EUWorker
BotHandler --> APWorker
USWorker --> Lambda
EUWorker --> Lambda
APWorker --> Lambda
Lambda --> IAM
Lambda --> CloudWatch
@enduml