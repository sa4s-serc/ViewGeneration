@startuml swir-rs_swir
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<utils>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend Handlers" <<frontend>> {
  rectangle "HTTP Handler" as HTTP
  rectangle "gRPC Handler" as GRPC
}

package "Core Handlers" <<backend>> {
  rectangle "Service Invocation\n(mDNS/DynamoDB)" as SI
  rectangle "PubSub\n(Kafka/NATS/Kinesis)" as PubSub
  rectangle "Persistence\n(Redis/DynamoDB)" as Persistence
}

package "Utilities" <<utils>> {
  rectangle "Configuration" as Config
  rectangle "Metrics (OpenTelemetry)" as Metrics
  rectangle "Tracing" as Tracing
  rectangle "Structs/Enums" as Structs
}

package "External Integrations" <<integration>> {
  rectangle "Kafka" as Kafka
  rectangle "NATS" as NATS
  rectangle "AWS Kinesis" as Kinesis
  rectangle "Redis" as Redis
  rectangle "DynamoDB" as DynamoDB
  rectangle "mDNS" as mDNS
}

HTTP --> SI
HTTP --> PubSub
HTTP --> Persistence
GRPC --> SI
GRPC --> PubSub
GRPC --> Persistence

SI --> mDNS
SI --> DynamoDB
PubSub --> Kafka
PubSub --> NATS
PubSub --> Kinesis
Persistence --> Redis
Persistence --> DynamoDB

Config --> HTTP
Config --> GRPC
Config --> SI
Config --> PubSub
Config --> Persistence
Metrics --> HTTP
Metrics --> GRPC
Metrics --> SI
Metrics --> PubSub
Metrics --> Persistence
Tracing --> HTTP
Tracing --> GRPC
Tracing --> SI
Tracing --> PubSub
Tracing --> Persistence
Structs --> HTTP
Structs --> GRPC
Structs --> SI
Structs --> PubSub
Structs --> Persistence
@enduml