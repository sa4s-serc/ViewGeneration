@startuml FPriv_factom-harmony-connect-python-sdk
skinparam rectangle {
  BackgroundColor<<client>> #d9e7fd
  BackgroundColor<<utility>> #d8f5d3
  BackgroundColor<<handler>> #fddddd
  BackgroundColor<<api>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Client Classes" <<client>> {
  rectangle "FactomClient" as FactomClient
  rectangle "ChainsClient" as ChainsClient
  rectangle "EntriesClient" as EntriesClient
  rectangle "IdentitiesClient" as IdentitiesClient
  rectangle "ApiInfoClient" as ApiInfoClient
  rectangle "ReceiptsClient" as ReceiptsClient
  rectangle "AnchorsClient" as AnchorsClient
  FactomClient --> ChainsClient
  FactomClient --> EntriesClient
  FactomClient --> IdentitiesClient
  FactomClient --> ApiInfoClient
  FactomClient --> ReceiptsClient
  FactomClient --> AnchorsClient
}

package "Utilities" <<utility>> {
  rectangle "Utils" as Utils
  rectangle "KeyCommon" as KeyCommon
  rectangle "ValidateSignatureUtil" as ValidateSig
  rectangle "CommonUtil" as CommonUtil
}

package "Request Handler" <<handler>> {
  rectangle "request_handler.py" as RequestHandler
}

package "Sample Application" <<client>> {
  rectangle "simulate_notary.py" as NotaryApp
}

[FactomClient] --> RequestHandler
[ChainsClient] --> RequestHandler
[EntriesClient] --> RequestHandler
[IdentitiesClient] --> RequestHandler
[ApiInfoClient] --> RequestHandler
[ReceiptsClient] --> RequestHandler
[AnchorsClient] --> RequestHandler

[Utils] --> KeyCommon
[ValidateSig] --> KeyCommon
[CommonUtil] --> RequestHandler

[NotaryApp] --> FactomClient

cloud "Factom Harmony\nConnect API" <<api>> as FactomAPI
RequestHandler --> FactomAPI
@enduml