@startuml McOrts_taller-iot-sensor_radiactividad
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Geiger Counter Module" as Geiger #palegreen

rectangle "ESP8266\n(WEMOS D1 mini Pro)" as ESP8266 #lightsteelblue {
    rectangle "Pulse Interrupt Handler" as Interrupt
    rectangle "CPM Calculator" as CPM
    rectangle "MQTT Client" as MQTT
}

rectangle "Wi-Fi Network" as WiFi #aliceblue

rectangle "MQTT Broker" as Broker #mistyrose

rectangle "Node-RED" as NodeRED #lightyellow

rectangle "GMC.MAP Platform" as GMC #peachpuff

' ========== Connections ==========
Geiger -> Interrupt : Radiation pulses
Interrupt -> CPM : Pulse count
CPM -> MQTT : CPM data
ESP8266 --> WiFi : Connect
MQTT --> Broker : Publish CPM data\nSubscribe to control topics
Broker --> NodeRED : Receive CPM data
NodeRED --> GMC : Forward data for visualization
Broker --> MQTT : LED control commands
MQTT -> ESP8266 : Execute commands (e.g. LED control)
@enduml