```plantuml
@startuml alanchn31_Movalytics-Data-Warehouse
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Apache Airflow" as Airflow {
  rectangle "Airflow DAG\n(movies_dwh_dag.py)" as DAG
}

rectangle "Apache Spark" as Spark {
  rectangle "Load Staging Ratings\n(load_staging_ratings.py)" as LoadRatings
  rectangle "Load Staging Movies\n(load_staging_movies.py)" as LoadMovies
}

rectangle "Amazon Redshift" as Redshift {
  rectangle "Staging Tables" as Staging
  rectangle "Dimension Tables" as Dimension
}

rectangle "Kaggle & St. Louis FRED" as DataSources {
  rectangle "MovieLens Dataset" as MovieLens
  rectangle "CPI Dataset" as CPI
}

rectangle "Docker" as Docker {
  rectangle "Docker Compose\n(docker-compose-LocalExecutor.yml)" as DockerCompose
}

rectangle "Data Quality" as DataQuality {
  rectangle "DataQualityOperator\n(data_quality.py)" as QualityOperator
}

' ========== Connections ==========
User --> Airflow : trigger DAG

' Airflow interactions
Airflow --> DataSources : extract data from\nMovieLens & CPI
Airflow --> Spark : execute Spark jobs\nfor data transformation
Airflow --> Redshift : load data into staging\ntables using BashOperator

' Spark interactions
Spark --> Redshift : transform and load data\ninto staging tables
Spark --> Airflow : notify task completion

' Redshift interactions
Staging --> Dimension : upsert transformed data
Airflow --> QualityOperator : perform data quality checks
QualityOperator --> Redshift : validate data integrity

' Docker interactions
Docker --> Airflow : containerize Airflow\nand its dependencies
Docker --> DockerCompose : manage service orchestration

@enduml
```