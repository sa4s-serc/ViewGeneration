```plantuml
@startuml yoshixmk_remarks
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Chrome Extension" as ChromeExt {
  rectangle "popup.html\npopup.css\nrecord.js" as ChromeFiles
}

rectangle "Deno Web Server" as WebServer {
  rectangle "server.ts" as Server
  rectangle "handlers" as Handlers {
    rectangle "homePage.jsx" as HomePage
    rectangle "quotes.ts" as QuotesHandler
    rectangle "remarks.ts" as RemarksHandler
  }
  rectangle "queries/queryFauna.ts" as QueryFauna
}

rectangle "FaunaDB" as FaunaDB #lightyellow {
  rectangle "GraphQL API" as GraphQLAPI
  rectangle "Quote\nRemark" as FaunaTypes
}

rectangle "GitPress Blog" as Blog {
  rectangle "source/*.md" as BlogPosts
}

' ========== Interactions ==========
User --> ChromeExt : Record remark
ChromeExt --> WebServer : Send remark data

WebServer --> Handlers : Route request
Handlers --> RemarksHandler : Process remark data
RemarksHandler --> QueryFauna : Store remark
QueryFauna --> FaunaDB : Execute GraphQL mutation

User --> WebServer : View homepage
WebServer --> Handlers : Route request
Handlers --> HomePage : Render remark count

User --> WebServer : View travelogue
WebServer --> Handlers : Route request
Handlers --> Blog : Fetch RSS feed
Blog --> Handlers : Return travelogue data
Handlers --> HomePage : Render travelogue content
@enduml
```