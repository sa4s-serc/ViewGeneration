```plantuml
@startuml GoogleCloudPlatform_datacatalog-tag-engine
skinparam rectangle {
  BackgroundColor<<api>> #d9e7fd
  BackgroundColor<<ui>> #d8f5d3
  BackgroundColor<<controller>> #fddddd
  BackgroundColor<<storage>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Tag Engine Services" {
  rectangle "Web UI\n(Jinja2 Templates)" <<ui>> as WebUI
  rectangle "API Endpoints\n(Flask)" <<api>> as API
  WebUI --> API
}

package "Controllers" <<controller>> {
  rectangle "DataCatalogController" as DataCatalogController
  rectangle "DataplexController" as DataplexController
  rectangle "TagEngineStoreHandler" as TagEngineStoreHandler
  rectangle "TaskManager" as TaskManager
  rectangle "JobManager" as JobManager
  rectangle "BigQueryUtils" as BigQueryUtils
  rectangle "Access Control\n(OAuth 2.0, IAM)" as AccessControl
  API --> DataCatalogController
  API --> DataplexController
  API --> TagEngineStoreHandler
  API --> TaskManager
  API --> JobManager
  API --> AccessControl
}

package "Storage" <<storage>> {
  database "Firestore" as Firestore
  database "BigQuery" as BigQuery
  rectangle "Cloud Storage (GCS)" as GCS
  TagEngineStoreHandler --> Firestore
  BigQueryUtils --> BigQuery
  API --> GCS
}

package "Asynchronous Processing" {
  rectangle "Cloud Tasks" as CloudTasks
  TaskManager --> CloudTasks
}

package "Configuration Management" {
  rectangle "Configurations\n(Stored in Firestore)" as Configurations
  Configurations --> Firestore
}

@enduml
```