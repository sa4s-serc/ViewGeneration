```plantuml
@startuml dspace-group_simphera-reference-architecture-azure

skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "DevOps Engineer" as DevOps

rectangle "Terraform" as TF {
  rectangle "main.tf" as MainTF
  rectangle "variables.tf" as VariablesTF
  rectangle "outputs.tf" as OutputsTF
}

rectangle "Azure" as Azure {
  rectangle "Kubernetes Cluster\n(AKS)" as AKS
  rectangle "PostgreSQL Flexible Servers" as PostgreSQL
  rectangle "MinIO Storage Accounts" as MinIO
  rectangle "Azure Key Vault" as KeyVault
  rectangle "Networking" as Networking
  rectangle "Private Link" as PrivateLink
  rectangle "License Server" as LicenseServer
  rectangle "Log Analytics" as LogAnalytics
  rectangle "Bastion Host" as BastionHost
}

rectangle "GitHub Actions" as GitHubActions {
  rectangle "workflow\n(qualitygate.yml)" as Workflow
}

' ========== Connections ==========
DevOps --> TF : initiate deployment

' Terraform interactions
TF --> Azure : provision resources
MainTF --> AKS
MainTF --> PostgreSQL
MainTF --> MinIO
MainTF --> KeyVault
MainTF --> Networking
MainTF --> PrivateLink
MainTF --> LicenseServer
MainTF --> LogAnalytics
MainTF --> BastionHost

' Variable and output usage
VariablesTF --> MainTF : provide configuration
MainTF --> OutputsTF : export information

' GitHub Actions workflow
DevOps --> GitHubActions : push code changes
GitHubActions --> TF : trigger pre-commit checks
Workflow --> TF : execute format, validation, linting

@enduml
```