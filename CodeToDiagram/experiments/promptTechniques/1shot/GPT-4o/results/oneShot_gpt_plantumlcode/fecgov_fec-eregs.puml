```plantuml
@startuml fecgov_fec-eregs
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
  rectangle "Django Templates\nSCSS & JS" as Templates #palegreen
}

rectangle "Backend" as BE {
  rectangle "Django App\nWSGI Entry" as DjangoApp #lightsteelblue
  rectangle "PostgreSQL\nDatabase" as Database #aliceblue
  rectangle "ElasticSearch" as ElasticSearch #lightyellow
}

rectangle "Cloud Foundry\n(cloud.gov)" as CloudFoundry #mistyrose

rectangle "API" as API #lightgrey

' ========== Connections ==========
User --> FE : Access Regulations

' Frontend interactions
FE <--> API : Fetch regulation data
FE --> Templates : Render Regulation Page

' Backend interactions
DjangoApp <--> Database : Query regulation data
DjangoApp <--> ElasticSearch : Keyword search

' Deployment
DjangoApp --> CloudFoundry : Deploy application
CloudFoundry --> DjangoApp : Run application

@enduml
```