```plantuml
@startuml brightzheng100_instana-handson-labs
skinparam rectangle {
  BackgroundColor<<installation>> #f0f9ff
  BackgroundColor<<core>> #eaffd0
  BackgroundColor<<advanced>> #ffe4c4
  BackgroundColor<<scripts>> #fddde6
  BackgroundColor<<extra>> #fceabb
  Style roundrect
}
skinparam defaultTextAlignment center

package "Instana Hands-on Labs" <<installation>> {
  rectangle "README.md" as README
  rectangle "part-1/lab-*.md\n(Installation & Configuration)" as Part1
}

package "Core APM Capabilities" <<core>> {
  rectangle "part-2/lab-*.md\n(Core Features)" as Part2
}

package "Advanced Monitoring" <<advanced>> {
  rectangle "part-3/lab-*.md\n(Advanced Topics)" as Part3
}

package "Scripts" <<scripts>> {
  rectangle "bootstrap-k8s.sh\n& prepare-join-k8s.sh" as K8sSetup
  rectangle "utils.sh" as Utils
  rectangle "rhel.sh & ubuntu.sh\n(OS Configurations)" as OSConfig
  rectangle "scripts/manifests\n(K8s Manifests)" as Manifests
}

package "Extra Resources" <<extra>> {
  rectangle "robot-shop-on-docker.md\n(Robot Shop Example)" as RobotShop
}

README --> Part1
Part1 --> Part2
Part2 --> Part3
Part3 --> K8sSetup
Part3 --> Utils
K8sSetup --> Manifests
Utils --> OSConfig
RobotShop --> Part3
@enduml
