```plantuml
@startuml rubenbupe_proyectos-data
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<metrics>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

rectangle "Frontend (Next.js)" <<frontend>> {
  rectangle "React Components" as React
  rectangle "TensorFlow.js" as TensorFlow
  User --> React
  React --> TensorFlow
}

rectangle "API (Python Flask)" <<backend>> {
  rectangle "Endpoints" as Endpoints
  rectangle "WebSocket" as WebSocket
  rectangle "Image Processing\n(OpenCV)" as OpenCV
  User --> Endpoints
  Endpoints --> WebSocket
  WebSocket --> OpenCV
}

rectangle "Metrics API (Node.js)" <<metrics>> {
  rectangle "Metrics Collection" as Metrics
  rectangle "RabbitMQ Consumer" as RabbitMQConsumer
  Metrics --> RabbitMQConsumer
}

database "MongoDB" <<db>> as MongoDB
rectangle "RabbitMQ" as RabbitMQ

React --> Endpoints : API Requests
Endpoints --> MongoDB : Data Storage
Endpoints --> RabbitMQ : Publish Events
RabbitMQConsumer --> MongoDB : Store Metrics
RabbitMQConsumer --> RabbitMQ : Consume Events

package "Kubernetes & GCP" {
  rectangle "Cert-Manager" as CertManager
  rectangle "Nginx-Ingress" as NginxIngress
  rectangle "GKE" as GKE

  CertManager --> NginxIngress : Manage TLS
  NginxIngress --> Endpoints : Route Requests
  NginxIngress --> React : Route Requests
  RabbitMQ --> GKE : Hosted
  MongoDB --> GKE : Hosted
}

@enduml
```