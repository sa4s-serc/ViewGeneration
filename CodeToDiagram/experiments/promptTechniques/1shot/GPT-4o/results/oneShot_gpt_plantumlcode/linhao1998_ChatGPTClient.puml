```plantuml
@startuml linhao1998_ChatGPTClient
skinparam rectangle {
  BackgroundColor<<view>> #d9e7fd
  BackgroundColor<<viewmodel>> #d8f5d3
  BackgroundColor<<model>> #fddddd
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "View" <<view>> {
  rectangle "Layout Files\n(app/src/main/res/layout)" as Layout
  rectangle "ChatActivity" as ChatActivity
  rectangle "SettingsActivity" as SettingsActivity
  Layout --> ChatActivity
  Layout --> SettingsActivity
}

package "ViewModel" <<viewmodel>> {
  rectangle "ChatViewModel" as ChatVM
  rectangle "ChatListViewModel" as ChatListVM
  rectangle "MsgListViewModel" as MsgListVM
  ChatActivity --> ChatVM
  ChatActivity --> ChatListVM
  ChatActivity --> MsgListVM
}

package "Model" <<model>> {
  rectangle "Chat" as Chat
  rectangle "Msg" as Msg
  ChatVM --> Chat
  MsgListVM --> Msg
}

package "Data Layer" <<data>> {
  rectangle "AppDatabase" as AppDB
  rectangle "ChatDao" as ChatDao
  rectangle "MsgDao" as MsgDao
  rectangle "Repository" as Repository
  ChatDao --> AppDB
  MsgDao --> AppDB
  Repository --> ChatDao
  Repository --> MsgDao
  ChatVM --> Repository
  MsgListVM --> Repository
}

@enduml
```