```plantuml
@startuml ingeniala_heybluekata
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "Web UI" as WebUI
  rectangle "Mobile UI" as MobileUI
  WebUI --> "Omnichannel BFF"
  MobileUI --> "HeyBlue BFF Mobile"
}

package "Backend" <<backend>> {
  rectangle "Omnichannel BFF" as OmnichannelBFF
  rectangle "HeyBlue BFF Mobile" as HeyBlueBFFMobile
  rectangle "BFF Web Container" as BFFWebContainer
  rectangle "User Management Service" as UserManagement
  rectangle "Interaction & Gamification" as InteractionGamification
  rectangle "Commerce Service" as Commerce
  rectangle "Content Management" as ContentManagement
  rectangle "Notification & Messaging" as NotificationMessaging
  OmnichannelBFF --> UserManagement
  HeyBlueBFFMobile --> UserManagement
  BFFWebContainer --> UserManagement
  UserManagement --> InteractionGamification
  InteractionGamification --> Commerce
  Commerce --> ContentManagement
  ContentManagement --> NotificationMessaging
}

package "Integration" <<integration>> {
  rectangle "AWS Cognito" as Cognito
  rectangle "Kinesis Data Streams" as Kinesis
  rectangle "API Gateway" as APIGateway
  rectangle "EventBridge" as EventBridge
  UserManagement --> Cognito
  NotificationMessaging --> Kinesis
  APIGateway --> OmnichannelBFF
  APIGateway --> HeyBlueBFFMobile
  APIGateway --> BFFWebContainer
  EventBridge --> InteractionGamification
}

package "Data Storage and Analytics" <<data>> {
  rectangle "DynamoDB" as DynamoDB
  rectangle "S3 & Glacier" as S3Glacier
  rectangle "Athena" as Athena
  rectangle "Metabase" as Metabase
  Commerce --> DynamoDB
  ContentManagement --> S3Glacier
  Athena --> Metabase
  S3Glacier --> Athena
}

@enduml
```