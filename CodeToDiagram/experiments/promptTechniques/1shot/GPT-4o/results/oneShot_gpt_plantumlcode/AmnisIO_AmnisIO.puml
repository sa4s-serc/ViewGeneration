```plantuml
@startuml AmnisIO_AmnisIO
skinparam rectangle {
  BackgroundColor<<typescript>> #d9e7fd
  BackgroundColor<<c_code>> #d8f5d3
  BackgroundColor<<platformio>> #fddddd
  BackgroundColor<<cli>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "TypeScript Layer" <<typescript>> {
  rectangle "Reactive IoT Programming\n(via rivulet)" as ReactiveIoT
  rectangle "TypeScript Examples\n(Arduino UNO)" as TSExamples
  TSExamples --> ReactiveIoT
}

package "C Code Layer" <<c_code>> {
  rectangle "Transpilation with typewriter" as Typewriter
  rectangle "rivulet Stream Library\n(C implementation)" as RivuletC
  rectangle "gyrus Board Abstraction\n(Arduino UNO)" as GyrusUNO
  ReactiveIoT --> Typewriter
  Typewriter --> RivuletC
  Typewriter --> GyrusUNO
}

package "PlatformIO Integration" <<platformio>> {
  rectangle "Project Management\n(Build & Deploy)" as PlatformIO
  Typewriter --> PlatformIO
}

package "AmnisIO CLI" <<cli>> {
  rectangle "CLI Commands\n(init, build, deploy)" as CLICommands
  rectangle "bin/index.js\n(Entry Point)" as CLIEntry
  CLIEntry --> CLICommands
  CLICommands --> Typewriter
  CLICommands --> PlatformIO
}

@enduml
```