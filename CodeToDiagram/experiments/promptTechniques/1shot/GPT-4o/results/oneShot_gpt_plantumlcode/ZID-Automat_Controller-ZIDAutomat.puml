```plantuml
@startuml ZID-Automat_Controller-ZIDAutomat
skinparam rectangle {
  BackgroundColor<<api>> #d9e7fd
  BackgroundColor<<borrow>> #d8f5d3
  BackgroundColor<<datacollect>> #fddddd
  BackgroundColor<<ui>> #fff1c9
  BackgroundColor<<config>> #e5e5e5
  Style roundrect
}
skinparam defaultTextAlignment center

package "API Module" <<api>> {
  rectangle "Requests.py\n(JWT, HTTP Requests)" as Requests
}

package "Borrow Module" <<borrow>> {
  rectangle "BorrowM (Facade)" as BorrowM
  rectangle "QRCodeReader.py\n(Serial Communication)" as QRCodeReader
  rectangle "Eject.py\n(GPIO Control)" as Eject
  rectangle "ClockPins\n(GPIO Pin Management)" as ClockPins
  BorrowM --> QRCodeReader
  BorrowM --> Eject
  Eject --> ClockPins
}

package "Data Collect Module" <<datacollect>> {
  rectangle "DataCollect.py\n(Event Logging)" as DataCollect
  BorrowM --> DataCollect
}

package "User Interface" <<ui>> {
  rectangle "ScreenOutput.py\n(I2C LCD)" as ScreenOutput
  rectangle "mp_i2c_lcd1602.py\n(I2C LCD Library)" as LCDLibrary
  rectangle "NeoPixel LED\n(LED Feedback)" as NeoPixelLED
  ScreenOutput --> LCDLibrary
  BorrowM --> ScreenOutput
  BorrowM --> NeoPixelLED
}

package "Configuration" <<config>> {
  rectangle "Configuration.json\n(System Settings)" as Configuration
}

rectangle "Main12.py\n(Core Logic)" as Main12 {
  Main12 --> BorrowM
  Main12 --> Requests
  Main12 --> Configuration
}

rectangle "main.py (Entry Point)" as Main {
  Main --> Main12
}

rectangle "boot.py (Initialization)" as Boot {
  Boot --> Main
}

@enduml
```