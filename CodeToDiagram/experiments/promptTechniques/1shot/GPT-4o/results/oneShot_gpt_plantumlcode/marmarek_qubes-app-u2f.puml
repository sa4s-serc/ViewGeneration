```plantuml
@startuml marmarek_qubes-app-u2f
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<protocol>> #fddddd
  BackgroundColor<<service>> #f1e1ff
  BackgroundColor<<utility>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Browser VM)" <<frontend>> {
  rectangle "CTAPHID Emulation\n(qubesctap/client/hidemu.py)" as HIDEmulation
  HIDEmulation -up-> "Qrexec Transport\n(qubes-rpc/*)" <<service>>
}

package "Backend (sys-usb VM)" <<backend>> {
  rectangle "CTAP Protocol Handlers" <<protocol>> {
    rectangle "CTAP1/U2F\n(qubesctap/ctap1.py)" as CTAP1
    rectangle "CTAP2\n(qubesctap/protocol.py)" as CTAP2
  }
  rectangle "Qrexec Transport\n(qubes-rpc/*)" as QrexecTransport
  rectangle "Policy Enforcement\n(qubes-rpc-policy/*)" as PolicyEnforcement
  rectangle "Systemd Services\n(systemd/*)" as SystemdServices
  rectangle "Udev Rules\n(udev/60-qctap-hidraw.rules)" as UdevRules
  rectangle "Sys-USB Code\n(qubesctap/sys_usb/*)" as SysUSB
  CTAP1 -up-> SysUSB
  CTAP2 -up-> SysUSB
  QrexecTransport -up-> SysUSB
  QrexecTransport -up-> PolicyEnforcement
  SystemdServices -up-> SysUSB
  UdevRules -up-> SysUSB
}

package "Utilities" <<utility>> {
  rectangle "Utility Functions\n(qubesctap/util.py)" as UtilFunctions
  rectangle "Setup and Build\n(setup.py, Makefile, .qubesbuilder)" as SetupBuild
  rectangle "CI Configurations\n(.gitlab-ci.yml, ci/*)" as CIConfig
  UtilFunctions --> SetupBuild
  SetupBuild --> CIConfig
}

HIDEmulation --> QrexecTransport
QrexecTransport --> CTAP1
QrexecTransport --> CTAP2

@enduml
```