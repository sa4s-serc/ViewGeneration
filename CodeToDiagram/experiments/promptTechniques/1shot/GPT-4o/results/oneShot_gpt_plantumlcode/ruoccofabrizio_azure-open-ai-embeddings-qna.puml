```plantuml
@startuml ruoccofabrizio_azure-open-ai-embeddings-qna
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Web Application" as WebApp {
  rectangle "Streamlit App\n(OpenAI_Queries.py)" as StreamlitApp
}

rectangle "Azure Services" as AzureServices #lightblue {
  rectangle "Azure OpenAI Service" as OpenAIService
  rectangle "Azure Cognitive Search" as CognitiveSearch
  rectangle "Redis" as Redis
  rectangle "PGVector" as PGVector
}

rectangle "Azure Functions" as AzureFunctions #lightyellow {
  rectangle "Batch Start Processing\n(__init__.py)" as BatchStartProcessing
  rectangle "Batch Push Results\n(__init__.py)" as BatchPushResults
}

rectangle "Azure Queue" as AzureQueue #lightgrey

rectangle "Azure Blob Storage" as BlobStorage #aliceblue

' ========== Connections ==========
User --> StreamlitApp : ask question

' WebApp interactions
StreamlitApp --> OpenAIService : convert query to embeddings
StreamlitApp --> CognitiveSearch : search for documents by embeddings
StreamlitApp --> Redis : search for documents by embeddings
StreamlitApp --> PGVector : search for documents by embeddings
CognitiveSearch --> StreamlitApp : return document chunks
Redis --> StreamlitApp : return document chunks
PGVector --> StreamlitApp : return document chunks
StreamlitApp --> OpenAIService : generate answer from documents + query
OpenAIService --> StreamlitApp : return generated answer

' Azure Functions interactions
BatchStartProcessing --> AzureQueue : add batch processing messages
AzureQueue --> BatchPushResults : trigger processing
BatchPushResults --> BlobStorage : read documents
BatchPushResults --> OpenAIService : create embeddings
BatchPushResults --> CognitiveSearch : store embeddings
BatchPushResults --> Redis : store embeddings
BatchPushResults --> PGVector : store embeddings

' Batch Processing Trigger
User --> BatchStartProcessing : trigger batch processing (HTTP request)

@enduml
```