```plantuml
@startuml mendhak_gpslogger
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<service>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "User Interface" <<ui>> {
  rectangle "GpsMainActivity" as MainActivity
  rectangle "MainPreferenceActivity" as PreferenceActivity
  rectangle "UI Views\n(Simple, Detailed, Big)" as UIViews
  rectangle "Notifications" as Notifications
  MainActivity --> UIViews
  MainActivity --> PreferenceActivity
  MainActivity --> Notifications
}

package "Background Service" <<service>> {
  rectangle "GpsLoggingService" as LoggingService
  rectangle "GeneralLocationListener" as LocationListener
  rectangle "PreferenceHelper" as PreferenceHelper
  LoggingService --> LocationListener
  LoggingService --> PreferenceHelper
}

package "Data Management" <<data>> {
  rectangle "FileLogger\n(GPX, KML, CSV, GeoJSON, NMEA)" as FileLogger
  rectangle "FileLoggerFactory" as LoggerFactory
  rectangle "AppSettings" as AppSettings
  rectangle "SharedPreferences" as SharedPreferences
  LoggerFactory --> FileLogger
  AppSettings --> SharedPreferences
}

package "External Integrations" <<external>> {
  rectangle "OpenStreetMap\nGoogle Drive\nDropbox" as CloudServices
  rectangle "SFTP, FTP" as FTPServices
  rectangle "Custom URLs\n(HTTP/HTTPS)" as CustomURLs
  rectangle "Tasker\nReceivers" as Tasker
  LoggingService --> CloudServices
  LoggingService --> FTPServices
  LoggingService --> CustomURLs
  LoggingService --> Tasker
}

rectangle "Event Bus" as EventBus
rectangle "WorkManager" as WorkManager

LoggingService --> FileLogger
LoggingService --> WorkManager
LoggingService --> EventBus
MainActivity --> EventBus
@enduml
```