```plantuml
@startuml victor369basu_Real-time-stock-market-prediction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Client" as User

rectangle "Node.js Server" as Server {
  rectangle "Kafka" as Kafka #lightyellow
  rectangle "MongoDB" as MongoDB #lightgreen
  rectangle "TensorFlow.js" as TensorFlow #lightblue
}

rectangle "Producer Service" as Producer #aliceblue
rectangle "Consumer Service" as Consumer #wheat
rectangle "ML Consumer" as MLConsumer #mistyrose
rectangle "Pre-process" as PreProcess #lavender
rectangle "Model Training" as ModelTraining #lightsteelblue
rectangle "Model Validation" as ModelValidation #palegreen

' ========== Connections ==========
User --> Server : HTTP Request for model\ntraining/validation

' Data Ingestion and Pipelining
Producer -> Kafka : Publish stock data

' Data Preprocessing
Kafka -> Consumer : Stream stock data
Consumer -> MongoDB : Store data logs

' ML Consumer for Real-time Prediction
Kafka -> MLConsumer : Stream live stock data
MLConsumer -> PreProcess : Preprocess data
MLConsumer -> TensorFlow : Generate predictions
MLConsumer -> MongoDB : Log predictions

' Model Training and Validation
Server -> ModelTraining : Train model using\nhistorical data
ModelTraining -> TensorFlow : Train LSTM Model
TensorFlow -> MongoDB : Save model weights

Server -> ModelValidation : Validate model performance
ModelValidation -> TensorFlow : Load model weights
ModelValidation -> MongoDB : Store performance metrics
@enduml
```