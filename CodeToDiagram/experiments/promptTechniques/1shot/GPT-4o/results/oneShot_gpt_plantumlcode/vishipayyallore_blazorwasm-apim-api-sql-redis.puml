```plantuml
@startuml vishipayyallore_blazorwasm-apim-api-sql-redis
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Blazor WebAssembly\nFrontend" as Frontend {
  rectangle "Pages/BookPages/*.razor"
}

rectangle "ASP.NET Core API\nBackend" as Backend {
  rectangle "Books.APIV1/Controllers/\nBooksController.cs"
  rectangle "BooksStore.Bll/\nBooksBll.cs"
}

rectangle "Data Persistence" as DataPersistence {
  rectangle "BooksStore.SqlDal/\nBookRepository.cs"
  rectangle "BooksDataStore/dbo/Tables/\nBooks.sql"
}

rectangle "Caching Layer" as CachingLayer {
  rectangle "BooksStore.CacheDal/\nBookCacheRepository.cs"
  rectangle "RedisCacheDbContext.cs"
}

rectangle "External Services" as ExternalServices {
  rectangle "Auth0"
  rectangle "Azure API Management"
}

' ========== Connections ==========
User --> Frontend : Interacts with UI

' Frontend interactions
Frontend <--> Backend : API calls for book management\n(authenticated via Auth0)

' Backend interactions
Backend --> DataPersistence : CRUD operations on SQL Server
Backend --> CachingLayer : Cache-aside pattern\n(check Redis cache before accessing SQL)

' Caching Layer interactions
CachingLayer <--> DataPersistence : Fetch data if not in cache

' External Services interactions
Backend --> ExternalServices : Auth0 for authentication
Backend <--> ExternalServices : Azure API Management as API Gateway
@enduml
```