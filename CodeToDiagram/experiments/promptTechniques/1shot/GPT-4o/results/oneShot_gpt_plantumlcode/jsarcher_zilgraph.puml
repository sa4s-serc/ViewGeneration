```plantuml
@startuml jsarcher_zilgraph
skinparam rectangle {
  BackgroundColor<<data_acquisition>> #d1e0f0
  BackgroundColor<<data_storage>> #f0d1d1
  BackgroundColor<<data_aggregation>> #d1f0d2
  BackgroundColor<<frontend_visualization>> #f0e6d1
  BackgroundColor<<reverse_proxy>> #e0d1f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Data Acquisition" <<data_acquisition>> {
  rectangle "Zilcrawler\n(zilswap/zilcrawl.py)" as Zilcrawler
  rectangle "Crawler\n(zilswap/crawler.py)" as Crawler
  Zilcrawler --> Crawler
}

package "Data Storage" <<data_storage>> {
  database "Elasticsearch\n(etc/elasticsearch/elasticsearch.yml)" as Elasticsearch
  database "MongoDB" as MongoDB
  Zilcrawler --> Elasticsearch
  Elasticsearch --> MongoDB
}

package "Data Aggregation\nand Processing" <<data_aggregation>> {
  rectangle "Aggregator Classes" as Aggregators
  rectangle "Zilswap Functions\n(zilswap/zilswap.py)" as ZilswapFunctions
  Aggregators --> Elasticsearch
  ZilswapFunctions --> Aggregators
}

package "Frontend Visualization" <<frontend_visualization>> {
  rectangle "Bokeh Charts\nand Tables" as Bokeh
  rectangle "Kibana Dashboards\n(etc/kibana/kibana.yml)" as Kibana
  rectangle "HTML/CSS\n(zilswap/templates/index.html)" as HTML
  Bokeh --> HTML
  Kibana --> HTML
}

package "Reverse Proxy" <<reverse_proxy>> {
  rectangle "Nginx Config\n(etc/nginx/conf.d/zilgraph.io.conf)" as Nginx
  Nginx --> Bokeh
  Nginx --> Kibana
}

rectangle "Zilgraph Oracle\n(Early Stage)" as Oracle

@enduml
```