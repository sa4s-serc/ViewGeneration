```plantuml
@startuml NLP4L_attic-nlp4l
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<analysis>> #d8f5d3
  BackgroundColor<<nlp>> #fddddd
  BackgroundColor<<repl>> #fff1c9
  BackgroundColor<<util>> #f0e4d7
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Components" <<core>> {
  rectangle "IWriter" as IWriter
  rectangle "IReader" as IReader
  rectangle "RawReader" as RawReader
  rectangle "ISearcher" as ISearcher
  rectangle "Schema\n(Field, FieldType)" as Schema
  rectangle "SchemaLoader" as SchemaLoader
  rectangle "Document" as Document
  IWriter --> Schema
  IReader --> Schema
  RawReader --> Schema
  ISearcher --> Schema
  SchemaLoader --> Schema
  Schema --> Document
}

package "Text Analysis" <<analysis>> {
  rectangle "Analyzer" as Analyzer
  rectangle "AnalyzerBuilder" as AnalyzerBuilder
  rectangle "Token" as Token
  rectangle "BrownCorpusAnalyzer" as BrownCorpusAnalyzer
  rectangle "TermDocs\n(Terms, Doc,\nPosAndOffset)" as TermDocs
  Analyzer --> Token
  AnalyzerBuilder --> Analyzer
  BrownCorpusAnalyzer --> Analyzer
  TermDocs --> Analyzer
}

package "NLP Algorithms" <<nlp>> {
  rectangle "HmmModel" as HmmModel
  rectangle "HmmTagger" as HmmTagger
  rectangle "HmmTokenizer" as HmmTokenizer
  rectangle "CollocationalAnalysisModel" as CollocationalAnalysisModel
  rectangle "SimpleFST" as SimpleFST
  HmmModel --> HmmTagger
  HmmTagger --> HmmTokenizer
  HmmTokenizer --> SimpleFST
  CollocationalAnalysisModel --> SimpleFST
}

package "REPL" <<repl>> {
  rectangle "NLP4LILoop" as NLP4LILoop
  rectangle "NLP4LMainGenericRunner" as NLP4LMainGenericRunner
  rectangle "NLP4L" as NLP4L
  rectangle "ZeppelinVisualizer" as ZeppelinVisualizer
  NLP4LILoop --> NLP4L
  NLP4LMainGenericRunner --> NLP4L
  NLP4L --> ZeppelinVisualizer
}

package "Utilities" <<util>> {
  rectangle "FeatureSelector" as FeatureSelector
  rectangle "TermsExtractor" as TermsExtractor
  rectangle "LoanWordsExtractor" as LoanWordsExtractor
  rectangle "TransliterationModel" as TransliterationModel
  FeatureSelector --> TermsExtractor
  TermsExtractor --> LoanWordsExtractor
  LoanWordsExtractor --> TransliterationModel
}

@enduml
