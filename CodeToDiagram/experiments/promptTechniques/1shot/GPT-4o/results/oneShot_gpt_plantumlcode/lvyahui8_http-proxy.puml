```plantuml
@startuml lvyahui8_http-proxy
skinparam rectangle {
  BackgroundColor<<core>> #d8f5d3
  BackgroundColor<<filter>> #fddddd
  BackgroundColor<<config>> #fff1c9
  BackgroundColor<<test>> #d9e7fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Proxy Server Core" <<core>> {
  rectangle "HttpProxyServer" as HttpProxyServer
  rectangle "ClientToProxyHandler" as ClientToProxyHandler
  rectangle "ProxyToServerInboundHandler" as ProxyToServerInboundHandler
  rectangle "EntitysManager" as EntitysManager
  rectangle "GlobalExceptionHandler" as GlobalExceptionHandler
  rectangle "EventLoopGroup" as EventLoopGroup
  rectangle "ChannelHandler" as ChannelHandler
  rectangle "Bootstrap" as Bootstrap

  HttpProxyServer --> ClientToProxyHandler
  ClientToProxyHandler --> ProxyToServerInboundHandler
  ClientToProxyHandler --> EntitysManager
  ProxyToServerInboundHandler --> GlobalExceptionHandler
  HttpProxyServer --> EventLoopGroup
  HttpProxyServer --> ChannelHandler
  HttpProxyServer --> Bootstrap
}

package "Request/Response Filters" <<filter>> {
  rectangle "ProxyRequestFilter" as ProxyRequestFilter
  rectangle "ProxyResponseFilter" as ProxyResponseFilter
  rectangle "AttackRequestFilter" as AttackRequestFilter
  rectangle "DefaultProxyResponseFilter" as DefaultProxyResponseFilter

  ProxyRequestFilter <|-- AttackRequestFilter
  ProxyResponseFilter <|-- DefaultProxyResponseFilter
  ClientToProxyHandler --> ProxyRequestFilter
  ProxyToServerInboundHandler --> ProxyResponseFilter
}

package "Configuration" <<config>> {
  rectangle "entitys.json" as EntitysJson
  EntitysManager --> EntitysJson
}

package "Testing Components" <<test>> {
  rectangle "TestClientApp" as TestClientApp
  rectangle "TestServerMain" as TestServerMain
  rectangle "TestResource" as TestResource

  TestClientApp --> HttpProxyServer
  TestServerMain --> TestResource
}

@enduml
```