```plantuml
@startuml wso2_chef-apim
skinparam rectangle {
  BackgroundColor<<chef>> #f7e8d7
  BackgroundColor<<wso2>> #d7f7f7
  BackgroundColor<<java>> #f7f7d7
  BackgroundColor<<mysql>> #d7f7d7
  Style roundrect
}

actor "User" as user

package "WSO2 API Manager Deployment" <<chef>> {
  rectangle "recipes/default.rb" as defaultRecipe
  rectangle "recipes/wso2_apim_installation.rb" as apimInstallation
  rectangle "recipes/apply_template.rb" as applyTemplate
  rectangle "attributes/default.rb" as attributes
  rectangle "templates/*.erb" as templates
  defaultRecipe --> apimInstallation : includes
  defaultRecipe --> applyTemplate : includes
  defaultRecipe --> attributes : uses
  applyTemplate --> templates : applies
}

package "Java Installation" <<java>> {
  rectangle "recipes/java_installation.rb" as javaInstallation
  defaultRecipe --> javaInstallation : includes
}

package "WSO2 API Manager 2.2.0" <<wso2>> {
  rectangle "Key Manager"
  rectangle "Publisher"
  rectangle "Store"
  rectangle "Traffic Manager"
  rectangle "Gateway Manager"
  rectangle "Gateway Worker"
  apimInstallation --> "Key Manager" : deploys
  apimInstallation --> "Publisher" : deploys
  apimInstallation --> "Store" : deploys
  apimInstallation --> "Traffic Manager" : deploys
  apimInstallation --> "Gateway Manager" : deploys
  apimInstallation --> "Gateway Worker" : deploys
}

package "MySQL Database" <<mysql>> {
  rectangle "Database Configuration"
  attributes --> "Database Configuration" : configures
}

user --> defaultRecipe : triggers
@enduml
```