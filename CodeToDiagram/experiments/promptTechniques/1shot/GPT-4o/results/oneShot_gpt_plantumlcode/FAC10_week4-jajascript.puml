```plantuml
@startuml FAC10_week4-jajascript
actor User

skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #fddddd
  BackgroundColor<<testing>> #fff1c9
  Style roundrect
}

rectangle "Frontend (Public Directory)" <<frontend>> {
  rectangle "index.html" as HTML
  rectangle "main.css" as CSS
  rectangle "main.js" as JS
  User --> HTML : "Enter Search Query"
  HTML --> JS : "Capture Input"
  JS --> HTML : "Display Suggestions"
}

rectangle "Backend (Src Directory)" <<backend>> {
  rectangle "server.js" as Server
  rectangle "router.js" as Router
  rectangle "handler.js" as Handler
  rectangle "algorithm.js" as Algorithm
  rectangle "data.json" as Data
  JS --> Server : "Send Query"
  Server --> Router : "Direct Request"
  Router --> Handler : "Serve Response"
  Handler --> Algorithm : "Call Autocomplete"
  Algorithm --> Data : "Retrieve Data"
  Data --> Algorithm : "Return Matches"
  Algorithm --> Handler : "Return Suggestions"
  Handler --> Router : "Return to Client"
  Router --> Server : "Return to Client"
  Server --> JS : "Return Suggestions"
}

rectangle "Testing (Test Directory)" <<testing>> {
  rectangle "qunit.html" as QUnitHTML
  rectangle "frontendTests.js" as FrontendTests
  rectangle "backendTests.js" as BackendTests
  QUnitHTML --> FrontendTests : "Run Front-End Tests"
  BackendTests --> Server : "Test Back-End Functions"
}

note right of JS
  Implements event listeners
  and fetches data asynchronously
end note

note right of Algorithm
  Filters and processes
  data for autocomplete
end note

@enduml
```