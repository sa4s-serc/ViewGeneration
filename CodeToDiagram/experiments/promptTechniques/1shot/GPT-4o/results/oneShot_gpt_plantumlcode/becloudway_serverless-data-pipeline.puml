```plantuml
@startuml becloudway_serverless-data-pipeline
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor API

rectangle "S3" as S3 #aliceblue {
}

rectangle "Kinesis Firehose" as Firehose #lightsteelblue {
}

rectangle "Kinesis Streams" as Streams #lightyellow {
}

rectangle "DynamoDB" as DynamoDB #lightcyan {
  rectangle "RealTimeAnalyticsPerPointTable" as RealTimeTable
  rectangle "TrafficJamAlertsTable" as AlertsTable
}

rectangle "Lambda Functions" as Lambdas #palegreen {
  rectangle "RetrieveXMLTrafficData" as RetrieveXML
  rectangle "TransformTrafficDataToJson" as TransformJSON
  rectangle "PublishTrafficData" as PublishData
  rectangle "StreamProcessor" as StreamProcessor
  rectangle "StoreAnalyticsResultsPerPoint" as StoreResults
  rectangle "AlertSaver" as AlertSaver
  rectangle "AlertSender" as AlertSender
  rectangle "CurrentSituation" as CurrentSituation
  rectangle "CurrentAlerts" as CurrentAlerts
  rectangle "PowerBiForwarder" as PowerBiForwarder
}

rectangle "Power BI" as PowerBI #mistyrose

rectangle "Slack" as Slack #lavender

rectangle "Flask API" as FlaskAPI #lightgrey

' ========== Connections ==========
API --> RetrieveXML : Trigger to ingest XML data
RetrieveXML --> S3 : Store XML data

S3 --> TransformJSON : Trigger on XML object creation
TransformJSON --> S3 : Store JSON data

S3 --> PublishData : Trigger on JSON object creation
PublishData --> Firehose : Send data for storage

Firehose --> S3 : Store raw data
Firehose --> Streams : Stream data for processing

Streams --> StreamProcessor : Trigger to process data
StreamProcessor --> DynamoDB : Store filtered results

DynamoDB --> AlertSaver : Trigger on new data
AlertSaver --> AlertsTable : Add alert indicators

DynamoDB --> AlertSender : Trigger on new alert
AlertSender --> Slack : Send traffic jam alerts
AlertSender --> FlaskAPI : Send alerts via API

PowerBiForwarder --> PowerBI : Forward data for visualization

CurrentSituation --> DynamoDB : Retrieve current traffic conditions
CurrentAlerts --> DynamoDB : Retrieve current alerts

@enduml
```