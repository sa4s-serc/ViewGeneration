```plantuml
@startuml blockchain-signaling-system_bloss-core
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor NetworkAdmin

rectangle "Stalk" as StalkComponent #lightblue {
  rectangle "Ryu SDN\nController" as RyuController
  rectangle "Flow Statistics\nManager" as FlowStatsManager
  rectangle "Hosts Manager" as HostsManager
  rectangle "REST API" as StalkAPI
}

rectangle "Pollen" as PollenComponent #lightgreen {
  rectangle "Blockchain\nManager" as BlockchainManager
  rectangle "Data Store\nManager" as DataStoreManager
  rectangle "Encryption\nManager" as EncryptionManager
  rectangle "Attack Reporting" as AttackReporting
}

rectangle "BloSS" as BloSSComponent #lightyellow {
  rectangle "REST API" as BloSSAPI
  rectangle "Manager" as BloSSManager
}

rectangle "Ethereum\nBlockchain" as EthereumBlockchain #mistyrose
rectangle "InfluxDB" as InfluxDB #aliceblue
rectangle "IPFS" as IPFS #lightgrey

' ========== Connections ==========
NetworkAdmin --> StalkAPI : Configures monitoring\nand detection

' Stalk interactions
StalkAPI --> RyuController : Request mitigation
RyuController --> FlowStatsManager : Retrieve flow stats
RyuController --> HostsManager : Update host status\nDetect attack

' Pollen interactions
RyuController --> BlockchainManager : Report attack
BlockchainManager --> EthereumBlockchain : Submit attack report
DataStoreManager --> IPFS : Store attack reports
DataStoreManager --> InfluxDB : Store traffic statistics
AttackReporting --> EncryptionManager : Encrypt attack data

' BloSS interactions
NetworkAdmin --> BloSSAPI : Report attack\nRequest mitigation
BloSSAPI --> BloSSManager : Process request
BloSSManager --> BlockchainManager : Manage blockchain interaction
@enduml
```