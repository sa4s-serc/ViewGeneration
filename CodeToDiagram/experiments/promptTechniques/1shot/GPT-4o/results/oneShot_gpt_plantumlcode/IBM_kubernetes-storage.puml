```plantuml
@startuml IBM_kubernetes-storage
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "MKDocs Documentation" as Docs #lightyellow {
  rectangle "MkDocs" as MkDocs
  rectangle "Labs" as Labs {
    rectangle "Lab[0-7]" as Lab
  }
  rectangle "Admin Guide" as AdminGuide
}

rectangle "Kubernetes Cluster" as K8sCluster #lightblue {
  rectangle "Guestbook Application" as GuestbookApp #aliceblue {
    rectangle "Node.js" as NodeJS
    rectangle "MongoDB" as MongoDB
  }
  rectangle "Storage Solutions" as Storage {
    rectangle "IBM Cloud Object Storage" as ObjectStorage
    rectangle "IBM Cloud Block Storage" as BlockStorage
    rectangle "Persistent Volumes & Claims" as PVC
    rectangle "IBM Cloud Operator" as CloudOperator
  }
}

rectangle "CI/CD Pipeline" as CICD #lightgreen {
  rectangle "Travis CI" as TravisCI
  rectangle "GitHub Actions" as GitHubActions
}

' ========== Connections ==========
User --> Docs : reads
User --> K8sCluster : interacts with applications

' Documentation interactions
Docs --> MkDocs : builds site
MkDocs --> Labs : includes lab instructions

' Application Deployment
GuestbookApp --> K8sCluster : deploys application
NodeJS --> MongoDB : interacts with
K8sCluster --> Storage : provisions storage

' Storage interactions
Storage --> ObjectStorage : configures object storage
Storage --> BlockStorage : configures block storage
Storage --> PVC : manages PVs and PVCs
Storage --> CloudOperator : manages cloud services

' CI/CD interactions
CICD --> TravisCI : performs markdown linting
CICD --> GitHubActions : builds and deploys MkDocs

@enduml
```