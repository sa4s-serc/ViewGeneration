```plantuml
@startuml input-output-hk_marlowe-starter-kit
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
  rectangle "controller.js" as ControllerJS #lightgrey
}

rectangle "Marlowe Runtime" as Runtime #lightsteelblue {
  rectangle "proxy" as Proxy
  rectangle "chain-indexer" as ChainIndexer
  rectangle "chain-sync" as ChainSync
  rectangle "contract" as Contract
  rectangle "indexer" as Indexer
  rectangle "sync" as Sync
  rectangle "tx" as Tx
  rectangle "web-server" as WebServer
}

rectangle "Wallet (CIP30/CIP45)" as Wallet #aliceblue

rectangle "Docker Compose Services" as Docker #lightyellow {
  rectangle "Cardano Node" as CardanoNode
  rectangle "Postgres" as Postgres
  rectangle "Jupyter Notebook" as Jupyter
}

' ========== Connections ==========
User --> FE

' Frontend interactions
FE --> Wallet : connect\nretrieve address\nsign transactions
FE --> Runtime : create contract\ndeposit/release funds\nquery status
FE --> Docker : deploy environment\ncheck services health

' Runtime interactions
Proxy --> ChainIndexer
Proxy --> ChainSync
Proxy --> Contract
Proxy --> Indexer
Proxy --> Sync
Proxy --> Tx
Proxy --> WebServer

' Docker interactions
Docker --> CardanoNode : start node\nsync with Cardano network
Docker --> Postgres : store transaction data
Docker --> Jupyter : provide learning resources

@enduml
```