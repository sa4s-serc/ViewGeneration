```plantuml
@startuml yuwen123441_NVMeAutomation
skinparam rectangle {
  BackgroundColor<<driver>> #d9e7fd
  BackgroundColor<<common>> #d8f5d3
  BackgroundColor<<test>> #fddddd
  BackgroundColor<<logic>> #fff1c9
  BackgroundColor<<data>> #e7f3fe
  Style roundrect
}
skinparam defaultTextAlignment center

package "Driver Layer" <<driver>> {
  rectangle "nvme-ioctl.c\nDynamic Library" as IoctlLib
  rectangle "nvme.py\nPython Wrapper" as NvmePy
  IoctlLib --> NvmePy
}

package "Common Library" <<common>> {
  rectangle "Admin Command Interface" as AdminCmd
  rectangle "IO Command Interface" as IOCmd
  rectangle "Buffer Management" as BufferMgmt
  NvmePy --> AdminCmd
  NvmePy --> IOCmd
  NvmePy --> BufferMgmt
}

package "Logic Layer" <<logic>> {
  rectangle "Logic for NVMe\nInteractions" as Logic
  rectangle "Abstract Base Classes" as ABC
  AdminCmd --> Logic
  IOCmd --> Logic
  Logic --> ABC
}

package "Data Structures" <<data>> {
  rectangle "NVMe Command DTOs" as CmdDTOs
  rectangle "Queue Structures" as QueueStructs
  rectangle "Log Page Structures" as LogPages
  Logic --> CmdDTOs
  Logic --> QueueStructs
  Logic --> LogPages
}

package "Test Cases" <<test>> {
  rectangle "Admin Test Suite" as AdminTests
  rectangle "IO Test Suite" as IOTests
  Logic --> AdminTests
  Logic --> IOTests
}

@enduml
```