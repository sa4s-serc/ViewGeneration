```plantuml
@startuml dylanvanh_MunchOut
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Customer
actor Restaurant

rectangle "Flutter Frontend" as FE #lightyellow {
  rectangle "AuthBloc\nLoginBloc\nSignupBloc" as Bloc #lightgrey
  rectangle "UserRepository" as UserRepo #lightsteelblue
  rectangle "RestaurantRepository" as RestRepo #lightsteelblue
  rectangle "CustomerRepository" as CustRepo #lightsteelblue
}

rectangle "Flask Backend" as BE #mistyrose {
  rectangle "app.py\nAPI Endpoints" as API #palegreen
  rectangle "Customer\nRestaurant\nEvent\nBooking\nResources" as Resources #palegreen
  rectangle "Database\n(SQLAlchemy Models)" as DB #lightsteelblue
}

' ========== Connections ==========
Customer --> FE : authenticate\nbrowse events\nbook events
Restaurant --> FE : authenticate\ncreate/manage events

' Frontend interactions
FE --> Bloc : manage authentication and session state
Bloc --> UserRepo : fetch user authentication data
FE --> RestRepo : fetch/create/manage events
FE --> CustRepo : fetch/book/manage booking

' Backend interactions
UserRepo --> BE : authenticate user\nvia REST API
RestRepo --> BE : manage event data\nvia REST API
CustRepo --> BE : manage booking data\nvia REST API

BE --> Resources : process API requests
Resources --> DB : query/update data models

@enduml
```