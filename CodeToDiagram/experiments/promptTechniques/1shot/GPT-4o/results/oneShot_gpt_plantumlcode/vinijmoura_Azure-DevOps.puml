```plantuml
@startuml vinijmoura_Azure-DevOps
skinparam rectangle {
  BackgroundColor<<extraction>> #d9e7fd
  BackgroundColor<<transformation>> #d8f5d3
  BackgroundColor<<storage>> #fddddd
  BackgroundColor<<visualization>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Data Extraction (PowerShell Scripts)" <<extraction>> {
  rectangle "Azure DevOps CLI\n(az devops)" as CLI
  rectangle "REST APIs" as REST
  CLI --> REST
}

package "Data Transformation (PowerShell Scripts)" <<transformation>> {
  rectangle "JSON Parsing" as JSON
  rectangle "Data Filtering" as Filtering
  rectangle "String Manipulation" as StringManip
  rectangle "Custom PSObjects" as PSObjects
  JSON --> Filtering
  Filtering --> StringManip
  StringManip --> PSObjects
}

package "Data Storage (Azure SQL Database)" <<storage>> {
  database "Azure SQL DB" as SQLDB
  rectangle "Tables\n(AreaPermissions, VariableGroups,\nFeedPackageVersions, etc.)" as Tables
  SQLDB --> Tables
}

package "Data Visualization (Power BI)" <<visualization>> {
  rectangle "Power BI Desktop Files\n(.pbix)" as PBIX
  rectangle "Custom Visuals" as CustomVisuals
  rectangle "Static Resources\n(Base Themes)" as Themes
  PBIX --> CustomVisuals
  PBIX --> Themes
}

CLI --> JSON
REST --> JSON
PSObjects --> SQLDB
SQLDB --> PBIX
@enduml
```