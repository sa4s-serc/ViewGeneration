```plantuml
@startuml IBM_datastax-cassandra-clickstream
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (Next.js/React)" as FE {
  rectangle "AppHeader.jsx" as AppHeader
  rectangle "ProductCard.jsx" as ProductCard
  rectangle "Category.jsx" as Category
}

rectangle "Backend (Next.js API routes)" as Backend #lightyellow {
  rectangle "api/history.js" as HistoryAPI
  rectangle "api/products/index.js" as ProductsAPI
  rectangle "api/products/[category].js" as CategoryAPI
  rectangle "api/auth/[...nextauth].js" as AuthAPI
}

rectangle "Redux Store" as ReduxStore #lightsteelblue {
  rectangle "cart.slice.js" as CartSlice
}

rectangle "Database (DSE/Cassandra)" as Database #mistyrose {
  rectangle "clicks.service.js" as ClicksService
}

' ========== Connections ==========
User --> AppHeader : sign-in/sign-out\nview cart
User --> ProductCard : view product\nadd to cart
User --> Category : browse categories

AppHeader --> AuthAPI : user authentication
ProductCard --> ProductsAPI : add to cart action
Category --> CategoryAPI : fetch products by category

ReduxStore <--> FE : manage cart state
CartSlice --> ProductsAPI : send add-to-cart events

Backend --> ClicksService : interact with database
ClicksService --> Database : insert/retrieve clickstream data

AppHeader --> HistoryAPI : view clickstream history
@enduml
```