```plantuml
@startuml spagnuolocarmine_serverless-computing-for-iot
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor IoT_Device

rectangle "Serverless Platform" as Nuclio #lightcyan {
  rectangle "AMQP Producer\nFunction" as AMQPProducer #lightblue
  rectangle "AMQP Consumer\nFunction" as AMQPConsumer #lightblue
  rectangle "MQTT Producer\nFunction" as MQTTProducer #lightblue
  rectangle "MQTT Consumer\nFunction" as MQTTConsumer #lightblue
}

rectangle "Message Broker" as RabbitMQ #lightyellow {
  rectangle "AMQP Queue" as AMQPQueue #lightgoldenrodyellow
  rectangle "MQTT Topic" as MQTTTopic #lightgoldenrodyellow
}

rectangle "Logger" as Logger #lightgrey

' ========== Connections ==========
IoT_Device --> AMQPProducer : send temperature data
AMQPProducer --> AMQPQueue : publish message

AMQPQueue --> AMQPConsumer : consume message
AMQPConsumer --> Logger : log temperature data

IoT_Device --> MQTTProducer : send temperature data
MQTTProducer --> MQTTTopic : publish message

MQTTTopic --> MQTTConsumer : consume message
MQTTConsumer --> Logger : log temperature data
@enduml
```