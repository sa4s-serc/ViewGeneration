```plantuml
@startuml jlhood_retweet-leaderboard
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "UI" as UI {
  rectangle "leaderboard.html" as LeaderboardHTML
}

rectangle "API Gateway" as APIGateway #lightyellow

rectangle "Lambda Functions" as Lambda #lightsteelblue {
  rectangle "TweetProcessorHandler" as TweetProcessorHandler
  rectangle "GetLeaderboardHandler" as GetLeaderboardHandler
}

rectangle "DynamoDB" as DynamoDB #aliceblue {
  rectangle "LeaderboardTable" as LeaderboardTable
}

rectangle "AWS Serverless\nEvent Source" as EventSource #mistyrose

' ========== Connections ==========
User --> LeaderboardHTML : view leaderboard
LeaderboardHTML --> APIGateway : request leaderboard data
APIGateway --> GetLeaderboardHandler : invoke
GetLeaderboardHandler --> DynamoDB : query leaderboard data
DynamoDB --> GetLeaderboardHandler : return data
GetLeaderboardHandler --> APIGateway : return leaderboard data
APIGateway --> LeaderboardHTML : return data

EventSource --> TweetProcessorHandler : trigger on tweet
TweetProcessorHandler --> DynamoDB : update retweet count
@enduml
```