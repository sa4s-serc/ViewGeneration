```plantuml
@startuml duanfuxiang0_MysqlMigrationTool
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Source MySQL Database" as SourceDB #lightyellow

rectangle "Binlog Parser" as BinlogParser #lightblue {
  rectangle "canal.Canal" as Canal #aliceblue 
  rectangle "RowEventHandler" as RowHandler #aliceblue
}

rectangle "Binlog Event Processing" as EventProcessing #lightsteelblue {
  rectangle "Binlog Capture and Parsing" as CaptureParsing #palegreen
  rectangle "Data Mapping\nand Conversion" as DataMapping #palegreen
  rectangle "Database Operations" as DbOperations #palegreen
}

rectangle "Destination Database" as DestDB #lightyellow

' ========== Connections ==========
User --> SourceDB : perform database operations

' Binlog Parser interactions
SourceDB --> Canal : produce binlog events
Canal --> RowHandler : notify binlog events

' Event Processing interactions
RowHandler --> CaptureParsing : parse binlog events
CaptureParsing --> DataMapping : map data to Go structs
DataMapping --> DbOperations : prepare database operations
DbOperations --> DestDB : insert/update/delete data

@enduml
```