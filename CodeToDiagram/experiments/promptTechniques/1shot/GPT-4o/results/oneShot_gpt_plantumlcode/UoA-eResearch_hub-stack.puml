```plantuml
@startuml UoA-eResearch_hub-stack
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Developer

rectangle "Jenkins CI/CD" as Jenkins #lightyellow

rectangle "Terraform Infrastructure" as Terraform #lightblue

rectangle "AWS Services" as AWS #mistyrose {
  rectangle "S3 Bucket" as S3 #aliceblue
  rectangle "CloudFront" as CloudFront #aliceblue
  rectangle "ECS Cluster" as ECS #aliceblue
  rectangle "Lambda Function" as Lambda #aliceblue
  rectangle "ElasticSearch" as ElasticSearch #aliceblue
}

rectangle "ResearchHub Components" as ResearchHub #lightsteelblue {
  rectangle "ResearchHub Website\n(Frontend)" as Frontend #palegreen
  rectangle "GraphQL API\n(cer-graphql)" as GraphQLAPI #palegreen
  rectangle "Search Proxy\n(hub-search-proxy)" as SearchProxy #palegreen
}

' ========== Connections ==========
Developer --> Jenkins : push code
Jenkins --> Terraform : trigger deployment
Terraform --> AWS : provision AWS resources
Jenkins --> ResearchHub : deploy application components

' ResearchHub Components interactions with AWS services
Frontend --> CloudFront : serve static assets
Frontend --> GraphQLAPI : send GraphQL requests
GraphQLAPI --> ElasticSearch : proxy search requests
SearchProxy --> Lambda : handle search, update, delete
SearchProxy --> ElasticSearch : update/search index

@enduml
```