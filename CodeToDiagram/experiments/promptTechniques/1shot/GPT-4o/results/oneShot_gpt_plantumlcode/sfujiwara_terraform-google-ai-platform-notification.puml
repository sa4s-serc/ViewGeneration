```plantuml
@startuml sfujiwara_terraform-google-ai-platform-notification
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Google AI Platform" as AIPlatform #lightgrey {
}

rectangle "Google Cloud Logging" as Logging #mistyrose {
  rectangle "Log Sink" as LogSink #palegreen
}

rectangle "Google Cloud Pub/Sub" as PubSub #aliceblue {
  rectangle "Log Topic" as LogTopic #aliceblue
  rectangle "Notification Topic" as NotificationTopic #aliceblue
}

rectangle "Google Cloud Function" as CloudFunction #lightyellow

rectangle "Google Cloud Storage" as Storage #lightsteelblue {
  rectangle "Source Bucket" as SourceBucket #lightsteelblue
}

' ========== Connections ==========
AIPlatform --> Logging : generate logs
Logging --> LogSink : forward logs
LogSink --> LogTopic : publish log messages

LogTopic --> CloudFunction : trigger on new message

CloudFunction --> PubSub : publish notification
PubSub --> NotificationTopic : receive notification message

CloudFunction --> Storage : access source code

@enduml
```