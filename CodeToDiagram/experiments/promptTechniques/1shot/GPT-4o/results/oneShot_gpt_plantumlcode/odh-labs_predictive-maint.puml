```plantuml
@startuml odh-labs_predictive-maint
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Edge Device / Image Capture" as EdgeDevice #lightcyan

rectangle "Kafka" as Kafka #lightyellow

rectangle "Consumer Application" as ConsumerApp #lightgreen

rectangle "Seldon Core" as SeldonCore #lightpink

rectangle "MinIO" as MinIO #aliceblue

rectangle "Web Interface" as WebInterface #lightsteelblue

rectangle "OpenShift" as OpenShift #lightcoral

' ========== Connections ==========
User --> EdgeDevice : capture images

' Edge device to Kafka interaction
EdgeDevice -> Kafka : stream images

' Kafka to Consumer Application interaction
ConsumerApp -> Kafka : subscribe to image topic
Kafka -> ConsumerApp : push images

' Consumer Application to Seldon Core interaction
ConsumerApp -> SeldonCore : send images for inference
SeldonCore -> ConsumerApp : return inference results

' Consumer Application to MinIO interaction
ConsumerApp -> MinIO : store inference results

' MinIO to Web Interface interaction
WebInterface -> MinIO : fetch prediction results
User -> WebInterface : view predictions

' Deployment automation
OpenShift -> SeldonCore : deploy model
OpenShift -> Kafka : deploy Kafka cluster
OpenShift -> MinIO : deploy MinIO instance
OpenShift -> ConsumerApp : deploy consumer application
@enduml
```