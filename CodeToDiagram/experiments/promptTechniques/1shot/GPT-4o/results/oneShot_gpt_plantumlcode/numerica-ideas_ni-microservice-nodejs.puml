```plantuml
@startuml numerica-ideas_ni-microservice-nodejs
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
}

rectangle "Server Deployment" as ServerDeployment #lightsteelblue {
  rectangle "Express App" as ExpressApp #lightyellow
  rectangle "MongoDB" as MongoDB #palegreen
  rectangle "Redis" as Redis #aliceblue
  rectangle "Redis Pub/Sub" as RedisPubSub #thistle
}

rectangle "AWS Lambda Deployment" as LambdaDeployment #mistyrose {
  rectangle "Lambda Function" as LambdaFunction #lightyellow
  rectangle "SNS" as SNS #lightblue
}

rectangle "CI/CD Pipeline" as CICD #lightgrey

' ========== Connections ==========
User --> FE

' Server Deployment interactions
FE --> ExpressApp : API Requests (CRUD operations)
ExpressApp --> MongoDB : Query/Update article data
ExpressApp <--> Redis : Cache article data
ExpressApp <-> RedisPubSub : Inter-service communication

' AWS Lambda Deployment interactions
FE --> LambdaFunction : API Requests (CRUD operations)
LambdaFunction --> MongoDB : Query/Update article data
LambdaFunction <-> SNS : Inter-service communication

' CI/CD Pipeline interactions
CICD -> ServerDeployment : Deploy Express App
CICD -> LambdaDeployment : Deploy Lambda Function

@enduml
```