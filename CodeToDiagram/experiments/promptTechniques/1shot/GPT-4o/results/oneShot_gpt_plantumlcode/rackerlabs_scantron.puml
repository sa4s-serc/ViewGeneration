```plantuml
@startuml rackerlabs_scantron
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<storage>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend Enhancements" <<frontend>> {
  rectangle "jQuery DataTables" as jQuery
  rectangle "Font Awesome" as FontAwesome
  rectangle "jQuery UI" as jQueryUI
}

package "Console (Django Application)" <<backend>> {
  rectangle "Django Models\n(Configuration, Engine,\nSite, Scan, ScheduledScan)" as Models
  rectangle "Scan Scheduler" as Scheduler
  rectangle "Data Cleanup\n(scan_retention.py)" as Retention
  rectangle "Utility Functions" as Utility
  rectangle "Scan Schedule Visualization" as Visualizer
  rectangle "Django REST API" as API
  Models --> Scheduler
  Scheduler --> Visualizer
  Scheduler --> API
  API --> Utility
  API --> Retention
}

package "Engine Components" <<backend>> {
  rectangle "Engine Script\n(engine.py)" as EngineScript
  rectangle "Engine Service\n(scantron-engine.service)" as EngineService
  rectangle "NFS Watcher\n(nfs_watcher.sh)" as NFSWatcher
}

package "Integration & Automation" <<integration>> {
  rectangle "Ansible Playbooks\n(console.yml, engine.yml)" as Ansible
  rectangle "REST API Client\n(scantron_api_client.py)" as APIClient
  rectangle "Email Alerts" as EmailAlerts
  rectangle "Redis Queue (RQ)" as RedisQueue
  Scheduler --> EmailAlerts
  Scheduler --> APIClient
  API --> RedisQueue
  Ansible --> EngineScript
  Ansible --> Models
}

database "Shared NFS Storage" <<storage>> as NFS
rectangle "Scan Results Parsing\n(nmap_to_csv.py,\nmasscan_json_to_csv.py)" as Parsing
rectangle "Target Extraction\n(extract_targets.py)" as TargetExtraction
Parsing --> NFS
TargetExtraction --> NFS
EngineScript --> NFS

rectangle "Scanning Tools\n(nmap, masscan)" as ScanningTools
EngineScript --> ScanningTools

rectangle "License & Docs\n(LICENSE, README.md)" as Docs
Docs -[hidden]--> Ansible

@enduml
```