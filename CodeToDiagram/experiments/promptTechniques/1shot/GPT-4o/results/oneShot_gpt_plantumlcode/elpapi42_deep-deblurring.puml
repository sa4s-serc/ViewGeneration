```plantuml
@startuml elpapi42_deep-deblurring
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<model>> #fddddd
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<cache>> #fdf5c9
  BackgroundColor<<database>> #e0e0e0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Vue.js)" <<frontend>> {
  rectangle "User Interface" as UI
}

package "Backend (Flask)" <<backend>> {
  rectangle "API Gateway" as APIGateway
  rectangle "Request Orchestration" as RequestOrchestration
  rectangle "Data Collection" as DataCollection
  UI --> APIGateway
  APIGateway --> RequestOrchestration
  RequestOrchestration --> DataCollection
}

package "Model Serving\n(TensorFlow Serving)" <<model>> {
  rectangle "DeblurGAN-V2 Model\nInference" as ModelInference
  RequestOrchestration --> ModelInference
}

package "Model Repository" <<model>> {
  rectangle "Trained Model Storage" as TrainedModel
  rectangle "Training Scripts" as TrainingScripts
}

package "Data Storage" <<storage>> {
  rectangle "Cloudinary" as Cloudinary
  RequestOrchestration --> Cloudinary
}

package "Caching & Session Management" <<cache>> {
  rectangle "Redis" as Redis
  RequestOrchestration --> Redis
}

database "PostgreSQL" <<database>> as PostgreSQL
RequestOrchestration --> PostgreSQL

@enduml
```