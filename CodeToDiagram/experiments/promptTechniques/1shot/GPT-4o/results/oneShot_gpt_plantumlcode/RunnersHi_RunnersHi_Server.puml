```plantuml
@startuml RunnersHi_RunnersHi_Server
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Express Server" as Server #lightgrey {
  rectangle "Controllers" as Controllers {
    rectangle "authController" as AuthController
    rectangle "userController" as UserController
    rectangle "rankingController" as RankingController
    rectangle "recordController" as RecordController
  }
  
  rectangle "Middleware" as Middleware {
    rectangle "auth.js" as AuthMiddleware
    rectangle "ErrorHandler.js" as ErrorHandler
    rectangle "responseHandler.js" as ResponseHandler
  }

  rectangle "Socket.IO" as SocketIO #lightyellow {
    rectangle "socket.js" as SocketJS
  }
}

rectangle "MySQL Database" as Database #lightblue

User -> Server : HTTP Request (API Endpoint)

Server -> Middleware : Process Request
Middleware -> AuthMiddleware : Authenticate User

Middleware -> Controllers : Route Request
AuthController --> Database : Verify Token
UserController --> Database : Handle User Data
RankingController --> Database : Fetch Leaderboards
RecordController --> Database : Store/Fetch Running Records

Database --> Controllers : Return Data
Controllers -> Middleware : Handle Response
Middleware -> ErrorHandler : Handle Errors
Middleware -> ResponseHandler : Format Response
Middleware -> User : Send Response

User -> SocketIO : Establish Connection
SocketIO -> SocketJS : Manage Real-time Matching\nand Communication
SocketJS -> Database : Update Running Data

@enduml
```