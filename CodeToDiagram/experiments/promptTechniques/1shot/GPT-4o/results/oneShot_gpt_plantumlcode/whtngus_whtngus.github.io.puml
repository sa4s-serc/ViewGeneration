```plantuml
@startuml whtngus_whtngus.github.io
skinparam rectangle {
  BackgroundColor<<api>> #fddddd
  BackgroundColor<<quota>> #d9e7fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Google API Quota System" <<api>> {
  rectangle "API Error Handler" as ErrorHandler
  rectangle "Quota Management\nService" as QuotaManagement
  rectangle "Gemini API" as GeminiAPI
  ErrorHandler --> QuotaManagement
  QuotaManagement --> GeminiAPI
}

package "Quota Details" <<quota>> {
  rectangle "Quota Metric" as QuotaMetric
  rectangle "Quota ID" as QuotaID
  rectangle "Quota Dimensions" as QuotaDimensions
  rectangle "Quota Value" as QuotaValue
  QuotaManagement --> QuotaMetric
  QuotaManagement --> QuotaID
  QuotaManagement --> QuotaDimensions
  QuotaManagement --> QuotaValue
}

GeminiAPI --> ErrorHandler
@enduml
```