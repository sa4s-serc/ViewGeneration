@startuml OAID_Tengine

skinparam component {
  BackgroundColor<<core>> #DDEBF7
  BackgroundColor<<utils>> #E2EFDA
  BackgroundColor<<backend>> #FFF2CC
  BackgroundColor<<interface>> #FCE4D6
}

package "Tengine Lite" {
  [Model Conversion] <<core>>
  [Inference Engine] <<core>>
  [Operator Library] <<core>>
  [Testing Framework] <<utils>>
  [Device Abstraction Layer] <<core>>
  [Graph Representation] <<core>>
  [Memory Management] <<utils>>
  [Shader Management] <<utils>>
  [Online Reporting] <<utils>>
  [Python Bindings] <<interface>>

  package "Backends" {
    [CPU Backend] <<backend>>
    [GPU Backend] <<backend>>
    [NPU Backend] <<backend>>
  }

  [Model Conversion] --> [Graph Representation]
  [Inference Engine] --> [Device Abstraction Layer]
  [Inference Engine] --> [Graph Representation]
  [Inference Engine] --> [Operator Library]
  [Device Abstraction Layer] --> [CPU Backend]
  [Device Abstraction Layer] --> [GPU Backend]
  [Device Abstraction Layer] --> [NPU Backend]
  [Operator Library] --> [CPU Backend]
  [Operator Library] --> [GPU Backend]
  [Operator Library] --> [NPU Backend]
  [Testing Framework] --> [Inference Engine]
  [Shader Management] --> [GPU Backend]
  [Memory Management] --> [CPU Backend]
  [Memory Management] --> [GPU Backend]
  [Python Bindings] --> [Inference Engine]
}

@enduml