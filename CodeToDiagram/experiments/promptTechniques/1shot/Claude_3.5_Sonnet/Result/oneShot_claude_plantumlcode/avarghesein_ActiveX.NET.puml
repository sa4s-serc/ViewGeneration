@startuml avarghesein_ActiveX.NET

actor "Client Application" as Client
participant "ActiveX.NET.Server.exe" as Server
participant "MEF" as MEF
database "Plugin DLLs" as Plugins
participant "COM Object Instance" as ComObject

Client -> Server : Invoke COM object
activate Server

Server -> MEF : Discover plugins
activate MEF
MEF -> Plugins : Load plugin DLLs
MEF --> Server : Return discovered plugins
deactivate MEF

Server -> Server : Create ActiveXServerContext

loop for each discovered plugin
    Server -> Server : Register COM class
end

Server -> Server : Start message loop

Client -> Server : CreateInstance request
Server -> Server : Locate appropriate plugin

Server -> ComObject : Create instance
activate ComObject

Server --> Client : Return COM object reference

Client -> ComObject : Method call
ComObject --> Client : Method response

Client -> ComObject : Release object
ComObject -> Server : Decrement reference count
deactivate ComObject

Client -> Server : Shutdown request
Server -> Server : Unregister COM classes
Server -> Server : Stop message loop
deactivate Server

@enduml