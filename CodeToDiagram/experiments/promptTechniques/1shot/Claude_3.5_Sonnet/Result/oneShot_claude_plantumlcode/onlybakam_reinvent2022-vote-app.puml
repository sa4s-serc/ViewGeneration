@startuml onlybakam_reinvent2022-vote-app

actor User
participant "Next.js Frontend" as Frontend
participant "AWS AppSync" as AppSync
database "DynamoDB" as DynamoDB
queue "SNS" as SNS
participant "AWS Translate" as Translate

User -> Frontend : Cast vote (BR/CM)
activate Frontend

Frontend -> AppSync : Mutation: AddVote
activate AppSync

AppSync -> SNS : publishToSNS
activate SNS
SNS --> AppSync : Confirmation
deactivate SNS

AppSync -> DynamoDB : saveToDynamodb
activate DynamoDB
DynamoDB --> AppSync : Confirmation
deactivate DynamoDB

AppSync -> Translate : translateMessage
activate Translate
Translate --> AppSync : Translated message
deactivate Translate

AppSync --> Frontend : Vote confirmation
deactivate AppSync

Frontend -> AppSync : Subscription: OnPlusOne
activate AppSync
AppSync --> Frontend : Real-time vote update
deactivate AppSync

Frontend -> User : Display updated vote count
deactivate Frontend

@enduml