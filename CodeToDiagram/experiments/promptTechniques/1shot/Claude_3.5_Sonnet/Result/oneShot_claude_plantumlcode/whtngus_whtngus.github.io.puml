@startuml whtngus_whtngus.github.io

skinparam component {
  BackgroundColor<<app>> LightBlue
  BackgroundColor<<infra>> LightGreen
  BackgroundColor<<data>> Yellow
}

cloud "Cloud Platform" {
  [Load Balancer] <<infra>> as LB
  
  package "Application Tier" {
    [Web Server] <<app>> as WS
    [Application Server] <<app>> as AS
  }
  
  database "Database" <<data>> as DB
  
  [Monitoring] <<infra>> as MON
  [Logging] <<infra>> as LOG
  [CI/CD Pipeline] <<infra>> as CICD
}

actor "Users" as USERS
[Content Delivery Network] <<infra>> as CDN

USERS --> CDN
CDN --> LB
LB --> WS
WS --> AS
AS --> DB
AS ..> MON : sends metrics
AS ..> LOG : sends logs
CICD --> AS : deploys

@enduml