@startuml IBM_logdna-cos

actor "CIS Logpush" as CIS
participant "Source COS Bucket" as SourceCOS
participant "Serverless Function" as Function
participant "LogDNA" as LogDNA
participant "Archive COS Bucket" as ArchiveCOS

CIS -> SourceCOS : Push logs
SourceCOS -> Function : Trigger on new object

activate Function

Function -> SourceCOS : Download log file
SourceCOS --> Function : Return log file

Function -> Function : Unzip and parse logs

loop For each batch of 5000 logs
    Function -> LogDNA : Send logs
    alt success
        LogDNA --> Function : Confirm receipt
    else failure
        Function -> Function : Retry sending
    end
end

Function -> ArchiveCOS : Copy log file
ArchiveCOS --> Function : Confirm copy

Function -> SourceCOS : Delete original log file
SourceCOS --> Function : Confirm deletion

deactivate Function

@enduml