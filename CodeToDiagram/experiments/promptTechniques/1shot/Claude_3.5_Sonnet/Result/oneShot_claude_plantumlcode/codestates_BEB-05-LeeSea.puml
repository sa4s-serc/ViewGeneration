@startuml codestates_BEB-05-LeeSea

skinparam component {
  BackgroundColor<<Smart Contract>> LightYellow
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Integration>> LightGreen
}

package "Smart Contracts" {
  [LeeSeaNFT.sol] <<Smart Contract>>
  [LeeSeaMarket.sol] <<Smart Contract>>
  [#utility.yul] <<Smart Contract>>
}

package "Frontend (React)" {
  [App.js] <<Frontend>>
  [Components] <<Frontend>>
  [Redux Store] <<Frontend>>
  [Web3.js] <<Integration>>
}

package "Redux" {
  [accountSlice.js] <<Frontend>>
  [tokenSlice.js] <<Frontend>>
}

cloud "Ethereum Blockchain" {
  [Deployed Contracts]
}

[LeeSeaNFT.sol] --> [#utility.yul]
[LeeSeaMarket.sol] --> [#utility.yul]
[LeeSeaNFT.sol] --> [Deployed Contracts]
[LeeSeaMarket.sol] --> [Deployed Contracts]

[App.js] --> [Components]
[App.js] --> [Redux Store]
[Components] --> [Redux Store]
[Redux Store] --> [accountSlice.js]
[Redux Store] --> [tokenSlice.js]

[Web3.js] --> [Deployed Contracts]
[App.js] --> [Web3.js]

@enduml