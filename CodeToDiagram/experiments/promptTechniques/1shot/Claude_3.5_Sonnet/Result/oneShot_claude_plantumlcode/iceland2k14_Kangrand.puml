@startuml iceland2k14_Kangrand

skinparam component {
  BackgroundColor<<CPU>> LightBlue
  BackgroundColor<<GPU>> LightGreen
  BackgroundColor<<Network>> LightYellow
}

[Main] as main
[Kangaroo] as kangaroo
[Secp256K1] as secp
[HashTable] as hashtable
[Integer Arithmetic] as intarith
[Network Component] as network
[Backup Component] as backup
[Thread Management] as thread
[Timer] as timer

component "CPU Processing" <<CPU>> {
  [CPU Solver]
}

component "GPU Processing" <<GPU>> {
  [GPUEngine]
  [CUDA Kernels]
}

component "Distributed Computing" <<Network>> {
  [Server]
  [Client]
}

main --> kangaroo
kangaroo --> secp
kangaroo --> hashtable
kangaroo --> intarith
kangaroo --> network
kangaroo --> backup
kangaroo --> thread
kangaroo --> timer

secp --> intarith
hashtable --> intarith

kangaroo --> [CPU Processing]
kangaroo --> [GPU Processing]
[GPU Processing] --> [CUDA Kernels]

network --> [Distributed Computing]

@enduml