@startuml
skinparam component {
  BackgroundColor<<PowerShell>> #LightBlue
  BackgroundColor<<Database>> #LightYellow
  BackgroundColor<<PowerBI>> #LightGreen
}

[Azure DevOps] as AzDO

package "Data Extraction & Transformation" {
  [User & Access Management Scripts]<<PowerShell>>
  [Project & Process Management Scripts]<<PowerShell>>
  [Code Repositories Scripts]<<PowerShell>>
  [Build & Release Pipeline Scripts]<<PowerShell>>
  [Team Configuration Scripts]<<PowerShell>>
  [Packaging Scripts]<<PowerShell>>
  [Environments & Approvals Scripts]<<PowerShell>>
  [Task Groups Scripts]<<PowerShell>>
  [Service Hooks Scripts]<<PowerShell>>
  [Installed Extensions Scripts]<<PowerShell>>
}

database "Azure SQL Database" <<Database>> {
  [User Data]
  [Project Data]
  [Repository Data]
  [Pipeline Data]
  [Team Data]
  [Package Data]
  [Environment Data]
  [Task Group Data]
  [Service Hook Data]
  [Extension Data]
}

package "Power BI Reporting" <<PowerBI>> {
  [Data Model]
  [Queries]
  [Visualizations]
  [Custom Visuals]
}

AzDO --> [User & Access Management Scripts]
AzDO --> [Project & Process Management Scripts]
AzDO --> [Code Repositories Scripts]
AzDO --> [Build & Release Pipeline Scripts]
AzDO --> [Team Configuration Scripts]
AzDO --> [Packaging Scripts]
AzDO --> [Environments & Approvals Scripts]
AzDO --> [Task Groups Scripts]
AzDO --> [Service Hooks Scripts]
AzDO --> [Installed Extensions Scripts]

[User & Access Management Scripts] --> [User Data]
[Project & Process Management Scripts] --> [Project Data]
[Code Repositories Scripts] --> [Repository Data]
[Build & Release Pipeline Scripts] --> [Pipeline Data]
[Team Configuration Scripts] --> [Team Data]
[Packaging Scripts] --> [Package Data]
[Environments & Approvals Scripts] --> [Environment Data]
[Task Groups Scripts] --> [Task Group Data]
[Service Hooks Scripts] --> [Service Hook Data]
[Installed Extensions Scripts] --> [Extension Data]

[User Data] --> [Data Model]
[Project Data] --> [Data Model]
[Repository Data] --> [Data Model]
[Pipeline Data] --> [Data Model]
[Team Data] --> [Data Model]
[Package Data] --> [Data Model]
[Environment Data] --> [Data Model]
[Task Group Data] --> [Data Model]
[Service Hook Data] --> [Data Model]
[Extension Data] --> [Data Model]

[Data Model] --> [Queries]
[Queries] --> [Visualizations]
[Custom Visuals] --> [Visualizations]

@enduml