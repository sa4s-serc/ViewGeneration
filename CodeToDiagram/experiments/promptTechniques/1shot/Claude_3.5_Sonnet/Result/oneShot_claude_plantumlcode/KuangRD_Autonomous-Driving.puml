@startuml KuangRD_Autonomous-Driving

actor User
participant "Waypoint Loader" as WL
participant "Waypoint Updater" as WU
participant "Traffic Light Detector" as TLD
participant "DBW Controller" as DBW
participant "Vehicle/Simulator" as VS

User -> WL : Initialize
activate WL
WL -> WU : Load waypoints
activate WU

loop Continuous Operation
    WU -> TLD : Request traffic light state
    activate TLD
    TLD -> TLD : Classify traffic light
    TLD --> WU : Return light state
    deactivate TLD
    
    WU -> WU : Update waypoints
    
    WU -> DBW : Send updated waypoints
    activate DBW
    
    DBW -> DBW : Calculate control commands
    DBW -> VS : Apply throttle/brake/steering
    activate VS
    
    VS --> DBW : Vehicle state feedback
    deactivate VS
    
    DBW --> WU : Control applied
    deactivate DBW
end

@enduml