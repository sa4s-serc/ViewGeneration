@startuml ShiftLeftSecurity_traceleft

actor User
participant "CLI Tool" as CLI
participant "eBPF Program" as eBPF
participant "Kernel" as Kernel
database "Event Buffer" as Buffer
participant "Tracer" as Tracer
participant "Output Formatter" as Formatter

User -> CLI : Execute traceleft command
activate CLI

CLI -> eBPF : Load and attach eBPF program
activate eBPF

eBPF -> Kernel : Hook into system calls
activate Kernel

loop For each traced event
    Kernel -> Buffer : Write event data
    Buffer -> Tracer : Read event data
    activate Tracer
    Tracer -> Formatter : Format event data
    activate Formatter
    Formatter --> CLI : Return formatted output
    deactivate Formatter
    CLI --> User : Display traced event
    deactivate Tracer
end

User -> CLI : Stop tracing
CLI -> eBPF : Detach eBPF program
deactivate eBPF
CLI -> Kernel : Remove hooks
deactivate Kernel
CLI --> User : Tracing complete

deactivate CLI

@enduml