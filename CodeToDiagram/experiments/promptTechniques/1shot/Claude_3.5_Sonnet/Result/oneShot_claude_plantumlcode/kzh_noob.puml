@startuml kzh_noob

!define KUBERNETES #CCFFCC
!define DOCKER #ADD8E6
!define RABBITMQ #FF9999
!define MONGODB #FFCC99
!define REDIS #FFCCCC
!define JAEGER #E6E6FA

skinparam component {
  BackgroundColor<<KUBERNETES>> KUBERNETES
  BackgroundColor<<DOCKER>> DOCKER
  BackgroundColor<<RABBITMQ>> RABBITMQ
  BackgroundColor<<MONGODB>> MONGODB
  BackgroundColor<<REDIS>> REDIS
  BackgroundColor<<JAEGER>> JAEGER
}

cloud "Kubernetes Cluster" <<KUBERNETES>> {
  component "Ingress Controller" as ingress
  
  package "Microservices" {
    [Auth Service] as auth
    [Frontend Service] as frontend
    [Problems Service] as problems
    [Submissions Service] as submissions
    [Executor Service] as executor
  }
  
  database "MongoDB" <<MONGODB>> as mongodb
  queue "RabbitMQ" <<RABBITMQ>> as rabbitmq
  database "Redis" <<REDIS>> as redis
  component "Jaeger" <<JAEGER>> as jaeger
  
  component "Docker Engine" <<DOCKER>> as docker
}

ingress --> auth
ingress --> frontend
ingress --> problems
ingress --> submissions

auth --> mongodb
auth --> redis

frontend --> mongodb
frontend --> redis

problems --> mongodb

submissions --> mongodb
submissions --> rabbitmq
submissions --> redis

executor --> rabbitmq
executor --> docker

auth ..> jaeger
frontend ..> jaeger
problems ..> jaeger
submissions ..> jaeger
executor ..> jaeger

@enduml