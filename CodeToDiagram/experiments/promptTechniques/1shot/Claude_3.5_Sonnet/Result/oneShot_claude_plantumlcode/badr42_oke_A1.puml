@startuml badr42_oke_A1

skinparam component {
  BackgroundColor<<OCI>> #FFEBCD
  BackgroundColor<<K8s>> #E6E6FA
  BackgroundColor<<Network>> #E0FFFF
}

package "Oracle Cloud Infrastructure (OCI)" <<OCI>> {
  [OKE Cluster] <<OCI>>
  [Virtual Cloud Network (VCN)] <<Network>>
  [Internet Gateway] <<Network>>
  [NAT Gateway] <<Network>>
  [Service Gateway] <<Network>>
  [Node Pool (Ampere A1)] <<OCI>>
}

package "Kubernetes Resources" <<K8s>> {
  [Nginx Deployment] <<K8s>>
  [LoadBalancer Service] <<K8s>>
}

package "Networking" <<Network>> {
  [Public Subnet] <<Network>>
  [Private Subnet] <<Network>>
  [Security Lists] <<Network>>
  [Route Tables] <<Network>>
}

[Terraform Configuration] --> [OKE Cluster] : provisions
[Terraform Configuration] --> [Virtual Cloud Network (VCN)] : creates
[Terraform Configuration] --> [Node Pool (Ampere A1)] : manages
[Terraform Configuration] --> [Networking] : configures

[OKE Cluster] --> [Node Pool (Ampere A1)] : uses
[Virtual Cloud Network (VCN)] --> [Internet Gateway]
[Virtual Cloud Network (VCN)] --> [NAT Gateway]
[Virtual Cloud Network (VCN)] --> [Service Gateway]
[Virtual Cloud Network (VCN)] --> [Public Subnet]
[Virtual Cloud Network (VCN)] --> [Private Subnet]

[Node Pool (Ampere A1)] --> [Private Subnet] : resides in
[OKE Cluster] --> [Public Subnet] : API endpoint

[Nginx Deployment] --> [Node Pool (Ampere A1)] : runs on
[LoadBalancer Service] --> [Nginx Deployment] : exposes
[LoadBalancer Service] --> [Public Subnet] : uses

[Security Lists] --> [Public Subnet] : secures
[Security Lists] --> [Private Subnet] : secures
[Route Tables] --> [Public Subnet] : routes
[Route Tables] --> [Private Subnet] : routes

@enduml