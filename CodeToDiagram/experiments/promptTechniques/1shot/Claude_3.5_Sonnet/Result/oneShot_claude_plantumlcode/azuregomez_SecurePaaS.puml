@startuml azuregomez_SecurePaaS

!define AzurePuml https://raw.githubusercontent.com/plantuml-stdlib/Azure-PlantUML/master/dist

!includeurl AzurePuml/AzureCommon.puml
!includeurl AzurePuml/Networking/AzureFirewall.puml
!includeurl AzurePuml/Networking/AzureVirtualNetwork.puml
!includeurl AzurePuml/Security/AzureWebApplicationFirewall.puml
!includeurl AzurePuml/Web/AzureAppService.puml
!includeurl AzurePuml/Databases/AzureSqlDatabase.puml

skinparam linetype ortho

rectangle "Azure Cloud" {
    AzureVirtualNetwork(vnet, "Virtual Network", "Hub-and-Spoke Topology")
    
    rectangle "App Subnet" {
        AzureAppService(appService, "App Service", "Web Application")
    }
    
    rectangle "Database Subnet" {
        AzureSqlDatabase(sqlDatabase, "Azure SQL Database", "Private Endpoint")
    }
    
    AzureFirewall(azureFirewall, "Azure Firewall", "Outbound Traffic Inspection")
    AzureWebApplicationFirewall(waf, "Web Application Firewall", "Inbound Protection")
}

actor "User" as user

user --> waf
waf --> appService
appService --> azureFirewall : Outbound Traffic
azureFirewall --> sqlDatabase : Inspected Traffic

note right of sqlDatabase
  No public endpoints
  Accessible only through
  private networking
end note

note bottom of azureFirewall
  User Defined Routes (UDRs)
  direct traffic through Firewall
end note

@enduml