@startuml redbadger_crux

skinparam componentStyle uml2

actor User
participant "UI Shell" as Shell
participant "Core" as Core
participant "App" as App
participant "Capability" as Capability
participant "Command" as Command
participant "Effect" as Effect

User -> Shell : Interact
activate Shell

Shell -> Core : Send Event
activate Core

Core -> App : update(Event)
activate App

App -> Capability : Request Side Effect
activate Capability

Capability --> Command : Create
activate Command

Command --> Effect : Generate
activate Effect

Effect --> Core : Return Effect
deactivate Effect

Core --> Shell : Request Effect Execution
deactivate Core

Shell -> Shell : Execute Effect

Shell --> Core : Return Effect Result
activate Core

Core -> App : Handle Effect Result
deactivate App

App --> Core : Return Updated Model
activate App

Core -> App : view()
App --> Core : Return ViewModel
deactivate App

Core --> Shell : Provide ViewModel
deactivate Core

Shell -> Shell : Render UI

Shell --> User : Display Updated UI
deactivate Shell

@enduml