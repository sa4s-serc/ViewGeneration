@startuml rackerlabs_scantron

skinparam component {
  BackgroundColor<<Console>> LightBlue
  BackgroundColor<<Engine>> LightGreen
  BackgroundColor<<Storage>> LightYellow
  BackgroundColor<<External>> LightGray
}

cloud "Scantron System" {
  component "Console (Django)" <<Console>> {
    [Web Frontend]
    [Django REST API]
    [Scan Scheduler]
    [Result Processor]
    [Django Models]
    [RQ Worker]
  }

  component "Engine" <<Engine>> {
    [Engine Script]
    [Nmap/Masscan]
  }

  database "Database" <<Storage>> {
    [PostgreSQL]
  }

  storage "Shared Storage" <<Storage>> {
    [NFS Volume]
  }

  queue "Redis" <<Storage>> {
    [Job Queue]
  }

  component "External Systems" <<External>> {
    [Big Data Analytics]
    [Email Server]
  }

  [Web Frontend] --> [Django REST API]
  [Django REST API] --> [Django Models]
  [Scan Scheduler] --> [Django Models]
  [Result Processor] --> [Django Models]
  [Django Models] --> [PostgreSQL]
  
  [Django REST API] <--> [Engine Script] : REST API
  [Engine Script] --> [Nmap/Masscan]
  [Engine Script] --> [NFS Volume] : Store Results
  
  [Result Processor] --> [NFS Volume] : Process Results
  [Result Processor] --> [Big Data Analytics] : CSV Export
  
  [Scan Scheduler] --> [Job Queue] : Schedule Tasks
  [RQ Worker] --> [Job Queue] : Process Tasks
  
  [Django REST API] --> [Email Server] : Send Alerts
}

note right of [Engine]
  Multiple engines can be deployed
  for distributed scanning
end note

note bottom of [Shared Storage]
  NFS used for sharing targets
  and storing scan results
end note

note bottom of [Console (Django)]
  Ansible used for automated
  deployment of console and engines
end note

@enduml