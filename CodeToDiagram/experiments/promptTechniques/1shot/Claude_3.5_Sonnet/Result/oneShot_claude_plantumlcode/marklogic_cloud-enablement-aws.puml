@startuml marklogic_cloud-enablement-aws

actor "AWS User" as User
participant "CloudFormation" as CF
participant "Lambda Functions" as Lambda
participant "Auto Scaling Group" as ASG
participant "EC2 Instances" as EC2
participant "DynamoDB" as DDB
participant "Elastic Network Interface" as ENI
participant "Application Load Balancer" as ALB

User -> CF: Deploy MarkLogic Cluster
activate CF

CF -> CF: Process mlcluster.template
CF -> ASG: Create Auto Scaling Group
CF -> DDB: Create MarkLogicDDBTable
CF -> ALB: Create Load Balancer

CF -> Lambda: Deploy managedeni.py
CF -> Lambda: Deploy nodemanager.py

ASG -> Lambda: EC2_INSTANCE_LAUNCHING event
activate Lambda
Lambda -> DDB: Check available ENIs
Lambda -> ENI: Create/Attach ENI
Lambda -> EC2: Launch MarkLogic Instance
deactivate Lambda

EC2 -> DDB: Update cluster state
EC2 -> ALB: Register with Target Group

ALB --> User: MarkLogic Cluster Accessible

@enduml