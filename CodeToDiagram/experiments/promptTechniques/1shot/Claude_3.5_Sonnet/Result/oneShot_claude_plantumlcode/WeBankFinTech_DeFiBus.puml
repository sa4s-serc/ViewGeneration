@startuml WeBankFinTech_DeFiBus

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<extension>> LightGreen
}

package "DeFiBus Broker" {
  [DeFiBrokerController] <<core>> as controller
  
  package "Message Processing" {
    [DeFiSendMessageProcessor] <<extension>>
    [DeFiReplyMessageProcessor] <<extension>>
    [DeFiPullMessageProcessor] <<extension>>
  }
  
  package "Queue Management" {
    [ConsumeQueueManager] <<extension>>
    [AdjustQueueNumStrategy] <<extension>>
    [QueueListeningMonitor] <<extension>>
  }
  
  package "Client Management" {
    [DeFiConsumerManager] <<extension>>
    [DeFiProducerManager] <<extension>>
    [ClientRebalanceResultManager] <<extension>>
  }
  
  package "Additional Features" {
    [MessageRedirectManager] <<extension>>
    [ConsumeQueueAccessLockManager] <<extension>>
    [DeFiTopicConfigManager] <<extension>>
  }
  
  [DeFiPluginMessageStore] <<extension>>
  [DeFiBusBroker2Client] <<extension>>
  [DeFiAdminBrokerProcessor] <<extension>>
}

cloud "Apache RocketMQ" {
  [RocketMQ Core] <<core>>
}

database "Message Store" {
  [RocketMQ MessageStore] <<core>>
}

[DeFiBrokerController] --> [RocketMQ Core] : extends
[DeFiPluginMessageStore] --> [RocketMQ MessageStore] : extends

[DeFiBrokerController] --> [Message Processing]
[DeFiBrokerController] --> [Queue Management]
[DeFiBrokerController] --> [Client Management]
[DeFiBrokerController] --> [Additional Features]
[DeFiBrokerController] --> [DeFiPluginMessageStore]
[DeFiBrokerController] --> [DeFiBusBroker2Client]
[DeFiBrokerController] --> [DeFiAdminBrokerProcessor]

cloud "Clients" {
  [Producers]
  [Consumers]
}

[Producers] <--> [DeFiBrokerController] : TCP
[Consumers] <--> [DeFiBrokerController] : TCP

@enduml