@startuml ingeniala_heybluekata

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<AWS>> Yellow
}

package "HeyBlue Application" {
  [Web Client] <<Frontend>>
  [Mobile Client] <<Frontend>>
  
  package "Backend" {
    [Omnichannel BFF] <<Backend>>
    [HeyBlue BFF Mobile] <<Backend>>
    [BFF Web Container] <<Backend>>
    
    [User Management] <<Backend>>
    [Interaction & Gamification] <<Backend>>
    [Commerce] <<Backend>>
    [Content Management] <<Backend>>
    [Data Archiving & Analytics] <<Backend>>
    [Notification & Messaging] <<Backend>>
    [Security and Privacy] <<Backend>>
  }
  
  package "AWS Services" {
    [Cognito] <<AWS>>
    [DynamoDB] <<AWS>>
    [S3] <<AWS>>
    [CloudFront] <<AWS>>
    [API Gateway] <<AWS>>
    [Lambda] <<AWS>>
    [EventBridge] <<AWS>>
    [Kinesis] <<AWS>>
    [Athena] <<AWS>>
    [Glacier] <<AWS>>
  }
}

[Web Client] --> [BFF Web Container]
[Mobile Client] --> [HeyBlue BFF Mobile]
[BFF Web Container] --> [Omnichannel BFF]
[HeyBlue BFF Mobile] --> [Omnichannel BFF]

[Omnichannel BFF] --> [User Management]
[Omnichannel BFF] --> [Interaction & Gamification]
[Omnichannel BFF] --> [Commerce]
[Omnichannel BFF] --> [Content Management]
[Omnichannel BFF] --> [Data Archiving & Analytics]
[Omnichannel BFF] --> [Notification & Messaging]
[Omnichannel BFF] --> [Security and Privacy]

[User Management] --> [Cognito]
[User Management] --> [DynamoDB]
[Interaction & Gamification] --> [DynamoDB]
[Commerce] --> [DynamoDB]
[Content Management] --> [S3]
[Content Management] --> [CloudFront]
[Data Archiving & Analytics] --> [S3]
[Data Archiving & Analytics] --> [Glacier]
[Data Archiving & Analytics] --> [Athena]
[Notification & Messaging] --> [EventBridge]
[Notification & Messaging] --> [Kinesis]

[API Gateway] --> [Omnichannel BFF]
[Lambda] --> [API Gateway]

@enduml