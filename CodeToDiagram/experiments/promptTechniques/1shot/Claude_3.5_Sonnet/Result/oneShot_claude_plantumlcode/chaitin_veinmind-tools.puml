@startuml chaitin_veinmind-tools

skinparam component {
  BackgroundColor<<plugin>> LightGreen
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<external>> LightGray
}

[veinmind-runner] <<core>> as runner
[libveinmind] <<external>>
[Docker] <<external>>

package "Plugins" {
  [malicious-file-scanner] <<plugin>>
  [weakpass-scanner] <<plugin>>
  [unsafe-mount-scanner] <<plugin>>
  [cve-scanner] <<plugin>>
  [intrusion-detection] <<plugin>>
  [sensitive-info-scanner] <<plugin>>
}

cloud "Container Images/Runtimes" {
  [Image 1]
  [Image 2]
  [Container 1]
  [Container 2]
}

runner --> [malicious-file-scanner]
runner --> [weakpass-scanner]
runner --> [unsafe-mount-scanner]
runner --> [cve-scanner]
runner --> [intrusion-detection]
runner --> [sensitive-info-scanner]

runner --> libveinmind
libveinmind --> [Image 1]
libveinmind --> [Image 2]
libveinmind --> [Container 1]
libveinmind --> [Container 2]

[malicious-file-scanner] --> libveinmind
[weakpass-scanner] --> libveinmind
[unsafe-mount-scanner] --> libveinmind
[cve-scanner] --> libveinmind
[intrusion-detection] --> libveinmind
[sensitive-info-scanner] --> libveinmind

runner --> Docker : Manages plugin containers

note right of runner
  Orchestrates plugins
  Manages services via TOML config
end note

note bottom of Plugins
  Each plugin has:
  - Dockerfile
  - CLI (cmd/cli.go)
  - Core logic (pkg/scanner/*)
end note

@enduml