@startuml darrenyao87_tnn-models

skinparam component {
  BackgroundColor<<model>> LightBlue
  BackgroundColor<<framework>> LightGreen
  BackgroundColor<<data>> LightYellow
  BackgroundColor<<processing>> LightPink
}

package "TNN Framework" <<framework>> {
  [Model Management]
  [Model Serialization]
  [Model Optimization]
  [Graph Representation]
}

package "HiAI DDK" <<framework>> {
  [AIPP Configuration]
  [Tensor Handling]
  [Hardware Acceleration]
}

package "Models" <<model>> {
  [Object Detection]
  [Face Detection]
  [Image Classification]
  [OCR]
  [BERT]
  [Image Segmentation]
  [Pose Estimation]
  [Image Translation]
}

package "Data Files" <<data>> {
  [Vocabulary Files]
  [Anchor Definitions]
  [Mean Face Points]
}

package "Processing" <<processing>> {
  [Pre-processing]
  [Post-processing]
}

[Model Management] --> [Model Serialization]
[Model Management] --> [Model Optimization]
[Model Management] --> [Graph Representation]

[AIPP Configuration] --> [Pre-processing]
[Tensor Handling] --> [Hardware Acceleration]

[Models] ..> [TNN Framework] : uses
[Models] ..> [HiAI DDK] : uses
[Models] ..> [Data Files] : uses
[Models] ..> [Processing] : uses

@enduml