@startuml madderle_Capstone-Realtime-Streaming-Analytics

actor "DevOps Engineer" as DevOps
participant "Docker Compose" as DockerCompose
participant "Docker" as Docker
database "MongoDB" as MongoDB
database "Redis" as Redis
cloud "AWS" {
  queue "Kinesis" as Kinesis
  database "S3" as S3
}
participant "Twitter Service" as TwitterService
participant "IEX Service" as IEXService
participant "Manager Service" as ManagerService
participant "Data Service" as DataService
participant "Model Development" as ModelDev
participant "Model Deployment" as ModelDeploy

DevOps -> DockerCompose: Run docker-compose up
activate DockerCompose

DockerCompose -> Docker: Start containers
activate Docker

Docker -> MongoDB: Initialize
Docker -> Redis: Initialize
Docker -> TwitterService: Start
Docker -> IEXService: Start
Docker -> ManagerService: Start
Docker -> DataService: Start
Docker -> ModelDev: Start
Docker -> ModelDeploy: Start

TwitterService -> Kinesis: Stream tweets
IEXService -> Kinesis: Stream stock data

ManagerService -> Redis: Check market hours
ManagerService -> TwitterService: Control data ingestion
ManagerService -> IEXService: Control data ingestion

Kinesis -> DataService: Process streamed data
DataService -> MongoDB: Store processed data

ModelDev -> MongoDB: Fetch training data
ModelDev -> ModelDev: Train model
ModelDev -> S3: Store trained model

ModelDeploy -> S3: Fetch latest model
ModelDeploy -> MongoDB: Fetch prediction data
ModelDeploy -> ModelDeploy: Make predictions
ModelDeploy -> MongoDB: Store predictions

DevOps -> DockerCompose: Monitor logs and metrics

@enduml