@startuml zeromicro_zero-doc

skinparam component {
  BackgroundColor<<core>> #FFCCCB
  BackgroundColor<<utility>> #CCFFCC
  BackgroundColor<<infrastructure>> #CCCCFF
}

package "Go-Zero Framework" {
  [goctl] <<core>> as goctl
  [zRPC] <<core>> as zRPC
  [API Gateway] <<core>> as apiGateway
  [Caching] <<core>> as caching
  [Service Discovery] <<core>> as serviceDiscovery
  [Load Shedding] <<utility>> as loadShedding
  [Rate Limiting] <<utility>> as rateLimiting
  [go-queue] <<utility>> as goQueue
  [Concurrency Utilities] <<utility>> as concurrencyUtils
  [Metrics & Monitoring] <<infrastructure>> as metricsMonitoring
  [Distributed Tracing] <<infrastructure>> as distributedTracing
  [Middleware] <<utility>> as middleware

  component "Service Layer" {
    [Handler]
    [Logic]
    [Model]
  }

  database "Database" as db
  
  goctl --> [Handler]
  goctl --> [Logic]
  goctl --> [Model]
  
  apiGateway --> zRPC
  apiGateway --> [Handler]
  
  [Handler] --> [Logic]
  [Logic] --> [Model]
  [Model] --> db
  
  caching --> [Model]
  serviceDiscovery --> zRPC
  loadShedding --> zRPC
  rateLimiting --> apiGateway
  goQueue --> [Logic]
  concurrencyUtils --> [Logic]
  
  metricsMonitoring --> apiGateway
  metricsMonitoring --> zRPC
  distributedTracing --> apiGateway
  distributedTracing --> zRPC
  
  middleware --> apiGateway
  middleware --> zRPC
}

@enduml