@startuml beston123_Tarzan

actor Client
participant "Tarzan Client" as TarzanClient
participant "Tarzan Server" as TarzanServer
participant "RocketMQ" as RocketMQ
participant "Zookeeper" as Zookeeper
database "Database" as DB
participant "Redis" as Redis

Client -> TarzanClient : Send message
activate TarzanClient

TarzanClient -> Zookeeper : Discover server
Zookeeper --> TarzanClient : Server address

TarzanClient -> TarzanServer : Send message request
activate TarzanServer

TarzanServer -> DB : Store message
DB --> TarzanServer : Confirmation

TarzanServer -> RocketMQ : Send message
RocketMQ --> TarzanServer : Message sent

TarzanServer --> TarzanClient : Transaction initiated
deactivate TarzanServer

TarzanClient --> Client : Message sent
deactivate TarzanClient

loop Scheduled Task
    TarzanServer -> Redis : Acquire lock
    activate Redis
    Redis --> TarzanServer : Lock acquired
    deactivate Redis

    TarzanServer -> DB : Check message status
    DB --> TarzanServer : Status

    alt Message not confirmed
        TarzanServer -> RocketMQ : Resend message
        RocketMQ --> TarzanServer : Message resent
    end

    TarzanServer -> Redis : Release lock
    activate Redis
    Redis --> TarzanServer : Lock released
    deactivate Redis
end

@enduml