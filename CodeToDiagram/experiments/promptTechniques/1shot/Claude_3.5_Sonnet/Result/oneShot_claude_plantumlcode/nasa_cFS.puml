@startuml nasa_cFS

skinparam component {
  BackgroundColor<<core>> #FFCCCB
  BackgroundColor<<abstraction>> #CCFFCC
  BackgroundColor<<app>> #CCCCFF
  BackgroundColor<<tool>> #FFFFCC
}

package "NASA Core Flight System (cFS)" {
  [cFE (Core Flight Executive)]<<core>> as cFE
  [OSAL (OS Abstraction Layer)]<<abstraction>> as OSAL
  [PSP (Platform Support Package)]<<abstraction>> as PSP
  
  package "Applications" {
    [Lab Applications]<<app>> as LabApps
    [User Applications]<<app>> as UserApps
  }
  
  package "Tools" {
    [Host-side Tools]<<tool>> as HostTools
  }
  
  [Event Services] as ES
  [Command and Telemetry] as CmdTlm
}

cFE --> OSAL : uses
cFE --> PSP : uses
LabApps --> cFE : built on
UserApps --> cFE : built on
ES --> cFE : part of
CmdTlm --> cFE : part of
HostTools --> cFE : supports

note right of OSAL : Abstracts OS-specific details
note right of PSP : Provides platform-specific support
note bottom of LabApps : Example applications
note bottom of UserApps : Custom mission applications
note right of HostTools : Build and development tools

@enduml