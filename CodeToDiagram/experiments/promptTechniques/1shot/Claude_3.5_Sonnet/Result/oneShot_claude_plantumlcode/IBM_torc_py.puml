@startuml IBM_torc_py

participant "Main Application" as Main
participant "Task Queue" as Queue
participant "Server Thread" as Server
participant "Worker Threads" as Workers
participant "MPI" as MPI

Main -> Main: start()
activate Main

Main -> Main: init()
Main -> Server: Create and start
activate Server

Main -> Workers: Create thread pool
activate Workers

Main -> Main: launch() primary task

loop Task Submission
    Main -> Queue: submit() task
    Queue -> Server: Enqueue task
end

Server -> MPI: Distribute tasks to other processes
MPI -> Server: Receive tasks from other processes

loop Task Execution
    Server -> Queue: Dequeue task
    Queue -> Workers: Execute task
    Workers -> Queue: Return result
    Queue -> Server: Enqueue result
end

Server -> MPI: Send results to other processes
MPI -> Server: Receive results from other processes

alt Load Imbalance Detected
    Server -> MPI: Request tasks (work stealing)
    MPI -> Server: Receive stolen tasks
end

Main -> Main: wait() or as_completed()
Queue --> Main: Return results

Main -> Main: shutdown()
Main -> Server: Stop
deactivate Server
Main -> Workers: Stop thread pool
deactivate Workers
deactivate Main

@enduml