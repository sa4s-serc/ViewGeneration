@startuml NatalieLouise91_T3A2-Skemi-FrontEnd

skinparam component {
  BackgroundColor<<UI>> LightSkyBlue
  BackgroundColor<<Core>> LightGreen
  BackgroundColor<<State>> LightYellow
  BackgroundColor<<Service>> LightPink
  BackgroundColor<<Config>> LightGray
}

[App.js] <<Core>> as App
[index.js] <<Core>> as Index
[StateContext] <<State>> as StateContext
[StateReducer] <<State>> as StateReducer

package "Components" {
  [Nav] <<UI>>
  [Login] <<UI>>
  [NewUser] <<UI>>
  
  package "Occasion" {
    [CreateOccasion] <<UI>>
    [ViewOccasion] <<UI>>
    [OccasionList] <<UI>>
  }
  
  package "Roster" {
    [CreateRoster] <<UI>>
    [ViewRoster] <<UI>>
    [EditRoster] <<UI>>
  }
}

package "Services" {
  [occasionServices] <<Service>>
  [rosterServices] <<Service>>
  [authServices] <<Service>>
  [userServices] <<Service>>
}

[api] <<Config>>

Index --> App
App --> StateContext
App --> StateReducer
App --> Nav
App --> Components

Nav --> Login
Nav --> NewUser

Components --> Occasion
Components --> Roster

Occasion --> occasionServices
Roster --> rosterServices
Login --> authServices
NewUser --> userServices

occasionServices --> api
rosterServices --> api
authServices --> api
userServices --> api

StateContext <--> Components
StateReducer <--> Components

@enduml