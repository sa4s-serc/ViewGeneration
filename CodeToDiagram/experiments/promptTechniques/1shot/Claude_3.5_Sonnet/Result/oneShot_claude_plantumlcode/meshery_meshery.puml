@startuml meshery_meshery

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<adapter>> LightGreen
  BackgroundColor<<ui>> LightYellow
  BackgroundColor<<cli>> LightPink
  BackgroundColor<<operator>> LightGray
}

[Meshery Server] <<core>> as Server
[Meshery UI] <<ui>> as UI
[mesheryctl] <<cli>> as CLI
[Meshery Operator] <<operator>> as Operator
[MeshSync] as MeshSync
[Event Broker] as Broker
database "Database" as DB

cloud "Kubernetes Cluster" {
  [Service Mesh Adapter 1] <<adapter>>
  [Service Mesh Adapter 2] <<adapter>>
  [Service Mesh Adapter N] <<adapter>>
}

cloud "Cloud Providers" {
  [Cloud Provider 1]
  [Cloud Provider 2]
  [Cloud Provider N]
}

Server -- DB
Server -- UI : GraphQL API
CLI -- Server : REST API
Operator -- Server
Operator -- MeshSync
Operator -- Broker

Server -- [Service Mesh Adapter 1] : gRPC
Server -- [Service Mesh Adapter 2] : gRPC
Server -- [Service Mesh Adapter N] : gRPC

Server -- [Cloud Provider 1]
Server -- [Cloud Provider 2]
Server -- [Cloud Provider N]

note right of Server
  Handles configuration, logging,
  database init, API setup,
  and adapter management
end note

note right of Operator
  Automates deployment, scaling,
  and management of Meshery
  components in Kubernetes
end note

note bottom of [Service Mesh Adapter 1]
  Adapters for different service meshes
  (Istio, Linkerd, Consul, etc.)
end note

@enduml