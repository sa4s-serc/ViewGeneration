@startuml apache_apisix-dashboard

skinparam component {
  BackgroundColor<<UI>> LightBlue
  BackgroundColor<<API>> LightGreen
  BackgroundColor<<State>> LightYellow
  BackgroundColor<<Routing>> LightPink
  BackgroundColor<<Data>> LightGray
}

[React Components] as RC <<UI>>
[Mantine UI] as MUI <<UI>>
[Ant Design Pro] as ADP <<UI>>

[API Layer] as API <<API>>
[React Query] as RQ <<API>>

[MobX Store] as MS <<State>>

[TanStack Router] as TR <<Routing>>

[Zod Schemas] as ZS <<Data>>
[TypeScript Types] as TS <<Data>>

cloud "Apache APISIX" as APISIX

RC --> MUI : uses
RC --> ADP : uses
RC --> API : calls
RC --> MS : observes
RC --> TR : uses for navigation
RC --> ZS : validates with
RC --> TS : typed with

API --> RQ : uses for caching
API --> APISIX : interacts with

MS --> RC : updates

TR --> RC : renders

ZS --> TS : defines

@enduml