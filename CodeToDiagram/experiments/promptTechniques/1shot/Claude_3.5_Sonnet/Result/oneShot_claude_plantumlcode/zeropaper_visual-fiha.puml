@startuml zeropaper_visual-fiha

skinparam component {
  BackgroundColor<<core>> #FFCCCB
  BackgroundColor<<ui>> #CCFFCC
  BackgroundColor<<rendering>> #CCCCFF
  BackgroundColor<<utils>> #FFFFCC
}

[VFExtension] <<core>> as "VFExtension"
[WebServer] <<core>> as "WebServer"
[Redux Store] <<core>> as "Redux Store"
[DisplayWorker] <<rendering>> as "DisplayWorker"
[Layers] <<rendering>> as "Layers"
[ScriptRunner] <<utils>> as "ScriptRunner"
[Scriptable] <<utils>> as "Scriptable"
[Com] <<utils>> as "Com"
[Commands] <<core>> as "Commands"
[Webviews] <<ui>> as "Webviews"
[Capture] <<ui>> as "Capture"

VFExtension --> WebServer
VFExtension --> "Redux Store"
VFExtension --> Commands
VFExtension --> Webviews

WebServer --> DisplayWorker
WebServer --> Capture

DisplayWorker --> Layers
DisplayWorker --> ScriptRunner
DisplayWorker --> Scriptable

Layers --> ScriptRunner
Layers --> Scriptable

Webviews --> "Redux Store"
Webviews --> Com

Com <--> VFExtension
Com <--> WebServer
Com <--> DisplayWorker

@enduml