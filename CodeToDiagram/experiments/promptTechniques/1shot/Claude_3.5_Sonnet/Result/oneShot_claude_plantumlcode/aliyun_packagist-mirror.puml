@startuml aliyun_packagist-mirror

skinparam component {
  BackgroundColor<<Core>> LightBlue
  BackgroundColor<<Storage>> LightYellow
  BackgroundColor<<External>> LightGreen
  BackgroundColor<<Config>> LightGray
}

[Main Application] as Main <<Core>>
[Packagist API Client] as PackagistClient <<Core>>
[GitHub API Client] as GitHubClient <<Core>>
[OSS Client] as OSSClient <<Core>>
[Redis Client] as RedisClient <<Core>>
[CDN Client] as CDNClient <<Core>>
[Config Loader] as Config <<Config>>

[Sync Providers] as SyncProviders <<Core>>
[Sync Packages V1] as SyncPackagesV1 <<Core>>
[Sync Packages V2] as SyncPackagesV2 <<Core>>
[Sync Distributions] as SyncDists <<Core>>
[Sync Composer Phar] as SyncComposerPhar <<Core>>
[Status Monitor] as StatusMonitor <<Core>>

database "Alibaba Cloud OSS" as OSS <<Storage>>
database "Redis Cache" as Redis <<Storage>>

cloud "Packagist.org" as Packagist <<External>>
cloud "GitHub" as GitHub <<External>>
cloud "Alibaba Cloud CDN" as CDN <<External>>

Main --> Config : Loads
Main --> PackagistClient : Uses
Main --> GitHubClient : Uses
Main --> OSSClient : Uses
Main --> RedisClient : Uses
Main --> CDNClient : Uses

Main --> SyncProviders : Initiates
Main --> SyncPackagesV1 : Initiates
Main --> SyncPackagesV2 : Initiates
Main --> SyncDists : Initiates
Main --> SyncComposerPhar : Initiates
Main --> StatusMonitor : Initiates

SyncProviders --> PackagistClient : Fetches data
SyncPackagesV1 --> PackagistClient : Fetches data
SyncPackagesV2 --> PackagistClient : Fetches data
SyncDists --> GitHubClient : Downloads distributions
SyncComposerPhar --> GitHubClient : Downloads phar

SyncProviders --> OSSClient : Stores data
SyncPackagesV1 --> OSSClient : Stores data
SyncPackagesV2 --> OSSClient : Stores data
SyncDists --> OSSClient : Stores data
SyncComposerPhar --> OSSClient : Stores phar

SyncProviders --> RedisClient : Caches data
SyncPackagesV1 --> RedisClient : Caches data
SyncPackagesV2 --> RedisClient : Caches data
SyncDists --> RedisClient : Caches data
StatusMonitor --> RedisClient : Reads status

CDNClient --> CDN : Warms up

PackagistClient --> Packagist : Syncs with
GitHubClient --> GitHub : Downloads from
OSSClient --> OSS : Stores in
RedisClient --> Redis : Caches in

@enduml