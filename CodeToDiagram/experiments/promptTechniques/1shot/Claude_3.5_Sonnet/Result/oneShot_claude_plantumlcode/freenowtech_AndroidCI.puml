@startuml freenowtech_AndroidCI

actor Developer
participant "Git Repository" as Git
participant "Jenkins Server" as Jenkins
participant "Docker Host" as DockerHost
participant "Android SDK Container" as SDKContainer
participant "Build Artifact Storage" as Storage

Developer -> Git : Push code changes
Git -> Jenkins : Trigger build
activate Jenkins

Jenkins -> DockerHost : Request container
activate DockerHost

DockerHost -> SDKContainer : Create container
activate SDKContainer

Jenkins -> SDKContainer : Execute build job
SDKContainer -> SDKContainer : Compile code
SDKContainer -> SDKContainer : Run tests
SDKContainer -> SDKContainer : Generate APK

SDKContainer --> Jenkins : Return build results
deactivate SDKContainer

DockerHost -> DockerHost : Destroy container
deactivate DockerHost

Jenkins -> Storage : Store build artifacts
Jenkins -> Developer : Notify build status

deactivate Jenkins

@enduml