@startuml marekq_rss-lambda

actor "CloudWatch Event" as CWE
participant "Step Function" as SF
participant "rsscrawl Lambda" as RCL
participant "S3" as S3
participant "rssgetfeed Lambda" as RGL
database "DynamoDB" as DDB
participant "SES" as SES
participant "AWS Comprehend" as Comprehend
participant "Algolia" as Algolia
participant "AppSync" as AppSync

CWE -> SF : Trigger (scheduled)
activate SF

SF -> RCL : Invoke
activate RCL

RCL -> S3 : Check for existing data
S3 --> RCL : Return data status

RCL -> RCL : Read feeds.txt
RCL --> SF : Return feed list
deactivate RCL

SF -> SF : Map state (for each feed)

loop For each feed
    SF -> RGL : Invoke with feed URL
    activate RGL
    
    RGL -> RGL : Fetch and parse RSS feed
    RGL -> RGL : Extract content with readability-lxml
    
    RGL -> Comprehend : Perform entity recognition
    Comprehend --> RGL : Return entities/tags
    
    RGL -> DDB : Store blog post data
    
    alt SendEmails is true
        RGL -> SES : Send notification email
    end
    
    alt EnableAlgolia is true
        RGL -> Algolia : Index blog post
    end
    
    RGL --> SF : Return processing result
    deactivate RGL
end

alt StorePublicS3 is true
    SF -> S3 : Store JSON of blog posts
end

SF -> SF : Complete execution
deactivate SF

@enduml