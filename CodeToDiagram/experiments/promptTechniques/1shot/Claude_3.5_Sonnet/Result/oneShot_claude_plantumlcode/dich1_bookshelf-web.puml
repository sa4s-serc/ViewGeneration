@startuml dich1_bookshelf-web

!define RECTANGLE class

skinparam class {
    BackgroundColor<<Container>> LightBlue
    BackgroundColor<<Service>> LightGreen
    BorderColor Black
    ArrowColor Black
}

RECTANGLE "Docker Host" as DockerHost {
    RECTANGLE "Docker Compose" as DockerCompose {
        RECTANGLE "Web Service" as WebService <<Container>> {
            RECTANGLE "Rails Application" as RailsApp
        }
        RECTANGLE "Database Service" as DBService <<Container>> {
            RECTANGLE "MySQL" as MySQL
        }
        RECTANGLE "Nginx Service" as NginxService <<Container>> {
            RECTANGLE "Nginx" as Nginx
        }
    }
}

RECTANGLE "CircleCI" as CircleCI <<Service>>
RECTANGLE "Capistrano" as Capistrano <<Service>>

CircleCI --> DockerHost : Deploys to
Capistrano --> DockerHost : Deploys to

Nginx --> RailsApp : Proxies requests
RailsApp --> MySQL : Reads/Writes data

note right of CircleCI : Automated CI/CD pipeline
note right of Capistrano : Deployment automation
note bottom of DockerCompose : Defined in docker-compose.yml

@enduml