@startuml IBM_vpc-flowlogs-log-analysis

actor "COS Trigger" as Trigger
participant "IBM Cloud Function" as Function
participant "COS Receiver Bucket" as ReceiverBucket
participant "COS Archive Bucket" as ArchiveBucket
participant "IBM Log Analysis" as LogAnalysis

Trigger -> Function : Invoke on new log file
activate Function

Function -> ReceiverBucket : Retrieve compressed log file
activate ReceiverBucket
ReceiverBucket --> Function : Return compressed log file
deactivate ReceiverBucket

Function -> Function : Decompress log file

Function -> Function : Parse JSON data

Function -> Function : Transform data for Log Analysis

Function -> LogAnalysis : Forward processed logs
activate LogAnalysis
LogAnalysis --> Function : Confirm receipt
deactivate LogAnalysis

Function -> ArchiveBucket : Copy processed logs
activate ArchiveBucket
ArchiveBucket --> Function : Confirm copy
deactivate ArchiveBucket

Function -> ReceiverBucket : Delete original log file
activate ReceiverBucket
ReceiverBucket --> Function : Confirm deletion
deactivate ReceiverBucket

deactivate Function

@enduml