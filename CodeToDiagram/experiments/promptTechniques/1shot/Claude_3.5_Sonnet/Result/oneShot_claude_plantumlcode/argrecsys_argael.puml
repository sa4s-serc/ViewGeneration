@startuml argrecsys_argael

skinparam component {
  BackgroundColor<<GUI>> LightBlue
  BackgroundColor<<Data>> LightGreen
  BackgroundColor<<IO>> LightYellow
  BackgroundColor<<Util>> LightGray
}

package "ARGAEL Application" {
  [ArgaelForm] <<GUI>>
  [DataManager] <<Data>>
  [IOManager] <<IO>>
  [FileUtils] <<Util>>
  [StringUtils] <<Util>>
  [ReportFormatter] <<GUI>>
  [InitParams] <<Util>>
  [TreeNode] <<Data>>
  [ArgumentModel] <<Data>>
  [SelectedItems] <<Data>>
}

database "JSONL Files" {
  [Proposals]
  [Comments]
}

[Configuration Files] as Config
Config : params.json
Config : users.txt

[HTML Templates] as Templates

ArgaelForm --> DataManager
ArgaelForm --> IOManager
ArgaelForm --> ReportFormatter
ArgaelForm --> InitParams

DataManager --> ArgumentModel
DataManager --> TreeNode
DataManager --> SelectedItems

IOManager --> FileUtils
IOManager --> StringUtils

ReportFormatter --> Templates

InitParams --> Config

IOManager --> "JSONL Files"

@enduml