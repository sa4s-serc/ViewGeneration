@startuml SocialGouv_archifiltre-docs

actor User
participant "Electron App" as App
participant "Main Process" as Main
participant "Renderer Process" as Renderer
participant "AsyncWorker" as Worker
database "File System" as FS
cloud "External Services" as External

User -> App : Launch application
activate App

App -> Main : Initialize
activate Main
Main -> Renderer : Start renderer process
activate Renderer

User -> Renderer : Load file system
Renderer -> Main : Request file system load
Main -> Worker : Spawn worker process
activate Worker
Worker -> FS : Read file system data
FS --> Worker : File system data
Worker -> Worker : Calculate hashes\nDetect duplicates
Worker --> Main : Processed data
deactivate Worker
Main --> Renderer : Update UI with data

User -> Renderer : Request export
Renderer -> Main : Initiate export process
Main -> Worker : Spawn export worker
activate Worker
Worker -> Worker : Generate export file
Worker -> FS : Write export file
FS --> Worker : File written confirmation
Worker --> Main : Export complete
deactivate Worker
Main --> Renderer : Update UI with export status

User -> Renderer : Modify metadata
Renderer -> Renderer : Update local state
Renderer -> Main : Sync metadata changes
Main -> FS : Save metadata

User -> Renderer : Generate audit report
Renderer -> Main : Request report generation
Main -> Worker : Spawn report worker
activate Worker
Worker -> Worker : Generate DOCX report
Worker -> FS : Write report file
FS --> Worker : File written confirmation
Worker --> Main : Report complete
deactivate Worker
Main --> Renderer : Update UI with report status

Renderer -> External : Send usage data (Matomo/Posthog)

App -> External : Check for updates
External --> App : Update available
App -> User : Prompt for update

@enduml