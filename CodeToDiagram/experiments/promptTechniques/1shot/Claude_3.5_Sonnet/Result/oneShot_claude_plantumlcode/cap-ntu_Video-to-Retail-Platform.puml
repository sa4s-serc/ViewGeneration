@startuml cap-ntu_Video-to-Retail-Platform

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<ML>> LightYellow
  BackgroundColor<<Data>> LightGray
}

package "Frontend" <<Frontend>> {
  [React Dashboard]
  [Redux State Management]
  [Material-UI Components]
}

package "Backend" <<Backend>> {
  [Django API]
  [gRPC Services]
  [System Monitoring]
  [Container Starter]
}

package "Machine Learning" <<ML>> {
  [Object Detection Models]
  [Face Recognition]
  [Scene Recognition]
  [Sentence Embedding]
  [Model Selection]
}

package "Data Processing" <<Data>> {
  [Video Decoding]
  [Audio Processing]
  [Subtitle Processing]
  [Data Augmentation]
}

database "Storage" {
  [SQLite]
  [Pickle Files]
}

[React Dashboard] --> [Django API]
[React Dashboard] --> [gRPC Services]
[Django API] --> [Video Decoding]
[Django API] --> [Object Detection Models]
[Django API] --> [Face Recognition]
[Django API] --> [Scene Recognition]
[Django API] --> [Sentence Embedding]
[gRPC Services] --> [Video Decoding]
[gRPC Services] --> [Object Detection Models]
[gRPC Services] --> [Face Recognition]
[gRPC Services] --> [Scene Recognition]
[gRPC Services] --> [Sentence Embedding]
[Video Decoding] --> [Audio Processing]
[Video Decoding] --> [Subtitle Processing]
[Object Detection Models] --> [Data Augmentation]
[Face Recognition] --> [Data Augmentation]
[Scene Recognition] --> [Data Augmentation]
[Model Selection] --> [Object Detection Models]
[Model Selection] --> [Face Recognition]
[Model Selection] --> [Scene Recognition]
[System Monitoring] --> [Container Starter]
[Django API] --> [SQLite]
[Django API] --> [Pickle Files]

@enduml