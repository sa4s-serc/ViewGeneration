@startuml Fenkey_irma

skinparam component {
  BackgroundColor<<C>> LightYellow
  BackgroundColor<<CSharp>> LightBlue
}

package "IRMA Framework" {
  [irmacall (C Engine)] <<C>> as irmacall {
    [Request Handler]
    [HTTP Client (Fetcher)]
    [Key-Value Storage]
    [Logging System]
    [SMTP Support]
    [Cryptography]
    [Fuse (Circuit Breaker)]
    [Buffer Management]
    [Async DNS Resolution]
  }

  [irmakit (C# Framework)] <<CSharp>> as irmakit {
    [Configuration System]
    [Session Management]
    [Request/Response Handling]
    [Attribute-Driven Routing]
    [Template Engine Integration]
    [Utilities]
    [Code Generation]
  }

  [FastCGI]
  [Mono Runtime]
  [Web Server]
}

database "Key-Value Stores" {
  [Memcached]
  [Redis]
}

[Web Applications] <<CSharp>>

irmacall --> FastCGI
FastCGI --> Web Server
irmacall --> [Key-Value Stores]
irmacall --> Mono Runtime
Mono Runtime --> irmakit
irmakit --> [Key-Value Stores]
[Web Applications] --> irmakit

@enduml