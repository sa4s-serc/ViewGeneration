@startuml abel-gr_warehouse-robot

skinparam component {
  BackgroundColor<<Unity>> LightBlue
  BackgroundColor<<CoppeliaSim>> LightGreen
  BackgroundColor<<Web>> LightYellow
  BackgroundColor<<Cloud>> LightGray
}

package "Warehouse Robot Simulation" {
  component "Unity Environment" <<Unity>> {
    [Warehouse Prefabs]
    [Unity Visualization]
  }

  component "CoppeliaSim Simulation" <<CoppeliaSim>> {
    [Robot Control]
    [Inverse Kinematics]
    [OCR Pipeline]
    [sim.py]
  }

  component "Web Interface" <<Web>> {
    [JavaScript Frontend]
    [Audio Recording]
  }

  cloud "Google Cloud Functions" <<Cloud>> {
    [Speech-to-Text]
  }

  [Unity Visualization] --> [sim.py] : Remote API
  [Robot Control] --> [Inverse Kinematics]
  [Robot Control] --> [OCR Pipeline]
  [JavaScript Frontend] --> [Speech-to-Text] : API Call
  [Audio Recording] --> [JavaScript Frontend] : Recorded Speech
  [Speech-to-Text] --> [JavaScript Frontend] : Text Commands
  [JavaScript Frontend] --> [sim.py] : Control Commands
}

@enduml