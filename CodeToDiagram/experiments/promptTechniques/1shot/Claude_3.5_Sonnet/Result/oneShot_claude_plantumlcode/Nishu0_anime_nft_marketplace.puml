@startuml Nishu0_anime_nft_marketplace

actor User
participant "React Frontend" as Frontend
participant "NFTContext" as Context
participant "Web3Modal" as Web3Modal
participant "IPFS" as IPFS
participant "NFTMarketplace\nSmart Contract" as Contract
database Blockchain

User -> Frontend : Interact with UI
Frontend -> Context : Request action
Context -> Web3Modal : Connect wallet
Web3Modal -> Context : Return wallet connection

alt Create NFT
    Context -> IPFS : Upload image and metadata
    IPFS --> Context : Return IPFS URI
    Context -> Contract : Mint NFT with URI
    Contract -> Blockchain : Store NFT data
    Blockchain --> Contract : Confirm transaction
    Contract --> Context : Return NFT details
    Context --> Frontend : Update UI with new NFT
end

alt List NFT for sale
    Context -> Contract : List NFT
    Contract -> Blockchain : Update NFT listing
    Blockchain --> Contract : Confirm transaction
    Contract --> Context : Return listing details
    Context --> Frontend : Update UI with listing
end

alt Buy NFT
    Context -> Contract : Buy NFT
    Contract -> Blockchain : Transfer ownership and funds
    Blockchain --> Contract : Confirm transaction
    Contract --> Context : Return purchase details
    Context --> Frontend : Update UI with purchase
end

alt Fetch NFTs
    Context -> Contract : Request NFT data
    Contract -> Blockchain : Fetch NFT data
    Blockchain --> Contract : Return NFT data
    Contract --> Context : Return NFT details
    Context --> Frontend : Update UI with NFTs
end

Frontend --> User : Display updated information

@enduml