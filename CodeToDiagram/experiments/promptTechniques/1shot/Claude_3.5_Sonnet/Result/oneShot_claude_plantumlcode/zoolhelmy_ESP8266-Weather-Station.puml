@startuml zoolhelmy_ESP8266-Weather-Station

actor User
participant "ESP8266\nNodeMCU" as ESP
participant "ThingSpeak" as TS
participant "OpenWRT\nRouter" as Router
participant "GitHub\nRepository" as GitHub

User -> ESP : Power on
activate ESP

ESP -> ESP : Initialize sensors
ESP -> ESP : Start HTTP server

loop Every sensor reading interval
    ESP -> ESP : Read sensor data
    ESP ->> TS : Publish data via MQTT
    ESP ->> Router : Publish data via MQTT
end

Router -> Router : Subscribe to MQTT topics
Router -> Router : Save data to temporary files

loop Every collectd interval
    Router -> Router : Process data with collectd
    Router -> Router : Update RRDTool database
    Router -> Router : Remove temporary files
end

loop Daily
    Router -> Router : Generate graphs from RRDTool data
    Router -> Router : Commit changes to local Git repo
    Router -> GitHub : Push updated graphs
end

User -> Router : Access local HTTP interface
Router --> User : Return real-time readings

deactivate ESP

@enduml