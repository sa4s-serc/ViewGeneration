@startuml today-real-estate_today-real-estate_front-end

!define RECTANGLE class

skinparam rectangle {
    BorderColor #A80036
    BackgroundColor #FEFECE
    ArrowColor #A80036
}

rectangle "Production Environment" as Prod {
    RECTANGLE "Nginx Web Server" as Nginx
    RECTANGLE "Vue.js Application" as VueApp
    RECTANGLE ".env.production" as EnvProd
}

rectangle "Development Environment" as Dev {
    RECTANGLE "Vue CLI Dev Server" as DevServer
    RECTANGLE ".env.development" as EnvDev
}

rectangle "Shared Components" as Shared {
    RECTANGLE "Vue Router" as Router
    RECTANGLE "Vuex Store" as Vuex
    RECTANGLE "API Module" as API
    RECTANGLE "Components" as Components
    RECTANGLE "Views" as Views
}

Nginx --> VueApp : Serves
VueApp --> EnvProd : Uses
DevServer --> VueApp : Serves
VueApp --> EnvDev : Uses (in dev)

VueApp --> Router : Uses
VueApp --> Vuex : Uses
VueApp --> API : Uses
VueApp --> Components : Includes
VueApp --> Views : Includes

note right of Prod
  Static files served by Nginx
  Environment variables from .env.production
end note

note right of Dev
  Hot-reloading enabled
  Environment variables from .env.development
end note

note bottom of Shared
  Common elements used in both
  production and development
end note

@enduml