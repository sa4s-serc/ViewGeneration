@startuml mcuking_offline-package-webpack-plugin

participant Webpack
participant OfflinePackagePlugin
participant JSZip
participant MimeTypes
participant FileSystem

Webpack -> OfflinePackagePlugin : apply(compiler)
activate OfflinePackagePlugin

OfflinePackagePlugin -> Webpack : hooks.emit.tapAsync()

Webpack -> OfflinePackagePlugin : emit callback
activate OfflinePackagePlugin

OfflinePackagePlugin -> JSZip : new JSZip()
activate JSZip

loop for each asset
    OfflinePackagePlugin -> OfflinePackagePlugin : filterAsset()
    alt asset passes filter
        OfflinePackagePlugin -> JSZip : file(assetPath, content)
        OfflinePackagePlugin -> MimeTypes : lookup(assetPath)
        MimeTypes --> OfflinePackagePlugin : mimeType
        OfflinePackagePlugin -> OfflinePackagePlugin : updateManifest()
    end
end

OfflinePackagePlugin -> JSZip : generateAsync()
JSZip --> OfflinePackagePlugin : zipBuffer

OfflinePackagePlugin -> FileSystem : writeFileSync(zipFilePath, zipBuffer)
OfflinePackagePlugin -> FileSystem : writeFileSync(manifestPath, manifest)

OfflinePackagePlugin --> Webpack : callback()
deactivate OfflinePackagePlugin

deactivate JSZip
deactivate OfflinePackagePlugin

@enduml