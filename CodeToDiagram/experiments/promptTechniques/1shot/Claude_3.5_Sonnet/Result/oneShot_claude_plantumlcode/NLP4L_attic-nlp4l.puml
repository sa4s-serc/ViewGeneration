@startuml NLP4L_attic-nlp4l

skinparam component {
  BackgroundColor<<core>> #E1F5FE
  BackgroundColor<<analysis>> #FFF3E0
  BackgroundColor<<nlp>> #E8F5E9
  BackgroundColor<<util>> #F3E5F5
}

package "Core" <<core>> {
  [IWriter]
  [IReader]
  [RawReader]
  [ISearcher]
  [Schema]
  [Field]
  [FieldType]
  [SchemaLoader]
  [Document]
}

package "Text Analysis" <<analysis>> {
  [Analyzer]
  [AnalyzerBuilder]
  [Token]
  [BrownCorpusAnalyzer]
  [TermDocs]
  [Terms]
  [Japanese Analysis Module]
}

package "NLP Algorithms" <<nlp>> {
  [HmmModel]
  [HmmTagger]
  [HmmTokenizer]
  [CollocationalAnalysisModel]
  [SimpleFST]
}

package "Utilities" <<util>> {
  [Corpora]
  [NLP4LILoop]
  [FeatureSelector]
  [TermsExtractor]
  [LoanWordsExtractor]
  [TransliterationModel]
}

[IWriter] --> [Schema]
[IReader] --> [Schema]
[RawReader] --> [Schema]
[ISearcher] --> [Schema]
[Schema] --> [Field]
[Field] --> [FieldType]
[SchemaLoader] --> [Schema]
[Document] --> [Field]

[Analyzer] --> [Token]
[AnalyzerBuilder] --> [Analyzer]
[BrownCorpusAnalyzer] --> [Analyzer]

[HmmModel] --> [SimpleFST]
[HmmTagger] --> [HmmModel]
[HmmTokenizer] --> [HmmModel]

[NLP4LILoop] --> [IWriter]
[NLP4LILoop] --> [IReader]
[NLP4LILoop] --> [ISearcher]

[FeatureSelector] --> [Terms]
[TermsExtractor] --> [Terms]

@enduml