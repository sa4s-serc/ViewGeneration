@startuml Simon-0711_ta_lyrics_sentiment_classification

actor User
participant "React Frontend" as Frontend
participant "FastAPI Backend" as Backend
participant "LyricsGenius API" as GeniusAPI
database "Elasticsearch" as ES
participant "CNN Model" as CNN

User -> Frontend : Input song/artist
activate Frontend

Frontend -> Backend : POST /search
activate Backend

Backend -> ES : Search for lyrics
activate ES

alt Lyrics not found
    Backend <-- ES : Not found
    Backend -> GeniusAPI : Fetch lyrics
    activate GeniusAPI
    Backend <-- GeniusAPI : Return lyrics
    deactivate GeniusAPI
    Backend -> ES : Store lyrics
else Lyrics found
    Backend <-- ES : Return lyrics
end
deactivate ES

Backend -> Backend : Preprocess lyrics
Backend -> CNN : Classify sentiment
activate CNN
Backend <-- CNN : Return mood
deactivate CNN

Backend -> ES : Find similar songs
activate ES
Backend <-- ES : Return similar songs
deactivate ES

Backend -> Backend : Calculate cosine similarity

Frontend <-- Backend : Return results
deactivate Backend

User <-- Frontend : Display results
deactivate Frontend

@enduml