@startuml CMUChimpsLab_Peekaboo

actor User
participant "Node-RED Flow" as Flow
participant "Provider Node" as Provider
participant "Inference Node" as Inference
participant "Filter Node" as Filter
participant "Network Node" as Network
participant "Utility Node" as Utility
participant "External Service" as ExternalService

User -> Flow : Create flow
activate Flow

Flow -> Provider : Configure data source
activate Provider
Provider --> Flow : Data ingested
deactivate Provider

Flow -> Inference : Apply ML model
activate Inference
Inference -> ExternalService : Request inference
ExternalService --> Inference : Return results
Inference --> Flow : Processed data
deactivate Inference

Flow -> Filter : Apply privacy filters
activate Filter
Filter --> Flow : Filtered data
deactivate Filter

Flow -> Utility : Aggregate/manipulate data
activate Utility
Utility --> Flow : Modified data
deactivate Utility

Flow -> Network : Transmit data
activate Network
Network -> ExternalService : Send processed data
ExternalService --> Network : Acknowledge
Network --> Flow : Transmission complete
deactivate Network

Flow --> User : Display results

deactivate Flow

@enduml