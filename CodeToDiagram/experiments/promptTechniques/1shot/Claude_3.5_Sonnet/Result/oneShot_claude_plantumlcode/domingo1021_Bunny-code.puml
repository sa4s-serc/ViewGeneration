@startuml domingo1021_Bunny-code

actor Developer
participant "CI/CD Pipeline" as CI
participant "Docker Registry" as Registry
participant "Deployment Server" as Server
database "MySQL" as DB
database "Redis" as Cache
database "InfluxDB" as InfluxDB
participant "Nginx Reverse Proxy" as Nginx
participant "API Server" as API
participant "Socket.IO Server" as Socket
participant "Code Sandbox" as Sandbox
cloud "AWS S3" as S3
cloud "AWS CloudFront" as CloudFront
cloud "AWS CloudWatch" as CloudWatch

Developer -> CI: Push code
activate CI

CI -> CI: Build Docker images
CI -> CI: Run tests
CI -> Registry: Push images
CI -> Server: Trigger deployment

activate Server
Server -> Server: Pull latest images
Server -> DB: Start MySQL container
Server -> Cache: Start Redis container
Server -> InfluxDB: Start InfluxDB container
Server -> Nginx: Start Nginx container
Server -> API: Start API container
Server -> Socket: Start Socket.IO container
Server -> Sandbox: Start Code Sandbox container
Server -> CloudWatch: Send deployment logs

Nginx <- API: Register routes
Nginx <- Socket: Register WebSocket
API <-> DB: Connect
API <-> Cache: Connect
API <-> InfluxDB: Connect
API <-> S3: Connect for file storage
API <-> CloudFront: Configure for content delivery
Socket <-> Cache: Manage real-time state

CloudWatch <- API: Send application logs
CloudWatch <- Socket: Send WebSocket logs
CloudWatch <- Sandbox: Send execution logs

Server -> CI: Deployment complete
deactivate Server

CI -> Developer: Notify deployment status
deactivate CI

@enduml