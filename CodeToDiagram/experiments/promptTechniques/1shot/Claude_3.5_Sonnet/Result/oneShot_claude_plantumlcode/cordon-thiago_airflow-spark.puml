@startuml cordon-thiago_airflow-spark

skinparam component {
  BackgroundColor<<container>> LightBlue
  BackgroundColor<<orchestration>> LightGreen
  BackgroundColor<<storage>> LightYellow
}

cloud "Kubernetes Cluster" {
  [Spark Master] <<container>>
  [Spark Worker] <<container>>
  [Airflow Webserver] <<container>>
  [Airflow Scheduler] <<container>>
  [Airflow Worker] <<container>>
  database "PostgreSQL" <<storage>>
}

[Docker Registry] <<container>>

[Spark Master] --> [Spark Worker] : manages
[Airflow Webserver] --> [Airflow Scheduler] : triggers
[Airflow Scheduler] --> [Airflow Worker] : schedules
[Airflow Worker] --> [Spark Master] : submits jobs
[Airflow Worker] --> PostgreSQL : reads/writes

[Docker Registry] --> [Spark Master] : provides image
[Docker Registry] --> [Spark Worker] : provides image
[Docker Registry] --> [Airflow Webserver] : provides image
[Docker Registry] --> [Airflow Scheduler] : provides image
[Docker Registry] --> [Airflow Worker] : provides image

component "Source Code Repository" {
  [Spark Applications]
  [Airflow DAGs]
  [Kubernetes Manifests]
  [Docker Configurations]
}

[Spark Applications] ..> [Spark Master] : deployed to
[Airflow DAGs] ..> [Airflow Scheduler] : loaded by
[Kubernetes Manifests] ..> [Kubernetes Cluster] : defines
[Docker Configurations] ..> [Docker Registry] : builds

@enduml