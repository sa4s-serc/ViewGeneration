@startuml onlybakam_reinvent2022-vote-app

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

actor User

rectangle "Next.js Frontend" {
  [Vote UI] as VoteUI
  [GraphQL Client] as GraphQLClient
}

rectangle "AWS AppSync" {
  [GraphQL API] as AppSyncAPI
  [Resolver Pipeline] as ResolverPipeline
}

rectangle "AWS Services" {
  [DynamoDB] as DynamoDB
  [SNS] as SNS
  [Translate] as Translate
}

User -> VoteUI : Cast Vote
VoteUI -> GraphQLClient : Trigger AddVote Mutation
GraphQLClient -> AppSyncAPI : AddVote Mutation

AppSyncAPI -> ResolverPipeline : Execute Resolver

ResolverPipeline -> SNS : publishToSNS
ResolverPipeline -> DynamoDB : saveToDynamodb
ResolverPipeline -> Translate : translateMessage

SNS --> AppSyncAPI : Vote Event
AppSyncAPI --> GraphQLClient : OnPlusOne Subscription
GraphQLClient --> VoteUI : Update Vote Count

@enduml