@startuml
skinparam rectangle {
  BackgroundColor #EEEEEE
  BorderColor #000000
  FontColor #000000
}

actor "User" as user

rectangle "Frontend (React)" as frontend {
  rectangle "Material UI" as mui
  rectangle "SignIn.js" as signin
}

cloud "Kubernetes Cluster" as k8s {
  
  rectangle "Authentication Service" as auth_service {
    rectangle "Flask" as flask_auth
    rectangle "JWT" as jwt
  }
  
  rectangle "Account Management Service" as account_service {
    rectangle "Flask" as flask_account
  }
  
  rectangle "Athlete Availability Service" as availability_service {
    rectangle "Flask" as flask_availability
  }
  
  rectangle "Test Scheduling Service" as scheduling_service {
    rectangle "Flask" as flask_scheduling
  }
  
  rectangle "Result Reporting Service" as reporting_service {
    rectangle "Flask" as flask_reporting
  }
}

rectangle "Docker" as docker
rectangle "GitHub Actions" as github_actions

database "DynamoDB" as dynamodb

user --> frontend
frontend --> k8s : API Requests

k8s --> auth_service
k8s --> account_service
k8s --> availability_service
k8s --> scheduling_service
k8s --> reporting_service

auth_service --> dynamodb
account_service --> dynamodb
availability_service --> dynamodb
scheduling_service --> dynamodb
reporting_service --> dynamodb

github_actions --> docker : Build & Push
docker --> k8s : Deploy

@enduml