@startuml
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

package "Resurgence VM" {
  [Virtual Machine Core] as VMCore
  [Bytecode Handler] as BytecodeHandler
  [FFI (Foreign Function Interface)] as FFI
  [Instruction Set] as InstructionSet
  [Error Handler] as ErrorHandler
  [Code Generator] as CodeGenerator

  component "Execution Engine" {
    [Interpreter] as Interpreter
    [ExecutionEngine Trait] as ExecutionEngineTrait
  }

  component "Memory Management" {
    [Stack Frames]
    [Registers]
    [Constant Pool]
  }

  component "External Interaction" {
    [ResurgenceState]
  }

  database "Bytecode Files" as BytecodeFiles
}

[C/C++ Application] as ExternalApp

VMCore --> Interpreter
VMCore --> BytecodeHandler
VMCore --> FFI
VMCore --> InstructionSet
VMCore --> ErrorHandler
VMCore --> CodeGenerator

Interpreter --> ExecutionEngineTrait : implements
Interpreter --> "Memory Management"
BytecodeHandler <--> BytecodeFiles : read/write

FFI <--> ExternalApp : interact
FFI --> ResurgenceState : use

ExternalApp --> ResurgenceState : interact with VM

@enduml