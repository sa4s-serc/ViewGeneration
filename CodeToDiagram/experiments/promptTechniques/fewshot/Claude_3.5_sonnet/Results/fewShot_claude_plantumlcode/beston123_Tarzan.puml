@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  ArrowColor #222222
  BorderColor #666666
}

rectangle "Client" as client
rectangle "Server" as server
rectangle "Registry (Zookeeper)" as registry
rectangle "Message Broker (RocketMQ)" as broker
database "Database (MySQL)" as db
rectangle "Redis" as redis

client -> server : Send message
server -> registry : Service discovery
server -> broker : Proxy message
server -> db : Store message info
server -> redis : Acquire distributed lock

rectangle "Scheduled Tasks" as tasks {
  rectangle "Transaction Status Check" as check
  rectangle "Message Resend" as resend
}

server --> tasks : Manage
tasks --> broker : Check/Resend
tasks --> db : Update status
tasks --> redis : Acquire lock

rectangle "RPC Layer (Netty)" as rpc {
  client <--> server : Communication
}

rectangle "Data Access Layer" as dal {
  server --> dal : Access data
  dal --> db : CRUD operations
}

@enduml