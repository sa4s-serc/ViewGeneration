@startuml anvasquezre_sabiduria_asegurada_experiments

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  FontColor #333333
}

actor User

rectangle "Chainlit Frontend" as Frontend
rectangle "Chatbot Application" as ChatbotApp {
  rectangle "Langchain Agent" as Agent
  rectangle "Policy Search Tool" as PolicyTool
  rectangle "Web Search Tool" as WebTool
  rectangle "Greeting Tool" as GreetingTool
}
rectangle "Qdrant Vector DB" as Qdrant
rectangle "Data Preloader" as Preloader
cloud "S3 Bucket" as S3
cloud "OpenAI API" as OpenAI
cloud "Google Search API" as GoogleSearch

User -> Frontend : Ask question
Frontend -> ChatbotApp : Forward question
ChatbotApp -> Agent : Process question
Agent -> PolicyTool : Query policy info
PolicyTool -> Qdrant : Semantic search
Agent -> WebTool : Search web
WebTool -> GoogleSearch : Perform search
Agent -> GreetingTool : Generate greeting
ChatbotApp -> OpenAI : Generate response
ChatbotApp -> Frontend : Return answer
Frontend -> User : Display answer

Preloader -> S3 : Download PDFs
Preloader -> OpenAI : Generate embeddings
Preloader -> Qdrant : Load policy data

@enduml