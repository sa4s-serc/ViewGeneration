@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor "GitHub API" as GitHub

rectangle "Crawler" as Crawler {
  [crawler.py] as CrawlerScript
}

queue "RabbitMQ" as RabbitMQ

rectangle "Worker" as Worker {
  [manager.py] as ManagerScript
  package "Analysis Modules" {
    [Security] as SecurityModule
    [Testability] as TestabilityModule
    [Reusability] as ReusabilityModule
    [Usability] as UsabilityModule
  }
}

database "MongoDB" as MongoDB

cloud "Repository Code" as RepoCode

GitHub <--> Crawler : Fetch repo info
Crawler --> RabbitMQ : Publish tasks
Crawler --> MongoDB : Store repo metadata
RabbitMQ <-- Worker : Consume tasks
Worker <--> RepoCode : Download & analyze
Worker --> MongoDB : Store analysis results

ManagerScript --> SecurityModule
ManagerScript --> TestabilityModule
ManagerScript --> ReusabilityModule
ManagerScript --> UsabilityModule

note right of Crawler
  Uses multiple GitHub accounts
  to mitigate rate limiting
end note

note right of Worker
  Performs analysis using:
  - radon
  - pylint
  - scikit-learn
end note

note bottom of MongoDB
  Stores:
  - Repository metadata
  - Analysis results
  - System state
end note

@enduml