@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Data Engineer" as user

rectangle "AWS Open Data Registry" as registry #lightblue

cloud "AWS" {
  database "S3 Data Lake" as s3 #lightyellow {
    rectangle "Raw Data" as raw
    rectangle "Transformed CSVs" as csv
  }
  
  rectangle "Athena" as athena #lightgreen
  
  database "Redshift" as redshift #pink {
    rectangle "Fact Table" as fact
    rectangle "Dimension Tables" as dim
  }
}

rectangle "Jupyter Notebook\n(covid19_project.ipynb)" as notebook #orange {
  rectangle "Extract" as extract
  rectangle "Transform" as transform
  rectangle "Load" as load
}

user --> notebook : Runs

registry --> s3 : Stores data
s3 --> athena : Queries
athena --> extract : Returns data
extract --> transform : Passes data
transform --> csv : Writes
csv --> load : Reads
load --> redshift : Inserts

@enduml