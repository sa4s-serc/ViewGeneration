@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (React)" {
  rectangle "MainInterface" {
    rectangle "Map" as Map
    rectangle "Sidebar" as Sidebar
    rectangle "Panel" {
      rectangle "GraphSVG" as GraphSVG
      rectangle "GraphTable" as GraphTable
    }
  }
  rectangle "Reports" as Reports
  rectangle "EventProxy" as EventProxy
}

rectangle "Backend (Node.js)" {
  rectangle "Express Server" as Express
  rectangle "Algorithm Executor" as AlgoExecutor
  rectangle "User Authentication" as Auth
  rectangle "Database Access" as DAO
}

database "MySQL" as DB

rectangle "External C++ Executables" as CPP

User --> MainInterface : interacts
User --> Reports : views

Sidebar --> Express : algorithm selection
Map --> Express : node management
Express --> AlgoExecutor : executes algorithm
AlgoExecutor --> CPP : runs
CPP --> AlgoExecutor : returns results
AlgoExecutor --> Express : animation steps
Express --> GraphSVG : updates
Express --> GraphTable : updates

GraphSVG <--> EventProxy : publishes/subscribes
GraphTable <--> EventProxy : publishes/subscribes

Express <--> Auth : authenticates
Auth <--> DAO : verifies
DAO <--> DB : queries/updates

@enduml