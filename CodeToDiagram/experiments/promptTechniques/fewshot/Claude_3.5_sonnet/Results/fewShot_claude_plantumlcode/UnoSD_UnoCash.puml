@startuml UnoSD_UnoCash

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  BorderThickness 1
}

actor User

rectangle "UnoCash.Blazor (Frontend)" {
  [Index Page]
  [FetchData Page]
  [Update Page]
  [MainLayout]
  [NavMenu]
}

rectangle "Azure Functions (Backend)" {
  [GetExpenses]
  [AddExpense]
  [UpdateExpense]
  [DeleteExpense]
  [GetReceiptData]
  [GetReceiptUploadSasToken]
}

rectangle "UnoCash.Core" {
  [ExpenseReader]
  [ExpenseWriter]
  [ReceiptParser]
  [AzureTableStorage]
}

cloud "Azure Services" {
  [Azure AD]
  [Azure Blob Storage]
  [Azure Table Storage]
  [Form Recognizer]
  [API Management]
}

rectangle "UnoCash.Pulumi (IaC)" {
  [Resource Provisioning]
}

rectangle "Azure DevOps" {
  [CI/CD Pipelines]
}

User --> [Index Page]
User --> [FetchData Page]
User --> [Update Page]

[Index Page] --> [GetExpenses]
[FetchData Page] --> [GetExpenses]
[Update Page] --> [AddExpense]
[Update Page] --> [UpdateExpense]
[Update Page] --> [DeleteExpense]
[Update Page] --> [GetReceiptData]
[Update Page] --> [GetReceiptUploadSasToken]

[GetExpenses] --> [ExpenseReader]
[AddExpense] --> [ExpenseWriter]
[UpdateExpense] --> [ExpenseWriter]
[DeleteExpense] --> [ExpenseWriter]
[GetReceiptData] --> [ReceiptParser]

[ExpenseReader] --> [AzureTableStorage]
[ExpenseWriter] --> [AzureTableStorage]
[ReceiptParser] --> [Form Recognizer]
[ReceiptParser] --> [Azure Blob Storage]

[AzureTableStorage] --> [Azure Table Storage]

[Azure Functions (Backend)] --> [API Management]
[API Management] --> [Azure AD]

[Resource Provisioning] ..> [Azure Services] : provisions
[CI/CD Pipelines] ..> [Resource Provisioning] : executes
[CI/CD Pipelines] ..> [Azure Functions (Backend)] : deploys
[CI/CD Pipelines] ..> [UnoCash.Blazor (Frontend)] : deploys

@enduml