@startuml
skinparam rectangle {
  BackgroundColor #EEEEEE
  BorderColor #000000
  RoundCorner 10
}
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #000000
}
skinparam arrow {
  Color #000000
  FontColor #000000
}

rectangle "User Interface" {
  [Main Page] as MainPage
  [OpenAPI Page] as OpenAPIPage
  [Request Form] as RequestForm
  [Payload Management] as PayloadManagement
  [Results Display] as ResultsDisplay
}

rectangle "State Management" {
  [Redux Store] as ReduxStore
  [Payloads Slice] as PayloadsSlice
  [Emulate Slice] as EmulateSlice
  [Endpoints Slice] as EndpointsSlice
  [Dialog Slice] as DialogSlice
}

rectangle "API Interaction" {
  [Execute Attack] as ExecuteAttack
  [API Client] as APIClient
}

rectangle "Data Handling" {
  [Import/Export] as ImportExport
  [Zod Schemas] as ZodSchemas
}

cloud "Backend API" as BackendAPI

MainPage --> RequestForm
MainPage --> PayloadManagement
MainPage --> ResultsDisplay
RequestForm --> ExecuteAttack
PayloadManagement --> ImportExport
ExecuteAttack --> APIClient
APIClient --> BackendAPI

ReduxStore --> PayloadsSlice
ReduxStore --> EmulateSlice
ReduxStore --> EndpointsSlice
ReduxStore --> DialogSlice

RequestForm ..> ReduxStore : Uses
PayloadManagement ..> ReduxStore : Uses
ResultsDisplay ..> ReduxStore : Uses
ExecuteAttack ..> ReduxStore : Uses

ImportExport ..> ZodSchemas : Validates
APIClient ..> ZodSchemas : Validates

OpenAPIPage --> BackendAPI : Documents

@enduml