@startuml ankithans_codeX

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<ExternalAPI>> LightYellow
  BackgroundColor<<Database>> LightGray
}

package "Frontend (React)" <<Frontend>> {
  [App.js]
  [Navbar.js]
  [PseudoCode.js]
  [Warnings.js]
  [Compile.js]
  [Monaco Editor]
}

package "Backend (FastAPI)" <<Backend>> {
  [API Gateway (app.py)]
  package "Routes" {
    [compile.py]
    [convertPseudo.py]
    [warnings.py]
    [translatePseudo.py]
    [shareCode.py]
    [flowchart.py]
  }
  package "Services" {
    [pylint.py]
    [pseudo_code.py]
    [hackerearth_compile.py]
    [translate.py]
    [flowchart.py]
  }
}

database "SQLite" <<Database>> {
  [Shared Code Snippets]
}

cloud "External APIs" <<ExternalAPI>> {
  [HackerEarth API]
  [Google Translate API]
}

[App.js] --> [API Gateway (app.py)] : REST API calls
[API Gateway (app.py)] --> [compile.py]
[API Gateway (app.py)] --> [convertPseudo.py]
[API Gateway (app.py)] --> [warnings.py]
[API Gateway (app.py)] --> [translatePseudo.py]
[API Gateway (app.py)] --> [shareCode.py]
[API Gateway (app.py)] --> [flowchart.py]

[compile.py] --> [hackerearth_compile.py]
[convertPseudo.py] --> [pseudo_code.py]
[warnings.py] --> [pylint.py]
[translatePseudo.py] --> [Google Translate API]
[shareCode.py] --> [Shared Code Snippets]
[flowchart.py] --> [flowchart.py]

[hackerearth_compile.py] --> [HackerEarth API]

@enduml