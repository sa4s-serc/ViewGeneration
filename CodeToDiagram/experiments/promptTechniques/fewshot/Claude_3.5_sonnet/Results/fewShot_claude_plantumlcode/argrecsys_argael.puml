@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  Style roundrect
}
skinparam defaultTextAlignment center

package "ARGAEL Desktop Application" {
  rectangle "GUI Layer" as GUI {
    [ArgaelForm] as AF
  }

  rectangle "Data Management Layer" as DML {
    [DataManager] as DM
    [ArgumentModel] as AM
    [SelectedItems] as SI
    [TreeNode] as TN
  }

  rectangle "IO Layer" as IOL {
    [IOManager] as IOM
  }

  rectangle "Utility Layer" as UL {
    [FileUtils] as FU
    [StringUtils] as SU
    [InitParams] as IP
    [ReportFormatter] as RF
  }

  rectangle "Configuration" as Config {
    [params.json] as PJ
    [users.txt] as UT
  }

  rectangle "Data Storage" as DS {
    folder "data/proposals" {
      [*.jsonl files] as JSONL
    }
  }

  rectangle "Report Templates" as RT {
    [HTML Templates] as HT
  }
}

AF --> DM : uses
AF --> IOM : uses
AF --> RF : uses
DM --> AM : uses
DM --> SI : uses
DM --> TN : uses
IOM --> FU : uses
IOM --> SU : uses
RF --> HT : uses
IP --> PJ : reads
AF --> UT : reads
IOM --> JSONL : reads/writes

@enduml