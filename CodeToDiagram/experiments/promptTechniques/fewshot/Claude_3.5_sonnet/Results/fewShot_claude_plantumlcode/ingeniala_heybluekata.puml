@startuml ingeniala_heybluekata

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

skinparam component {
  BackgroundColor #85BBF0
  BorderColor #333333
}

skinparam cloud {
  BackgroundColor #F0F0F0
}

skinparam database {
  BackgroundColor #F5DA81
  BorderColor #333333
}

rectangle "Client Applications" {
  [Web App]
  [Mobile App]
}

cloud "AWS Cloud" {
  rectangle "API Layer" {
    [API Gateway]
    [Omnichannel BFF]
    [HeyBlue BFF Mobile]
    [BFF Web Container]
  }
  
  rectangle "Core Services" {
    [User Management]
    [Interaction & Gamification]
    [Commerce]
    [Content Management]
    [Notification & Messaging]
  }
  
  rectangle "Data & Analytics" {
    [Data Archiving]
    [Analytics]
  }
  
  rectangle "Security" {
    [Cognito]
    [IAM]
  }
  
  database "Storage" {
    [DynamoDB]
    [S3]
    [Glacier]
  }
  
  [EventBridge]
  [Kinesis]
  [Lambda]
}

[Web App] --> [API Gateway]
[Mobile App] --> [API Gateway]

[API Gateway] --> [Omnichannel BFF]
[API Gateway] --> [HeyBlue BFF Mobile]
[API Gateway] --> [BFF Web Container]

[Omnichannel BFF] --> [Core Services]
[HeyBlue BFF Mobile] --> [Core Services]
[BFF Web Container] --> [Core Services]

[Core Services] --> [DynamoDB]
[Core Services] --> [S3]
[Core Services] --> [Cognito]

[Core Services] --> [EventBridge]
[EventBridge] --> [Kinesis]
[Kinesis] --> [Lambda]

[Lambda] --> [Data Archiving]
[Lambda] --> [Analytics]

[Data Archiving] --> [Glacier]
[Analytics] --> [S3]

@enduml