@startuml iceland2k14_Kangrand

skinparam component {
  BackgroundColor LightBlue
  BorderColor Black
  ArrowColor Black
}

[Main] as main
[Kangaroo] as kangaroo
[Secp256K1] as secp
[GPUEngine] as gpu
[HashTable] as hash
[Integer Arithmetic] as int
[Network] as net
[Backup] as backup
[Thread Management] as thread
[Timer] as timer

cloud "Client Machines" {
  [Client 1]
  [Client 2]
  [Client N]
}

database "Work Files" as workfiles

main --> kangaroo
kangaroo --> secp
kangaroo --> gpu
kangaroo --> hash
kangaroo --> int
kangaroo --> net
kangaroo --> backup
kangaroo --> thread
kangaroo --> timer

secp --> int
gpu --> int

net <--> [Client 1]
net <--> [Client 2]
net <--> [Client N]

backup <--> workfiles

note right of kangaroo
  Orchestrates ECDLP solving process
  Manages threads and network communication
end note

note right of gpu
  CUDA-based GPU computations
end note

note right of hash
  Stores and detects distinguished points
end note

note right of int
  Fixed-size and modular arithmetic
end note

note right of net
  Client-server communication
end note

note right of backup
  Work file management and merging
end note

note right of thread
  Cross-platform thread management
end note

@enduml