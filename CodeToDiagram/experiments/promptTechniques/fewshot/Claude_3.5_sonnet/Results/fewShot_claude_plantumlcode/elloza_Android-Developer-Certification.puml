@startuml elloza_Android-Developer-Certification

skinparam component {
  BackgroundColor LightSkyBlue
  BorderColor Black
  ArrowColor Black
}

package "UI Layer" {
  [MainActivity]
  [RibotsAdapter]
}

package "Presentation Layer" {
  [MainPresenter]
}

package "Data Layer" {
  [DataManager]
  [SyncService]
  [DatabaseHelper]
  [RibotsService]
}

package "Model" {
  [Ribot]
  [Profile]
  [Name]
}

package "Core" {
  [BaseApplication]
}

package "Dependency Injection" {
  [Dagger 2]
}

package "Reactive Programming" {
  [RxJava 2]
}

package "Testing" {
  [Espresso Tests]
  [Unit Tests]
}

[MainActivity] --> [MainPresenter]
[MainActivity] --> [RibotsAdapter]
[MainPresenter] --> [DataManager]
[DataManager] --> [DatabaseHelper]
[DataManager] --> [RibotsService]
[DataManager] --> [SyncService]
[DatabaseHelper] --> [SqlBrite]
[RibotsService] --> [Retrofit]
[BaseApplication] --> [Dagger 2]
[BaseApplication] --> [Timber]

[DataManager] --> [Ribot]
[Ribot] --> [Profile]
[Profile] --> [Name]

[RxJava 2] ..> [DataManager] : used by
[Dagger 2] ..> [UI Layer] : injects
[Dagger 2] ..> [Presentation Layer] : injects
[Dagger 2] ..> [Data Layer] : injects

[Espresso Tests] ..> [MainActivity] : tests
[Unit Tests] ..> [MainPresenter] : tests
[Unit Tests] ..> [DataManager] : tests

@enduml