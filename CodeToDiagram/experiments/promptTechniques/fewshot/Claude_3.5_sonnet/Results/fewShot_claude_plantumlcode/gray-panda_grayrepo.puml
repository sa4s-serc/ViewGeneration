@startuml gray-panda_grayrepo

skinparam backgroundColor #EEEBDC
skinparam handwritten true

actor "Attacker" as ATK

rectangle "Malware Analysis" as MA {
  [induct (ELF Binary)] as INDUCT
  [UDP/IRC Communication] as COMM
  [Custom Golang VM] as VM
  [File Encryption] as FENC
  [Persistence (crontab)] as PERS
}

rectangle "SSHD Exploitation" as SE {
  [Compromised sshd] as SSHD
  [Core Dump Analysis] as CORE
  [ECC Key Recovery] as ECC
  [Shellcode Analysis] as SHELL
  [Smart Contract Interaction] as SC
}

rectangle "Mobile App RE" as MARE {
  [Android App] as AND
  [Windows Mobile App] as WM
  [Gesture Handling] as GH
  [XOR Encryption] as XOR
  [Device Info Verification] as DIV
}

ATK --> MA : Reverse Engineers
ATK --> SE : Exploits
ATK --> MARE : Analyzes

INDUCT --> COMM : Uses
INDUCT --> VM : Executes
INDUCT --> FENC : Performs
INDUCT --> PERS : Establishes

SSHD --> CORE : Generates
CORE --> ECC : Enables
SHELL --> SC : Interacts with

AND --> GH : Implements
WM --> XOR : Uses for Flag
WM --> DIV : Performs

@enduml