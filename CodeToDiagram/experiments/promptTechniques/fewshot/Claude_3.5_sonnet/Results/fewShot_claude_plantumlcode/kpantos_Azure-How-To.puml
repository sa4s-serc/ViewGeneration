@startuml
skinparam backgroundColor #EEEBDC
skinparam handwritten true
skinparam rectangle {
  BackgroundColor<<external>> #FFBD9D
  BackgroundColor<<azure>> #ADD1B2
  BorderColor Black
  ArrowColor Black
}

rectangle "Internet" <<external>> as internet

package "Azure" {
  rectangle "Azure Application Gateway" <<azure>> as appgw {
    rectangle "Web Application Firewall" as waf
  }
  
  rectangle "Azure App Service" <<azure>> as appservice {
    rectangle "Bot Application" as bot
  }
  
  rectangle "Azure AD\nApplication Proxy" <<azure>> as aadproxy
  
  rectangle "Azure API Management" <<azure>> as apim
  
  rectangle "Azure AD" <<azure>> as aad
}

cloud "On-Premises / Simulated Azure VM" {
  rectangle "Active Directory" as ad
  rectangle "IIS Web Server" as iis {
    rectangle "Kerberos-secured API" as api
  }
}

internet --> appgw
appgw --> appservice
internet --> aadproxy
aadproxy --> apim
apim --> api
aad <--> ad : Azure AD Connect

note right of appgw : Let's Encrypt SSL/TLS
note right of aadproxy : Enables remote access\nwithout VPN
note right of apim : API management,\nsecurity, analytics
note right of api : Service Principal Name (SPN)

@enduml