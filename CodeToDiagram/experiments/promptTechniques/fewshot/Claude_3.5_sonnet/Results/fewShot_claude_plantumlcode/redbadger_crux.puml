@startuml redbadger_crux

skinparam rectangle {
  BackgroundColor #EEEEEE
  BorderColor #000000
  RoundCorner 10
}

rectangle "Core (Rust)" as Core {
  [App Trait]
  [Core Struct]
  [Effect Trait]
  [Capabilities]
  [Command]
  [Bridge]
}

rectangle "Utilities" as Utils {
  [crux_http]
  [crux_time]
}

rectangle "Shell (Platform-Specific)" as Shell {
  [iOS (Swift)]
  [Android (Kotlin)]
  [Web (TypeScript)]
}

rectangle "Testing" as Testing {
  [AppTester]
  [FakeShell]
}

cloud "External Services" as External {
  [HTTP APIs]
  [Time Services]
}

Core --> Utils : uses
Core <--> Shell : Bridge communication
Core --> Testing : enables
Utils --> External : interacts with
Shell --> External : renders UI, handles I/O

note right of Core
  - Event Sourcing
  - Model-View-Update (MVU)
  - Pure business logic
end note

note bottom of Shell
  - Platform-specific UI
  - Executes side effects
  - Translates UI events to Core events
end note

note left of Utils
  - HTTP requests
  - Time operations
end note

note top of Testing
  - Unit tests
  - Effect inspection
end note

@enduml