@startuml OpiumProtocol_opium-protocol-v2

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

actor User
actor "Protocol Admin" as Admin

rectangle "Registry" {
  [AccessControl]
  [ContractAddresses]
  [ProtocolParameters]
}

rectangle "Core" {
  [CreatePositions]
  [HoldMargin]
  [DistributePayouts]
}

rectangle "SyntheticAggregator" {
  [CacheDerivativeData]
  [CalculateMargin]
  [DeterminePayouts]
}

rectangle "OracleAggregator" {
  [FetchOracleData]
  [CacheOracleData]
}

rectangle "OpiumProxyFactory" {
  [DeployPositionTokens]
}

rectangle "TokenSpender" {
  [ManageAllowances]
  [ExecuteTransfers]
}

User --> [CreatePositions] : Create derivative
User --> [HoldMargin] : Deposit margin
Admin --> [AccessControl] : Manage roles
Admin --> [ProtocolParameters] : Update parameters

[CreatePositions] --> [CacheDerivativeData] : Get derivative info
[CreatePositions] --> [DeployPositionTokens] : Create ERC20 tokens
[DistributePayouts] --> [FetchOracleData] : Get settlement data
[DistributePayouts] --> [DeterminePayouts] : Calculate payouts
[HoldMargin] --> [CalculateMargin] : Determine required margin
[CreatePositions] --> [ManageAllowances] : Approve token transfers
[HoldMargin] --> [ExecuteTransfers] : Transfer margin tokens

[Core] --> [ContractAddresses] : Get contract addresses
[SyntheticAggregator] --> [ContractAddresses] : Get contract addresses
[OracleAggregator] --> [ContractAddresses] : Get contract addresses
[TokenSpender] --> [ContractAddresses] : Get contract addresses

@enduml