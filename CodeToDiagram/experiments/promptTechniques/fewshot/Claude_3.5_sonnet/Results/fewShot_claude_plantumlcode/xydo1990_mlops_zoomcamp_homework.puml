@startuml xydo1990_mlops_zoomcamp_homework

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  Style roundrect
}

actor User

rectangle "Data Preparation" {
  [get_data.py] as GetData
  [data_feeling.ipynb] as DataExplore
}

rectangle "Model Training" {
  [train_model.py] as TrainModel
}

rectangle "MLflow" {
  [Experiment Tracking] as MLflowTrack
  [Model Registry] as MLflowRegistry
}

rectangle "Deployment" {
  [Docker] as DockerDeploy
}

rectangle "Prediction Services" {
  [Batch Prediction] as BatchPred
  [Stream Prediction] as StreamPred
}

rectangle "Workflow Orchestration" {
  [Prefect] as PrefectFlow
}

rectangle "Monitoring" {
  [Evidently] as Evidently
}

rectangle "CI/CD" {
  [GitHub Actions] as GithubActions
}

User --> GetData : Initiates
GetData --> DataExplore : Provides data
DataExplore --> TrainModel : Informs

TrainModel --> MLflowTrack : Logs experiments
MLflowTrack --> MLflowRegistry : Registers model

MLflowRegistry --> DockerDeploy : Deploys model
DockerDeploy --> BatchPred : Configures
DockerDeploy --> StreamPred : Configures

PrefectFlow --> BatchPred : Orchestrates
User --> StreamPred : Sends requests

BatchPred --> Evidently : Sends metrics
StreamPred --> Evidently : Sends metrics

GithubActions --> DockerDeploy : Triggers deployment
GithubActions --> TrainModel : Runs tests

@enduml