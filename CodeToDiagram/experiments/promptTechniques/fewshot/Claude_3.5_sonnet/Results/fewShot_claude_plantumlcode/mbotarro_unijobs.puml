@startuml mbotarro_unijobs

skinparam component {
  BackgroundColor LightSkyBlue
  BorderColor Black
}

skinparam database {
  BackgroundColor PaleGreen
  BorderColor Black
}

skinparam rectangle {
  BackgroundColor LightYellow
  BorderColor Black
}

package "Frontend (React Native)" {
  [App.js] as App
  [AppNavigator] as AppNav
  [FeedNavigator] as FeedNav
  [Screens] as Screens
  [Components] as Components
  [Constants] as Constants
  [Actions] as Actions
}

package "Backend (Go)" {
  [main.go] as Main
  [Handlers] as Handlers
  [Use Cases] as UseCases
  [DAL] as DAL
  [Models] as Models
}

database "PostgreSQL" as PostgreSQL
database "Elasticsearch" as Elasticsearch

rectangle "Docker" as Docker

App --> AppNav
App --> FeedNav
AppNav --> Screens
FeedNav --> Screens
Screens --> Components
Screens --> Constants
Screens --> Actions

Actions --> Main : API Calls

Main --> Handlers
Handlers --> UseCases
UseCases --> DAL
DAL --> Models
DAL --> PostgreSQL
UseCases --> Elasticsearch

Docker --> PostgreSQL : Manages
Docker --> Elasticsearch : Manages

@enduml