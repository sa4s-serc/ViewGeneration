@startuml
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

package "Factom Harmony Connect API Python SDK" {
  [FactomClient] as FC
  
  package "Resource Clients" {
    [ChainsClient]
    [EntriesClient]
    [IdentitiesClient]
    [ApiInfoClient]
    [ReceiptsClient]
    [AnchorsClient]
  }
  
  package "Utilities" {
    [Utils]
    [KeyCommon]
    [ValidateSignatureUtil]
    [CommonUtil]
  }
  
  [RequestHandler]
}

[Sample Application\n(simulate_notary.py)] as SampleApp

cloud "Factom Harmony\nConnect API" as API

FC --> ChainsClient
FC --> EntriesClient
FC --> IdentitiesClient
FC --> ApiInfoClient
FC --> ReceiptsClient
FC --> AnchorsClient

ChainsClient --> RequestHandler
EntriesClient --> RequestHandler
IdentitiesClient --> RequestHandler
ApiInfoClient --> RequestHandler
ReceiptsClient --> RequestHandler
AnchorsClient --> RequestHandler

RequestHandler --> API

ChainsClient ..> Utils
EntriesClient ..> Utils
IdentitiesClient ..> Utils
ChainsClient ..> KeyCommon
EntriesClient ..> KeyCommon
IdentitiesClient ..> KeyCommon
ChainsClient ..> ValidateSignatureUtil
EntriesClient ..> ValidateSignatureUtil
RequestHandler ..> CommonUtil

SampleApp --> FC

@enduml