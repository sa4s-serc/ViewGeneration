@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam ArrowColor Black
skinparam defaultTextAlignment center

actor User

rectangle "Android App" as AndroidApp {
  [MainActivity]
  [BotManager]
  [DialogManager]
  [RecordingManager]
  [Provider Classes]
}

cloud "Google Cloud" {
  [Speech-to-Text API]
  [Text-to-Speech API]
}

rectangle "Main Server" as MainServer {
  [Flask App]
  [Intent Classifier]
  [Speech Processing]
  [Task Execution]
}

rectangle "NER Server" as NERServer {
  [NER Model]
}

database "Device Storage" as DeviceStorage

User -> AndroidApp : Voice/Text Input
AndroidApp -> [RecordingManager] : Record Audio
[RecordingManager] -> [Speech-to-Text API] : Send Audio
[Speech-to-Text API] -> MainServer : Transcribed Text
AndroidApp -> MainServer : Send Text Command
MainServer -> [Intent Classifier] : Classify Intent
[Intent Classifier] -> NERServer : Extract Entities
NERServer --> MainServer : Named Entities
MainServer -> [Task Execution] : Execute Intent
[Task Execution] -> [Provider Classes] : Perform Action
[Provider Classes] <-> DeviceStorage : Read/Write Data
MainServer -> [Text-to-Speech API] : Generate Speech
[Text-to-Speech API] -> AndroidApp : Audio Response
AndroidApp -> User : Display/Play Response

@enduml