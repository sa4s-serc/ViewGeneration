@startuml takoko55_LectureLens

skinparam componentStyle rectangle
skinparam defaultTextAlignment center

package "Frontend (React)" {
  [App.jsx] as App
  [SyllabusSearch.jsx] as Search
  [GlassCard.jsx] as Card
  [LecturePage.jsx] as LecturePage
  [ReviewItem.jsx] as ReviewItem
  [Auth.jsx] as Auth
  [ReviewPost.jsx] as ReviewPost
  [React Query Hooks] as ReactQuery
  [Zustand Store] as Zustand
}

package "Backend (Go)" {
  [main.go] as Main
  [router.go] as Router
  [controller] as Controller
  [usecase] as Usecase
  [repository] as Repository
  [model] as Model
  [db.go] as DB
  [migrate.go] as Migrate
}

database "PostgreSQL" as PostgreSQL

App --> Search
App --> LecturePage
App --> Auth
App --> ReviewPost
Search --> Card
LecturePage --> ReviewItem
ReviewPost --> ReactQuery
Auth --> ReactQuery
ReactQuery --> Zustand

Main --> Router
Router --> Controller
Controller --> Usecase
Usecase --> Repository
Repository --> Model
Repository --> DB
DB --> PostgreSQL
Migrate --> PostgreSQL

Frontend <--> Backend : REST API

@enduml