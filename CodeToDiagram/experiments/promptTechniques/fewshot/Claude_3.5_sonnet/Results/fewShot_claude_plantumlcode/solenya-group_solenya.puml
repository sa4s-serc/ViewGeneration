@startuml solenya-group_solenya

skinparam componentStyle rectangle
skinparam defaultTextAlignment center

actor User

rectangle "App" {
  [Router]
  [TimeTravel]
  [Storage]
}

rectangle "Component" {
  [State]
  [View Function]
  [Update Method]
}

rectangle "Validation" {
  [Validator]
}

rectangle "Virtual DOM" {
  [DOM Patching]
}

rectangle "Styling" {
  [Typestyle]
}

database "Local Storage" as LocalStorage

User --> [Router] : Interacts
[Router] --> [Component] : Routes to
[Component] --> [State] : Manages
[State] --> [View Function] : Renders
[View Function] --> [Virtual DOM] : Creates
[Virtual DOM] --> [DOM Patching] : Updates
[DOM Patching] --> User : Displays

[Component] --> [Update Method] : Triggers
[Update Method] --> [State] : Modifies

[Component] <--> [Validator] : Validates input

[App] --> [TimeTravel] : Manages
[TimeTravel] --> [State] : Records/Restores

[App] --> [Storage] : Uses
[Storage] <--> LocalStorage : Persists/Retrieves

[View Function] --> [Styling] : Applies

@enduml