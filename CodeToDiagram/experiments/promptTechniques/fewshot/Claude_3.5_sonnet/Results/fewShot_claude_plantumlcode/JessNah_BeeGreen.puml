@startuml JessNah_BeeGreen

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

actor User

rectangle "Chrome Extension" {
  [background.ts]
  [contentScript.tsx]
  [popup.tsx]
  [storesCommon.js]
  [storage.ts]
}

rectangle "Client Website (React)" {
  [App.js]
  [BeeGreen.js]
  [HomePage.js]
  [DashBoard.js]
  [Contribute.js]
}

rectangle "Server (LoopBack 4)" {
  [application.ts]
  [index.ts]
  [dataprocessing.ts]
  database "IBM Cloudant DB" as DB
}

User --> [background.ts] : Opens e-commerce site
[background.ts] --> [contentScript.tsx] : Injects
[contentScript.tsx] --> [storesCommon.js] : Extracts cart data
[storesCommon.js] --> [popup.tsx] : Provides data
[popup.tsx] --> [storage.ts] : Stores/retrieves data

User --> [App.js] : Visits website
[App.js] --> [BeeGreen.js] : Routes
[BeeGreen.js] --> [HomePage.js] : Renders
[HomePage.js] --> [DashBoard.js] : Shows if logged in
[HomePage.js] --> [Contribute.js] : User contributes data

[popup.tsx] --> [index.ts] : API requests
[Contribute.js] --> [index.ts] : API requests
[index.ts] --> [application.ts] : Processes request
[application.ts] --> [dataprocessing.ts] : Processes data
[dataprocessing.ts] <--> DB : Stores/retrieves data

@enduml