@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as user

rectangle "Android UI" as ui {
  [GpsMainActivity]
  [MainPreferenceActivity]
  [BigViewActivity]
}

rectangle "Core Services" as core {
  [GpsLoggingService]
  [GeneralLocationListener]
}

rectangle "Data Management" as data {
  [FileLoggerFactory]
  [FileLogger]
}

rectangle "Configuration" as config {
  [PreferenceHelper]
  [AppSettings]
}

rectangle "Upload Services" as upload {
  [WorkManager]
  [FileSender]
}

cloud "External Services" as external {
  [OpenStreetMap]
  [Google Drive]
  [Dropbox]
  [SFTP/FTP]
  [Custom URLs]
}

database "Device Storage" as storage

user --> ui
ui --> core
core --> data
core --> config
core --> upload
data --> storage
upload --> external
config --> storage

@enduml