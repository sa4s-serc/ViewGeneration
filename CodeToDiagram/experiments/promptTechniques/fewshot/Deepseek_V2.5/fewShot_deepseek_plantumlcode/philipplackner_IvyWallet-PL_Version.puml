@startuml philipplackner_IvyWallet-PL_Version
left to right direction
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<design>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "UI Layer" <<ui>> {
  [Home Screen] as Home
  [Transaction Screen] as TrnsScreen
  [Account Screen] as AccountScreen
  [Category Screen] as CategoryScreen
  [Backup Screen] as BackupScreen
  [Sync Screen] as SyncScreen
  [Formula Screen] as FormulaScreen
}

package "Design System" <<design>> {
  [IvyTheme] as Theme
  [Custom Components] as Components
  [Color Palette] as Colors
  [Typography] as Typography
}

package "Domain Layer" <<domain>> {
  [TrnsFlow] as TrnsFlow
  [WriteTrnsAct] as WriteTrns
  [WriteAccountsAct] as WriteAccounts
  [FormulaFlow] as FormulaFlow
  [SyncAct] as SyncAct
  [BackupDataAct] as BackupAct
  [ImportBackupDataAct] as ImportAct
  [RatesStateFlow] as RatesFlow
}

package "Data Layer" <<data>> {
  [Transaction Repo] as TrnsRepo
  [Account Repo] as AccountRepo
  [Category Repo] as CategoryRepo
  [Exchange Rates Repo] as RatesRepo
  [Backup Repo] as BackupRepo
  [Sync Repo] as SyncRepo
}

package "External Services" <<external>> {
  [Google Drive] as Drive
  [Exchange Rate API] as RateAPI
  [File System] as FileSystem
}

Home --> TrnsFlow
TrnsScreen --> WriteTrns
AccountScreen --> WriteAccounts
FormulaScreen --> FormulaFlow
SyncScreen --> SyncAct
BackupScreen --> BackupAct
BackupScreen --> ImportAct

Theme --> Home
Theme --> TrnsScreen
Theme --> AccountScreen
Theme --> CategoryScreen
Components --> Home
Components --> TrnsScreen

TrnsFlow --> TrnsRepo
WriteTrns --> TrnsRepo
WriteAccounts --> AccountRepo
FormulaFlow --> TrnsRepo
SyncAct --> SyncRepo
BackupAct --> BackupRepo
ImportAct --> BackupRepo
RatesFlow --> RatesRepo

SyncRepo --> Drive
RatesRepo --> RateAPI
BackupRepo --> FileSystem
@enduml