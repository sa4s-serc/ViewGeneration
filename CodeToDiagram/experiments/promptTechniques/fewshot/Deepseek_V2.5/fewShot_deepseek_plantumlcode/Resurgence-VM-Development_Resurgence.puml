### Actual Output:
@startuml Resurgence-VM-Development_Resurgence
left to right direction
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<data>> #d8f5d3
  BackgroundColor<<ffi>> #fddddd
  BackgroundColor<<util>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core VM" <<core>> {
  rectangle "Interpreter" as Interpreter
  rectangle "Execution Engine" as ExecutionEngine
  rectangle "Memory Manager" as Memory
  rectangle "Instruction Set" as InstructionSet
  rectangle "Bytecode Reader/Writer" as BytecodeIO
}

package "Data Structures" <<data>> {
  rectangle "CodeHolder" as CodeHolder
  rectangle "Instruction" as Instruction
  rectangle "Constant Pool" as ConstantPool
  rectangle "Stack Frames" as StackFrames
  rectangle "Registers" as Registers
}

package "FFI Interface" <<ffi>> {
  rectangle "C Header (resurgence.h)" as CHeader
  rectangle "FFI Implementation" as FFIImpl
  rectangle "External Function Registry" as ExtFuncReg
}

package "Utilities" <<util>> {
  rectangle "Error Handling" as ErrorHandling
  rectangle "Code Generation" as CodeGen
  rectangle "CI/CD Workflows" as CI
}

Interpreter --> ExecutionEngine
ExecutionEngine --> Memory
ExecutionEngine --> InstructionSet
BytecodeIO --> CodeHolder
CodeHolder --> Instruction
Memory --> ConstantPool
Memory --> StackFrames
Memory --> Registers

FFIImpl --> CHeader
FFIImpl --> ExtFuncReg
ExtFuncReg --> Interpreter
FFIImpl --> Memory

ErrorHandling --> Interpreter
CodeGen --> BytecodeIO
CI --> ExecutionEngine
@enduml