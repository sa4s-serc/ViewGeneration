@startuml mebaysan_Modern-Data-Architecture
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Kaggle CSV Files" as csv

rectangle "Airbyte" as airbyte {
  rectangle "Extractor" as extractor
  rectangle "Loader" as loader
}

rectangle "Python Script" as python

rectangle "PostgreSQL" as postgres {
  rectangle "Raw Data" as raw
  rectangle "Transformed Data" as transformed
}

rectangle "DBT" as dbt {
  rectangle "Models" as models
  rectangle "Transformations" as transforms
}

rectangle "Apache Superset" as superset {
  rectangle "Dashboards" as dash
  rectangle "Visualizations" as viz
}

rectangle "pgAdmin" as pgadmin

rectangle "Nginx" as nginx

csv --> extractor
extractor --> loader
loader --> raw

csv --> python
python --> raw

raw --> models
models --> transforms
transforms --> transformed

transformed --> dash
transformed --> viz

postgres --> pgadmin
pgadmin --> nginx

note right of airbyte
  Primary extraction method
end note

note right of python
  Alternative extraction method
end note

note right of dbt
  Git submodule
end note

note right of superset
  Git submodule
end note
@enduml