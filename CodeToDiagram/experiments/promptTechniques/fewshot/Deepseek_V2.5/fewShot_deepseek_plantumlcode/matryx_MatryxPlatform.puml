@startuml matryx_MatryxPlatform
left to right direction
skinparam rectangle {
  BackgroundColor<<contract>> #d9e7fd
  BackgroundColor<<library>> #d8f5d3
  BackgroundColor<<ui>> #fff1c9
  BackgroundColor<<token>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Smart Contract Layer" {
  component "MatryxPlatform.sol" <<contract>> as Platform
  component "MatryxSystem.sol" <<contract>> as System
  component "MatryxForwarder.sol" <<contract>> as Forwarder
  component "MatryxToken.sol" <<token>> as Token

  rectangle "Libraries" <<library>> {
    component "LibPlatform.sol" as LibPlatform
    component "LibCommit.sol" as LibCommit
    component "LibTournament.sol" as LibTournament
  }

  Platform --> Forwarder : inherits
  Platform --> System : version mgmt
  Platform ..> LibPlatform : delegatecall
  Platform ..> LibCommit : delegatecall
  Platform ..> LibTournament : delegatecall
  Platform --> Token : uses
}

package "JavaScript Layer" {
  component "utils.js" <<ui>> as Utils
  component "test.js" <<ui>> as Tests
  component "benchmark.js" <<ui>> as Benchmark
  component "network.js" <<ui>> as Network

  Utils --> Platform : interacts
  Tests --> Utils : uses
  Benchmark --> Utils : uses
  Network --> Utils : configures
}

package "Documentation" {
  component "index.rst" <<ui>> as Docs
  component "searchtools.js" <<ui>> as Search

  Docs --> Search : uses
}

package "Users" {
  actor "Researchers"
  actor "Tournament Creators"
  actor "Reviewers"

  Researchers --> Platform : create commits\nparticipate
  Tournament Creators --> Platform : create tournaments
  Reviewers --> Platform : vote submissions
}

note right of Platform
  Core functionality:
  - Tournament management
  - Commit chains
  - Forking system
  - Group collaboration
  - Reputation tracking
end note
@enduml