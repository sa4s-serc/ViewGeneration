@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Agent (Java)" {
  rectangle "SystemInfo" as SystemInfo #lightblue
  rectangle "TCPServer" as TCPServer #lightblue
  SystemInfo --> TCPServer : Collects system data
}

package "Logstash" {
  rectangle "TCP Input" as LogstashTCP #orange
  rectangle "JSON Codec" as LogstashJSON #orange
  rectangle "Elasticsearch Output" as LogstashES #orange
  LogstashTCP --> LogstashJSON : Receives data
  LogstashJSON --> LogstashES : Processes data
}

database "Elasticsearch" as ES #pink

rectangle "Kibana" as Kibana #green

TCPServer --> LogstashTCP : Sends data via TCP
LogstashES --> ES : Stores indexed data
ES --> Kibana : Provides data for visualization

note right of SystemInfo
  Collects:
  - CPU load
  - Memory usage
  - Computer name
  - IP address
end note

note right of LogstashJSON
  Enriches with:
  - Timestamps
  - Metadata
end note
@enduml