@startuml geovanegodoi_MicroServicesPOC
left to right direction
skinparam rectangle {
  BackgroundColor<<service>> #d9e7fd
  BackgroundColor<<queue>> #d8f5d3
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<infra>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Microservices" {
  rectangle "Catalog Service" <<service>> as Catalog
  rectangle "Customer Service" <<service>> as Customer
  rectangle "Order Service" <<service>> as Order
}

package "Message Broker" <<queue>> {
  rectangle "RabbitMQ" as RabbitMQ
}

package "Databases" <<db>> {
  database "Catalog DB\n(MongoDB)" as CatalogDB
  database "Customer DB\n(MongoDB)" as CustomerDB
  database "Order DB\n(MongoDB)" as OrderDB
}

package "Infrastructure" <<infra>> {
  rectangle "Docker" as Docker
  rectangle "GitHub Actions" as GitHubActions
}

Catalog --> RabbitMQ : Publishes\nCatalogItemCreated
Catalog --> RabbitMQ : Publishes\nCatalogItemUpdated
Catalog --> RabbitMQ : Publishes\nCatalogItemRemoved

Customer --> RabbitMQ : Publishes\nCustomerCreated
Customer --> RabbitMQ : Publishes\nCustomerUpdated
Customer --> RabbitMQ : Publishes\nCustomerRemoved

Order --> RabbitMQ : Publishes\nOrderCreated
Order --> RabbitMQ : Publishes\nOrderUpdated
Order --> RabbitMQ : Publishes\nOrderRemoved

RabbitMQ --> Customer : Consumes\nOrder events
RabbitMQ --> Order : Consumes\nCustomer events
RabbitMQ --> Order : Consumes\nCatalog events

Catalog --> CatalogDB
Customer --> CustomerDB
Order --> OrderDB

Docker --> Catalog
Docker --> Customer
Docker --> Order
Docker --> RabbitMQ
Docker --> CatalogDB
Docker --> CustomerDB
Docker --> OrderDB

GitHubActions --> Docker : Builds & deploys
@enduml