### Actual Output:
@startuml
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<integration>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

package "Frontend" <<frontend>> {
  rectangle "Markdown Editor\n(CodeMirror 2)" as Editor
  rectangle "UI Components\n(Jade Templates)" as UI
  rectangle "Client-side Logic\n(jQuery, Underscore)" as ClientLogic
  rectangle "Real-time Updates\n(Socket.IO Client)" as SocketClient
  Editor --> UI
  ClientLogic --> UI
  ClientLogic --> SocketClient
}

package "Backend" <<backend>> {
  rectangle "Express Server" as Express
  rectangle "Wiki Module" as Wiki
  rectangle "User Module" as User
  rectangle "File Module" as File
  rectangle "Admin Module" as Admin
  rectangle "Localization" as I18n
  rectangle "Middleware\n(Sessions, Auth)" as Middleware
  Express --> Wiki
  Express --> User
  Express --> File
  Express --> Admin
  Express --> I18n
  Express --> Middleware
}

package "Data Storage" <<storage>> {
  database "Git Repository" as Git
}

package "Integrations" <<integration>> {
  rectangle "Email Service" as Email
  rectangle "Socket.IO Server" as SocketServer
}

Express --> SocketServer
SocketServer --> SocketClient
Wiki --> Git
User --> Git
File --> Git
Admin --> Email

note right of Git
  Version-controlled
  data persistence
end note
@enduml