@startuml laziestcoder_Budget_App_JS
skinparam backgroundColor #f0f0f0
skinparam defaultTextAlignment center
left to right direction

actor "User" as user

rectangle "UI Layer" {
    component "HTML/CSS" as html
    component "Event Listeners" as events
}

rectangle "Controller" {
    component "Main Controller" as controller
}

rectangle "Model" {
    component "Budget Controller" as budgetController
}

rectangle "View" {
    component "UI Controller" as uiController
}

database "Browser Memory" as memory

user --> html : Interacts with\n(input/buttons)
html --> events : Triggers
events --> controller : Calls handlers
controller --> budgetController : Updates data\n(income/expenses)
budgetController --> memory : Stores data
budgetController --> controller : Returns\ncalculated values
controller --> uiController : Requests UI updates
uiController --> html : Updates DOM

note right of budgetController
    - Manages income/expense data
    - Calculates budget/percentages
end note

note right of uiController
    - Updates UI elements
    - Clears input fields
    - Displays budget info
end note

note right of controller
    - Mediates between Model/View
    - Handles event callbacks
end note
@enduml