@startuml thill_kafkacap
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Message Sources" {
  rectangle "Aeron" as aeron
  rectangle "Multicast" as multicast
  rectangle "Websocket" as websocket
}

package "Capture Devices" {
  rectangle "AeronCaptureDevice" as aeron_capture
  rectangle "MulticastCaptureDevice" as multicast_capture
  rectangle "WebsocketCaptureDevice" as websocket_capture
}

package "Kafka Topics" {
  rectangle "Aeron Topic" as aeron_topic
  rectangle "Multicast Topic" as multicast_topic
  rectangle "Websocket Topic" as websocket_topic
}

package "Deduplication" {
  rectangle "Deduplicator" as deduplicator
  rectangle "DedupStrategy" as dedup_strategy
  rectangle "CaptureQueue" as capture_queue
}

package "Output" {
  rectangle "Outbound Kafka Topic" as outbound_topic
}

aeron --> aeron_capture
multicast --> multicast_capture
websocket --> websocket_capture

aeron_capture --> aeron_topic
multicast_capture --> multicast_topic
websocket_capture --> websocket_topic

aeron_topic --> deduplicator
multicast_topic --> deduplicator
websocket_topic --> deduplicator

deduplicator --> dedup_strategy
deduplicator --> capture_queue
deduplicator --> outbound_topic

note right of deduplicator
  Uses Kafka Consumer Group
  for fault tolerance
end note

note right of capture_queue
  Memory or Chronicle-Queue
  based implementation
end note
@enduml