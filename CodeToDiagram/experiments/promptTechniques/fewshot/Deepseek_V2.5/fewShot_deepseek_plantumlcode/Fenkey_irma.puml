### Output:
@startuml Fenkey_irma
left to right direction
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<framework>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Engine (irmacall)" <<core>> {
  rectangle "Multi-threaded\nRequest Handler" as RequestHandler
  rectangle "FastCGI\nInterface" as FastCGI
  rectangle "HTTP Client\n(Fetcher)" as Fetcher
  rectangle "Logging\nSystem" as Logging
  rectangle "SMTP\nSupport" as SMTP
  rectangle "Cryptography\n(OpenSSL)" as Crypto
  rectangle "Circuit Breaker\n(Fuse)" as Fuse
  rectangle "Buffer Pool\nManagement" as BufferPool
  rectangle "Async DNS\n(c-ares)" as DNS

  RequestHandler --> FastCGI
  RequestHandler --> Fetcher
  RequestHandler --> Logging
  RequestHandler --> SMTP
  RequestHandler --> Crypto
  RequestHandler --> Fuse
  RequestHandler --> BufferPool
  RequestHandler --> DNS
}

package "Framework (irmakit)" <<framework>> {
  rectangle "Configuration\nSystem" as Config
  rectangle "Session\nManagement" as Session
  rectangle "Request/Response\nHandling" as ReqRes
  rectangle "Attribute-Based\nRouting" as Routing
  rectangle "Template Engine\n(NVelocity)" as Templates
  rectangle "Utilities\n(Encryption, QR etc)" as Utils
  rectangle "Code\nGenerator" as CodeGen

  Config --> Session
  Config --> ReqRes
  ReqRes --> Routing
  Routing --> Templates
  Utils --> ReqRes
  CodeGen --> Config
}

package "Storage Backends" <<storage>> {
  database "Memcached" as Memcached
  database "Redis" as Redis
}

package "External Services" <<external>> {
  rectangle "Web Server\n(Nginx/Apache)" as WebServer
  rectangle "Email Server" as Email
  rectangle "External APIs" as APIs
}

WebServer --> FastCGI
Fetcher --> APIs
SMTP --> Email
Session --> Memcached
Session --> Redis
@enduml