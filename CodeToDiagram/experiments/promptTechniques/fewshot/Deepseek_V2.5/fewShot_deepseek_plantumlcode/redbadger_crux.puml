@startuml redbadger_crux
left to right direction
skinparam rectangle {
  BackgroundColor<<core>> #d8f5d3
  BackgroundColor<<shell>> #d9e7fd
  BackgroundColor<<capability>> #fff1c9
  BackgroundColor<<ffi>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core (Rust)" <<core>> {
  rectangle "App Trait" as App
  rectangle "Core Struct" as Core
  rectangle "Effect Trait" as Effect
  rectangle "Command" as Command
  rectangle "Bridge" as Bridge
  rectangle "Model" as Model
  rectangle "ViewModel" as ViewModel

  App --> Core
  Core --> Effect
  Core --> Command
  Core --> Bridge
  Core --> Model
  Core --> ViewModel
}

package "Capabilities" <<capability>> {
  rectangle "Http" as Http
  rectangle "Time" as Time
  rectangle "KeyValue" as KeyValue
  rectangle "Render" as Render

  Command --> Http
  Command --> Time
  Command --> KeyValue
  Command --> Render
}

package "Shells" <<shell>> {
  rectangle "iOS (Swift)" as IOS
  rectangle "Android (Kotlin)" as Android
  rectangle "Web (TypeScript)" as Web

  Bridge --> IOS
  Bridge --> Android
  Bridge --> Web
}

package "FFI Boundary" <<ffi>> {
  rectangle "Serialization/\nDeserialization" as Serde
  rectangle "Type Generation" as TypeGen

  Bridge --> Serde
  Serde --> TypeGen
  TypeGen --> IOS
  TypeGen --> Android
  TypeGen --> Web
}

Http --> "HTTP Client" as HttpClient
Time --> "Timer Service" as TimerService
KeyValue --> "Storage" as Storage
Render --> "UI Framework" as UIFramework

IOS --> "SwiftUI"
Android --> "Jetpack Compose"
Web --> "React/Leptos/Yew"

note right of Core
  Update Loop:
  1. Handle Events
  2. Mutate Model
  3. Request Effects
end note

note left of Bridge
  Message-Based Communication
  using serialized types
end note
@enduml