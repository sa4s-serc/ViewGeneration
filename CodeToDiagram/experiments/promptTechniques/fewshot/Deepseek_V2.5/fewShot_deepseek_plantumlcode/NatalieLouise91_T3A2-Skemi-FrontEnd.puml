@startuml NatalieLouise91_T3A2-Skemi-FrontEnd
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<state>> #fff1c9
  BackgroundColor<<api>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "App.js" as App
  rectangle "Nav.js" as Nav
  rectangle "Login.js" as Login
  rectangle "NewUser.js" as NewUser
  rectangle "Occasion/\nComponents" as Occasion
  rectangle "Roster/\nComponents" as Roster
}

package "State Management" <<state>> {
  rectangle "stateContext.js" as Context
  rectangle "stateReducer.js" as Reducer
}

package "Services" <<api>> {
  rectangle "authServices.js" as Auth
  rectangle "occasionServices.js" as OccasionService
  rectangle "rosterServices.js" as RosterService
  rectangle "userServices.js" as UserService
  rectangle "api.js" as ApiConfig
}

database "Rails API\nBackend" as RailsBackend

App --> Nav
App --> Login
App --> NewUser
App --> Occasion
App --> Roster

App --> Context
Context --> Reducer

Login --> Auth
NewUser --> Auth
Occasion --> OccasionService
Roster --> RosterService
Nav --> UserService

Auth --> ApiConfig
OccasionService --> ApiConfig
RosterService --> ApiConfig
UserService --> ApiConfig

ApiConfig --> RailsBackend
@enduml