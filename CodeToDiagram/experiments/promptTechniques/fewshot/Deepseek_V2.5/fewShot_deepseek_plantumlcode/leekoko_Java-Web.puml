@startuml leekoko_Java-Web
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<framework>> #f0d9ff
  Style roundrect
}

actor User

package "Frontend" <<frontend>> {
  rectangle "HTML/CSS" as HTML
  rectangle "JavaScript/jQuery" as JS
  rectangle "AJAX Calls" as AJAX
  HTML --> JS
  JS --> AJAX
}

package "Backend" <<backend>> {
  rectangle "Servlets" as Servlets
  rectangle "Spring Boot" as Spring
  rectangle "Business Logic" as Logic
  rectangle "API Integration" as API
  Servlets --> Logic
  Spring --> Logic
  Logic --> API
}

package "Frameworks" <<framework>> {
  rectangle "Dubbo RPC" as Dubbo
  rectangle "Tomcat" as Tomcat
  rectangle "Shiro Security" as Shiro
}

package "Data Storage" <<db>> {
  database "MySQL" as MySQL
  database "Redis" as Redis
}

package "External Services" <<integration>> {
  rectangle "Baidu Translate API" as Baidu
  rectangle "OAuth2 Providers" as OAuth
}

User --> HTML
AJAX --> Servlets
AJAX --> Spring

Servlets --> Tomcat
Spring --> Tomcat

Logic --> Dubbo
Dubbo --> MySQL
Dubbo --> Redis

API --> Baidu

Shiro --> OAuth
Spring --> Shiro
Tomcat --> Shiro

@enduml