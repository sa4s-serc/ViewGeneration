### Output:
@startuml mrubash1_trainspotting
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Raspberry Pi" as RPi {
  rectangle "Video Camera" as Camera
  rectangle "Video Capture" as Capture
  rectangle "Image Processing" as Processing
  rectangle "Motion Detection" as Motion
  rectangle "Train Classification" as Classification
  rectangle "Direction Analysis" as Direction
  rectangle "Data Storage" as Storage
}

rectangle "Cloud Services" as Cloud {
  rectangle "TensorFlow Model" as TFModel
  rectangle "Data Persistence" as Persistence
}

rectangle "User Interface" as UI {
  rectangle "Jupyter Notebook" as Notebook
  rectangle "Visualization" as Viz
}

Camera --> Capture
Capture --> Processing : Raw Frames
Processing --> Motion : Processed Frames
Motion --> Classification : Motion Events
Classification --> Direction : Classification Results
Direction --> Storage : Direction Data

Processing --> TFModel : Model Inference
Classification --> TFModel : Classification Request
Storage --> Persistence : Sync Data

Notebook --> RPi : Control/Configure
RPi --> Viz : Detection Results
Storage --> Viz : Historical Data

note right of Processing
  Background Subtraction (KNN/MOG2)
  ROI Extraction
end note

note right of Classification
  Pre-trained TensorFlow Model
  Classifies: Trains/Cars/Trucks
end note

note right of Direction
  Analyzes motion sequence
  Determines North/South direction
end note
@enduml