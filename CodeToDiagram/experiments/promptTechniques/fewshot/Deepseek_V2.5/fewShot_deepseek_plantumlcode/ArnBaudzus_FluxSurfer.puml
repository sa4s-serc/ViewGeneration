### Actual Output:
@startuml ArnBaudzus_FluxSurfer
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<solver>> #d8f5d3
  BackgroundColor<<parallel>> #fff1c9
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<util>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

package "Core Components" <<core>> {
  class QuantumSystem {
    - states: State[]
    - edges: Edge[]
    + saveToGraphML()
  }

  class State {
    - id
    - occupation
  }

  class Edge {
    - source
    - target
    - weight
  }
}

package "Solvers" <<solver>> {
  abstract class Solver {
    {abstract} + solve()
  }

  class SingleStepScheme {
    + step()
  }

  class EulerForward
  class RichardsonSolver
  class MonteCarloWanderer

  Solver <|-- SingleStepODESolver
  SingleStepODESolver *-- SingleStepScheme
  SingleStepScheme <|-- EulerForward
  SingleStepScheme <|-- RichardsonSolver
  Solver <|-- MonteCarloWanderer
}

package "Parallel Processing" <<parallel>> {
  class Experiment {
    - workQueue: WorkSource
    - mutex
    + runParallel()
  }

  class WorkSource {
    - queue
    + getNext()
  }
}

package "Data Storage" <<data>> {
  class GraphMLWriter
  class MetadataJSON
  class MetadataCSV

  QuantumSystem --> GraphMLWriter
  Experiment --> MetadataJSON
  Experiment --> MetadataCSV
}

package "Utilities" <<util>> {
  class BinaryNumberUtils
  class XMLParser
  class PlotTools
  class PhysicalFormulas
}

QuantumSystem --> Solver
Experiment --> QuantumSystem
Experiment --> Solver
@enduml