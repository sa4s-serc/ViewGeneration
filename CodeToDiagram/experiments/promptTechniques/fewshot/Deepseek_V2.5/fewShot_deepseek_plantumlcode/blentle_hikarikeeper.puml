@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Clients" {
  rectangle "HikariKeeper Client" as client
  rectangle "Spring Boot App" as springboot
}

package "HikariKeeper Cluster" {
  rectangle "Leader Node" as leader #lightgreen
  rectangle "Follower Node 1" as follower1
  rectangle "Follower Node 2" as follower2
  rectangle "Follower Node N" as followerN
}

package "Storage" {
  database "RocksDB" as rocksdb
}

client --> leader : RPC Requests
springboot --> leader : RPC Requests

leader --> follower1 : AppendEntries RPC
leader --> follower2 : AppendEntries RPC
leader --> followerN : AppendEntries RPC

follower1 --> leader : Vote Requests
follower2 --> leader : Vote Requests
followerN --> leader : Vote Requests

leader --> rocksdb : Read/Write
follower1 --> rocksdb : Read/Write
follower2 --> rocksdb : Read/Write
followerN --> rocksdb : Read/Write

note right of leader
  Implements Raft Consensus:
  - Leader election
  - Log replication
  - State persistence
end note

note right of rocksdb
  Hierarchical metadata storage
  with strong consistency
end note
@enduml