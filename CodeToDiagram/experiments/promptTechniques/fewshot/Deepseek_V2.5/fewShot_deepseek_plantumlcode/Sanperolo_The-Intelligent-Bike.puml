@startuml Sanperolo_The-Intelligent-Bike
left to right direction
skinparam rectangle {
  BackgroundColor<<sensor>> #d9e7fd
  BackgroundColor<<mqtt>> #d8f5d3
  BackgroundColor<<backend>> #fff1c9
  BackgroundColor<<frontend>> #fddddd
  BackgroundColor<<db>> #d4f0f0
  Style roundrect
}

package "Sensors" <<sensor>> {
  rectangle "Velocity Sensor" as Velocity
  rectangle "Humidity/Temp Sensor" as Humidity
  rectangle "GPS" as GPS
  rectangle "Gyroscope" as Gyro
  rectangle "Light Sensor" as Light
  rectangle "Rain Sensor" as Rain
}

rectangle "MQTT Broker" <<mqtt>> as MQTT

package "Backend" <<backend>> {
  rectangle "Django API" as Django
  rectangle "MQTT Subscriber" as Subscriber
  Django --> Subscriber
}

package "Database" <<db>> {
  database "PostgreSQL" as Postgres
  database "SQLite (Dev)" as SQLite
}

package "Frontend" <<frontend>> {
  rectangle "Angular Dashboard" as Angular
}

Velocity --> MQTT
Humidity --> MQTT
GPS --> MQTT
Gyro --> MQTT
Light --> MQTT
Rain --> MQTT

MQTT --> Subscriber
Subscriber --> Postgres
Subscriber --> SQLite

Django --> Postgres
Django --> SQLite

Angular --> Django : REST API

note right of MQTT
  Real-time data transmission
end note

note left of Django
  Handles data processing
  and API requests
end note
@enduml