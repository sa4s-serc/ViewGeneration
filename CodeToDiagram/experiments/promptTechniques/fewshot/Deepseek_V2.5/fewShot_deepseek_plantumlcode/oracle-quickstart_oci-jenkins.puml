@startuml oracle-quickstart_oci-jenkins
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "OCI Resources" {
  rectangle "VCN" as vcn {
    rectangle "Public Subnet" as public_subnet {
      rectangle "Bastion Host" as bastion
      rectangle "Load Balancer" as lb
    }
    rectangle "Private Subnet" as private_subnet {
      rectangle "Jenkins Controller" as controller
      rectangle "Jenkins Agent 1" as agent1
      rectangle "Jenkins Agent 2" as agent2
    }
  }

  rectangle "Internet Gateway" as igw
  rectangle "NAT Gateway" as nat
  rectangle "Security Lists" as sec
}

package "Terraform" {
  rectangle "main.tf" as main
  rectangle "variables.tf" as vars
  rectangle "modules/jenkins-controller" as mod_controller
  rectangle "modules/jenkins-agent" as mod_agent
}

package "Users" {
  rectangle "Admin User" as admin
  rectangle "Build Users" as users
}

admin --> bastion : SSH
bastion --> controller : SSH
controller -[hidden]-> agent1 : SSH
controller -[hidden]-> agent2 : SSH

users --> lb : HTTP/HTTPS
lb --> controller : HTTP/HTTPS

igw --> public_subnet
nat --> private_subnet
sec --> vcn

main --> mod_controller
main --> mod_agent
main --> vars

mod_controller --> controller
mod_agent --> agent1
mod_agent --> agent2
@enduml