@startuml elloza_Android-Developer-Certification
left to right direction
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<presentation>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<test>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "UI Layer" <<ui>> {
  rectangle "MainActivity" as MainActivity
  rectangle "RibotsAdapter" as RibotsAdapter
}

package "Presentation Layer" <<presentation>> {
  rectangle "MainPresenter" as MainPresenter
}

package "Data Layer" <<data>> {
  rectangle "DataManager" as DataManager
  rectangle "SyncService" as SyncService
  rectangle "DatabaseHelper" as DatabaseHelper
  rectangle "RibotsService" as RibotsService
}

package "External Services" <<external>> {
  rectangle "Ribot API" as RibotAPI
  database "SQLite" as SQLite
  rectangle "Crashlytics" as Crashlytics
}

package "Testing" <<test>> {
  rectangle "Unit Tests" as UnitTests
  rectangle "UI Tests" as UITests
}

MainActivity --> MainPresenter
MainPresenter --> DataManager
DataManager --> RibotsService
DataManager --> DatabaseHelper
DataManager --> SyncService
RibotsService --> RibotAPI
DatabaseHelper --> SQLite
SyncService --> RibotAPI
SyncService --> SQLite

MainActivity --> RibotsAdapter
RibotsAdapter --> DataManager

DataManager --> Crashlytics

UnitTests --> MainPresenter
UnitTests --> DataManager
UITests --> MainActivity
@enduml