@startuml vishipayyallore_blazorwasm-apim-api-sql-redis
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<bll>> #fff1c9
  BackgroundColor<<dal>> #fddddd
  BackgroundColor<<db>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as user

package "Frontend (Blazor WASM)" <<frontend>> {
  rectangle "Book Pages" as pages
  rectangle "Auth Component" as auth
  rectangle "UI Components" as ui
}

package "API Gateway (APIM)" <<api>> {
  rectangle "API Management" as apim
}

package "Backend API" <<api>> {
  rectangle "BooksController" as controller
  rectangle "Auth0 Integration" as auth0
}

package "Business Logic" <<bll>> {
  rectangle "BooksBLL" as bll
  rectangle "Cache-Aside Logic" as cache_logic
}

package "Data Access" <<dal>> {
  rectangle "BookRepository" as sql_repo
  rectangle "BookCacheRepository" as redis_repo
}

database "SQL Server" <<db>> as sql
database "Redis Cache" <<db>> as redis

user --> pages
pages --> apim : HTTP Requests
pages --> auth : Auth Flow
auth --> auth0 : JWT

apim --> controller
controller --> bll
bll --> cache_logic
cache_logic --> sql_repo : if not cached
cache_logic --> redis_repo : if cached
sql_repo --> sql
redis_repo --> redis

controller --> auth0 : Token Validation

note right of cache_logic
  Implements Cache-Aside Pattern:
  1. Check Redis first
  2. Fallback to SQL if miss
  3. Update Redis on write
end note
@enduml