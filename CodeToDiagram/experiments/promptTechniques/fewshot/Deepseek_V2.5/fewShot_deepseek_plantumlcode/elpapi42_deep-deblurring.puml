@startuml elpapi42_deep-deblurring
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<ml>> #fddddd
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  [Vue.js] as Vue
}

package "Backend" <<backend>> {
  [Flask API Gateway] as Flask
}

package "Model Serving" <<ml>> {
  [TensorFlow Serving] as TFServing
  [DeblurGAN-V2 Model] as Model
}

package "Data Storage" <<storage>> {
  [PostgreSQL] as Postgres
  [Cloudinary] as Cloudinary
  [Redis] as Redis
}

package "Infrastructure" <<infra>> {
  [Docker] as Docker
  [Heroku] as Heroku
}

Vue --> Flask : HTTP
Flask --> TFServing : gRPC
TFServing --> Model
Flask --> Postgres : ORM
Flask --> Cloudinary : API
Flask --> Redis : Cache
Docker --> Heroku : Deployment
@enduml