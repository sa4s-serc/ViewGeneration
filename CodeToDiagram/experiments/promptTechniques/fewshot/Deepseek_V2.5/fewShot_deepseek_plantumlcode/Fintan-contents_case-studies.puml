@startuml
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as User

rectangle "Frontend" as Frontend {
  rectangle "React/Redux" as React
  rectangle "React Native" as ReactNative
  rectangle "Electron" as Electron
}

rectangle "Backend" as Backend {
  rectangle "Spring Boot" as SpringBoot
  rectangle "gRPC Services" as gRPC
  rectangle "ZeroMQ" as ZeroMQ
}

rectangle "CI/CD" as CICD {
  rectangle "Azure DevOps" as AzureDevOps
  rectangle "CircleCI" as CircleCI
  rectangle "AWS Code*" as AWSCode
}

rectangle "Monitoring" as Monitoring {
  rectangle "New Relic" as NewRelic
  rectangle "Elastic Stack" as Elastic
}

rectangle "Security" as Security {
  rectangle "Spring Security" as SpringSecurity
  rectangle "OAuth" as OAuth
}

database "Database" as DB

User --> Frontend
Frontend --> Backend
Backend --> DB

Backend --> gRPC
gRPC --> Frontend

Backend --> ZeroMQ
ZeroMQ --> Backend

Frontend --> CICD
Backend --> CICD
CICD --> AzureDevOps
CICD --> CircleCI
CICD --> AWSCode

Backend --> Monitoring
Monitoring --> NewRelic
Monitoring --> Elastic

Backend --> Security
Security --> SpringSecurity
Security --> OAuth

@enduml