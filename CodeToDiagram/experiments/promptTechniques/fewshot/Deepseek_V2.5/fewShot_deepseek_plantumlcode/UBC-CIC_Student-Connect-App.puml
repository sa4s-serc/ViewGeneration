@startuml UBC-CIC_Student-Connect-App
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as User

rectangle "React PWA" as Frontend {
  rectangle "Authentication" as AuthUI
  rectangle "Survey" as SurveyUI
  rectangle "Content View" as ContentUI
  rectangle "Search" as SearchUI
}

rectangle "AWS Cognito" as Cognito
rectangle "OneLogin" as OneLogin

rectangle "Backend Services" {
  rectangle "GraphQL API" as GraphQL
  rectangle "Lambda Functions" as Lambda {
    rectangle "Data Aggregators" as Aggregators
    rectangle "ES Hasher" as ESHasher
    rectangle "Stream Handler" as StreamHandler
    rectangle "ES Query" as ESQuery
  }
}

rectangle "Data Storage" {
  database "DynamoDB" as DynamoDB
  database "Elasticsearch" as Elasticsearch
  rectangle "S3 Data Lake" as S3
}

rectangle "External Sources" {
  rectangle "UBCO Events" as Events
  rectangle "News" as News
  rectangle "Blogs" as Blogs
  rectangle "Athletics" as Athletics
  rectangle "Clubs" as Clubs
}

rectangle "Admin Tools" {
  rectangle "Kibana" as Kibana
}

' Connections
User --> Frontend
Frontend --> Cognito
Cognito --> OneLogin

Frontend --> GraphQL
GraphQL --> Lambda

Aggregators --> Events
Aggregators --> News
Aggregators --> Blogs
Aggregators --> Athletics
Aggregators --> Clubs
Aggregators --> DynamoDB

DynamoDB --> StreamHandler
StreamHandler --> Elasticsearch

DynamoDB --> ESHasher
ESHasher --> Elasticsearch

GraphQL --> ESQuery
ESQuery --> Elasticsearch

DynamoDB --> S3
Elasticsearch --> Kibana

' Internal frontend flows
AuthUI --> SurveyUI
SurveyUI --> ContentUI
ContentUI --> SearchUI
@enduml