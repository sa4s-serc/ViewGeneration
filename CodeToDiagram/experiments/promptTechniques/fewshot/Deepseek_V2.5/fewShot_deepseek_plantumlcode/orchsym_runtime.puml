@startuml orchsym_runtime
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<storage>> #d8f5d3
  BackgroundColor<<security>> #fddddd
  BackgroundColor<<ext>> #fff1c9
  BackgroundColor<<cluster>> #e6e6fa
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

package "Core Framework" <<core>> {
  rectangle "FlowController" as FC
  rectangle "ProcessScheduler" as PS
  rectangle "ProcessSession" as PSe
  rectangle "FlowFile" as FF
  rectangle "Connection" as Conn
  rectangle "StateManager" as SM
  FC --> PS
  FC --> PSe
  PSe --> FF
  FC --> Conn
  FC --> SM
}

package "Storage" <<storage>> {
  rectangle "FlowFile Repo" as FFRepo
  rectangle "Content Repo" as CRepo
  rectangle "Provenance Repo" as PRepo
  FF --> FFRepo
  FF --> CRepo
  FF --> PRepo
}

package "Security" <<security>> {
  rectangle "Authentication" as Auth
  rectangle "RBAC" as RBAC
  rectangle "SSL/TLS" as SSL
  rectangle "Property Encryption" as Encrypt
  FC --> Auth
  FC --> RBAC
  FC --> SSL
  FC --> Encrypt
}

package "Extensions" <<ext>> {
  rectangle "NAR Bundles" as NAR
  rectangle "Scripting" as Script
  rectangle "External Systems" as ExtSys
  FC --> NAR
  FC --> Script
  FC --> ExtSys
}

package "Cluster" <<cluster>> {
  rectangle "Zookeeper" as ZK
  rectangle "ClusterCoordinator" as CC
  rectangle "Heartbeat" as HB
  FC --> ZK
  ZK --> CC
  CC --> HB
}

package "Orchsym" {
  rectangle "Branding" as Brand
  rectangle "Custom Auth" as CAuth
  rectangle "UDC Service" as UDC
  Brand --> FC
  CAuth --> Auth
  UDC --> FC
}

rectangle "REST API" as API
rectangle "Web UI" as UI
API --> FC
UI --> API

rectangle "External Clients" as Clients
Clients --> API
@enduml