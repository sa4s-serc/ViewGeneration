@startuml mateuseap_apache-airflow
left to right direction
skinparam rectangle {
  BackgroundColor<<orchestration>> #d9e7fd
  BackgroundColor<<processing>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<monitoring>> #fddddd
  BackgroundColor<<deployment>> #d4f0f0
  Style roundrect
}

package "Orchestration" <<orchestration>> {
  [Airflow Webserver] as Webserver
  [Airflow Scheduler] as Scheduler
  [Airflow Worker] as Worker
  [Redis] as Redis
  [PostgreSQL] as Postgres
}

package "Data Processing" <<processing>> {
  [Spark] as Spark
  [Hive] as Hive
  [Livy] as Livy
}

package "Storage" <<storage>> {
  [HDFS NameNode] as NameNode
  [HDFS DataNode] as DataNode
}

package "Monitoring" <<monitoring>> {
  [Telegraf] as Telegraf
  [InfluxDB] as Influx
  [Grafana] as Grafana
  [Elasticsearch] as ES
  [Logstash] as Logstash
  [Kibana] as Kibana
}

package "Deployment" <<deployment>> {
  [Docker] as Docker
  [Kubernetes] as K8s
}

Webserver --> Postgres
Scheduler --> Postgres
Worker --> Redis
Worker --> Postgres

Worker --> Spark
Worker --> Hive
Worker --> Livy

Spark --> NameNode
Hive --> NameNode
NameNode --> DataNode

Telegraf --> Influx
Influx --> Grafana
Logstash --> ES
ES --> Kibana

Docker --> Webserver
Docker --> Scheduler
Docker --> Worker
Docker --> Redis
Docker --> Postgres
Docker --> Spark
Docker --> Hive
Docker --> Livy
Docker --> NameNode
Docker --> DataNode

K8s --> Webserver
K8s --> Scheduler
K8s --> Worker
@enduml