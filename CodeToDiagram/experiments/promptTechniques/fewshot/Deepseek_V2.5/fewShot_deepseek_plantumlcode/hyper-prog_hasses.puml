@startuml hyper-prog_hasses
skinparam backgroundColor #ffffff
skinparam defaultTextAlignment center
skinparam linetype ortho

rectangle "Web Server\n(Apache/Nginx)" as WebServer
rectangle "FIFO/TCP Socket" as CommChannel
rectangle "hasses SSE Server" as Hasses {
    rectangle "epoll Event Loop" as Epoll
    rectangle "Client Management\n(cdata.c/h)" as ClientMgmt
    rectangle "SSE Protocol\n(chat.c/h)" as SSE
    rectangle "I/O Operations\n(cio.c/h)" as IO
    rectangle "SSL/TLS" as SSL
}

rectangle "Clients" as Clients {
    rectangle "Browser 1" as Client1
    rectangle "Browser 2" as Client2
    rectangle "Browser N" as ClientN
}

WebServer --> CommChannel : Push messages
CommChannel --> Hasses : Receive messages

Hasses --> Clients : SSE Stream
Client1 --> Hasses : HTTP GET /events
Client2 --> Hasses : HTTP GET /events
ClientN --> Hasses : HTTP GET /events

Epoll --> ClientMgmt : Manage connections
Epoll --> SSE : Handle events
Epoll --> IO : Non-blocking I/O
IO --> SSL : Secure comms

note right of Hasses
  Configuration:
  - hasses.conf
  - Logging levels
  - CORS settings
end note

note left of WebServer
  Integration:
  - FIFO file
  - TCP socket
end note
@enduml