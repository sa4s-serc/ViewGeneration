### Actual Output:
@startuml kerollesroshdi_Cima-
left to right direction
skinparam rectangle {
  BackgroundColor<<presentation>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Presentation Layer" <<presentation>> {
  [AppCoordinator] as Coordinator
  [NowPlayingVC] as NowPlaying
  [TopRatedVC] as TopRated
  [SearchVC] as Search
  [MovieDetailsVC] as Details
  [BaseViewController] as BaseVC
  [StateView] as StateView
  [TextyTabBar] as TabBar

  Coordinator --> NowPlaying
  Coordinator --> TopRated
  Coordinator --> Search
  Coordinator --> Details
  NowPlaying --> BaseVC
  TopRated --> BaseVC
  Search --> BaseVC
  Details --> BaseVC
  BaseVC --> StateView
  Coordinator --> TabBar
}

package "Domain Layer" <<domain>> {
  [BrowseUseCase] as BrowseUC
  [SearchUseCase] as SearchUC
  [MovieDetailsUseCase] as DetailsUC
  [MoviesRepository] as RepoInterface
  [Movie] as Movie
  [MovieDetails] as MovieDetails
  [Genre] as Genre
  [AppError] as Error

  BrowseUC --> RepoInterface
  SearchUC --> RepoInterface
  DetailsUC --> RepoInterface
  RepoInterface --> Movie
  RepoInterface --> MovieDetails
  RepoInterface --> Genre
  RepoInterface --> Error
}

package "Data Layer" <<data>> {
  [MoviesRepositoryImpl] as RepoImpl
  [RemoteMoviesDataSource] as RemoteDS
  [MoviesService] as Service

  RepoImpl --> RemoteDS
  RemoteDS --> Service
}

package "External" <<external>> {
  [TMDB API] as TMDB
  Service --> TMDB
}

NowPlaying --> BrowseUC
TopRated --> BrowseUC
Search --> SearchUC
Details --> DetailsUC
RepoImpl .u.> RepoInterface
@enduml