@startuml abel-gr_warehouse-robot
left to right direction
skinparam rectangle {
  BackgroundColor<<simulation>> #d9e7fd
  BackgroundColor<<control>> #d8f5d3
  BackgroundColor<<cloud>> #fddddd
  BackgroundColor<<web>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Simulation" <<simulation>> {
  rectangle "Unity\nWarehouse Environment" as Unity
  rectangle "CoppeliaSim\nRobot Physics" as Coppelia
  Unity -[#blue]-> Coppelia : Remote API
}

package "Control System" <<control>> {
  rectangle "sim.py\n(API Facade)" as SimAPI
  rectangle "robot.py\n(Robot Class)" as Robot
  rectangle "main.py\n(Main Logic)" as Main
  rectangle "Inverse Kinematics" as IK
  rectangle "OCR Pipeline" as OCR
  SimAPI --> Coppelia
  Main --> SimAPI
  Main --> Robot
  Robot --> IK
  Robot --> OCR
}

package "Web Interface" <<web>> {
  rectangle "Browser UI" as WebUI
  rectangle "Speech-to-Text" as STT
  rectangle "Audio Recorder" as Recorder
  WebUI --> STT
  WebUI --> Recorder
  Recorder --> STT
}

package "Cloud Services" <<cloud>> {
  rectangle "Google Cloud\nFunctions" as GCF
  STT -[#green]-> GCF
}

Main --> Unity : Control Commands
Unity --> Main : Sensor Data
@enduml