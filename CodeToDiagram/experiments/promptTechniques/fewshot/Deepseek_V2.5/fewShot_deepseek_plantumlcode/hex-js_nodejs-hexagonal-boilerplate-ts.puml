@startuml hex-js_nodejs-hexagonal-boilerplate-ts
left to right direction
skinparam rectangle {
  BackgroundColor<<core>> #d8f5d3
  BackgroundColor<<adapter>> #d9e7fd
  BackgroundColor<<port>> #fff1c9
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}

package "Core Business Logic" <<core>> {
  [Todo Management] as TodoCore
}

package "Adapters" <<adapter>> {
  [Todo Adapter] as TodoAdapter
  [Adapter Factory] as AdapterFactory
}

package "Ports" <<port>> {
  [HTTP Interface] as HttpPort
  [DynamoDB Repository] as DynamoPort
  [SQS Client] as SQSPort
  [Lambda Handler] as LambdaPort
  [Logger] as LoggerPort
}

package "External Systems" <<external>> {
  [Express.js] as Express
  [AWS DynamoDB] as DynamoDB
  [AWS SQS] as SQS
  [AWS Lambda] as Lambda
  [Pino Logger] as Pino
}

package "Infrastructure" <<infra>> {
  [Localstack] as Localstack
  [Terraform] as Terraform
  [Serverless] as Serverless
}

TodoCore --> TodoAdapter
TodoAdapter --> AdapterFactory
AdapterFactory --> HttpPort
AdapterFactory --> DynamoPort
AdapterFactory --> SQSPort
AdapterFactory --> LambdaPort
AdapterFactory --> LoggerPort

HttpPort --> Express
DynamoPort --> DynamoDB
SQSPort --> SQS
LambdaPort --> Lambda
LoggerPort --> Pino

Express --> Localstack
DynamoDB --> Localstack
SQS --> Localstack
Lambda --> Localstack

Localstack --> Terraform
Lambda --> Serverless
@enduml