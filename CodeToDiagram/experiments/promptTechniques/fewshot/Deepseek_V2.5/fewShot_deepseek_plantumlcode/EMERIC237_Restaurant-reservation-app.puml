@startuml EMERIC237_Restaurant-reservation-app
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<deployment>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "Dashboard" as Dashboard
  rectangle "Reservation Form" as ReservationForm
  rectangle "Table Management" as TableManagement
  rectangle "API Client" as APIClient
  Dashboard --> APIClient
  ReservationForm --> APIClient
  TableManagement --> APIClient
}

package "Backend (Node.js/Express)" <<backend>> {
  rectangle "Reservations Router" as ReservationsRouter
  rectangle "Reservations Controller" as ReservationsController
  rectangle "Reservations Service" as ReservationsService
  rectangle "Tables Router" as TablesRouter
  rectangle "Tables Controller" as TablesController
  rectangle "Tables Service" as TablesService
  rectangle "Error Handler" as ErrorHandler
  
  ReservationsRouter --> ReservationsController
  ReservationsController --> ReservationsService
  TablesRouter --> TablesController
  TablesController --> TablesService
}

package "Database" <<db>> {
  database "PostgreSQL" as PostgreSQL
  rectangle "Knex Migrations" as KnexMigrations
  ReservationsService --> PostgreSQL
  TablesService --> PostgreSQL
  KnexMigrations --> PostgreSQL
}

package "Deployment" <<deployment>> {
  rectangle "Vercel" as Vercel
  rectangle "Node.js Server" as NodeServer
  APIClient --> NodeServer
  NodeServer --> Vercel
}

APIClient --> ReservationsRouter
APIClient --> TablesRouter
ReservationsController --> ErrorHandler
TablesController --> ErrorHandler
@enduml