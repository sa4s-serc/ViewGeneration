@startuml mincloud1501_MSA_miniProject
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Developer" {
  rectangle "Local Machine" as DevMachine
}

package "Docker" {
  rectangle "Dockerfile" as Dockerfile
  rectangle "Docker Image" as DockerImage
  rectangle "Docker Hub" as DockerHub
}

package "Kubernetes Cluster" {
  rectangle "Master Node" as MasterNode
  rectangle "Worker Node" as WorkerNode {
    rectangle "Pod" as Pod {
      rectangle "Nginx Container" as Nginx
      rectangle "Envoy Sidecar" as Envoy
    }
  }
  rectangle "Service" as Service
  rectangle "Deployment" as Deployment
}

package "Service Mesh" {
  rectangle "Istio" as Istio
}

package "Monitoring" {
  rectangle "Prometheus" as Prometheus
  rectangle "K8s Dashboard" as Dashboard
}

package "Cloud Providers" {
  rectangle "GKE" as GKE
  rectangle "AWS EKS" as EKS
  rectangle "Azure AKS" as AKS
}

' Connections
DevMachine --> Dockerfile : Build
Dockerfile --> DockerImage
DockerImage --> DockerHub : Push
DockerHub --> WorkerNode : Pull

MasterNode --> WorkerNode : Manages
Deployment --> Pod : Creates
Service --> Pod : Exposes
Pod --> Nginx
Pod --> Envoy

Istio --> Envoy : Manages
Istio --> Service : Traffic Control

Prometheus --> WorkerNode : Monitors
Dashboard --> MasterNode : Visualizes

WorkerNode --> GKE : Deployable to
WorkerNode --> EKS : Deployable to
WorkerNode --> AKS : Deployable to

note right of Istio
  Handles traffic management,
  version routing, and
  fault injection
end note
@enduml