```plantuml
@startuml IBM_spectrum-protect-sppmon
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Administrator" as Admin

package "SPPMon Core" {
  rectangle "sppmon.py" as SPPMon #lightblue
  rectangle "SPPCheck" as SPPCheck #lightyellow
  rectangle "REST API Client" as RestClient #lightgreen
  rectangle "SSH Client" as SSHClient #lightgreen
  rectangle "InfluxDB Client" as InfluxClient #lightgreen
}

package "SPP Components" {
  rectangle "SPP Server" as SPPServer #lightpink
  rectangle "vSnap" as vSnap #lightpink
  rectangle "VADP" as VADP #lightpink
  rectangle "Microsoft 365 Proxies" as M365Proxies #lightpink
}

package "Data Storage & Visualization" {
  rectangle "InfluxDB" as InfluxDB #lightcoral
  rectangle "Grafana" as Grafana #lightcoral
}

package "Automation" {
  rectangle "Installer Script" as InstallerScript #lightgrey
  rectangle "Crontab Jobs" as CrontabJobs #lightgrey
}

Admin --> InstallerScript : Install and Configure
InstallerScript --> SPPMon
InstallerScript --> CrontabJobs

SPPMon --> RestClient : Collect Data
SPPMon --> SSHClient : Execute Commands

RestClient --> SPPServer : API Requests
SSHClient --> vSnap : SSH Commands
SSHClient --> VADP : SSH Commands
SSHClient --> M365Proxies : SSH Commands

SPPMon --> InfluxClient : Store Data
InfluxClient --> InfluxDB

InfluxDB --> Grafana : Visualization
Admin --> Grafana : View Dashboards

SPPCheck --> InfluxClient : Analyze Data
SPPCheck --> "PDF Reports" : Generate
@enduml
```