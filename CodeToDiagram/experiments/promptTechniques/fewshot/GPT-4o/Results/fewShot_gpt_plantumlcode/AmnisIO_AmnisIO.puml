```plantuml
@startuml AmnisIO_AmnisIO
left to right direction
skinparam rectangle {
  BackgroundColor #dff0ff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "AmnisIO CLI" {
  rectangle "bin/index.js" as CLI <<CLI>> #fbd9d9
}

package "Transpiler" {
  rectangle "TypeScript to C\n(typewriter)" as Typewriter #fddddd
}

package "Stream Library" {
  rectangle "rivulet\n(C Library)" as Rivulet #d8f5d3
}

package "Board Abstraction" {
  rectangle "Gyrus\n(Board Abstraction)" as Gyrus #fddddd
}

package "PlatformIO Integration" {
  rectangle "PlatformIO" as PlatformIO #d8f5d3
}

package "Configuration" {
  rectangle "configs/types.ts" as TypesTS #d9e7fd
  rectangle "configs/index.ts" as IndexTS #d9e7fd
  rectangle "configs/arduino-uno.ts" as ArduinoConfig #d9e7fd
}

package "Examples" {
  rectangle "examples/arduino-uno/*.ts" as ExamplesTS #d8f5d3
}

CLI --> Typewriter : Transpile TypeScript to C
CLI --> PlatformIO : Build/Deploy via PlatformIO
CLI --> Rivulet : Use reactive streams
CLI --> Gyrus : Abstract board specifics
CLI --> TypesTS : Leverage TypeScript interfaces
CLI --> IndexTS : Access board configurations
CLI --> ArduinoConfig : Use Arduino UNO config
ExamplesTS --> CLI : Demonstrate usage

@enduml
```