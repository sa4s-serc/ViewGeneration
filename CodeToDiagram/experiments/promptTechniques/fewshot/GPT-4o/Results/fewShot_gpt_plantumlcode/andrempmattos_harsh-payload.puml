    [FreeRTOS] as FreeRTOS
    [Peripheral Drivers] as PeripheralDrivers
    [System Services Driver] as SystemServices
    [Experiment Algorithms] as ExperimentAlgorithms
    [OBC Communication (FSP)] as OBCCommunication
    [Raspberry Pi Software Wrapper] as RaspberryPiWrapper
}

package "Hardware Components and Architecture" {
    [FPGA Fabric] as FPGAFabric
    [AXI/AHB Interconnect] as Interconnect
    [Memory Subsystem] as MemorySubsystem
    [Clocking and Reset] as ClockingReset
    [Peripheral Interfaces] as PeripheralInterfaces
    [Power Management] as PowerManagement
}

package "Design Patterns" {
    [Hierarchical Design] as HierarchicalDesign
    [Bus-Based Architecture] as BusArchitecture
    [Data-Driven Design] as DataDrivenDesign
    [Component-Based Design] as ComponentDesign
    [Configuration-Driven Design] as ConfigDrivenDesign
    [Constraint-Driven Design] as ConstraintDesign
    [HAL] as HAL
    [Gated Logic] as GatedLogic
}

package "Synthesis and Implementation" {
    [Synplify Pro] as SynplifyPro
    [Simulation] as Simulation
    [Resource Utilization Reports] as ResourceReports
}

FreeRTOS --> PeripheralDrivers
