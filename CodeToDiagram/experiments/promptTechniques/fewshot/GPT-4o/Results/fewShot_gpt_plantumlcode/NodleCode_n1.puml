```plantuml
@startuml NodleCode_n1
left to right direction
skinparam rectangle {
  BackgroundColor<<hardware>> #f0f8ff
  BackgroundColor<<firmware>> #e6ffe6
  BackgroundColor<<mobile>> #fef9e7
  BackgroundColor<<cloud>> #e0f7fa
  Style roundrect
}

actor "User" as user

package "iBeacon Device" <<hardware>> {
  rectangle "Dialog DA14531\nDev Kit" as devkit
}

package "Firmware" <<firmware>> {
  rectangle "iBeacon Firmware" as firmware
  rectangle "Dialog SDK" as sdk
  devkit --> firmware
  firmware --> sdk
}

package "Mobile App" <<mobile>> {
  rectangle "Nodle Mobile App" as mobileapp
  mobileapp --> firmware : Beacon Detection
}

package "Cloud Backend" <<cloud>> {
  rectangle "Nodle Cloud" as nodlecloud
  rectangle "getBeaconInformation.py" as beaconinfo
  nodlecloud --> beaconinfo : API
}

package "PCB Manufacturing" <<hardware>> {
  rectangle "Gerber Files" as gerber
  rectangle "CNC Drill Files" as cnc
  gerber --> cnc
}

user --> mobileapp : Interacts
mobileapp --> nodlecloud : Data Relay
beaconinfo --> nodlecloud : Data Retrieval
@enduml
```