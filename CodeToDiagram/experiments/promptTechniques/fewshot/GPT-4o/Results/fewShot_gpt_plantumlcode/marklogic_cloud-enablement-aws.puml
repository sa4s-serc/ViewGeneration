```plantuml
@startuml marklogic_cloud-enablement-aws
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "AWS Cloud" {
  rectangle "VPC" as VPC {
    rectangle "Subnets" as Subnets
    rectangle "Security Groups" as SecurityGroups
    rectangle "EC2 Instances" as EC2
    rectangle "EBS Volumes" as EBS
    rectangle "Application Load Balancer (ALB)" as ALB
    rectangle "Auto Scaling Groups" as ASG
    rectangle "IAM Roles" as IAM
    rectangle "Elastic Network Interfaces (ENIs)" as ENIs
  }
  
  database "DynamoDB\nMarkLogicDDBTable" as DynamoDB
  
  package "Lambda Functions" {
    rectangle "managedeni.py" as ManagedEni
    rectangle "nodemanager.py" as NodeManager
    rectangle "utils.py" as Utils
  }
  
  rectangle "SNS (Logging)" as SNS
}

rectangle "CloudFormation" as CloudFormation {
  rectangle "mlcluster.template\nmlcluster-vpc.template" as CFTemplates
  rectangle "ml-managedeni.template\nml-nodemanager.template" as CFTemplatesENI
}

CloudFormation --> CFTemplates
CloudFormation --> CFTemplatesENI

CFTemplates --> VPC
CFTemplates --> EC2
CFTemplates --> EBS
CFTemplates --> ALB
CFTemplates --> ASG
CFTemplates --> IAM
CFTemplates --> DynamoDB
CFTemplates --> ENIs

CFTemplatesENI --> ManagedEni
CFTemplatesENI --> NodeManager

ManagedEni --> ENIs
NodeManager --> ASG

ASG --> EC2
EC2 --> ENIs
EC2 --> EBS

ALB --> EC2

NodeManager --> SNS

CloudFormation --> DynamoDB
ManagedEni --> DynamoDB
NodeManager --> DynamoDB

@enduml
```