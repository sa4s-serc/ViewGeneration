```plantuml
@startuml terrenjpeterson_javawatch
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User"

rectangle "Raspberry Pi" as Pi {
  rectangle "photo.py\n(Capture Image)" as PhotoScript #lightgrey
}

package "AWS" {
  rectangle "S3 Bucket\n(Store Images)" as S3Bucket #orange
  rectangle "Lambda Function\n(checkImage.py)" as LambdaCheckImage #lightblue
  rectangle "Lambda Function\n(labelCheck.js)" as LambdaLabelCheck #lightblue
  rectangle "Rekognition\n(Analyze Image)" as Rekognition #orange
  rectangle "DRS\n(Order Beans)" as DRS #orange
}

package "Web Interface" {
  rectangle "Static Website" {
    rectangle "index.html\n(Home Page)" as IndexPage #lightgrey
    rectangle "registration.html\n(Register Device)" as RegistrationPage #lightgrey
    rectangle "confirm.html\n(Confirmation)" as ConfirmPage #lightgrey
  }
}

Pi --> S3Bucket : Upload Image
S3Bucket --> LambdaCheckImage : Trigger
LambdaCheckImage --> Rekognition : Detect Labels
Rekognition --> LambdaLabelCheck : Confirm "Bean" Label
LambdaLabelCheck --> DRS : Place Order if Low

User --> IndexPage : View Information
User --> RegistrationPage : Register Device
@enduml
```