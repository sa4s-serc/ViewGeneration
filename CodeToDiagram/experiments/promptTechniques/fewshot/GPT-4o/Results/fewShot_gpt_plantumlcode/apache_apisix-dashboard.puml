```
@startuml apache_apisix-dashboard
left to right direction
skinparam rectangle {
  BackgroundColor #f9f9f9
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" {
  rectangle "React Components\n(index.tsx, add.tsx, detail.$id.tsx)" as ReactComponents #d9e7fd
  rectangle "Mantine UI\n(Applayout, Header, Navbar)" as MantineUI #d9e7fd
  rectangle "Ant Design Pro\n(ProTable)" as AntDesignPro #d9e7fd
  rectangle "React Hook Form & Zod\n(FormProvider, FormTOCBox)" as FormHandling #d9e7fd
  rectangle "react-i18next\n(Internationalization)" as I18n #d9e7fd
  rectangle "MobX State Management\n(global.ts)" as MobX #d9e7fd
}

package "Backend API" {
  rectangle "APISIX Admin API\n(src/apis/*.ts)" as APISIXAPI #fff1c9
  rectangle "Axios Instance\n(req.ts)" as AxiosInstance #fff1c9
}

package "Routing & Navigation" {
  rectangle "TanStack Router\n(react-router)" as TanStackRouter #d8f5d3
  rectangle "Route Definitions\n(routeTree.gen.ts, __root.tsx)" as RouteDefinitions #d8f5d3
}

package "State Management" {
  rectangle "MobX Stores\n(global.ts)" as MobXStores #d8f5d3
  rectangle "TanStack Query\n(Query Client)" as TanStackQuery #d8f5d3
}

package "Configuration" {
  rectangle "Constants\n(constant.ts)" as Constants #d8f5d3
  rectangle "Vite Config\n(vite.config.ts)" as ViteConfig #d8f5d3
}

rectangle "Authentication\n(Admin Key)" as Authentication #fddddd

rectangle "E2E Tests\n(Playwright)" as E2ETests #fddddd

ReactComponents --> MantineUI
ReactComponents --> AntDesignPro
ReactComponents --> FormHandling
ReactComponents --> I18n
ReactComponents --> MobX

ReactComponents --> TanStackRouter
TanStackRouter --> RouteDefinitions

ReactComponents --> APISIXAPI
APISIXAPI --> AxiosInstance

ReactComponents --> MobXStores
ReactComponents --> TanStackQuery

ReactComponents --> Constants
ReactComponents --> ViteConfig

ReactComponents --> Authentication

ReactComponents --> E2ETests

@enduml
