@startuml jkahn117_aws-news
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

package "Frontend (Next.js)" {
  rectangle "Static Site\n(Amplify Hosted)" as StaticSite
}

package "AWS Infrastructure" {
  rectangle "AWS AppSync\nGraphQL API" as AppSync #lightblue

  package "News Ingestion" {
    rectangle "Lambda\nRSS Feed Parser" as FeedParser #orange
    rectangle "Lambda\nImage Processor" as ImageProcessor #orange
    database "DynamoDB" as DynamoDB #lightyellow
    rectangle "S3\nArticle Storage" as ArticleS3 #lightyellow
  }

  package "Content Delivery" {
    rectangle "CloudFront\nCDN" as CloudFront #lightblue
  }

  package "Caching & Storage" {
    rectangle "ElastiCache\nRedis" as Redis #lightyellow
    database "S3\nProcessed Images" as ImageS3 #lightyellow
  }

  package "Analytics" {
    rectangle "Kinesis Data\nFirehose" as Firehose #lightyellow
    rectangle "Amazon Pinpoint" as Pinpoint #lightyellow
  }
}

User --> StaticSite
StaticSite --> AppSync

AppSync --> DynamoDB
AppSync --> Redis
AppSync --> CloudFront

FeedParser --> ArticleS3
FeedParser --> DynamoDB
ImageProcessor --> ImageS3
ImageProcessor --> DynamoDB

ArticleS3 --> FeedParser
ImageS3 --> ImageProcessor

Pinpoint --> Firehose
@enduml