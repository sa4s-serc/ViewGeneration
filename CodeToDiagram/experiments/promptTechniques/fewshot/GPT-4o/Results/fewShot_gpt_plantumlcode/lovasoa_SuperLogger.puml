```plantuml
@startuml lovasoa_SuperLogger
skinparam rectangle {
  BackgroundColor #f8f9fa
  BorderColor black
  Style roundrect
}

actor "User"

package "System Monitoring with ELK Stack" {
  rectangle "Java Agent" {
    rectangle "SystemInfo.java" as SystemInfo
    rectangle "TCPServer.java" as TCPServer
  }
  
  rectangle "Logstash" {
    rectangle "tcp2elastic.conf" as LogstashConf
  }
  
  rectangle "Elasticsearch" as ES
  rectangle "Kibana" as Kibana
}

SystemInfo --> TCPServer
TCPServer --> Logstash : TCP
Logstash --> ES : Processed Data
ES --> Kibana : Indexed Data

User --> Kibana : View Dashboard
@enduml
```