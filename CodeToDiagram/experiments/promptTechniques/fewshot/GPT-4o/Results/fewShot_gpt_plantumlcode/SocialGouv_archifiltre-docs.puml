```plantuml
@startuml SocialGouv_archifiltre-docs
skinparam componentStyle rectangle
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor black
  Style roundrect
}

actor "User" as User

package "Archifiltre Application" {
  rectangle "Main Process" as MainProcess
  rectangle "Renderer Process" as RendererProcess
  rectangle "Async Workers" as AsyncWorkers
  rectangle "State Management\n(Redux/Zustand)" as StateManagement
  rectangle "Data Export Handlers" as DataExport
  rectangle "File System Manager" as FileSystemManager
  rectangle "Metadata Manager" as MetadataManager
  rectangle "Configuration Manager" as ConfigManager
  rectangle "Internationalization\n(i18n)" as I18n
  rectangle "Tracking & Monitoring" as Tracking
}

package "External Services" {
  rectangle "Sentry" as Sentry
  rectangle "Matomo/Posthog" as Analytics
  rectangle "Electron Updater" as Updater
}

User --> RendererProcess : Interact with UI
RendererProcess --> StateManagement : Manage State
RendererProcess --> AsyncWorkers : Perform Resource-Intensive Operations
AsyncWorkers --> FileSystemManager : Load & Process File System Data
AsyncWorkers --> DataExport : Export Data
RendererProcess --> MetadataManager : Manage Metadata
RendererProcess --> ConfigManager : Load User Config
RendererProcess --> I18n : Handle Translations
RendererProcess --> Tracking : Log Errors & Track Usage

Tracking --> Sentry : Error Logging
Tracking --> Analytics : Usage Tracking

MainProcess --> AsyncWorkers : Initiate Async Tasks
MainProcess --> RendererProcess : Manage UI
MainProcess --> Updater : Check for Updates

@enduml
```