```plantuml
@startuml badr42_oke_A1
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Administrator"

cloud "Oracle Cloud Infrastructure" as OCI {
  rectangle "VCN (Virtual Cloud Network)" as VCN {
    rectangle "Private Subnet" as PrivateSubnet
    rectangle "Public Subnet" as PublicSubnet
  }
  
  rectangle "OKE Cluster" as OKE {
    rectangle "Control Plane" as ControlPlane
    rectangle "Node Pool\n(Ampere A1)" as NodePool
  }
  
  rectangle "Gateways" as Gateways {
    rectangle "Internet Gateway" as IGW
    rectangle "NAT Gateway" as NGW
    rectangle "Service Gateway" as SGW
  }

  rectangle "Load Balancer" as LoadBalancer
}

rectangle "Local Machine" as LocalMachine {
  rectangle "Terraform" as Terraform
  rectangle "kubectl" as Kubectl
}

Administrator --> Terraform
Terraform --> OCI

VCN --> IGW
VCN --> NGW
VCN --> SGW
VCN --> OKE

OKE --> NodePool
OKE --> ControlPlane

NodePool --> PrivateSubnet
ControlPlane --> PublicSubnet
LoadBalancer --> PublicSubnet
LoadBalancer --> NodePool

Terraform --> "nginx_deployment.yaml"
Terraform --> "setup_nginx.sh"

Kubectl --> OKE : kubeconfig

@enduml
```