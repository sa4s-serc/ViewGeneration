```plantuml
@startuml DecenterApps_ResistanceProtocol
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<simulation>> #fff1c9
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<smartcontract>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "Dashboard" as Dashboard
  rectangle "CDP Management" as CDPManagement
  rectangle "Web3 Connectors" as Web3Connectors
  Dashboard --> CDPManagement
  CDPManagement --> Web3Connectors
}

package "Simulation Engine (Python)" <<simulation>> {
  rectangle "sim1.py" as sim1
  rectangle "Agent Models" as AgentModels
  rectangle "PID Controllers" as PIDControllers
  rectangle "External Data\nSimulations" as ExternalData
  sim1 --> AgentModels
  sim1 --> PIDControllers
  sim1 --> ExternalData
}

package "Backend Services (Python)" <<backend>> {
  rectangle "Contract Deployment" as ContractDeployment
  rectangle "Event Monitoring" as EventMonitoring
  rectangle "Liquidation Bot" as LiquidationBot
  EventMonitoring --> LiquidationBot
}

package "Smart Contracts (Solidity)" <<smartcontract>> {
  rectangle "NOI Stablecoin" as NOIStablecoin
  rectangle "CDPManager" as CDPManager
  rectangle "MultiSigWallet" as MultiSigWallet
  NOIStablecoin --> CDPManager
  CDPManager --> MultiSigWallet
}

rectangle "Ethereum Blockchain" as Blockchain #lightgrey

Web3Connectors --> NOIStablecoin
Web3Connectors --> Blockchain

ContractDeployment --> Blockchain
EventMonitoring --> Blockchain
LiquidationBot --> Blockchain

@enduml
```