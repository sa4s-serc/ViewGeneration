```plantuml
@startuml abel-gr_warehouse-robot
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Unity Simulation" {
  rectangle "Prefabs" as UnityPrefabs
  rectangle "Warehouse Simulation" as WarehouseSim
  UnityPrefabs --> WarehouseSim
}

package "CoppeliaSim" {
  rectangle "sim.py\nFacade" as SimPy
  rectangle "robot.py\nRobot Control" as RobotPy
  rectangle "main.py\nSimulation Entry" as MainPy
  rectangle "Inverse Kinematics\ncinematica_inversa.ipynb" as InverseKinematics
  rectangle "OCR\nOCR_Lite.py" as OCR
  SimPy --> RobotPy
  SimPy --> MainPy
  RobotPy --> InverseKinematics
  InverseKinematics --> OCR
}

package "Web Interface" {
  rectangle "JavaScript" as JS
  rectangle "Speech-to-Text\nCloud Function" as CloudFunction
  rectangle "recorderjs\nAudio Recording" as RecorderJS
  JS --> CloudFunction
  JS --> RecorderJS
}

package "IntelliJ IDEA Config" {
  rectangle "Project Settings" as IDEASettings
  rectangle "Dependencies" as IDEADependencies
  rectangle "Version Control" as IDEAVersionControl
  IDEASettings --> IDEADependencies
  IDEASettings --> IDEAVersionControl
}

cloud "CoppeliaSim Remote API" as RemoteAPI
UnityPrefabs --> RemoteAPI
SimPy --> RemoteAPI

cloud "Google Cloud Services" as GoogleCloud
CloudFunction --> GoogleCloud
@enduml
```