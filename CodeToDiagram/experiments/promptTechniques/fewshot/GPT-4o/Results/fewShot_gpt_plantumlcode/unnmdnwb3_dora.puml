```plantuml
@startuml unnmdnwb3_dora
skinparam rectangle {
  BackgroundColor #f8f8f8
  BorderColor #000000
  Style roundrect
}
left to right direction

actor User

package "DORA Metrics Automation Tool" {
  rectangle "Backend API\n(Gin-Gonic)" as Backend
  rectangle "MongoDB Service" as MongoDBService
  rectangle "GitLab Connector" as GitLabConnector
  rectangle "Prometheus Connector" as PrometheusConnector
  rectangle "Metrics Calculation\nServices" as MetricsService

  User --> Backend : API Requests

  Backend --> MongoDBService : CRUD Operations
  Backend --> GitLabConnector : Fetch Data
  Backend --> PrometheusConnector : Query Alerts
  Backend --> MetricsService : Calculate Metrics

  GitLabConnector --> GitLab : API Calls
  PrometheusConnector --> Prometheus : Alert Queries
}

package "Persistence" {
  database "MongoDB" as MongoDB
}

package "External Services" {
  rectangle "GitLab" as GitLab
  rectangle "Prometheus" as Prometheus
}

MongoDBService --> MongoDB : Data Storage
MetricsService --> MongoDBService : Access Data

@enduml
