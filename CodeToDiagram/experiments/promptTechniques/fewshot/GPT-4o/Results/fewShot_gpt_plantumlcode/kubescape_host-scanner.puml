```plantuml
@startuml kubescape_host-scanner
left to right direction
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Kubescape Host Scanner" {
  rectangle "HTTP API Server" as ApiServer <<component>>
  rectangle "Sensor Functions" as SensorFuncs <<component>>
  rectangle "Middleware (Negroni)" as Middleware <<component>>
  rectangle "Logging (go-logger, zap)" as Logging <<component>>
  rectangle "OpenTelemetry" as OpenTelemetry <<component>>
}

package "Host Information" {
  rectangle "OS Details" as OSDetails
  rectangle "Network Configuration" as NetworkConfig
  rectangle "Container Runtime Info" as ContainerRuntime
  rectangle "Kubelet & Kube-proxy" as KubeletProxy
  rectangle "Control Plane Details" as ControlPlane
  rectangle "Linux Security Hardening" as SecurityHardening
  rectangle "Cloud Provider Info" as CloudProvider
}

package "Deployment" {
  rectangle "Kubernetes DaemonSet" as DaemonSet <<component>>
  rectangle "Dockerfile" as Dockerfile <<component>>
}

package "E2E Testing" {
  rectangle "Ginkgo & Gomega" as GinkgoGomega <<component>>
  rectangle "Kind Cluster" as KindCluster <<component>>
}

ApiServer --> Middleware
ApiServer --> SensorFuncs
ApiServer --> Logging
ApiServer --> OpenTelemetry

SensorFuncs --> OSDetails
SensorFuncs --> NetworkConfig
SensorFuncs --> ContainerRuntime
SensorFuncs --> KubeletProxy
SensorFuncs --> ControlPlane
SensorFuncs --> SecurityHardening
SensorFuncs --> CloudProvider

DaemonSet --> ApiServer
Dockerfile --> DaemonSet

GinkgoGomega --> ApiServer
GinkgoGomega --> KindCluster

KindCluster --> DaemonSet
@enduml
