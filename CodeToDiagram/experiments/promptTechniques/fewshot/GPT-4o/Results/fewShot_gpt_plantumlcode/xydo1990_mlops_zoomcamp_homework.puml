```plantuml
@startuml xydo1990_mlops_zoomcamp_homework
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User"

package "Data Layer" {
  rectangle "Kaggle\nData Source" as Kaggle #lightblue
}

package "Training" {
  rectangle "Jupyter Notebook\n(src/data_feeling.ipynb)" as DataExploration #lightyellow
  rectangle "Train Model\n(src/train_model.py)" as TrainModel #lightyellow
  rectangle "MLflow Tracking" as MLflowTracking #lightyellow
  rectangle "Model Registry" as ModelRegistry #lightyellow
}

package "Deployment" {
  rectangle "Batch Prediction\nService" as BatchService #lightgreen
  rectangle "Streaming Prediction\nService" as StreamService #lightgreen
  rectangle "Docker" as Docker #lightgreen
  rectangle "Prefect\nWorkflow" as Prefect #lightgreen
}

package "Monitoring" {
  rectangle "Evidently\nMonitoring" as Evidently #lightcoral
  rectangle "Prometheus" as Prometheus #lightcoral
  rectangle "Grafana" as Grafana #lightcoral
}

package "Testing" {
  rectangle "Unit Tests" as UnitTests #lightgray
  rectangle "Integration Tests" as IntegrationTests #lightgray
}

User --> Kaggle : Download Data
Kaggle --> DataExploration
DataExploration --> TrainModel
TrainModel --> MLflowTracking : Track Experiments
MLflowTracking --> ModelRegistry : Register Model

ModelRegistry --> Docker : Deploy via Docker
Docker --> BatchService : Deploy Batch
Docker --> StreamService : Deploy Streaming
BatchService --> Prefect : Orchestrate Workflow

BatchService --> Evidently : Monitor Batch
StreamService --> Evidently : Monitor Stream
Evidently --> Prometheus : Metrics
Prometheus --> Grafana : Visualization

UnitTests --> Docker
IntegrationTests --> Docker

@enduml
```