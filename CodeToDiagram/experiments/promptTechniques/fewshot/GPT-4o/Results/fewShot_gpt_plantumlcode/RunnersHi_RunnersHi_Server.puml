```plantuml
@startuml RunnersHi_RunnersHi_Server
actor User

rectangle "Frontend" {
  User --> "Web/Mobile App"
}

rectangle "Backend" {
  rectangle "Express.js Server" as Express {
    rectangle "Socket.IO\nReal-time Communication" as SocketIO
    rectangle "RESTful API\nEndpoints" as API
  }

  package "Controllers" {
    rectangle "Auth Controller" as AuthController
    rectangle "User Controller" as UserController
    rectangle "Record Controller" as RecordController
    rectangle "Ranking Controller" as RankingController
  }

  package "Models" {
    rectangle "Auth Model" as AuthModel
    rectangle "User Model" as UserModel
    rectangle "Record Model" as RecordModel
    rectangle "Ranking Model" as RankingModel
    rectangle "Matching Model" as MatchingModel
  }

  package "Database" {
    database "MySQL" as MySQL
  }

  User --> "Web/Mobile App"
  "Web/Mobile App" --> Express
  Express --> API
  Express --> SocketIO

  API --> AuthController
  API --> UserController
  API --> RecordController
  API --> RankingController

  AuthController --> AuthModel
  UserController --> UserModel
  RecordController --> RecordModel
  RankingController --> RankingModel

  SocketIO --> MatchingModel

  AuthModel --> MySQL
  UserModel --> MySQL
  RecordModel --> MySQL
  RankingModel --> MySQL
  MatchingModel --> MySQL
}
@enduml
```