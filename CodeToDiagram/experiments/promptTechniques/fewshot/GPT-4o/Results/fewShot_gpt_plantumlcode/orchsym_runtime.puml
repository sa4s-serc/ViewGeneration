```plantuml
@startuml orchsym_runtime
skinparam rectangle {
  BackgroundColor #f2f2f2
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

package "Apache NiFi Core" {
  rectangle "FlowController" as FlowController
  rectangle "ProcessSession" as ProcessSession
  rectangle "FlowFile" as FlowFile
  rectangle "Connection" as Connection
  rectangle "ProcessScheduler" as ProcessScheduler

  FlowController --> ProcessSession
  ProcessSession --> FlowFile
  ProcessSession --> Connection
  ProcessScheduler --> FlowController
}

package "Repositories" {
  rectangle "FlowFile Repository" as FlowFileRepo
  rectangle "Content Repository" as ContentRepo
  rectangle "Provenance Repository" as ProvenanceRepo

  FlowController --> FlowFileRepo
  FlowController --> ContentRepo
  FlowController --> ProvenanceRepo
}

package "Infrastructure Components" {
  rectangle "ControllerServiceProvider" as ControllerServiceProvider
  rectangle "REST API" as RestAPI
  rectangle "StateManagerProvider" as StateManagerProvider
  rectangle "Site-to-Site" as SiteToSite
  rectangle "Web UI" as WebUI

  FlowController --> ControllerServiceProvider
  FlowController --> RestAPI
  FlowController --> StateManagerProvider
  FlowController --> SiteToSite
  RestAPI --> WebUI
}

package "Security & Authorization" {
  rectangle "Login Identity Provider" as LoginIdentityProvider
  rectangle "Authorizer" as Authorizer
  rectangle "SSLContextService" as SSLContextService
  rectangle "Sensitive Property Encryption" as SensitivePropertyEncryption

  FlowController --> LoginIdentityProvider
  FlowController --> Authorizer
  FlowController --> SSLContextService
  FlowController --> SensitivePropertyEncryption
}

package "Integration & Extensibility" {
  rectangle "NAR Bundles" as NARBundles
  rectangle "ExecuteScript" as ExecuteScript
  rectangle "External Integrations" as ExternalIntegrations
  rectangle "Schema Registry" as SchemaRegistry

  FlowController --> NARBundles
  FlowController --> ExecuteScript
  FlowController --> ExternalIntegrations
  FlowController --> SchemaRegistry
}

package "Cluster Coordination" {
  rectangle "Cluster Coordinator" as ClusterCoordinator
  rectangle "ZooKeeper" as ZooKeeper

  FlowController --> ClusterCoordinator
  ClusterCoordinator --> ZooKeeper
}

package "Orchsym Runtime" {
  rectangle "Branding Extension" as BrandingExtension
  rectangle "Custom Login Provider" as CustomLoginProvider
  rectangle "Usage Data Collection Service" as UsageDataCollectionService

  FlowController --> BrandingExtension
  FlowController --> CustomLoginProvider
  FlowController --> UsageDataCollectionService
}

@enduml
