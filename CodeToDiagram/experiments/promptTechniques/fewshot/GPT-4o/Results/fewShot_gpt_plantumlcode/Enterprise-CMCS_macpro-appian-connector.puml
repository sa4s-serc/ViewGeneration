```plantuml
@startuml Enterprise-CMCS_macpro-appian-connector
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Developer" as dev

package "GitHub" {
  rectangle "GitHub Actions" as gha #lightgrey
  rectangle "GitOps" as gitops #lightgrey
}

package "AWS" {
  rectangle "ECS" as ecs #lightblue
  rectangle "SNS" as sns #lightblue
  rectangle "CloudWatch" as cw #lightblue
  rectangle "IAM" as iam #lightblue
  rectangle "Parameter Store\n& Secrets Manager" as ssm #lightblue
}

package "Enterprise-CMCS_macpro-appian-connector" {
  rectangle "Kafka Connector" as kafka #lightyellow
  rectangle "EventBridge Rules" as eventbridge #lightyellow
}

dev --> gha : Code Commit
gha -> gitops : Trigger Deployment
gitops -> ecs : Deploy Serverless Services
ecs -> kafka : Run Connector
kafka -> sns : Send Notifications
sns -> dev : Alert
kafka -> cw : Log Metrics
cw -> dev : Monitoring Dashboard

rectangle "Jira" as jira #lightgrey
gha -> jira : Sync Security Findings
ecs -> ssm : Fetch Configuration
ecs -> iam : Assume Role
eventbridge -> sns : Trigger Notification

@enduml
```