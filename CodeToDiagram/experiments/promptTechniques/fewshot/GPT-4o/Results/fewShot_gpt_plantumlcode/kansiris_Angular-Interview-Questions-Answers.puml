```plantuml
@startuml kansiris_Angular-Interview-Questions-Answers
skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor black
}
skinparam defaultTextAlignment center
left to right direction

package "Angular Interview Questions and Answers" {
  rectangle "Q&A Collection" as QA
  rectangle "Code Examples" as Code
  rectangle "README.md\n(Table of Contents)" as TOC
  rectangle "LICENSE\n(Apache 2.0)" as License
}

rectangle "External Resources" {
  rectangle "YouTube Content" as YouTube
  rectangle "Author's Website" as Website
}

QA --> Code : includes
QA --> TOC : navigated by
QA --> License : covered by

TOC --> YouTube : links to
TOC --> Website : links to

@enduml
```