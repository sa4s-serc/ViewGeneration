```plantuml
@startuml IBM_vpc-flowlogs-log-analysis

skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "COS Trigger" as Trigger

package "Serverless Function" {
  rectangle "handler.js\nCore Logic" as Handler #lightblue
  rectangle "index.js\nHTTP Endpoint" as Endpoint #lightgreen
  rectangle "local-handler.js\nLocal Testing" as LocalHandler #lightyellow
}

package "IBM Cloud Object Storage" {
  rectangle "COS Receiver Bucket" as ReceiverBucket #orange
  rectangle "COS Archive Bucket" as ArchiveBucket #orange
}

package "IBM Log Analysis" {
  rectangle "Log Analysis API" as LogAPI #lightgrey
}

Trigger --> ReceiverBucket : COS Write Event
ReceiverBucket --> Handler : Triggered
Handler --> ReceiverBucket : Retrieve Logs
Handler --> Handler : Decompress and Parse
Handler --> Handler : Transform and Add Metadata
Handler --> LogAPI : Forward Logs
Handler --> ArchiveBucket : Copy Logs
Handler --> ReceiverBucket : Delete Logs

Endpoint --> Handler : HTTP Invoke (Testing)
LocalHandler --> Handler : Simulate Trigger (Local Testing)

@enduml
```