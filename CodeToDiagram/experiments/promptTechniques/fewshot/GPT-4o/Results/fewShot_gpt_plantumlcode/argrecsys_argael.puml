package "Input/Output" {
  rectangle "FileUtils" as FileUtils
  rectangle "StringUtils" as StringUtils
}

package "Reporting" {
  rectangle "ReportFormatter" as ReportFormatter
  rectangle "HTML Templates" as HTMLTemplates
}

package "User Management" {
  rectangle "users.txt\n(Registered Users)" as UsersTxt
}

package "Data Storage" {
  rectangle "Proposals Data\n(JSONL)" as ProposalsData
}

