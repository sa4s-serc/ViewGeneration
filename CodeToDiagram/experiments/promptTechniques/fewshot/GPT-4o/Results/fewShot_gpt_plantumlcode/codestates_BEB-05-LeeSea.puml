```plantuml
@startuml codestates_BEB-05-LeeSea
left to right direction
skinparam rectangle {
  BackgroundColor #f9f9f9
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" {
  rectangle "App.js\n(Front Controller)" as App #d9e7fd
  rectangle "Components" as Components #d9e7fd
  rectangle "Redux Store" as Redux #d9e7fd
  rectangle "Web3.js\n(Blockchain API)" as Web3 #d9e7fd
}

package "Smart Contracts (Solidity/Yul)" {
  rectangle "LeeSeaNFT.sol\n(ERC-721)" as LeeSeaNFT #f5d3d8
  rectangle "LeeSeaMarket.sol\n(Marketplace)" as LeeSeaMarket #f5d3d8
  rectangle "Utility.yul\n(Low-Level Yul)" as Yul #f5d3d8
}

package "Blockchain (Ethereum)" {
  rectangle "Ethereum Network\n(Ropsten, Ganache)" as Ethereum #fddddd
}

actor "User"

User --> App
App --> Components
App --> Redux
App --> Web3

Web3 --> LeeSeaNFT
Web3 --> LeeSeaMarket

LeeSeaNFT --> Ethereum
LeeSeaMarket --> Ethereum

Yul --> LeeSeaNFT

@enduml
```