```plantuml
@startuml onlybakam_reinvent2022-vote-app
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Reinvent2022 Vote App" as App {
  rectangle "Front-end (Next.js)" {
    rectangle "Voting UI" as VotingUI
    rectangle "GraphQL Operations" as GraphQLOps
  }

  rectangle "AWS AppSync" as AppSync {
    rectangle "GraphQL API" as GraphQLAPI
  }

  rectangle "AWS Services" {
    rectangle "DynamoDB" as DynamoDB
    rectangle "SNS" as SNS
    rectangle "AWS Translate" as Translate
    rectangle "Lambda Functions" as Lambda {
      rectangle "publishToSNS" as PublishSNS
      rectangle "saveToDynamoDB" as SaveDynamoDB
      rectangle "translateMessage" as TranslateMessage
    }
  }
}

' User interactions
User --> VotingUI : Vote (BR/CM)\nSelect Message

' Front-end Operations
VotingUI --> GraphQLOps : AddVote Mutation
VotingUI --> GraphQLOps : OnPlusOne Subscription

' GraphQL API interactions
GraphQLOps --> GraphQLAPI : Mutations/Subscriptions

' AppSync resolver functions
GraphQLAPI --> PublishSNS : AddVote
GraphQLAPI --> SaveDynamoDB : AddVote
GraphQLAPI --> TranslateMessage : AddVote

' AWS Services interactions
PublishSNS --> SNS : Publish Vote Event
SaveDynamoDB --> DynamoDB : Store Vote Data
TranslateMessage --> Translate : Translate Message

' Real-time updates
SNS --> GraphQLAPI : Notify
GraphQLAPI --> VotingUI : Update UI via Subscription
@enduml
```