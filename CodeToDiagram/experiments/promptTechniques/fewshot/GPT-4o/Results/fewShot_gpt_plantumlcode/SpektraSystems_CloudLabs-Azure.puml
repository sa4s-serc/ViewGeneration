```plantuml
@startuml SpektraSystems_CloudLabs-Azure
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam linetype ortho

actor "User"

package "Azure CloudLabs" {
  
  package "Azure Migration" {
    rectangle "Azure Migrate Project" as MigrateProject #lightblue
    rectangle "Hyper-V VMs" as HyperV #lightblue
    rectangle "Azure IaaS" as AzureIaaS #lightblue
    HyperV <--> MigrateProject : Assess & Replicate
    MigrateProject <--> AzureIaaS : Test & Validate
  }

  package "Azure VM & Compute" {
    rectangle "Virtual Network" as VNet #lightgreen
    rectangle "VM Deployment" as VMDeploy #lightgreen
    rectangle "IIS Installation" as IIS #lightgreen
    VNet <--> VMDeploy
    VMDeploy <--> IIS
  }

  package "Serverless App Modernization" {
    rectangle "Azure Functions" as Functions #lightyellow
    rectangle "Cosmos DB" as CosmosDB #lightyellow
    rectangle "Blazor Website" as Blazor #lightyellow
    Functions <--> CosmosDB
    Functions <--> Blazor
    Blazor --> "Azure Storage" : Deploy
  }

  package "Azure Monitoring" {
    rectangle "Azure Monitor" as Monitor #lightcoral
    rectangle "Log Analytics" as LogAnalytics #lightcoral
    rectangle "App Insights" as AppInsights #lightcoral
    rectangle "Grafana" as Grafana #lightcoral
    Monitor <--> LogAnalytics
    Monitor <--> AppInsights
    Monitor <--> Grafana
  }

}

User --> MigrateProject
User --> VNet
User --> Functions
User --> Monitor
@enduml
```