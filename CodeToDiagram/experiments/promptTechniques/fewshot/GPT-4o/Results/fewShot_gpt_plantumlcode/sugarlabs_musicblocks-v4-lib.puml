```plantuml
@startuml sugarlabs_musicblocks-v4-lib
left to right direction

skinparam rectangle {
  BackgroundColor<<syntax>> #d9e7fd
  BackgroundColor<<execution>> #d8f5d3
  BackgroundColor<<library>> #fff1c9
  Style roundrect
}

package "Syntax Representation" <<syntax>> {
  rectangle "Element API" as ElementAPI
  rectangle "Specification" as Specification
  rectangle "Warehouse" as Warehouse
  rectangle "Syntax Tree" as SyntaxTree
}

package "Execution Engine" <<execution>> {
  rectangle "Symbol Table" as SymbolTable
  rectangle "Parser" as Parser
  rectangle "Interpreter" as Interpreter
  rectangle "Scheduler" as Scheduler
}

package "Library" <<library>> {
  rectangle "Values" as Values
  rectangle "Boxes & Identifiers" as Boxes
  rectangle "Math Operators" as MathOps
  rectangle "Conditionals" as Conditionals
  rectangle "Loops" as Loops
  rectangle "Program Structures" as ProgStruct
  rectangle "Miscellaneous" as Misc
}

ElementAPI --> Specification
Specification --> Warehouse
Warehouse --> SyntaxTree

Parser --> SyntaxTree
Interpreter --> Parser
Interpreter --> SymbolTable
Scheduler --> Interpreter

ProgStruct --> ElementAPI
Values --> ElementAPI
Boxes --> ElementAPI
MathOps --> ElementAPI
Conditionals --> ElementAPI
Loops --> ElementAPI
Misc --> ElementAPI

@enduml
```