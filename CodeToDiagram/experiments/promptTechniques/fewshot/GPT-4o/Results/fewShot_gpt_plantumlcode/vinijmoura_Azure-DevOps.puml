```plantuml
@startuml vinijmoura_Azure-DevOps
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "User"

package "Azure DevOps" {
  rectangle "Azure DevOps CLI" as CLI
  rectangle "Azure DevOps REST API" as REST
}

package "ETL Scripts (PowerShell)" {
  rectangle "Data Extraction" as Extract
  rectangle "Data Transformation" as Transform
  rectangle "Data Loading" as Load
}

package "Azure SQL Database" {
  database "SQL Database" as SQL
}

package "Power BI" {
  rectangle "Power BI Desktop" as PBI
  rectangle "Custom Visuals" as CustomVisuals
}

User --> CLI
User --> REST

CLI --> Extract
REST --> Extract

Extract --> Transform
Transform --> Load

Load --> SQL
SQL --> PBI

PBI --> CustomVisuals

@enduml
```