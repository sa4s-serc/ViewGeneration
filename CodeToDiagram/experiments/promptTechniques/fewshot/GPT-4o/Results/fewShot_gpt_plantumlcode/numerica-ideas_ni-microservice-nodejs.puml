```plantuml
@startuml numerica-ideas_ni-microservice-nodejs
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}

actor "User" as user

package "Microservice" {
  
  rectangle "Express Application" as express {
    rectangle "Routes" as routes
    rectangle "Controllers" as controllers
    rectangle "Services" as services
    rectangle "Models" as models
    rectangle "Middleware" as middleware
  }

  rectangle "MongoDB" as mongodb
  rectangle "Redis" as redis
  rectangle "AWS SNS" as sns
  rectangle "AWS Lambda" as lambda
  rectangle "Express Server" as server

  user --> express : HTTP Requests
  express --> routes
  routes --> controllers
  controllers --> services
  services --> models
  services --> redis
  services --> sns
  services --> mongodb
  services --> lambda

  express --> middleware
  express --> server
  lambda --> sns
  sns --> services
  redis --> services
}

@enduml
```