```plantuml
@startuml SecHack365-Fans_PyJailBreak
left to right direction
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor black
  Style roundrect
}
skinparam componentStyle rectangle

actor User

package "Frontend (Next.js)" {
  rectangle "UI for Scan Configuration" as ScanUI
  rectangle "Payload Management" as PayloadMgmt
  rectangle "Execute Scan" as ExecuteScan
  rectangle "Emulation Mode" as EmulationMode
  rectangle "Configuration" as Configuration
  rectangle "API Documentation (Swagger UI)" as APIDoc
}

package "Backend API" {
  rectangle "Scan Execution API" as ScanAPI
}

package "State Management (Redux Toolkit)" {
  rectangle "Payloads Slice" as PayloadsSlice
  rectangle "Endpoints Slice" as EndpointsSlice
  rectangle "Emulation Slice" as EmulationSlice
  rectangle "Dialog Slice" as DialogSlice
  rectangle "Store Configuration" as StoreConfig
}

User --> ScanUI : configure scan
ScanUI --> PayloadMgmt : manage payloads
ScanUI --> ExecuteScan : execute scan
ScanUI --> EmulationMode : toggle emulation mode
ScanUI --> Configuration : set API endpoint
ScanUI --> APIDoc : view API documentation

PayloadMgmt --> PayloadsSlice
ExecuteScan --> ScanAPI
ExecuteScan --> PayloadsSlice
ExecuteScan --> EndpointsSlice
EmulationMode --> EmulationSlice
Configuration --> EndpointsSlice

PayloadsSlice --> StoreConfig
EndpointsSlice --> StoreConfig
EmulationSlice --> StoreConfig
DialogSlice --> StoreConfig
@enduml
```