```plantuml
@startuml icoxfog417_karura
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

package "Kintone Environment" {
  rectangle "Karura Master App" as MasterApp #d9e7fd
  rectangle "Karura Client Plugin" as ClientPlugin #d9e7fd
  ClientPlugin --> MasterApp : Configure ML task\nInitiate Training
}

package "Karura Server (Tornado)" {
  rectangle "REST API" as API {
    rectangle "/train" as TrainEndpoint
    rectangle "/predict" as PredictEndpoint
    rectangle "/ping" as PingEndpoint
  }
  rectangle "Data Handling" as DataHandling {
    rectangle "DataSet" as DataSet
    rectangle "FieldManager" as FieldManager
    rectangle "FeatureBuilder" as FeatureBuilder
  }
  rectangle "Model Handling" as ModelHandling {
    rectangle "ModelBuilder" as ModelBuilder
    rectangle "ModelManager" as ModelManager
  }
}

package "Storage" {
  rectangle "Disk" as Disk {
    rectangle "Trained Models" as TrainedModels
    rectangle "Field Configs" as FieldConfigs
  }
}

User --> ClientPlugin : Initiate ML Task
MasterApp --> API : REST Call
API --> DataHandling : Load Data & Features
DataHandling --> FieldManager : Manage Fields
DataHandling --> FeatureBuilder : Build Features
DataHandling --> DataSet : Load Data
DataHandling --> ModelHandling : Pass Features & Data

ModelHandling --> ModelBuilder : Build & Train Model
ModelHandling --> ModelManager : Orchestrate Process
ModelBuilder --> ModelManager : Pass Trained Model
ModelManager --> Disk : Save Model & Config

TrainEndpoint --> ModelHandling : Trigger Training
PredictEndpoint --> ModelHandling : Trigger Prediction
PingEndpoint --> API : Health Check
@enduml
```