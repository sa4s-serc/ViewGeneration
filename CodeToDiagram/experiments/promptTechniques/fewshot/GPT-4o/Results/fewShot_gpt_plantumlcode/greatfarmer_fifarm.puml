```plantuml
@startuml greatfarmer_fifarm
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
skinparam linetype ortho

package "Controllers" {
  rectangle "IndexController" as IndexController
  rectangle "PathController" as PathController
  rectangle "JsonController (REST API)" as JsonController
}

package "Services" {
  rectangle "HttpRequestService" as HttpRequestService
  rectangle "MongoService" as MongoService
  rectangle "LogService" as LogService
}

package "Data Access" {
  database "MongoDB" as MongoDB
}

package "Scheduled Tasks" {
  rectangle "Scheduler" as Scheduler
}

package "Configuration" {
  rectangle "application.yml" as AppConfig
  rectangle "logback.xml" as LogConfig
}

package "Web Interface" {
  rectangle "Thymeleaf Templates" as Templates
  rectangle "Static Resources" as Static
}

package "Utilities" {
  rectangle "FileUtils" as FileUtils
  rectangle "DateUtils" as DateUtils
  rectangle "JsonUtils" as JsonUtils
}

IndexController --> Templates
PathController --> Templates
JsonController --> MongoService

HttpRequestService --> MongoService
MongoService --> MongoDB
LogService --> LogConfig

Scheduler --> HttpRequestService
Scheduler --> MongoService

AppConfig --> MongoService
AppConfig --> MongoDB

Static --> Templates

@enduml
```