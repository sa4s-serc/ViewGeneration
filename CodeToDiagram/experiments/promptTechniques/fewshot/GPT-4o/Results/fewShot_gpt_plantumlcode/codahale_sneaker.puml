```plantuml
@startuml codahale_sneaker
skinparam defaultTextAlignment center
skinparam linetype ortho

rectangle "S3" as S3
rectangle "IAM" as IAM
rectangle "Management\\nServer" as MGMT
rectangle "KMS" as KMS
rectangle "Target\\nServer" as TARGET

rectangle "read/write/list\\nobjects" as RW
rectangle "generate data key/\\ndecrypt" as GEN
rectangle "deploy\\npacked secrets" as DEPLOY
rectangle "decrypt" as DECRYPT

note right of S3
  ACL
end note

note right of MGMT
  ACL
end note

note right of IAM
  ACL
end note

S3 <-- RW
RW --> MGMT
RW --> IAM
MGMT --> GEN
GEN --> KMS
GEN --> IAM 
DECRYPT --> IAM
MGMT --> DEPLOY
DEPLOY --> TARGET
TARGET --> DECRYPT
DECRYPT --> KMS
IAM --> MGMT
@enduml
```