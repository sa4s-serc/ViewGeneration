skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Contributor
actor User

package "Repository Structure" {
  rectangle "Root README.md" as RootReadme #lightyellow
  rectangle "Use Case README.md" as UseCaseReadme #lightyellow
  rectangle "Use Case Template" as Template #lightyellow
  rectangle "Interview Topics" as InterviewTopics #lightyellow
  rectangle "Funding Config" as FundingConfig #lightyellow
  rectangle "Images" as Images #lightyellow
}

package "AWS Use Cases" {
  rectangle "Security" as Security #lightblue
  rectangle "Storage" as Storage #lightblue
  rectangle "Compute" as Compute #lightblue
  rectangle "Management" as Management #lightblue
  rectangle "Messaging" as Messaging #lightblue
}

package "Learning Resources" {
  rectangle "AWS Documentation" as AWSDocs #lightgreen
  rectangle "Udemy Courses" as Udemy #lightgreen
}

Contributor --> RootReadme : Read guidelines
