```plantuml
@startuml lowtalkers_escape-reality
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

actor "User"

package "Client-Side (React)" {
  rectangle "VR Renderer\n(A-Frame)" as VRRenderer
  rectangle "App Component" as AppComponent
  rectangle "Authentication\nComponent" as AuthComponent
  rectangle "Scene Components\n(e.g., Louvre, SF)" as SceneComponents
  rectangle "UI Elements\n(TextPlane, RingTag)" as UIComponents
  rectangle "User Profile" as UserProfile
  rectangle "Bookmarking" as Bookmarking
  rectangle "Social Interaction\n(Comments, Likes)" as SocialInteraction

  User --> AuthComponent : Login/Signup
  AuthComponent --> AppComponent
  AppComponent --> SceneComponents : Navigate
  AppComponent --> UIComponents
  AppComponent --> VRRenderer
  AppComponent --> UserProfile
  AppComponent --> Bookmarking
  AppComponent --> SocialInteraction
}

package "Server-Side (Node.js)" {
  rectangle "Express.js API" as API
  rectangle "Sequelize ORM" as Sequelize
  database "MariaDB" as MariaDB
  rectangle "AWS S3" as AWSS3
  rectangle "Utilities\n(Wikipedia, Base64)" as Utilities

  API --> Sequelize : DB Interaction
  API --> AWSS3 : Image Storage
  API --> Utilities
  Sequelize --> MariaDB
}

package "Database Models & Controllers" {
  rectangle "User Model & Controller" as UserModel
  rectangle "Photo Model & Controller" as PhotoModel
  rectangle "Bookmark Model & Controller" as BookmarkModel
  rectangle "Comment Model & Controller" as CommentModel
  rectangle "Like Model & Controller" as LikeModel

  Sequelize --> UserModel
  Sequelize --> PhotoModel
  Sequelize --> BookmarkModel
  Sequelize --> CommentModel
  Sequelize --> LikeModel
}

AppComponent --> API : HTTP Requests
@enduml
```