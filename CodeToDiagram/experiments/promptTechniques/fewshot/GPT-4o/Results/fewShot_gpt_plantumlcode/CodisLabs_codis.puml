```plantuml
@startuml CodisLabs_codis
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor #aaaaaa
  Style roundrect
}
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
left to right direction

package "Redis System" {
  rectangle "Redis Server" as RedisServer
  rectangle "Sentinel" as Sentinel
  rectangle "Cluster" as Cluster
  rectangle "Codis Proxy" as CodisProxy
  rectangle "Client Libraries" as ClientLibs
  rectangle "Persistence" as Persistence
}

package "Core Components" {
  rectangle "Event Loop\n(ae)" as EventLoop
  rectangle "Memory Allocator\n(zmalloc, jemalloc)" as MemoryAllocator
  rectangle "Networking\n(Networking.c)" as Networking
  rectangle "Configuration\n(config.c)" as Configuration
  rectangle "IO Streams\n(rio)" as IOStreams
}

package "Functional Components" {
  rectangle "Lua Scripting" as LuaScripting
  rectangle "Command Processing" as CommandProcessing
  rectangle "Data Structures" as DataStructures
  rectangle "Error Handling" as ErrorHandling
}

package "Integration & Extensibility" {
  rectangle "hiredis\n(redigo)" as Hiredis
  rectangle "Monitoring\n(StatsD, InfluxDB)" as Monitoring
  rectangle "Testing Framework\n(Tcl)" as Testing
}

RedisServer --> EventLoop : Handles I/O Events
RedisServer --> MemoryAllocator : Manages Memory
RedisServer --> Networking : Manages Connections
RedisServer --> Configuration : Loads Settings
RedisServer --> IOStreams : Manages Persistence
RedisServer --> CommandProcessing : Executes Commands
RedisServer --> DataStructures : Utilizes for Storage
RedisServer --> ErrorHandling : Handles Errors
RedisServer --> LuaScripting : Extends Capabilities

CodisProxy --> RedisServer : Intermediary
Sentinel --> RedisServer : Monitors
Cluster --> RedisServer : Manages Sharding
ClientLibs --> RedisServer : Access & Interaction
Persistence --> IOStreams : Utilizes RDB/AOF

Hiredis --> ClientLibs : Provides Access
Monitoring --> RedisServer : Collects Metrics
Testing --> RedisServer : Validates Behavior

@enduml
