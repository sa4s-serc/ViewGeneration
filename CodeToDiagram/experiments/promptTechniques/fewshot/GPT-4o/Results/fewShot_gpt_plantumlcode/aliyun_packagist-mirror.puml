```plantuml
@startuml aliyun_packagist-mirror
skinparam componentStyle rectangle
skinparam shadowing false
skinparam linetype ortho

package "Alibaba Cloud OSS" {
  [OSS Storage] <<storage>>
}

package "Redis" {
  [Redis Cache] <<cache>>
}

package "GitHub" {
  [GitHub API] <<external>>
}

package "Packagist" {
  [Packagist API] <<external>>
}

package "CDN" {
  [CDN Warm-up] <<external>>
}

package "aliyun_packagist-mirror" {
  [main.go] <<entrypoint>>
  
  component "util/packagist.go" as PackagistUtil
  component "util/config.go" as ConfigUtil
  component "util/mirror.go" as MirrorUtil
  component "util/sync_dists.go" as SyncDistsUtil
  component "util/sync_packages_v2.go" as SyncPackagesV2Util
  component "util/sync_packages_p1.go" as SyncPackagesP1Util
  component "util/sync_status.go" as SyncStatusUtil
  component "util/github.go" as GitHubUtil
  component "util/util.go" as Util
  component "util/entry.go" as EntryUtil
  component "util/sync_composer_phar.go" as SyncComposerPharUtil
  component "util/cdn.go" as CdnUtil
  component "util/context.go" as ContextUtil
  component "util/sync_providers.go" as SyncProvidersUtil
}

[main.go] --> ConfigUtil : load config
[main.go] --> EntryUtil : initialize
[main.go] --> ContextUtil : create context

EntryUtil --> SyncProvidersUtil : start goroutine
EntryUtil --> SyncPackagesP1Util : start goroutine
EntryUtil --> SyncPackagesV2Util : start goroutine
EntryUtil --> SyncDistsUtil : start goroutine

SyncProvidersUtil --> PackagistUtil : sync providers
SyncPackagesP1Util --> PackagistUtil : sync packages V1
SyncPackagesV2Util --> PackagistUtil : sync packages V2
SyncDistsUtil --> GitHubUtil : download distributions

SyncDistsUtil --> OSS Storage : store distributions
SyncPackagesP1Util --> OSS Storage : store packages
SyncPackagesV2Util --> OSS Storage : store packages
SyncProvidersUtil --> OSS Storage : store providers

SyncStatusUtil --> [status.json] : update status

SyncDistsUtil --> Redis Cache : queue processing
SyncPackagesP1Util --> Redis Cache : queue processing
SyncPackagesV2Util --> Redis Cache : queue processing
SyncProvidersUtil --> Redis Cache : queue processing

GitHubUtil --> GitHub API : interact

CdnUtil --> CDN Warm-up : warm-up

ConfigUtil --> [packagist.yml] : load config
@enduml
```