```plantuml
@startuml ankithans_codeX
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (ReactJS)" {
  rectangle "App.js" as App
  rectangle "components" {
    rectangle "Navbar.js" as Navbar
    rectangle "PseudoCode.js" as PseudoCode
    rectangle "Warnings.js" as Warnings
    rectangle "Compile.js" as Compile
  }
  App --> Navbar
  App --> PseudoCode
  App --> Warnings
  App --> Compile
}

package "Backend (FastAPI)" {
  rectangle "main.py" as Main
  rectangle "app/app.py" as AppPy
  rectangle "app/routes" {
    rectangle "compile.py" as CompileRoute
    rectangle "convertPseudo.py" as ConvertPseudo
    rectangle "warnings.py" as WarningsRoute
    rectangle "translatePseudo.py" as TranslatePseudo
    rectangle "shareCode.py" as ShareCode
    rectangle "flowchart.py" as Flowchart
  }
  rectangle "app/services" {
    rectangle "pylint.py" as PylintService
    rectangle "pseudo_code.py" as PseudoCodeService
    rectangle "hackerearth_compile.py" as HackerEarthService
    rectangle "translate.py" as TranslateService
    rectangle "flowchart.py" as FlowchartService
  }

  Main --> AppPy
  AppPy --> CompileRoute
  AppPy --> ConvertPseudo
  AppPy --> WarningsRoute
  AppPy --> TranslatePseudo
  AppPy --> ShareCode
  AppPy --> Flowchart

  CompileRoute --> HackerEarthService
  ConvertPseudo --> PseudoCodeService
  WarningsRoute --> PylintService
  TranslatePseudo --> TranslateService
  Flowchart --> FlowchartService
}

package "External Services" {
  rectangle "HackerEarth API" as HackerEarthAPI
  rectangle "Google Translate" as GoogleTranslate
}

CompileRoute --> HackerEarthAPI
TranslatePseudo --> GoogleTranslate

package "Database" {
  database "SQLite" as SQLite
}

ShareCode --> SQLite
@enduml
```