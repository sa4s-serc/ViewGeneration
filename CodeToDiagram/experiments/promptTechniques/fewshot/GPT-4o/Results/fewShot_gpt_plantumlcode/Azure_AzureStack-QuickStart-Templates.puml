@startuml Azure_AzureStack-QuickStart-Templates
skinparam rectangle {
  BackgroundColor #f0f8ff
  BorderColor black
  Style roundrect
}
left to right direction

package "Azure Environment" {
  rectangle "Azure Resource Manager\nTemplates" as ARM #lightblue
  rectangle "Virtual Machines" as VM #lightblue
  rectangle "Virtual Networks" as VNet #lightblue
  rectangle "Load Balancers" as LB #lightblue
  rectangle "Key Vault" as KV #lightblue
  rectangle "Storage Accounts" as SA #lightblue
  rectangle "Network Security Groups" as NSG #lightblue
}

package "Azure Stack Environment" {
  rectangle "Azure Stack Resource Manager\nTemplates" as ASARM #lightgreen
  rectangle "Azure Stack Virtual Machines" as ASVM #lightgreen
  rectangle "Azure Stack Virtual Networks" as ASVNet #lightgreen
}

package "Deployment Scripts" {
  rectangle "PowerShell Scripts" as PS #aliceblue
  rectangle "Shell Scripts" as SH #aliceblue
  rectangle "Configuration Files" as CFG #aliceblue
}

package "Application Platforms" {
  rectangle "Docker Swarm" as Docker #lavender
  rectangle "Service Fabric" as SF #lavender
  rectangle "Hadoop" as Hadoop #lavender
  rectangle "Ethereum Consortium\nBlockchain" as Ethereum #lavender
  rectangle "Mesos Cluster" as Mesos #lavender
  rectangle "Active Directory" as AD #lavender
}

package "Security & Validation" {
  rectangle "Validation Scripts" as Validation #lightyellow
  rectangle "Security Documentation" as Security #lightyellow
}

