```plantuml
@startuml ut-ims-robotics_robotont
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho

package "Robotont ROS Package" {
    package "robotont_driver" {
        [Serial Communication] <<component>>
        [Hardware Interface] <<component>>
        [Odometry Calculation] <<component>>
    }
    
    package "robotont_teleop" {
        [Teleoperation Nodes] <<component>>
        [Navigation Configurations] <<component>>
    }

    package "robotont_training" {
        [Training Exercises] <<component>>
        [AR Tag Tracking] <<component>>
    }

    package "robotont_description" {
        [URDF Models] <<component>>
        [Meshes] <<component>>
        [Materials] <<component>>
    }

    package "robotont_sensors" {
        [LaserScan Processing] <<component>>
    }
}

rectangle "ROS Communication" as ROSComm {
    [Publisher-Subscriber] <<component>>
    [Services] <<component>>
}

[Serial Communication] --> ROSComm
[Teleoperation Nodes] --> ROSComm
[Training Exercises] --> ROSComm
[LaserScan Processing] --> ROSComm

note right of [Serial Communication]
  Hardware Abstraction Layer (HAL)
end note

note right of [Teleoperation Nodes]
  Timer-based Safety Mechanism
end note

note right of [LaserScan Processing]
  Custom Message: LaserScanSplit.msg
end note

@enduml
```