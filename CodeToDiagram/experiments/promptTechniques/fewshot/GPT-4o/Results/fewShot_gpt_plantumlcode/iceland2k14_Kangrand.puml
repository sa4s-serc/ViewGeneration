```plantuml
@startuml iceland2k14_Kangrand
skinparam componentStyle rectangle
skinparam linetype ortho

package "Client-Server Architecture" {
    [Client] as Client
    [Server] as Server
    [Network Component] as Network

    Client --> Network
    Network --> Server
}

package "Core Components" {
    [Kangaroo Class] as Kangaroo
    [Secp256K1 Class] as Secp256K1
    [GPU/GPUEngine Class] as GPUEngine
    [HashTable Class] as HashTable
    [Integer Arithmetic Classes] as IntArithmetic

    Kangaroo --> Secp256K1
    Kangaroo --> GPUEngine
    Kangaroo --> HashTable
    Secp256K1 --> IntArithmetic
}

package "Supporting Components" {
    [Backup Component] as Backup
    [Thread Management] as ThreadManagement
    [Timer] as Timer

    Kangaroo --> Backup
    Kangaroo --> ThreadManagement
    Kangaroo --> Timer
}

package "Main Program" {
    [main.cpp] as Main
    [Constants.h] as Constants

    Main --> Kangaroo
    Main --> Constants
}

package "File Management" {
    [Merge] as Merge
    [PartMerge] as PartMerge
    [Check] as Check

    Backup --> Merge
    Backup --> PartMerge
    Backup --> Check
}

note left of GPUEngine
    CUDA Optimization
end note

note right of HashTable
    Distinguished Point Method
end note

note bottom of Client
    Command-line Configurations
end note

@enduml
```