```plantuml
@startuml jzyong_GameServer4g
skinparam defaultTextAlignment center
skinparam linetype ortho

actor Client

rectangle "ZooKeeper" as ZK

package "GameServer4g" {
    rectangle "Gate Service" as Gate {
        [ClientManager]
        [UserManager]
        [GameManager]
    }
    
    rectangle "Hall Service" as Hall {
        [HallManager]
    }
    
    rectangle "World Service" as World {
        [WorldManager]
    }
    
    rectangle "Resource Service" as Resource
    rectangle "Manager Service" as Manager
}

Client --> Gate : TCP\nover custom protocol
Gate --> Hall : gRPC
Hall --> World : gRPC
Gate --> World : gRPC

ZK --> Gate : Service Discovery\nand Configuration
ZK --> Hall : Service Discovery\nand Configuration
ZK --> World : Service Discovery\nand Configuration

@enduml
```