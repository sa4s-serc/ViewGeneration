```plantuml
@startuml googleinterns_typescript-flag-upgrade
left to right direction
skinparam rectangle {
  BackgroundColor #f0f8ff
  BorderColor black
  Style roundrect
}

package "TypeScript Flag Upgrade Tool" {
  rectangle "CLI Entry Point\nsrc/index.ts" as CLI #lightblue

  rectangle "Runner\nsrc/runner.ts" as Runner #lightgreen
  rectangle "Parser\nsrc/parser.ts" as Parser #lightyellow
  rectangle "Error Detectors\nsrc/error_detectors/*.ts" as ErrorDetectors #lightcoral
  rectangle "Manipulators\nsrc/manipulators/*.ts" as Manipulators #lightpink
  rectangle "Emitters\nsrc/emitters/*.ts" as Emitters #lightgray
  rectangle "Loggers\nsrc/loggers/*.ts" as Loggers #lightgoldenrodyellow
  rectangle "Utilities\nsrc/util/*.ts" as Utilities #lightcyan
  rectangle "Tests\ntest/**/*_test.ts" as Tests #lavender

  CLI --> Runner
  Runner --> Parser
  Runner --> ErrorDetectors
  Runner --> Manipulators
  Runner --> Emitters
  Runner --> Loggers
  Runner --> Utilities
  Tests --> ErrorDetectors
  Tests --> Manipulators
  Tests --> Emitters
  Tests --> Loggers
}

note right of Manipulators
  Implements strategies for fixing errors
end note

note right of ErrorDetectors
  Detects specific TypeScript errors
end note

note right of Emitters
  Writes modified code
end note

note right of Loggers
  Logs messages to the user
end note

note right of Utilities
  Provides utility functions
end note
@enduml
```