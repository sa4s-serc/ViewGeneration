```plantuml
@startuml Elkinmt19_feature-hero-ml
left to right direction
skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor Developer

package "Feature Store" {
  rectangle "Feast" as Feast #lightblue
}

package "Online Store" {
  rectangle "Redis" as Redis #ffdddd
}

package "Offline Store" {
  rectangle "Parquet Files" as Parquet #ffebcd
}

package "Containerization" {
  rectangle "Docker & Docker Compose" as Docker #e0ffff
}

Developer --> Docker
Docker --> Feast
Docker --> Redis
Docker --> Parquet

package "Data Pipeline" {
  rectangle "Data Fetching\nand Transformation" as DataPipeline #d3f3d3
}

package "Feature Management" {
  rectangle "Feature Definitions" as FeatureDef #d1e7e0
}

DataPipeline --> FeatureDef
FeatureDef --> Feast
Feast --> Redis : Serve Features
Feast --> Parquet : Batch Features

@enduml
```