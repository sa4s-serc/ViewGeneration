```plantuml
@startuml intel_edge-insights-vision
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as User

package "Edge Insights for Vision" {
  rectangle "eiv_install.sh" as InstallScript #lightsteelblue
  rectangle "eiv_setup.py" as SetupScript #lightsteelblue
  rectangle "eiv_callbacks.sh" as CallbacksScript #lightsteelblue
  rectangle "launch_notebooks.sh" as LaunchNotebooks #lightsteelblue
  rectangle "adl_*.sh" as AlderLakeScripts #lightsteelblue
  rectangle "Docker Container" as DockerContainer #lightgoldenrodyellow

  InstallScript --> SetupScript
  InstallScript --> CallbacksScript
  InstallScript --> AlderLakeScripts

  User --> InstallScript
  LaunchNotebooks --> DockerContainer
  DockerContainer --> "Jupyter Notebooks"
}

package "Documentation & Information" {
  rectangle "README.md" as Readme #lightgray
  rectangle "docs/*" as Docs #lightgray
  rectangle "CONTRIBUTING.md" as Contributing #lightgray
  rectangle "CODE_OF_CONDUCT.md" as CodeOfConduct #lightgray
  rectangle "LICENSE" as License #lightgray
  rectangle "security.md" as Security #lightgray
}

package "Project Governance & Dependencies" {
  rectangle "requirements.txt" as Requirements #lightgray
}

DockerContainer --> "OpenVINO Toolkit"
DockerContainer --> "Intel Graphics Drivers"

@enduml
```