```plantuml
@startuml pgrignaffini_AlgoCrowd
left to right direction
skinparam rectangle {
  BackgroundColor #f3f4f6
  BorderColor #2c3e50
  Style roundrect
}

package "Next.js Frontend" {
  rectangle "UI Components" as UIComponents
  rectangle "AppContext\n(Provider Pattern)" as AppContext
  rectangle "API.js" as API
  rectangle "utils/\nContractOperations.js\nTxOperations.js" as Utils
}

package "Express.js Backend" {
  rectangle "server.js\n(REST API Endpoints)" as Server
  rectangle "db.js\n(SQLite Connection)" as DBConnection
  rectangle "dao.js\n(DAO Pattern)" as DAO
}

package "Algorand Blockchain" {
  rectangle "Smart Contracts\n(PyTeal)" as SmartContracts
  rectangle "operations.py\n(Contract Logic)" as Operations
  rectangle "util.py\n(Blockchain Utils)" as BlockchainUtils
}

actor "User" as User

User --> UIComponents : Interacts
UIComponents --> AppContext : Uses
UIComponents --> API : Invokes
API --> Server : Makes API Calls
Server --> DAO : Uses
DAO --> DBConnection : Connects

Server --> SmartContracts : Interacts with
SmartContracts --> Operations : Calls
Operations --> BlockchainUtils : Utilizes

User --> BlockchainUtils : Via AlgoSigner

@enduml
```