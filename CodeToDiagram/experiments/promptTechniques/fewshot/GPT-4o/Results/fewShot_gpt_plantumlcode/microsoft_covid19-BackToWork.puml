```plantuml
@startuml microsoft_covid19-BackToWork
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Employee" as User

rectangle "Azure Functions" as Functions {
  rectangle "PostUserInfo" as PostUserInfo
  rectangle "PostSymptomsInfo" as PostSymptomsInfo
  rectangle "PostLabTestInfo" as PostLabTestInfo
  rectangle "PostRequestStatus" as PostRequestStatus
  rectangle "GetUserInfo" as GetUserInfo
  rectangle "GetSymptomsInfo" as GetSymptomsInfo
  rectangle "GetLabTestInfo" as GetLabTestInfo
  rectangle "GetRequestStatus" as GetRequestStatus
  rectangle "TriggerNotification" as TriggerNotification
}

database "Azure SQL Database" as SQLDB

rectangle "Microsoft Healthcare Bot" as HealthcareBot

rectangle "Notification System" as NotificationSystem {
  rectangle "SendGrid" as SendGrid
  rectangle "Microsoft Teams" as Teams
}

User --> PostUserInfo : submit personal info
User --> PostSymptomsInfo : submit symptoms
User --> PostLabTestInfo : submit lab results
User --> PostRequestStatus : request clearance

PostUserInfo --> SQLDB
PostSymptomsInfo --> SQLDB
PostLabTestInfo --> SQLDB
PostRequestStatus --> SQLDB

GetUserInfo --> SQLDB
GetSymptomsInfo --> SQLDB
GetLabTestInfo --> SQLDB
GetRequestStatus --> SQLDB

SQLDB --> HealthcareBot : fetch data
HealthcareBot --> SQLDB : update clearance status

TriggerNotification --> SendGrid : send email notifications
TriggerNotification --> Teams : send Teams notifications

GetUserInfo --> User : retrieve personal info
GetSymptomsInfo --> User : retrieve symptoms
GetLabTestInfo --> User : retrieve lab results
GetRequestStatus --> User : retrieve clearance status

@enduml
```