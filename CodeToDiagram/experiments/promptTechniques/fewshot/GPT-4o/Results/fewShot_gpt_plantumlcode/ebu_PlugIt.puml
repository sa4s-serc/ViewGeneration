```plantuml
@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Analysis System" as Analysis

rectangle "Google Gemini API" as Gemini {
  rectangle "gemini-2.0-flash" as Flash
}

package "Error Handling" {
  rectangle "Retry Logic" as Retry
  rectangle "Monitoring" as Monitor
  rectangle "Token Optimization" as Optimize
  rectangle "API Plan Upgrade" as Upgrade
  rectangle "Reduce Input Size" as Reduce
  rectangle "Caching" as Cache
}

package "API Response" {
  usecase "429 Error" as Error
  usecase "Retry Delay\n(10-12s)" as Delay
}

Analysis --> Flash : Request
Flash --> Error : HTTP 429
Flash --> Delay

Error --> Retry
Error --> Monitor
Error --> Optimize
Error --> Upgrade
Error --> Reduce
Error --> Cache

Monitor --> Analysis
@enduml
```