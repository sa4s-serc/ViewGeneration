```plantuml
@startuml usds_justice40-tool
left to right direction
skinparam rectangle {
  BorderColor black
  Style roundrect
}

package "Data Pipeline" {
  rectangle "runner.py" as Runner
  rectangle "base.py\nExtractTransformLoad" as Base
  rectangle "datasource.py" as DataSource
  rectangle "score_runner.py" as ScoreRunner
  rectangle "generate.py" as TileGeneration
}

package "Frontend" {
  rectangle "React App" as ReactApp
  rectangle "Map Display\n(Maplibre GL)" as MapDisplay
}

package "Configuration" {
  rectangle "settings.toml" as Settings
  rectangle "config/datasets.yml" as ConfigDatasets
}

package "Storage" {
  rectangle "Data Lake\n(S3)" as S3
}

package "ETL Process" {
  rectangle "Data Sources\n(Census, FEMA, EPA, etc.)" as DataSources
}

package "Scoring" {
  rectangle "ScoreA, ScoreB\nMethods" as ScoreMethods
}

User --> ReactApp
ReactApp --> MapDisplay

Settings --> Runner
ConfigDatasets --> Runner

DataSources --> DataSource
DataSource --> Base
Runner --> Base
Base --> S3

ScoreRunner --> ScoreMethods
ScoreMethods --> S3

TileGeneration --> S3
TileGeneration --> MapDisplay

@enduml
```