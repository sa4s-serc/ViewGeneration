```plantuml
@startuml mrubash1_trainspotting
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as user

package "Raspberry Pi System" {
  rectangle "Video_Camera" as Camera #lightblue
  rectangle "Video_Sensor" as Sensor #lightblue
  rectangle "Video_Detector" as Detector #lightblue
}

package "Processing" {
  rectangle "Background Subtraction" as BgSubtraction #lightyellow
  rectangle "TensorFlow Classification" as TFClassification #lightyellow
  rectangle "Direction Analysis" as DirectionAnalysis #lightyellow
}

package "Data Management" {
  rectangle "Data Storage" as DataStorage #lightgreen
  rectangle "Data Visualization" as DataVisualization #lightgreen
}

user --> Camera : Configure Settings
Camera --> Sensor : Capture Video Frames
Sensor --> BgSubtraction : Process Motion
BgSubtraction --> Detector : Detect Train
Detector --> DirectionAnalysis : Determine Direction
DirectionAnalysis --> DataStorage : Store Detection Events
DataStorage --> DataVisualization : Visualize Data
Detector --> TFClassification : Classify Objects
TFClassification --> DataVisualization : Display Results
@enduml
```