```plantuml
@startuml odh-labs_predictive-maint
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User"

package "Data Producer" {
  rectangle "Webcam\nCapture" as Webcam #lightblue
  rectangle "Event Producer\n(JavaScript)" as EventProducer #lightblue
}

package "Kafka Cluster" {
  rectangle "Kafka" as Kafka #orange
}

package "Model Serving" {
  rectangle "Seldon Core\nModel Server" as Seldon #lightgreen
  rectangle "Prediction\nAPI" as PredictionAPI #lightgreen
}

package "Data Storage & Visualization" {
  rectangle "MinIO\nObject Storage" as MinIO #lightyellow
  rectangle "Web Interface\n(Node.js)" as WebInterface #lightyellow
}

package "Consumer Application" {
  rectangle "Image Predictor\nConsumer" as Consumer #lightcoral
}

User --> Webcam
Webcam --> EventProducer
EventProducer --> Kafka : Publish Images
Kafka --> Consumer : Stream Images
Consumer --> Seldon : Request Inference
Seldon --> PredictionAPI : Expose Model
Consumer --> MinIO : Store Results
MinIO --> WebInterface : Serve Dashboard
User --> WebInterface : View Predictions
@enduml
```