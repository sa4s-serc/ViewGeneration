```plantuml
@startuml florianhoehn_sf-apex-rest-api
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam linetype ortho

actor "External System" as ExternalSystem

package "Salesforce" {
  rectangle "Inbound REST API" as InboundAPI {
    rectangle "ExampleRatingRestResource" as ExampleResource
  }

  rectangle "Outbound REST Callout" as OutboundCallout {
    rectangle "ExampleRatingCallout" as ExampleCallout
  }

  rectangle "Data Transformation" as DataTransformation {
    rectangle "RestWrapper" as RestWrapper
    rectangle "RestResponse" as RestResponse
  }

  rectangle "Logging" as Logging {
    rectangle "RestLogBuilder" as LogBuilder
    database "Rest_Log__c" as LogObject
  }
}

ExternalSystem --> ExampleResource : Request
ExampleResource --> RestWrapper : Deserialize
ExampleResource --> ExampleCallout : Invoke
ExampleCallout --> RestWrapper : Serialize
ExampleCallout --> ExternalSystem : HTTP Request
ExampleCallout --> RestResponse : Handle Response
ExampleCallout --> LogBuilder : Log Interaction
LogBuilder --> LogObject : Create Log Record

@enduml
```