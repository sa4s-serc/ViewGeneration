```plantuml
@startuml cordon-thiago_airflow-spark
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho

package "Data Processing System" {
    [Spark Core] as SparkCore
    [Spark SQL] as SparkSQL
    [Spark MLlib] as SparkMLlib
    [Spark Streaming] as SparkStreaming
    [GraphX] as GraphX

    SparkSQL -up-> SparkCore
    SparkMLlib -up-> SparkCore
    SparkStreaming -up-> SparkCore
    GraphX -up-> SparkCore
}

package "Integration Components" {
    [Apache Airflow] as Airflow
    [Kubernetes] as Kubernetes
    [PostgreSQL] as PostgreSQL
    [SparkR] as SparkR
    [Java Interoperability] as JavaInterop
}

package "Deployment Environment" {
    [Docker] as Docker
    [Jupyter Notebooks] as Jupyter
}

SparkCore <-up-> JavaInterop
SparkCore <-up-> SparkR
SparkCore <-up-> PostgreSQL

Airflow -up-> Docker
Kubernetes -up-> Docker

Airflow --- SparkCore : orchestrates
Kubernetes --- SparkCore : deploys
Docker --- SparkCore : containerizes
Jupyter --- SparkCore : interactive env

@enduml
```