```plantuml
@startuml exmgr_GatewayXM
left to right direction
skinparam rectangle {
  BackgroundColor #f3f3f3
  BorderColor black
  Style roundrect
}

package "IoT Gateway" {
  rectangle "Eclipse Kura" as Kura #lightblue
  rectangle "Agile-Stack" as AgileStack #lightgreen
  rectangle "Kura Bundle\n(Thingsboard Integration)" as KuraBundle #lightblue
  rectangle "Gateway\nOTA Updates" as GatewayOTA #lightblue
}

package "Sensor Nodes" {
  rectangle "ESP8266/ESP32" as ESP #lightyellow
  rectangle "Arduino Firmware" as ArduinoFW #lightyellow
  rectangle "Mesh Network" as MeshNetwork #lightyellow
  rectangle "Sensor Node\nOTA Updates" as SensorOTA #lightyellow
}

package "External Services" {
  rectangle "Thingsboard IoT Platform" as Thingsboard #lightpink
  rectangle "Artemis MQTT Broker" as MQTT #lightpink
  rectangle "Resin.io (Balena)" as Resin #lightpink
}

ESP --> MeshNetwork
ESP --> ArduinoFW
ESP --> SensorOTA
MeshNetwork --> MQTT : Publish Telemetry Data
MQTT --> KuraBundle : Subscribe to Data
Kura --> KuraBundle
Kura --> GatewayOTA
KuraBundle --> Thingsboard
Kura --> AgileStack
AgileStack --> Resin
Resin --> Kura
@enduml
```