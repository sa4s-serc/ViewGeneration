```plantuml
@startuml nforge_devnote
left to right direction
skinparam rectangle {
  BackgroundColor #f3f4f5
  BorderColor black
  Style roundrect
}

package "Frontend" {
  rectangle "HTML (Jade Templates)" as Templates
  rectangle "JavaScript (jQuery)" as JavaScript
  rectangle "CSS (Bootstrap)" as CSS
  rectangle "Markdown Editor\n(CodeMirror 2)" as CodeMirror
}

package "Backend" {
  rectangle "Node.js\nExpress Server" as Express
  rectangle "Socket.IO" as SocketIO
  rectangle "Git Storage" as Git
  rectangle "Core Logic\n(lib/)" as CoreLogic
}

package "Supporting Components" {
  rectangle "Authentication\n(userApp.coffee)" as Auth
  rectangle "File Handling\n(fileApp.coffee)" as FileHandling
  rectangle "Admin Tasks\n(adminApp.coffee)" as AdminTasks
  rectangle "Wiki Functionality\n(wikiApp.coffee)" as Wiki
  rectangle "Localization\n(locales/)" as Localization
}

package "Testing" {
  rectangle "Mocha Tests" as Mocha
  rectangle "Travis CI\n(.travis.yml)" as Travis
  rectangle "Makefile" as Makefile
}

package "Configuration" {
  rectangle "config.js" as Config
  rectangle "Routing\n(routes/index.js)" as Routing
}

package "Utilities" {
  rectangle "Markdown Rendering\n(showdown.js)" as MarkdownRender
  rectangle "Syntax Highlighting\n(highlight.js)" as SyntaxHighlight
}

Frontend --> Express
Frontend --> SocketIO
Express --> Git
Express --> CoreLogic
Express --> Routing

CoreLogic --> Wiki
CoreLogic --> Auth
CoreLogic --> FileHandling
CoreLogic --> AdminTasks
CoreLogic --> Localization

Testing --> CoreLogic
Testing --> Git

Utilities --> Frontend

Config --> Express
@enduml
```