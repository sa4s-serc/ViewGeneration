```plantuml
@startuml lvyahui8_http-proxy

package "Proxy Server" {
    [HttpProxyServer] -> [ClientToProxyHandler]
    [ClientToProxyHandler] -> [ProxyToServerInboundHandler]
    [ClientToProxyHandler] --> [EntitysManager]
    [EntitysManager] --> [entitys.json]
    [ProxyToServerInboundHandler] -> [ProxyResponseFilter]
    [ProxyRequestFilter] --> [ClientToProxyHandler]
    [ProxyResponseFilter] --> [ProxyToServerInboundHandler]
    [GlobalExceptionHandler] <-- [HttpProxyServer]
}

package "Test Client" {
    [TestClientApp]
}

package "Test Server" {
    [TestServerMain] --> [TestResource]
}

package "Configuration" {
    [log4j2.xml]
    [pom.xml]
}

package "Libraries" {
    [Netty]
    [Log4j2]
    [Gson]
    [Commons Configuration]
}

[HttpProxyServer] ..> [Netty]
[HttpProxyServer] ..> [Log4j2]
[HttpProxyServer] ..> [Gson]
[HttpProxyServer] ..> [Commons Configuration]

@enduml
```