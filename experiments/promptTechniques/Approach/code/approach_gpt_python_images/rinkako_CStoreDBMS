// Rinkako_CStoreDB Architecture
digraph {
	node [color=lightblue shape=rectangle style=filled]
	edge [arrowhead=normal]
	DBInterface [label="DBInterface
(DBController, DBConnectionPool)"]
	DBCompiler [label="DBCompiler
(LexicalAnalyzer, SyntaxParser, Pile, CSDatabase, DBBridge)"]
	DBEngine [label="DBEngine
(FileManager, TableManager, DBAllocator, DBLock, DBTransaction)"]
	DBInterface -> DBCompiler [label=calls]
	DBCompiler -> DBEngine [label=executes]
	Singleton [label="Singleton
(FileManager, DBAllocator, DBConnectionPool, TableManager)" color=lightgrey]
	"Base Class" [label="Base Class
(DBObject)" color=lightgrey]
	Bridge [label="Bridge
(DBBridge)" color=lightgrey]
	DBEngine -> Singleton [label=uses style=dashed]
	DBEngine -> "Base Class" [label=extends style=dashed]
	DBCompiler -> Bridge [label=implements style=dashed]
}
