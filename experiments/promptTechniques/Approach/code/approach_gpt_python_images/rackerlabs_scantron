// Scantron Architecture
digraph {
	rankdir=LR size="8,5"
	Console [label="Console (Web Front-End)" color=lightblue shape=rectangle style=filled]
	API [label="REST API" color=lightcoral shape=ellipse style=filled]
	Engines [label="Engines (Scanning Nodes)" color=lightgreen shape=rectangle style=filled]
	NFS [label="Shared NFS Volume" color=lightgrey shape=cylinder style=filled]
	Email [label="Email Alerts" color=lightyellow shape=octagon style=filled]
	Ansible [label="Ansible Playbooks" color=lightpink shape=parallelogram style=filled]
	Queue [label="Redis Queue" color=lightgoldenrod1 shape=diamond style=filled]
	Console -> API [label="Communicates through" arrowhead=vee]
	Engines -> API [label="Polls for tasks" arrowhead=vee]
	Engines -> NFS [label="Stores results" arrowhead=vee]
	NFS -> Console [label="Processes results" arrowhead=vee]
	Console -> Email [label="Sends alerts" arrowhead=vee]
	Ansible -> Console [label=Deploys arrowhead=vee]
	Ansible -> Engines [label=Deploys arrowhead=vee]
	Console -> Queue [label="Queues tasks" arrowhead=vee]
}
