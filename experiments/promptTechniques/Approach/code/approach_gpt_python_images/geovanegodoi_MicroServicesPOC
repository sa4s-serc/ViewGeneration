// MicroServicesPOC Architecture
digraph {
	Catalog [label="Catalog Microservice" fillcolor=lightblue shape=rectangle style=filled]
	Customer [label="Customer Microservice" fillcolor=lightgreen shape=rectangle style=filled]
	Order [label="Order Microservice" fillcolor=lightcoral shape=rectangle style=filled]
	CatalogDB [label=CatalogDB fillcolor=lightgrey shape=cylinder style=filled]
	CustomerDB [label=CustomerDB fillcolor=lightgrey shape=cylinder style=filled]
	OrderDB [label=OrderDB fillcolor=lightgrey shape=cylinder style=filled]
	RabbitMQ [label=RabbitMQ fillcolor=orange shape=ellipse style=filled]
	Catalog -> CatalogDB [label=CRUD]
	Customer -> CustomerDB [label=CRUD]
	Order -> OrderDB [label=CRUD]
	Catalog -> RabbitMQ [label="Publish/Subscribe"]
	Customer -> RabbitMQ [label="Publish/Subscribe"]
	Order -> RabbitMQ [label="Publish/Subscribe"]
	Catalog -> Customer [label="Event: CustomerUpdated" dir=both]
	Customer -> Order [label="Event: OrderCreated" dir=both]
	Order -> Catalog [label="Event: CatalogItemCreated" dir=both]
}
