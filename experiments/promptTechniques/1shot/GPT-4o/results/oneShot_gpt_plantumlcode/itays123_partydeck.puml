```plantuml
@startuml itays123_partydeck
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<deployment>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Panel (React Frontend)" <<frontend>> {
  rectangle "Card Deck Management" as CardDeck
  rectangle "User Authentication" as Auth
  rectangle "Game Library" as Library
  CardDeck --> Auth
  Auth --> Library
}

package "Server (Java Backend)" <<backend>> {
  rectangle "WebSocket Communication" as WebSocket
  rectangle "Game State Management" as GameState
  rectangle "Player Actions" as PlayerActions
  rectangle "Game Code\nGeneration & Validation" as GameCode
  rectangle "REST API Endpoints" as RESTAPI
  GameState --> PlayerActions
  PlayerActions --> GameCode
  RESTAPI --> GameCode
  WebSocket --> GameState
}

package "Game (React Frontend)" <<frontend>> {
  rectangle "Connect to Server" as ConnectServer
  rectangle "Display Cards & Info" as Display
  rectangle "Capture User Input" as UserInput
  ConnectServer --> Display
  Display --> UserInput
}

package "Deployment" <<deployment>> {
  rectangle "Google Cloud Run" as GCRun
  rectangle "Google Cloud Build" as GCBuild
  CardDeck --> GCRun
  WebSocket --> GCRun
  ConnectServer --> GCRun
  GCRun --> GCBuild
}

@enduml
```