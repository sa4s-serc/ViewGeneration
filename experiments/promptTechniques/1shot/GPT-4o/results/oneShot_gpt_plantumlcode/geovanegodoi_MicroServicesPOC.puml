```plantuml
@startuml geovanegodoi_MicroServicesPOC
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Catalog Service" as CatalogService #lightblue {
  rectangle "Catalog DB" as CatalogDB #lightgrey
}

rectangle "Customer Service" as CustomerService #lightcyan {
  rectangle "Customer DB" as CustomerDB #lightgrey
}

rectangle "Order Service" as OrderService #lightyellow {
  rectangle "Order DB" as OrderDB #lightgrey
}

rectangle "RabbitMQ" as RabbitMQ #lightpink

' ========== User Interactions ==========
User --> CatalogService : CRUD operations on catalog items
User --> CustomerService : CRUD operations on customer info
User --> OrderService : Create and manage orders

' ========== Internal Interactions ==========
CatalogService --> RabbitMQ : publish CatalogItemCreated event
RabbitMQ --> OrderService : consume CatalogItemCreated event

CustomerService --> RabbitMQ : publish CustomerUpdated event
RabbitMQ --> OrderService : consume CustomerUpdated event

OrderService --> RabbitMQ : publish OrderCreated event
RabbitMQ --> CustomerService : consume OrderCreated event to update order history

' ========== Database Interactions ==========
CatalogService --> CatalogDB : Read/Write catalog data
CustomerService --> CustomerDB : Read/Write customer data
OrderService --> OrderDB : Read/Write order data

@enduml
```