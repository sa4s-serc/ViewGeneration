```plantuml
@startuml jquku_Matrix-Chatbot
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Matrix Homeserver" as MatrixServer #lightyellow

rectangle "Chatbot System" as Chatbot #aliceblue {
  rectangle "Main Module" as MainModule #lightsteelblue
  rectangle "Message Evaluation" as MsgEvaluation #lightgreen
  rectangle "NLP Pipeline" as NLP #lightcoral
  rectangle "Response Management" as ResponseMgmt #lightgoldenrodyellow
  rectangle "Database Service" as DatabaseService #lightpink
}

rectangle "PostgreSQL Database" as Database #mistyrose

' ========== Connections ==========
User --> MatrixServer : sendMessage()

' Main Module interactions
MatrixServer --> MainModule : receiveMessage()
MainModule --> MsgEvaluation : evaluateMessage()
MsgEvaluation --> NLP : processInput()
NLP --> MsgEvaluation : returnProcessedInput()
MsgEvaluation --> DatabaseService : queryKnowledgeBase()
DatabaseService --> Database : executeQuery()
Database --> DatabaseService : returnData()
DatabaseService --> MsgEvaluation : returnResults()
MsgEvaluation --> ResponseMgmt : generateResponse()
ResponseMgmt --> MainModule : sendResponse()
MainModule --> MatrixServer : sendMessage()

@enduml
```