```plantuml
@startuml bluekiri_mlab
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "MLAB Dashboard" <<frontend>> {
  rectangle "Flask App\n(app.py)" as FlaskApp
  rectangle "Flask-Security\n(Authentication & Authorization)" as FlaskSecurity
  rectangle "API Endpoints\n(api_dashboard.py)" as APIEndpoints
  rectangle "HTML Templates\n(AdminLTE, jQuery)" as HTMLTemplates
  rectangle "Interactors\n(Use Cases)" as Interactors
  rectangle "Repositories\n(MongoDB, ZooKeeper)" as Repositories
  rectangle "Model Publisher\n(MLModelPublisherView)" as ModelPublisher
  FlaskApp --> FlaskSecurity
  FlaskApp --> APIEndpoints
  FlaskApp --> HTMLTemplates
  FlaskApp --> Interactors
  FlaskApp --> Repositories
  FlaskApp --> ModelPublisher
}

package "Worker Service" <<backend>> {
  rectangle "Model Management\n(ModelRepository)" as ModelManagement
  rectangle "ZooKeeper Integration\n(WorkerRepository)" as ZKIntegration
  rectangle "Error Handling\n(UnpickleModelException)" as ErrorHandling
  rectangle "Logging\n(Python logging)" as Logging
  rectangle "HTTP API\n(Falcon Controllers)" as HTTPAPI
  rectangle "Model Change Listener" as ModelChangeListener
  ModelManagement --> ZKIntegration
  ModelManagement --> ErrorHandling
  ModelManagement --> Logging
  ModelManagement --> HTTPAPI
  ZKIntegration --> ModelChangeListener
}

package "Integrations" <<integration>> {
  rectangle "ZooKeeper" as ZK
  rectangle "MongoDB" as MongoDB
  rectangle "Docker" as Docker
  FlaskApp --> ZK
  FlaskApp --> MongoDB
  ModelManagement --> MongoDB
  ZKIntegration --> ZK
}

database "Data Storage\n(Model Metadata, Logs, Messages)" <<db>> as DataStorage
Repositories --> DataStorage
ModelManagement --> DataStorage
@enduml
```