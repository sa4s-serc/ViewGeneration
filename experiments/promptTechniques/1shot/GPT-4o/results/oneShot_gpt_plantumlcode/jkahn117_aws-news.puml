```plantuml
@startuml jkahn117_aws-news
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Next.js Frontend" as Frontend #lightblue

rectangle "AWS" as AWS #lightyellow {
  rectangle "AppSync API" as AppSync
  rectangle "Lambda Functions" as Lambda {
    rectangle "RSS Feed Ingestion\nRuby Function" as RSSIngestion
    rectangle "Image Processing\nNode.js Function" as ImageProcessing
  }
  rectangle "DynamoDB" as DynamoDB
  rectangle "S3" as S3
  rectangle "ElastiCache for Redis" as ElastiCache
  rectangle "CloudFront CDN" as CloudFront
  rectangle "EventBridge" as EventBridge
  rectangle "Kinesis Data Firehose" as Kinesis
}

' ========== Connections ==========
User --> Frontend

' Frontend interactions
Frontend --> AppSync : Request articles
AppSync --> ElastiCache : Check cache for articles
AppSync --> DynamoDB : Query articles if not in cache
AppSync --> Frontend : Return articles
Frontend --> CloudFront : Load static assets

' Backend interactions
RSSIngestion --> EventBridge : Emit "article_created" event
EventBridge --> ImageProcessing : Trigger image processing
RSSIngestion --> S3 : Store article content
RSSIngestion --> DynamoDB : Store metadata
ImageProcessing --> S3 : Store processed images
ImageProcessing --> DynamoDB : Update image metadata

' Analytics
Frontend --> Kinesis : Stream user interaction data

@enduml
```