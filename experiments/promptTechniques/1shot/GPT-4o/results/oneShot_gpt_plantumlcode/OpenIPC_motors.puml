```plantuml
@startuml OpenIPC_motors
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor CameraApp

rectangle "Motors Daemon" as Daemon {
}

rectangle "Driver Wrapper Layer" as DriverWrapper #lightgrey {
  rectangle "GPIO Driver" as GPIODriver #lightyellow
  rectangle "I2C Driver" as I2CDriver #lightyellow
  rectangle "SPI Driver\n(AN41908A)" as SPIDriver #lightyellow
  rectangle "UART Driver\n(Pelco-D)" as UARTDriver #lightyellow
}

rectangle "Kernel Driver Layer" as KernelDriver #lightblue {
  rectangle "GPIO Kernel Module" as GPIOKernel #aliceblue
  rectangle "I2C Kernel Module" as I2CKernel #aliceblue
  rectangle "SPI Kernel Module" as SPIKernel #aliceblue
  rectangle "UART Kernel Module" as UARTKernel #aliceblue
}

rectangle "Hardware Layer" as Hardware #mistyrose {
  rectangle "Motor Hardware" as Motors #palegreen
}

' ========== Connections ==========
CameraApp --> Daemon : send motor control commands
Daemon --> DriverWrapper : select appropriate driver\nbased on hardware

' GPIO Control Flow
DriverWrapper --> GPIODriver : adapt command to GPIO
GPIODriver --> GPIOKernel : ioctl commands
GPIOKernel --> Motors : direct motor control

' I2C Control Flow
DriverWrapper --> I2CDriver : adapt command to I2C
I2CDriver --> I2CKernel : ioctl with I2C data
I2CKernel --> Motors : I2C communication

' SPI Control Flow
DriverWrapper --> SPIDriver : adapt command to SPI
SPIDriver --> SPIKernel : ioctl for SPI operations
SPIKernel --> Motors : SPI communication

' UART Control Flow
DriverWrapper --> UARTDriver : adapt command to UART
UARTDriver --> UARTKernel : ioctl with UART data
UARTKernel --> Motors : UART communication

@enduml
```