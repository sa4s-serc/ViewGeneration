```plantuml
@startuml ankithans_codeX
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (ReactJS)" <<frontend>> {
  rectangle "App.js" as AppMain
  rectangle "Navbar.js" as Navbar
  rectangle "PseudoCode.js" as PseudoCode
  rectangle "Warnings.js" as Warnings
  rectangle "Compile.js" as Compile
  AppMain --> Navbar
  AppMain --> PseudoCode
  AppMain --> Warnings
  AppMain --> Compile
}

package "Backend (FastAPI)" <<backend>> {
  rectangle "main.py\n(Uvicorn Server)" as Main
  rectangle "app/app.py\n(API Gateway)" as API
  package "Routes" {
    rectangle "compile.py" as CompileRoute
    rectangle "convertPseudo.py" as ConvertPseudoRoute
    rectangle "warnings.py" as WarningsRoute
    rectangle "translatePseudo.py" as TranslatePseudoRoute
    rectangle "shareCode.py" as ShareCodeRoute
    rectangle "flowchart.py" as FlowchartRoute
  }
  package "Services" {
    rectangle "pylint.py" as PylintService
    rectangle "pseudo_code.py" as PseudoService
    rectangle "hackerearth_compile.py" as HECompileService
    rectangle "translate.py" as TranslateService
    rectangle "flowchart.py" as FlowchartService
  }
  API --> CompileRoute
  API --> ConvertPseudoRoute
  API --> WarningsRoute
  API --> TranslatePseudoRoute
  API --> ShareCodeRoute
  API --> FlowchartRoute
  CompileRoute --> HECompileService
  ConvertPseudoRoute --> PseudoService
  WarningsRoute --> PylintService
  TranslatePseudoRoute --> TranslateService
  FlowchartRoute --> FlowchartService
}

database "SQLite\n(Code Sharing)" as SQLiteDB
ShareCodeRoute --> SQLiteDB
@enduml
```