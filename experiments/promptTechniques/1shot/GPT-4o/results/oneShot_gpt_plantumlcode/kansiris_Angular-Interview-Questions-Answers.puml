```plantuml
@startuml kansiris_Angular-Interview-Questions-Answers
skinparam rectangle {
  BackgroundColor<<content>> #f0e68c
  BackgroundColor<<navigation>> #add8e6
  BackgroundColor<<licensing>> #98fb98
  Style roundrect
}
skinparam defaultTextAlignment center

package "Angular Interview Q&A Repository" {
  package "Content" <<content>> {
    rectangle "Q&A Collection" as QA
    rectangle "Code Examples" as Code
    QA --> Code
  }
  
  package "Navigation" <<navigation>> {
    rectangle "README.md" as Readme
    rectangle "TOC" as TOC
    Readme --> TOC
  }
  
  package "Licensing" <<licensing>> {
    rectangle "LICENSE File" as License
  }
}

QA --> Readme
Readme --> License
@enduml
```