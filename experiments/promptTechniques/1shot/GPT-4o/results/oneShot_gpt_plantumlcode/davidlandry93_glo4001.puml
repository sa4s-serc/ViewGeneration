```plantuml
@startuml davidlandry93_glo4001
skinparam rectangle {
  BackgroundColor<<rendering>> #d9e7fd
  BackgroundColor<<robotic_control>> #d8f5d3
  BackgroundColor<<data_handling>> #fddddd
  BackgroundColor<<common>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "3D Rendering and Visualization" <<rendering>> {
  rectangle "Three.js\n(Core Rendering)" as ThreeJS
  rectangle "Potree\n(Point Cloud Rendering)" as Potree
  rectangle "WebGLRenderer" as WebGL
  rectangle "LAS/LAZ Decoders" as Decoders
  rectangle "Shader System" as Shaders
  ThreeJS --> Potree
  Potree --> Decoders
  ThreeJS --> WebGL
  ThreeJS --> Shaders
}

package "Robotic Control and Sensing" <<robotic_control>> {
  rectangle "Robot Control" as RobotControl
  rectangle "Sensor Data Acquisition" as SensorData
  rectangle "Point Cloud Processing" as PointCloud
  rectangle "Iterative Closest Point (ICP)" as ICP
  rectangle "ROS Integration" as ROS
  ROS --> RobotControl
  ROS --> SensorData
  SensorData --> PointCloud
  PointCloud --> ICP
}

package "Geometric Data Handling" <<data_handling>> {
  rectangle "CZML Processing" as CZML
  rectangle "Data Sources" as DataSources
  rectangle "Animation" as Animation
  rectangle "Appearance System" as Appearance
  CZML --> DataSources
  DataSources --> Appearance
  CZML --> Animation
}

package "Architectural Design" <<common>> {
  rectangle "Component-Based Architecture" as ComponentBased
  rectangle "Plugin Architecture" as Plugin
  rectangle "Observer Pattern" as Observer
  rectangle "Factory Pattern" as Factory
  rectangle "Command Pattern" as Command
  rectangle "Flyweight Pattern" as Flyweight
  ComponentBased -[hidden]--> Plugin
  Plugin -[hidden]--> Observer
  Observer -[hidden]--> Factory
  Factory -[hidden]--> Command
  Command -[hidden]--> Flyweight
}

@enduml
