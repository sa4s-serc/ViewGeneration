```plantuml
@startuml IBM_ios-mapkit-indoor-map
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "iOS Application" as IOSApp {
  rectangle "ViewController.swift" as ViewController
  rectangle "FloorplanOverlay.swift" as FloorplanOverlay
  rectangle "CoordinateConverter.swift" as CoordinateConverter
  rectangle "VisibleMapRegionDelegate.swift" as MapRegionDelegate
}

rectangle "Backend (Node.js)" as Backend {
  rectangle "app.js" as AppJS
  rectangle "routes/*.js" as Routes
  rectangle "models/*.js" as Models
}

rectangle "Database" as MongoDB #lightyellow

User --> ViewController : Launch app

ViewController --> AppJS : Fetch PDF floorplan and event data
AppJS --> MongoDB : Retrieve map and event data
MongoDB --> AppJS : Return map and event data
AppJS --> ViewController : Send map and event data

ViewController --> FloorplanOverlay : Load PDF floorplan
FloorplanOverlay --> CoordinateConverter : Convert PDF to geo coordinates

ViewController --> MapRegionDelegate : Manage map camera
MapRegionDelegate --> ViewController : Restrict scrolling/zooming

ViewController --> FloorplanOverlay : Render heatmap overlay

ViewController --> AppJS : [Optional] Trigger event via POST request
@enduml
```