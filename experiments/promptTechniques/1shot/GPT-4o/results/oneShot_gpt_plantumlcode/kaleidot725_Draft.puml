```plantuml
@startuml kaleidot725_Draft

skinparam rectangle {
  BackgroundColor<<app>> #f3e5f5
  BackgroundColor<<domain>> #e8f5e9
  BackgroundColor<<data>> #e1f5fe
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

package "App Module" <<app>> {
  rectangle "ComposeMainActivity.kt" as MainActivity
  rectangle "EmomemoApp.kt" as EmomemoApp
  rectangle "UI Pages\n(Notebook, Memo, Add, Edit, Delete, Detail)" as UIPages
  rectangle "ViewModels" as ViewModels
  MainActivity --> EmomemoApp
  MainActivity --> UIPages
  UIPages --> ViewModels
}

package "Domain Module" <<domain>> {
  rectangle "Use Cases" as UseCases
  rectangle "Repositories" as Repositories
  ViewModels --> UseCases
  UseCases --> Repositories
}

package "Data Module" <<data>> {
  rectangle "Room Database\n(AppDatabase.kt)" as RoomDB
  rectangle "DAOs & Entities" as DAOs
  Repositories --> DAOs
  DAOs --> RoomDB
}

User --> MainActivity

@enduml
