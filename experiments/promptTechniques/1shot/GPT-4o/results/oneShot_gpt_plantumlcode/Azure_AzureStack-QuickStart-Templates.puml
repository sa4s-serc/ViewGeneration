```plantuml
@startuml Azure_AzureStack-QuickStart-Templates
skinparam rectangle {
  BackgroundColor<<template>> #d9e7fd
  BackgroundColor<<script>> #d8f5d3
  BackgroundColor<<config>> #fddddd
  BackgroundColor<<documentation>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "ARM Templates" <<template>> {
  rectangle "azuredeploy.json" as ARMTemplate
  rectangle "azuredeploy.parameters.json" as ARMParam
  ARMTemplate --> ARMParam
}

package "Scripts" <<script>> {
  rectangle "PowerShell Scripts" as PSScripts
  rectangle "Shell Scripts" as ShScripts
  rectangle "DSC Configurations" as DSC
  PSScripts --> DSC
  ShScripts --> ARMTemplate
}

package "Configuration Files" <<config>> {
  rectangle "XML/YML/Config" as ConfigFiles
  rectangle "Geth Configuration" as GethConfig
  ARMTemplate --> ConfigFiles
  ShScripts --> GethConfig
}

package "Documentation" <<documentation>> {
  rectangle "README.md" as README
  rectangle "SECURITY.md" as SECURITY
  rectangle "License.txt" as License
  ARMTemplate --> README
  PSScripts --> SECURITY
}

package "Validation" <<script>> {
  rectangle "Validation Scripts" as ValidationScripts
  ValidationScripts --> ARMTemplate
}

rectangle "Azure" as Azure
rectangle "Azure Stack" as AzureStack
Azure --> ARMTemplate
AzureStack --> ARMTemplate

@enduml
```