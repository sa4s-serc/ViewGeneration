```plantuml
@startuml matryx_MatryxPlatform
skinparam rectangle {
  BackgroundColor<<smart_contract>> #d8f5d3
  BackgroundColor<<javascript>> #d9e7fd
  BackgroundColor<<documentation>> #fddddd
  BackgroundColor<<testing>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Smart Contracts (Solidity)" <<smart_contract>> {
  rectangle "MatryxPlatform.sol" as MatryxPlatform
  rectangle "MatryxSystem.sol" as MatryxSystem
  rectangle "MatryxForwarder.sol" as MatryxForwarder
  rectangle "LibPlatform.sol" as LibPlatform
  rectangle "LibCommit.sol" as LibCommit
  rectangle "LibTournament.sol" as LibTournament
  rectangle "MatryxToken.sol" as MatryxToken

  MatryxPlatform --> LibPlatform
  MatryxPlatform --> LibCommit
  MatryxPlatform --> LibTournament
  MatryxPlatform --> MatryxForwarder
  MatryxPlatform --> MatryxSystem
  MatryxPlatform --> MatryxToken
}

package "Javascript/Build" <<javascript>> {
  rectangle "truffle-config.js" as TruffleConfig
  rectangle "truffle/utils.js" as TruffleUtils
  rectangle "migrations/" as Migrations
  rectangle "generate-setup/" as GenerateSetup

  TruffleUtils --> MatryxPlatform
}

package "Testing/Deployment" <<testing>> {
  rectangle "truffle/test.js" as TruffleTest
  rectangle "truffle/benchmark.js" as TruffleBenchmark
  rectangle "truffle/network.js" as TruffleNetwork

  TruffleTest --> TruffleUtils
  TruffleBenchmark --> TruffleUtils
  TruffleNetwork --> TruffleConfig
}

package "Documentation" <<documentation>> {
  rectangle "index.rst" as IndexRST
  rectangle "searchtools.js" as SearchTools
}

@enduml
```