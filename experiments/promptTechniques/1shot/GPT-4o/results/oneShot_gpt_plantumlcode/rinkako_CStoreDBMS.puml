```plantuml
@startuml rinkako_CStoreDBMS

skinparam rectangle {
  BackgroundColor<<dbinterface>> #d9e7fd
  BackgroundColor<<dbcompiler>> #d8f5d3
  BackgroundColor<<dbengine>> #fddddd
  BackgroundColor<<utilities>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "DBInterface" <<dbinterface>> {
  rectangle "DBController" as DBController
  rectangle "DBConnectionPool" as DBConnectionPool
  DBController --> DBConnectionPool
}

package "DBCompiler" <<dbcompiler>> {
  rectangle "LexicalAnalyzer" as LexicalAnalyzer
  rectangle "SyntaxParser" as SyntaxParser
  rectangle "Pile" as Pile
  rectangle "CSDatabase" as CSDatabase
  rectangle "DBBridge" as DBBridge
  LexicalAnalyzer --> SyntaxParser
  SyntaxParser --> Pile
  Pile --> CSDatabase
  DBBridge --> CSDatabase
  DBConnectionPool --> DBBridge
}

package "DBEngine" <<dbengine>> {
  rectangle "FileManager" as FileManager
  rectangle "TableManager" as TableManager
  rectangle "DBAllocator" as DBAllocator
  rectangle "DBLock" as DBLock
  rectangle "DBTransaction" as DBTransaction
  CSDatabase --> FileManager
  CSDatabase --> TableManager
  CSDatabase --> DBAllocator
  CSDatabase --> DBLock
  CSDatabase --> DBTransaction
}

package "Utilities & Base Classes" <<utilities>> {
  rectangle "DBCommonUtils" as DBCommonUtils
  rectangle "DBObject" as DBObject
  DBObject --> DBController
  DBObject --> DBConnectionPool
  DBObject --> LexicalAnalyzer
  DBObject --> SyntaxParser
  DBObject --> Pile
  DBObject --> CSDatabase
  DBObject --> FileManager
  DBObject --> TableManager
  DBObject --> DBAllocator
  DBObject --> DBLock
  DBObject --> DBTransaction
  DBObject --> DBBridge
}

@enduml
```