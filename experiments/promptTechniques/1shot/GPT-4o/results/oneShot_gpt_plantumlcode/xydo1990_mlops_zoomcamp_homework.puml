```plantuml
@startuml xydo1990_mlops_zoomcamp_homework
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Jupyter Notebooks" as Notebooks #lightyellow
rectangle "Python Scripts" as Scripts #lightcyan {
  rectangle "train_model.py" as TrainModel
  rectangle "get_data.py" as GetData
}
rectangle "MLflow" as MLflow #palegreen
rectangle "Docker" as Docker #lightsteelblue {
  rectangle "Batch Prediction Service" as BatchService
  rectangle "Streaming Prediction Service" as StreamService
  rectangle "MLflow Tracking Server" as MLflowServer
}
rectangle "Prefect" as Prefect #thistle
rectangle "Evidently" as Evidently #aliceblue
rectangle "CI/CD" as CICD #lavender {
  rectangle "GitHub Actions" as GitHubActions
}

' ========== Connections ==========
User --> Notebooks : Perform Data Exploration

' Data and Model Training
Notebooks --> Scripts : Execute Scripts
Scripts --> MLflow : Log Experiments\nTrack Models

' Model Deployment
MLflow --> Docker : Deploy Model\nvia Docker
Docker --> BatchService : Start Batch Service
Docker --> StreamService : Start Streaming Service

' Workflow Orchestration
Prefect --> BatchService : Orchestrate Batch Inference\non Schedule

' Model Monitoring
Evidently --> BatchService : Monitor Performance\nDetect Drift
Evidently --> StreamService : Monitor Performance\nDetect Drift

' CI/CD
CICD --> GitHubActions : Run Tests\non Code Push
GitHubActions --> Docker : Build Containers\nDeploy Services
@enduml
```