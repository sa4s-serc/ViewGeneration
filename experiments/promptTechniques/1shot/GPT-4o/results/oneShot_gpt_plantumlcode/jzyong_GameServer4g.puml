```plantuml
@startuml jzyong_GameServer4g
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Client

rectangle "ZooKeeper" as ZK #lightyellow

rectangle "Gateway" as Gate #lightblue {
  rectangle "UserManager" as UserManager
  rectangle "ClientManager" as ClientManager
  rectangle "GameManager" as GameManager
}

rectangle "Hall" as Hall #lightgreen {
  rectangle "HallManager" as HallManager
  rectangle "ClientManager" as HallClientManager
}

rectangle "World" as World #lightpink {
  rectangle "WorldManager" as WorldManager
}

rectangle "Resource" as Resource #aliceblue

' ========== Connections ==========
Client --> Gate : TCP Connection\nvia custom protocol
Gate --> ZK : register/discover services
Hall --> ZK : register/discover services
World --> ZK : register/discover services

Gate --> Hall : gRPC Communication
Hall --> World : gRPC Communication
Gate --> World : gRPC Communication

ZK <--> HallManager : Service Discovery
HallManager <--> HallClientManager : Manage Connections
GameManager <--> UserManager : Manage User Data/Sessions
ClientManager <--> GameManager : Handle Connections
WorldManager <--> World : Manage World Logic

@enduml
```