```plantuml
@startuml SafeBreach-Labs_hAFL2

skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<drivers>> #fddddd
  BackgroundColor<<kvm>> #d8f5d3
  BackgroundColor<<tools>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Fuzzing Implementation (kAFL)" <<core>> {
  rectangle "kafl_fuzz.py" as Fuzz
  rectangle "kafl_gui.py" as GUI
  rectangle "master.py" as Master
  rectangle "slave.py" as Slave
  rectangle "kafl_user_prepare.py" as Prepare
  rectangle "kafl_cov.py" as Coverage
  rectangle "kafl_debug.py" as Debug
  rectangle "kafl_plot.py" as Plot
  Fuzz --> Master
  Master --> Slave
  Slave --> Fuzz
  Fuzz --> GUI
  Fuzz --> Prepare
  Fuzz --> Coverage
  Fuzz --> Debug
  Fuzz --> Plot
}

package "Drivers" <<drivers>> {
  rectangle "CPHarness.sys" as CPHarness
  rectangle "CrashMonitoringDriver.sys" as CrashDriver
  CPHarness --> CrashDriver
}

package "KVM Modifications" <<kvm>> {
  rectangle "arch/x86/kvm/*" as KVM
  rectangle "pt.c, pt.h" as PT
  rectangle "pt/hypercall.c, pt/hypercall.h" as Hypercall
  rectangle "pt/redqueen.*" as Redqueen
  rectangle "redqueen.c/h" as RedqueenCore
  KVM --> PT
  KVM --> Hypercall
  Hypercall --> Redqueen
  Redqueen --> RedqueenCore
}

package "Tools and Scripts" <<tools>> {
  rectangle "install.sh" as Install
  rectangle "compile-kvm.sh" as CompileKVM
  rectangle "tutorial.md" as Tutorial
  Install --> CompileKVM
  CompileKVM --> Tutorial
}

rectangle "Nested Virtualization Environment" {
  rectangle "QEMU" as QEMU
  rectangle "Root Partition Windows VM" as RootVM
  rectangle "Child Partition Windows VM" as ChildVM
  ChildVM --> RootVM
  RootVM --> QEMU
}

Fuzz --> CPHarness
CrashDriver --> Fuzz
QEMU --> Fuzz
@enduml
```