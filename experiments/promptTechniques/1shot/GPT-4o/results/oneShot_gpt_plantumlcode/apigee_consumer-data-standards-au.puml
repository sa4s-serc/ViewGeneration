```plantuml
@startuml apigee_consumer-data-standards-au
skinparam rectangle {
  BackgroundColor<<api_proxy>> #fddddd
  BackgroundColor<<shared_flows>> #d9e7fd
  BackgroundColor<<services>> #d8f5d3
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "CDS Banking API Proxies" <<api_proxy>> {
  rectangle "Get Products" as GetProducts
  rectangle "Get Accounts" as GetAccounts
  rectangle "Get Transactions" as GetTransactions
  rectangle "Discovery API" as DiscoveryAPI
  GetProducts --> GetAccounts
  GetAccounts --> GetTransactions
  GetTransactions --> DiscoveryAPI
}

package "Authentication and Authorization" <<api_proxy>> {
  rectangle "OIDC Proxy" as OIDCProxy
  rectangle "JWT Verification" as JWTVerification
  rectangle "Private Key JWT\nAuthentication" as PrivateKeyJWT
  OIDCProxy --> JWTVerification
  OIDCProxy --> PrivateKeyJWT
}

package "Consent Management" <<api_proxy>> {
  rectangle "ConsentMgmtWithKVM Proxy" as ConsentMgmt
  rectangle "Key Value Maps" as KVM
  ConsentMgmt --> KVM
}

package "Dynamic Client Registration" <<api_proxy>> {
  rectangle "Client Management" as ClientMgmt
  rectangle "Mock CDR Register" as MockCDRRegister
  rectangle "ADR Client Roles" as ADRClientRoles
  ClientMgmt --> MockCDRRegister
  ClientMgmt --> ADRClientRoles
}

package "Reusable Artefacts" <<shared_flows>> {
  rectangle "Request Header Checking" as HeaderCheck
  rectangle "Pagination" as Pagination
  rectangle "Traffic Threshold" as TrafficThreshold
  rectangle "JWT Verification Flow" as JWTFlow
  rectangle "Request Parameter Validation" as ParamValidation
  HeaderCheck --> Pagination
  Pagination --> TrafficThreshold
  TrafficThreshold --> JWTFlow
  JWTFlow --> ParamValidation
}

package "Mock OIDC Provider" <<services>> {
  rectangle "Node.js OIDC Provider" as NodeOIDC
  NodeOIDC --> OIDCProxy
}

package "Admin APIs" <<api_proxy>> {
  rectangle "Metadata Update" as MetadataUpdate
  rectangle "Get Metrics" as GetMetrics
  MetadataUpdate --> GetMetrics
}

package "Metrics Service" <<services>> {
  rectangle "Apigee Analytics Integration" as AnalyticsIntegration
  rectangle "Performance Metrics" as PerformanceMetrics
  rectangle "Request Parsers" as RequestParsers
  AnalyticsIntegration --> PerformanceMetrics
  PerformanceMetrics --> RequestParsers
}

@enduml
