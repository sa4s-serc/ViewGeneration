```plantuml
@startuml andrempmattos_harsh-payload
skinparam rectangle {
  BackgroundColor<<firmware>> #d9e7fd
  BackgroundColor<<hardware>> #fddddd
  BackgroundColor<<integration>> #d8f5d3
  Style roundrect
}
skinparam defaultTextAlignment center

package "Software/Firmware Components" <<firmware>> {
  rectangle "FreeRTOS\n(Task Mgmt, Queues)" as FreeRTOS
  rectangle "Peripheral Drivers\n(GPIO, UART, SPI, etc.)" as PeripheralDrivers
  rectangle "System Services\n(AES, RNG, ISP)" as SystemServices
  rectangle "Experiment Algorithms\n(Memory Tests)" as ExperimentAlgorithms
  rectangle "OBC Communication\n(FloripaSat Protocol)" as OBCCommunication
  rectangle "Raspberry Pi\nSoftware Wrapper" as RaspberryPiWrapper
}

package "Hardware Components and Architecture" <<hardware>> {
  rectangle "FPGA Fabric\n(SmartFusion2)" as FPGAFabric
  rectangle "AXI/AHB Interconnect\n(Bridge and Logic)" as AXI_AHB
  rectangle "Memory Subsystem\n(SRAM, DDR SDRAM)" as MemorySubsystem
  rectangle "Clocking and Reset\n(Oscillators, CCC)" as ClockReset
  rectangle "Peripheral Interfaces\n(GPIO, UART, I2C, etc.)" as PeripheralInterfaces
  rectangle "Power Management\n(Protection, Filtering)" as PowerManagement
}

package "Integration Components" <<integration>> {
  rectangle "Hardware Abstraction Layer\n(Raspberry Pi HAL)" as HAL
  rectangle "Bus-Based Architecture\n(AXI, AHB)" as BusArchitecture
  rectangle "Configuration and Constraints\n(TCL, SDC, PDC)" as ConfigConstraints
}

FreeRTOS --> PeripheralDrivers
PeripheralDrivers --> SystemServices
SystemServices --> ExperimentAlgorithms
ExperimentAlgorithms --> OBCCommunication
OBCCommunication --> RaspberryPiWrapper
RaspberryPiWrapper --> HAL

FPGAFabric --> AXI_AHB
AXI_AHB --> MemorySubsystem
MemorySubsystem --> ClockReset
ClockReset --> PeripheralInterfaces
PeripheralInterfaces --> PowerManagement
FPGAFabric --> BusArchitecture

HAL --> BusArchitecture
BusArchitecture --> ConfigConstraints
@enduml
```