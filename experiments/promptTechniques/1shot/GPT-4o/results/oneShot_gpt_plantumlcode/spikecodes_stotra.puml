```plantuml
@startuml spikecodes_stotra
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (React)" as FE {
  rectangle "App.tsx" as App
  rectangle "services" as Services {
    rectangle "tokens.service.tsx" as TokenService
    rectangle "api.service.tsx" as ApiService
    rectangle "accounts.service.tsx" as AccountsService
  }
}

rectangle "Backend (Node.js/Express)" as BE {
  rectangle "routes.ts" as Routes
  rectangle "controllers" as Controllers {
    rectangle "auth.controller.ts" as AuthController
    rectangle "user.controller.ts" as UserController
    rectangle "stocks.controller.ts" as StocksController
    rectangle "news.controller.ts" as NewsController
  }
  rectangle "middleware" as Middleware {
    rectangle "authJwt.ts" as AuthJwt
    rectangle "verifySignUp.ts" as VerifySignUp
  }
  rectangle "models" as Models {
    rectangle "user.model.ts" as UserModel
    rectangle "position.model.ts" as PositionModel
    rectangle "transaction.model.ts" as TransactionModel
  }
  rectangle "utils" as Utils {
    rectangle "requests.ts" as Requests
    rectangle "db.ts" as DB
    rectangle "swagger.ts" as Swagger
  }
}

rectangle "External APIs" as ExternalAPIs {
  rectangle "Yahoo Finance" as YahooFinance
  rectangle "Alpha Vantage" as AlphaVantage
  rectangle "NewsFilter" as NewsFilter
}

rectangle "AWS" as AWS {
  rectangle "Amplify" as Amplify
  rectangle "Elastic Cloud Compute" as EC2
  rectangle "MongoDB Atlas" as MongoDB
}

' ========== Connections ==========
User --> FE : interacts with
FE --> App : route setup
App --> Services : requests data
Services --> BE : RESTful API calls

' Backend interactions
BE --> Middleware : request processing
Middleware --> Controllers : handle logic
Controllers --> Models : access data
Controllers --> ExternalAPIs : fetch data
Controllers --> Utils : utility functions

' External API interactions
ExternalAPIs --> Controllers : provide data

' Deployment interactions
FE --> Amplify : hosted on
BE --> EC2 : hosted on
BE --> MongoDB : data stored in
@enduml
```