Instances --> Connect
Instances --> KSQL
Instances --> ControlCenter

Connect --> ObjectStorage
Connect --> OracleDB

ServiceScripts --> Brokers
ServiceScripts --> Zookeeper
ServiceScripts --> SchemaRegistry
ServiceScripts --> RestProxy
ServiceScripts --> Connect
ServiceScripts --> KSQL
ServiceScripts --> ControlCenter

Install --> ServiceScripts
Firewall --> Instances
Disks --> Volumes
KafkaHelper --> ServiceScripts

@enduml
