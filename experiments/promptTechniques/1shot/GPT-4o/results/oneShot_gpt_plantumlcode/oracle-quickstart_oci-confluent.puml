```plantuml
@startuml oracle-quickstart_oci-confluent
skinparam packageStyle rectangle
skinparam componentStyle rectangle

package "OCI Resources" {
  component "Virtual Network" as VNet
  component "Subnets" as Subnets
  component "Instances" as Instances
  component "Volumes" as Volumes
  component "Security Lists" as SecurityLists
}

package "Confluent Platform" {
  component "Kafka Brokers" as Brokers
  component "Zookeeper" as Zookeeper
  component "Schema Registry" as SchemaRegistry
  component "REST Proxy" as RestProxy
  component "Connect" as Connect
  component "KSQL" as KSQL
  component "Control Center" as ControlCenter
}

package "Integration" {
  component "Oracle Object Storage" as ObjectStorage
  component "Oracle ADW/ATP" as OracleDB
}

package "Scripts" {
  component "install.sh" as Install
  component "firewall.sh" as Firewall
  component "disks.sh" as Disks
  component "kafka_deploy_helper.sh" as KafkaHelper
  component "Service Scripts" as ServiceScripts
}

VNet --> Subnets
Subnets --> Instances
Instances --> Volumes
Instances --> SecurityLists

Instances --> Brokers
Instances --> Zookeeper
Instances --> SchemaRegistry
