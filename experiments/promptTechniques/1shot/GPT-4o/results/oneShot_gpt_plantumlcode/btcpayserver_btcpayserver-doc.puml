```plantuml
@startuml btcpayserver_btcpayserver-doc
skinparam rectangle {
  BackgroundColor<<guides>> #d9e7fd
  BackgroundColor<<deployment>> #d8f5d3
  BackgroundColor<<development>> #fddddd
  BackgroundColor<<api>> #fff1c9
  BackgroundColor<<theme>> #e0d1f1
  Style roundrect
}
skinparam defaultTextAlignment center

package "User Guides" <<guides>> {
  rectangle "Merchant Guides" as MerchantGuides
  rectangle "Wallet Setup" as WalletSetup
  rectangle "App Usage\n(Point of Sale, etc.)" as AppUsage
  MerchantGuides --> WalletSetup
  WalletSetup --> AppUsage
}

package "Deployment Docs" <<deployment>> {
  rectangle "Setup Methods\n(Docker, Azure, etc.)" as SetupMethods
  rectangle "Configuration Scripts\n(btcpay-setup.sh)" as ConfigScripts
  SetupMethods --> ConfigScripts
}

package "Development Docs" <<development>> {
  rectangle "API Docs\n(Greenfield, BitPay)" as APIDocs
  rectangle "Plugin Development" as PluginDev
  rectangle "Theming with CSS" as ThemingCSS
  APIDocs --> PluginDev
  PluginDev --> ThemingCSS
}

package "API Integration" <<api>> {
  rectangle "E-commerce Platforms\nIntegration" as ECommerceIntegration
  rectangle "Custom Applications\n(Greenfield API)" as CustomApps
  ECommerceIntegration --> CustomApps
}

package "Theming System" <<theme>> {
  rectangle "VuePress Theme\nCustomizations" as ThemeCustomizations
  rectangle "CSS Variables\nOverrides" as CSSOverrides
  ThemeCustomizations --> CSSOverrides
}

rectangle "Troubleshooting & FAQ" as Troubleshooting
rectangle "VuePress Configuration" as VuePressConfig
rectangle "Build & Deployment\n(create-redirects.js)" as BuildDeployment

VuePressConfig --> BuildDeployment
BuildDeployment --> Troubleshooting

@enduml
```