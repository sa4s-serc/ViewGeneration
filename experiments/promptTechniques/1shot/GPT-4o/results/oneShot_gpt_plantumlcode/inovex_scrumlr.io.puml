```plantuml
@startuml inovex_scrumlr.io
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (React)" as FE {
  rectangle "Board.tsx" as Board
  rectangle "Column.tsx" as Column
  rectangle "Note.tsx" as Note
  rectangle "SettingsDialog.tsx" as SettingsDialog
  rectangle "BoardUsers.tsx" as BoardUsers
  rectangle "Infobar.tsx" as Infobar
}

rectangle "Backend (Go)" as BE {
  rectangle "API" as API {
    rectangle "auth.go" as Auth
    rectangle "router.go" as Router
    rectangle "boards_listen_on_board.go" as WebSocketHandler
  }
  rectangle "Realtime" as Realtime {
    rectangle "nats.go" as Nats
    rectangle "redis.go" as Redis
  }
  rectangle "Database" as Database {
    rectangle "database.go" as DatabaseAccess
    rectangle "DTO" as DTO
  }
  rectangle "Services" as Services {
    rectangle "CoreLogic" as CoreLogic
  }
}

rectangle "Infrastructure" as Infra {
  rectangle "NATS/Redis" as Messaging
  rectangle "Database" as DB
}

' ========== Connections ==========
User -> FE
FE <-> BE : HTTP API calls
FE <-> DB : Load/Save board data
FE <-> Messaging : Real-time updates
FE --> Board
FE --> Column
FE --> Note
FE --> SettingsDialog
FE --> BoardUsers
FE --> Infobar

BE <-> DB : Data storage/retrieval
BE <-> Messaging : Real-time communication
API <-> Services : Execute business logic
API <-> Realtime : WebSocket connections
API <-> Auth : Handle authentication
API <-> Router : Route API requests
API <-> WebSocketHandler : Manage WebSocket connections

Realtime <-> Nats
Realtime <-> Redis

@enduml
```