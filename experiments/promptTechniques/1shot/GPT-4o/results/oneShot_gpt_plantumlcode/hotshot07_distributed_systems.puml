```plantuml
@startuml hotshot07_distributed_systems
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<database>> #fff1c9
  BackgroundColor<<scripts>> #fdd8e5
  BackgroundColor<<ci_cd>> #e5fdd8
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

package "Frontend (React)" <<frontend>> {
  rectangle "UI Components" as UI
  rectangle "SignIn.js\n(Authentication)" as SignIn
  UI --> SignIn
}

package "Backend (Flask)" <<backend>> {
  rectangle "User Auth Service" as AuthService
  rectangle "Availability Tracking\nService" as AvailabilityService
  rectangle "Test Scheduling\nService" as TestService
  rectangle "Reporting Service" as ReportingService
  rectangle "API Gateway" as APIGateway
  User --> APIGateway
  APIGateway --> AuthService
  APIGateway --> AvailabilityService
  APIGateway --> TestService
  APIGateway --> ReportingService
}

database "DynamoDB" <<database>> as DB
AuthService --> DB
AvailabilityService --> DB
TestService --> DB
ReportingService --> DB

package "Deployment Scripts" <<scripts>> {
  rectangle "deploy-cluster.sh" as ClusterDeploy
  rectangle "deploy-local.sh" as LocalDeploy
}

package "CI/CD (GitHub Actions)" <<ci_cd>> {
  rectangle "Build & Push Docker Images" as BuildPush
}

UI --> APIGateway
SignIn --> AuthService
BuildPush --> ClusterDeploy
BuildPush --> LocalDeploy

@enduml
```