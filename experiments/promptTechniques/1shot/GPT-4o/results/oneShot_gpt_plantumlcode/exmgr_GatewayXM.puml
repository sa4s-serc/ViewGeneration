```plantuml
@startuml exmgr_GatewayXM
skinparam rectangle {
  BackgroundColor<<gateway>> #d9e7fd
  BackgroundColor<<sensor>> #d8f5d3
  BackgroundColor<<platform>> #fddddd
  BackgroundColor<<container>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "GatewayXM" <<gateway>> {
  rectangle "Eclipse Kura" as Kura
  rectangle "Kura-Tb-Bundle\n(Thingsboard Connector)" as KuraTbBundle
  rectangle "OTA Update Service" as OTAService
  Kura -> KuraTbBundle
  Kura -> OTAService
}

package "Sensor Nodes" <<sensor>> {
  rectangle "ESP8266/ESP32 Firmware" as Firmware
  rectangle "Mesh Network" as MeshNetwork
  rectangle "OTA Update Support" as OTAUpdate
  Firmware -> MeshNetwork
  Firmware -> OTAUpdate
}

package "Thingsboard IoT Platform" <<platform>> {
  rectangle "Data Storage and Analysis" as DataStorage
  rectangle "Visualization" as Visualization
  DataStorage <- KuraTbBundle
  Visualization <- KuraTbBundle
}

package "Docker Containers" <<container>> {
  rectangle "Agile-Stack" as AgileStack
  rectangle "Resin.io (Balena)" as Resin
  AgileStack -> Kura
  Resin -> AgileStack
}

KuraTbBundle --> DataStorage
KuraTbBundle --> Visualization
Firmware --> Kura
MeshNetwork --> Firmware
OTAUpdate --> OTAService
@enduml
```