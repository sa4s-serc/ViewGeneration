```plantuml
@startuml madderle_Capstone-Realtime-Streaming-Analytics
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Twitter Service" as TwitterService #lightyellow
rectangle "IEX Service" as IEXService #lightyellow

rectangle "Manager Service" as ManagerService #lightsteelblue
rectangle "Data Service\n(Django API)" as DataService #lightsteelblue

rectangle "AWS Kinesis" as Kinesis #aliceblue
rectangle "Redis" as Redis #aliceblue
rectangle "MongoDB" as MongoDB #aliceblue
rectangle "S3 Storage" as S3 #aliceblue

rectangle "SKLearn Model\nDevelopment" as ModelDevelopment #palegreen
rectangle "SKLearn Model\nDeployment" as ModelDeployment #palegreen
rectangle "EDA" as EDA #mistyrose

' ========== Connections ==========
User --> ManagerService : Start Data Ingestion

' Data Ingestion
ManagerService --> TwitterService : Collect Tweets
ManagerService --> IEXService : Retrieve Stock Data
TwitterService --> Redis : Publish Tweets
IEXService --> Redis : Publish Stock Data

' Data Streaming
ManagerService --> Kinesis : Stream Data

' Data Storage
Redis --> MongoDB : Store Tweets and Stock Data
ModelDevelopment --> S3 : Upload Serialized Models

' Data Analysis
ModelDeployment --> S3 : Fetch Models
ModelDeployment --> MongoDB : Fetch Data
ModelDeployment --> MongoDB : Log Predictions

' Data Access
User --> DataService : Access Data via API
DataService --> MongoDB : Query Data

' EDA
User --> EDA : Perform Exploratory Data Analysis
@enduml
```