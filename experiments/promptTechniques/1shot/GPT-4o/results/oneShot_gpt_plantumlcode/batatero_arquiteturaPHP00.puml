```plantuml
@startuml batatero_arquiteturaPHP00
skinparam rectangle {
  BackgroundColor<<codeigniter>> #d9e7fd
  BackgroundColor<<doctrine>> #d8f5d3
  BackgroundColor<<symfony>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "CodeIgniter Application" <<codeigniter>> {
  rectangle "Controller" as Controller
  rectangle "Facade" as Facade
  rectangle "Business Logic" as BusinessLogic
  rectangle "DAO" as DAO
  rectangle "GenericDAO" as GenericDAO
  rectangle "FactoryBusiness" as FactoryBusiness
  rectangle "FactoryDAO" as FactoryDAO

  Controller --> Facade
  Facade --> BusinessLogic
  BusinessLogic --> DAO
  DAO --> GenericDAO
  FactoryBusiness --> BusinessLogic
  FactoryDAO --> DAO
}

package "Doctrine ORM" <<doctrine>> {
  rectangle "EntityManager" as EntityManager
  rectangle "UnitOfWork" as UnitOfWork
  rectangle "EntityRepository" as EntityRepository
  rectangle "Configuration" as Configuration
  rectangle "ClassMetadata" as ClassMetadata
  rectangle "AnnotationReader" as AnnotationReader
  rectangle "Hydration" as Hydration
  rectangle "Querying (DQL)" as Querying

  EntityManager --> UnitOfWork
  EntityManager --> EntityRepository
  EntityManager --> Configuration
  EntityManager --> ClassMetadata
  Configuration --> AnnotationReader
  EntityRepository --> Hydration
  Querying --> Hydration
}

package "Symfony Components" <<symfony>> {
  rectangle "YAML Component" as YAML
  rectangle "Console Component" as Console

  YAML --> Console
}

database "Database" <<db>> as DB
DAO --> DB
UnitOfWork --> DB
@enduml
```