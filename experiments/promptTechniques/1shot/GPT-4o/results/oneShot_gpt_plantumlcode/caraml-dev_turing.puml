```plantuml
@startuml caraml-dev_turing
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Python SDK" as SDK #lightgoldenrodyellow

rectangle "API Server" as APIServer #lightblue

rectangle "Router Engine" as RouterEngine #lavender

rectangle "Experiment Engine" as ExperimentEngine #lightgray

rectangle "Batch Ensembler Engine" as BatchEnsemblerEngine #lightcoral

rectangle "Kubernetes" as K8s #mintcream

rectangle "Logging/Monitoring\nBackend" as LoggingBackend #lightsteelblue

rectangle "External Services" as ExternalServices #aliceblue {
  rectangle "Prometheus" as Prometheus
  rectangle "GitLab" as GitLab
  rectangle "Jaeger" as Jaeger
}

' ========== Connections ==========
User --> SDK : interact via Python SDK
SDK --> APIServer : API requests (REST/gRPC)

' API Server interactions
APIServer --> RouterEngine : manage routers
APIServer --> ExperimentEngine : manage experiments
APIServer --> BatchEnsemblerEngine : manage batch jobs
APIServer --> LoggingBackend : log results

' Router Engine interactions
RouterEngine --> ExternalServices : trigger webhooks
RouterEngine --> K8s : deploy routers

' Experiment Engine interactions
ExperimentEngine --> ExternalServices : query experiment engines
ExperimentEngine --> APIServer : register experiment outcomes

' Batch Ensembler Engine interactions
BatchEnsemblerEngine --> K8s : submit Spark jobs
BatchEnsemblerEngine --> APIServer : report job status

' Logging and Monitoring
APIServer --> Prometheus : export metrics
APIServer --> Jaeger : trace requests

@enduml
```