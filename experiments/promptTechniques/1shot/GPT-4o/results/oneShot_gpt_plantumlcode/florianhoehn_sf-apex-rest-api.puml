```plantuml
@startuml florianhoehn_sf-apex-rest-api
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<example>> #d8f5d3
  BackgroundColor<<test>> #fddddd
  BackgroundColor<<log>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

actor "External System" as External

package "Core Components" <<core>> {
  rectangle "RestWrapper.cls" as RestWrapper
  rectangle "RestResponse.cls" as RestResponse
  rectangle "RestCallout.cls" as RestCallout
  rectangle "RestLogBuilder.cls" as RestLogBuilder
  rectangle "Rest_Log__c.object" as RestLogObject
}

package "Example Code" <<example>> {
  rectangle "ExampleRatingRestResource" as ExampleRatingRestResource
  rectangle "ExampleRatingCallout" as ExampleRatingCallout
}

package "Testing Classes" <<test>> {
  rectangle "Comprehensive Unit Tests" as UnitTests
}

package "Logging" <<log>> {
  rectangle "Rest_Log__c Records" as RestLogRecords
}

External -> ExampleRatingRestResource : Sends REST Request
ExampleRatingRestResource -> RestWrapper : Map JSON to SObject
ExampleRatingRestResource -> RestResponse : Create REST Response
RestResponse -> RestLogBuilder : Log Interaction
RestLogBuilder -> RestLogObject : Record Log
RestLogObject -> RestLogRecords : Store Log

ExampleRatingRestResource -> ExampleRatingCallout : Make External Callout
ExampleRatingCallout -> RestCallout : Manage HTTP Request
RestCallout -> External : Send HTTP Request
External -> RestCallout : Receive HTTP Response
RestCallout -> ExampleRatingCallout : Process Response
ExampleRatingCallout -> RestResponse : Handle Errors

UnitTests -> ExampleRatingRestResource : Validate Functionality
UnitTests -> ExampleRatingCallout : Test Callouts

@enduml
```