```plantuml
@startuml IBM_logdna-cos
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Event

rectangle "IBM Cloud Object Storage (COS)" as COS #aliceblue {
  rectangle "Source Bucket" as SourceBucket
  rectangle "Archive Bucket" as ArchiveBucket
}

rectangle "Serverless Function" as ServerlessFunction #lightsteelblue {
  rectangle "handler.js" as Handler
}

rectangle "IBM LogDNA" as LogDNA #mistyrose

' ========== Connections ==========
Event --> COS : New Object Creation Event

' COS interactions
COS -> ServerlessFunction : Trigger on new object\nin Source Bucket

' Serverless Function interactions
ServerlessFunction -> COS : Download zipped log file\nfrom Source Bucket
ServerlessFunction -> Handler : Process logs\nUnzip, parse JSON
Handler -> LogDNA : Send logs in batches\nmax 5000 logs/batch
Handler -> COS : Copy processed file\nto Archive Bucket
Handler -> COS : Delete file\nfrom Source Bucket

@enduml
```