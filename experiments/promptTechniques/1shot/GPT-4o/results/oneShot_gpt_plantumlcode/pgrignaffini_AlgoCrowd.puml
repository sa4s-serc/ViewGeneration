```plantuml
@startuml pgrignaffini_AlgoCrowd
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<blockchain>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Next.js)" <<frontend>> {
  rectangle "Pages\n(Home, Create Project,\nProject Details, User Area)" as Pages
  rectangle "React Components\n(Header, Footer, Project, etc.)" as Components
  rectangle "API.js\n(API Functions for Backend)" as API
  rectangle "AppContext.js\n(Global State Management)" as AppContext
  rectangle "Constants\n(Algod Token, Base URL, etc.)" as Constants
  rectangle "Utilities\n(Contract & Tx Operations,\nDate Formatting)" as Utils
  Pages --> Components
  Components --> API
  Components --> AppContext
  AppContext --> Constants
  AppContext --> Utils
}

package "Backend (Express.js)" <<backend>> {
  rectangle "server.js\n(Express Server & API Endpoints)" as Server
  rectangle "db.js\n(SQLite Database Connection)" as DBConnection
  rectangle "dao.js\n(Data Access Object Pattern)" as DAO
  Server --> DAO
  DAO --> DBConnection
}

package "Smart Contracts (PyTeal)" <<blockchain>> {
  rectangle "contracts.py\n(TEAL Logic for Contracts)" as Contracts
  rectangle "operations.py\n(Contract Operations)" as Operations
  rectangle "util.py\n(Blockchain Utility Functions)" as BlockchainUtils
  Operations --> Contracts
  Operations --> BlockchainUtils
}

database "SQLite DB" <<db>> as SQLiteDB
DAO --> SQLiteDB

package "Algorand Blockchain" <<blockchain>> {
  rectangle "AlgoSigner\n(Transaction Signing)" as AlgoSigner
}

API --> Server
Server --> Contracts
Contracts --> AlgoSigner
@enduml
```