```plantuml
@startuml danielfm_prometheus-for-developers
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Developer

rectangle "Sample Node.js\nApplication" as NodeApp #lightblue {
}

rectangle "Prometheus" as Prometheus #lightyellow {
  rectangle "prometheus.yml\nConfiguration" as PrometheusConfig #lightgrey
}

rectangle "Alertmanager" as Alertmanager #lightpink {
  rectangle "prometheus.rules.yml\nConfiguration" as AlertRules #lightgrey
}

rectangle "Grafana" as Grafana #lightgreen {
  rectangle "datasource.yml\nConfiguration" as GrafanaDatasource #lightgrey
  rectangle "dashboard-providers.yml\nConfiguration" as GrafanaDashboard #lightgrey
}

rectangle "Docker Compose" as DockerCompose #aliceblue

' ========== Connections ==========
Developer --> DockerCompose : deploy setup

' Node.js Application interactions
NodeApp --> Prometheus : expose /metrics

' Prometheus interactions
PrometheusConfig --> Prometheus : configure scrape\ntargets and intervals
Prometheus --> NodeApp : scrape metrics

' Alertmanager interactions
Prometheus --> Alertmanager : send alerts based\non rules
AlertRules --> Alertmanager : configure alert rules

' Grafana interactions
GrafanaDatasource --> Grafana : configure Prometheus\ndata source
GrafanaDashboard --> Grafana : configure dashboards
Grafana --> Prometheus : query metrics for dashboards

@enduml
```