```plantuml
@startuml Spiderpig86_SmoresUnderflow
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
  rectangle "React App" as ReactApp
}

rectangle "Backend" as BE {
  rectangle "su-users\nService" as UsersService
  rectangle "su-accounts\nService" as AccountsService
  rectangle "su-questions\nService" as QuestionsService
  rectangle "su-answers\nService" as AnswersService
  rectangle "su-search\nService" as SearchService
  rectangle "su-media\nService" as MediaService
}

rectangle "Queue Services" as QueueServices {
  rectangle "qu-questions\nQueue" as QuestionsQueue
  rectangle "qu-answers\nQueue" as AnswersQueue
  rectangle "qu-delete-questions\nQueue" as DeleteQuestionsQueue
}

rectangle "Infrastructure" as Infrastructure {
  rectangle "RabbitMQ" as RabbitMQ
  rectangle "Redis" as Redis
  rectangle "ElasticSearch" as ElasticSearch
  rectangle "MongoDB" as MongoDB
  rectangle "Nginx" as Nginx
}

' ========== Connections ==========
User --> ReactApp : Interactions

' Frontend interactions
ReactApp --> UsersService : authenticate/register user
ReactApp --> AccountsService : manage user account
ReactApp --> QuestionsService : post/get questions
ReactApp --> AnswersService : post/get answers
ReactApp --> SearchService : search questions/answers
ReactApp --> MediaService : upload media

' Backend interactions
QuestionsService --> RabbitMQ : send message to qu-questions
AnswersService --> RabbitMQ : send message to qu-answers
QuestionsService --> RabbitMQ : send message to qu-delete-questions

' Queue processing
QuestionsQueue --> MongoDB : insert question
AnswersQueue --> MongoDB : insert answer
DeleteQuestionsQueue --> MongoDB : delete question

' Search and Caching
SearchService --> ElasticSearch : index/search questions/answers
UsersService --> Redis : cache user data
QuestionsService --> Redis : cache questions data

' Load Balancing
User --> Nginx : access services
Nginx --> BE : distribute requests

@enduml
```