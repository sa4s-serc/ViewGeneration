```plantuml
@startuml OAID_Tengine
skinparam rectangle {
  BackgroundColor<<core>> #f3f4fe
  BackgroundColor<<component>> #e8f5e9
  BackgroundColor<<backend>> #fddddd
  BackgroundColor<<utility>> #fff8e1
  Style roundrect
}
skinparam defaultTextAlignment center

package "Tengine Lite Core" <<core>> {
  rectangle "Device Abstraction\nLayer" as DeviceAbstraction
  rectangle "Graph Representation\n(IR)" as GraphIR
  rectangle "Operator Prototypes" as OperatorPrototypes
  rectangle "Memory Management" as MemoryManagement
  rectangle "Shader Management\n(Vulkan)" as ShaderManagement
  DeviceAbstraction --> GraphIR
  GraphIR --> OperatorPrototypes
  OperatorPrototypes --> MemoryManagement
  MemoryManagement --> ShaderManagement
}

package "Components" <<component>> {
  rectangle "Model Conversion Tools" as ModelConversion
  rectangle "Inference Engine" as InferenceEngine
  rectangle "Operator Library" as OperatorLibrary
  rectangle "Testing Framework" as TestingFramework
  rectangle "Python Bindings\n(Pytengine)" as PythonBindings
  ModelConversion --> InferenceEngine
  InferenceEngine --> OperatorLibrary
  OperatorLibrary --> TestingFramework
  TestingFramework --> PythonBindings
}

package "Backends" <<backend>> {
  rectangle "CPU Backend" as CPUBackend
  rectangle "GPU Backend\n(Vulkan/OpenCL)" as GPUBackend
  rectangle "NPU Backend" as NPUBackend
  DeviceAbstraction --> CPUBackend
  DeviceAbstraction --> GPUBackend
  DeviceAbstraction --> NPUBackend
}

package "Utilities & Optimizations" <<utility>> {
  rectangle "Online Reporting" as OnlineReporting
  rectangle "Auto-tuning & Caching\n(OpenCL)" as AutoTuning
  rectangle "Image Processing\nFunctions" as ImageProcessing
  OnlineReporting --> AutoTuning
  AutoTuning --> ImageProcessing
}

@enduml
```