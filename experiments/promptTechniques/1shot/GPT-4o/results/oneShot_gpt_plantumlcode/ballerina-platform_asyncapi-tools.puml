```plantuml
@startuml ballerina-platform_asyncapi-tools
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<websocket>> #d8f5d3
  BackgroundColor<<cli>> #fddddd
  BackgroundColor<<file>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Functionalities" <<core>> {
  rectangle "AsyncAPI/OpenAPI\nCode Generation" as CodeGen
  rectangle "Ballerina to\nAsyncAPI Export" as Export
  rectangle "Authentication\nHandling" as Auth
  rectangle "Error Handling" as Error
  CodeGen --> Export
  CodeGen --> Auth
  CodeGen --> Error
}

package "WebSocket Support" <<websocket>> {
  rectangle "WebSocket Protocol\nSupport (ws)" as WebSocket
  rectangle "Zoom.yaml" as Zoom
  WebSocket --> Zoom
  WebSocket --> CodeGen
}

package "CLI Tooling" <<cli>> {
  rectangle "AsyncAPI CLI\n(bal asyncapi)" as CLI
  rectangle "AsyncApiCmd.java" as CmdJava
  CLI --> CmdJava
  CLI --> CodeGen
  CLI --> Export
}

package "File Handling" <<file>> {
  rectangle "API Definition Files\n(*.yaml)" as YamlFiles
  rectangle "Ballerina Code Files\n(*.bal)" as BalFiles
  rectangle "Test Suites\n(Tests.java)" as TestSuites
  YamlFiles --> CodeGen
  BalFiles --> Export
  TestSuites --> YamlFiles
  TestSuites --> BalFiles
}

@enduml
```