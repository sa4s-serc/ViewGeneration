```plantuml
@startuml dwt0317_Search_Adserver
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
  rectangle "Servlets" as Servlets {
    rectangle "ESServlet" as ESServlet
    rectangle "BingServlet" as BingServlet
  }
}

rectangle "Elasticsearch" as ES #lightblue

rectangle "Bing API" as BingAPI #lightgrey

rectangle "Ad Retrieval" as AdRetrieval #lightgreen
rectangle "Query Rewriting" as QueryRewriting #lightyellow
rectangle "Thrift Service" as ThriftService #lightcoral

rectangle "MariaDB" as MariaDB #lightpink

rectangle "Logging System" as Logging #lightgoldenrodyellow

' ========== Connections ==========
User --> FE : search query

' Frontend interactions
FE --> Servlets
Servlets --> ESServlet : process query
Servlets --> BingServlet : process query

' Elasticsearch interactions
ESServlet --> ES : retrieve results

' Bing API interactions
BingServlet --> BingAPI : retrieve results

' Ad Retrieval interactions
ESServlet --> AdRetrieval : retrieve ads
BingServlet --> AdRetrieval : retrieve ads
AdRetrieval --> QueryRewriting : rewrite query
QueryRewriting --> ThriftService : use Thrift for rewriting
AdRetrieval --> ThriftService : rank ads using Thrift

' MariaDB interactions
AdRetrieval --> MariaDB : fetch ad data\nmanage budgets

' Logging interactions
Servlets --> Logging : log search requests
AdRetrieval --> Logging : log ad impressions/clicks

@enduml
```