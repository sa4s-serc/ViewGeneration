```plantuml
@startuml hamzatugrul_surl
skinparam rectangle {
  BackgroundColor<<controller>> #d9e7fd
  BackgroundColor<<service>> #d8f5d3
  BackgroundColor<<repository>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<cache>> #ffebd9
  BackgroundColor<<infra>> #e0f7ff
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

rectangle "Load Balancer (Nginx)" <<infra>> as LB

package "Controller Layer" <<controller>> {
  rectangle "ShortURLController" as ShortURLController
}

package "Service Layer" <<service>> {
  rectangle "UrlShortenerService" as UrlShortenerService
  rectangle "KeyGenerator\n(Murmur3With32BitsHashKeyGenerator)" as KeyGenerator
}

package "Repository Layer" <<repository>> {
  rectangle "ShortUrlRepository" as ShortUrlRepository
}

database "MongoDB" <<db>> as MongoDB
queue "Redis Cache" <<cache>> as Redis

User -> LB : Access short URL
LB -> ShortURLController : HTTP GET /{surl}
ShortURLController -> Redis : Check cache for surl
alt Cache hit
  Redis -> ShortURLController : Return long URL
else Cache miss
  ShortURLController -> ShortUrlRepository : Find surl in DB
  ShortUrlRepository -> MongoDB : Query surl
  MongoDB -> ShortUrlRepository : Return long URL
  ShortUrlRepository -> ShortURLController : Return long URL
  ShortURLController -> Redis : Cache long URL
end
ShortURLController -> User : Redirect to long URL

User -> LB : Shorten URL
LB -> ShortURLController : HTTP POST /api/v1/shortener
ShortURLController -> UrlShortenerService : Shorten URL
UrlShortenerService -> KeyGenerator : Generate key
UrlShortenerService -> ShortUrlRepository : Save URL mapping
ShortUrlRepository -> MongoDB : Insert mapping
ShortUrlRepository -> Redis : Cache new URL
ShortURLController -> User : Return short URL

User -> LB : Request stats
LB -> ShortURLController : HTTP GET /api/v1/status/{surl}
ShortURLController -> ShortUrlRepository : Fetch stats
ShortUrlRepository -> MongoDB : Query stats
MongoDB -> ShortUrlRepository : Return stats
ShortUrlRepository -> ShortURLController : Return stats
ShortURLController -> User : Return stats

@enduml
```