```plantuml
@startuml orchsym_runtime
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<infrastructure>> #d8f5d3
  BackgroundColor<<security>> #fddddd
  BackgroundColor<<integration>> #fff1c9
  BackgroundColor<<cluster>> #e1f7d5
  BackgroundColor<<orchsym>> #f3e5f5
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Framework" <<core>> {
  rectangle "FlowController" as FlowController
  rectangle "ProcessSession" as ProcessSession
  rectangle "FlowFile" as FlowFile
  rectangle "Connection" as Connection
  rectangle "ProcessScheduler" as ProcessScheduler
  FlowController --> ProcessSession
  ProcessSession --> FlowFile
  FlowFile --> Connection
  FlowController --> ProcessScheduler
}

package "Flow Management" <<core>> {
  rectangle "Process Groups" as ProcessGroups
  rectangle "StandardFlowService" as StandardFlowService
  rectangle "FlowSynchronizer" as FlowSynchronizer
  rectangle "FlowFileQueue" as FlowFileQueue
  ProcessGroups --> StandardFlowService
  StandardFlowService --> FlowSynchronizer
  FlowSynchronizer --> FlowFileQueue
}

package "State Management" <<core>> {
  rectangle "StateManagerProvider" as StateManager
  StateManager --> [ZooKeeper]
}

package "Key Infrastructure Components" <<infrastructure>> {
  rectangle "FlowFile Repository" as FlowFileRepo
  rectangle "Content Repository" as ContentRepo
  rectangle "Provenance Repository" as ProvenanceRepo
  rectangle "ControllerServiceProvider" as ControllerServiceProvider
  rectangle "REST API" as RestAPI
  rectangle "Site-to-Site" as SiteToSite
  rectangle "Web UI" as WebUI
  FlowFileRepo --> ContentRepo
  ContentRepo --> ProvenanceRepo
  ControllerServiceProvider --> RestAPI
  RestAPI --> SiteToSite
  SiteToSite --> WebUI
}

package "Security and Authorization" <<security>> {
  rectangle "Login Identity Provider" as LoginIdentityProvider
  rectangle "Authorizer" as Authorizer
  rectangle "SSLContextService" as SSLContextService
  rectangle "Encryption" as Encryption
  LoginIdentityProvider --> Authorizer
  Authorizer --> SSLContextService
  SSLContextService --> Encryption
}

package "Integration and Extensibility" <<integration>> {
  rectangle "NAR Bundles" as NARBundles
  rectangle "ExecuteScript" as ExecuteScript
  rectangle "External Integrations" as ExternalIntegrations
  rectangle "Data Formats" as DataFormats
  rectangle "Schema Management" as SchemaManagement
  NARBundles --> ExecuteScript
  ExecuteScript --> ExternalIntegrations
  ExternalIntegrations --> DataFormats
  DataFormats --> SchemaManagement
}

package "Cluster Coordination and Management" <<cluster>> {
  rectangle "Zero-Master Clustering" as ZeroMasterClustering
  rectangle "Cluster Protocol" as ClusterProtocol
  rectangle "Flow Election" as FlowElection
  ZeroMasterClustering --> ClusterProtocol
  ClusterProtocol --> FlowElection
}

package "Orchsym Runtime Specifics" <<orchsym>> {
  rectangle "Branding Extension" as BrandingExtension
  rectangle "Custom Login Provider" as CustomLoginProvider
  rectangle "Usage Data Collection" as UsageDataCollection
  BrandingExtension --> CustomLoginProvider
  CustomLoginProvider --> UsageDataCollection
}

@enduml
```