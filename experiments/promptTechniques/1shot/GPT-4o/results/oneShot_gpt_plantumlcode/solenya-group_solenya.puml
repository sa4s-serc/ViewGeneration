```plantuml
@startuml solenya-group_solenya
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Developer

rectangle "Solenya Framework" as Framework {
}

rectangle "Component" as Component #lightsteelblue {
  rectangle "State Management" as StateManagement #aliceblue
  rectangle "View Function" as ViewFunction #aliceblue
  rectangle "Lifecycle Events" as LifecycleEvents #aliceblue
}

rectangle "App" as App #lightyellow {
  rectangle "Root Component" as RootComponent #aliceblue
  rectangle "Time Travel" as TimeTravel #aliceblue
}

rectangle "Router" as Router #lightpink

rectangle "Validator" as Validator #palegreen

rectangle "Storage" as Storage #lightgrey

rectangle "Virtual DOM" as VirtualDOM #mistyrose

rectangle "Widget Functions" as WidgetFunctions #lightcyan

rectangle "HTML Helper Functions" as HTMLHelperFunctions #lightgoldenrodyellow

rectangle "Typestyle" as Typestyle #lavender

' ========== Connections ==========
Developer --> Framework : Initialize Application

' Framework interactions
Framework <--> Component : Create/Update Components
Component <--> StateManagement : Manage Component States
Component <--> ViewFunction : Render Views
Component <--> LifecycleEvents : Handle Lifecycle Changes

App --> RootComponent : Manage Root Component
App <--> TimeTravel : Enable Time Travel Debugging

Framework <--> Router : Handle Navigation
Framework <--> Validator : Validate Inputs
Framework <--> Storage : Serialize/Deserialize State
Framework <--> VirtualDOM : Patch DOM Updates
Framework <--> WidgetFunctions : Create Form Inputs
Framework <--> HTMLHelperFunctions : Create Virtual DOM Nodes
Framework <--> Typestyle : Apply CSS-in-JS Styling
@enduml
