```plantuml
@startuml AndreasM009_AadApiGatekeeper

skinparam rectangle {
  BackgroundColor<<web>> #d9e7fd
  BackgroundColor<<auth>> #d8f5d3
  BackgroundColor<<proxy>> #fddddd
  BackgroundColor<<config>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "AadApiGatekeeper" {
  rectangle "AuthProxyMiddleware" <<proxy>> as ProxyMiddleware
  rectangle "AuthBackChannelHandler" <<proxy>> as BackChannelHandler
  rectangle "AzureAdAuthenticationBuilderExtension" <<auth>> as AuthExtension
  rectangle "AadAuthenticationOptions" <<config>> as AuthOptions
  rectangle "AuthProxyOptions" <<config>> as ProxyOptions
  rectangle "InMemoryTokenCache" <<auth>> as TokenCache
  rectangle "Startup" <<web>> as Startup
  rectangle "Program" <<web>> as Program

  ProxyMiddleware --> BackChannelHandler
  Startup --> [AuthExtension, AuthOptions, ProxyOptions]
  Startup --> [ProxyMiddleware, TokenCache]
  Program --> Startup
}

package "Controllers" {
  rectangle "MeController" <<web>> as MeController
  rectangle "LoginController" <<web>> as LoginController
  MeController --> [ProxyMiddleware, TokenCache]
  LoginController --> AuthExtension
}

package "Examples" {
  rectangle "MyApi" <<web>> as MyApi
  rectangle "EchoController" <<web>> as EchoController
  MyApi --> EchoController
}

package "Deployment" {
  rectangle "Kubernetes" <<config>> as Kubernetes
  rectangle "Service Fabric Mesh" <<config>> as ServiceFabric
  Kubernetes --> MyApi
  ServiceFabric --> MyApi
}

@enduml
```