```plantuml
@startuml open-risk_Open_Risk_API
skinparam rectangle {
  BackgroundColor<<api>> #d9e7fd
  BackgroundColor<<server>> #d8f5d3
  BackgroundColor<<client>> #fddddd
  BackgroundColor<<library>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Open Risk API" <<api>> {
  rectangle "RESTful Endpoints" as Endpoints
}

package "Servers" <<server>> {
  rectangle "Model Server\n(Flask)" as ModelServer
  rectangle "Data Server\n(Python-Eve)" as DataServer
}

package "API Explorer (Python Client)" <<client>> {
  rectangle "Python Client" as PythonClient
}

package "OpenCPM" <<library>> {
  rectangle "NPL-Concentration" as NPLC
  rectangle "ConcentrationMetrics\nLibrary" as MetricsLibrary
}

package "Database" <<server>> {
  database "MongoDB" as MongoDB
}

Endpoints --> ModelServer
Endpoints --> DataServer
PythonClient --> Endpoints
ModelServer --> MetricsLibrary
DataServer --> MongoDB
NPLC --> ModelServer
NPLC --> MetricsLibrary
@enduml
```