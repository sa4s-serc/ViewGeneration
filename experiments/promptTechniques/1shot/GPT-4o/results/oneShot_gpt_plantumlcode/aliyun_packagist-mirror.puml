  rectangle "sync_packages_v2.go" as SyncPackagesV2
  rectangle "sync_packages_p1.go" as SyncPackagesP1
  rectangle "sync_status.go" as SyncStatus
  rectangle "github.go" as GitHub
  rectangle "util.go" as Util
  rectangle "entry.go" as Entry
  rectangle "sync_composer_phar.go" as SyncComposerPhar
  rectangle "cdn.go" as CDN
  rectangle "context.go" as Context
  rectangle "sync_providers.go" as SyncProviders
}

package "Storage" <<storage>> {
  rectangle "Alibaba Cloud OSS" as OSS
}

package "Caching" <<caching>> {
  rectangle "Redis" as Redis
}

