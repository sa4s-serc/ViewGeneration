```plantuml
@startuml DecenterApps_ResistanceProtocol
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<simulation>> #fddddd
  BackgroundColor<<contracts>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Smart Contracts" <<contracts>> {
  rectangle "NOI Stablecoin Protocol" as Protocol
  rectangle "CDP Management" as CDP
  rectangle "Liquidation Mechanisms" as Liquidation
  Protocol --> CDP
  CDP --> Liquidation
}

package "Simulation Engine (Python)" <<simulation>> {
  rectangle "Agent Models" as Agents
  rectangle "Economic Simulation" as EconSim
  rectangle "PID Controllers" as PID
  EconSim --> Agents
  EconSim --> PID
}

package "Frontend (React)" <<frontend>> {
  rectangle "React Components" as ReactComponents
  rectangle "Contract Interfaces" as ContractInterfaces
  rectangle "Blockchain Services" as BlockchainServices
  ReactComponents --> ContractInterfaces
  ContractInterfaces --> BlockchainServices
}

package "Backend (Python)" <<backend>> {
  rectangle "Smart Contract Deployment" as Deployment
  rectangle "Event Monitoring" as Monitoring
  rectangle "Bot Scripts" as Bots
  Deployment --> Monitoring
  Monitoring --> Bots
}

package "Development & Testing (Hardhat)" <<contracts>> {
  rectangle "Smart Contracts\nTesting" as Testing
  rectangle "Deployment Scripts" as DeployScripts
  Protocol --> Testing
  Testing --> DeployScripts
}

DeployScripts -> Deployment
BlockchainServices -> Protocol
Monitoring -> Protocol
Bots -> Liquidation
@enduml
