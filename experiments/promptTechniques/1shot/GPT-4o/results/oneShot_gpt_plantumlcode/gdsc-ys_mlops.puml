```plantuml
@startuml gdsc-ys_mlops
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor MLDeveloper

rectangle "Client-Side Tools" as ClientTools {
}

rectangle "Nginx Reverse Proxy" as Nginx #lightsteelblue

rectangle "MLflow Tracking Server" as MLflowServer #lightyellow {
  rectangle "REST API Endpoints" as RestAPI #aliceblue
}

rectangle "MySQL Database" as MySQL #mistyrose

rectangle "AWS S3 Artifact Store" as S3 #palegreen

' ========== Connections ==========
MLDeveloper --> ClientTools
ClientTools --> Nginx : track experiments\nlog artifacts
Nginx --> MLflowServer : route requests
MLflowServer --> MySQL : store metadata
MLflowServer --> S3 : store artifacts

@enduml
