```plantuml
@startuml shawntabrizi_Ethereum-Twitter-Bounty
skinparam rectangle {
  BackgroundColor<<smartcontract>> #f7d8ba
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<web3>> #fce5cd
  BackgroundColor<<truffle>> #e0f7d8
  Style roundrect
}
skinparam defaultTextAlignment center

package "Smart Contracts" <<smartcontract>> {
  rectangle "TwitterBounty.sol" as TwitterBounty
  rectangle "TwitterOracle.sol" as TwitterOracle
  TwitterBounty --> TwitterOracle : "oraclizeTweet()"
}

package "Frontend" <<frontend>> {
  rectangle "index.html" as HTML
  rectangle "CSS & JavaScript\n(Bootstrap, jQuery)" as CSSJS
  rectangle "app.js" as AppJS
  HTML --> CSSJS
  HTML --> AppJS
}

package "Web3 Integration" <<web3>> {
  rectangle "Web3.js" as Web3JS
  rectangle "TruffleContract" as TruffleContract
  AppJS --> Web3JS
  AppJS --> TruffleContract
}

package "Truffle Framework" <<truffle>> {
  rectangle "truffle-config.js" as TruffleConfig
  rectangle "migrations/2_deploy_contracts.js" as DeployScripts
  rectangle "test/TestTwitterBounty.js" as TestBounty
  rectangle "test/TestTwitterOracle.js" as TestOracle
  rectangle "TwitterBounty.json" as BountyJSON
  TruffleContract --> BountyJSON
}

Web3JS --> TwitterBounty
Web3JS --> TwitterOracle
@enduml
```