```plantuml
@startuml SimonLdj_hypnolog-server
skinparam rectangle {
  BackgroundColor<<server>> #d9e7fd
  BackgroundColor<<client>> #d8f5d3
  BackgroundColor<<component>> #fddddd
  BackgroundColor<<utility>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Server (Node.js/Express)" <<server>> {
  rectangle "HTTP Request Handler" as HTTPHandler
  rectangle "Socket.IO\nReal-time Communication" as SocketIO
  rectangle "Ajv JSON Validator" as AjvValidator
  rectangle "Routes" as Routes
  HTTPHandler --> SocketIO
  HTTPHandler --> AjvValidator
  HTTPHandler --> Routes
}

package "Web UI (HTML, JavaScript, CSS)" <<client>> {
  rectangle "Client HTML & CSS" as ClientHTML
  rectangle "Client JavaScript" as ClientJS
  rectangle "SystemJS" as SystemJS
  rectangle "JQuery" as JQuery
  ClientHTML --> ClientJS
  ClientJS --> SystemJS
  ClientJS --> JQuery
}

package "Components" <<component>> {
  rectangle "Visualizers" as Visualizers
  rectangle "VisualizerDispatcher" as VisualizerDispatcher
  rectangle "Windows" as Windows
  rectangle "WindowsDispatcher" as WindowsDispatcher
  rectangle "WindowsFilter" as WindowsFilter
  rectangle "ConfigFactory" as ConfigFactory
  VisualizerDispatcher --> Visualizers
  Windows --> VisualizerDispatcher
  Windows --> WindowsDispatcher
  Windows --> WindowsFilter
  ConfigFactory --> Visualizers
}

package "Utilities" <<utility>> {
  rectangle "hypnolog.sh Script" as HypnoLogScript
  rectangle "config.json" as ConfigJSON
  HypnoLogScript --> ConfigJSON
}

HTTPHandler --> SocketIO : Data Broadcast
SocketIO --> ClientJS : Real-time Updates
ConfigFactory --> ConfigJSON : Load Configuration
@enduml
```