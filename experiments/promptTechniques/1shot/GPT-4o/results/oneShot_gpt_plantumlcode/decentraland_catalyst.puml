```plantuml
@startuml decentraland_catalyst
skinparam rectangle {
  BackgroundColor<<service>> #d9e7fd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<logic>> #fddddd
  BackgroundColor<<controller>> #fff1c9
  BackgroundColor<<utility>> #f0f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Decentraland Catalyst Content Server" {
  package "Service Layer" <<service>> {
    rectangle "Server Setup\n(Server.ts)" as Server
    rectangle "Environment\n(Environment.ts)" as Environment
    rectangle "Content Service\n(service.ts)" as ContentService
    Server --> Environment
    ContentService --> Server
  }

  package "API Layer" <<api>> {
    rectangle "Profiles API\n(profiles/*)" as ProfilesAPI
    rectangle "Content API\n(content-v2/*)" as ContentAPI
    rectangle "Collections API\n(collections/*)" as CollectionsAPI
    rectangle "API Routes\n(routes.ts)" as APIRoutes
    APIRoutes --> ContentAPI
    APIRoutes --> ProfilesAPI
    APIRoutes --> CollectionsAPI
  }

  package "Logic Layer" <<logic>> {
    rectangle "Deployments Logic\n(deployments.ts)" as DeploymentsLogic
    rectangle "Entity Parser\n(entity-parser.ts)" as EntityParser
    rectangle "Synchronization\n(synchronization.ts)" as Synchronization
    rectangle "Snapshots\n(snapshots.ts)" as Snapshots
    DeploymentsLogic --> EntityParser
    Synchronization --> Snapshots
  }

  package "Controller Layer" <<controller>> {
    rectangle "API Handlers\n(handlers/*)" as APIHandlers
    APIHandlers --> APIRoutes
  }

  package "Utility Layer" <<utility>> {
    rectangle "Utility Classes\n(utils/*)" as Utils
    rectangle "Database Queries\n(database-queries/*)" as DBQueries
    rectangle "Validation Logic\n(validations/*)" as Validations
    Utils --> DBQueries
    Validations --> Utils
  }

  database "PostgreSQL" as PostgreSQL
  ContentService --> DeploymentsLogic
  ContentService --> APIHandlers
  ContentService --> PostgreSQL

  package "Third Party Services" {
    rectangle "The Graph\n(ports/the-graph/*)" as TheGraph
    rectangle "Third-Party Providers\n(ports/third-party/*)" as ThirdParty
    ContentAPI --> TheGraph
    ProfilesAPI --> TheGraph
    CollectionsAPI --> ThirdParty
  }
}
@enduml
```