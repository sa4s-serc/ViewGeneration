```plantuml
@startuml heli-os_member-invitation-java-springboot
skinparam rectangle {
  BackgroundColor<<interface>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<infrastructure>> #fddddd
  BackgroundColor<<commons>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Member Invitation Interface" <<interface>> {
  rectangle "MemberInvitationApplication" as App
  rectangle "RestController" as RestController
  rectangle "DTOs" as DTOs
  rectangle "Mapper" as Mapper
  rectangle "Configuration" as Config
  App --> RestController
  RestController --> DTOs
  DTOs --> Mapper
  RestController --> Config
}

package "Member Invitation Domain" <<domain>> {
  rectangle "Member" as Member
  rectangle "Invitation" as Invitation
  rectangle "Use Cases" as UseCases
  rectangle "Services" as Services
  UseCases --> Member
  UseCases --> Invitation
  Services --> UseCases
}

package "Member Invitation Infrastructure" <<infrastructure>> {
  package "Persistence Database" {
    rectangle "JPA Entities" as JPAEntities
    rectangle "Repositories" as Repositories
    rectangle "Persistence Services" as PersistenceServices
    Services --> JPAEntities
    JPAEntities --> Repositories
    Repositories --> PersistenceServices
  }

  package "Redis Adapter" {
    rectangle "Redis Persistence" as RedisPersistence
    Services --> RedisPersistence
  }
}

package "Commons" <<commons>> {
  rectangle "Common Models" as CommonModels
  rectangle "Common Utilities" as CommonUtilities
  CommonModels --> Member
  CommonModels --> Invitation
  CommonUtilities --> Services
}

@enduml
