```plantuml
@startuml quasirsg_Henry-M3
skinparam sequence {
  BackgroundColor #f0f0f0
  ArrowColor #000000
  ActorBorderColor #000000
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #f0f0f0
  ParticipantBorderColor #000000
  ParticipantBackgroundColor #ffffff
  ActorBackgroundColor #ffffff
  BoxBorderColor black
  BoxBackgroundColor white
}

actor Developer

box "Node.js/Express.js Learning Repository" #lightgrey
  participant "pledge.js\n(Custom $Promise)" as Pledge
  participant "server.js\n(Express Server)" as Server
  participant "index.js\n(Express Example)" as Index
  participant "myapp/\n(Express Application)" as MyApp
  participant "custom.matchers.js\n(Jasmine Matchers)" as Matchers
end box

box "Testing Framework" #aliceblue
  participant "Mocha/Chai" as TestingFramework
  participant "Supertest" as Supertest
end box

Developer -> Pledge : Create custom $Promise
Pledge -> Developer : Return $Promise instance

Developer -> Matchers : Test $Promise with Jasmine

Developer -> Server : Start Express server
Server -> MyApp : Load Express application
Server -> Index : Load Express example

Developer -> Server : Send HTTP request
Server -> MyApp : Route request
MyApp -> MyApp : Process with middleware
MyApp -> MyApp : Handle request and return response
MyApp -> Server : Send response

Server -> Developer : Return HTTP response

Developer -> TestingFramework : Run tests for server.js
TestingFramework -> Supertest : Simulate HTTP requests

TestingFramework -> Developer : Report test results

@enduml
```