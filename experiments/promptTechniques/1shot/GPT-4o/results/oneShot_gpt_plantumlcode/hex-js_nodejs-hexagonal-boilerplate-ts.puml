```plantuml
@startuml hex-js_nodejs-hexagonal-boilerplate-ts
skinparam rectangle {
  BackgroundColor<<business>> #d9e7fd
  BackgroundColor<<adapters>> #d8f5d3
  BackgroundColor<<ports>> #fddddd
  BackgroundColor<<aws>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Business Logic" <<business>> {
  rectangle "Core Logic" as CoreLogic
}

package "Adapters" <<adapters>> {
  rectangle "Todo Adapter" as TodoAdapter
  rectangle "todoAdapterFactory" as AdapterFactory
  CoreLogic <-- TodoAdapter
  TodoAdapter --> AdapterFactory
}

package "Ports" <<ports>> {
  rectangle "DynamoDB Repository" as DynamoDBRepo
  rectangle "SQS Interaction" as SQSInteraction
  rectangle "Lambda Handler" as LambdaHandler
  rectangle "HTTP Server\n(Express.js)" as HTTPServer
  rectangle "Logger (pino)" as Logger
  TodoAdapter --> DynamoDBRepo
  TodoAdapter --> SQSInteraction
  TodoAdapter --> LambdaHandler
  HTTPServer --> CoreLogic
  CoreLogic --> Logger
}

package "AWS Services" <<aws>> {
  rectangle "DynamoDB" as DynamoDB
  rectangle "SQS" as SQS
  rectangle "Lambda" as Lambda
  DynamoDBRepo --> DynamoDB
  SQSInteraction --> SQS
  LambdaHandler --> Lambda
}

@enduml
```