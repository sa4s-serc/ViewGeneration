```plantuml
@startuml codestates_BEB-05-LeeSea
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<blockchain>> #fddddd
  BackgroundColor<<state>> #fff1c9
  BackgroundColor<<smart_contract>> #e0e7fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "Components\n(Navbar, Home, Profile,\nCreate, Explore)" as Components
  rectangle "Web3.js" as Web3
  rectangle "Redux Store" <<state>> {
    rectangle "accountSlice.js" as AccountSlice
    rectangle "tokenSlice.js" as TokenSlice
  }
  Components --> Web3
  Components --> AccountSlice
  Components --> TokenSlice
}

package "Backend (Solidity & Yul)" <<backend>> {
  rectangle "LeeSeaNFT.sol" <<smart_contract>> as LeeSeaNFT
  rectangle "LeeSeaMarket.sol" <<smart_contract>> as LeeSeaMarket
  rectangle "#utility.yul" <<smart_contract>> as UtilityYul
  LeeSeaNFT --> UtilityYul
  LeeSeaMarket --> UtilityYul
}

package "Blockchain Interaction" <<blockchain>> {
  rectangle "Ethereum Blockchain" as Ethereum
  Web3 --> Ethereum
  LeeSeaNFT --> Ethereum
  LeeSeaMarket --> Ethereum
}

@enduml
```