```plantuml
@startuml adityajain10_foot365-live-streaming-chatbot-prediction-app-on-aws
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
  rectangle "HTML/CSS/JS\nUI" as UI
  rectangle "apigClient.js" as APIGClient
}

rectangle "API Gateway" as APIGateway #lightcoral

rectangle "AWS Lambda" as Lambda #lightblue {
  rectangle "standings.py" as Standings
  rectangle "predictions.py" as Predictions
  rectangle "LF2.py" as LF2
  rectangle "getFixtures.py" as GetFixtures
  rectangle "scrapeMatchData.py" as ScrapeMatchData
  rectangle "getScore.py" as GetScore
  rectangle "LF1.py" as LF1
  rectangle "getLiveScores.py" as GetLiveScores
}

rectangle "AWS Services" as AWSServices #lightyellow {
  rectangle "Cognito" as Cognito
  rectangle "DynamoDB" as DynamoDB
  rectangle "ElasticSearch" as ElasticSearch
  rectangle "S3" as S3
  rectangle "SQS" as SQS
  rectangle "SNS" as SNS
  rectangle "SageMaker" as SageMaker
  rectangle "Lex" as Lex
  rectangle "EC2" as EC2
  rectangle "CloudWatch" as CloudWatch
}

rectangle "Kafka Infrastructure" as Kafka #aliceblue {
  rectangle "producer.js" as Producer
  rectangle "consumer.js" as Consumer
}

' ========== Connections ==========
User --> UI : Access match data,\nmake predictions,\nuse chatbot

UI --> APIGClient : Make API requests

APIGClient --> APIGateway : Call API endpoints

APIGateway --> Lambda : Route requests to functions

' Lambda functions interactions
Standings --> DynamoDB : Fetch/Process standings data
Predictions --> SageMaker : Predict match outcomes
LF2 --> SQS : Process chatbot requests
LF2 --> ElasticSearch : Retrieve fixtures
LF2 --> SNS : Send SMS
GetFixtures --> ElasticSearch : Fetch match fixtures
ScrapeMatchData --> S3 : Trigger on JSON upload
ScrapeMatchData --> DynamoDB : Store match standings
GetScore --> ElasticSearch : Query match data
GetScore --> DynamoDB : Retrieve details
LF1 --> Lex : Handle chatbot requests
GetLiveScores --> DynamoDB : Fetch live scores

' Kafka interactions
Producer --> Kafka : Publish Football API data
Consumer --> Kafka : Consume messages
Consumer --> DynamoDB : Store/Update data

' Other AWS service interactions
Cognito <--> APIGateway : User authentication
CloudWatch --> Lambda : Monitor/Trigger functions
EC2 --> Kafka : Host infrastructure
@enduml
```