```plantuml
@startuml abel-gr_warehouse-robot
skinparam rectangle {
  BackgroundColor<<unity>> #d9e7fd
  BackgroundColor<<coppelia>> #d8f5d3
  BackgroundColor<<web>> #fddddd
  BackgroundColor<<cloud>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Unity Environment" <<unity>> {
  rectangle "Warehouse Prefabs\n(Drop Zone, Shelves, Robot)" as Prefabs
  rectangle "MonoBehaviour Scripts" as MonoBehaviour
  Prefabs --> MonoBehaviour
}

package "CoppeliaSim Simulation" <<coppelia>> {
  rectangle "sim.py\n(Remote API Interface)" as SimPy
  rectangle "robot.py\n(Robot Class)" as RobotPy
  rectangle "main.py\n(Simulation Entry Point)" as MainPy
  rectangle "OCR Functionality\n(OCR_Lite.py, etc.)" as OCR
  SimPy --> RobotPy
  RobotPy --> MainPy
  MainPy --> OCR
}

package "Web Interface" <<web>> {
  rectangle "JavaScript UI" as JSUI
  rectangle "Recorder.js\n(Audio Recording)" as RecorderJS
  JSUI --> RecorderJS
}

package "Cloud Integration" <<cloud>> {
  rectangle "Speech-to-Text Function\n(Google Cloud Functions)" as SpeechToText
  RecorderJS --> SpeechToText
}

SimPy --> Prefabs
@enduml
```