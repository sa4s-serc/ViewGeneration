```plantuml
@startuml coverage-robot_core
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Developer

rectangle "Webhooks" as Webhooks #aliceblue

rectangle "AWS S3" as S3 #lightyellow

rectangle "AWS DynamoDB" as DynamoDB #lightsteelblue

rectangle "AWS EventBridge" as EventBridge #mistyrose

rectangle "AWS Lambda\n(api service)" as APILambda #palegreen

rectangle "AWS Lambda\n(orchestrator service)" as OrchestratorLambda #thistle

rectangle "AWS Lambda\n(analyse service)" as AnalyseLambda #lavender

rectangle "AWS Lambda\n(publish service)" as PublishLambda #lightcoral

rectangle "External Platforms\n(e.g., GitHub)" as ExternalPlatform #beige

' ========== Connections ==========
Developer --> Webhooks : initiate webhook

' API Service interactions
Webhooks --> APILambda : process webhook\nvalidate & enqueue

APILambda --> DynamoDB : store configurations\n& metadata
APILambda --> S3 : generate pre-signed URLs\nfor report upload

' Event-driven workflow
APILambda --> EventBridge : emit event\nfor orchestration

' Orchestrator Service interactions
EventBridge --> OrchestratorLambda : trigger processing
OrchestratorLambda --> DynamoDB : update event store

' Analyse Service interactions
OrchestratorLambda --> AnalyseLambda : trigger analysis
AnalyseLambda --> DynamoDB : store analysis state

' Publish Service interactions
AnalyseLambda --> PublishLambda : trigger report publishing
PublishLambda --> ExternalPlatform : publish report to GitHub

@enduml
```