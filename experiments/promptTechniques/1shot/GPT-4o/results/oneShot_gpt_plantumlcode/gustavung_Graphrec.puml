```plantuml
@startuml gustavung_Graphrec
skinparam rectangle {
  BackgroundColor<<client>> #f3f4f6
  BackgroundColor<<server>> #e8f4ea
  BackgroundColor<<nn>> #f4e8f4
  Style roundrect
}
skinparam defaultTextAlignment center

package "Android Application (Client)" <<client>> {
  rectangle "MainActivity.java" as MainActivity
  rectangle "CameraActivity.java" as CameraActivity
  rectangle "ResultActivity.java" as ResultActivity
  rectangle "ImageUploadTask.java" as ImageUploadTask
  rectangle "CameraPreview.java\nSurfaceOverlay.java" as CameraComponents
  MainActivity --> CameraActivity
  CameraActivity --> ImageUploadTask
  ImageUploadTask --> ResultActivity
  CameraActivity --> CameraComponents
}

package "Flask Server (Backend)" <<server>> {
  rectangle "server.py" as ServerPy
  rectangle "graph_classifier.py" as GraphClassifier
  rectangle "graph_images.py" as GraphImages
  rectangle "generate_data.py" as GenerateData
  rectangle "cn.py" as CN
  ServerPy --> GraphClassifier
  GraphClassifier --> CN
  CN --> GraphImages
  GenerateData --> GraphImages
}

package "Neural Network (CNN)" <<nn>> {
  rectangle "TensorFlow Model" as TFModel
  GraphClassifier --> TFModel
}

MainActivity --> ServerPy : HTTP POST
@enduml
```