```plantuml
@startuml NodleCode_n1
skinparam rectangle {
  BackgroundColor<<device>> #d9e7fd
  BackgroundColor<<application>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<hardware>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Device Tier (iBeacon Firmware)" <<device>> {
  rectangle "Dialog DA14531\nFirmware" as Firmware
  rectangle "Peripheral Initialization" as Peripherals
  rectangle "BLE Stack Components" as BLEStack
  rectangle "Configuration Files" as ConfigFiles
  rectangle "Memory Management" as MemManage
  Firmware --> Peripherals
  Firmware --> BLEStack
  Firmware --> ConfigFiles
  Firmware --> MemManage
}

package "Application Tier (Nodle Mobile App)" <<application>> {
  rectangle "Beacon Detector" as Detector
  rectangle "Relay to Cloud" as Relay
  Detector --> Relay
}

package "Data Tier (Nodle Cloud)" <<data>> {
  rectangle "Backend System" as Backend
  rectangle "API Data Retrieval" as API
  Backend --> API
}

package "Hardware Design (PCB)" <<hardware>> {
  rectangle "Gerber Files" as Gerber
  rectangle "Manufacturing Layers" as Layers
  rectangle "Design Rules" as Rules
  Gerber --> Layers
  Gerber --> Rules
}

rectangle "Python Script\n(getBeaconInformation.py)" as PythonScript
PythonScript --> Backend

Detector --> Firmware
Relay --> Backend
@enduml
```