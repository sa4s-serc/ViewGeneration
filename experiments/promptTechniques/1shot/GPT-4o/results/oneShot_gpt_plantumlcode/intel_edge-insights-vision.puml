```plantuml
@startuml intel_edge-insights-vision
skinparam rectangle {
  BackgroundColor<<core>> #f5f5dc
  BackgroundColor<<scripts>> #e6e6fa
  BackgroundColor<<documentation>> #ffe4e1
  BackgroundColor<<governance>> #d3d3d3
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Functionality" <<core>> {
  rectangle "eiv_install.sh" as Install
  rectangle "eiv_setup.py" as Setup
}

package "Scripts" <<scripts>> {
  rectangle "eiv_callbacks.sh" as Callbacks
  rectangle "launch_notebooks.sh" as LaunchNotebooks
  rectangle "adl_*.sh" as ADLScripts
}

package "Documentation & Information" <<documentation>> {
  rectangle "README.md" as Readme
  rectangle "docs/*" as Docs
}

package "Project Governance & Dependencies" <<governance>> {
  rectangle "CODE_OF_CONDUCT.md" as CodeOfConduct
  rectangle "LICENSE" as License
  rectangle "CONTRIBUTING.md" as Contributing
  rectangle "security.md" as Security
  rectangle "requirements.txt" as Requirements
}

Install --> Setup
Install --> Callbacks
Callbacks --> LaunchNotebooks
Callbacks --> ADLScripts
Readme --> Docs
Contributing --> CodeOfConduct
Contributing --> License
Contributing --> Security
Contributing --> Requirements
@enduml
```