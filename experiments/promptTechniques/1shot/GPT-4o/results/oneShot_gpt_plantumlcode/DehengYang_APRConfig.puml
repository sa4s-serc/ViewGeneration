```plantuml
@startuml DehengYang_APRConfig
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Researcher" as User

rectangle "APRConfig" as APRConfig {
  rectangle "Run_d4j_1.py" as RunScript
  rectangle "Dataset/Defects4j.py" as Dataset
  rectangle "Localization/Gzoltar.py" as Localization
  rectangle "Apr/*.py" as APRTools
  rectangle "Config.py" as Config
  rectangle "Main_parse.py" as Parse
}

rectangle "Defects4J" as Defects4J #lightgrey

rectangle "Gzoltar" as Gzoltar #lightblue

rectangle "SimFix" as SimFix #lightgreen
rectangle "TBar" as TBar #lightgreen
rectangle "Nopol" as Nopol #lightgreen
rectangle "DynamoTH" as DynamoTH #lightgreen

' ========== Connections ==========
User --> RunScript : execute

RunScript --> Dataset : access
RunScript --> Config : load configurations
RunScript --> Localization : perform fault localization
RunScript --> APRTools : generate patches
RunScript --> Parse : parse results

Dataset --> Defects4J : utilize benchmark dataset
Localization --> Gzoltar : perform fault localization

APRTools --> SimFix : use tool
APRTools --> TBar : use tool
APRTools --> Nopol : use tool
APRTools --> DynamoTH : use tool

Parse --> User : output results in CSV
@enduml
```