```plantuml
@startuml llvm_torch-mlir
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<dialect>> #fddddd
  BackgroundColor<<transformation>> #fff1c9
  BackgroundColor<<target>> #f3e5ab
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as user

package "Frontends" <<frontend>> {
  rectangle "Tracing-based (LTC)" as Tracing
  rectangle "TorchScript & FX Graph Importers" as TorchScriptFX
}

package "Core Dialects" <<dialect>> {
  rectangle "Torch Dialect" as TorchDialect
  rectangle "TMTensor Dialect" as TMTensorDialect
  rectangle "TorchConversion Dialect" as TorchConversionDialect
}

package "Transformation Passes" <<transformation>> {
  rectangle "Reify Shape/Dtype Calculations" as ReifyShape
  rectangle "Adjust Calling Conventions" as AdjustCalling
  rectangle "Globalize Object Graph" as GlobalizeObject
  rectangle "Fuse Quantized Ops" as FuseOps
  rectangle "Scalarize Shapes" as ScalarizeShapes
  rectangle "Lower To Backend Contract" as LowerBackend
}

package "Backend Targets" <<target>> {
  rectangle "Linalg-on-Tensors" as Linalg
  rectangle "TOSA" as TOSA
  rectangle "StableHLO" as StableHLO
  rectangle "ONNX" as ONNX
  rectangle "Lazy Tensor Core (LTC)" as LazyTensor
}

user --> Tracing
user --> TorchScriptFX

Tracing --> TorchDialect
TorchScriptFX --> TorchDialect

TorchDialect --> ReifyShape
TorchDialect --> AdjustCalling
TorchDialect --> GlobalizeObject
TorchDialect --> FuseOps
TorchDialect --> ScalarizeShapes
TorchDialect --> LowerBackend

ReifyShape --> TMTensorDialect
AdjustCalling --> TMTensorDialect
GlobalizeObject --> TMTensorDialect
FuseOps --> TMTensorDialect
ScalarizeShapes --> TMTensorDialect
LowerBackend --> TMTensorDialect

TMTensorDialect --> Linalg
TMTensorDialect --> TOSA
TMTensorDialect --> StableHLO
TMTensorDialect --> ONNX
TMTensorDialect --> LazyTensor

@enduml
```