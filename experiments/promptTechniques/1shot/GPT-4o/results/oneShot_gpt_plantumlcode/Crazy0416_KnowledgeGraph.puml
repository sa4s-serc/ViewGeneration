```plantuml
@startuml Crazy0416_KnowledgeGraph
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Knowledge Graph\nVisualization Application" as KGApp {
  rectangle "Sigma.js" as SigmaJs
  rectangle "Elasticsearch" as Elasticsearch
  rectangle "CayleyGraph" as CayleyGraph
}

rectangle "Materialize CSS Framework" as MaterializeCSS {
  rectangle "DOM Manipulation\nUtilities" as DOMUtils
  rectangle "Anime.js" as AnimeJS
  rectangle "ForceAtlas2" as ForceAtlas2
}

rectangle "Core Libraries" as CoreLibs {
  rectangle "Redux" as Redux
  rectangle "Flatpickr" as Flatpickr
}

' ========== Connections ==========
User --> KGApp : Interact with\nVisualization Tool

' Knowledge Graph Visualization interactions
KGApp <--> SigmaJs : Render and manipulate\nknowledge graphs
KGApp <--> Elasticsearch : Query RDF data
KGApp <--> CayleyGraph : Store and query graph data

' Materialize CSS Framework interactions
MaterializeCSS <--> DOMUtils : UI Element\nManipulation
MaterializeCSS <--> AnimeJS : Handle Animations
MaterializeCSS <--> ForceAtlas2 : Apply Layout Algorithms

' Core Libraries interactions
CoreLibs <--> Redux : State Management
CoreLibs <--> Flatpickr : Date/Time Selection

@enduml
```