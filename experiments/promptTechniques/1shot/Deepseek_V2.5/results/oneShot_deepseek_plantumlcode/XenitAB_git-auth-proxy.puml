@startuml XenitAB_git-auth-proxy
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Git Client" as Client

rectangle "Kubernetes Cluster" as K8s {
  rectangle "git-auth-proxy" as Proxy {
    rectangle "Auth Layer" as Auth
    rectangle "Proxy Server" as Server
    rectangle "Token Writer" as TokenWriter
    rectangle "Metrics" as Metrics
  }
  rectangle "Secrets" as Secrets
}

rectangle "Git Providers" as GitProviders {
  rectangle "GitHub" as GitHub
  rectangle "Azure DevOps" as AzureDevOps
}

' ========== Connections ==========
Client -> Proxy: Git requests (clone/pull/push)
Proxy --> K8s: Read configuration\nValidate tokens
Proxy --> GitProviders: Forward authenticated requests

Auth --> Server: Validate tokens
Server --> Auth: Check authorization
TokenWriter --> Secrets: Create/update/delete tokens
Secrets --> TokenWriter: Watch for changes
Proxy --> Metrics: Expose metrics

GitProviders --> Proxy: Return responses
Proxy --> Client: Return responses
@enduml