@startuml dwt0317_Search_Adserver
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
}

rectangle "Search Ad Server" as Server {
  rectangle "ESServlet" as ESServlet #palegreen
  rectangle "BingServlet" as BingServlet #palegreen
  rectangle "AdRetrieval" as AdRetrieval #lightsteelblue
  rectangle "QueryRewriter" as QueryRewriter #lightyellow
  rectangle "ESHandler" as ESHandler #aliceblue
  rectangle "DBPool" as DBPool #mistyrose
}

rectangle "External Services" as External {
  rectangle "Bing Search API" as BingAPI #lightcoral
  rectangle "Elasticsearch" as ES #lightblue
  rectangle "MariaDB" as DB #wheat
  rectangle "Thrift Services" as Thrift #plum
}

User -> FE : Search Query
FE -> ESServlet : HTTP Request (ES path)
FE -> BingServlet : HTTP Request (Bing path)

' ES Path
ESServlet -> ESHandler : Process query
ESHandler -> ES : Search books/ads
ES --> ESHandler : Results
ESHandler -> AdRetrieval : Pass query

' Bing Path
BingServlet -> BingAPI : Forward query
BingAPI --> BingServlet : Results
BingServlet -> AdRetrieval : Pass query

' Common Ad Flow
AdRetrieval -> QueryRewriter : Rewrite query
QueryRewriter -> Thrift : Call rewriting service
Thrift --> QueryRewriter : Rewritten query
QueryRewriter --> AdRetrieval : Return rewritten query

AdRetrieval -> ESHandler : Search ads
ESHandler -> ES : Search ads
ES --> ESHandler : Ad IDs
ESHandler --> AdRetrieval : Return ad IDs

AdRetrieval -> DBPool : Get ad details
DBPool -> DB : Query ads
DB --> DBPool : Ad data
DBPool --> AdRetrieval : Return ads

AdRetrieval -> Thrift : Call ranking service
Thrift --> AdRetrieval : Ranked ads

AdRetrieval --> ESServlet/BingServlet : Return ads
ESServlet/BingServlet --> FE : HTTP Response
FE --> User : Display results
@enduml