@startuml s-sokolko_smev3_adapter_service
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Client

rectangle "API Layer" as API {
  rectangle "views.py" as Views
}

rectangle "Business Logic" as Business {
  rectangle "query.py" as QueryProcessor
}

rectangle "SMEV3 Integration" as SMEV {
  rectangle "adapter.py" as Adapter
}

rectangle "Data Access" as Data {
  rectangle "models.py" as Models
  rectangle "core.py" as Core
}

rectangle "Schema Management" as Schema {
  rectangle "loader.py" as Loader
  rectangle "transport.py" as Transport
}

rectangle "MongoDB" as MongoDB #aliceblue
rectangle "SMEV3 Adapter" as SMEV3 #mistyrose

' ========== Connections ==========
Client -> Views : HTTP Request (REST API)
Views -> QueryProcessor : Process request
QueryProcessor -> Adapter : Send SOAP request
Adapter -> SMEV3 : SOAP call
SMEV3 -> Adapter : SOAP response
Adapter -> QueryProcessor : Process response
QueryProcessor -> Models : Store data
Models -> MongoDB : CRUD operations
QueryProcessor --> Loader : Validate with XSD
Loader -> Transport : Load schema
Transport -> Schema : Access XSD files
Core <--> MongoDB : DB connection
Core <--> Adapter : Initialize
@enduml