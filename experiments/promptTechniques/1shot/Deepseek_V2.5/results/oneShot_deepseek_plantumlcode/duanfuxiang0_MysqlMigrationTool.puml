@startuml duanfuxiang0_MysqlMigrationTool
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "MySQL Source DB" as SourceDB #palegreen

rectangle "Migration Tool" as MigrationTool {
    rectangle "Binlog Listener" as BinlogListener #lightsteelblue
    rectangle "Binlog Parser" as BinlogParser #lightyellow
    rectangle "Row Event Handler" as EventHandler #aliceblue
    rectangle "Data Mapper" as DataMapper #mistyrose
}

rectangle "Target Database" as TargetDB #palegreen

' ========== Connections ==========
SourceDB --> BinlogListener : Stream binlog events
BinlogListener --> BinlogParser : Forward raw events
BinlogParser --> EventHandler : Processed row events
EventHandler --> DataMapper : Map to target schema
DataMapper --> TargetDB : Execute SQL operations

' Event Handler details
EventHandler --> EventHandler : InsertToNew\nUpdateToNew\nDeleteFromNew
EventHandler --> EventHandler : Error handling\n(defer/recover)

' Data flow annotations
note right of BinlogParser
  Converts MySQL data types
  to Go types (bool, string, int, time)
end note

note right of DataMapper
  Uses reflection to map
  binlog data to structs
  (User, Email, Mobile)
end note
@enduml