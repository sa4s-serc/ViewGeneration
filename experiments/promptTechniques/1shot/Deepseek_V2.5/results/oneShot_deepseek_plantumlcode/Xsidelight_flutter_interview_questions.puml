@startuml Xsidelight_flutter_interview_questions
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<docs>> #d8f5d3
  BackgroundColor<<patterns>> #fddddd
  BackgroundColor<<content>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Repository" <<core>> {
  rectangle "README.md" as README
  rectangle "Interview Questions" as Questions
  rectangle "Answers & Examples" as Answers
  README --> Questions
  Questions --> Answers
}

package "Documentation" <<docs>> {
  rectangle "Flutter Internals" as FlutterDocs
  rectangle "Dart Internals" as DartDocs
  Answers --> FlutterDocs
  Answers --> DartDocs
}

package "Design Patterns" <<patterns>> {
  rectangle "Creational" as Creational
  rectangle "Structural" as Structural
  rectangle "Behavioral" as Behavioral
  rectangle "Dependency Injection" as DI
  Answers --> Creational
  Answers --> Structural
  Answers --> Behavioral
  Answers --> DI
}

package "Content Categories" <<content>> {
  rectangle "Software Development" as SoftwareDev
  rectangle "Dart Concepts" as Dart
  rectangle "Flutter Concepts" as Flutter
  Questions --> SoftwareDev
  Questions --> Dart
  Questions --> Flutter
}
@enduml