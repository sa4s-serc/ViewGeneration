@startuml zeromicro_zero-doc
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<rpc>> #d8f5d3
  BackgroundColor<<tooling>> #fddddd
  BackgroundColor<<infra>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Framework" <<core>> {
  rectangle "API Gateway" as Gateway
  rectangle "Service Discovery" as Discovery
  rectangle "Adaptive Load Shedding" as LoadShedding
  rectangle "Circuit Breaker" as CircuitBreaker
  rectangle "Rate Limiting" as RateLimit
  rectangle "Caching Layer" as Caching
  rectangle "Concurrency Utilities" as Concurrency
  rectangle "Metrics & Tracing" as Observability
}

package "zRPC Framework" <<rpc>> {
  rectangle "gRPC Core" as gRPC
  rectangle "Service Stubs" as Stubs
  rectangle "Interceptors" as Interceptors
  rectangle "Load Balancing" as LB
}

package "Tooling" <<tooling>> {
  rectangle "goctl CLI" as goctl
  rectangle "API Definition (.api)" as APIDef
  rectangle "Model Generation" as ModelGen
  rectangle "Proto Generation" as ProtoGen
  rectangle "Deployment Gen" as DeployGen
}

package "Infrastructure" <<infra>> {
  rectangle "Database" as DB
  rectangle "Redis" as Redis
  rectangle "etcd" as etcd
  rectangle "Kafka" as Kafka
  rectangle "Prometheus" as Prometheus
}

Gateway --> Discovery
Gateway --> LoadShedding
Gateway --> CircuitBreaker
Gateway --> RateLimit
Gateway --> Caching
Gateway --> Observability

gRPC --> Stubs
gRPC --> Interceptors
gRPC --> LB
gRPC --> Discovery

goctl --> APIDef
goctl --> ModelGen
goctl --> ProtoGen
goctl --> DeployGen

Caching --> Redis
Discovery --> etcd
Concurrency --> Kafka
Observability --> Prometheus
ModelGen --> DB
@enduml