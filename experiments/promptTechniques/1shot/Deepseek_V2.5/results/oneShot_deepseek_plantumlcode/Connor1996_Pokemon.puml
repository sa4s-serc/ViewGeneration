@startuml Connor1996_Pokemon
skinparam rectangle {
  BackgroundColor<<client>> #d9e7fd
  BackgroundColor<<server>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<gui>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Client" <<client>> {
  rectangle "Qt GUI" as GUI
  rectangle "Game Logic" as GameLogic
  rectangle "Pokemon Classes" as Pokemon
  rectangle "Pokemon Factory" as Factory
  rectangle "JSON Communication" as JSON
  GUI --> GameLogic
  GameLogic --> Pokemon
  GameLogic --> Factory
  GameLogic --> JSON
}

package "Server" <<server>> {
  rectangle "Multi-threaded Server" as Server
  rectangle "Request Dispatcher" as Dispatcher
  rectangle "Socket Communication" as Socket
  Server --> Dispatcher
  Dispatcher --> Socket
}

package "Data Management" <<data>> {
  rectangle "SQLite Database" as DB
  rectangle "ORM Layer" as ORM
  rectangle "Data Models" as Models
  ORM --> DB
  Models --> ORM
}

package "GUI Components" <<gui>> {
  rectangle "Login Widget" as Login
  rectangle "Game Lobby" as Lobby
  rectangle "Battle Widgets" as Battle
  rectangle "User Interface" as UI
  Login --> Lobby
  Lobby --> Battle
  Lobby --> UI
}

JSON --> Socket
Dispatcher --> ORM
GameLogic --> UI
@enduml