@startuml gpsnmeajp_VirtualMotionTracker
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<modules>> #d8f5d3
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<unsupported>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Components" <<core>> {
  rectangle "Matrix/Vector Operations" as MatrixOps
  rectangle "Expression Templates" as ExprTemplates
  rectangle "SIMD Vectorization" as SIMD
  rectangle "Memory Management" as Memory
  rectangle "Traits & Metaprogramming" as Traits
  MatrixOps --> ExprTemplates
  ExprTemplates --> SIMD
  ExprTemplates --> Memory
  ExprTemplates --> Traits
}

package "Main Modules" <<modules>> {
  rectangle "Dense Linear Algebra" as Dense
  rectangle "Sparse Linear Algebra" as Sparse
  rectangle "Decompositions" as Decomp
  rectangle "Eigenvalue Solvers" as EigenSolvers
  rectangle "Iterative Solvers" as Iterative
  rectangle "Geometry" as Geometry
  Dense --> MatrixOps
  Sparse --> MatrixOps
  Decomp --> Dense
  Decomp --> Sparse
  EigenSolvers --> Decomp
  Iterative --> Sparse
  Geometry --> MatrixOps
}

package "Unsupported Modules" <<unsupported>> {
  rectangle "Tensor Operations" as Tensor
  rectangle "Matrix Functions" as MatFunc
  rectangle "NonLinear Optimization" as NLOpt
  Tensor --> MatrixOps
  MatFunc --> Decomp
  NLOpt --> MatrixOps
}

package "External Integrations" <<external>> {
  rectangle "BLAS/LAPACK" as BLAS
  rectangle "MKL/OpenBLAS" as MKL
  rectangle "LAPACKE" as LAPACKE
  Dense --> BLAS
  Sparse --> BLAS
  Decomp --> LAPACKE
  LAPACKE --> MKL
}

@enduml