@startuml victorshinya_serverless-chatbot
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
}

rectangle "IBM Cloud Functions" as ICF #mistyrose {
  rectangle "assistant.js" as Assistant #palegreen
  rectangle "mongodb.js" as MongoDB #lightsteelblue
}

rectangle "Watson Assistant" as WA #lightyellow

rectangle "MongoDB" as DB #aliceblue

' ========== Connections ==========
User -> FE : Sends message
FE -> ICF : Triggers function sequence

' IBM Cloud Functions interactions
Assistant -> WA : Sends user input\nGets response
MongoDB -> DB : Stores conversation data

' Sequence flow
Assistant -> MongoDB : Passes conversation data
@enduml