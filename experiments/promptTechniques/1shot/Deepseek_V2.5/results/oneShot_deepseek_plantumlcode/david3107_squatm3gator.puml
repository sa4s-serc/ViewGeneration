@startuml david3107_squatm3gator
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "HTML Templates" as HTML
  rectangle "CSS (Bootstrap/MDB)" as CSS
  rectangle "JavaScript" as JS
  rectangle "Socket.IO Client" as SocketIO
  HTML --> CSS
  HTML --> JS
  JS --> SocketIO
}

package "Backend (Flask)" <<backend>> {
  rectangle "API Endpoints" as API
  rectangle "Attack Modules" as Attacks
  rectangle "Job Queue Handler" as JobQueue
  rectangle "Configuration" as Config
  API --> JobQueue
  JobQueue --> Attacks
  Attacks --> Config
}

package "Integrations" <<integration>> {
  rectangle "Redis" as Redis
  rectangle "GoDaddy API" as GoDaddy
  rectangle "WHOIS Lookup" as Whois
  JobQueue --> Redis
  Attacks --> GoDaddy
  Attacks --> Whois
}

database "Redis Cache" <<db>> as Cache
Redis --> Cache

API --> SocketIO
@enduml