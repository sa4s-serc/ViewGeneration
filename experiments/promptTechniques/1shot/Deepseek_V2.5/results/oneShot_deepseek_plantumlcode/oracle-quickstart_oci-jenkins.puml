@startuml oracle-quickstart_oci-jenkins
skinparam rectangle {
  BackgroundColor<<terraform>> #d9e7fd
  BackgroundColor<<jenkins>> #d8f5d3
  BackgroundColor<<oci>> #fddddd
  BackgroundColor<<security>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Terraform Modules" <<terraform>> {
  rectangle "main.tf" as Main
  rectangle "jenkins-controller\nmodule" as ControllerModule
  rectangle "jenkins-agent\nmodule" as AgentModule
  rectangle "variables.tf" as Variables
  rectangle "outputs.tf" as Outputs
  Main --> ControllerModule
  Main --> AgentModule
  Main --> Variables
  Main --> Outputs
}

package "Jenkins Components" <<jenkins>> {
  rectangle "Jenkins Controller" as Controller
  rectangle "Jenkins Agents" as Agents
  ControllerModule --> Controller
  AgentModule --> Agents
  Controller --> Agents
}

package "OCI Resources" <<oci>> {
  rectangle "VCN & Subnets" as VCN
  rectangle "Load Balancer" as LB
  rectangle "NAT Gateway" as NAT
  rectangle "Internet Gateway" as IGW
  Controller --> LB
  Controller --> VCN
  Agents --> VCN
  VCN --> NAT
  VCN --> IGW
}

package "Security" <<security>> {
  rectangle "Bastion Host/Service" as Bastion
  rectangle "Security Lists" as SecurityLists
  rectangle "SSH Keys" as SSH
  Bastion --> Controller
  Bastion --> Agents
  VCN --> SecurityLists
  Controller --> SSH
  Agents --> SSH
}

note right of ControllerModule
  Contains setup.sh for
  Jenkins installation
  and configuration
end note

note right of AgentModule
  Contains config.sh for
  agent registration
  and setup
end note
@enduml