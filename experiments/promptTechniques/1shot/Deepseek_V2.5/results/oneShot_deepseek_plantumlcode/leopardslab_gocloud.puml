@startuml leopardslab_gocloud
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<providers>> #d8f5d3
  BackgroundColor<<services>> #fddddd
  BackgroundColor<<auth>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Interfaces" <<core>> {
  rectangle "Gocloud Interface" as Gocloud
  rectangle "CloudProvider Factory" as Factory
  rectangle "Common Interfaces" as CommonInterfaces
  Factory --> Gocloud
  Gocloud --> CommonInterfaces
}

package "Cloud Providers" <<providers>> {
  rectangle "AWS" as AWS
  rectangle "Google Cloud" as Google
  rectangle "DigitalOcean" as DO
  rectangle "Alibaba Cloud" as Ali
  rectangle "Azure" as Azure
  rectangle "OpenStack" as OpenStack
  rectangle "Vultr" as Vultr
  rectangle "Rackspace" as Rackspace
  Gocloud <|-- AWS
  Gocloud <|-- Google
  Gocloud <|-- DO
  Gocloud <|-- Ali
  Gocloud <|-- Azure
  Gocloud <|-- OpenStack
  Gocloud <|-- Vultr
  Gocloud <|-- Rackspace
}

package "Cloud Services" <<services>> {
  rectangle "Compute" as Compute
  rectangle "Storage" as Storage
  rectangle "Container" as Container
  rectangle "DNS" as DNS
  rectangle "Load Balancer" as LB
  rectangle "Serverless" as Serverless
  rectangle "Database" as DB
  rectangle "ML Services" as ML
  rectangle "Analytics" as Analytics
  rectangle "Notifications" as Notifications
  rectangle "Stream Processing" as Stream
  CommonInterfaces --> Compute
  CommonInterfaces --> Storage
  CommonInterfaces --> Container
  CommonInterfaces --> DNS
  CommonInterfaces --> LB
  CommonInterfaces --> Serverless
  CommonInterfaces --> DB
  CommonInterfaces --> ML
  CommonInterfaces --> Analytics
  CommonInterfaces --> Notifications
  CommonInterfaces --> Stream
}

package "Authentication" <<auth>> {
  rectangle "AWS Auth" as AWSAuth
  rectangle "Google Auth" as GoogleAuth
  rectangle "Ali Auth" as AliAuth
  rectangle "Vultr Auth" as VultrAuth
  rectangle "DO Auth" as DOAuth
  rectangle "Rackspace Auth" as RackAuth
  AWS --> AWSAuth
  Google --> GoogleAuth
  Ali --> AliAuth
  Vultr --> VultrAuth
  DO --> DOAuth
  Rackspace --> RackAuth
}

@enduml