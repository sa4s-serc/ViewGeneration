@startuml MyEMS_myems
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<services>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (AngularJS)" <<frontend>> {
  rectangle "Admin UI" as AdminUI
  rectangle "User UI" as UserUI
  rectangle "AngularJS App" as AngularApp
  rectangle "UI Components" as UIComponents
  AdminUI --> AngularApp
  UserUI --> AngularApp
  AngularApp --> UIComponents
}

package "API Layer (Falcon)" <<api>> {
  rectangle "REST API" as RESTAPI
  rectangle "Controllers" as Controllers
  rectangle "Core Entities" as CoreEntities
  rectangle "Report Modules" as Reports
  RESTAPI --> Controllers
  Controllers --> CoreEntities
  Controllers --> Reports
}

package "Services" <<services>> {
  rectangle "Data Acquisition" as DataAcquisition
  rectangle "Data Cleaning" as DataCleaning
  rectangle "Normalization" as Normalization
  rectangle "Aggregation" as Aggregation
  rectangle "FDD Service" as FDD
  DataAcquisition --> DataCleaning
  DataCleaning --> Normalization
  Normalization --> Aggregation
  Aggregation --> FDD
}

package "Databases" <<db>> {
  database "System DB" as SystemDB
  database "Energy DB" as EnergyDB
  database "Billing DB" as BillingDB
  database "Historical DB" as HistoricalDB
  database "Carbon DB" as CarbonDB
}

RESTAPI --> DataAcquisition
RESTAPI --> DataCleaning
RESTAPI --> Normalization
RESTAPI --> Aggregation
RESTAPI --> FDD

CoreEntities --> SystemDB
Reports --> EnergyDB
Reports --> BillingDB
Aggregation --> HistoricalDB
FDD --> CarbonDB

AngularApp --> RESTAPI
@enduml