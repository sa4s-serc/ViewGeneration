@startuml aliyun_packagist-mirror
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<storage>> #d8f5d3
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<config>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Logic" <<core>> {
  rectangle "main.go" as Main
  rectangle "Packagist API\nInteraction" as PackagistAPI
  rectangle "Synchronization\nControllers" as SyncControllers
  rectangle "Context" as Context
  rectangle "GitHub API\nInteraction" as GitHubAPI
  rectangle "CDN Warm-up" as CDN

  Main --> Context
  Context --> PackagistAPI
  Context --> GitHubAPI
  Context --> CDN
  PackagistAPI --> SyncControllers
  GitHubAPI --> SyncControllers
}

package "Storage" <<storage>> {
  rectangle "Alibaba Cloud OSS" as OSS
  rectangle "Redis Cache" as Redis
  SyncControllers --> OSS
  SyncControllers --> Redis
}

package "External Services" <<external>> {
  rectangle "Packagist.org" as UpstreamPackagist
  rectangle "GitHub" as GitHub
  rectangle "Alibaba CDN" as AlibabaCDN

  PackagistAPI --> UpstreamPackagist
  GitHubAPI --> GitHub
  CDN --> AlibabaCDN
}

package "Configuration" <<config>> {
  rectangle "packagist.yml" as Config
  rectangle "status.json" as Status
  Main --> Config
  SyncControllers --> Status
}

note right of SyncControllers
  Includes:
  - sync_dists.go
  - sync_packages_v2.go
  - sync_packages_p1.go
  - sync_providers.go
  - sync_composer_phar.go
end note
@enduml