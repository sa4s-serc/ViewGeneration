@startuml doitintl_banias
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<gcp>> #fddddd
  BackgroundColor<<config>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Go)" <<frontend>> {
  rectangle "HTTP API (/track)" as API
  rectangle "Event Collector" as Collector
  rectangle "Event Publisher" as Publisher
  rectangle "GoPool" as GoPool
  rectangle "Prometheus Metrics" as Metrics
  API --> Collector
  Collector --> Publisher
  Publisher --> GoPool
  API --> Metrics
}

package "Backend (Java Dataflow)" <<backend>> {
  rectangle "Dataflow Pipeline" as Pipeline
  rectangle "BigQuery Writer" as BQWriter
  rectangle "Error Handler" as ErrorHandler
  Pipeline --> BQWriter
  Pipeline --> ErrorHandler
}

package "Google Cloud Platform" <<gcp>> {
  rectangle "Pub/Sub" as PubSub
  rectangle "BigQuery" as BigQuery
  rectangle "GCS (Schemas)" as GCS
  rectangle "Stackdriver" as Stackdriver
}

package "Configuration" <<config>> {
  rectangle "Environment Vars" as EnvVars
  rectangle "Kubernetes Manifests" as K8s
  rectangle "Makefile" as Makefile
}

Publisher --> PubSub
PubSub --> Pipeline
BQWriter --> BigQuery
Pipeline --> GCS
Metrics --> Stackdriver

Collector --> EnvVars
EnvVars --> K8s
Makefile --> Pipeline
@enduml