@startuml apigee_consumer-data-standards-au
skinparam rectangle {
  BackgroundColor<<api_proxy>> #d9e7fd
  BackgroundColor<<auth>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<shared>> #fff1c9
  BackgroundColor<<mock>> #e6e6fa
  Style roundrect
}
skinparam defaultTextAlignment center

package "API Proxies" <<api_proxy>> {
  rectangle "Banking APIs\n(Products/Accounts/Transactions)" as BankingAPIs
  rectangle "Discovery API" as DiscoveryAPI
  rectangle "Consent Management" as ConsentMgmt
  rectangle "Admin APIs" as AdminAPIs
}

package "Authentication" <<auth>> {
  rectangle "OIDC Proxy" as OIDCProxy
  rectangle "Dynamic Client Registration" as ClientReg
}

package "Shared Flows" <<shared>> {
  rectangle "Request Validation" as Validation
  rectangle "JWT Verification" as JWT
  rectangle "Pagination" as Pagination
  rectangle "Traffic Control" as Traffic
}

package "Mock Services" <<mock>> {
  rectangle "Mock OIDC Provider" as MockOIDC
  rectangle "Mock Data" as MockData
}

package "External Services" <<integration>> {
  rectangle "Metrics Service\n(App Engine)" as Metrics
  rectangle "CDR Register" as CDRRegister
}

BankingAPIs --> Validation
BankingAPIs --> JWT
BankingAPIs --> Pagination
BankingAPIs --> MockData

DiscoveryAPI --> Validation
DiscoveryAPI --> JWT

ConsentMgmt --> Validation
ConsentMgmt --> JWT
ConsentMgmt --> Traffic

AdminAPIs --> Validation
AdminAPIs --> JWT

OIDCProxy --> MockOIDC
OIDCProxy --> ClientReg
ClientReg --> CDRRegister

Metrics --> BankingAPIs
Metrics --> DiscoveryAPI
Metrics --> ConsentMgmt
@enduml