@startuml sugarlabs_musicblocks-v4-lib
skinparam rectangle {
  BackgroundColor<<syntax>> #d9e7fd
  BackgroundColor<<execution>> #d8f5d3
  BackgroundColor<<library>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Syntax Representation" <<syntax>> {
  rectangle "Element API\n(IElementSpecification)" as ElementAPI
  rectangle "Specification\n(Syntax Element Table)" as Specification
  rectangle "Warehouse\n(Element Instances)" as Warehouse
  rectangle "Syntax Tree\n(AST)" as SyntaxTree
  ElementAPI --> Specification
  Specification --> Warehouse
  Warehouse --> SyntaxTree
}

package "Execution Engine" <<execution>> {
  rectangle "Symbol Table\n(Variables & State)" as SymbolTable
  rectangle "Parser" as Parser
  rectangle "Interpreter" as Interpreter
  rectangle "Scheduler" as Scheduler
  Parser --> Interpreter
  Interpreter --> SymbolTable
  Interpreter --> Scheduler
  SyntaxTree --> Parser
}

package "Library" <<library>> {
  rectangle "Values\n(Boolean, Number, String)" as Values
  rectangle "Variables\n(Boxes & Identifiers)" as Variables
  rectangle "Operators\n(Math, Logic)" as Operators
  rectangle "Control Flow\n(If, Repeat)" as ControlFlow
  rectangle "Program Structures\n(Process, Routine)" as ProgramStructures
  rectangle "Miscellaneous\n(Print)" as Miscellaneous
  Values --> Specification
  Variables --> Specification
  Operators --> Specification
  ControlFlow --> Specification
  ProgramStructures --> Specification
  Miscellaneous --> Specification
}

@enduml