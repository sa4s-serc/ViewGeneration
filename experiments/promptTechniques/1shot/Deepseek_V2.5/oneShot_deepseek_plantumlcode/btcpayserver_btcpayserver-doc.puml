@startuml btcpayserver_btcpayserver-doc
skinparam rectangle {
  BackgroundColor<<content>> #d9e7fd
  BackgroundColor<<build>> #d8f5d3
  BackgroundColor<<config>> #fddddd
  BackgroundColor<<theme>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Content" <<content>> {
  rectangle "User Guides" as UserGuides
  rectangle "Deployment Docs" as Deployment
  rectangle "API Docs" as API
  rectangle "Troubleshooting" as Troubleshooting
  rectangle "Theming Guide" as Theming
}

package "Build & Deployment" <<build>> {
  rectangle "Github Actions" as GithubActions
  rectangle "Setup Scripts" as SetupScripts
  rectangle "Redirect Generator" as Redirects
}

package "Configuration" <<config>> {
  rectangle "VuePress Config" as VuePressConfig
  rectangle "Editor Config" as EditorConfig
}

package "Theme" <<theme>> {
  rectangle "Custom Components" as Components
  rectangle "Global Styles" as Styles
  rectangle "Theme Logic" as ThemeLogic
}

UserGuides --> VuePressConfig
Deployment --> SetupScripts
API --> VuePressConfig
Troubleshooting --> VuePressConfig
Theming --> Styles

GithubActions --> VuePressConfig
SetupScripts --> EditorConfig
Redirects --> VuePressConfig

Components --> ThemeLogic
Styles --> ThemeLogic
ThemeLogic --> VuePressConfig
@enduml