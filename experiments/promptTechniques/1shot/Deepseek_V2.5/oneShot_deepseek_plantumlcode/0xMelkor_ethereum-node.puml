@startuml 0xMelkor_ethereum-node
skinparam rectangle {
  BackgroundColor<<geth>> #d9e7fd
  BackgroundColor<<lighthouse>> #d8f5d3
  BackgroundColor<<monitoring>> #fddddd
  BackgroundColor<<proxy>> #fff1c9
  BackgroundColor<<k8s>> #e6d9ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "Kubernetes Cluster" <<k8s>> {
  package "Execution Layer" <<geth>> {
    rectangle "Geth Node" as Geth
    rectangle "Geth RPC" as GethRPC
    rectangle "Geth WebSocket" as GethWS
    Geth --> GethRPC
    Geth --> GethWS
  }

  package "Consensus Layer" <<lighthouse>> {
    rectangle "Lighthouse Client" as Lighthouse
  }

  package "Monitoring" <<monitoring>> {
    rectangle "InfluxDB" as InfluxDB
    rectangle "Metrics Collector" as Metrics
    Metrics --> InfluxDB
    Geth --> Metrics
    Lighthouse --> Metrics
  }

  package "Proxy Layer" <<proxy>> {
    rectangle "Nginx" as Nginx
    Nginx --> GethRPC
    Nginx --> GethWS
    Nginx --> InfluxDB
  }
}

rectangle "External Clients" as Clients
Clients --> Nginx

rectangle "Google Cloud Build" as CloudBuild
CloudBuild --> "Kubernetes Cluster"

rectangle "Secret Manager" as Secrets
Secrets --> CloudBuild
Secrets --> Geth
Secrets --> Lighthouse
Secrets --> Nginx
@enduml