@startuml shawntabrizi_Ethereum-Twitter-Bounty
skinparam rectangle {
  BackgroundColor<<contract>> #d9e7fd
  BackgroundColor<<frontend>> #d8f5d3
  BackgroundColor<<framework>> #fddddd
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Smart Contracts" <<contract>> {
  rectangle "TwitterBounty.sol" as Bounty {
    - createBounty()
    - contribute()
    - fulfillBounty()
    - oraclizeTweet()
  }
  rectangle "TwitterOracle.sol" as Oracle {
    - oraclizeTweet()
    - __callback()
  }
  Bounty --> Oracle : uses
}

package "Frontend" <<frontend>> {
  rectangle "HTML/CSS (Bootstrap)" as HTML
  rectangle "JavaScript/jQuery" as JS
  rectangle "Web3.js" as Web3
  rectangle "TruffleContract" as TruffleContract
  HTML --> JS
  JS --> Web3
  JS --> TruffleContract
  TruffleContract --> Bounty
  TruffleContract --> Oracle
}

package "Development Framework" <<framework>> {
  rectangle "Truffle" as Truffle {
    - Testing
    - Deployment
    - Migrations
  }
  rectangle "Ganache" as Ganache
  Truffle --> Bounty
  Truffle --> Oracle
  Truffle --> Ganache
}

package "External Services" <<external>> {
  rectangle "Ethereum Blockchain" as Ethereum
  rectangle "Provable Oracle" as Provable
  rectangle "Twitter API" as Twitter
  Bounty --> Ethereum
  Oracle --> Provable
  Provable --> Twitter
}

note right of Bounty
  OpenZeppelin:
  - Ownable
  - Pausable
  - Destructible
  - Pull Payments
end note
@enduml