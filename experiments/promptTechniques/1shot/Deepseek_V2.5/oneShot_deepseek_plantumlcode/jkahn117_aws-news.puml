@startuml jkahn117_aws-news
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Next.js Frontend" as Frontend #lightblue

rectangle "AWS Infrastructure" as AWS {
  rectangle "CloudFront CDN" as CloudFront #aliceblue
  rectangle "AppSync GraphQL API" as AppSync #palegreen
  rectangle "Lambda Functions" as Lambda #lightyellow {
    rectangle "RSS Parser" as RSSParser
    rectangle "Image Processor" as ImageProcessor
    rectangle "API Handlers" as APIHandlers
  }
  rectangle "DynamoDB" as DynamoDB #mistyrose
  rectangle "S3 Storage" as S3 #lightsteelblue
  rectangle "ElastiCache Redis" as Redis #peachpuff
  rectangle "EventBridge" as EventBridge #lavender
  rectangle "Pinpoint Analytics" as Pinpoint #wheat
  rectangle "Kinesis Firehose" as Firehose #thistle
}

' ========== Connections ==========
User --> Frontend : Interacts with
Frontend --> CloudFront : Requests content
CloudFront --> AppSync : API calls
AppSync --> APIHandlers : Resolves queries
APIHandlers --> DynamoDB : Reads metadata
APIHandlers --> Redis : Checks cache
APIHandlers --> S3 : Gets content

RSSParser --> DynamoDB : Stores metadata
RSSParser --> S3 : Stores content
RSSParser --> EventBridge : article_created
EventBridge --> ImageProcessor : Triggers
ImageProcessor --> S3 : Stores processed images
ImageProcessor --> DynamoDB : Updates metadata

Frontend --> Pinpoint : Sends analytics
Pinpoint --> Firehose : Streams data
Firehose --> S3 : Stores analytics
@enduml