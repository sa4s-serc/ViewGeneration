@startuml emreturgutce_stock-management
skinparam rectangle {
  BackgroundColor<<api>> #d9e7fd
  BackgroundColor<<middleware>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<utility>> #fff1c9
  BackgroundColor<<config>> #e7d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "API Controllers" <<api>> {
  rectangle "Personnel\nManagement" as Personnel
  rectangle "Data\nManagement" as Data
  rectangle "Awaiting\nList" as Awaiting
}

package "Middleware" <<middleware>> {
  rectangle "Authentication" as Auth
  rectangle "Authorization" as Authorize
  rectangle "Validation" as Validate
  rectangle "Rate Limiting" as RateLimit
  rectangle "Error Handling" as ErrorHandler
}

package "Data Layer" <<data>> {
  rectangle "PostgreSQL" as Postgres
  rectangle "Redis" as Redis
  rectangle "AWS S3" as S3
}

package "Utilities" <<utility>> {
  rectangle "Email" as Email
  rectangle "PDF Generation" as PDF
  rectangle "Image Upload" as Image
}

package "Configuration" <<config>> {
  rectangle "Environment\nVariables" as Env
  rectangle "Constants" as Constants
}

Personnel --> Auth
Data --> Validate
Awaiting --> Authorize
Auth --> Redis
Validate --> Postgres
Authorize --> Postgres
Email --> Postgres
PDF --> Postgres
Image --> S3
Env --> Auth
Env --> Postgres
Env --> Redis
Env --> S3
Constants --> RateLimit
Constants --> Authorize
ErrorHandler --> Personnel
ErrorHandler --> Data
ErrorHandler --> Awaiting
@enduml