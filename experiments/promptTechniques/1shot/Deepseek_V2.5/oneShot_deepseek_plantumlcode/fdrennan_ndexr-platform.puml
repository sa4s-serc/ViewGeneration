@startuml fdrennan_ndexr-platform
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<orchestration>> #e6d5ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Shiny)" <<frontend>> {
  rectangle "Shiny UI" as ShinyUI
  rectangle "Shiny Server" as ShinyServer
  ShinyUI --> ShinyServer
}

package "API Layer" <<backend>> {
  rectangle "Plumber API" as PlumberAPI
  rectangle "R/Python Services" as RPyServices
  PlumberAPI --> RPyServices
}

package "Data Processing" <<backend>> {
  rectangle "Reddit Data Ingestion\n(PRAW)" as RedditIngest
  rectangle "Data Processing\n(R/Python)" as DataProcessing
  rectangle "AWS Services\n(S3, EC2, SNS)" as AWSServices
  RedditIngest --> DataProcessing
  DataProcessing --> AWSServices
}

package "Orchestration" <<orchestration>> {
  rectangle "Airflow DAGs" as Airflow
  rectangle "Docker Containers" as Docker
  Airflow --> Docker
}

package "Database" <<db>> {
  rectangle "PostgreSQL" as Postgres
  rectangle "Elasticsearch" as Elastic
}

package "Infrastructure" <<integration>> {
  rectangle "NGINX\n(Reverse Proxy)" as Nginx
  rectangle "AWS EC2" as EC2
  rectangle "System Monitoring\n(Glances)" as Monitoring
}

ShinyServer --> PlumberAPI
PlumberAPI --> DataProcessing
DataProcessing --> Postgres
DataProcessing --> Elastic
Airflow --> RedditIngest
Airflow --> DataProcessing
Nginx --> PlumberAPI
AWSServices --> EC2
AWSServices --> Monitoring
@enduml