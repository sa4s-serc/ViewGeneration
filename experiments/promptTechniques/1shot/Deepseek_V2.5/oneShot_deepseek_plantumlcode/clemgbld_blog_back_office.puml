@startuml clemgbld_blog_back_office
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<core>> #d8f5d3
  BackgroundColor<<infra>> #fddddd
  BackgroundColor<<ui>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "App.tsx\n(Router)" as App
  rectangle "Index.tsx\n(Entry)" as Index
  rectangle "Redux Store" as Store
  Index --> App
  Index --> Store
}

package "Core" <<core>> {
  rectangle "Articles\n(Use Cases/Entities)" as Articles
  rectangle "Auth\n(Use Cases/Entities)" as Auth
  rectangle "Emails\n(Use Cases/Entities)" as Emails
  rectangle "Ports" as Ports
  Articles --> Ports
  Auth --> Ports
  Emails --> Ports
}

package "Infrastructure" <<infra>> {
  rectangle "API Services" as APIServices
  rectangle "LocalStorage" as LocalStorage
  rectangle "InMemory\n(Testing)" as InMemory
  APIServices --> Ports
  LocalStorage --> Ports
  InMemory --> Ports
}

package "UI Components" <<ui>> {
  rectangle "RichTextEditor\n(Plate)" as Editor
  rectangle "Header/Modal/Buttons" as Components
  rectangle "WithNotificationError\n(HOC)" as HOC
  App --> Editor
  App --> Components
  App --> HOC
}

Store --> Articles
Store --> Auth
Store --> Emails
@enduml