@startuml matryx_MatryxPlatform
skinparam rectangle {
  BackgroundColor<<contract>> #d9e7fd
  BackgroundColor<<library>> #d8f5d3
  BackgroundColor<<js>> #fddddd
  BackgroundColor<<token>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Contracts" <<contract>> {
  rectangle "MatryxPlatform" as Platform
  rectangle "MatryxSystem" as System
  rectangle "MatryxForwarder" as Forwarder
  rectangle "MatryxToken (MTX)" as Token <<token>>
  Platform --> System
  Platform --> Forwarder
  Platform --> Token
}

package "Libraries" <<library>> {
  rectangle "LibPlatform" as LibPlatform
  rectangle "LibCommit" as LibCommit
  rectangle "LibTournament" as LibTournament
  Platform --> LibPlatform
  Platform --> LibCommit
  Platform --> LibTournament
}

package "JavaScript Layer" <<js>> {
  rectangle "utils.js" as Utils
  rectangle "test.js" as Test
  rectangle "benchmark.js" as Benchmark
  rectangle "network.js" as Network
  Utils --> Platform
  Test --> Platform
  Benchmark --> Platform
  Network --> Platform
}

package "Documentation" <<js>> {
  rectangle "index.rst" as Docs
  rectangle "searchtools.js" as Search
  Docs --> Search
}

note right of Platform: Uses delegatecall pattern\nfor upgradability
note right of Token: ERC20 token for rewards\nand transactions
@enduml