@startuml laziestcoder_Budget_App_JS
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "UI (HTML/CSS)" as UI {
}

rectangle "JavaScript" as JS {
  rectangle "controller" as Controller
  rectangle "UIController" as UIController
  rectangle "budgetController" as BudgetController
}

' ========== Connections ==========
User -> UI : Inputs income/expense\nClicks buttons

UI -> Controller : Triggers event listeners

Controller -> BudgetController : addItem()\ncalculateBudget()\ncalculatePercentages()\ngetBudget()
Controller -> UIController : getInput()\naddListItem()\nclearFields()\ndisplayBudget()\ndisplayPercentages()

BudgetController --> Controller : Returns calculated data
UIController --> Controller : Returns UI updates

UIController -> UI : Updates DOM elements
@enduml