@startuml LouisvilleMetro_WazeCCPProcessor
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Waze CCP" as Waze

rectangle "AWS Cloud" as AWS {
  rectangle "S3 Bucket" as S3 #aliceblue
  rectangle "Lambda" as Lambda {
    rectangle "waze-data-download" as Download #lightsteelblue
    rectangle "waze-data-process" as Process #lightsteelblue
    rectangle "waze-data-alerts-processing" as Alerts #lightsteelblue
    rectangle "waze-data-jams-processing" as Jams #lightsteelblue
    rectangle "waze-data-irregularities-processing" as Irregularities #lightsteelblue
  }
  rectangle "SQS Queue" as SQS #mistyrose
  rectangle "SNS Topic" as SNS #lightyellow
  rectangle "API Gateway" as APIGW #palegreen
  rectangle "Aurora PostgreSQL" as DB #palegreen
}

' ========== Connections ==========
Waze --> Download : Fetch data feed
Download --> S3 : Store raw JSON
S3 --> Process : Trigger on new file
Process --> SQS : Enqueue processing tasks
SQS --> Alerts : Process alerts
SQS --> Jams : Process jams
SQS --> Irregularities : Process irregularities
Alerts --> DB : Store processed data
Jams --> DB : Store processed data
Irregularities --> DB : Store processed data
Process --> SNS : Notify processing status
APIGW --> Lambda : Invoke\nwaze-data-api
Lambda --> DB : Query data
APIGW --> Client : Provide API responses
@enduml