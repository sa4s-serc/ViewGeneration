@startuml davidlandry93_glo4001
skinparam rectangle {
  BackgroundColor<<rendering>> #d9e7fd
  BackgroundColor<<robotic>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<utils>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "3D Rendering & Visualization" <<rendering>> {
  rectangle "Three.js" as ThreeJS
  rectangle "Potree" as Potree
  rectangle "LAS/LAZ Decoders" as Decoders
  rectangle "Shader System" as Shaders
  ThreeJS --> Potree
  Potree --> Decoders
  ThreeJS --> Shaders
}

package "Robotic Control & Sensing" <<robotic>> {
  rectangle "Robot Control" as Robot
  rectangle "Sensor Classes" as Sensors
  rectangle "ICP Algorithm" as ICP
  rectangle "ROS Integration" as ROS
  Robot --> Sensors
  Sensors --> ROS
  Sensors --> ICP
}

package "Geometric Data Handling" <<data>> {
  rectangle "CZML Processing" as CZML
  rectangle "BillboardGraphics" as Billboard
  rectangle "ModelGraphics" as Model
  rectangle "MaterialProperty" as Material
  CZML --> Billboard
  CZML --> Model
  Model --> Material
}

package "Utilities" <<utils>> {
  rectangle "jQuery UI" as JQuery
  rectangle "React" as React
  rectangle "bluebird.js" as Bluebird
  rectangle "lodash.min.js" as Lodash
}

ThreeJS --> JQuery
ThreeJS --> React
ThreeJS --> Bluebird
ThreeJS --> Lodash
Potree --> CZML
ROS --> ThreeJS
@enduml