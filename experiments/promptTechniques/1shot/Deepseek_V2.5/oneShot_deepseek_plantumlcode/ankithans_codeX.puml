@startuml ankithans_codeX
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<service>> #fddddd
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (ReactJS)" <<frontend>> {
  rectangle "App.js" as App
  rectangle "Navbar.js" as Navbar
  rectangle "PseudoCode.js" as PseudoCode
  rectangle "Warnings.js" as Warnings
  rectangle "Compile.js" as Compile
  App --> Navbar
  App --> PseudoCode
  App --> Warnings
  App --> Compile
}

package "Backend (FastAPI)" <<backend>> {
  rectangle "app.py (API Gateway)" as API
  rectangle "compile.py" as CompileRoute
  rectangle "convertPseudo.py" as PseudoRoute
  rectangle "warnings.py" as WarningsRoute
  rectangle "translatePseudo.py" as TranslateRoute
  rectangle "shareCode.py" as ShareRoute
  rectangle "flowchart.py" as FlowchartRoute
  API --> CompileRoute
  API --> PseudoRoute
  API --> WarningsRoute
  API --> TranslateRoute
  API --> ShareRoute
  API --> FlowchartRoute
}

package "Services" <<service>> {
  rectangle "pylint.py" as Pylint
  rectangle "pseudo_code.py" as PseudoService
  rectangle "hackerearth_compile.py" as HackerEarth
  rectangle "translate.py" as TranslateService
  rectangle "flowchart.py" as FlowchartService
  CompileRoute --> HackerEarth
  PseudoRoute --> PseudoService
  WarningsRoute --> Pylint
  TranslateRoute --> TranslateService
  FlowchartRoute --> FlowchartService
}

database "SQLite" <<external>> as DB
ShareRoute --> DB

cloud "External Services" <<external>> as Ext {
  rectangle "HackerEarth API" as HE
  rectangle "Google Translate" as GT
  HackerEarth --> HE
  TranslateService --> GT
}

App --> API
@enduml