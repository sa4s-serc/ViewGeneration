@startuml ShiftLeftSecurity_traceleft
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "CLI Application" as CLI {
}

rectangle "Text Processing" as TextProc #palegreen {
  rectangle "Unicode\nNormalization" as Norm
  rectangle "Collation" as Collate
  rectangle "IDNA" as IDNA
}

rectangle "System Interaction" as Sys #lightsteelblue {
  rectangle "Unix/Win\nSystem Calls" as SysCalls
  rectangle "eBPF" as eBPF
}

rectangle "External Services" as Ext #lightyellow {
  rectangle "CLDR Data" as CLDR
  rectangle "File System" as FS
  rectangle "Network" as Net
}

' ========== Connections ==========
User -> CLI : Commands/Input

' CLI to Text Processing
CLI -> Norm : Normalize text
CLI -> Collate : Sort strings
CLI -> IDNA : Process domain names

' CLI to System Interaction
CLI -> SysCalls : OS operations
CLI -> eBPF : BPF programs

' Text Processing external
Norm --> CLDR : Unicode data
Collate --> CLDR : Locale data
IDNA --> Net : Domain resolution

' System Interaction external
SysCalls --> FS : File operations
SysCalls --> Net : Network ops
eBPF --> Net : Packet filtering

' External services
FS --> CLI : File events
Net --> CLI : Network data
@enduml