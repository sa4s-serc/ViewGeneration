@startuml marklogic_cloud-enablement-aws
skinparam rectangle {
  BackgroundColor<<cf>> #d9e7fd
  BackgroundColor<<lambda>> #d8f5d3
  BackgroundColor<<aws>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "CloudFormation Templates" <<cf>> {
  rectangle "mlcluster.template" as MLCluster
  rectangle "mlcluster-vpc.template" as MLVPC
  rectangle "ml-managedeni.template" as ENITemplate
  rectangle "ml-nodemanager.template" as NodeManagerTemplate
}

package "Lambda Functions" <<lambda>> {
  rectangle "managedeni.py" as ENIHandler
  rectangle "nodemanager.py" as NodeManager
  rectangle "utils.py" as Utils
  ENIHandler --> Utils
  NodeManager --> Utils
}

package "AWS Resources" <<aws>> {
  rectangle "EC2 Instances" as EC2
  rectangle "EBS Volumes" as EBS
  rectangle "VPC/Subnets" as VPC
  rectangle "ALB" as ALB
  rectangle "Auto Scaling" as ASG
  rectangle "DynamoDB" as DDB
  rectangle "SNS" as SNS
}

MLCluster --> EC2
MLCluster --> EBS
MLCluster --> VPC
MLCluster --> ALB
MLCluster --> ASG
MLCluster --> DDB
MLCluster --> SNS
MLVPC --> VPC

ENITemplate --> ENIHandler
NodeManagerTemplate --> NodeManager

ASG -> NodeManager: Lifecycle Events
NodeManager --> EC2: Attach ENI
ENIHandler --> EC2: Manage ENIs
DDB --> NodeManager: Cluster State
DDB --> ENIHandler: ENI Allocation
@enduml