@startuml NLP4L_attic-nlp4l
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<analysis>> #d8f5d3
  BackgroundColor<<nlp>> #fddddd
  BackgroundColor<<utils>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Indexing & Search" <<core>> {
  rectangle "IWriter/IReader" as IO
  rectangle "ISearcher" as Searcher
  rectangle "Schema/Field" as Schema
  rectangle "Document" as Doc
  IO --> Schema
  Schema --> Doc
  Searcher --> Doc
}

package "Text Analysis" <<analysis>> {
  rectangle "Analyzer/AnalyzerBuilder" as Analyzer
  rectangle "Token/TermDocs" as Tokens
  rectangle "Japanese Analysis" as JA
  Analyzer --> Tokens
  Tokens --> JA
}

package "NLP Algorithms" <<nlp>> {
  rectangle "HMM Model/Tagger" as HMM
  rectangle "Collocational Analysis" as Colloc
  rectangle "SimpleFST" as FST
  HMM --> FST
  Colloc --> FST
}

package "Utilities" <<utils>> {
  rectangle "Corpora" as Corpus
  rectangle "REPL Shell" as REPL
  rectangle "Feature Selection" as Features
  rectangle "Synonym Mgmt" as Synonyms
  REPL --> Corpus
  REPL --> Features
  REPL --> Synonyms
}

IO --> Analyzer
Schema --> Analyzer
Searcher --> HMM
Analyzer --> HMM
Analyzer --> Colloc
@enduml