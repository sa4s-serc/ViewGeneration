@startuml Spiderpig86_SmoresUnderflow
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as Frontend {
}

rectangle "Load Balancer" as Nginx #lightblue

rectangle "Microservices" as Microservices {
  rectangle "su-users" as Users #palegreen
  rectangle "su-questions" as Questions #lightyellow
  rectangle "su-answers" as Answers #mistyrose
  rectangle "su-search" as Search #aliceblue
  rectangle "su-media" as Media #lightsteelblue
}

rectangle "Message Queue" as RabbitMQ #wheat {
  rectangle "qu-questions" as QQuestions
  rectangle "qu-answers" as QAnswers
  rectangle "qu-delete-questions" as QDelete
}

rectangle "Database" as MongoDB #lavender

rectangle "Cache" as Redis #peachpuff

rectangle "Search Index" as ElasticSearch #lightgrey

' ========== Connections ==========
User --> Frontend
Frontend --> Nginx : HTTP requests
Nginx --> Users : Auth requests
Nginx --> Questions : Question ops
Nginx --> Answers : Answer ops
Nginx --> Search : Search queries
Nginx --> Media : Media uploads

Questions --> RabbitMQ : async ops
Answers --> RabbitMQ : async ops
QQuestions --> MongoDB : insert questions
QAnswers --> MongoDB : insert answers
QDelete --> MongoDB : delete questions

Questions --> Redis : cache
Answers --> Redis : cache
Users --> Redis : cache

Search --> ElasticSearch : index/search
Questions --> ElasticSearch : index
Answers --> ElasticSearch : index
@enduml