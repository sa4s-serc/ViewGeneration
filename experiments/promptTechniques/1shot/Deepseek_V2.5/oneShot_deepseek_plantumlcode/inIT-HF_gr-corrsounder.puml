@startuml IT-HF_gr-corrsounder
skinparam rectangle {
  BackgroundColor<<cpp>> #d9e7fd
  BackgroundColor<<python>> #d8f5d3
  BackgroundColor<<gnuradio>> #fddddd
  BackgroundColor<<utils>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "C++ Core" <<cpp>> {
  rectangle "Sequence Generation\n(FZC/MLS)" as SeqGen
  rectangle "Correlation Blocks" as Correlator
  rectangle "Error Correction" as ErrorCorr
  rectangle "Moving Average" as MovAvg
  rectangle "Sequence Gate" as SeqGate
  rectangle "RAM Disk Sink" as RamDisk
  rectangle "IR SNR Detection" as IRSNR
  SeqGen --> Correlator
  Correlator --> ErrorCorr
  ErrorCorr --> MovAvg
  MovAvg --> SeqGate
  SeqGate --> RamDisk
  Correlator --> IRSNR
}

package "Python Integration" <<python>> {
  rectangle "SWIG Bindings" as SWIG
  rectangle "pycorrsounder\n(Standalone)" as PyCorr
  rectangle "GNU Radio\nCompanion (GRC)" as GRC
  rectangle "Unit Tests" as Tests
  SWIG --> PyCorr
  PyCorr --> GRC
  PyCorr --> Tests
}

package "GNU Radio Framework" <<gnuradio>> {
  rectangle "Tagged Stream\nMechanism" as TaggedStream
  rectangle "Flowgraph\nExecution" as Flowgraph
  rectangle "Python\nBindings" as PyBind
  TaggedStream --> Flowgraph
  Flowgraph --> PyBind
}

package "Utilities" <<utils>> {
  rectangle "Doxygen XML\nParser" as DoxyParser
  rectangle "CMake\nBuild System" as CMake
  rectangle "Example\nFlowgraphs" as Examples
  rectangle "Documentation" as Docs
}

Correlator --> SWIG
SWIG --> PyBind
PyCorr --> TaggedStream
GRC --> Flowgraph
Tests --> SeqGen
Tests --> Correlator
DoxyParser --> Docs
CMake --> SeqGen
CMake --> Correlator
Examples --> Flowgraph
@enduml