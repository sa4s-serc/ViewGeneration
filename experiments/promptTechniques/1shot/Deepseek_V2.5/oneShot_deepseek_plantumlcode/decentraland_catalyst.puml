@startuml decentraland_catalyst
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<storage>> #e8d1ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "API Layer" <<backend>> {
  rectangle "Server.ts\n(Express.js)" as Server
  rectangle "Routes" as Routes
  rectangle "Handlers" as Handlers
  Server --> Routes
  Routes --> Handlers
}

package "Core Services" <<backend>> {
  rectangle "Deployment Service" as Deployment
  rectangle "Entity Management" as EntityMgmt
  rectangle "Synchronization" as Sync
  rectangle "Validation" as Validation
  rectangle "Collections API" as Collections
  Handlers --> Deployment
  Handlers --> EntityMgmt
  Handlers --> Sync
  Handlers --> Validation
  Handlers --> Collections
}

package "External Integrations" <<integration>> {
  rectangle "The Graph" as TheGraph
  rectangle "Third-Party Resolvers" as ThirdParty
  rectangle "Blockchain" as Blockchain
  EntityMgmt --> TheGraph
  Collections --> TheGraph
  EntityMgmt --> ThirdParty
  Collections --> ThirdParty
  Validation --> Blockchain
}

package "Data Access" <<db>> {
  rectangle "PostgreSQL" as DB
  rectangle "Database Queries" as Queries
  rectangle "Migrations" as Migrations
  Deployment --> DB
  EntityMgmt --> DB
  Sync --> DB
  Collections --> DB
  DB --> Queries
  DB --> Migrations
}

package "Storage" <<storage>> {
  rectangle "Content Storage" as ContentStorage
  rectangle "IPFS" as IPFS
  Deployment --> ContentStorage
  EntityMgmt --> ContentStorage
  ContentStorage --> IPFS
}

package "Utilities" <<backend>> {
  rectangle "Caching (LRU)" as Cache
  rectangle "Rate Limiting" as RateLimit
  rectangle "Metrics" as Metrics
  rectangle "Snapshots" as Snapshots
  EntityMgmt --> Cache
  Deployment --> RateLimit
  Server --> Metrics
  Sync --> Snapshots
}
@enduml