@startuml kryptokrauts_ae-prediction-cards
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
  rectangle "WalletClient" as Wallet
  rectangle "PredictionCardsAPI" as API
}

rectangle "Aeternity Blockchain" as Blockchain #mistyrose {
  rectangle "PredictionCards\nSmart Contract" as Contract #palegreen
}

rectangle "process-prediction-\nservice" as PredictionService #lightsteelblue

rectangle "oracle-service" as OracleService #lightyellow

rectangle "CoinGecko API" as CoinGecko #aliceblue

' ========== Connections ==========
User -> FE : Interacts with UI
FE -> Wallet : Connect wallet\nSign transactions
Wallet -> Blockchain : Deploy contract\nCall methods
API -> Contract : Dry-run calls\nSubmit transactions

PredictionService -> Blockchain : Poll for CLOSED predictions
PredictionService -> Contract : Call ask_for_winning_option
Contract -> OracleService : Oracle query
OracleService -> CoinGecko : Fetch price data
OracleService -> Contract : Submit oracle response
Contract -> PredictionService : Trigger process_oracle_response
Contract -> FE : Update prediction state (events)
@enduml