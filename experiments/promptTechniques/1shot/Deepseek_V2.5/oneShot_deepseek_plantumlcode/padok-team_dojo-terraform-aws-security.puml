@startuml padok-team_dojo-terraform-aws-security
skinparam rectangle {
  BackgroundColor<<terraform>> #d9e7fd
  BackgroundColor<<aws>> #d8f5d3
  BackgroundColor<<dev>> #fddddd
  BackgroundColor<<security>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Terraform Configuration" <<terraform>> {
  rectangle "main.tf" as Main
  rectangle "variables.tf" as Variables
  rectangle "output.tf" as Outputs
  rectangle "network.tf" as Network
  rectangle "_providers.tf" as Providers
  rectangle "_backend.tf" as Backend
  rectangle "web/install_apache.sh.tpl" as UserData

  Main --> Variables
  Main --> Network
  Main --> Providers
  Main --> UserData
  Network --> Outputs
  Providers --> Backend
}

package "Bootstrap Module" <<terraform>> {
  rectangle "bootstrap/main.tf" as BootstrapMain
  rectangle "bootstrap/output.tf" as BootstrapOutputs
  rectangle "bootstrap/env.tfvars.tpl" as EnvTemplate

  BootstrapMain --> BootstrapOutputs
  BootstrapOutputs --> EnvTemplate
}

package "Environment Configs" <<dev>> {
  rectangle "dev.tfvars" as DevConfig
  rectangle "prd.tfvars" as PrdConfig
  EnvTemplate --> DevConfig
  EnvTemplate --> PrdConfig
}

package "AWS Resources" <<aws>> {
  rectangle "VPC" as VPC
  rectangle "Subnets" as Subnets
  rectangle "EC2 Instances" as EC2
  rectangle "Load Balancer" as ALB
  rectangle "Security Groups" as SGs

  VPC --> Subnets
  Subnets --> EC2
  Subnets --> ALB
  SGs --> EC2
  SGs --> ALB
}

package "Security Components" <<security>> {
  rectangle "IP Whitelisting" as Whitelist
  rectangle "Environment Isolation" as Isolation
  rectangle "Network Filtering" as Filtering

  Whitelist --> SGs
  Isolation --> VPC
  Filtering --> SGs
}

Main --> VPC
Variables --> DevConfig
Variables --> PrdConfig
UserData --> EC2
@enduml