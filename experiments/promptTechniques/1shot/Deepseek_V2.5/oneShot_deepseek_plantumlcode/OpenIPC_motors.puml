@startuml OpenIPC_motors
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Camera Application" as App

rectangle "Motors Daemon" as Daemon #lightblue {
}

rectangle "Driver Wrappers" as Wrappers #palegreen {
  rectangle "GPIO Driver" as GPIO
  rectangle "I2C Driver" as I2C
  rectangle "SPI Driver" as SPI
  rectangle "UART Driver" as UART
}

rectangle "Kernel Modules" as Kernel #mistyrose {
  rectangle "/dev/motor" as DevMotor
  rectangle "i2c-dev" as I2CDev
  rectangle "SPI Interface" as SPIInterface
  rectangle "UART Interface" as UARTInterface
}

rectangle "Hardware" as HW #aliceblue {
  rectangle "Motor Controller" as Controller
  rectangle "Motors" as Motors
}

' ========== Connections ==========
App -> Daemon : PTZ/Focus Commands\nvia Unix Socket
Daemon -> Wrappers : Standardized API Calls

Wrappers -> Kernel : Hardware-specific\nControl Calls
GPIO --> DevMotor
I2C --> I2CDev
SPI --> SPIInterface
UART --> UARTInterface

Kernel -> HW : Electrical Signals
DevMotor --> Controller
I2CDev --> Controller
SPIInterface --> Controller
UARTInterface --> Controller
Controller -> Motors : Drive Signals

Daemon <-- Wrappers : Status Updates
Daemon --> App : Status/Feedback
@enduml