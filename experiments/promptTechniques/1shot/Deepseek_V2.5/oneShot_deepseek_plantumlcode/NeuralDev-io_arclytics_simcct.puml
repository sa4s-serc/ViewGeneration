@startuml NeuralDev-io_arclytics_simcct
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<database>> #fff1c9
  BackgroundColor<<infra>> #fddddd
  BackgroundColor<<monitoring>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "React Components" as React
  rectangle "Redux Store" as Redux
  rectangle "React Router" as Router
  rectangle "Plotly Charts" as Charts
  React --> Redux
  React --> Router
  React --> Charts
}

package "Backend (Flask)" <<backend>> {
  rectangle "REST API" as API
  rectangle "Auth Service" as Auth
  rectangle "Simulation Logic" as Simulation
  rectangle "Celery Tasks" as Celery
  rectangle "Email Service" as Email
  API --> Auth
  API --> Simulation
  API --> Email
  API --> Celery
}

package "Data Stores" <<database>> {
  database "MongoDB" as MongoDB
  database "Redis" as Redis
  Auth --> MongoDB
  Simulation --> MongoDB
  Celery --> Redis
  Auth --> Redis
}

package "Infrastructure" <<infra>> {
  rectangle "Docker" as Docker
  rectangle "Kubernetes" as K8s
  rectangle "Skaffold" as Skaffold
  Docker --> K8s
  Skaffold --> K8s
}

package "Monitoring" <<monitoring>> {
  rectangle "Fluentd" as Fluentd
  rectangle "Elasticsearch" as ES
  rectangle "Kibana" as Kibana
  rectangle "Elastic APM" as APM
  Fluentd --> ES
  ES --> Kibana
  API --> APM
  React --> APM
}

React --> API
@enduml