@startuml Fintan-contents_case-studies
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Developer" as Dev

rectangle "Frontend" as FE {
  rectangle "React/Redux" as React
  rectangle "React Native" as RN
  rectangle "Electron" as Electron
}

rectangle "Backend" as BE {
  rectangle "Spring Boot" as Spring
  rectangle "gRPC Server" as gRPC
  rectangle "Message Queue" as MQ
}

rectangle "CI/CD Pipeline" as CICD {
  rectangle "Azure DevOps" as Azure
  rectangle "CircleCI" as Circle
  rectangle "AWS Code*" as AWS
}

rectangle "Monitoring" as Monitor {
  rectangle "New Relic" as NR
  rectangle "Elastic Stack" as ELK
}

rectangle "Testing" as Test {
  rectangle "Unit Tests" as Unit
  rectangle "Integration Tests" as Integration
  rectangle "Performance Tests" as Perf
}

' ========== Connections ==========
Dev --> FE : Develops
Dev --> BE : Develops

FE --> BE : API Calls\n(HTTP/gRPC)
React --> RN : Shares components
React --> Electron : Shares components

BE --> MQ : Async processing
BE --> gRPC : Push notifications

FE --> CICD : Triggers build
BE --> CICD : Triggers build
CICD --> Azure : Pipeline execution
CICD --> Circle : Pipeline execution
CICD --> AWS : Pipeline execution

BE --> Monitor : Sends metrics/logs
FE --> Monitor : Sends metrics/logs
Monitor --> NR : APM data
Monitor --> ELK : Log aggregation

CICD --> Test : Runs tests
Test --> Unit : Verifies logic
Test --> Integration : Verifies services
Test --> Perf : Verifies scalability
@enduml