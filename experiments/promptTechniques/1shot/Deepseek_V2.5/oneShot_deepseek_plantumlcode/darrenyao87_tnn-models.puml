@startuml darrenyao87_tnn-models
skinparam rectangle {
  BackgroundColor<<framework>> #d9e7fd
  BackgroundColor<<model>> #d8f5d3
  BackgroundColor<<processing>> #fddddd
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "TNN Framework" <<framework>> {
  rectangle "Model Manager" as ModelManager
  rectangle "Tensor Handling" as TensorHandling
  rectangle "Native Memory" as NativeMemory
  rectangle "Graph Operators" as GraphOps
  ModelManager --> TensorHandling
  TensorHandling --> NativeMemory
  ModelManager --> GraphOps
}

package "Model Definitions" <<model>> {
  rectangle "TNN Proto Files" as TNNProto
  rectangle "TNN Model Files" as TNNModel
  rectangle "RapidProto Files" as RapidProto
  rectangle "RapidModel Files" as RapidModel
  rectangle "ONNX Files" as ONNX
  TNNProto --> TNNModel
  RapidProto --> RapidModel
  ONNX --> TNNProto
}

package "AI Pre-Processing" <<processing>> {
  rectangle "AIPP Config" as AIPP
  rectangle "Image Processing" as ImageProc
  rectangle "Tensor Dimension" as TensorDim
  AIPP --> ImageProc
  ImageProc --> TensorDim
}

package "Supporting Data" <<data>> {
  rectangle "Vocab Files" as Vocab
  rectangle "Key Files" as Keys
  rectangle "Anchor Files" as Anchors
  rectangle "Mean Files" as Mean
}

ModelManager --> TNNProto
ModelManager --> RapidProto
TensorHandling --> TensorDim
GraphOps --> AIPP
GraphOps --> Vocab
GraphOps --> Keys
GraphOps --> Anchors
GraphOps --> Mean
@enduml