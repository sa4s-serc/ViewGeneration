@startuml mrubash1_trainspotting
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Raspberry Pi" as RPi {
  rectangle "Video_Camera" as Camera #lightblue
  rectangle "Video_Sensor" as Sensor #palegreen
  rectangle "Video_Detector" as Detector #mistyrose
  rectangle "TensorFlow Model" as TFModel #lightyellow
}

rectangle "Data Storage" as Storage #aliceblue

' ========== Connections ==========
User --> Camera : Start/Stop Capture

' Video processing flow
Camera --> Sensor : Raw frames (input_deque)
Sensor --> Detector : Processed frames (motion data)
Detector --> TFModel : ROI images for classification
TFModel --> Detector : Classification results

' Data handling
Detector --> Storage : Store detection events\nand motion data
Detector --> Storage : Sample frames\naround events

' Internal processing
Sensor --> Sensor : Background subtraction\nNoise reduction\nROI extraction
Detector --> Detector : Motion analysis\nDirection determination\nDynamic camera adjustment

' Visualization
Detector --> User : Display processed video\nDetection alerts\nDirection indicators
@enduml