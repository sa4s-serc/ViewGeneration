@startuml jes_autopatzer
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Electron UI (React)" as UI {
}

rectangle "Lichess API" as Lichess #mistyrose

rectangle "Teensy 3.2 Microcontroller" as Teensy #palegreen {
  rectangle "Stepper Motor Control" as Motors
  rectangle "Hall Effect Sensors" as Sensors
}

rectangle "Perl Script" as Perl #lightsteelblue

rectangle "Physical Chess Board" as Board #lightyellow {
  rectangle "NEMA17 Steppers" as Steppers
  rectangle "Electromagnet" as Magnet
}

' ========== Connections ==========
User --> UI

' UI interactions
UI <--> Lichess : WebSocket\nGame State\nMove Events
UI --> Perl : TCP/IP\nMove Commands\nSensor Data
UI --> Teensy : Serial\nMotor Control\nMagnet Control

' Perl script interactions
Perl --> Teensy : Serial\nSensor Readings\nMove Confirmations

' Teensy interactions
Teensy --> Board : Motor Signals\nMagnet Control
Board --> Teensy : Hall Effect Readings

' Physical interactions
User <--> Board : Place/Remove Pieces
@enduml