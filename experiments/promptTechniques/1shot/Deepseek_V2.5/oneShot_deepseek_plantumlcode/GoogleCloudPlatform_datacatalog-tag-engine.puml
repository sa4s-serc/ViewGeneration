@startuml GoogleCloudPlatform_datacatalog-tag-engine
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<gcp>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "UI Service (Cloud Run)" <<ui>> {
  rectangle "Jinja2 Templates" as Templates
  rectangle "Web Interface" as WebUI
  rectangle "Static Assets" as Assets
  Templates --> WebUI
  WebUI --> Assets
}

package "API Service (Cloud Run)" <<api>> {
  rectangle "Flask App (main.py)" as Flask
  rectangle "Controllers\n(DataCatalog, Dataplex)" as Controllers
  rectangle "Job Manager" as JobManager
  rectangle "Task Manager" as TaskManager
  rectangle "Access Control" as Access
  Flask --> Controllers
  Flask --> JobManager
  JobManager --> TaskManager
  Flask --> Access
}

package "Storage" <<storage>> {
  database "Firestore\n(Configurations)" as Firestore
  database "BigQuery\n(Tag History)" as BigQuery
  database "Cloud Storage\n(CSV Files)" as GCS
}

package "Google Cloud Services" <<gcp>> {
  rectangle "Cloud Tasks" as CloudTasks
  rectangle "Data Catalog API" as DataCatalog
  rectangle "Dataplex API" as Dataplex
  rectangle "IAM" as IAM
}

Flask --> Firestore
Flask --> BigQuery
Flask --> GCS
TaskManager --> CloudTasks
Controllers --> DataCatalog
Controllers --> Dataplex
Access --> IAM
WebUI --> Flask
@enduml