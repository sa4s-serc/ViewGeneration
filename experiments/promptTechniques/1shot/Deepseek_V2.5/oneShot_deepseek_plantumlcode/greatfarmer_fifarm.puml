@startuml greatfarmer_fifarm
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Thymeleaf)" <<frontend>> {
  rectangle "HTML Templates" as HTML
  rectangle "Static Assets\n(CSS/JS/Images)" as Assets
}

package "Backend (Spring Boot)" <<backend>> {
  rectangle "Controllers\n(Index/Path/Json)" as Controllers
  rectangle "Services\n(Mongo/Log/Http)" as Services
  rectangle "Scheduler" as Scheduler
  rectangle "Utils\n(File/Date/Json)" as Utils
  Controllers --> Services
  Services --> Utils
  Scheduler --> Services
}

package "Integrations" <<integration>> {
  rectangle "EA Sports FUT API" as FUTAPI
  Services --> FUTAPI
}

database "MongoDB" <<db>> as MongoDB
Services --> MongoDB

Controllers --> HTML
HTML --> Assets
@enduml