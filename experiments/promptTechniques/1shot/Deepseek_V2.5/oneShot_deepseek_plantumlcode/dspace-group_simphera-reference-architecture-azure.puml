@startuml dspace-group_simphera-reference-architecture-azure
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "DevOps Engineer" as User

rectangle "Terraform CLI" as Terraform #lightblue

rectangle "Azure Resource Manager" as ARM #azure

rectangle "Azure Kubernetes Service" as AKS #palegreen

rectangle "Azure PostgreSQL" as Postgres #lightyellow

rectangle "Azure Key Vault" as KeyVault #mistyrose

rectangle "Azure Storage (MinIO)" as MinIO #aliceblue

rectangle "Azure Log Analytics" as LogAnalytics #lightgrey

' ========== Deployment Flow ==========
User -> Terraform : apply
Terraform -> ARM : create/update resources
ARM -> AKS : provision cluster
ARM -> Postgres : provision database
ARM -> KeyVault : provision vault
ARM -> MinIO : provision storage
ARM -> LogAnalytics : setup monitoring (optional)

' ========== Connectivity Flow ==========
AKS <--> Postgres : private link
AKS <--> MinIO : private link
AKS <--> KeyVault : secret access
Postgres <--> KeyVault : credential management
MinIO <--> KeyVault : credential management
AKS -> LogAnalytics : send logs (optional)

@enduml