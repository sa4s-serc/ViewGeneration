@startuml IBM_cognos-analytics-to-visualize-business-data
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Node.js Data Generator" as NodeJS {
  rectangle "create-product-data.js" as DataGen
  rectangle "save-product-reviews.js" as Reviews
  rectangle "database-util.js" as DBUtil
}

rectangle "Data Warehouse" as Warehouse {
  rectangle "Db2 Warehouse" as Db2
  rectangle "Netezza" as Netezza
}

rectangle "IBM Cognos Analytics" as Cognos {
  rectangle "Data Modules" as Modules
  rectangle "Dashboards" as Dashboards
}

' ========== Connections ==========
User --> NodeJS : Triggers data generation

DataGen --> DBUtil : Uses database utilities
Reviews --> DBUtil : Uses database utilities
DBUtil --> Db2 : Loads business data
DBUtil --> Netezza : Loads business data

Cognos --> Db2 : Connects to warehouse\ncreates data modules
Cognos --> Netezza : Connects to warehouse\ncreates data modules

Modules --> Dashboards : Builds visualizations
User --> Cognos : Interacts with dashboards
@enduml