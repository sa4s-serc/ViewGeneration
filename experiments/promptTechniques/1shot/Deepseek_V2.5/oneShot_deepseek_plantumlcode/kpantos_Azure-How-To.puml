@startuml kpantos_Azure-How-To
skinparam rectangle {
  BackgroundColor<<bot>> #d9e7fd
  BackgroundColor<<waf>> #fddddd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<auth>> #fff1c9
  BackgroundColor<<onprem>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Bot Application\n(Microsoft Bot Framework)" <<bot>> as Bot
rectangle "Azure App Service" <<bot>> as AppService
rectangle "Azure Application Gateway" <<waf>> as AppGateway
rectangle "Web Application Firewall" <<waf>> as WAF
rectangle "Let's Encrypt" <<waf>> as LetsEncrypt

Bot --> AppService
AppService --> AppGateway
AppGateway --> WAF
WAF --> LetsEncrypt

rectangle "On-Premises API\n(Simulated in Azure)" <<onprem>> as OnPremAPI
rectangle "Azure AD Application Proxy" <<auth>> as AppProxy
rectangle "Azure API Management" <<api>> as APIM
rectangle "Azure AD Connect" <<auth>> as ADConnect
rectangle "Service Principal Name" <<auth>> as SPN

OnPremAPI --> AppProxy
AppProxy --> APIM
ADConnect --> SPN
SPN --> OnPremAPI

cloud "Azure Cloud" {
  AppService
  AppGateway
  WAF
  AppProxy
  APIM
  ADConnect
}

database "On-Premises\nActive Directory" <<onprem>> as AD
ADConnect --> AD
@enduml