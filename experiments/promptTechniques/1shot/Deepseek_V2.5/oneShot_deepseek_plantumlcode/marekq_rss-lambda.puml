@startuml marekq_rss-lambda
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "CloudWatch\nEvents" as CloudWatch #lightblue

rectangle "Step Function" as StepFunction #palegreen

rectangle "Lambda\nFunctions" as LambdaGroup #lightyellow {
  rectangle "rsscrawl" as Crawl
  rectangle "rssgetfeed" as GetFeed
}

rectangle "External\nServices" as External #mistyrose {
  rectangle "RSS Feeds" as RSS
  rectangle "AWS Comprehend" as Comprehend
  rectangle "SES" as SES
}

rectangle "Storage" as Storage #aliceblue {
  rectangle "DynamoDB" as DynamoDB
  rectangle "S3" as S3
}

rectangle "Optional\nComponents" as Optional #lavender {
  rectangle "AppSync" as AppSync
  rectangle "Algolia" as Algolia
}

' ========== Connections ==========
CloudWatch --> StepFunction : Triggers on schedule
StepFunction --> Crawl : Start execution
Crawl --> RSS : Fetch feed URLs
Crawl --> S3 : Check existing data
Crawl --> StepFunction : Report status

StepFunction --> GetFeed : Process each feed (Map state)
GetFeed --> RSS : Parse feed content
GetFeed --> Comprehend : Entity recognition
GetFeed --> DynamoDB : Store processed data
GetFeed --> SES : Send notifications (if enabled)
GetFeed --> Algolia : Index data (if enabled)
GetFeed --> S3 : Store public JSON (if enabled)

DynamoDB --> AppSync : GraphQL queries (if enabled)
@enduml