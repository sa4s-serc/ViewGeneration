@startuml Enterprise-CMCS_macpro-appian-connector
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Appian System" as Appian
rectangle "Kafka Connector" as Connector #lightblue {
  rectangle "run.ts" as RunTS
  rectangle "Serverless Services" as Services
}

rectangle "AWS Infrastructure" as AWS #mistyrose {
  rectangle "ECS" as ECS
  rectangle "SNS" as SNS
  rectangle "CloudWatch" as CW
  rectangle "EventBridge" as EB
}

rectangle "BigMAC" as BigMAC #palegreen
rectangle "GitHub Actions" as CI #aliceblue

' ========== Connections ==========
Appian --> Connector : Data changes
Connector --> BigMAC : Stream data

' Internal connector flow
RunTS --> Services : Process data
Services --> ECS : Deploy
Services --> SNS : Publish alerts

' AWS interactions
ECS --> CW : Log metrics
CW --> EB : Trigger events
EB --> SNS : Send notifications

' CI/CD interactions
CI --> Connector : Deploy updates
CI --> AWS : Infrastructure changes
CI --> CI : Run tests\nDependency checks

' Monitoring
CW --> SNS : Alert on failures
SNS --> CI : Notify status
@enduml