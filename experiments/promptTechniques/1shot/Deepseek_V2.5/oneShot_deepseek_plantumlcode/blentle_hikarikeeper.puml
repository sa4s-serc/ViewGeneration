@startuml blentle_hikarikeeper
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<client>> #d8f5d3
  BackgroundColor<<server>> #fddddd
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<integration>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Module" <<core>> {
  rectangle "Raft Consensus\n(Leader/Follower/Candidate)" as Raft
  rectangle "RPC Communication" as RPC
  rectangle "Event Manager" as EventManager
  rectangle "Node Repository" as NodeRepo
  Raft --> RPC
  Raft --> EventManager
  Raft --> NodeRepo
}

package "Client Module" <<client>> {
  rectangle "HikariClient API" as ClientAPI
  rectangle "Client Factory" as ClientFactory
  ClientFactory --> ClientAPI
}

package "Server Module" <<server>> {
  rectangle "Bootstrap Server" as Bootstrap
  rectangle "Main Server Logic" as ServerLogic
  Bootstrap --> ServerLogic
}

package "Storage" <<storage>> {
  database "RocksDB" as RocksDB
  rectangle "In-Memory Log" as MemLog
  rectangle "File-Based Log" as FileLog
  RocksDB -down-> MemLog
  RocksDB -down-> FileLog
}

package "Integrations" <<integration>> {
  rectangle "Spring Boot Starter" as SpringBoot
  rectangle "Discovery Service" as Discovery
}

ClientAPI --> RPC
ServerLogic --> Raft
ServerLogic --> RocksDB
SpringBoot --> ClientAPI
Discovery --> ServerLogic
@enduml