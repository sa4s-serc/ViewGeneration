@startuml leekoko_Java-Web
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
}

rectangle "Backend" as BE {
  rectangle "Servlet Controller" as Controller
  rectangle "Service Layer" as Service
  rectangle "DAO Layer" as DAO
}

rectangle "Database" as DB #lightblue {
}

rectangle "External APIs" as API #palegreen {
}

rectangle "Dubbo Registry" as Registry #mistyrose

rectangle "Dubbo Provider" as Provider #lightyellow

' ========== Connections ==========
User -> FE : HTTP Request
FE -> Controller : Form Data/AJAX
Controller -> Service : Business Logic
Service -> DAO : Data Access
DAO -> DB : SQL Queries
Service -> API : REST Calls (e.g. Baidu Translate)
Controller <-> Registry : Service Discovery
Registry <-> Provider : Service Registration
Provider -> BE : RPC Calls
FE <-> BE : JSON Responses
@enduml