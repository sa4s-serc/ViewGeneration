@startuml inovex_scrumlr.io
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
  rectangle "React Components" as React
  rectangle "Redux Store" as Redux
}

rectangle "Backend" as BE {
  rectangle "API Handlers" as API
  rectangle "Services" as Services
  rectangle "Database" as DB
}

rectangle "Infrastructure" as Infra {
  rectangle "NATS/Redis" as NATS
  rectangle "Auth Providers" as Auth
}

' ========== Connections ==========
User --> React : Interacts with UI
React --> Redux : Dispatches actions
Redux --> React : Updates state

React --> API : HTTP Requests (REST)
API --> Services : Business logic
Services --> DB : Data access
DB --> Services : Query results
Services --> API : Response data
API --> React : JSON response

API --> Auth : Authenticate requests
Auth --> API : Auth status

Services --> NATS : Publish events
NATS --> React : Real-time updates (WS)
React --> NATS : Subscribe to events

@enduml