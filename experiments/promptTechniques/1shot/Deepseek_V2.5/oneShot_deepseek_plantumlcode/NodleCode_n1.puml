@startuml NodleCode_n1
skinparam rectangle {
  BackgroundColor<<firmware>> #d9e7fd
  BackgroundColor<<mobile>> #d8f5d3
  BackgroundColor<<cloud>> #fddddd
  BackgroundColor<<hardware>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Firmware (Dialog DA14531)" <<firmware>> {
  rectangle "iBeacon Implementation" as iBeacon
  rectangle "BLE Stack" as BLE
  rectangle "Peripheral Drivers" as Drivers
  rectangle "Configuration Files" as Config
  rectangle "Memory Management" as Memory
  iBeacon --> BLE
  iBeacon --> Drivers
  iBeacon --> Config
  iBeacon --> Memory
}

package "Mobile App" <<mobile>> {
  rectangle "Beacon Detector" as Detector
  rectangle "Location Services" as Location
  rectangle "Cloud Connector" as Connector
  Detector --> Location
  Detector --> Connector
}

package "Nodle Cloud" <<cloud>> {
  rectangle "API Gateway" as API
  rectangle "Beacon Database" as DB
  rectangle "Authentication" as Auth
  API --> DB
  API --> Auth
}

package "Hardware" <<hardware>> {
  rectangle "PCB Design" as PCB
  rectangle "Gerber Files" as Gerber
  rectangle "Drill Files" as Drill
  PCB --> Gerber
  PCB --> Drill
}

Connector --> API
iBeacon --> Detector
Drivers --> PCB
@enduml