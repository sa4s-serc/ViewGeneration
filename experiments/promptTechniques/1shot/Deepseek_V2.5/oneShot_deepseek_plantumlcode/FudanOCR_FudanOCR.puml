@startuml FudanOCR_FudanOCR
skinparam rectangle {
  BackgroundColor<<detection>> #d9e7fd
  BackgroundColor<<recognition>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<training>> #fff1c9
  BackgroundColor<<utils>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Text Detection" <<detection>> {
  rectangle "EAST" as EAST
  rectangle "AdvancedEAST" as AdvEAST
  rectangle "PSENet" as PSENet
  rectangle "PixelLink" as PixelLink
  rectangle "TextSnake" as TextSnake
  rectangle "RRPN" as RRPN
}

package "Text Recognition" <<recognition>> {
  rectangle "CRNN" as CRNN
  rectangle "MORAN" as MORAN
  rectangle "GRCNN" as GRCNN
  rectangle "DAN" as DAN
  rectangle "SAR" as SAR
  rectangle "RARE" as RARE
}

package "Data Handling" <<data>> {
  rectangle "Data Loaders" as Loaders
  rectangle "Augmentation" as Augment
  rectangle "LMDB Maker" as LMDB
  rectangle "Preprocessing" as Preprocess
  Loaders --> Augment
  Augment --> Preprocess
  Preprocess --> LMDB
}

package "Training & Evaluation" <<training>> {
  rectangle "Training Engine" as Engine
  rectangle "Config Manager" as Config
  rectangle "Loss Functions" as Loss
  rectangle "Evaluation Metrics" as Eval
  Config --> Engine
  Engine --> Loss
  Engine --> Eval
}

package "Utilities" <<utils>> {
  rectangle "Custom Layers" as Layers
  rectangle "Post-processing" as Post
  rectangle "Registry" as Registry
  rectangle "Cython/CUDA Ops" as CUDA
  Layers --> Post
  Post --> CUDA
  Registry --> Layers
}

EAST --> Engine
AdvEAST --> Engine
PSENet --> Engine
TextSnake --> Engine
CRNN --> Engine
MORAN --> Engine
DAN --> Engine
Loaders --> Engine
Config --> EAST
Config --> CRNN
Loss --> EAST
Loss --> CRNN
Eval --> EAST
Eval --> CRNN
Layers --> EAST
Layers --> CRNN
CUDA --> Post
Post --> EAST
Post --> CRNN
@enduml