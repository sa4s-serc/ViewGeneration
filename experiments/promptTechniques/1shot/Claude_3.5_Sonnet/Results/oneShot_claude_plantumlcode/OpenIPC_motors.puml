@startuml OpenIPC_motors

actor "Camera Application" as App
participant "Motors Daemon" as Daemon
participant "Driver Wrapper" as Wrapper
participant "Kernel Driver" as KernelDriver
participant "Hardware" as Hardware

App -> Daemon : Send motor control command
activate Daemon

Daemon -> Daemon : Validate command

alt Command valid
    Daemon -> Wrapper : Translate command to hardware-specific instruction
    activate Wrapper
    
    alt Direct hardware access
        Wrapper -> Hardware : Send control signal
        Hardware --> Wrapper : Return status
    else Kernel driver required
        Wrapper -> KernelDriver : Send ioctl command
        activate KernelDriver
        KernelDriver -> Hardware : Control hardware
        Hardware --> KernelDriver : Return status
        KernelDriver --> Wrapper : Return result
        deactivate KernelDriver
    end
    
    Wrapper --> Daemon : Return operation result
    deactivate Wrapper
    
    Daemon --> App : Return success status
else Command invalid
    Daemon --> App : Return error status
end

deactivate Daemon

@enduml