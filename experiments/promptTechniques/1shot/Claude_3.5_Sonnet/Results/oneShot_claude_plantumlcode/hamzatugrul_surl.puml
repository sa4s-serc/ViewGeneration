@startuml hamzatugrul_surl

skinparam componentStyle uml2

actor User

component "Nginx Load Balancer" as Nginx
component "Spring Boot Application" as App {
  [ShortURLController] as Controller
  [UrlShortenerService] as Service
  [ShortUrlRepository] as Repository
  [KeyGenerator] as KeyGen
}
database "MongoDB" as MongoDB
database "Redis Cache" as Redis

User --> Nginx : HTTP Request
Nginx --> Controller : Forward Request
Controller --> Service : Process Request
Service --> KeyGen : Generate Key
Service --> Repository : CRUD Operations
Repository --> MongoDB : Persist Data
Repository <--> Redis : Cache Data

@enduml