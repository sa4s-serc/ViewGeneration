@startuml NicoJuicy_Airline-Microservices

!define RECTANGLE class

skinparam component {
  BackgroundColor<<service>> LightBlue
  BackgroundColor<<gateway>> LightGreen
  BackgroundColor<<messaging>> LightYellow
  BackgroundColor<<shared>> LightGray
}

rectangle "API Gateway" as gateway <<gateway>> {
  [YARP Reverse Proxy]
}

rectangle "Identity Service" as identity <<service>> {
  [IdentityServer]
  [JWT Authentication]
}

rectangle "Flight Service" as flight <<service>> {
  [Flight Management]
  [Seat Availability]
}

rectangle "Passenger Service" as passenger <<service>> {
  [Passenger Information]
}

rectangle "Reservation Service" as reservation <<service>> {
  [Ticket Reservations]
}

cloud "Message Broker" as broker <<messaging>> {
  [RabbitMQ]
}

rectangle "Building Blocks" as buildingblocks <<shared>> {
  [Exception Handling]
  [Logging (Serilog)]
  [Swagger Configuration]
  [Data Access Interfaces]
  [Messaging Utilities]
  [Security Components]
}

database "Database" as db

gateway -down-> identity
gateway -down-> flight
gateway -down-> passenger
gateway -down-> reservation

identity -[hidden]right- flight
flight -[hidden]right- passenger
passenger -[hidden]right- reservation

identity -up-> buildingblocks
flight -up-> buildingblocks
passenger -up-> buildingblocks
reservation -up-> buildingblocks

identity -down-> db
flight -down-> db
passenger -down-> db
reservation -down-> db

identity <--> broker
flight <--> broker
passenger <--> broker
reservation <--> broker

@enduml