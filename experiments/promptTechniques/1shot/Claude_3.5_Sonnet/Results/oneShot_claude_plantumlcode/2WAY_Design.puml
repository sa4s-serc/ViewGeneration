@startuml 2WAY_Design

skinparam component {
  BackgroundColor LightBlue
  BorderColor Black
  ArrowColor Black
}

[Trusted Entity 1] as TE1
[Trusted Entity 2] as TE2
[Trusted Entity 3] as TE3

cloud "Trust Network" {
  [Authorization & Authentication] as AA
  [Private Data Exchange] as PDE
  [Trust Management] as TM
}

database "Secure Data Storage" as SDS

TE1 -down-> AA : Authenticate
TE2 -down-> AA : Authenticate
TE3 -down-> AA : Authenticate

AA -down-> TM : Verify Trust
TM -right-> PDE : Allow Exchange

PDE <-up-> SDS : Store/Retrieve Data

TE1 <-right-> PDE : Exchange Data
TE2 <-up-> PDE : Exchange Data
TE3 <-left-> PDE : Exchange Data

@enduml