@startuml ankithans_codeX

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<ExternalService>> LightYellow
}

package "Frontend (ReactJS)" <<Frontend>> {
  [App.js]
  [Navbar]
  [PseudoCode]
  [Warnings]
  [Compile]
  [Monaco Editor]
}

package "Backend (FastAPI)" <<Backend>> {
  [API Gateway]
  [Compile Service]
  [PseudoCode Service]
  [Warnings Service]
  [Translation Service]
  [Code Sharing Service]
  [Flowchart Service]
}

database "SQLite" {
  [Shared Code Storage]
}

cloud "External Services" <<ExternalService>> {
  [HackerEarth API]
  [Google Translate API]
}

[App.js] --> [Navbar]
[App.js] --> [PseudoCode]
[App.js] --> [Warnings]
[App.js] --> [Compile]
[App.js] --> [Monaco Editor]

[App.js] --> [API Gateway] : HTTP Requests

[API Gateway] --> [Compile Service]
[API Gateway] --> [PseudoCode Service]
[API Gateway] --> [Warnings Service]
[API Gateway] --> [Translation Service]
[API Gateway] --> [Code Sharing Service]
[API Gateway] --> [Flowchart Service]

[Compile Service] --> [HackerEarth API]
[Translation Service] --> [Google Translate API]
[Code Sharing Service] --> [Shared Code Storage]

@enduml