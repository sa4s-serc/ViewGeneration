@startuml alextanhongpin_node-rest

skinparam component {
  BackgroundColor<<API>> LightBlue
  BackgroundColor<<Service>> LightGreen
  BackgroundColor<<Data>> LightYellow
  BackgroundColor<<Config>> LightGray
}

[Express App] <<API>>
[Food Service] <<Service>>
[Database] <<Data>>
[Configuration] <<Config>>

package "Food Service" {
  [Route]
  [Model]
  [Store]
}

[Express App] --> [Food Service]
[Food Service] --> [Route]
[Food Service] --> [Model]
[Food Service] --> [Store]
[Store] --> [Database]
[Model] --> [Store]

[Express App] --> [Configuration]
[Database] --> [Configuration]

[Schema Validation]
[Error Handling]

[Model] --> [Schema Validation]
[Express App] --> [Error Handling]

[Docker]
[Docker] ..> [Express App] : contains
[Docker] ..> [Database] : contains

@enduml