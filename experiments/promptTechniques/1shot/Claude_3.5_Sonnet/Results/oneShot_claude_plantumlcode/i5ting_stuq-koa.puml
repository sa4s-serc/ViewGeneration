@startuml i5ting_stuq-koa

actor User
participant "Koa.js Application" as Koa
participant "Middleware Stack" as Middleware
participant "Router" as Router
participant "Controller" as Controller
database "MongoDB" as DB

User -> Koa: HTTP Request
activate Koa

Koa -> Middleware: Process Request
activate Middleware

loop For each middleware
    Middleware -> Middleware: Execute middleware function
end

Middleware -> Router: Route Request
activate Router

Router -> Controller: Handle Request
activate Controller

Controller -> DB: Query/Update Data
activate DB
DB --> Controller: Return Data
deactivate DB

Controller --> Router: Return Response
deactivate Controller

Router --> Middleware: Pass Response
deactivate Router

Middleware --> Koa: Finalize Response
deactivate Middleware

Koa --> User: HTTP Response
deactivate Koa

@enduml