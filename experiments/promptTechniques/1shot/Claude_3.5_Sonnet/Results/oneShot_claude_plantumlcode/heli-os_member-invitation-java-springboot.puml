@startuml heli-os_member-invitation-java-springboot

skinparam component {
  BackgroundColor<<API>> LightBlue
  BackgroundColor<<Domain>> LightGreen
  BackgroundColor<<Infrastructure>> LightYellow
  BackgroundColor<<External>> LightGray
}

package "API Layer" <<API>> {
  [MemberInvitationApplication]
  [REST Controllers]
  [DTOs]
  [Mappers]
  [Exception Handlers]
}

package "Domain Layer" <<Domain>> {
  [Member]
  [Invitation]
  [Use Cases]
  [Domain Services]
}

package "Infrastructure Layer" <<Infrastructure>> {
  package "Database Persistence" {
    [JPA Entities]
    [JPA Repositories]
  }
  
  package "Redis Persistence" {
    [Redis Adapter]
  }
}

package "Commons" {
  [Common Models]
  [Utility Functions]
}

cloud "External Systems" <<External>> {
  database "Relational Database"
  database "Redis"
}

[MemberInvitationApplication] --> [REST Controllers]
[REST Controllers] --> [DTOs]
[REST Controllers] --> [Mappers]
[REST Controllers] --> [Use Cases]
[DTOs] ..> [Common Models]
[Mappers] ..> [Common Models]

[Use Cases] --> [Domain Services]
[Domain Services] --> [Member]
[Domain Services] --> [Invitation]

[Domain Services] --> [JPA Repositories]
[Domain Services] --> [Redis Adapter]

[JPA Repositories] --> [JPA Entities]
[JPA Entities] --> "Relational Database"
[Redis Adapter] --> Redis

[Common Models] <.. [Member]
[Common Models] <.. [Invitation]
[Utility Functions] <.. [Domain Services]

@enduml