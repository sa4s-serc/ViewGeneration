@startuml NodleCode_n1

!define RECTANGLE class

skinparam rectangle {
    BackgroundColor<<device>> LightBlue
    BackgroundColor<<mobile>> LightGreen
    BackgroundColor<<cloud>> LightYellow
    BackgroundColor<<hardware>> LightPink
}

rectangle "Dialog DA14531 Device" <<device>> {
    RECTANGLE "iBeacon Firmware" as Firmware
    RECTANGLE "SDK6" as SDK
    RECTANGLE "SPI Flash" as Flash
}

rectangle "Nodle Mobile App" <<mobile>> {
    RECTANGLE "Beacon Detector" as Detector
}

rectangle "Nodle Cloud" <<cloud>> {
    RECTANGLE "API" as API
    RECTANGLE "Beacon Data Storage" as Storage
}

rectangle "Hardware" <<hardware>> {
    RECTANGLE "PCB Design Files" as PCB
}

Firmware --> SDK : uses
Firmware --> Flash : reads from
Detector --> Firmware : detects
Detector --> API : sends data
API --> Storage : stores/retrieves
PCB ..> Firmware : supports

rectangle "Development & Deployment" {
    RECTANGLE "Keil uVision IDE" as IDE
    RECTANGLE "Python Script" as Script
}

IDE --> Firmware : builds
Script --> API : retrieves data

@enduml