@startuml IBM_cognos-analytics-to-visualize-business-data

actor User
participant "Node.js Scripts" as NodeJS
database "CSV Files" as CSV
database "Db2 Warehouse/\nNetezza" as Warehouse
participant "IBM Cognos Analytics" as Cognos

User -> NodeJS : Run data generation scripts
activate NodeJS

NodeJS -> NodeJS : Generate sample data
NodeJS -> CSV : Write data to CSV files
deactivate NodeJS

User -> NodeJS : Run data loading scripts
activate NodeJS

NodeJS -> CSV : Read CSV files
NodeJS -> Warehouse : Load data into warehouse
deactivate NodeJS

User -> Cognos : Connect to data warehouse
activate Cognos

Cognos -> Warehouse : Establish connection
Cognos -> Cognos : Create data modules

User -> Cognos : Build dashboards
Cognos -> Cognos : Generate visualizations

User -> Cognos : Analyze data
Cognos --> User : Display insights

deactivate Cognos

@enduml