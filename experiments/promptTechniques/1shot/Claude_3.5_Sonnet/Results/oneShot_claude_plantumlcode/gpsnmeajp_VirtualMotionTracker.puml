@startuml gpsnmeajp_VirtualMotionTracker

skinparam component {
  BackgroundColor<<Core>> LightBlue
  BackgroundColor<<Module>> LightGreen
  BackgroundColor<<External>> LightYellow
}

package "Eigen Library" {
  [Core Module] <<Core>> as Core
  [Sparse Module] <<Module>>
  [Geometry Module] <<Module>>
  [Eigenvalues Module] <<Module>>
  [Unsupported Module] <<Module>>

  component "Expression Templates" as ET
  component "Memory Management" as MM
  component "SIMD Vectorization" as SIMD
  component "Plugin System" as Plugin

  Core --> ET
  Core --> MM
  Core --> SIMD
  Core --> Plugin

  [Sparse Module] --> Core
  [Geometry Module] --> Core
  [Eigenvalues Module] --> Core
  [Unsupported Module] --> Core
}

package "External Libraries" {
  [BLAS] <<External>>
  [LAPACK] <<External>>
}

interface "C++ Application" as App

App --> [Core Module]
App --> [Sparse Module]
App --> [Geometry Module]
App --> [Eigenvalues Module]
App --> [Unsupported Module]

[Core Module] --> [BLAS]
[Core Module] --> [LAPACK]

@enduml