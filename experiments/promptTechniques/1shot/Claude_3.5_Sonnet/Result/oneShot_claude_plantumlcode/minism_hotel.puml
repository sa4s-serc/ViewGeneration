@startuml minism_hotel

skinparam component {
  BackgroundColor<<service>> LightBlue
  BackgroundColor<<library>> LightGreen
  BackgroundColor<<config>> LightYellow
  BackgroundColor<<database>> LightGray
}

cloud "Docker Environment" {
  component "hotel-master" <<service>> {
    [REST API]
    [RPC Server]
    [Session Management]
    [Database Access Layer]
    [Reaper]
  }
  
  component "hotel-spawner" <<service>> {
    [Spawner RPC Server]
    [Game Server Management]
    [Master Communication]
  }
  
  database "SQLite" <<database>>
  
  [hotel-master] --> SQLite
}

component "Shared Libraries" <<library>> {
  [Configuration Loading]
  [Environment Variable Handling]
  [Logging]
  [Crypto]
  [Common Utilities]
}

component "Protobuf Definitions" <<config>> {
  [gRPC Messages]
  [gRPC Services]
}

component "Configuration Files" <<config>> {
  [Master Config]
  [Spawner Config]
}

component "Build & Deployment" {
  [Makefile]
  [Docker Compose]
}

[hotel-master] ..> [Shared Libraries] : uses
[hotel-spawner] ..> [Shared Libraries] : uses
[hotel-master] ..> [Protobuf Definitions] : uses
[hotel-spawner] ..> [Protobuf Definitions] : uses
[hotel-master] ..> [Master Config] : reads
[hotel-spawner] ..> [Spawner Config] : reads
[Makefile] ..> [hotel-master] : builds
[Makefile] ..> [hotel-spawner] : builds
[Docker Compose] ..> [hotel-master] : deploys
[Docker Compose] ..> [hotel-spawner] : deploys

@enduml