@startuml terrenjpeterson_javawatch

actor User
participant "Raspberry Pi" as RPI
participant "S3 Bucket" as S3
participant "Lambda (checkImage.py)" as Lambda1
participant "Lambda (labelCheck.js)" as Lambda2
participant "Amazon Rekognition" as Rekognition
participant "Amazon DRS" as DRS
participant "Website" as Web

User -> RPI : Activate camera
RPI -> RPI : Capture image
RPI -> RPI : Overlay timestamp
RPI -> S3 : Upload image

S3 -> Lambda1 : Trigger event
activate Lambda1
Lambda1 -> Rekognition : detect_labels()
Rekognition --> Lambda1 : Return labels
Lambda1 -> Lambda2 : Trigger
deactivate Lambda1

activate Lambda2
Lambda2 -> Lambda2 : Check for "Bean" label
alt Bean level low
    Lambda2 -> DRS : Place order
    DRS --> Lambda2 : Order confirmation
end
deactivate Lambda2

User -> Web : Access website
Web -> User : Display registration page
User -> Web : Enter device details
Web -> DRS : Register device
DRS --> Web : Confirmation
Web -> User : Display confirmation

@enduml