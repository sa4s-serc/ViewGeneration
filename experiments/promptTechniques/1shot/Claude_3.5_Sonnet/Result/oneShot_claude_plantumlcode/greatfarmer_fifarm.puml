@startuml greatfarmer_fifarm

!define RECTANGLE class

skinparam rectangle {
    BackgroundColor<<Application>> LightBlue
    BackgroundColor<<API>> LightGreen
    BackgroundColor<<Database>> LightYellow
    BackgroundColor<<External>> LightGray
}

rectangle "FIFArm Application" <<Application>> {
    RECTANGLE SpiderApplication
    RECTANGLE WebInterface
    RECTANGLE Controllers
    RECTANGLE MongoService
    RECTANGLE HttpRequestService
    RECTANGLE Scheduler
}

rectangle "MongoDB" <<Database>> {
    RECTANGLE PlayerData
}

rectangle "EA Sports FUT API" <<External>> {
    RECTANGLE PlayerDataAPI
}

cloud "Internet" {
    RECTANGLE Users
}

SpiderApplication --> WebInterface
SpiderApplication --> Controllers
SpiderApplication --> MongoService
SpiderApplication --> HttpRequestService
SpiderApplication --> Scheduler

Controllers --> MongoService
Controllers --> HttpRequestService

MongoService --> PlayerData
HttpRequestService --> PlayerDataAPI

Scheduler --> HttpRequestService
Scheduler --> MongoService

Users --> WebInterface : HTTP

@enduml