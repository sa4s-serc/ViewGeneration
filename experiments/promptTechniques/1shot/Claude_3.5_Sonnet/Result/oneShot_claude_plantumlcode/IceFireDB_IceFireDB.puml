@startuml IceFireDB_IceFireDB

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<proxy>> LightGreen
  BackgroundColor<<lib>> LightYellow
  BackgroundColor<<protocol>> LightPink
}

[IceFireDB Core] <<core>> as core
[IceFireDB-SQLProxy] <<proxy>> as sqlproxy
[Uhaha] <<lib>> as uhaha
[Protocol Buffers] <<protocol>> as protobuf
[gRPC] <<protocol>> as grpc
[Crypto Libraries] <<lib>> as crypto
[Go Extended Toolchain] <<lib>> as gotools
[OpenTelemetry] <<lib>> as otel
[HTTP/2] <<lib>> as http2
[Low-Level System Calls] <<lib>> as syscalls

database "LevelDB" as leveldb
database "MySQL" as mysql

core --> uhaha : uses
core --> leveldb : persists data
sqlproxy --> mysql : proxies
core --> protobuf : serialization
core --> grpc : communication
sqlproxy --> protobuf : serialization
sqlproxy --> grpc : communication
core --> crypto : security
sqlproxy --> crypto : security
core --> gotools : code management
sqlproxy --> gotools : code management
core --> otel : telemetry
sqlproxy --> otel : telemetry
grpc --> http2 : transport
core --> syscalls : low-level ops
sqlproxy --> syscalls : low-level ops

@enduml