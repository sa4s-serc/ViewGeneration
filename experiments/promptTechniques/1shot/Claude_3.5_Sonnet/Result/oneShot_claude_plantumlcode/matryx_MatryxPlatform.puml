@startuml matryx_MatryxPlatform

skinparam component {
  BackgroundColor<<Smart Contract>> LightBlue
  BackgroundColor<<Library>> LightGreen
  BackgroundColor<<JavaScript>> LightYellow
}

component "MatryxPlatform" <<Smart Contract>> as MP
component "MatryxSystem" <<Smart Contract>> as MS
component "MatryxForwarder" <<Smart Contract>> as MF
component "MatryxToken" <<Smart Contract>> as MT

component "LibPlatform" <<Library>> as LP
component "LibCommit" <<Library>> as LC
component "LibTournament" <<Library>> as LT

component "utils.js" <<JavaScript>> as UJS
component "test.js" <<JavaScript>> as TJS
component "benchmark.js" <<JavaScript>> as BJS

MP --> LP : delegatecall
MP --> LC : delegatecall
MP --> LT : delegatecall

MS --> MP : manages versions
MF --> MP : forwards calls

UJS --> MP : interacts
UJS --> MT : interacts
TJS --> UJS : uses
BJS --> UJS : uses

@enduml