@startuml shinesolutions_sitechecker-slackbot

skinparam component {
  BackgroundColor<<AWS>> #LightYellow
  BackgroundColor<<External>> #LightBlue
}

[Slack] <<External>> as slack
[API Gateway] <<AWS>> as apigateway
[Master Lambda] <<AWS>> as master
[Worker Lambda (Region 1)] <<AWS>> as worker1
[Worker Lambda (Region 2)] <<AWS>> as worker2
[Worker Lambda (Region N)] <<AWS>> as workerN

cloud "AWS" {
  apigateway - [master]
  master --> worker1
  master --> worker2
  master --> workerN
}

slack <--> apigateway : Outgoing Webhook

note right of master
  - Receives requests
  - Authenticates
  - Parses URL
  - Distributes tasks
  - Aggregates results
end note

note right of worker1
  - Checks website
  - Returns status
end note

@enduml