@startuml elloza_Android-Developer-Certification

skinparam component {
  BackgroundColor<<UI>> LightBlue
  BackgroundColor<<Presenter>> LightGreen
  BackgroundColor<<Data>> LightYellow
  BackgroundColor<<Service>> LightPink
}

component "MainActivity" <<UI>> as MainActivity
component "RibotsAdapter" <<UI>> as RibotsAdapter
component "MainPresenter" <<Presenter>> as MainPresenter
component "DataManager" <<Data>> as DataManager
component "SyncService" <<Service>> as SyncService
component "DatabaseHelper" <<Data>> as DatabaseHelper
component "RibotsService" <<Data>> as RibotsService
component "PreferencesHelper" <<Data>> as PreferencesHelper
component "RxEventBus" <<Data>> as RxEventBus

database "SQLite" as SQLite

MainActivity --> RibotsAdapter
MainActivity --> MainPresenter
MainPresenter --> DataManager
DataManager --> DatabaseHelper
DataManager --> RibotsService
DataManager --> PreferencesHelper
DataManager --> RxEventBus
SyncService --> DataManager
DatabaseHelper --> SQLite

note right of MainActivity
  Uses RecyclerView to display Ribots
end note

note right of MainPresenter
  Handles presentation logic
  Uses RxJava for async operations
end note

note right of DataManager
  Central data management
  Coordinates data retrieval and persistence
end note

note right of SyncService
  Performs background data synchronization
end note

note right of DatabaseHelper
  Manages database interactions using SqlBrite
end note

note right of RibotsService
  Defines Retrofit API interface
  for fetching data from Ribot API
end note

@enduml