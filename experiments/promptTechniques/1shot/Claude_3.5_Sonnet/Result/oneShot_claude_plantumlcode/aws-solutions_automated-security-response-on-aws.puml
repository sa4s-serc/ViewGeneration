@startuml aws-solutions_automated-security-response-on-aws

actor "Security Admin" as Admin
participant "AWS Security Hub" as SecurityHub
participant "EventBridge" as EventBridge
participant "Step Functions\nOrchestrator" as StepFunctions
participant "SSM Automation" as SSM
participant "Lambda Function" as Lambda
participant "AWS Services" as AWSServices
participant "CloudWatch" as CloudWatch
database "SQS Queue" as SQS

Admin -> SecurityHub : Trigger Custom Action
SecurityHub -> EventBridge : Emit Finding
EventBridge -> StepFunctions : Trigger Orchestrator

StepFunctions -> SQS : Enqueue Remediation Task
SQS -> SSM : Dequeue and Start Remediation

SSM -> Lambda : Execute Remediation Logic
Lambda -> AWSServices : Perform Remediation Actions
AWSServices --> Lambda : Action Results
Lambda -> SecurityHub : Update Finding Status

SSM -> CloudWatch : Log Remediation Outcome
SSM -> CloudWatch : Emit Metrics

alt Successful Remediation
    SSM -> EventBridge : Emit Success Event
    EventBridge -> Lambda : Create Ticket (Optional)
else Failed Remediation
    SSM -> EventBridge : Emit Failure Event
    EventBridge -> CloudWatch : Trigger Alarm
end

CloudWatch --> Admin : Alert on Failures

@enduml