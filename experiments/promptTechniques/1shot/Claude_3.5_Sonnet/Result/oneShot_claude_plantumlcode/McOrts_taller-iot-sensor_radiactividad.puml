@startuml McOrts_taller-iot-sensor_radiactividad

actor "User" as user
participant "ESP8266\n(WEMOS D1 mini Pro)" as esp8266
participant "Geiger Counter\nModule" as geiger
participant "MQTT Broker" as mqtt
participant "Node-RED" as nodered
participant "GMC.MAP" as gmcmap

user -> esp8266 : Power on
activate esp8266

esp8266 -> esp8266 : Read settings.h

esp8266 -> esp8266 : Connect to Wi-Fi

loop Every pulse
    geiger -> esp8266 : Radiation pulse
    esp8266 -> esp8266 : Increment count
end

loop Every minute
    esp8266 -> esp8266 : Calculate CPM
    esp8266 -> mqtt : Publish CPM data
    activate mqtt
    mqtt -> nodered : Forward CPM data
    activate nodered
    nodered -> gmcmap : Send data to GMC.MAP
    activate gmcmap
    gmcmap -> gmcmap : Update map
    deactivate gmcmap
    deactivate nodered
    deactivate mqtt
end

user -> mqtt : Send LED control command
activate mqtt
mqtt -> esp8266 : Forward LED command
esp8266 -> esp8266 : Control LED

deactivate mqtt

@enduml