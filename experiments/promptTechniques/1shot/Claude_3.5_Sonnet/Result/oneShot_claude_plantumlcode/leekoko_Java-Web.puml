@startuml leekoko_Java-Web

actor User
participant "Web Browser" as Browser
participant "Servlet Container" as Container
participant "Spring Boot App" as SpringBoot
participant "Dubbo Service" as Dubbo
database "Database" as DB
participant "Redis Cache" as Redis
participant "External API" as API

User -> Browser: Interact with web application
Browser -> Container: HTTP Request

alt Java Web Application
    Container -> Container: Process request through filters
    Container -> Container: Invoke appropriate servlet
    Container -> DB: Query data
    Container -> Redis: Cache data
    Container -> API: Make external API call (e.g. Baidu Translate)
    Container --> Browser: Return response
else Spring Boot Application
    Container -> SpringBoot: Forward request
    SpringBoot -> SpringBoot: Process through DispatcherServlet
    SpringBoot -> SpringBoot: Handle request in Controller
    SpringBoot -> DB: Perform database operations
    SpringBoot -> Redis: Cache/Retrieve data
    SpringBoot --> Browser: Return response
else Dubbo RPC
    Container -> Dubbo: Invoke remote service
    Dubbo -> Dubbo: Load balance request
    Dubbo -> Dubbo: Serialize/Deserialize data
    Dubbo -> DB: Perform database operations
    Dubbo --> Container: Return result
    Container --> Browser: Return response
end

Browser -> User: Display result

@enduml