@startuml Connor1996_Pokemon

skinparam component {
  BackgroundColor<<GUI>> LightBlue
  BackgroundColor<<Logic>> LightGreen
  BackgroundColor<<Data>> LightYellow
  BackgroundColor<<Communication>> LightPink
}

package "Client" {
  [Qt GUI Components]<<GUI>>
  [Pokemon Classes]<<Logic>>
  [PokemonFactory]<<Logic>>
  [Client Socket]<<Communication>>
  [ORM (ormlite)]<<Data>>
}

package "Server" {
  [Server Socket]<<Communication>>
  [Dispatcher]<<Logic>>
  [Multi-threading]<<Logic>>
}

database "SQLite Database" {
  [User Data]
  [Pokemon Info]
  [Game State]
}

[Qt GUI Components] --> [Pokemon Classes]
[Qt GUI Components] --> [PokemonFactory]
[Pokemon Classes] --> [ORM (ormlite)]
[Client Socket] --> [Server Socket] : JSON
[Server Socket] --> [Dispatcher]
[Dispatcher] --> [Multi-threading]
[ORM (ormlite)] --> [SQLite Database]

@enduml