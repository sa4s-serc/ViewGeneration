@startuml leopardslab_gocloud

skinparam component {
  BackgroundColor<<interface>> LightSkyBlue
  BackgroundColor<<provider>> LightGreen
  BackgroundColor<<service>> LightYellow
}

[Gocloud Interface] <<interface>> as GI
[CloudProvider Factory] as CPF

package "Cloud Providers" {
  [AWS Provider] <<provider>>
  [Google Cloud Provider] <<provider>>
  [DigitalOcean Provider] <<provider>>
  [Alibaba Cloud Provider] <<provider>>
  [Azure Provider] <<provider>>
  [OpenStack Provider] <<provider>>
  [Vultr Provider] <<provider>>
  [Rackspace Provider] <<provider>>
}

package "Cloud Services" {
  [Compute Service] <<service>>
  [Storage Service] <<service>>
  [Container Service] <<service>>
  [DNS Service] <<service>>
  [Load Balancer Service] <<service>>
  [Serverless Service] <<service>>
  [Database Service] <<service>>
  [Machine Learning Service] <<service>>
  [Analytics Service] <<service>>
  [Notification Service] <<service>>
  [Stream Processing Service] <<service>>
}

GI -- CPF
CPF --> [AWS Provider]
CPF --> [Google Cloud Provider]
CPF --> [DigitalOcean Provider]
CPF --> [Alibaba Cloud Provider]
CPF --> [Azure Provider]
CPF --> [OpenStack Provider]
CPF --> [Vultr Provider]
CPF --> [Rackspace Provider]

[AWS Provider] --> [Compute Service]
[AWS Provider] --> [Storage Service]
[AWS Provider] --> [Container Service]
[AWS Provider] --> [DNS Service]
[AWS Provider] --> [Load Balancer Service]
[AWS Provider] --> [Serverless Service]
[AWS Provider] --> [Database Service]
[AWS Provider] --> [Machine Learning Service]
[AWS Provider] --> [Analytics Service]
[AWS Provider] --> [Notification Service]
[AWS Provider] --> [Stream Processing Service]

[Google Cloud Provider] --> [Compute Service]
[Google Cloud Provider] --> [Storage Service]
[Google Cloud Provider] --> [Container Service]
[Google Cloud Provider] --> [DNS Service]
[Google Cloud Provider] --> [Load Balancer Service]
[Google Cloud Provider] --> [Serverless Service]
[Google Cloud Provider] --> [Database Service]
[Google Cloud Provider] --> [Machine Learning Service]
[Google Cloud Provider] --> [Analytics Service]
[Google Cloud Provider] --> [Notification Service]
[Google Cloud Provider] --> [Stream Processing Service]

@enduml