@startuml YW-Ma_Algorithms-Visualizer

actor User
participant "React Frontend" as Frontend
participant "EventProxy" as EventProxy
participant "Node.js Backend" as Backend
participant "C++ Executables" as CPP
database "MySQL Database" as DB

User -> Frontend : Interacts with UI
Frontend -> Backend : Request algorithm execution
Backend -> DB : Check user authentication
DB --> Backend : Authentication result

alt Authentication successful
    Backend -> CPP : Execute algorithm
    CPP --> Backend : Algorithm results
    Backend -> DB : Store algorithm state and steps
    Backend --> Frontend : Send visualization data
    Frontend -> EventProxy : Publish animation events
    EventProxy -> Frontend : Notify components (GraphSVG, GraphTable)
    Frontend -> User : Display visualization
else Authentication failed
    Backend --> Frontend : Send error
    Frontend -> User : Display login screen
end

User -> Frontend : Interact with visualization
Frontend -> EventProxy : Publish interaction events
EventProxy -> Frontend : Update components

User -> Frontend : Request report
Frontend -> Backend : Fetch report data
Backend -> DB : Retrieve report data
DB --> Backend : Report data
Backend --> Frontend : Send report data
Frontend -> User : Display report

@enduml