@startuml philipplackner_IvyWallet-PL_Version

skinparam componentStyle uml2

actor User

component "UI Layer" {
  [HomeViewModel]
  [AmountModalWithAccounts]
  [CategoryPickerModal]
}

component "Domain Layer" {
  [TrnsFlow]
  [WriteTrnsAct]
  [WriteAccountsAct]
  [SyncAct]
  [BackupDataAct]
  [ImportBackupDataAct]
  [RatesStateFlow]
  [FormulaFlow]
}

component "Data Layer" {
  [Repository]
  database "Local Database"
  [RemoteBackupSource]
}

User -> [HomeViewModel] : Interacts
[HomeViewModel] --> [TrnsFlow] : Retrieves transactions
[HomeViewModel] --> [RatesStateFlow] : Gets exchange rates
[HomeViewModel] --> [FormulaFlow] : Executes formulas

[AmountModalWithAccounts] --> [WriteAccountsAct] : Manages accounts
[CategoryPickerModal] --> [WriteTrnsAct] : Creates/Edits transactions

[TrnsFlow] --> [Repository] : Fetches data
[WriteTrnsAct] --> [Repository] : Writes data
[WriteAccountsAct] --> [Repository] : Manages account data

[SyncAct] --> [RemoteBackupSource] : Syncs data
[BackupDataAct] --> [RemoteBackupSource] : Exports data
[ImportBackupDataAct] --> [RemoteBackupSource] : Imports data

[Repository] --> [Local Database] : Persists/Retrieves data

@enduml