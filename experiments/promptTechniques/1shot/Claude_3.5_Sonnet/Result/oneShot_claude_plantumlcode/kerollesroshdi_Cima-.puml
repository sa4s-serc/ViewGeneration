@startuml kerollesroshdi_Cima-

skinparam component {
  BackgroundColor<<UI>> LightSkyBlue
  BackgroundColor<<ViewModel>> LightGreen
  BackgroundColor<<Domain>> LightYellow
  BackgroundColor<<Data>> LightPink
}

package "App Layer" {
  [AppDelegate] <<UI>>
  [AppCoordinator] <<UI>>
  
  package "Scenes" {
    [NowPlayingVC] <<UI>>
    [TopRatedVC] <<UI>>
    [SearchVC] <<UI>>
    [MovieDetailsVC] <<UI>>
    [BrowseVM] <<ViewModel>>
    [SearchVM] <<ViewModel>>
    [MovieDetailsVM] <<ViewModel>>
  }
  
  package "Core" {
    [BaseViewController] <<UI>>
    [ViewModel] <<ViewModel>>
    [TextyTabBar] <<UI>>
    [StateView] <<UI>>
  }
}

package "Domain Layer" {
  [MoviesRepository] <<Domain>>
  [BrowseUseCase] <<Domain>>
  [SearchUseCase] <<Domain>>
  [MovieDetailsUseCase] <<Domain>>
  package "Entities" {
    [Movie] <<Domain>>
    [MovieDetails] <<Domain>>
    [Genre] <<Domain>>
    [AppError] <<Domain>>
    [Page] <<Domain>>
  }
}

package "Data Layer" {
  [RemoteMoviesDataSource] <<Data>>
  [MoviesService] <<Data>>
  [MoviesRepositoryImpl] <<Data>>
}

cloud "TMDB API" {
}

[AppDelegate] --> [AppCoordinator]
[AppCoordinator] --> [NowPlayingVC]
[AppCoordinator] --> [TopRatedVC]
[AppCoordinator] --> [SearchVC]
[AppCoordinator] --> [MovieDetailsVC]

[NowPlayingVC] --> [BrowseVM]
[TopRatedVC] --> [BrowseVM]
[SearchVC] --> [SearchVM]
[MovieDetailsVC] --> [MovieDetailsVM]

[BrowseVM] --> [BrowseUseCase]
[SearchVM] --> [SearchUseCase]
[MovieDetailsVM] --> [MovieDetailsUseCase]

[BrowseUseCase] --> [MoviesRepository]
[SearchUseCase] --> [MoviesRepository]
[MovieDetailsUseCase] --> [MoviesRepository]

[MoviesRepositoryImpl] ..|> [MoviesRepository]
[MoviesRepositoryImpl] --> [RemoteMoviesDataSource]
[RemoteMoviesDataSource] --> [MoviesService]
[MoviesService] --> [TMDB API]

@enduml