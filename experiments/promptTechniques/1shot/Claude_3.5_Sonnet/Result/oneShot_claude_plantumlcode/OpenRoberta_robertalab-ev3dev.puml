@startuml OpenRoberta_robertalab-ev3dev

skinparam component {
  BackgroundColor LightBlue
  BorderColor Black
  ArrowColor Black
}

[Open Roberta Lab Server] as Server
[EV3 Brick] as EV3 {
  [Brickman UI] as UI
  [Service] as Service
  [Connector] as Connector
  [AbortHandler] as AbortHandler
  [GfxMode] as GfxMode
  [Hal] as Hal
  [ev3dev] as ev3dev
}

Server <--> Connector : HTTP

UI <--> Service : DBus
Service --> Connector : manages
Service --> AbortHandler : manages
Service --> GfxMode : manages

Connector --> Hal : uses
AbortHandler --> Hal : monitors

Hal --> ev3dev : interacts

@enduml