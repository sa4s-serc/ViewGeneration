@startuml little-hands_webdbpress-2019-10-ddd

skinparam component {
  BackgroundColor<<Application>> #CCFFCC
  BackgroundColor<<Domain>> #FFFFCC
  BackgroundColor<<Infrastructure>> #CCCCFF
}

package "Application Layer" <<Application>> {
  [ScreeningApplicationServiceV1]
  [ScreeningApplicationServiceV2]
  [ScreeningApplicationServiceV3]
  [ScreeningApplicationServiceV4]
}

package "Domain Layer" <<Domain>> {
  [ScreeningV1]
  [ScreeningV2]
  [ScreeningV3]
  [ScreeningV4]
  [InterviewV1]
  [InterviewV2]
  [InterviewV3]
  [InterviewV4]
  [EmailAddress]
  [ScreeningId]
  [Interviews]
  [ScreeningStatusV1]
  [ScreeningStatusV2]
  [ScreeningStatusV3]
  [ScreeningStatusV4]
  [ScreeningStepResult]
}

package "Infrastructure Layer" <<Infrastructure>> {
  [ScreeningDao]
  [InterviewDao]
  [ScreeningRepository]
  [ScreeningJdbcRepository]
}

package "Shared Components" {
  [ApplicationException]
  [Const]
}

[DddSampleApplication] --> [ScreeningApplicationServiceV4]
[ScreeningApplicationServiceV4] --> [ScreeningV4]
[ScreeningApplicationServiceV4] --> [ScreeningRepository]
[ScreeningV4] --> [InterviewV4]
[ScreeningV4] --> [EmailAddress]
[ScreeningV4] --> [ScreeningId]
[ScreeningV4] --> [ScreeningStatusV4]
[ScreeningRepository] --> [ScreeningJdbcRepository]

@enduml