@startuml gabrielfarah_OpenHub

skinparam component {
  BackgroundColor<<crawler>> LightBlue
  BackgroundColor<<worker>> LightGreen
  BackgroundColor<<database>> LightYellow
  BackgroundColor<<queue>> LightPink
}

cloud "GitHub" as github

component "Crawler" <<crawler>> as crawler {
  [crawler.py]
  [github3.py]
}

queue "RabbitMQ" <<queue>> as rabbitmq

component "Worker" <<worker>> as worker {
  [manager.py]
  package "Analysis Modules" {
    [Security]
    [Testability]
    [Reusability]
    [Usability]
  }
}

database "MongoDB" <<database>> as mongodb

github --> crawler : Fetch repositories
crawler --> rabbitmq : Publish tasks
crawler --> mongodb : Store metadata
rabbitmq --> worker : Consume tasks
worker --> github : Download code
worker --> mongodb : Store analysis results

note right of crawler
  Crawls repositories
  Publishes analysis tasks
end note

note right of worker
  Performs analysis:
  - Security
  - Testability
  - Reusability
  - Usability
end note

note bottom of mongodb
  Stores:
  - Repository metadata
  - Analysis results
  - System state
end note

@enduml