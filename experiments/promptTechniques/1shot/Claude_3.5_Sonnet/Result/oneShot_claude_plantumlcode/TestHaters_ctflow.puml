@startuml TestHaters_ctflow

actor User
participant "VS Code" as VSCode
participant "CTFLOW Extension" as Extension
participant "React Webview UI" as WebviewUI
participant "Compiler" as Compiler
participant "Cypress" as Cypress
database "Firebase" as Firebase

User -> VSCode : Open VS Code
VSCode -> Extension : Load CTFLOW extension
Extension -> WebviewUI : Initialize React UI

User -> WebviewUI : Create test flow using drag-and-drop
WebviewUI -> WebviewUI : Update flow graph

User -> WebviewUI : Request compilation
WebviewUI -> Compiler : Send flow graph
Compiler -> Compiler : Traverse graph
Compiler -> Compiler : Generate Cypress code
Compiler --> WebviewUI : Return generated code

User -> WebviewUI : Execute test
WebviewUI -> Extension : Request test execution
Extension -> Cypress : Run generated test code
Cypress --> Extension : Return test results
Extension --> WebviewUI : Display test results

alt Real-time collaboration
    User -> WebviewUI : Modify test flow
    WebviewUI -> Firebase : Sync changes
    Firebase --> WebviewUI : Broadcast changes to other users
end

@enduml