@startuml boot2podman_machine

actor User
participant "CLI Commands" as CLI
participant "Libmachine" as Libmachine
participant "Driver" as Driver
participant "Provisioner" as Provisioner
participant "Host" as Host
participant "Network Components" as Network
database "Configuration Files" as Config

User -> CLI : Execute command
activate CLI

CLI -> Libmachine : Create/Manage VM
activate Libmachine

Libmachine -> Driver : Load driver plugin
activate Driver

Driver --> Libmachine : Driver loaded
deactivate Driver

Libmachine -> Host : Create/Load host
activate Host

Host -> Config : Read/Write configuration
activate Config
Config --> Host : Configuration data
deactivate Config

Host --> Libmachine : Host ready
deactivate Host

Libmachine -> Provisioner : Provision VM
activate Provisioner

Provisioner -> Driver : Execute commands via SSH
activate Driver
Driver --> Provisioner : Command results
deactivate Driver

Provisioner -> Network : Configure networking
activate Network
Network --> Provisioner : Network configured
deactivate Network

Provisioner --> Libmachine : VM provisioned
deactivate Provisioner

Libmachine --> CLI : Operation complete
deactivate Libmachine

CLI --> User : Display result
deactivate CLI

@enduml