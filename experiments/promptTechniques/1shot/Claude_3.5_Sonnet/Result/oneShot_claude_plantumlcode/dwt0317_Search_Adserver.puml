@startuml dwt0317_Search_Adserver

actor User
participant "Search Interface" as UI
participant "SearchServlet" as SearchServlet
participant "AdRetrieval" as AdRetrieval
participant "RewritingHandler" as RewritingHandler
participant "ESHandler" as ESHandler
participant "DBPool" as DBPool
participant "RankingService" as RankingService
participant "Elasticsearch" as Elasticsearch
database "MariaDB" as MariaDB

User -> UI: Enter search query
activate UI

UI -> SearchServlet: Submit query
activate SearchServlet

SearchServlet -> AdRetrieval: Process query
activate AdRetrieval

AdRetrieval -> RewritingHandler: Rewrite query
activate RewritingHandler
RewritingHandler --> AdRetrieval: Rewritten query
deactivate RewritingHandler

AdRetrieval -> ESHandler: Retrieve ad candidates
activate ESHandler
ESHandler -> Elasticsearch: Search for ads
Elasticsearch --> ESHandler: Ad candidates
ESHandler --> AdRetrieval: Ad candidates
deactivate ESHandler

AdRetrieval -> DBPool: Get ad details
activate DBPool
DBPool -> MariaDB: Query ad information
MariaDB --> DBPool: Ad details
DBPool --> AdRetrieval: Ad details
deactivate DBPool

AdRetrieval -> RankingService: Rank ads
activate RankingService
RankingService --> AdRetrieval: Ranked ads
deactivate RankingService

AdRetrieval -> DBPool: Update budgets
activate DBPool
DBPool -> MariaDB: Deduct impressions
MariaDB --> DBPool: Updated budgets
DBPool --> AdRetrieval: Confirmation
deactivate DBPool

AdRetrieval --> SearchServlet: Ranked ads
deactivate AdRetrieval

SearchServlet --> UI: Display ads
deactivate SearchServlet

UI --> User: Show search results and ads
deactivate UI

@enduml