@startuml ashavijit_Face-Find

actor User
participant "Django Frontend" as Frontend
participant "Django Views" as Views
participant "Django Models" as Models
participant "Azure Face API" as AzureAPI
database Database
participant "Email Service" as Email

User -> Frontend : Access application
Frontend -> Views : Request page

alt List Missing Persons
    Views -> Models : Fetch missing persons
    Models -> Database : Query
    Database --> Models : Return data
    Models --> Views : Return objects
    Views --> Frontend : Render list
    Frontend --> User : Display list
else Report New Person
    User -> Frontend : Submit report form
    Frontend -> Views : POST form data
    Views -> Models : Create new ReportedPerson
    Models -> Database : Insert record
    Views -> AzureAPI : Generate face ID
    AzureAPI --> Views : Return face ID
    Views -> Models : Update with face ID
    Models -> Database : Update record
    Views -> Models : Check for potential matches
    Models -> Database : Query for matches
    Database --> Models : Return potential matches
    alt Potential Match Found
        Views -> Email : Send notification
        Email -> User : Receive match notification
    end
    Views --> Frontend : Redirect to success page
    Frontend --> User : Display success message
else Update Missing Person
    User -> Frontend : Submit update form
    Frontend -> Views : POST updated data
    Views -> Models : Update MissingPerson
    Models -> Database : Update record
    Views --> Frontend : Redirect to detail page
    Frontend --> User : Display updated info
end

@enduml