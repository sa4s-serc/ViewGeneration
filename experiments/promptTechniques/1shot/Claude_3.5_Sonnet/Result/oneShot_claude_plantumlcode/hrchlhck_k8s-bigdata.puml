@startuml hrchlhck_k8s-bigdata

!define KUBERNETES #CCFFCC
!define DOCKER #CCCCFF
!define COMPONENT #FFFFCC

skinparam component {
    BackgroundColor<<KUBERNETES>> KUBERNETES
    BackgroundColor<<DOCKER>> DOCKER
    BackgroundColor<<COMPONENT>> COMPONENT
}

cloud "Kubernetes Cluster" <<KUBERNETES>> {
    component "NameNode Pod" <<KUBERNETES>> {
        [NameNode Container] <<DOCKER>> {
            [HiBench] <<COMPONENT>>
            [Hadoop NameNode] <<COMPONENT>>
            [Spark Master] <<COMPONENT>>
        }
    }
    
    component "ResourceManager Pod" <<KUBERNETES>> {
        [ResourceManager Container] <<DOCKER>> {
            [YARN ResourceManager] <<COMPONENT>>
        }
    }
    
    component "HistoryServer Pod" <<KUBERNETES>> {
        [HistoryServer Container] <<DOCKER>> {
            [YARN HistoryServer] <<COMPONENT>>
        }
    }
    
    component "DataNode Pod" <<KUBERNETES>> {
        [DataNode Container] <<DOCKER>> {
            [Hadoop DataNode] <<COMPONENT>>
        }
        [NodeManager Container] <<DOCKER>> {
            [YARN NodeManager] <<COMPONENT>>
        }
    }
}

cloud "Docker Hub" {
    [vpemfh7 Repository] <<DOCKER>>
}

[build.sh] --> [vpemfh7 Repository] : Builds and pushes images
[kubernetes/cluster.yml] --> [Kubernetes Cluster] : Defines deployment
[scripts/init-cluster.sh] --> [Kubernetes Cluster] : Deploys cluster
[scripts/run.sh] --> [HiBench] : Executes benchmarks

@enduml