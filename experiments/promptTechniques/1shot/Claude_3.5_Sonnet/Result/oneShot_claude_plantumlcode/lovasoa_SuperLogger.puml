@startuml lovasoa_SuperLogger

skinparam component {
  BackgroundColor<<agent>> #LightBlue
  BackgroundColor<<elk>> #LightGreen
}

component "Java Agent" <<agent>> as agent {
  [SystemInfo]
  [TCPServer]
}

component "Logstash" <<elk>> as logstash
component "Elasticsearch" <<elk>> as elasticsearch
component "Kibana" <<elk>> as kibana

agent --> logstash : TCP
logstash --> elasticsearch : JSON
elasticsearch --> kibana : Data Query

note bottom of agent
  Collects system info
  and sends via TCP
end note

note bottom of logstash
  Receives data,
  adds timestamp,
  forwards to Elasticsearch
end note

note bottom of elasticsearch
  Stores and indexes
  system information
end note

note bottom of kibana
  Visualizes data
  and creates dashboards
end note

@enduml