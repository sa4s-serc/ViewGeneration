@startuml llvm_torch-mlir

skinparam componentStyle uml2
skinparam linetype ortho

package "Frontends" {
  [PyTorch Model]
  [TorchScript]
  [FX Graph]
  [ONNX Model]
}

package "Torch-MLIR Core" {
  [Torch Dialect]
  [TMTensor Dialect]
  [TorchConversion Dialect]
  [Transformation Passes]
}

package "Backends" {
  [Linalg-on-Tensors]
  [TOSA]
  [StableHLO]
  [LTC (Lazy Tensor Core)]
}

package "Code Generation & Interop" {
  [TableGen]
  [Python Bindings]
  [C-API]
}

package "Testing & Validation" {
  [E2E Tests]
  [LIT Tests]
  [Unit Tests]
}

[PyTorch Model] --> [Torch Dialect]
[TorchScript] --> [Torch Dialect]
[FX Graph] --> [Torch Dialect]
[ONNX Model] --> [Torch Dialect]

[Torch Dialect] --> [Transformation Passes]
[TMTensor Dialect] --> [Transformation Passes]
[TorchConversion Dialect] --> [Transformation Passes]

[Transformation Passes] --> [Linalg-on-Tensors]
[Transformation Passes] --> [TOSA]
[Transformation Passes] --> [StableHLO]
[Transformation Passes] --> [LTC (Lazy Tensor Core)]

[TableGen] ..> [Torch Dialect] : generates
[TableGen] ..> [TMTensor Dialect] : generates
[TableGen] ..> [Transformation Passes] : generates

[Python Bindings] ..> [Torch Dialect] : interacts
[C-API] ..> [Torch-MLIR Core] : exposes

[E2E Tests] ..> [Torch-MLIR Core] : validates
[LIT Tests] ..> [Torch-MLIR Core] : validates
[Unit Tests] ..> [Transformation Passes] : validates

@enduml