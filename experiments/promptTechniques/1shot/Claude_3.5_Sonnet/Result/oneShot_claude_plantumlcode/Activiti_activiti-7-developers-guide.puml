@startuml
!define RECTANGLE class

skinparam class {
    BackgroundColor<<component>> LightBlue
    BackgroundColor<<infrastructure>> LightGreen
    BorderColor Black
    ArrowColor Black
}

rectangle "Kubernetes Cluster" as k8s {
    RECTANGLE "Helm Charts" <<infrastructure>>
    RECTANGLE "Jenkins X" <<infrastructure>>

    RECTANGLE "Activiti Cloud Runtime Bundle" <<component>>
    RECTANGLE "Activiti Cloud Query Service" <<component>>
    RECTANGLE "Activiti Cloud Audit Service" <<component>>
    RECTANGLE "Activiti Cloud Notification Service" <<component>>
    RECTANGLE "Activiti Cloud Connectors" <<component>>
    RECTANGLE "Gateway" <<component>>
    RECTANGLE "Identity Management / SSO (Keycloak)" <<component>>
    RECTANGLE "BPMN Modeling Application" <<component>>
}

RECTANGLE "Activiti Core" <<component>>
RECTANGLE "Spring Cloud Stream" <<infrastructure>>
RECTANGLE "Spring Cloud Kubernetes" <<infrastructure>>
RECTANGLE "Spring Cloud Gateway" <<infrastructure>>

"Helm Charts" -[hidden]-> "Jenkins X"
"Jenkins X" --> k8s : deploys to

"Activiti Cloud Runtime Bundle" --> "Activiti Core" : uses
"Activiti Cloud Runtime Bundle" --> "Spring Cloud Stream" : uses
"Activiti Cloud Runtime Bundle" --> "Spring Cloud Kubernetes" : uses

"Gateway" --> "Spring Cloud Gateway" : uses

"Activiti Cloud Connectors" --> "Spring Cloud Stream" : uses

note bottom of k8s
  Deployment focused on Kubernetes
  using Helm Charts and Jenkins X
  for CI/CD and GitOps
end note

@enduml