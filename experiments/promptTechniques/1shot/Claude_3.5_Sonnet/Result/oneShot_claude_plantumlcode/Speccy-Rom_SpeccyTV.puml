@startuml Speccy-Rom_SpeccyTV

skinparam componentStyle uml2

actor User
participant "movies_auth" as Auth
participant "movies_async_api" as API
participant "movies_streaming_converter" as Converter
participant "movies_streaming_etl" as ETL
participant "movies_ugc" as UGC
participant "movies_billing" as Billing
database "PostgreSQL" as DB
database "Elasticsearch" as ES
database "Redis" as Redis
queue "Kafka" as Kafka
database "ClickHouse" as CH
database "MinIO" as MinIO

User -> Auth : Authenticate
activate Auth
Auth --> User : JWT Token
deactivate Auth

User -> API : Request Content
activate API
API -> ES : Search Content
ES --> API : Content Metadata
API -> Redis : Check Cache
alt Cache Hit
    Redis --> API : Cached Content
else Cache Miss
    API -> DB : Fetch Content
    DB --> API : Content Data
    API -> Redis : Cache Content
end
API --> User : Stream Content
deactivate API

User -> UGC : Generate Activity
activate UGC
UGC -> Kafka : Publish Event
Kafka -> CH : Store Event
deactivate UGC

User -> Billing : Subscribe/Pay
activate Billing
Billing -> DB : Update Subscription
DB --> Billing : Confirmation
Billing --> User : Payment Confirmation
deactivate Billing

loop Periodic ETL
    ETL -> MinIO : Fetch Raw Videos
    MinIO --> ETL : Raw Video Files
    ETL -> Converter : Convert Video
    Converter --> ETL : Converted Videos
    ETL -> MinIO : Store Converted Videos
end

@enduml