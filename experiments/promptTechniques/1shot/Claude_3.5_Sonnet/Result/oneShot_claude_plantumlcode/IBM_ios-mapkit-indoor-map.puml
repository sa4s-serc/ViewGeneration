@startuml IBM_ios-mapkit-indoor-map

actor User
participant "iOS App" as App
participant "ViewController" as VC
participant "FloorplanOverlay" as FO
participant "FloorplanOverlayRenderer" as FOR
participant "CoordinateConverter" as CC
participant "VisibleMapRegionDelegate" as VMRD
participant "Backend Server" as Server
database MongoDB

User -> App : Open app
activate App

App -> VC : Initialize
activate VC

VC -> Server : GET /api/pages
activate Server
Server -> MongoDB : Query pages
MongoDB --> Server : Return pages data
Server --> VC : Return pages data
deactivate Server

VC -> FO : Create overlay
activate FO
FO -> CC : Initialize converter
activate CC
CC --> FO : Return converter
deactivate CC
FO --> VC : Return overlay
deactivate FO

VC -> FOR : Create renderer
activate FOR
FOR --> VC : Return renderer
deactivate FOR

VC -> VMRD : Set delegate
activate VMRD

VC -> Server : GET /api/events
activate Server
Server -> MongoDB : Query events
MongoDB --> Server : Return events data
Server --> VC : Return events data
deactivate Server

VC -> VC : Generate heatmap

VC -> App : Display map with heatmap
deactivate VC

User -> App : Interact with map
App -> VMRD : Handle map region changes
VMRD -> VC : Update visible region
VC -> App : Refresh display

User -> App : Trigger event
App -> VC : Handle event
VC -> Server : POST /api/triggers
activate Server
Server -> MongoDB : Store trigger
MongoDB --> Server : Confirm storage
Server --> VC : Confirm trigger recorded
deactivate Server

VC -> VC : Update heatmap
VC -> App : Refresh display

deactivate VMRD
deactivate App

@enduml