@startuml
skinparam component {
  BackgroundColor<<lab>> #FFEBCD
  BackgroundColor<<script>> #E0FFFF
  BackgroundColor<<config>> #98FB98
}

package "Instana Hands-on Labs" {
  [README.md] as readme

  package "Lab Instructions" {
    component "Part 1: Installation" as part1 <<lab>>
    component "Part 2: Core Functionality" as part2 <<lab>>
    component "Part 3: Advanced Topics" as part3 <<lab>>
  }

  package "Scripts" {
    component "bootstrap-k8s.sh" as bootstrap <<script>>
    component "prepare-join-k8s.sh" as prepare <<script>>
    component "utils.sh" as utils <<script>>
    component "rhel.sh" as rhel <<script>>
    component "ubuntu.sh" as ubuntu <<script>>
  }

  package "Kubernetes Manifests" {
    component "Local Path Provisioner" as provisioner <<config>>
  }

  package "Extra" {
    component "Robot Shop on Docker" as robotshop <<lab>>
  }

  package "Preparation" {
    component "Manage-to Host Setup" as manageto <<lab>>
  }

  readme --> part1
  readme --> part2
  readme --> part3

  part1 ..> bootstrap : uses
  part1 ..> prepare : uses
  part2 ..> utils : uses
  part3 ..> utils : uses

  bootstrap --> provisioner : deploys
  prepare --> provisioner : configures

  part2 ..> rhel : configures
  part2 ..> ubuntu : configures

  robotshop ..> utils : uses
}

cloud "Deployment Targets" {
  [Kubernetes Cluster] as k8s
  [Virtual Machines] as vm
  [Docker Environment] as docker
}

bootstrap --> k8s : sets up
prepare --> k8s : configures
part1 --> vm : installs on
part2 --> k8s : monitors
part2 --> vm : monitors
part3 --> k8s : advanced monitoring
robotshop --> docker : deploys to
@enduml