@startuml mendhak_gpslogger

skinparam component {
  BackgroundColor<<UI>> #DDEBF7
  BackgroundColor<<Core>> #E2F0D9
  BackgroundColor<<Data>> #FFF2CC
  BackgroundColor<<Integration>> #FCE4D6
}

package "GPSLogger" {
  [User Interface] as UI <<UI>>
  [GPS Logging Service] as GpsService <<Core>>
  [File Loggers] as FileLoggers <<Data>>
  [Data Uploaders] as Uploaders <<Integration>>
  [Preference Helper] as PrefHelper <<Core>>
  [Event Bus] as EventBus <<Core>>
  
  component "External Services" as ExternalServices {
    [OpenStreetMap]
    [Google Drive]
    [Dropbox]
    [SFTP/FTP]
    [OwnCloud]
    [Email]
    [Custom URLs]
  }
}

UI --> GpsService : Uses
UI --> PrefHelper : Configures
GpsService --> FileLoggers : Writes to
GpsService --> Uploaders : Triggers
Uploaders --> ExternalServices : Uploads to
PrefHelper --> GpsService : Configures
PrefHelper --> FileLoggers : Configures
PrefHelper --> Uploaders : Configures
EventBus --> UI : Notifies
EventBus --> GpsService : Communicates
EventBus --> Uploaders : Notifies

note right of ExternalServices
  Connectivity-focused
  integration points
end note

@enduml