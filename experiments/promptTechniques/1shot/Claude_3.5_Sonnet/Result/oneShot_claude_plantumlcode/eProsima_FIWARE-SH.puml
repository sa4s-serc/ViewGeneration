@startuml eProsima_FIWARE-SH

actor "Integration Service" as IS
participant "SystemHandle" as SH
participant "Publisher" as PUB
participant "Subscriber" as SUB
participant "NGSIV2Connector" as CONN
participant "Listener" as LIS
actor "FIWARE Context Broker" as FCB

IS -> SH : configure()
activate SH

SH -> CONN : create
activate CONN

SH -> LIS : create
activate LIS

IS -> SH : create_publisher()
SH -> PUB : create
activate PUB

IS -> SH : create_subscriber()
SH -> SUB : create
activate SUB

IS -> PUB : write(data)
PUB -> CONN : publish_entity()
CONN -> FCB : HTTP POST/PATCH

FCB -> LIS : send notification
LIS -> CONN : on_data_available()
CONN -> SUB : on_data_available()
SUB -> IS : data_callback()

@enduml