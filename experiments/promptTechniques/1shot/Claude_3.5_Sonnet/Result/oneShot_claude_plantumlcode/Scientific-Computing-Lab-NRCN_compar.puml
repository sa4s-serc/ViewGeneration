@startuml

skinparam linetype ortho

actor User

participant "ComPar GUI" as GUI
participant "Compar Facade" as Facade
participant "Compiler Factory" as CompilerFactory
participant "Parallelizer" as Parallelizer
participant "Parameter Generator" as ParamGen
participant "Code Instrumentor" as Instrumentor
participant "Runtime Analyzer" as Analyzer
participant "Slurm Job Manager" as Slurm
participant "Output Validator" as Validator
participant "MongoDB" as DB

User -> GUI: Configure project
GUI -> Facade: Initialize project
Facade -> CompilerFactory: Create compiler instance
Facade -> Parallelizer: Select parallelization tool
Facade -> ParamGen: Generate parameter combinations
Facade -> Instrumentor: Instrument code
Facade -> Slurm: Submit jobs
Slurm -> Analyzer: Collect runtime data
Analyzer -> Facade: Return performance results
Facade -> Validator: Validate output
Facade -> DB: Store results
Facade -> GUI: Update results
GUI -> User: Display results

@enduml