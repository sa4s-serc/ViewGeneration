@startuml gcba-iris_iris

actor User
participant CLI
participant "Iris Framework" as Iris
participant Dispatcher
participant "Thread Pool" as ThreadPool
participant Dock
participant Handler
participant Hook
database "Configuration Files" as Config

User -> CLI: Execute command
CLI -> Iris: Initialize framework
Iris -> Config: Load configuration
Config --> Iris: Configuration data
Iris -> Iris: Validate configuration

Iris -> Dispatcher: Create and initialize
Dispatcher -> ThreadPool: Initialize

loop For each configured flow
    Iris -> Dock: Initialize and register
    Iris -> Handler: Initialize and register
    Iris -> Hook: Initialize and register (if any)
end

User -> CLI: Start data processing
CLI -> Iris: Start processing flows
Iris -> Dispatcher: Start processing

loop For each incoming message
    Dock -> Dispatcher: Receive message
    Dispatcher -> ThreadPool: Assign to available thread
    ThreadPool -> Hook: Execute input hook (if any)
    ThreadPool -> Handler: Process message
    ThreadPool -> Hook: Execute output hook (if any)
    ThreadPool -> Dispatcher: Return result
    Dispatcher -> Dock: Send response
end

@enduml