@startuml ParaStation_psmpi

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<external>> LightGreen
  BackgroundColor<<communication>> LightPink
  BackgroundColor<<testing>> LightYellow
}

package "ParaStation MPI (PSMPI)" {
  [MPICH] <<core>>
  [pscom] <<communication>>
  [UCG] <<core>> as "Collectives Framework (UCG)"
  [ROMIO] <<core>>
  [Yaksa] <<core>>
  
  package "Process Management" {
    [Hydra] <<core>>
    [psmgmt] <<core>> as "ParaStation Management"
    [PMIx] <<external>>
  }
  
  package "Communication Modules" {
    [TCP] <<communication>>
    [RDMA] <<communication>>
    [Shared Memory] <<communication>>
    [CUDA-aware] <<communication>>
  }
  
  package "Optimizations" {
    [Multi-NIC Support] <<core>>
    [Data Sieving] <<core>>
    [Zero Copy] <<core>>
    [DMA] <<core>>
  }
  
  package "External Libraries" {
    [HCOLL] <<external>>
    [HWLOC] <<external>>
    [UCX] <<external>>
    [RoCE] <<external>>
  }
  
  package "Testing" {
    [MPICH Test Suite] <<testing>>
    [Jenkins CI/CD] <<testing>>
  }
}

[MPICH] --> [pscom] : uses
[MPICH] --> [UCG] : uses
[MPICH] --> [ROMIO] : integrates
[MPICH] --> [Yaksa] : uses

[pscom] --> [TCP]
[pscom] --> [RDMA]
[pscom] --> [Shared Memory]
[pscom] --> [CUDA-aware]

[MPICH] --> [Hydra] : uses
[MPICH] --> [psmgmt] : uses
[MPICH] --> [PMIx] : uses

[MPICH] --> [HCOLL] : optional
[MPICH] --> [HWLOC] : optional
[MPICH] --> [UCX] : uses
[MPICH] --> [RoCE] : uses

[MPICH] --> [Multi-NIC Support] : implements
[MPICH] --> [Data Sieving] : implements
[MPICH] --> [Zero Copy] : implements
[MPICH] --> [DMA] : implements

[MPICH] --> [MPICH Test Suite] : validated by
[MPICH Test Suite] --> [Jenkins CI/CD] : integrated with

@enduml