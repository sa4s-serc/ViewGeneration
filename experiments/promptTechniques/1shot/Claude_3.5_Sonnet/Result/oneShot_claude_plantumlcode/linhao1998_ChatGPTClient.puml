@startuml linhao1998_ChatGPTClient

skinparam component {
  BackgroundColor<<UI>> LightBlue
  BackgroundColor<<ViewModel>> LightGreen
  BackgroundColor<<Data>> LightYellow
  BackgroundColor<<Util>> LightGray
}

package "UI" {
  [ChatActivity] <<UI>>
  [SettingsActivity] <<UI>>
  [ChatAdapter] <<UI>>
  [MsgAdapter] <<UI>>
}

package "ViewModel" {
  [ChatViewModel] <<ViewModel>>
  [ChatListViewModel] <<ViewModel>>
  [MsgListViewModel] <<ViewModel>>
}

package "Data" {
  [Repository] <<Data>>
  [AppDatabase] <<Data>>
  [ChatDao] <<Data>>
  [MsgDao] <<Data>>
  [Chat] <<Data>>
  [Msg] <<Data>>
}

package "Util" {
  [Markwon] <<Util>>
  [SharedPreferences] <<Util>>
}

[ChatActivity] --> [ChatViewModel]
[ChatActivity] --> [ChatAdapter]
[ChatActivity] --> [MsgAdapter]
[SettingsActivity] --> [SharedPreferences]

[ChatViewModel] --> [Repository]
[ChatListViewModel] --> [Repository]
[MsgListViewModel] --> [Repository]

[Repository] --> [AppDatabase]
[Repository] --> [ChatDao]
[Repository] --> [MsgDao]

[AppDatabase] --> [ChatDao]
[AppDatabase] --> [MsgDao]

[ChatDao] --> [Chat]
[MsgDao] --> [Msg]

[MsgAdapter] --> [Markwon]

[ChatGPTClientApplication] --> [SharedPreferences]

@enduml