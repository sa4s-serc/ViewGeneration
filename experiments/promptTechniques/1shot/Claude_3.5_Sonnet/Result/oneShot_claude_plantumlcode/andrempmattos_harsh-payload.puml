@startuml andrempmattos_harsh-payload

skinparam component {
  BackgroundColor<<FPGA>> LightYellow
  BackgroundColor<<OS>> LightBlue
  BackgroundColor<<Driver>> LightGreen
  BackgroundColor<<Application>> LightPink
}

component "SmartFusion2 FPGA" <<FPGA>> {
  [AXI/AHB Interconnect]
  [Memory Subsystem]
  [Clocking and Reset]
  [Peripheral Interfaces]
}

component "FreeRTOS" <<OS>> {
  [Task Scheduler]
  [Resource Management]
  [Interrupt Handling]
}

component "Drivers" <<Driver>> {
  [GPIO Driver]
  [UART Driver]
  [SPI Driver]
  [RTC Driver]
  [PDMA Driver]
  [Watchdog Timer Driver]
  [CAN Driver]
  [NVM Driver]
  [I2C Driver]
}

component "System Services" <<Driver>> {
  [Cryptography]
  [Random Number Generator]
  [Flash*Freeze]
  [Zeroization]
  [In-System Programming]
}

component "Application Layer" <<Application>> {
  [Experiment Algorithms]
  [OBC Communication (FSP)]
  [Latch-up Detection]
}

[Task Scheduler] --> [Resource Management]
[Task Scheduler] --> [Interrupt Handling]

[Experiment Algorithms] --> [Task Scheduler]
[OBC Communication (FSP)] --> [Task Scheduler]
[Latch-up Detection] --> [Task Scheduler]

[Experiment Algorithms] --> [GPIO Driver]
[Experiment Algorithms] --> [SPI Driver]
[OBC Communication (FSP)] --> [UART Driver]

[GPIO Driver] --> [AXI/AHB Interconnect]
[UART Driver] --> [AXI/AHB Interconnect]
[SPI Driver] --> [AXI/AHB Interconnect]
[RTC Driver] --> [AXI/AHB Interconnect]
[PDMA Driver] --> [AXI/AHB Interconnect]
[Watchdog Timer Driver] --> [AXI/AHB Interconnect]
[CAN Driver] --> [AXI/AHB Interconnect]
[NVM Driver] --> [AXI/AHB Interconnect]
[I2C Driver] --> [AXI/AHB Interconnect]

[AXI/AHB Interconnect] --> [Memory Subsystem]
[AXI/AHB Interconnect] --> [Peripheral Interfaces]
[Clocking and Reset] --> [AXI/AHB Interconnect]

@enduml