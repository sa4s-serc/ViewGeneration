@startuml clemgbld_blog_back_office

skinparam component {
  BackgroundColor<<UI>> #FFCCCB
  BackgroundColor<<Core>> #CCFFCC
  BackgroundColor<<Infrastructure>> #CCCCFF
}

[React Router] as Router
[Redux Store] as Store
[Local Storage] as LocalStorage

package "UI Components" <<UI>> {
  [App]
  [RichTextEditor]
  [Header]
  [Modal]
  [Button]
  [Input]
}

package "Core" <<Core>> {
  [Articles Slice]
  [Auth Slice]
  [Emails Slice]
  [Use Cases]
  [Entities]
}

package "Infrastructure" <<Infrastructure>> {
  [RestAuthService]
  [RestArticlesService]
  [RestEmailsService]
  [InMemoryServices]
}

cloud "External API" as API

App --> Router
App --> Store
App --> [Articles Slice]
App --> [Auth Slice]
App --> [Emails Slice]

Store --> [Articles Slice]
Store --> [Auth Slice]
Store --> [Emails Slice]

[Articles Slice] --> [Use Cases]
[Auth Slice] --> [Use Cases]
[Emails Slice] --> [Use Cases]

[Use Cases] --> [Entities]

[RestAuthService] --> API
[RestArticlesService] --> API
[RestEmailsService] --> API

[Articles Slice] ..> [RestArticlesService] : uses
[Auth Slice] ..> [RestAuthService] : uses
[Emails Slice] ..> [RestEmailsService] : uses

[Auth Slice] ..> LocalStorage : persists token

@enduml