@startuml mbotarro_unijobs

skinparam component {
  BackgroundColor<<Frontend>> LightSkyBlue
  BackgroundColor<<Backend>> PaleGreen
  BackgroundColor<<Database>> Khaki
  BackgroundColor<<Search>> LightCoral
}

package "Frontend (React Native)" <<Frontend>> {
  [App.js] as App
  [Navigation] as Nav
  [Screens] as Screens
  [Components] as Comp
  [Actions] as Actions
  [Constants] as Const
}

package "Backend (Go)" <<Backend>> {
  [HTTP Handlers] as Handlers
  [Use Cases] as UseCases
  [Data Access Layer] as DAL
  [Models] as Models
}

database "PostgreSQL" <<Database>> as DB
component "Elasticsearch" <<Search>> as ES

App --> Nav
Nav --> Screens
Screens --> Comp
Screens --> Actions
Comp --> Const
Actions --> Handlers : HTTP Requests

Handlers --> UseCases
UseCases --> DAL
DAL --> Models
DAL --> DB
UseCases --> ES

@enduml