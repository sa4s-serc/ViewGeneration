@startuml danielfm_prometheus-for-developers

actor Developer
participant "Sample Node.js App" as App
participant Prometheus
participant Alertmanager
participant Grafana

Developer -> App : Access application
activate App
App -> App : Generate metrics
App --> Developer : Serve content
deactivate App

loop Every scrape interval
    Prometheus -> App : Scrape metrics
    activate App
    App --> Prometheus : Return metrics
    deactivate App
    
    Prometheus -> Prometheus : Process and store metrics
    
    alt Alert rules triggered
        Prometheus -> Alertmanager : Send alert
        Alertmanager -> Alertmanager : Process alert (deduplicate, group, route)
    end
end

Developer -> Grafana : View dashboards
activate Grafana
Grafana -> Prometheus : Query metrics
Prometheus --> Grafana : Return data
Grafana --> Developer : Display visualizations
deactivate Grafana

@enduml