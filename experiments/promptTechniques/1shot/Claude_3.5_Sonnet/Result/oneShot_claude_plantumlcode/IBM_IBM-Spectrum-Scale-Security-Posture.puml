@startuml IBM_IBM-Spectrum-Scale-Security-Posture

actor "Cron Job" as cron
participant "cronjob.py" as cronjob
participant "fetch_security_posture_and_upload_to_ES.sh" as fetch
participant "security_posture.py" as collector
participant "split_json_for_kibana.py" as splitter
database "Spectrum Scale Cluster" as cluster
database "Elasticsearch" as es
participant "Kibana" as kibana

cron -> cronjob: Trigger periodically
activate cronjob

cronjob -> fetch: Execute
activate fetch

fetch -> cluster: SSH connection
fetch -> collector: Run on cluster
activate collector

collector -> cluster: Execute mm commands
cluster --> collector: Return security data
collector --> fetch: Return JSON data
deactivate collector

fetch -> splitter: Split JSON
activate splitter
splitter --> fetch: Return split JSON files
deactivate splitter

fetch -> es: Upload JSON data via curl
activate es

es --> fetch: Confirm upload
deactivate es

fetch --> cronjob: Complete process
deactivate fetch

cronjob --> cron: Finish execution
deactivate cronjob

es <- kibana: Query data
es --> kibana: Return visualizations

@enduml