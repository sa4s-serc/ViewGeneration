@startuml decentraland_catalyst

skinparam component {
  BackgroundColor<<external>> LightGray
  BorderColor<<external>> DarkGray
}

[Content Server] as CS
[The Graph] as TG <<external>>
[Blockchain] as BC <<external>>
[Third-Party Services] as TPS <<external>>
database "PostgreSQL" as DB
[Content Storage] as Storage
[Snapshots Fetcher] as SF

package "Content Server Components" {
  [Entity Retrieval] as ER
  [Content Deployment] as CD
  [Active Entity Management] as AEM
  [Synchronization] as Sync
  [Security & Validation] as SV
  [Collections API] as CA
  [Garbage Collection] as GC
  [API Endpoints] as API
  [Caching] as Cache
  [Rate Limiting] as RL
  [Metrics & Monitoring] as MM
  [Content Resizing] as CR
  [Migration] as Mig
}

CS -- ER
CS -- CD
CS -- AEM
CS -- Sync
CS -- SV
CS -- CA
CS -- GC
CS -- API
CS -- Cache
CS -- RL
CS -- MM
CS -- CR
CS -- Mig

CS -- DB
CS -- Storage
CS -- SF

SF -- TG
SF -- BC

CS -- TG
CS -- BC
CS -- TPS

@enduml