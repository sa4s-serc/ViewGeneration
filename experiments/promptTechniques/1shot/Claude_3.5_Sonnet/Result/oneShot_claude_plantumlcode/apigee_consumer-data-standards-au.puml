@startuml apigee_consumer-data-standards-au

!define RECTANGLE class

skinparam component {
  BackgroundColor<<API Proxy>> LightBlue
  BackgroundColor<<Shared Flow>> LightGreen
  BackgroundColor<<External>> LightYellow
}

rectangle "Apigee Edge" {
  package "API Proxies" {
    [CDS Banking APIs]<<API Proxy>>
    [OIDC Proxy]<<API Proxy>>
    [ConsentMgmtWithKVM]<<API Proxy>>
    [Dynamic Client Registration]<<API Proxy>>
    [Admin APIs]<<API Proxy>>
  }
  
  package "Shared Flows" {
    [Request Header Checking]<<Shared Flow>>
    [Pagination]<<Shared Flow>>
    [Traffic Threshold]<<Shared Flow>>
    [JWT Verification]<<Shared Flow>>
    [Request Parameter Validation]<<Shared Flow>>
  }
  
  [Key Value Maps (KVM)] as KVM
  [Mock Data] as MockData
  
  [Hosted Target: Mock OIDC Provider]
}

cloud "External Services" {
  [OIDC Provider]<<External>>
  [CDR Register]<<External>>
}

rectangle "Google Cloud Platform" {
  [App Engine: Metrics Service]
}

[CDS Banking APIs] --> [Request Header Checking]
[CDS Banking APIs] --> [Pagination]
[CDS Banking APIs] --> [Traffic Threshold]
[CDS Banking APIs] --> [JWT Verification]
[CDS Banking APIs] --> [Request Parameter Validation]
[CDS Banking APIs] --> MockData

[OIDC Proxy] --> [OIDC Provider]
[OIDC Proxy] --> KVM

[ConsentMgmtWithKVM] --> KVM

[Dynamic Client Registration] --> [CDR Register]

[Admin APIs] --> [App Engine: Metrics Service]

[App Engine: Metrics Service] --> [Apigee Analytics API]

@enduml