@startuml becloudway_serverless-data-pipeline

actor "Traffic API" as API
participant "RetrieveXMLTrafficData\nLambda" as RetrieveXML
participant "S3 Bucket\n(XML)" as S3XML
participant "TransformTrafficDataToJson\nLambda" as TransformJSON
participant "S3 Bucket\n(JSON)" as S3JSON
participant "PublishTrafficData\nLambda" as PublishData
participant "Kinesis Firehose" as Firehose
participant "Kinesis Stream" as Stream
participant "StreamProcessor\nLambda" as StreamProcessor
participant "Kinesis Data Analytics" as Analytics
participant "StoreAnalyticsResultsPerPoint\nLambda" as StoreAnalytics
participant "RealTimeAnalyticsPerPointTable\nDynamoDB" as AnalyticsDB
participant "AlertSaver\nLambda" as AlertSaver
participant "TrafficJamAlertsTable\nDynamoDB" as AlertsDB
participant "AlertSender\nLambda" as AlertSender
participant "Slack" as Slack
participant "PowerBiForwarder\nLambda" as PowerBIForwarder
participant "Power BI" as PowerBI

API -> RetrieveXML: Fetch XML data
RetrieveXML -> S3XML: Store XML
S3XML -> TransformJSON: Trigger
TransformJSON -> S3JSON: Store JSON
S3JSON -> PublishData: Trigger
PublishData -> Firehose: Publish events
PublishData -> Stream: Publish events
Stream -> StreamProcessor: Process
StreamProcessor -> Analytics: Filter data
Analytics -> StoreAnalytics: Process analytics
StoreAnalytics -> AnalyticsDB: Store results
AnalyticsDB -> AlertSaver: Stream changes
AlertSaver -> AlertsDB: Save alerts
AlertsDB -> AlertSender: Stream changes
AlertSender -> Slack: Send notifications
Stream -> PowerBIForwarder: Forward data
PowerBIForwarder -> PowerBI: Update dashboard

@enduml