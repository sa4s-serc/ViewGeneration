@startuml emreturgutce_stock-management

!define RECTANGLE class

skinparam component {
  BackgroundColor<<app>> LightBlue
  BackgroundColor<<db>> LightYellow
  BackgroundColor<<cache>> LightGreen
  BackgroundColor<<storage>> LightGray
}

rectangle "Stock Management Application" <<app>> {
  [API Controllers] as controllers
  [Middleware] as middleware
  [Database Queries] as queries
  [Utility Functions] as utils
  [Configuration] as config
}

database "PostgreSQL" <<db>> as postgres
database "Redis" <<cache>> as redis
storage "AWS S3" <<storage>> as s3

controllers --> middleware
controllers --> queries
controllers --> utils
controllers --> config

middleware --> redis : Session Management
queries --> postgres : CRUD Operations
utils --> s3 : Image Storage

@enduml