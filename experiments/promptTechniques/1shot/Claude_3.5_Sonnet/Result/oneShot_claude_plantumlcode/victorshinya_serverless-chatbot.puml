@startuml victorshinya_serverless-chatbot

actor User
participant "IBM Cloud Functions" as ICF
participant "Watson Assistant" as WA
database MongoDB

User -> ICF : Send message
activate ICF

ICF -> WA : Process message
activate WA
WA --> ICF : Return response
deactivate WA

ICF -> MongoDB : Store conversation data
activate MongoDB
MongoDB --> ICF : Confirm storage
deactivate MongoDB

ICF --> User : Deliver response
deactivate ICF

@enduml