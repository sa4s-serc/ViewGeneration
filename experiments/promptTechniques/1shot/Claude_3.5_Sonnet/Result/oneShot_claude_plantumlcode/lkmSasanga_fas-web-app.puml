@startuml lkmSasanga_fas-web-app

skinparam component {
  BackgroundColor<<UI>> LightBlue
  BackgroundColor<<API>> LightGreen
  BackgroundColor<<External>> LightYellow
}

actor User

component "React App" as ReactApp <<UI>> {
  [App.js]
  [Login]
  [InputControl]
  [RequestData]
  [Charts]
}

component "Backend API" as BackendAPI <<API>> {
  [Sentiment Analysis]
}

cloud "Firebase Hosting" as Firebase <<External>>
database "Heroku" as Heroku <<External>>

User -> ReactApp : Interacts
ReactApp -> Firebase : Deployed to
ReactApp --> BackendAPI : API Requests
BackendAPI -> Heroku : Hosted on

[App.js] --> [Login]
[App.js] --> [InputControl]
[InputControl] --> [RequestData]
[RequestData] --> [Charts]

note right of [RequestData]
  Fetches data from
  https://malindu-fas.herokuapp.com/sentiment
end note

@enduml