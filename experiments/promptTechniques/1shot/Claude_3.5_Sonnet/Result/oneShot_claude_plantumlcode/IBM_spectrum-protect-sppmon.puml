@startuml IBM_spectrum-protect-sppmon

skinparam componentStyle uml2

' Main components
component "SPPMon Core Engine" as SPPMon
component "SPPCheck" as SPPCheck
component "InfluxDB" as InfluxDB
component "Grafana" as Grafana
component "SPP Server" as SPPServer
component "vSnap/VADP/M365 Proxies" as RemoteSystems

' Connections and control flow
SPPMon --> SPPServer : REST API
SPPMon --> RemoteSystems : SSH
SPPMon --> InfluxDB : Store data
Grafana --> InfluxDB : Query data
SPPCheck --> SPPServer : REST API
SPPCheck --> RemoteSystems : SSH
SPPCheck --> InfluxDB : Query/Store data

' Subcomponents
component "REST API Client" as RESTClient
component "SSH Client" as SSHClient
component "InfluxDB Client" as InfluxClient
component "Data Collector" as DataCollector
component "Report Generator" as ReportGenerator
component "Predictor" as Predictor

' Connections for subcomponents
SPPMon ..> RESTClient
SPPMon ..> SSHClient
SPPMon ..> InfluxClient
SPPMon ..> DataCollector

SPPCheck ..> RESTClient
SPPCheck ..> SSHClient
SPPCheck ..> InfluxClient
SPPCheck ..> ReportGenerator
SPPCheck ..> Predictor

' Dynamic behavior
note right of SPPMon
  1. Collect data from SPP and remote systems
  2. Process and store data in InfluxDB
  3. Repeat at configured intervals
end note

note right of SPPCheck
  1. Verify system setup
  2. Predict resource consumption
  3. Generate PDF reports
end note

note bottom of Grafana
  Visualize data from InfluxDB
end note

@enduml