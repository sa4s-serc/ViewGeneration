@startuml turkcellcloud_jupyter-openshift

skinparam component {
  BackgroundColor<<OpenShift>> #FFCCCB
  BackgroundColor<<External>> #CCFFCC
}

package "OpenShift Cluster" <<OpenShift>> {
  component "JupyterHub Pod" {
    [JupyterHub]
    [KubeSpawner]
    [Idle Server Culler]
  }
  
  component "Jupyter Notebook Pods" {
    [Notebook Server 1]
    [Notebook Server 2]
    [Notebook Server N]
  }

  component "PostgreSQL Pod" {
    [PostgreSQL Database]
  }

  [ConfigMap]
  [Network Policies]
  [Persistent Volumes]
}

cloud "External Services" <<External>> {
  [Active Directory/LDAP]
}

[JupyterHub] --> [KubeSpawner] : manages
[JupyterHub] --> [Idle Server Culler] : uses
[JupyterHub] --> [ConfigMap] : reads config
[JupyterHub] --> [PostgreSQL Database] : stores state
[JupyterHub] --> [Active Directory/LDAP] : authenticates
[KubeSpawner] --> [Notebook Server 1] : spawns
[KubeSpawner] --> [Notebook Server 2] : spawns
[KubeSpawner] --> [Notebook Server N] : spawns
[Notebook Server 1] --> [Persistent Volumes] : stores data
[Notebook Server 2] --> [Persistent Volumes] : stores data
[Notebook Server N] --> [Persistent Volumes] : stores data
[Network Policies] --> [Notebook Server 1] : secures
[Network Policies] --> [Notebook Server 2] : secures
[Network Policies] --> [Notebook Server N] : secures

@enduml