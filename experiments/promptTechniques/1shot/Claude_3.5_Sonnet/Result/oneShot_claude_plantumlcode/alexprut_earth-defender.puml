@startuml alexprut_earth-defender

skinparam component {
  BackgroundColor<<client>> LightBlue
  BackgroundColor<<server>> LightGreen
}

cloud "Client (Browser)" {
  [Three.js] <<client>>
  [WebSocket Client] <<client>>
  component "Game Client" as GameClient <<client>> {
    [Game]
    [GameDOMHandler]
    [GameElements]
    [TextureLoader]
  }
}

cloud "Server (Erlang/OTP)" {
  component "Master Node" as MasterNode <<server>> {
    [WebSocket Handler]
    [Room Manager]
    [Player Manager]
  }
  
  component "Slave Node" as SlaveNode <<server>> {
    [Slave Handler]
  }
  
  [Monitor Mesh] <<server>>
}

database "Distributed State" as DistributedState

MasterNode -- SlaveNode : replication
MasterNode -- Monitor Mesh
SlaveNode -- Monitor Mesh

[WebSocket Client] <--> [WebSocket Handler] : WebSocket
GameClient --> [Three.js] : renders
[Game] --> [WebSocket Client] : uses
MasterNode --> DistributedState : manages
SlaveNode --> DistributedState : replicates

@enduml