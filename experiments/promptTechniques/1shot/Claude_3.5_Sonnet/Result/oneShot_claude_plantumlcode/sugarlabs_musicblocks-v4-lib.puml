@startuml

skinparam component {
  BackgroundColor<<syntax>> #FFECB3
  BackgroundColor<<execution>> #E1F5FE
  BackgroundColor<<library>> #E8F5E9
}

package "Visual Programming Environment Library" {
  
  component "Syntax Representation" <<syntax>> {
    [Element API]
    [Specification]
    [Warehouse]
    [Syntax Tree]
  }
  
  component "Execution Engine" <<execution>> {
    [Symbol Table]
    [Parser]
    [Interpreter]
    [Scheduler]
  }
  
  component "Library" <<library>> {
    [Values]
    [Boxes]
    [Math Operators]
    [Conditionals]
    [Loops]
    [Program Structures]
    [Miscellaneous]
  }
  
  [Element API] --> [Specification]
  [Specification] --> [Warehouse]
  [Warehouse] --> [Syntax Tree]
  
  [Syntax Tree] --> [Parser]
  [Parser] --> [Interpreter]
  [Interpreter] --> [Symbol Table]
  [Interpreter] --> [Scheduler]
  
  [Library] ..> [Element API] : uses
  [Library] ..> [Specification] : defines
  
  [Syntax Tree] ..> [Library] : composed of
}

@enduml