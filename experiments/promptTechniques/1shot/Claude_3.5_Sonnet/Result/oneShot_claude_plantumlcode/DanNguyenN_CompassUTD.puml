@startuml DanNguyenN_CompassUTD

skinparam component {
  BackgroundColor<<API>> LightBlue
  BackgroundColor<<Inference>> LightGreen
  BackgroundColor<<Tools>> LightYellow
  BackgroundColor<<Database>> LightGray
  BackgroundColor<<ExternalService>> LightPink
}

cloud "Google Cloud Run" {
  component "FastAPI Application" as FastAPI <<API>> {
    [main.py]
  }
  
  component "CompassUTD Inference" as Inference <<Inference>> {
    [inference.py]
    [CompassAgent]
    [CompassToolkit]
  }
  
  component "Tools" as Tools <<Tools>> {
    [SearchCourse]
    [SearchDegree]
    [SearchGeneral]
    [DefinitionLookup]
    [RateMyProfessorTool]
  }
  
  component "Web Scraping" as WebScraping <<Tools>> {
    [text_extractor.py]
  }
}

database "MongoDB" as MongoDB <<Database>>

cloud "External Services" {
  [Google PaLM 2 / Vertex AI] as PaLM2 <<ExternalService>>
  [RateMyProfessor API] as RMP <<ExternalService>>
  [UTD Websites] as UTDSites <<ExternalService>>
}

FastAPI --> Inference : Uses
Inference --> Tools : Orchestrates
Inference --> PaLM2 : Queries
Tools --> WebScraping : Uses
Tools --> RMP : Queries
Tools --> UTDSites : Scrapes
FastAPI --> MongoDB : Stores chat history
WebScraping --> UTDSites : Extracts content

@enduml