@startuml staples-sparx_Wonko

actor "SparX Services" as Services
participant "Kafka" as Kafka
participant "Wonko Core" as Core
participant "Kafka Consumer" as Consumer
participant "Alert Processor" as AlertProcessor
participant "Prometheus Exporter" as PrometheusExporter
participant "Web Server" as WebServer
participant "PagerDuty" as PagerDuty
actor "Prometheus" as Prometheus

Services -> Kafka : Publish events
activate Kafka

Core -> Consumer : Start consumer
activate Consumer

loop Event processing
    Consumer -> Kafka : Consume events
    Kafka --> Consumer : Event data
    Consumer -> AlertProcessor : Process event
    activate AlertProcessor
    
    alt Alert triggered
        AlertProcessor -> PagerDuty : Send alert
        activate PagerDuty
        PagerDuty --> AlertProcessor : Confirmation
        deactivate PagerDuty
    end
    
    AlertProcessor -> PrometheusExporter : Update metrics
    activate PrometheusExporter
    PrometheusExporter --> AlertProcessor : Confirmation
    deactivate PrometheusExporter
    
    deactivate AlertProcessor
end

Core -> WebServer : Start server
activate WebServer

Prometheus -> WebServer : Scrape metrics
WebServer -> PrometheusExporter : Get metrics
PrometheusExporter --> WebServer : Metrics data
WebServer --> Prometheus : Metrics response

@enduml