@startuml teamgram_teamgram-server

!define RECTANGLE class

skinparam component {
  BackgroundColor<<service>> LightBlue
  BackgroundColor<<storage>> LightYellow
  BackgroundColor<<messaging>> LightGreen
  BackgroundColor<<discovery>> LightPink
}

rectangle "Backend for Frontend (BFF)" as BFF

component "Message Service" as MSG <<service>>
component "Chat Service" as CHAT <<service>>
component "User Service" as USER <<service>>
component "AuthSession Service" as AUTH <<service>>
component "Media Service" as MEDIA <<service>>
component "Username Service" as USERNAME <<service>>
component "Dialog Service" as DIALOG <<service>>
component "Updates Service" as UPDATES <<service>>
component "IDGen Service" as IDGEN <<service>>

database "MySQL" as DB <<storage>>
database "Redis" as REDIS <<storage>>
database "MinIO" as MINIO <<storage>>

queue "Kafka" as KAFKA <<messaging>>

component "Etcd" as ETCD <<discovery>>

BFF -down-> MSG
BFF -down-> CHAT
BFF -down-> USER
BFF -down-> AUTH
BFF -down-> MEDIA
BFF -down-> USERNAME
BFF -down-> DIALOG
BFF -down-> UPDATES

MSG --> DB
CHAT --> DB
USER --> DB
AUTH --> DB
MEDIA --> DB
USERNAME --> DB
DIALOG --> DB
UPDATES --> DB
IDGEN --> DB

MSG --> REDIS
USER --> REDIS
AUTH --> REDIS
IDGEN --> REDIS

MEDIA --> MINIO

MSG --> KAFKA
UPDATES --> KAFKA

MSG ..> ETCD
CHAT ..> ETCD
USER ..> ETCD
AUTH ..> ETCD
MEDIA ..> ETCD
USERNAME ..> ETCD
DIALOG ..> ETCD
UPDATES ..> ETCD
IDGEN ..> ETCD

@enduml