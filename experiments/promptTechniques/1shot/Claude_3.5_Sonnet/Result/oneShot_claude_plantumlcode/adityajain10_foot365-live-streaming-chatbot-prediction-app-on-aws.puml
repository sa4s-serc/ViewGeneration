@startuml adityajain10_foot365-live-streaming-chatbot-prediction-app-on-aws

actor User
participant "Frontend (HTML/JS)" as Frontend
participant "API Gateway" as APIGateway
participant "Cognito" as Cognito
participant "Lambda Functions" as Lambda
participant "SQS" as SQS
participant "SNS" as SNS
participant "DynamoDB" as DynamoDB
participant "ElasticSearch" as ElasticSearch
participant "SageMaker" as SageMaker
participant "Lex" as Lex
participant "Kafka" as Kafka
participant "S3" as S3

User -> Frontend : Access application
Frontend -> Cognito : Authenticate
Cognito --> Frontend : Auth token

Frontend -> APIGateway : API request
APIGateway -> Lambda : Invoke function

alt Get Standings
    Lambda -> DynamoDB : Fetch standings
    DynamoDB --> Lambda : Return data
else Get Predictions
    Lambda -> SageMaker : Request prediction
    SageMaker --> Lambda : Return prediction
else Get Fixtures
    Lambda -> ElasticSearch : Query fixtures
    ElasticSearch --> Lambda : Return fixtures
else Get Live Scores
    Lambda -> DynamoDB : Fetch live scores
    DynamoDB --> Lambda : Return scores
else Chatbot Interaction
    Lambda -> Lex : Process user input
    Lex --> Lambda : Intent/response
    Lambda -> SQS : Queue request
    SQS -> Lambda : Dequeue for processing
    Lambda -> ElasticSearch : Fetch relevant data
    ElasticSearch --> Lambda : Return data
    Lambda -> SNS : Send SMS notification
end

Lambda --> APIGateway : Return response
APIGateway --> Frontend : API response
Frontend -> User : Display results

loop Live Score Updates
    Kafka -> DynamoDB : Stream live scores
end

S3 -> Lambda : Trigger scrapeMatchData
Lambda -> DynamoDB : Update match data

@enduml