}

package "Conceptual Explanations" {
  [File System Hierarchy] as fsh
  [User Types] as usertypes
  [Process Types] as processtypes
  [Signal Handling] as signals
}

package "Examples and References" {
  [Command Examples] as examples
  [Help Page References] as helpref
}

readme --> basic
