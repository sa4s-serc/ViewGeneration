@startuml krishnaprasadkv_Linux-Commands

skinparam component {
  BackgroundColor LightSkyBlue
  BorderColor Black
  ArrowColor Black
}

[README.md] as readme
[_config.yml] as config

package "Linux Command Tutorials" {
  [Basic Commands] as basic
  [Filter Commands] as filter
  [File Permissions] as permissions
  [Process Management] as process
  [User Administration] as useradmin
  [Group Administration] as groupadmin
  [File System Operations] as filesystem
