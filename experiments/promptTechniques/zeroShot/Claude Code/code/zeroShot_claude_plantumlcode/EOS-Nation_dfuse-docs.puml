@startuml
!define RECTANGLE class

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<api>> LightGreen
  BackgroundColor<<storage>> LightYellow
  BackgroundColor<<external>> LightGray
}

package "dfuse System" {

  package "API Layer" {
    [GraphQL API] <<api>> as graphql
    [Authentication Service] <<api>> as auth
    [API Gateway] <<api>> as gateway
  }

  package "Core Services" {
    [mindreader] <<core>> as mindreader
    [relayer] <<core>> as relayer
    [search] <<core>> as search
    [dgraphql] <<core>> as dgraphql
  }

  package "CLI Tools" {
    [dfuseeos CLI] as cli
  }

  package "Storage Layer" {
    database "BigTable" <<storage>> as bigtable
    database "TiKV" <<storage>> as tikv
    database "Badger" <<storage>> as badger
    database "Object Store" <<storage>> as objectstore
  }

  package "Data Abstraction" {
    [kvdb Abstraction] as kvdb
    [dstore Abstraction] as dstore
  }

  package "External Systems" {
    [nodeos Node] <<external>> as nodeos
    [EOSIO Blockchain] <<external>> as blockchain
  }

  package "Multi-Chain Support" {
    [EOS Mainnet] as eos
    [WAX] as wax
    [Kylin] as kylin
    [Jungle 4] as jungle
  }
}

package "Client Applications" {
  [Web Clients] as webclient
  [Mobile Apps] as mobile
  [Developer Tools] as devtools
}

' API Layer relationships
webclient --> gateway : HTTPS
mobile --> gateway : HTTPS
devtools --> gateway : HTTPS

gateway --> auth : JWT/API Key
gateway --> graphql : GraphQL Queries

graphql --> dgraphql : gRPC

' Core Services relationships
mindreader --> relayer : Block Data Stream
relayer --> search : Indexed Data
relayer --> dgraphql : Real-time Data

dgraphql --> search : Query Index

' CLI relationships
cli --> mindreader : Manage
cli --> relayer : Manage
cli --> search : Manage
cli --> dgraphql : Manage

' Storage relationships
kvdb --> bigtable : Store/Retrieve
kvdb --> tikv : Store/Retrieve
kvdb --> badger : Store/Retrieve

dstore --> objectstore : Store Artifacts

search --> kvdb : Index Storage
dgraphql --> kvdb : Data Access
relayer --> dstore : Block Files

' External integrations
mindreader --> nodeos : Deep-mind Data
nodeos --> blockchain : Sync
gateway --> nodeos : Proxy API Calls

' Multi-chain connections
blockchain <|-- eos
blockchain <|-- wax
blockchain <|-- kylin
blockchain <|-- jungle

' Interface definitions
interface "GraphQL over gRPC" as grpcif
interface "REST API" as restif
interface "WebSocket" as wsif
interface "Storage Interface" as storageif

gateway -up- restif
gateway -up- wsif
dgraphql -up- grpcif
kvdb -down- storageif

' Notes
note right of graphql
  - Single Queries
  - Real-time Subscriptions
  - Pagination Support
  - Fork Handling
end note

note right of mindreader
  Extracts raw blockchain
  data from nodeos with
  deep-mind patch
end note

note right of search
  Implements search query
  language for efficient
  blockchain data lookup
end note

note bottom of kvdb
  Adapter Pattern:
  Supports multiple
  database backends
end note

note bottom of auth
  - API Key Authentication
  - JWT Tokens
  - Rate Limiting
end note

@enduml
