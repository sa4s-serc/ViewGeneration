@startuml

skinparam component {
    BackgroundColor<<external>> LightGray
    BorderColor<<external>> DarkGray
    BackgroundColor<<crawler>> LightBlue
    BackgroundColor<<worker>> LightGreen
    BackgroundColor<<analysis>> LightYellow
}

package "OpenHub System" {

    [crawler.py] as Crawler <<crawler>>
    [GitHub API Client] as GitHubClient <<crawler>>
    [Crawler Config Loader] as CrawlerConfig <<crawler>>

    [RabbitMQ] as Queue <<external>>

    [manager.py] as Manager <<worker>>
    [Repository Downloader] as RepoDownloader <<worker>>
    [Worker Config Loader] as WorkerConfig <<worker>>

    package "Analysis Modules" {
        [Code Linter] as CodeLinter <<analysis>>
        [Basic Security] as BasicSecurity <<analysis>>
        [Cyclomatic Complexity] as CyclomaticComplexity <<analysis>>
        [Maintainability Index] as MaintainabilityIndex <<analysis>>
        [Coupling Analyzer] as CouplingAnalyzer <<analysis>>
        [Documentation Analysis] as DocAnalysis <<analysis>>
        [Popularity Index] as PopularityIndex <<analysis>>
    }

    [MongoDB] as Database <<external>>

    package "External Libraries" {
        [github3.py] as GitHub3 <<external>>
        [radon] as Radon <<external>>
        [pylint] as Pylint <<external>>
        [scikit-learn] as ScikitLearn <<external>>
    }

    [JSON Config Files] as ConfigFiles
}

Crawler --> Queue : publishes repository tasks
Crawler --> Database : stores repository metadata
Crawler --> GitHubClient : uses
GitHubClient --> GitHub3 : uses
CrawlerConfig --> ConfigFiles : reads
Crawler --> CrawlerConfig : uses

Queue --> Manager : consumes tasks
Manager --> RepoDownloader : downloads repository code
Manager --> Database : updates analysis results
WorkerConfig --> ConfigFiles : reads
Manager --> WorkerConfig : uses

Manager --> CodeLinter : invokes
Manager --> BasicSecurity : invokes
Manager --> CyclomaticComplexity : invokes
Manager --> MaintainabilityIndex : invokes
Manager --> CouplingAnalyzer : invokes
Manager --> DocAnalysis : invokes
Manager --> PopularityIndex : invokes

CodeLinter --> Pylint : uses
BasicSecurity --> Pylint : uses
CyclomaticComplexity --> Radon : uses
MaintainabilityIndex --> Radon : uses
DocAnalysis --> ScikitLearn : uses

CodeLinter --> Database : writes results
BasicSecurity --> Database : writes results
CyclomaticComplexity --> Database : writes results
MaintainabilityIndex --> Database : writes results
CouplingAnalyzer --> Database : writes results
DocAnalysis --> Database : writes results
PopularityIndex --> Database : writes results

note right of Queue
  Enables asynchronous
  task processing and
  decoupling of crawler
  and worker processes
end note

note bottom of CouplingAnalyzer
  Modular plugin-based architecture
  allows easy addition/modification
  of analysis routines
end note

note left of Database
  Stores repository metadata,
  analysis results, and
  system state information
end note

@enduml
