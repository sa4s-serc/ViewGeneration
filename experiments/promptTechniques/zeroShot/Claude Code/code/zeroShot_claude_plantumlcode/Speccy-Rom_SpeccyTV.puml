@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<external>> LightBlue
    BackgroundColor<<storage>> LightGreen
    BackgroundColor<<service>> LightYellow
    BackgroundColor<<processing>> LightCoral
}

title Streaming Service - Component Diagram (Data Flow Focus)

package "Client Layer" {
    [Web Client] as WebClient
    [Admin Client] as AdminClient
}

package "API Gateway Layer" {
    [movies_async_api] as AsyncAPI <<service>>
    [movies_auth] as Auth <<service>>
    [movies_billing] as Billing <<service>>
}

package "Content Management Layer" {
    [movies_admin] as Admin <<service>>
    [movies_streaming_admin] as StreamingAdmin <<service>>
}

package "Processing Layer" {
    [movies_streaming_etl] as ETL <<processing>>
    [movies_streaming_converter] as Converter <<processing>>
    [Apache Airflow] as Airflow <<processing>>
    [FFmpeg] as FFmpeg <<processing>>
}

package "User Generated Content Layer" {
    [movies_ugc] as UGC <<service>>
}

package "Data Storage Layer" {
    database "PostgreSQL" as PostgreSQL <<storage>>
    database "Elasticsearch" as Elasticsearch <<storage>>
    database "Redis Cache" as Redis <<storage>>
    database "ClickHouse" as ClickHouse <<storage>>
    storage "MinIO Object Storage" as MinIO <<storage>>
}

package "Message Queue Layer" {
    queue "RabbitMQ" as RabbitMQ
    queue "Kafka" as Kafka
}

package "External Services" {
    [Stripe API] as Stripe <<external>>
    [Google OAuth] as GoogleOAuth <<external>>
}

' Client to API Gateway
WebClient --> AsyncAPI : API Requests\n(movies, genres, persons)
WebClient --> Auth : Authentication Requests
WebClient --> Billing : Subscription/Payment
WebClient --> UGC : User Activity Events
AdminClient --> Admin : Content Management
AdminClient --> StreamingAdmin : Streaming Management

' Authentication Flow
Auth --> PostgreSQL : User Credentials\n(read/write)
Auth --> GoogleOAuth : OAuth Flow
Auth --> Redis : Session/Token Cache

' Billing Flow
Billing --> PostgreSQL : Subscription Data\n(read/write)
Billing --> Stripe : Payment Processing
Billing --> Redis : Billing Cache

' Async API Data Flow
AsyncAPI --> Elasticsearch : Search Queries\n(movies, genres, persons)
AsyncAPI --> Redis : Cache Read/Write
Elasticsearch --> PostgreSQL : Data Sync

' Content Management Flow
Admin --> PostgreSQL : Content Metadata\n(write)
StreamingAdmin --> PostgreSQL : Streaming Config\n(write)
PostgreSQL --> Elasticsearch : Index Content

' ETL Pipeline Flow
ETL --> Airflow : DAG Orchestration
Airflow --> Converter : Trigger Conversion Jobs
Converter --> MinIO : Read Raw Videos
Converter --> FFmpeg : Video Conversion
FFmpeg --> MinIO : Write Converted Videos\n(multiple resolutions)
Converter --> RabbitMQ : Job Status Messages
RabbitMQ --> ETL : Job Completion Events
ETL --> PostgreSQL : Update Metadata

' UGC Flow
UGC --> Kafka : User Events\n(views, ratings, bookmarks)
Kafka --> ClickHouse : Event Stream Processing
UGC --> ClickHouse : Analytics Queries
ClickHouse --> AsyncAPI : Recommendation Data

' Streaming Data Flow
AsyncAPI --> MinIO : Stream Video Content
MinIO --> WebClient : Video Delivery

' Cache Invalidation Flow
Admin --> Redis : Invalidate Cache
StreamingAdmin --> Redis : Invalidate Cache

note right of Elasticsearch
  Full-text search for:
  - Movies
  - Genres
  - Persons
end note

note right of Redis
  Caching layer for:
  - API responses
  - Sessions/Tokens
  - Frequently accessed data
end note

note right of ClickHouse
  Analytics storage for:
  - User activity
  - Viewing patterns
  - Recommendation engine
end note

note right of MinIO
  Object storage for:
  - Raw video files
  - Converted videos
  - Multiple resolutions
end note

note bottom of Kafka
  Event streaming for:
  - Real-time user activity
  - Event-driven architecture
end note

@enduml
