@startuml
!define RECTANGLE class

skinparam componentStyle rectangle

package "Android Application (Client)" {
    component [MainActivity] as MainActivity
    component [CameraActivity] as CameraActivity
    component [ResultActivity] as ResultActivity
    component [ImageUploadTask] as ImageUploadTask
    component [CameraPreview] as CameraPreview
    component [SurfaceOverlay] as SurfaceOverlay

    package "UI Resources" {
        component [activity_main.xml] as MainLayout
        component [activity_camera.xml] as CameraLayout
        component [activity_result.xml] as ResultLayout
        component [strings.xml] as Strings
    }
}

package "Flask Server (Backend)" {
    component [server.py] as FlaskServer
    component [graph_classifier.py] as GraphClassifier
    component [graph_images.py] as GraphImages
    component [generate_data.py] as GenerateData
    component [cn.py] as CNTraining
}

package "Neural Network" {
    component [TensorFlow CNN Model] as CNNModel
}

package "Data Layer" {
    database "Training Data" as TrainingData
    database "Synthetic Graph Images" as SyntheticData
}

' Android App Internal Relationships
MainActivity --> CameraActivity : launches
CameraActivity --> CameraPreview : uses
CameraActivity --> SurfaceOverlay : uses
CameraActivity --> ImageUploadTask : creates
ImageUploadTask --> ResultActivity : triggers
ResultActivity ..> Strings : uses
MainActivity ..> MainLayout : uses
CameraActivity ..> CameraLayout : uses
ResultActivity ..> ResultLayout : uses

' Client-Server Communication
ImageUploadTask --> FlaskServer : HTTP POST\n(image upload)
FlaskServer --> ImageUploadTask : classification result
ResultActivity ..> FlaskServer : receives from

' Server Internal Relationships
FlaskServer --> GraphClassifier : invokes classification
GraphClassifier --> CNNModel : uses
GraphImages --> CNNModel : provides training data
GenerateData --> SyntheticData : generates
SyntheticData --> GraphImages : loads
CNTraining --> CNNModel : trains & evaluates
GraphImages --> TrainingData : loads

' Data Flow
CameraActivity --> ImageUploadTask : captured image
TrainingData --> GraphImages : raw images

interface "HTTP REST API" as API
ImageUploadTask -down- API
API -down- FlaskServer

interface "Camera API" as CameraAPI
CameraActivity -down- CameraAPI

note right of CNNModel
  Trained to classify:
  - Ascending Linear
  - Descending Linear
  - Constant
  - Other graph types
end note

note right of ImageUploadTask
  AsyncTask for
  asynchronous network
  operations using okhttp3
end note

note bottom of FlaskServer
  Main entry point for
  image classification
  requests
end note

@enduml
