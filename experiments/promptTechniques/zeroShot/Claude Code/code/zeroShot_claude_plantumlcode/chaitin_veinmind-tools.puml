@startuml
skinparam component {
    BackgroundColor<<plugin>> LightSkyBlue
    BackgroundColor<<core>> LightGreen
    BackgroundColor<<runtime>> LightYellow
    BackgroundColor<<cicd>> LightPink
}

package "Container Runtime Environment" {
    component [Docker Runtime] as docker <<runtime>>
    component [Container Images] as images <<runtime>>
    component [Running Containers] as containers <<runtime>>
}

package "Core Library" {
    component [libveinmind] as libveinmind <<core>>
}

package "Veinmind Runner" {
    component [veinmind-runner] as runner <<core>>
    component [Service Manager] as servicemgr <<core>>
    component [Plugin Manager] as pluginmgr <<core>>
    component [Configuration Loader] as configloader <<core>>

    runner --> servicemgr
    runner --> pluginmgr
    runner --> configloader
}

package "Security Plugins" {
    component [veinmind-weakpass] as weakpass <<plugin>>
    component [veinmind-malicious] as malicious <<plugin>>
    component [veinmind-sensitive] as sensitive <<plugin>>
    component [veinmind-unsafe-mount] as unsafemount <<plugin>>
    component [veinmind-backdoor] as backdoor <<plugin>>
    component [veinmind-cve] as cve <<plugin>>
}

package "Plugin Components" {
    package "Weakpass Plugin" {
        component [CLI Interface] as weakpass_cli
        component [Scanner Logic] as weakpass_scanner
        component [Service Modules] as weakpass_services
        component [Password Dictionaries] as weakpass_dict
        component [MySQL Parsers] as mysql_parser

        weakpass_cli --> weakpass_scanner
        weakpass_scanner --> weakpass_services
        weakpass_scanner --> weakpass_dict
        weakpass_services --> mysql_parser
    }

    package "Sensitive Plugin" {
        component [CLI Interface] as sens_cli
        component [Scanner Logic] as sens_scanner
        component [Rules Engine] as rules_engine
        component [Filesystem Access] as veinfs

        sens_cli --> sens_scanner
        sens_scanner --> rules_engine
        sens_scanner --> veinfs
    }
}

package "Common Libraries" {
    component [veinmind-common-go] as common
    component [Report Generator] as reporter

    common --> reporter
}

package "Configuration Files" {
    component [service.toml] as service_config
    component [rules.toml] as rules_config
    component [dict files] as dict_files
}

package "CI/CD Pipeline" {
    component [GitHub Actions] as github_actions <<cicd>>
    component [Build Workflow] as build_wf <<cicd>>
    component [Test Workflow] as test_wf <<cicd>>
    component [Package Workflow] as package_wf <<cicd>>
    component [Push Workflow] as push_wf <<cicd>>

    github_actions --> build_wf
    github_actions --> test_wf
    github_actions --> package_wf
    github_actions --> push_wf
}

package "Deployment Artifacts" {
    component [Docker Images] as plugin_images
    component [Binary Executables] as binaries
    component [Git Repository] as git_repo
}

package "Output" {
    component [JSON Reports] as json_out
    component [HTML Reports] as html_out
    component [CLI Output] as cli_out
}

runner --> libveinmind
weakpass --> libveinmind
malicious --> libveinmind
sensitive --> libveinmind
unsafemount --> libveinmind
backdoor --> libveinmind
cve --> libveinmind

libveinmind --> docker
libveinmind --> images
libveinmind --> containers

pluginmgr --> weakpass
pluginmgr --> malicious
pluginmgr --> sensitive
pluginmgr --> unsafemount
pluginmgr --> backdoor
pluginmgr --> cve

configloader ..> service_config : reads
rules_engine ..> rules_config : reads
weakpass_dict ..> dict_files : embeds

weakpass --> common
malicious --> common
sensitive --> common
unsafemount --> common
backdoor --> common
cve --> common

weakpass --> weakpass_cli
sensitive --> sens_cli

build_wf --> plugin_images : builds
build_wf --> binaries : compiles
package_wf --> plugin_images : packages
push_wf --> plugin_images : publishes
push_wf --> git_repo : updates

plugin_images --> docker : deploys to
binaries --> runner : deploys as

servicemgr --> git_repo : clones from

reporter --> json_out
reporter --> html_out
reporter --> cli_out

note right of runner
  Central orchestrator that:
  - Manages plugin lifecycle
  - Loads TOML configurations
  - Monitors service health
  - Coordinates scanning tasks
end note

note right of libveinmind
  Core library for:
  - Container runtime interaction
  - Filesystem access
  - Image inspection
end note

note bottom of "Security Plugins"
  Plugins deployed as:
  - Standalone Docker containers
  - Binary executables
  - Modular components
end note

note right of github_actions
  Automated CI/CD:
  - Multi-stage Docker builds
  - Cross-platform compilation
  - Automated testing
  - Release management
end note

@enduml
