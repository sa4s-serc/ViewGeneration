@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<frontend>> LightBlue
    BackgroundColor<<backend>> LightGreen
    BackgroundColor<<infrastructure>> LightYellow
    BackgroundColor<<security>> LightCoral
    BackgroundColor<<building_block>> Wheat
}

skinparam database {
    BackgroundColor LightGray
}

package "Frontend Layer" {
    component "WebUI\n(Blazor WebAssembly)" as WebUI <<frontend>> {
        component "Product Management UI" as ProductUI
        component "Authentication State" as AuthState
        component "StrawberryShake\nGraphQL Client" as GraphQLClient
    }
}

package "API Gateway Layer" {
    component "Kubernetes Ingress" as Ingress <<infrastructure>>
    component "Graph API\n(GraphQL Endpoint)" as GraphAPI <<backend>>
}

package "Identity & Security" {
    component "IdentityServer4" as IdentityServer <<security>> {
        component "OpenID Connect" as OIDC
        component "OAuth 2.0" as OAuth
        component "Quickstart UI" as QuickstartUI
        component "Test Users" as TestUsers
    }
}

package "Microservices Layer" {
    component "ProductCatalogApi" as ProductAPI <<backend>> {
        component "REST API" as ProductREST
        component "gRPC API" as ProductGRPC
        component "GraphQL API" as ProductGraphQL
        component "Command Handlers" as ProductCommands
        component "Query Handlers" as ProductQueries
        component "Domain Events" as ProductEvents
    }

    component "InventoryApi" as InventoryAPI <<backend>> {
        component "REST API" as InventoryREST
        component "gRPC API" as InventoryGRPC
        component "GraphQL API" as InventoryGraphQL
        component "Event Handlers" as InventoryEvents
    }
}

package "Building Blocks (N8T)" {
    component "N8T.Domain" as N8TDomain <<building_block>> {
        component "Aggregate Root" as AggregateRoot
        component "Domain Events" as DomainEvents
        component "Value Objects" as ValueObjects
    }

    component "N8T.Infrastructure" as N8TInfra <<building_block>> {
        component "Configuration" as Config
        component "MediatR Integration" as MediatR
        component "gRPC Extensions" as gRPCExt
        component "GraphQL Extensions" as GraphQLExt
        component "Dapr Client Setup" as DaprClient
        component "DB Context" as DBContext
        component "Logging" as Logging
    }
}

package "Dapr Sidecar" {
    component "Dapr Runtime" as Dapr <<infrastructure>> {
        component "Service Invocation" as ServiceInvocation
        component "State Management" as StateManagement
        component "Pub/Sub" as PubSub
        component "Observability" as Observability
    }
}

package "Data Layer" {
    database "Product Database\n(EF Core)" as ProductDB
    database "Inventory Database\n(EF Core)" as InventoryDB
    database "Redis\n(State Store)" as Redis
}

package "Observability & Monitoring" {
    component "Zipkin\n(Distributed Tracing)" as Zipkin <<infrastructure>>
    component "Seq\n(Structured Logging)" as Seq <<infrastructure>>
}

package "Orchestration & Deployment" {
    component "Kubernetes" as K8s <<infrastructure>> {
        component "Deployments" as Deployments
        component "Services" as Services
        component "ConfigMaps" as ConfigMaps
    }
    component "Helm Charts" as Helm <<infrastructure>>
    component "Tye\n(Local Dev)" as Tye <<infrastructure>>
    component "GitHub Actions\n(CI/CD)" as GithubActions <<infrastructure>>
}

' Frontend connections
WebUI --> Ingress : HTTPS
GraphQLClient --> GraphAPI : GraphQL Queries
WebUI --> IdentityServer : Authentication

' API Gateway connections
Ingress --> GraphAPI : Route Traffic
GraphAPI --> ProductAPI : Query Products
GraphAPI --> InventoryAPI : Query Inventory

' Microservices connections
ProductAPI --> ProductDB : Read/Write
InventoryAPI --> InventoryDB : Read/Write

' Dapr connections
ProductAPI --> Dapr : Service-to-Service\nPub/Sub
InventoryAPI --> Dapr : Service-to-Service\nPub/Sub
Dapr --> Redis : State Storage
ProductEvents --> PubSub : Publish Events
PubSub --> InventoryEvents : Subscribe Events

' Building blocks dependencies
ProductAPI ..> N8TDomain : uses
ProductAPI ..> N8TInfra : uses
InventoryAPI ..> N8TDomain : uses
InventoryAPI ..> N8TInfra : uses

MediatR --> ProductCommands : Pipeline
MediatR --> ProductQueries : Pipeline
DBContext --> ProductDB : Access
DBContext --> InventoryDB : Access

' Observability connections
Dapr --> Zipkin : Traces
Logging --> Seq : Logs
ProductAPI --> Seq : Logs
InventoryAPI --> Seq : Logs

' Deployment connections
K8s --> ProductAPI : Deploy
K8s --> InventoryAPI : Deploy
K8s --> IdentityServer : Deploy
K8s --> GraphAPI : Deploy
K8s --> WebUI : Deploy
K8s --> Dapr : Sidecar Pattern
Helm --> K8s : Provision
GithubActions --> K8s : Deploy
Tye --> ProductAPI : Local Run
Tye --> InventoryAPI : Local Run

' Internal component relationships
ProductCommands --> AggregateRoot : Domain Logic
ProductQueries --> ProductDB : Query
ProductEvents --> DomainEvents : Publish
DaprClient --> Dapr : Configure

note right of Dapr
  Dapr handles:
  - Service-to-service communication
  - State management (Redis)
  - Pub/Sub messaging
  - Distributed tracing
end note

note right of N8TDomain
  Reusable domain patterns:
  - CQRS
  - Event-driven architecture
  - Repository pattern
  - Unit of Work
end note

note bottom of WebUI
  Frontend Features:
  - Product CRUD operations
  - Search & filtering
  - Pagination
  - Bootstrap styling
end note

note top of IdentityServer
  Security Features:
  - OpenID Connect
  - OAuth 2.0 flows
  - Token management
  - Security headers
end note

@enduml
