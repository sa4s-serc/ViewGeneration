@startuml
!define COMPONENT_BG_COLOR #LightBlue
!define NODE_BG_COLOR #LightGray

title Kangrand - ECDLP Solver Deployment Architecture

node "Server Node" as ServerNode {
  component "Kangaroo Server" as Server {
    component "Network Component" as ServerNetwork
    component "Work Distribution" as WorkDistribution
    component "Data Collector" as DataCollector
  }

  component "HashTable" as ServerHashTable
  component "Backup Component" as ServerBackup

  database "Work Files" as ServerWorkFiles
  database "Merged Results" as MergedResults
}

node "Client Node 1" as ClientNode1 {
  component "Kangaroo Client" as Client1 {
    component "Network Component" as Client1Network
    component "Thread Manager" as Client1ThreadMgr
    component "Timer" as Client1Timer
  }

  component "CPU Engine" as Client1CPU {
    component "Secp256K1" as Client1Secp
    component "Integer Arithmetic" as Client1IntArith
  }

  component "GPU Engine (CUDA)" as Client1GPU {
    component "GPU Kernels" as Client1Kernels
    component "GPU Memory Manager" as Client1GPUMem
  }

  component "HashTable" as Client1HashTable
  component "Backup Component" as Client1Backup

  database "Local Work Files" as Client1WorkFiles
}

node "Client Node 2" as ClientNode2 {
  component "Kangaroo Client" as Client2 {
    component "Network Component" as Client2Network
    component "Thread Manager" as Client2ThreadMgr
    component "Timer" as Client2Timer
  }

  component "CPU Engine" as Client2CPU {
    component "Secp256K1" as Client2Secp
    component "Integer Arithmetic" as Client2IntArith
  }

  component "GPU Engine (CUDA)" as Client2GPU {
    component "GPU Kernels" as Client2Kernels
    component "GPU Memory Manager" as Client2GPUMem
  }

  component "HashTable" as Client2HashTable
  component "Backup Component" as Client2Backup

  database "Local Work Files" as Client2WorkFiles
}

node "Client Node N" as ClientNodeN {
  component "Kangaroo Client" as ClientN {
    component "Network Component" as ClientNNetwork
    component "Thread Manager" as ClientNThreadMgr
  }

  component "CPU/GPU Engine" as ClientNEngine
  component "HashTable" as ClientNHashTable
  component "Backup Component" as ClientNBackup

  database "Local Work Files" as ClientNWorkFiles
}

cloud "Network" as Network {
}

' Server Internal Connections
WorkDistribution --> ServerNetwork
DataCollector --> ServerNetwork
DataCollector --> ServerHashTable
ServerHashTable --> ServerBackup
ServerBackup --> ServerWorkFiles
ServerHashTable --> MergedResults
ServerBackup --> MergedResults

' Client 1 Internal Connections
Client1 --> Client1Network
Client1ThreadMgr --> Client1CPU
Client1ThreadMgr --> Client1GPU
Client1CPU --> Client1HashTable
Client1GPU --> Client1HashTable
Client1HashTable --> Client1Backup
Client1Backup --> Client1WorkFiles
Client1Secp --> Client1IntArith

' Client 2 Internal Connections
Client2 --> Client2Network
Client2ThreadMgr --> Client2CPU
Client2ThreadMgr --> Client2GPU
Client2CPU --> Client2HashTable
Client2GPU --> Client2HashTable
Client2HashTable --> Client2Backup
Client2Backup --> Client2WorkFiles
Client2Secp --> Client2IntArith

' Client N Internal Connections
ClientN --> ClientNNetwork
ClientNEngine --> ClientNHashTable
ClientNHashTable --> ClientNBackup
ClientNBackup --> ClientNWorkFiles

' Network Communication
ServerNetwork <--> Network : "TCP/IP"
Client1Network <--> Network : "TCP/IP"
Client2Network <--> Network : "TCP/IP"
ClientNNetwork <--> Network : "TCP/IP"

' Server-Client Interactions
Network ..> WorkDistribution : "Distribute\nConfigurations"
DataCollector ..> Network : "Receive\nCalculated Data"
Client1Network ..> Network : "Request Work"
Network ..> Client1Network : "Send Work Config"
Client1Network ..> Network : "Send Results"
Client2Network ..> Network : "Request Work"
Network ..> Client2Network : "Send Work Config"
Client2Network ..> Network : "Send Results"
ClientNNetwork ..> Network : "Request/Send Data"

note right of ServerNode
  Server distributes work
  and collects results from
  multiple client nodes
end note

note right of ClientNode1
  Each client can run
  CPU and/or GPU engines
  in parallel threads
end note

note bottom of Network
  Distributed architecture enables
  horizontal scaling across multiple
  client nodes for ECDLP solving
end note

legend right
  |= Symbol |= Description |
  | Node | Physical/Virtual Machine |
  | Component | Software Component |
  | Database | Persistent Storage |
  | Cloud | Network Infrastructure |
endlegend

@enduml
