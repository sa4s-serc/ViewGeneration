@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<execution>> LightGreen
    BackgroundColor<<metadata>> LightYellow
    BackgroundColor<<integration>> LightPink
    BorderColor Black
    ArrowColor Black
}

skinparam interface {
    BackgroundColor White
    BorderColor Black
}

package "DagScheduler.jl Core" {
    component [DagScheduler\nMain Module] as MainModule <<core>>
    component [rundag\nFunction] as RunDag <<core>>
    component [Common\nUtilities] as Common <<core>>

    interface "DAG Execution API" as DAGAPI
    interface "Configuration API" as ConfigAPI
}

package "Scheduling Layer" {
    component [Scheduler] as Scheduler <<core>>
    component [Task Prioritizer] as TaskPrioritizer <<core>>
    component [DAG Decomposer] as DAGDecomposer <<core>>
    component [Affinity Manager] as AffinityManager <<core>>

    interface "Scheduling API" as ScheduleAPI
}

package "Execution Environment" {
    component [RunEnv\nSetup] as RunEnv <<execution>>
    component [NodeEnv\nConfiguration] as NodeEnv <<execution>>

    interface "Environment API" as EnvAPI
}

package "Execution Engine" {
    component [Execution\nEngine] as ExecEngine <<execution>>
    component [Task Queue\nManager] as QueueManager <<execution>>
    component [Task Stealing\nMechanism] as TaskStealing <<execution>>
    component [Fault Handler] as FaultHandler <<execution>>

    interface "Execution API" as ExecAPI
    interface "Queue API" as QueueAPI
}

package "Distributed Processes" {
    node "Node 1" {
        component [Broker 1] as Broker1 <<execution>>
        component [Executor 1.1] as Exec11 <<execution>>
        component [Executor 1.2] as Exec12 <<execution>>
        component [I/O Handler 1] as IO1 <<execution>>
    }

    node "Node 2" {
        component [Broker 2] as Broker2 <<execution>>
        component [Executor 2.1] as Exec21 <<execution>>
        component [Executor 2.2] as Exec22 <<execution>>
        component [I/O Handler 2] as IO2 <<execution>>
    }

    interface "Broker API" as BrokerAPI
    interface "Executor API" as ExecutorAPI
}

package "Metadata Store Implementations" {
    component [MetaStore\nAbstraction] as MetaAbstract <<metadata>>

    component [ShmemMetaStore\n(Shared Memory)] as ShmemMeta <<metadata>>
    component [SimpleMetaStore\n(Julia Messaging)] as SimpleMeta <<metadata>>
    component [FDBMetaStore\n(FoundationDB)] as FDBMeta <<metadata>>

    interface "MetaStore API" as MetaAPI
}

package "Data Management" {
    component [Data Locality\nManager] as DataLocality <<core>>
    component [Reference\nCounter] as RefCounter <<metadata>>
    component [Result Location\nTracker] as ResultTracker <<metadata>>
    component [Async I/O\nController] as AsyncIO <<execution>>

    interface "Data API" as DataAPI
}

package "Integration Layer" {
    component [Dagger.jl\nPlugin] as DaggerPlugin <<integration>>
    component [RemoteMonitor\nHooks] as RemoteMonitor <<integration>>

    interface "Plugin API" as PluginAPI
}

MainModule --> DAGAPI
RunDag ..> DAGAPI
MainModule --> ConfigAPI
Common ..> ConfigAPI

RunDag --> ScheduleAPI : initiates
Scheduler ..> ScheduleAPI
Scheduler --> TaskPrioritizer : uses
Scheduler --> DAGDecomposer : decomposes DAGs
Scheduler --> AffinityManager : considers locality

RunDag --> EnvAPI : sets up
RunEnv ..> EnvAPI
NodeEnv ..> EnvAPI

Scheduler --> ExecAPI : submits tasks
ExecEngine ..> ExecAPI
ExecEngine --> QueueAPI : manages
QueueManager ..> QueueAPI
QueueManager --> TaskStealing : implements
ExecEngine --> FaultHandler : handles failures

ExecEngine --> BrokerAPI : coordinates
Broker1 ..> BrokerAPI
Broker2 ..> BrokerAPI

Broker1 --> ExecutorAPI : manages
Broker2 --> ExecutorAPI : manages
Exec11 ..> ExecutorAPI
Exec12 ..> ExecutorAPI
Exec21 ..> ExecutorAPI
Exec22 ..> ExecutorAPI

Broker1 --> IO1 : async I/O
Broker2 --> IO2 : async I/O
IO1 --> AsyncIO : uses
IO2 --> AsyncIO : uses

ExecEngine --> MetaAPI : reads/writes
MetaAbstract ..> MetaAPI
ShmemMeta --|> MetaAbstract : implements
SimpleMeta --|> MetaAbstract : implements
FDBMeta --|> MetaAbstract : implements

MetaAbstract --> ResultTracker : tracks results
MetaAbstract --> RefCounter : manages refs

Scheduler --> DataLocality : optimizes placement
DataLocality --> DataAPI : accesses
ExecEngine --> DataAPI : transfers data
AsyncIO ..> DataAPI

Broker1 <--> Broker2 : data transfer\n(async, locality-aware)
IO1 <--> IO2 : cross-node I/O

TaskStealing --> QueueManager : steals tasks\n(load balancing)
FaultHandler --> Scheduler : reschedules failed tasks

DaggerPlugin --> PluginAPI : exposes
MainModule --> PluginAPI : implements
RemoteMonitor --> ExecEngine : monitors

ShmemMeta --> NodeEnv : node-local\n(fast access)
SimpleMeta --> Broker1 : cluster-wide\n(messaging)
SimpleMeta --> Broker2 : cluster-wide\n(messaging)
FDBMeta --> Broker1 : persistent\n(fault-tolerant)
FDBMeta --> Broker2 : persistent\n(fault-tolerant)

note right of DataLocality
  Data Flow Optimization:
  - Minimizes data transfer
  - Computes where data resides
  - Prioritizes local execution
end note

note right of AsyncIO
  Performance Optimization:
  - Non-blocking I/O
  - Broker-based transfer
  - Prevents computation blocking
end note

note right of TaskStealing
  Performance Optimization:
  - Queue-based work stealing
  - Load balancing
  - Resource utilization
end note

note bottom of MetaAbstract
  Performance Trade-offs:
  - ShmemMeta: Fast, node-local
  - SimpleMeta: Shared-nothing, scalable
  - FDBMeta: Persistent, fault-tolerant
end note

@enduml
