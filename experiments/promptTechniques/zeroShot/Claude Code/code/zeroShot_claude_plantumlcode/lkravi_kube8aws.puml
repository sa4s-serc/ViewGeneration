@startuml

skinparam componentStyle rectangle
skinparam linetype ortho

title Kubernetes on AWS - Deployment and Connectivity Architecture

package "AWS Cloud" {

    rectangle "VPC\n(terraform-aws-modules/vpc/aws)" as VPC {

        package "Public Subnet" {
            component "Bastion Host" as Bastion <<EC2>> {
                component "Ansible Control" as AnsibleControl
                component "SSH Jump Box" as SSHJump
            }
        }

        package "Private Subnet - Control Plane" {
            component "Master Node 1" as Master1 <<EC2>> {
                portin api1
                component "API Server" as M1API
                component "Kubelet" as M1Kubelet
                component "Kubeadm" as M1Kubeadm
                component "cri-dockerd" as M1CRI
                component "Docker" as M1Docker
            }

            component "Master Node N" as MasterN <<EC2>> {
                portin apiN
                component "API Server" as MNAPI
                component "Kubelet" as MNKubelet
                component "Kubeadm" as MNKubeadm
                component "cri-dockerd" as MNCRI
                component "Docker" as MNDocker
            }
        }

        package "Private Subnet - Worker Nodes" {
            component "Worker Node 1" as Worker1 <<EC2>> {
                component "Kubelet" as W1Kubelet
                component "Kubeadm" as W1Kubeadm
                component "cri-dockerd" as W1CRI
                component "Docker" as W1Docker
            }

            component "Worker Node N" as WorkerN <<EC2>> {
                component "Kubelet" as WNKubelet
                component "Kubeadm" as WNKubeadm
                component "cri-dockerd" as WNCRI
                component "Docker" as WNDocker
            }
        }

        component "Network Load Balancer" as NLB <<NLB>> {
            portout APIEndpoint
            component "Target Group\n(IP-based)" as TargetGroup
        }

        rectangle "Security Groups" as SecurityGroups {
            component "Bastion SG" as BastionSG
            component "Master SG" as MasterSG
            component "Worker SG" as WorkerSG
        }
    }

    component "AWS Key Pair" as AWSKeyPair
}

package "Terraform Configuration" {
    component "vpc.tf" as VPCTerraform
    component "servers.tf" as ServersTerraform
    component "load_balance.tf" as LBTerraform
    component "security.tf" as SecurityTerraform
    component "keys.tf" as KeysTerraform
    component "ansible_helper.tf" as AnsibleHelper
    component "providers.tf" as ProvidersTerraform
    component "vars.tf" as VarsTerraform
    component "outputs.tf" as OutputsTerraform
}

package "Ansible Playbooks" {
    component "play.yml" as PlayYml
    component "ansible_vars_file.yml" as AnsibleVars
    component "inventry.tftpl" as InventoryTemplate
}

package "Local Machine" {
    component "SSH Private Key" as LocalKey
    component "Terraform CLI" as TerraformCLI
}

' Terraform provisioning
TerraformCLI -down-> VPCTerraform : executes
TerraformCLI -down-> ServersTerraform : executes
TerraformCLI -down-> LBTerraform : executes
TerraformCLI -down-> SecurityTerraform : executes
TerraformCLI -down-> KeysTerraform : executes
TerraformCLI -down-> AnsibleHelper : executes

VPCTerraform -down-> VPC : provisions
ServersTerraform -down-> Bastion : provisions
ServersTerraform -down-> Master1 : provisions
ServersTerraform -down-> MasterN : provisions
ServersTerraform -down-> Worker1 : provisions
ServersTerraform -down-> WorkerN : provisions
LBTerraform -down-> NLB : provisions
SecurityTerraform -down-> SecurityGroups : configures
KeysTerraform -down-> AWSKeyPair : creates
KeysTerraform -down-> LocalKey : generates

' Ansible configuration
AnsibleHelper --> InventoryTemplate : uses template
AnsibleHelper --> PlayYml : copies to Bastion
AnsibleHelper --> AnsibleVars : copies to Bastion
AnsibleHelper --> AnsibleControl : remote-exec

AnsibleControl --> PlayYml : executes
PlayYml --> AnsibleVars : reads
PlayYml -down-> Master1 : configures K8s
PlayYml -down-> MasterN : configures K8s
PlayYml -down-> Worker1 : configures K8s
PlayYml -down-> WorkerN : configures K8s

' SSH connectivity
LocalKey -right-> Bastion : SSH (22)
SSHJump --> Master1 : SSH (22)
SSHJump --> MasterN : SSH (22)
SSHJump --> Worker1 : SSH (22)
SSHJump --> WorkerN : SSH (22)

' Load balancer connectivity
NLB --> TargetGroup : routes
TargetGroup --> api1 : 6443
TargetGroup --> apiN : 6443

' Container runtime
M1API --> M1CRI : uses
M1CRI --> M1Docker : runtime
MNKubelet --> MNCRI : uses
MNCRI --> MNDocker : runtime
W1Kubelet --> W1CRI : uses
W1CRI --> W1Docker : runtime
WNKubelet --> WNCRI : uses
WNCRI --> WNDocker : runtime

' API connectivity
W1Kubelet --> APIEndpoint : connects\n6443
WNKubelet --> APIEndpoint : connects\n6443
M1Kubelet --> APIEndpoint : connects\n6443
MNKubelet --> APIEndpoint : connects\n6443

' Security enforcement
BastionSG -up-> Bastion : SSH: 22
MasterSG -up-> Master1 : API: 6443\nSSH: 22
MasterSG -up-> MasterN : API: 6443\nSSH: 22
WorkerSG -up-> Worker1 : SSH: 22
WorkerSG -up-> WorkerN : SSH: 22

' Cluster initialization
M1Kubeadm ..> M1API : initializes\ncontrol plane
MNKubeadm ..> M1API : joins as\nmaster
W1Kubeadm ..> APIEndpoint : joins as\nworker
WNKubeadm ..> APIEndpoint : joins as\nworker

note right of NLB
  <b>Highly Available API Endpoint</b>
  - Stable DNS endpoint
  - IP-based target group
  - Routes to master nodes
end note

note right of Bastion
  <b>Secure Access & Control</b>
  - SSH jump box
  - Ansible control node
  - Single entry point
end note

note bottom of VPC
  <b>Infrastructure as Code</b>
  Terraform: Provisions AWS resources
  Ansible: Configures Kubernetes cluster
  Kubeadm: Initializes & manages cluster
end note

note top of SecurityGroups
  <b>Security Controls</b>
  - Bastion: SSH (22)
  - Masters: API (6443), SSH (22)
  - Workers: SSH (22)
end note

@enduml
