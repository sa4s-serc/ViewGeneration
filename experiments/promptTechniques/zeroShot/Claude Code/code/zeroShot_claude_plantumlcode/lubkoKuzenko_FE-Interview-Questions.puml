@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<documentation>> LightYellow
    BackgroundColor<<topic>> LightBlue
    BackgroundColor<<code>> LightGreen
    BackgroundColor<<infrastructure>> LightGray
}

package "FE-Interview-Questions Repository" {

    component "README.md\n(Root)" as RootReadme <<documentation>> {
        [Table of Contents]
        [Contributor Information]
        [Overview]
    }

    package "HTML Topic" {
        component "HTML/README.md" as HTMLReadme <<topic>>
        component "HTML Questions\nDatabase" as HTMLQuestions <<documentation>>
        component "HTML Answers" as HTMLAnswers <<documentation>>
    }

    package "CSS Topic" {
        component "CSS/README.md" as CSSReadme <<topic>>
        component "CSS Questions\nDatabase" as CSSQuestions <<documentation>>
        component "CSS Answers" as CSSAnswers <<documentation>>
    }

    package "JavaScript Topic" {
        component "JavaScript/README.md" as JSReadme <<topic>>
        component "JS Questions\nDatabase" as JSQuestions <<documentation>>
        component "JS Answers\n(Hoisting, Closures,\nPrototypes, Async)" as JSAnswers <<documentation>>
        component "JS Code\nExamples" as JSCode <<code>>
    }

    package "TypeScript Topic" {
        component "TypeScript/README.md" as TSReadme <<topic>>
        component "TS Questions\nDatabase" as TSQuestions <<documentation>>
        component "TS Answers" as TSAnswers <<documentation>>
        component "TS Code\nExamples" as TSCode <<code>>
    }

    package "React Topic" {
        component "React/README.md" as ReactReadme <<topic>>
        component "React Questions\nDatabase" as ReactQuestions <<documentation>>
        component "React Answers\n(Hooks, Lifecycle,\nState Management)" as ReactAnswers <<documentation>>

        package "React Code Examples" {
            component "App.js" as AppComponent <<code>>
            component "PortalDemo.js" as PortalComponent <<code>>
            component "Functional\nComponents" as FunctionalComp <<code>>
            component "Class\nComponents" as ClassComp <<code>>
        }
    }

    package "Redux Topic" {
        component "Redux/README.md" as ReduxReadme <<topic>>
        component "Redux Questions\nDatabase" as ReduxQuestions <<documentation>>
        component "Redux Answers\n(Middleware,\nThunk, Saga)" as ReduxAnswers <<documentation>>

        package "Redux Code Examples" {
            component "actions.js" as Actions <<code>>
            component "reducers.js" as Reducers <<code>>
            component "Container\nComponents" as ContainerComp <<code>>
            component "Presentational\nComponents" as PresentationalComp <<code>>
        }
    }

    package "Angular Topic" {
        component "Angular/README.md" as AngularReadme <<topic>>
        component "Angular Questions\nDatabase" as AngularQuestions <<documentation>>
        component "Angular Answers" as AngularAnswers <<documentation>>
    }

    package "Testing Topic" {
        component "Testing/README.md" as TestingReadme <<topic>>
        component "Testing Questions\nDatabase" as TestingQuestions <<documentation>>
        component "Testing Answers" as TestingAnswers <<documentation>>
    }

    package "General Topics" {
        component "Data Structures\nREADME.md" as DSReadme <<topic>>
        component "Web Fundamentals\nREADME.md" as WebReadme <<topic>>
        component "Coding Questions\nREADME.md" as CodingReadme <<topic>>
        component "Reverse Interview\nREADME.md" as ReverseReadme <<topic>>
    }

    component "External\nResources" as ExternalRes <<infrastructure>>
    component "LICENSE\n(MIT)" as License <<infrastructure>>
}

' Relationships from Root README
RootReadme --> HTMLReadme : navigates to
RootReadme --> CSSReadme : navigates to
RootReadme --> JSReadme : navigates to
RootReadme --> TSReadme : navigates to
RootReadme --> ReactReadme : navigates to
RootReadme --> ReduxReadme : navigates to
RootReadme --> AngularReadme : navigates to
RootReadme --> TestingReadme : navigates to
RootReadme --> DSReadme : navigates to
RootReadme --> WebReadme : navigates to
RootReadme --> CodingReadme : navigates to
RootReadme --> ReverseReadme : navigates to

' HTML Topic Internal Relations
HTMLReadme --> HTMLQuestions : contains
HTMLReadme --> HTMLAnswers : contains

' CSS Topic Internal Relations
CSSReadme --> CSSQuestions : contains
CSSReadme --> CSSAnswers : contains

' JavaScript Topic Internal Relations
JSReadme --> JSQuestions : contains
JSReadme --> JSAnswers : contains
JSAnswers --> JSCode : illustrated by

' TypeScript Topic Internal Relations
TSReadme --> TSQuestions : contains
TSReadme --> TSAnswers : contains
TSAnswers --> TSCode : illustrated by

' React Topic Internal Relations
ReactReadme --> ReactQuestions : contains
ReactReadme --> ReactAnswers : contains
ReactAnswers --> AppComponent : illustrated by
ReactAnswers --> PortalComponent : illustrated by
ReactAnswers --> FunctionalComp : illustrated by
ReactAnswers --> ClassComp : illustrated by

' Redux Topic Internal Relations
ReduxReadme --> ReduxQuestions : contains
ReduxReadme --> ReduxAnswers : contains
ReduxAnswers --> Actions : illustrated by
ReduxAnswers --> Reducers : illustrated by
ReduxAnswers --> ContainerComp : illustrated by
ReduxAnswers --> PresentationalComp : illustrated by

' Redux Pattern Relations
Actions --> Reducers : dispatched to
ContainerComp --> PresentationalComp : renders
ContainerComp --> Actions : uses
ContainerComp --> Reducers : connects to

' React-Redux Integration
ReactAnswers ..> ReduxAnswers : integrates with

' Angular Topic Internal Relations
AngularReadme --> AngularQuestions : contains
AngularReadme --> AngularAnswers : contains

' Testing Topic Internal Relations
TestingReadme --> TestingQuestions : contains
TestingReadme --> TestingAnswers : contains

' External Resources Integration
HTMLAnswers --> ExternalRes : links to
CSSAnswers --> ExternalRes : links to
JSAnswers --> ExternalRes : links to
TSAnswers --> ExternalRes : links to
ReactAnswers --> ExternalRes : links to
ReduxAnswers --> ExternalRes : links to
AngularAnswers --> ExternalRes : links to
TestingAnswers --> ExternalRes : links to

' License
License --> RootReadme : governs

note right of RootReadme
  Entry point for the repository
  Provides navigation to all topics
end note

note right of "React Code Examples"
  Component-based architecture
  Demonstrates React patterns
  Unidirectional data flow
end note

note right of "Redux Code Examples"
  Separation of concerns
  Pure functions (reducers)
  Middleware pattern support
end note

note bottom of ExternalRes
  External learning resources
  Referenced throughout topics
end note

@enduml
