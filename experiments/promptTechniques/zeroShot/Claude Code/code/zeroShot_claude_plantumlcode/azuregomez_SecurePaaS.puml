@startuml
title Secure PaaS Deployment Architecture - Security and Connectivity

skinparam componentStyle rectangle
skinparam component {
    BackgroundColor<<WAF>> #FF6B6B
    BackgroundColor<<AppService>> #4ECDC4
    BackgroundColor<<Firewall>> #FFA500
    BackgroundColor<<SQLDatabase>> #95E1D3
    BackgroundColor<<KeyVault>> #38A169
    BackgroundColor<<PrivateEndpoint>> #9B59B6
    BackgroundColor<<Network>> #E8F5E9
    BackgroundColor<<Security>> #B0BEC5
}

actor "External User" as User

package "WAF Layer" {
    component "Web Application Firewall" as WAF <<WAF>> {
        port "WAF_In" as WAF_In
        port "WAF_Out" as WAF_Out
    }
    note right of WAF
        Protects against:
        - OWASP Top 10
        - Common web threats
    end note
}

package "Hub Network" {
    component "Azure Firewall" as Firewall <<Firewall>> {
        port "Firewall_In" as FW_In
        port "Firewall_Out" as FW_Out
    }
    component "Route Table\n(UDR)" as RouteTable <<Network>>

    note right of Firewall
        All outbound traffic from
        App Service to SQL Database
        is inspected here
    end note
}

package "Spoke Network (VNet)" <<Network>> {
    package "App Service Subnet" {
        component "Azure App Service" as AppService <<AppService>> {
            port "HTTP_In" as HTTP_In
            port "SQL_Out" as SQL_Out
        }
        component "VNet Integration" as VNetIntegration <<Network>>
    }

    package "Private Endpoint Subnet" {
        component "SQL Private Endpoint" as SQLPrivateEndpoint <<PrivateEndpoint>> {
            port "PE_In" as PE_In
            port "PE_Out" as PE_Out
        }
        note right of SQLPrivateEndpoint
            Private Link ensures
            SQL Database has no
            public endpoints
        end note
    }

    component "Network Security Groups" as NSG <<Security>>
}

package "Data Layer" {
    component "Azure SQL Database" as SQLDatabase <<SQLDatabase>> {
        port "DB_In" as DB_In
    }
    note right of SQLDatabase
        - No Public Endpoints
        - Private Access Only
    end note
}

package "Security Services" {
    component "Azure Key Vault" as KeyVault <<KeyVault>> {
        port "KV_In" as KV_In
    }
    note top of KeyVault
        Secrets stored separately
        from application code
        and configuration
    end note
}

User --> WAF_In : HTTPS Request

WAF_Out --> HTTP_In : Filtered Traffic\n(OWASP Protection)

AppService --> VNetIntegration : VNet Injection

SQL_Out --> RouteTable : Outbound Traffic\n(via UDR)

RouteTable --> FW_In : Route to Firewall\nfor Inspection

FW_Out --> PE_In : Inspected Traffic

PE_Out --> DB_In : Private Connection\n(No Public Endpoint)

AppService ..> KV_In : Retrieve Connection\nStrings & Secrets

KeyVault ..> SQLDatabase : Secure Credentials

NSG ..> AppService : Subnet Protection
NSG ..> SQLPrivateEndpoint : Subnet Protection

legend right
    |= Component |= Purpose |
    | WAF | Web Application Firewall |
    | UDR | User Defined Routes |
    | NSG | Network Security Groups |
    | VNet | Virtual Network |

    **Security Features:**
    • No public endpoints on SQL Database
    • All traffic inspected by Firewall
    • WAF protection at entry point
    • Secret management via Key Vault
    • Multi-layered security (Defense in Depth)
    • Private Link connectivity
    • VNet integration for isolation
endlegend

@enduml
