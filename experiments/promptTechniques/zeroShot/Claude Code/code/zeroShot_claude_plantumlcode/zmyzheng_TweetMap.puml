@startuml
!define RECTANGLE component

skinparam component {
    BackgroundColor<<external>> LightBlue
    BackgroundColor<<processing>> LightGreen
    BackgroundColor<<storage>> LightYellow
    BackgroundColor<<api>> LightCoral
    BackgroundColor<<frontend>> LightPink
}

title TweetMap System - Component Diagram (Deployment & Data Flow)

cloud "Twitter Streaming API" as TwitterAPI <<external>>

package "Kubernetes Cluster" {

    package "Tweet Collector Service" <<processing>> {
        component "Tweet Collector" as Collector {
            interface "SocialMediaCollector" as SMC
            interface "Sinkable" as Sink
            component "KafkaSink" as KSink
        }
    }

    package "Message Queue" <<processing>> {
        component "Kafka Cluster" as Kafka {
            queue "Tweet Stream Topic" as KafkaTopic
        }
    }

    package "Stream Processing Service" <<processing>> {
        component "Flink Processor" as Flink {
            component "StreamProcessor" as SP
            component "StreamProcessingDriver" as SPD
            component "KafkaEsProcessor" as KEP
            component "TweetKafkaEsProcessor" as TKEP
        }
    }

    package "Data Store" <<storage>> {
        component "Elasticsearch" as ES {
            database "Tweet Index" as TweetIndex
        }
    }

    package "REST API Service" <<api>> {
        component "Spring Boot API Server" as API {
            component "Controllers" as Controllers {
                [TweetController]
                [TopicController]
            }
            component "Services" as Services {
                [TweetService]
                [TopicService]
            }
            component "Repositories" as Repos {
                [TweetRepository]
                [EsOperationRepository]
            }
            component "Domain Objects" as Domain {
                [Tweet]
                [TopicStatistic]
                [TopicTrend]
                [HotTopicsTrend]
            }
            component "DTOs" as DTOs {
                [TweetDTO]
                [TopicStatisticDTO]
                [TopicTrendDTO]
                [HotTopicsTrendDTO]
            }
            component "Mappers" as Mappers {
                [TweetMapper]
                [TopicStatisticMapper]
                [TopicTrendMapper]
                [HotTopicsTrendMapper]
            }
        }
        interface "REST Endpoints" as REST
    }
}

package "Frontend Container" <<frontend>> {
    component "Angular Web App" as Frontend {
        [Tweet Visualization]
        [Heatmap Component]
        [Trend Dashboard]
    }
}

component "Kibana" as Kibana <<frontend>>

' Data Flow Connections
TwitterAPI -down-> Collector : "Real-time\nTweet Stream"
Collector -down-> KSink : "implements"
KSink -down-> Kafka : "push tweets"
Kafka -down-> Flink : "consume tweets"
SP <-down- SPD
SPD <-down- KEP
KEP <-down- TKEP
Flink -down-> ES : "ingest processed\ntweets"

ES -up-> Repos : "query"
Repos -up-> Services
Services -up-> Controllers
Controllers -up-> REST : "expose"

REST -right-> Frontend : "HTTP/JSON\nAPI calls"
ES -right-> Kibana : "visualization"

Domain <--> Mappers : "map"
Mappers <--> DTOs : "convert"
Services --> Domain : "use"
Controllers --> DTOs : "transfer"

' Deployment Notes
note right of Collector
  Deployed via K8s
  (tweet-collector.yaml)
  Docker containerized
end note

note right of Kafka
  Event-driven architecture
  Asynchronous messaging
  Central message queue
end note

note right of Flink
  Stream processing:
  - Parse tweets
  - Filter data
  - Transform structure
end note

note right of ES
  Indexed storage
  for querying & analysis
end note

note right of API
  Spring Boot REST API
  Endpoints:
  - Get all tweets
  - Filter by time/hashtags
  - Location-based queries
  - Topic statistics/trends
end note

note right of Frontend
  Angular-based
  Real-time visualization
  Geographic heatmap
end note

@enduml
