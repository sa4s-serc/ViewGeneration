@startuml
!define RECTANGLE class

skinparam componentStyle rectangle

package "Development Environment" {
    package "VSCode Remote Box" {
        component [VSCode Container] as VSCode
        component [Terraform CLI] as TerraformCLI
        component [AWS CLI] as AWSCLI
    }
}

package "Terraform Infrastructure as Code" {
    component [main.tf] as MainTF
    component [network.tf] as NetworkTF
    component [variables.tf] as VariablesTF
    component [output.tf] as OutputTF
    component [_providers.tf] as ProvidersTF
    component [_backend.tf] as BackendTF

    package "Environment Configuration" {
        component [dev.tfvars] as DevVars
        component [prd.tfvars] as PrdVars
    }

    package "Bootstrap Module" {
        component [bootstrap/main.tf] as BootstrapMain
        component [bootstrap/output.tf] as BootstrapOutput
    }

    component [install_apache.sh.tpl] as UserDataTemplate
}

package "AWS Cloud Infrastructure" {
    package "Development Environment (dev)" {
        component [VPC - Dev] as VPCDev

        package "Network Layer - Dev" {
            component [Public Subnets - Dev] as PublicSubnetDev
            component [Private Subnets - Dev] as PrivateSubnetDev
            component [Security Groups - Dev] as SGDev
        }

        package "Compute Layer - Dev" {
            component [EC2 Instances - Dev] as EC2Dev
            component [Apache Web Server - Dev] as ApacheDev
        }

        component [Application Load Balancer - Dev] as ALBDev
    }

    package "Production Environment (prd)" {
        component [VPC - Prd] as VPCPrd

        package "Network Layer - Prd" {
            component [Public Subnets - Prd] as PublicSubnetPrd
            component [Private Subnets - Prd] as PrivateSubnetPrd
            component [Security Groups - Prd] as SGPrd
        }

        package "Compute Layer - Prd" {
            component [EC2 Instances - Prd] as EC2Prd
            component [Apache Web Server - Prd] as ApachePrd
        }

        component [Application Load Balancer - Prd] as ALBPrd
    }
}

component [Terraform State (Local)] as TFState

cloud "Internet" {
    actor User
    component [IP Whitelist] as IPWhitelist
}

VSCode --> TerraformCLI
TerraformCLI --> MainTF
TerraformCLI --> NetworkTF
TerraformCLI --> BootstrapMain

MainTF --> VariablesTF
MainTF --> ProvidersTF
MainTF --> BackendTF
NetworkTF --> VariablesTF

DevVars ..> VariablesTF : configures
PrdVars ..> VariablesTF : configures

BootstrapMain --> BootstrapOutput
BootstrapOutput ..> DevVars : generates
BootstrapOutput ..> PrdVars : generates

MainTF --> UserDataTemplate : uses template

TerraformCLI --> AWSCLI
AWSCLI --> VPCDev : provisions
AWSCLI --> VPCPrd : provisions

BackendTF --> TFState : manages

BootstrapMain --> VPCDev : creates
BootstrapMain --> VPCPrd : creates
BootstrapMain --> PublicSubnetDev : creates
BootstrapMain --> PublicSubnetPrd : creates
BootstrapMain --> PrivateSubnetDev : creates
BootstrapMain --> PrivateSubnetPrd : creates

MainTF --> EC2Dev : deploys
MainTF --> EC2Prd : deploys
MainTF --> ALBDev : deploys
MainTF --> ALBPrd : deploys

NetworkTF --> SGDev : configures
NetworkTF --> SGPrd : configures

UserDataTemplate --> ApacheDev : installs
UserDataTemplate --> ApachePrd : installs

VPCDev *-- PublicSubnetDev
VPCDev *-- PrivateSubnetDev
VPCPrd *-- PublicSubnetPrd
VPCPrd *-- PrivateSubnetPrd

PublicSubnetDev --> EC2Dev : hosts
PrivateSubnetDev --> EC2Dev : hosts
PublicSubnetPrd --> EC2Prd : hosts
PrivateSubnetPrd --> EC2Prd : hosts

SGDev --> EC2Dev : filters traffic
SGPrd --> EC2Prd : filters traffic
SGDev --> ALBDev : filters traffic
SGPrd --> ALBPrd : filters traffic

EC2Dev --> ApacheDev : runs
EC2Prd --> ApachePrd : runs

ALBDev --> EC2Dev : distributes traffic
ALBPrd --> EC2Prd : distributes traffic

User --> IPWhitelist : source IP checked
IPWhitelist --> ALBDev : allowed traffic
IPWhitelist --> ALBPrd : allowed traffic
IPWhitelist --> SGDev : enforced by
IPWhitelist --> SGPrd : enforced by

note right of SGDev
  Security Groups provide
  network-level filtering
  with IP whitelisting
end note

note right of ALBDev
  Load balancers distribute
  traffic and enhance security
  by hiding backend instances
end note

note bottom of VPCDev
  Environment isolation ensures
  dev and prd separation
end note

note bottom of TFState
  Local backend for state
  (should migrate to S3 for
  collaboration)
end note

@enduml
