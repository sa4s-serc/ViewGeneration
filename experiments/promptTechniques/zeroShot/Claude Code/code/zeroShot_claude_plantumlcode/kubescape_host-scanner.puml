@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<middleware>> LightBlue
    BackgroundColor<<sensor>> LightGreen
    BackgroundColor<<utility>> LightYellow
    BackgroundColor<<external>> LightGray
}

package "Host Scanner Microservice" {
    component "sensor.go\n(Main Entry Point)" as Main {
        [Logger Initialization]
        [HTTP Router Setup]
        [Signal Handling]
        [OpenTelemetry Setup]
    }

    component "HTTP API Server" as HTTPServer {
        port "HTTP API" as HTTPAPI
    }

    package "Middleware Layer" <<middleware>> {
        component "Negroni Middleware" as Negroni {
            [Recovery]
            [Logging]
            [Liveness Probe]
            [Readiness Probe]
        }
    }

    package "HTTP Handlers" {
        component "httphandlers.go" as Handlers {
            [/healthz]
            [/readyz]
            [/osrelease]
            [/kubeletinfo]
            [/version]
            [/openedports]
            [/linuxsecurityhardening]
            [/controlplaneinfo]
            [/cloudprovider]
            [/CNIinfo]
        }
    }

    package "Sensor Layer" <<sensor>> {
        component "OS Sensor\n(osrelease.go)" as OSSensor
        component "Kubelet Sensor\n(kubelet.go)" as KubeletSensor
        component "Control Plane Sensor\n(controlplane.go)" as CPSensor
        component "CNI Sensor\n(CNI.go)" as CNISensor
        component "Network Sensor" as NetworkSensor
        component "Security Sensor" as SecuritySensor
        component "Cloud Provider Sensor" as CloudSensor
        component "Container Runtime Sensor" as RuntimeSensor
    }

    package "Utilities" <<utility>> {
        component "Container Runtime Utils\n(containerruntime.go)" as RuntimeUtils {
            [Runtime Detection]
            [CNI Config Discovery]
        }
        component "File System Utils" as FSUtils
    }

    package "Data Structures" {
        component "Sensor Package\n(Response Models)" as Models {
            [OS Info Model]
            [Kubelet Info Model]
            [Control Plane Model]
            [CNI Model]
            [Network Model]
            [Security Model]
        }
    }
}

package "External Dependencies" <<external>> {
    component "go-logger" as Logger
    component "zap" as Zap
    component "OpenTelemetry" as OTel
    database "Host Filesystem" as HostFS {
        [/etc/os-release]
        [Kubelet Config]
        [CNI Config]
        [Service Files]
        [Kube Configs]
    }
}

package "Deployment Environment" <<external>> {
    component "Kubernetes Cluster" as K8s {
        [DaemonSet]
        [Privileged Pod]
    }
    component "Container Runtime" as ContainerRuntime {
        [containerd]
        [CRI-O]
    }
}

package "Testing Infrastructure" {
    component "E2E Test Suite" as E2ETests {
        [e2e_suite_test.go]
        [API Endpoint Tests]
        [Kind Cluster Setup]
    }
    component "Ginkgo/Gomega" as TestFramework
}

' Main connections
Main --> HTTPServer
HTTPServer --> Negroni
Negroni --> Handlers
Handlers --> OSSensor
Handlers --> KubeletSensor
Handlers --> CPSensor
Handlers --> CNISensor
Handlers --> NetworkSensor
Handlers --> SecuritySensor
Handlers --> CloudSensor
Handlers --> RuntimeSensor

' Sensor to utility connections
OSSensor --> FSUtils
KubeletSensor --> FSUtils
CPSensor --> FSUtils
CNISensor --> RuntimeUtils
RuntimeSensor --> RuntimeUtils
SecuritySensor --> FSUtils

' Utility to host filesystem
RuntimeUtils --> HostFS
FSUtils --> HostFS

' Sensors to models
OSSensor --> Models
KubeletSensor --> Models
CPSensor --> Models
CNISensor --> Models
NetworkSensor --> Models
SecuritySensor --> Models

' Logging connections
Main --> Logger
Main --> Zap
Main --> OTel
Handlers --> Logger

' Deployment connections
K8s --> HTTPServer : deploys
HTTPServer ..> HostFS : accesses
RuntimeUtils --> ContainerRuntime : inspects

' Testing connections
E2ETests --> HTTPServer : tests
E2ETests --> TestFramework : uses
E2ETests --> K8s : creates Kind cluster

' Configuration
component "Environment Variables" as EnvVars {
    [OTEL_COLLECTOR_SVC]
    [BuildVersion]
}
Main --> EnvVars : reads

' API exposure
HTTPAPI --> [External Clients] : HTTP REST API

note right of HTTPServer
  Exposes host information
  via HTTP API endpoints
end note

note bottom of K8s
  Runs as privileged DaemonSet
  to access host resources
end note

note right of RuntimeUtils
  Strategy Pattern:
  - Kubelet flags inspection
  - Runtime config parsing
  - Default location search
end note

@enduml
