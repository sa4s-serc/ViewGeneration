@startuml
!define RECTANGLE_COMPONENT

skinparam component {
    BackgroundColor<<frontend>> LightBlue
    BackgroundColor<<backend>> LightGreen
    BackgroundColor<<blockchain>> Orange
    BackgroundColor<<external>> LightGray
}

package "Frontend (Next.js Client)" <<frontend>> {
    [Pages] as Pages
    [Components] as Components
    [API Client] as APIClient
    [App Context] as AppContext
    [Constants] as Constants
    [Utils] as Utils

    component "Components" {
        [Header]
        [Footer]
        [Project]
        [CreateProjectForm]
        [FundProject]
        [DisplayProjects]
    }

    component "Utils" {
        [ContractOperations]
        [TxOperations]
        [Helper Functions]
    }

    Pages --> Components : uses
    Pages --> APIClient : HTTP requests
    Pages --> AppContext : consumes state
    Components --> AppContext : consumes state
    Components --> Utils : uses
    Utils --> Constants : reads
    AppContext --> Constants : reads
}

package "Backend (Express.js Server)" <<backend>> {
    [REST API Server] as Server
    [Database Manager] as DBManager
    [DAO Layer] as DAO

    Server --> DAO : queries data
    DAO --> DBManager : executes SQL
}

package "Smart Contracts (PyTeal)" <<blockchain>> {
    [Approval Program] as ApprovalProgram
    [Clear Program] as ClearProgram
    [Contract Operations] as ContractOps
    [Utility Functions] as ContractUtils

    ContractOps --> ApprovalProgram : deploys
    ContractOps --> ClearProgram : deploys
    ContractOps --> ContractUtils : uses
}

database "SQLite Database" {
    [Application Data]
}

cloud "Algorand Blockchain" <<external>> {
    [Smart Contract Instance]
    [Transaction Pool]
}

cloud "AlgoSigner" <<external>> {
    [Wallet Interface]
}

' Frontend to Backend connections
APIClient --> Server : REST API calls\n(create project, fund, retrieve)

' Backend to Database connections
DBManager --> [Application Data] : CRUD operations

' Frontend to Blockchain connections
AppContext --> [Smart Contract Instance] : Algod client
ContractOperations --> [Smart Contract Instance] : contract interactions
TxOperations --> [Transaction Pool] : submit transactions
ContractOperations --> [Wallet Interface] : sign transactions

' Backend to Blockchain connections
Server --> ContractOps : trigger deployment

' Smart Contracts to Blockchain
ContractOps --> [Smart Contract Instance] : deploy & invoke
ContractUtils --> [Smart Contract Instance] : blockchain queries

' User interaction points
actor User
User --> Pages : browses
User --> [Wallet Interface] : connects wallet

note right of AppContext
  Provides global state management
  and Algod client to components
  using Provider Pattern
end note

note right of DAO
  Implements DAO pattern
  for database abstraction
end note

note right of ContractOps
  Implicit Factory pattern
  for creating compiled
  TEAL contracts
end note

note bottom of [Smart Contract Instance]
  Enforces crowdfunding rules:
  - Funding
  - Refunds
  - Fund collection
  - Platform fees
end note

@enduml
