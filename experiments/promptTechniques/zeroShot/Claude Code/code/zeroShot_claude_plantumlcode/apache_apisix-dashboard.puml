@startuml
!define RECTANGLE class

skinparam component {
  BackgroundColor<<frontend>> LightBlue
  BackgroundColor<<backend>> LightGreen
  BackgroundColor<<library>> LightYellow
  BackgroundColor<<storage>> LightGray
}

title Apache APISIX Dashboard - Deployment and Data Flow

package "Client Browser" {
  [Web Browser] as Browser
}

package "Frontend Application" <<frontend>> {
  [index.html] as HTML
  [main.tsx] as Main

  package "React Application" {
    [TanStack Router] as Router <<library>>
    [Route Components] as Routes

    package "UI Layer" {
      [Mantine UI Components] as Mantine <<library>>
      [Ant Design Pro Components] as AntD <<library>>
      [Form Components] as Forms
      [ProTable Components] as Tables
    }

    package "State Management" {
      [MobX Stores] as MobX <<library>>
      [Global Store] as GlobalStore
      [TanStack Query] as ReactQuery <<library>>
    }

    package "Data Layer" {
      [API Hooks] as Hooks
      [API Functions] as APIs
      [Axios Instance] as Axios <<library>>
    }

    package "Form Management" {
      [React Hook Form] as RHF <<library>>
      [Zod Schemas] as Zod <<library>>
      [Form Slices] as FormSlices
    }
  }

  [Vite Build Tool] as Vite <<library>>
}

package "Configuration" {
  [constant.ts] as Config
  [req.ts] as ReqConfig
  [Local Storage] as LocalStorage <<storage>>
}

package "Backend Services" <<backend>> {
  [APISIX Admin API] as AdminAPI

  package "APISIX Resources" {
    [Routes] as APIRoutes
    [Services] as APIServices
    [Upstreams] as APIUpstreams
    [Consumers] as APIConsumers
    [SSL Certificates] as APISSL
    [Plugins] as APIPlugins
  }
}

package "Testing Infrastructure" {
  [Playwright E2E Tests] as E2E
}

Browser --> HTML : HTTP Request
HTML --> Main : Load Application
Main --> Router : Initialize Routing
Main --> ReactQuery : Setup Query Client
Main --> Vite : Build & Serve

Router --> Routes : Navigate
Routes --> Forms : Render Forms
Routes --> Tables : Render Tables
Forms --> Mantine : Use UI Components
Tables --> AntD : Use ProTable
Forms --> RHF : Form State
RHF --> Zod : Validation
Forms --> FormSlices : Compose Form Parts

Routes --> Hooks : Fetch Data
Hooks --> ReactQuery : Query Management
Hooks --> APIs : API Calls
APIs --> Axios : HTTP Client
Axios --> ReqConfig : Request Configuration
ReqConfig --> Config : Load Constants
Axios --> AdminAPI : REST API Calls

AdminAPI --> APIRoutes : CRUD Operations
AdminAPI --> APIServices : CRUD Operations
AdminAPI --> APIUpstreams : CRUD Operations
AdminAPI --> APIConsumers : CRUD Operations
AdminAPI --> APISSL : CRUD Operations
AdminAPI --> APIPlugins : Manage Plugins

ReactQuery --> GlobalStore : Cache & State
GlobalStore --> MobX : Reactive State
MobX --> Routes : Update UI

Axios ..> LocalStorage : Store/Retrieve Admin Key
ReqConfig ..> LocalStorage : Authentication

Forms --> APIs : Submit Data
Tables --> Hooks : Load Table Data
Routes --> GlobalStore : Read Global State

E2E --> Browser : Automated Tests

note right of Axios
  Interceptors for:
  - Authentication
  - Error Handling
  - Skip Interceptor Flag
end note

note right of ReactQuery
  Manages:
  - Data Caching
  - Server State
  - Async Operations
end note

note left of AdminAPI
  HTTP REST API
  Endpoints for APISIX
  Resource Management
end note

note bottom of LocalStorage
  Stores:
  - Admin Key
  - User Preferences
end note

@enduml
