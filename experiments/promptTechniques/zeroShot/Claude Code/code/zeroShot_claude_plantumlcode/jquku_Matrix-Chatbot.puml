@startuml
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor User
participant "Matrix Homeserver" as Matrix
participant "main.py\n(Event Handler)" as Main
participant "nlp.py\n(NLP Pipeline)" as NLP
participant "message_evaluation.py\n(Intent Recognition)" as MessageEval
participant "database_service.py\n(DAO)" as DBService
database "PostgreSQL\n(Knowledge Base)" as DB
participant "response_management.py\n(Response Generator)" as ResponseMgmt

== Initialization ==
Main -> Matrix: Login with credentials from config.yaml
activate Main
activate Matrix
Matrix --> Main: Authentication successful
Main -> Matrix: Register event callbacks
Main -> Matrix: Start sync loop
deactivate Main
deactivate Matrix

== User Message Flow ==
User -> Matrix: Send message
activate Matrix
Matrix -> Main: Message event callback
activate Main
Main -> NLP: Process raw message
activate NLP
NLP -> NLP: Lowercase text
NLP -> NLP: Remove noise
NLP -> NLP: Tokenize
NLP -> NLP: Spell correction (autocorrect)
NLP -> NLP: Lemmatization (nltk)
NLP -> NLP: Remove stop words
NLP --> Main: Standardized tokens
deactivate NLP

Main -> MessageEval: Evaluate message intent
activate MessageEval
MessageEval -> DBService: Query knowledge domains
activate DBService
DBService -> DB: SELECT from knowledge base
activate DB
DB --> DBService: Domain data
deactivate DB
DBService --> MessageEval: Knowledge entries
deactivate DBService

MessageEval -> MessageEval: Calculate matching coefficients
MessageEval -> MessageEval: Identify relevant domains\n(lecture topics, small talk, organisation)
MessageEval -> MessageEval: Sort responses by relevance
MessageEval --> Main: Evaluated intent + sorted results
deactivate MessageEval

Main -> ResponseMgmt: Generate response
activate ResponseMgmt
ResponseMgmt -> DBService: Retrieve best matching answer
activate DBService
DBService -> DB: SELECT response data
activate DB
DB --> DBService: Response content
deactivate DB
DBService --> ResponseMgmt: Answer with metadata
deactivate DBService

ResponseMgmt -> ResponseMgmt: Format links and references
ResponseMgmt -> ResponseMgmt: Prepare response text

ResponseMgmt -> DBService: Update statistics
activate DBService
DBService -> DB: INSERT/UPDATE topic frequency
activate DB
DB --> DBService: Statistics updated
deactivate DB
deactivate DBService

ResponseMgmt --> Main: Formatted response
deactivate ResponseMgmt

Main -> Matrix: Send response message
activate Matrix
Matrix --> User: Display chatbot response
deactivate Matrix
deactivate Main
deactivate Matrix

== Room Invite Flow ==
User -> Matrix: Invite bot to room
activate Matrix
Matrix -> Main: Invite event callback
activate Main
Main -> Matrix: Accept invite and join room
Matrix --> User: Bot joined room
deactivate Main
deactivate Matrix

== Knowledge Base Population ==
Main -> Main: Initialize knowledge base
activate Main
Main -> "index_evaluation.py" as IndexEval: Scrape web indices
activate IndexEval
IndexEval -> IndexEval: Parse HTML with BeautifulSoup
IndexEval -> DBService: Store extracted knowledge
activate DBService
DBService -> DB: INSERT lecture topics
activate DB
DB --> DBService: Data stored
deactivate DB
deactivate DBService
deactivate IndexEval

Main -> "small_talk_evaluation.py" as SmallTalkEval: Load small talk
activate SmallTalkEval
SmallTalkEval -> SmallTalkEval: Parse small_talk.txt
SmallTalkEval -> DBService: Store phrases and responses
activate DBService
DBService -> DB: INSERT small talk entries
activate DB
DB --> DBService: Data stored
deactivate DB
deactivate DBService
deactivate SmallTalkEval

Main -> "organisation_evaluation.py" as OrgEval: Load organizational info
activate OrgEval
OrgEval -> OrgEval: Parse organisation.txt
OrgEval -> DBService: Store module information
activate DBService
DBService -> DB: INSERT organisation entries
activate DB
DB --> DBService: Data stored
deactivate DB
deactivate DBService
deactivate OrgEval
deactivate Main

@enduml
