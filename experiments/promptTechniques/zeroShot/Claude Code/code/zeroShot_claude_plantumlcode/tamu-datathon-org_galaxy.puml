@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<external>> LightBlue
    BackgroundColor<<service>> LightGreen
    BackgroundColor<<infrastructure>> LightYellow
}

package "Galaxy - Central Gateway" {
    component Router <<infrastructure>> {
        [Nginx Reverse Proxy]
    }

    component "Configuration" <<infrastructure>> {
        [routes.conf]
        [Environment Variables]
    }
}

package "Authentication & User Management" {
    component Gatekeeper <<service>> {
        [Authentication Service]
        [User Data Management]
    }
}

package "Event Management" {
    component OBOS <<service>> {
        [Event Management Service]
    }
}

package "Static Content" {
    component Gigabowser <<service>> {
        [Static Website]
    }
}

package "Deployment Infrastructure" {
    component "Heroku Platform" <<infrastructure>> {
        [Gatekeeper Instance]
        [OBOS Instance]
    }

    component "Docker Environment" <<infrastructure>> {
        [Docker Compose]
        [Local Development]
    }
}

package "CI/CD Pipeline" {
    component "GitHub Actions" <<infrastructure>> {
        [Deploy Gatekeeper Workflow]
        [Deploy OBOS Workflow]
        [Dependabot]
    }
}

cloud "Internet" {
    actor User
}

database "Shared Cookies" {
    [Session Data]
}

' User interactions
User --> [Nginx Reverse Proxy] : HTTP Requests\n(tamudatathon.com)

' Router routing logic
[Nginx Reverse Proxy] ..> [routes.conf] : uses
[routes.conf] ..> [Environment Variables] : configured by
[Nginx Reverse Proxy] --> Gatekeeper : routes /auth/*
[Nginx Reverse Proxy] --> OBOS : routes /events/*
[Nginx Reverse Proxy] --> Gigabowser : routes /*

' Authentication flow
[Nginx Reverse Proxy] ..> [Authentication Service] : delegates auth
[Authentication Service] --> [Session Data] : manages

' Shared cookie domain
[Nginx Reverse Proxy] --> [Session Data] : single domain\nfor shared cookies

' Deployment relationships
[GitHub Actions] --> [Heroku Platform] : deploys
[Deploy Gatekeeper Workflow] ..> [Gatekeeper Instance] : deploys
[Deploy OBOS Workflow] ..> [OBOS Instance] : deploys

' Development environment
[Docker Compose] ..> Router : orchestrates
[Docker Compose] ..> Gatekeeper : orchestrates

' Dependency management
[Dependabot] ..> Gatekeeper : updates submodule

' Service deployment
Gatekeeper ..> [Gatekeeper Instance] : deployed as
OBOS ..> [OBOS Instance] : deployed as

note right of [Nginx Reverse Proxy]
    Central routing component
    Uses envsubst for dynamic
    configuration
end note

note right of Gatekeeper
    Submodule dependency
    Handles authentication
    and user data
end note

note bottom of [Session Data]
    Single domain architecture
    enables shared cookies
    across all services
end note

note right of [GitHub Actions]
    Automated deployment
    with secret management
    for environment variables
end note

@enduml
