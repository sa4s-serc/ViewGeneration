@startuml
!define RECTANGLE rectangle
!define COMPONENT component

title Tag Engine v3 - Deployment Architecture

skinparam componentStyle rectangle

package "Google Cloud Platform" {

    package "Cloud Run Services" {
        component "Tag Engine API Service" as API {
            component "main.py\n(Flask Application)" as MainApp
            component "API Endpoints" as APIEndpoints
            component "Authentication\n(access.py)" as Auth
            component "DataCatalogController" as DCController
            component "DataplexController" as DPController
            component "JobManager" as JobMgr
            component "TaskManager" as TaskMgr
            component "TagEngineStoreHandler" as StoreHandler
            component "BigQueryUtils" as BQUtils
        }

        component "Tag Engine UI Service" as UI {
            component "Jinja2 Templates" as Templates
            component "UI Router" as UIRouter
            component "Settings Manager" as SettingsMgr
        }
    }

    package "Storage & Database" {
        database "Firestore" as Firestore {
            component "Tag Configurations" as TagConfigs
            component "Job Status" as JobStatus
            component "User Settings" as UserSettings
        }

        database "BigQuery" as BigQuery {
            component "Metadata Tables" as MetadataTables
            component "Tag History Tables" as HistoryTables
            component "Export Tables" as ExportTables
        }

        cloud "Cloud Storage (GCS)" as GCS {
            component "CSV Import Files" as CSVFiles
        }
    }

    package "Google Cloud APIs" {
        component "Data Catalog API" as DataCatalogAPI {
            component "Tag Templates" as TagTemplates
            component "Tag Management" as TagMgmt
        }

        component "Dataplex API" as DataplexAPI {
            component "Aspect Types" as AspectTypes
            component "Aspect Management" as AspectMgmt
        }
    }

    package "Asynchronous Processing" {
        component "Cloud Tasks" as CloudTasks {
            component "Tag Creation Tasks" as TagTasks
            component "Job Split Tasks" as JobSplitTasks
        }
    }

    package "Identity & Access" {
        component "OAuth 2.0" as OAuth
        component "IAM Roles" as IAM
        component "Service Account" as ServiceAccount
    }

    package "CI/CD" {
        component "Cloud Build" as CloudBuild {
            component "cloudbuild.yaml" as BuildConfig
        }

        component "Terraform" as Terraform {
            component "Infrastructure as Code" as IaC
        }
    }
}

actor "End User" as User
actor "API Consumer" as APIUser

' User interactions
User --> UI : "Access Web Interface"
APIUser --> API : "API Calls"

' UI to API communication
UI --> API : "Internal API Calls"
UIRouter --> MainApp
Templates --> UIRouter
SettingsMgr --> StoreHandler

' API internal flow
MainApp --> APIEndpoints
MainApp --> Auth
APIEndpoints --> DCController
APIEndpoints --> DPController
APIEndpoints --> JobMgr
APIEndpoints --> StoreHandler

' Authentication flow
Auth --> OAuth : "Verify User"
Auth --> IAM : "Check Permissions"
Auth --> ServiceAccount : "Use Service Account"

' Controller interactions
DCController --> DataCatalogAPI : "Manage Tags"
DPController --> DataplexAPI : "Manage Aspects"
DCController --> BQUtils
DPController --> BQUtils

' Data Catalog API interactions
DataCatalogAPI --> TagTemplates
DataCatalogAPI --> TagMgmt

' Dataplex API interactions
DataplexAPI --> AspectTypes
DataplexAPI --> AspectMgmt

' Job and Task management
JobMgr --> TaskMgr : "Create Tasks"
TaskMgr --> CloudTasks : "Enqueue Tasks"
CloudTasks --> API : "Execute Tag Operations"
TagTasks --> DCController
TagTasks --> DPController
JobSplitTasks --> JobMgr

' Storage interactions
StoreHandler --> Firestore : "Read/Write"
StoreHandler --> TagConfigs
StoreHandler --> JobStatus
StoreHandler --> UserSettings

' BigQuery interactions
BQUtils --> BigQuery : "Query/Write"
BQUtils --> MetadataTables : "Read Metadata"
BQUtils --> HistoryTables : "Write Tag History"
BQUtils --> ExportTables : "Export Tags"
DCController --> HistoryTables : "Store Tag History"

' GCS interactions
StoreHandler --> GCS : "Read CSV Files"
CSVFiles --> StoreHandler

' Deployment flow
CloudBuild --> API : "Deploy API Service"
CloudBuild --> UI : "Deploy UI Service"
BuildConfig --> CloudBuild
Terraform --> CloudBuild : "Provision Infrastructure"
IaC --> Terraform

note right of API
  Deployed as Cloud Run Service
  Handles API requests and
  tag management operations
end note

note right of UI
  Deployed as Cloud Run Service
  Provides web interface for
  configuration and monitoring
end note

note bottom of CloudTasks
  Asynchronous processing of
  tag creation and update jobs
  Enables scalability
end note

note bottom of Firestore
  Configuration storage
  - Tag configurations
  - Job status tracking
  - User settings
end note

note bottom of BigQuery
  Data and history storage
  - Metadata queries
  - Tag history
  - Export results
end note

@enduml
