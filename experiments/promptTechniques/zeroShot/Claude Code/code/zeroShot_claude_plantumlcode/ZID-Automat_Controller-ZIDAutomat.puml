@startuml

skinparam component {
    BackgroundColor LightBlue
    BorderColor Black
}

skinparam package {
    BackgroundColor WhiteSmoke
    BorderColor DarkGray
}

skinparam rectangle {
    BackgroundColor LightGreen
    BorderColor DarkGreen
}

title ZID-Automat Controller - Component Diagram

package "ESP32 Controller" {
    component "main.py" as main
    component "boot.py" as boot

    package "Core Module" {
        component "Main12.py\n(Main123 class)" as main123
    }

    package "Borrow Module" {
        component "Borrow.py\n(BorrowM class)" as borrow

        package "Borrow Dependencies" {
            component "QRCodeReader.py" as qrreader
            component "Eject.py" as eject
            component "LoadBorrowData" as loaddata
        }
    }

    package "API Module" {
        component "Requests.py\n(Requestsi class)" as requests
    }

    package "Data Collection Module" {
        component "DataCollect.py" as datacollect
    }

    package "UI Module" {
        component "ScreenOutput.py" as screen
        component "mp_i2c_lcd1602.py" as lcdlib
    }

    component "Configuration.json" as config
}

rectangle "Hardware Components" {
    component "QR Code Reader\n(Serial)" as qrhw
    component "Ejection Mechanism\n(GPIO)" as ejecthw
    component "I2C LCD Display" as lcdhw
    component "NeoPixel LED Strip" as ledhw
}

rectangle "Backend System" {
    component "Backend API" as api
    database "Backend Database" as db
}

main --> main123 : instantiates
boot --> main123 : initialization

main123 --> borrow : orchestrates
main123 --> requests : uses
main123 --> screen : provides
main123 --> datacollect : uses
main123 --> config : reads
main123 --> ledhw : controls

borrow --> qrreader : reads QR codes
borrow --> eject : triggers ejection
borrow --> loaddata : validates data
borrow --> requests : receives dependency
borrow --> screen : receives dependency

qrreader --> qrhw : serial communication

eject --> ejecthw : controls GPIO pins

screen --> lcdlib : uses
lcdlib --> lcdhw : I2C communication

requests --> api : HTTP requests\n(GET, POST, PATCH)
loaddata --> requests : uses
datacollect --> requests : uses

api --> db : stores/retrieves

note right of requests
  JWT Management
  Authentication
  API Communication
end note

note right of borrow
  Borrowing Process:
  1. QR Code Scan
  2. Backend Validation
  3. Item Location Retrieval
  4. Ejection Trigger
  5. Event Logging
end note

note bottom of config
  Contains:
  - WLAN credentials
  - Backend URL
  - Pin assignments
  - LED configuration
end note

note right of eject
  Strategy Pattern:
  Simulates keyboard presses
  based on item location
end note

@enduml
