@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<Core>> LightBlue
    BackgroundColor<<Utility>> LightGreen
    BackgroundColor<<External>> LightGray
    BorderColor Black
    ArrowColor Black
}

package "ShadeSwap Ecosystem" {

    package "Core Contracts" <<Core>> {
        component "LP Token\n(SNIP-20)" as LPToken {
            portin IReceive
            portout ITransfer
            portout IMint
            portout IBurn
        }

        component "Staking Contract" as Staking {
            portin IStake
            portin IUnstake
            portin IClaim
        }

        component "AMM Pair Contract" as AMMPair {
            portin ISwap
            portin ILiquidity
            portout IFees
        }

        component "Factory Contract" as Factory {
            portin ICreate
            portout IDeploy
        }

        component "Router Contract" as Router {
            portin IMultiHop
            portout ICallback
        }

        component "Admin Contract" as Admin {
            portin IPermissions
            portout IControl
        }
    }

    package "Shared Utilities" <<Utility>> {
        component "shadeswap-shared" as Shared {
            portin ITypes
            portin IMessages
        }

        component "Multi-Test Environment" as MultiTest {
            portin ITestSupport
        }
    }

    package "Contract Modules" {
        component "Contract Module" as ContractMod
        component "Operations Module" as OpsMod
        component "Query Module" as QueryMod
        component "State Module" as StateMod
        component "Receiver Module" as ReceiverMod
        component "Batch Module" as BatchMod
    }
}

package "External Dependencies" <<External>> {
    component "secret-toolkit" as SecretToolkit {
        portout IPrivacy
        portout IViewingKeys
    }

    component "cosmwasm-storage" as CosmWasmStorage {
        portout IStorage
    }

    component "Secret Network" as SecretNetwork
}

package "Testing & Deployment" {
    component "Integration Tests" as IntegrationTests
    component "Network Integration" as NetworkIntegration
    component "Docker Build" as Docker
}

' Core Contract Relationships
Factory ..> AMMPair : <<deploys>>
Factory ..> LPToken : <<creates>>
Router ..> AMMPair : <<orchestrates>>
Router ..> AMMPair : <<callback>>
Staking ..> LPToken : <<stakes>>
AMMPair ..> LPToken : <<manages>>
Admin ..> Factory : <<controls>>
Admin ..> AMMPair : <<controls>>
Admin ..> Staking : <<controls>>
Admin ..> Router : <<controls>>

' Module Usage
LPToken *-- ContractMod
LPToken *-- ReceiverMod
LPToken *-- BatchMod
LPToken *-- StateMod
Staking *-- OpsMod
Staking *-- QueryMod
Staking *-- StateMod

' Shared Dependencies
LPToken ..> Shared : <<uses>>
Staking ..> Shared : <<uses>>
AMMPair ..> Shared : <<uses>>
Factory ..> Shared : <<uses>>
Router ..> Shared : <<uses>>
Admin ..> Shared : <<uses>>

' External Dependencies
LPToken ..> SecretToolkit : <<privacy>>
Staking ..> SecretToolkit : <<privacy>>
AMMPair ..> SecretToolkit : <<privacy>>
LPToken ..> CosmWasmStorage : <<persists>>
Staking ..> CosmWasmStorage : <<persists>>
AMMPair ..> CosmWasmStorage : <<persists>>
Factory ..> CosmWasmStorage : <<persists>>

' Testing Dependencies
IntegrationTests ..> LPToken : <<tests>>
IntegrationTests ..> Staking : <<tests>>
IntegrationTests ..> AMMPair : <<tests>>
MultiTest ..> IntegrationTests : <<supports>>
NetworkIntegration ..> SecretNetwork : <<deploys>>
Docker ..> NetworkIntegration : <<builds>>

' Token Flow
LPToken -[#Green]-> Staking : "LP Tokens"
AMMPair -[#Green]-> LPToken : "Mint/Burn"
Staking -[#Orange]-> LPToken : "Rewards"

' Data Flow
Router -[#Blue]-> AMMPair : "Swap Requests"
AMMPair -[#Blue]-> Router : "Swap Results"

note right of Factory
  Uses Factory Pattern
  to deploy AMM Pairs
  and LP Tokens with
  code hash verification
end note

note right of Router
  Facilitates multi-hop
  swaps using callback
  pattern for complex
  interactions
end note

note right of LPToken
  SNIP-20 compliant
  Privacy-focused token
  with viewing keys
end note

note right of Staking
  Multi-reward staking
  Supports proxy staking
  for delegation
end note

note bottom of SecretToolkit
  Provides privacy features:
  - Viewing Keys
  - Authenticated Queries
  - SNIP-20 Implementation
end note

@enduml
