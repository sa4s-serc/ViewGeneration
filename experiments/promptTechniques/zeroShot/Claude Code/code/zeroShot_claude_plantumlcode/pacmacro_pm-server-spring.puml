@startuml
!define CONTROLLER #LightBlue
!define MANAGER #LightGreen
!define REGISTRY #LightYellow
!define REPOSITORY #LightCoral

title Pac Macro Game Server - Control Flow and Deployment Sequence

actor Client
participant "HomeController" as Home CONTROLLER
participant "PlayerController" as PC CONTROLLER
participant "GameStateController" as GSC CONTROLLER
participant "PacdotController" as PDC CONTROLLER
participant "TagController" as TC CONTROLLER
participant "AdminController" as AC CONTROLLER

participant "PlayerManager" as PM MANAGER
participant "GameStateManager" as GSM MANAGER
participant "PacdotManager" as PDM MANAGER
participant "TagManager" as TM MANAGER
participant "AdminManager" as AM MANAGER

participant "PlayerRegistry" as PR REGISTRY
participant "GameStateRegistry" as GSR REGISTRY
participant "PacdotRegistry" as PDTR REGISTRY
participant "TagRegistry" as TR REGISTRY

participant "PlayerRepository" as PREP REPOSITORY
participant "PacdotRepository" as PDREPO REPOSITORY

participant "ValidationUtils" as VU
participant "CustomExceptionHandler" as EH

== Game Initialization ==
Client -> AC: POST /admin/initialize
activate AC
AC -> AM: initializeGame()
activate AM
AM -> GSR: resetGameState()
activate GSR
GSR --> AM: game state reset
deactivate GSR
AM -> PR: clearPlayers()
activate PR
PR --> AM: players cleared
deactivate PR
AM -> PDTR: loadPacdots()
activate PDTR
PDTR -> PDREPO: getAllPacdots()
activate PDREPO
PDREPO --> PDTR: pacdots list
deactivate PDREPO
PDTR --> AM: pacdots loaded
deactivate PDTR
AM --> AC: initialization complete
deactivate AM
AC --> Client: 200 OK
deactivate AC

== Player Selection ==
Client -> PC: POST /player/select
activate PC
PC -> VU: validateRequest()
activate VU
VU --> PC: validation result
deactivate VU
PC -> PM: selectPlayer(playerId)
activate PM
PM -> PR: getPlayer(playerId)
activate PR
PR -> PREP: findById(playerId)
activate PREP
PREP --> PR: player data
deactivate PREP
PR --> PM: player
deactivate PR
PM -> PR: updatePlayerState(player, selected)
activate PR
PR -> PREP: save(player)
activate PREP
PREP --> PR: saved
deactivate PREP
PR --> PM: updated
deactivate PR
PM -> GSR: updateGameState()
activate GSR
GSR --> PM: state updated
deactivate GSR
PM --> PC: PlayerDetailsResponse
deactivate PM
PC --> Client: 200 OK with player details
deactivate PC

== Location Update ==
Client -> PC: PUT /player/location
activate PC
PC -> VU: validateLocationRequest()
activate VU
VU --> PC: validation result
deactivate VU
PC -> PM: updatePlayerLocation(playerId, coordinate)
activate PM
PM -> PR: getPlayer(playerId)
activate PR
PR --> PM: player
deactivate PR
PM -> PR: updateLocation(player, coordinate)
activate PR
PR --> PM: location updated
deactivate PR
PM --> PC: PlayerDetailsResponse
deactivate PM
PC --> Client: 200 OK
deactivate PC

== Game State Check ==
Client -> GSC: GET /gamestate
activate GSC
GSC -> GSM: getGameState()
activate GSM
GSM -> GSR: getCurrentState()
activate GSR
GSR --> GSM: game state
deactivate GSR
GSM -> PR: getAlivePlayers()
activate PR
PR --> GSM: alive players count
deactivate PR
GSM -> PDTR: getUneattenPacdotsCount()
activate PDTR
PDTR --> GSM: uneaten count
deactivate PDTR
GSM -> GSM: determineGameStatus()
GSM --> GSC: GameStateResponse
deactivate GSM
GSC --> Client: 200 OK with game state
deactivate GSC

== Pacdot Retrieval ==
Client -> PDC: GET /pacdot/uneaten
activate PDC
PDC -> PDM: getUneattenPacdots()
activate PDM
PDM -> PDTR: getUneattenPacdots()
activate PDTR
PDTR --> PDM: uneaten pacdots list
deactivate PDTR
PDM --> PDC: pacdots list
deactivate PDM
PDC --> Client: 200 OK with pacdots
deactivate PDC

== Tag Interaction ==
Client -> TC: POST /tag
activate TC
TC -> VU: validateTagRequest()
activate VU
VU --> TC: validation result
deactivate VU
TC -> TM: registerTag(taggerId, taggedId)
activate TM
TM -> PR: getPlayer(taggerId)
activate PR
PR --> TM: tagger player
deactivate PR
TM -> PR: getPlayer(taggedId)
activate PR
PR --> TM: tagged player
deactivate PR
TM -> TM: validateTagRules()
TM -> TR: recordTag(taggerId, taggedId)
activate TR
TR --> TM: tag recorded
deactivate TR
TM -> PR: updatePlayerState(taggedPlayer, dead)
activate PR
PR --> TM: state updated
deactivate PR
TM -> GSR: updateGameState()
activate GSR
GSR --> TM: state updated
deactivate GSR
TM --> TC: tag result
deactivate TM
TC --> Client: 200 OK
deactivate TC

== Exception Handling ==
Client -> PC: POST /player/invalid
activate PC
PC -> PM: invalidOperation()
activate PM
PM -> PR: operationFails()
activate PR
PR --> PM: PmServerException
deactivate PR
PM --> PC: PmServerException
deactivate PM
PC --> EH: handle(PmServerException)
activate EH
EH -> EH: createErrorResponse()
EH --> Client: 4xx/5xx Error Response
deactivate EH
deactivate PC

@enduml
