@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<chef>> LightYellow
    BackgroundColor<<wso2>> LightBlue
    BackgroundColor<<external>> LightGreen
    BackgroundColor<<database>> LightCoral
}

package "Chef Infrastructure" {
    [Chef Server] <<chef>>
    [Berksfile] <<chef>>
    [Chef Supermarket] <<chef>>
}

package "Chef Cookbook Components" {
    [metadata.rb] <<chef>>
    [attributes/default.rb] <<chef>>
    [recipes/default.rb] <<chef>>
    [recipes/java_installation.rb] <<chef>>
    [recipes/wso2_apim_installation.rb] <<chef>>
    [recipes/apply_template.rb] <<chef>>
    [ERB Templates] <<chef>>
}

package "WSO2 API Manager Deployment Profiles" {
    component "Key Manager" <<wso2>> {
        [Key Manager Instance]
        [carbon.xml - KM]
        [axis2.xml - KM]
        [master-datasources.xml - KM]
    }

    component "Publisher" <<wso2>> {
        [Publisher Instance]
        [carbon.xml - PUB]
        [axis2.xml - PUB]
        [master-datasources.xml - PUB]
    }

    component "Store" <<wso2>> {
        [Store Instance]
        [carbon.xml - ST]
        [axis2.xml - ST]
        [master-datasources.xml - ST]
    }

    component "Traffic Manager" <<wso2>> {
        [Traffic Manager Instance]
        [carbon.xml - TM]
        [axis2.xml - TM]
        [master-datasources.xml - TM]
    }

    component "Gateway Manager" <<wso2>> {
        [Gateway Manager Instance]
        [carbon.xml - GM]
        [axis2.xml - GM]
        [master-datasources.xml - GM]
    }

    component "Gateway Worker" <<wso2>> {
        [Gateway Worker Instance]
        [carbon.xml - GW]
        [axis2.xml - GW]
        [master-datasources.xml - GW]
    }
}

package "External Dependencies" {
    [Java JDK] <<external>>
    [WSO2 APIM 2.2.0 Distribution] <<external>>
}

database "MySQL Database" <<database>> {
    [API Manager DB]
    [User Management DB]
    [Registry DB]
}

package "Clustering" {
    cloud "Cluster Network" {
        [Hazelcast]
        [Axis2 Clustering]
    }
}

' Chef Infrastructure Connectivity
[Berksfile] --> [Chef Supermarket] : fetch cookbooks
[Chef Server] --> [metadata.rb] : manages
[Chef Server] --> [recipes/default.rb] : executes

' Recipe Dependencies
[recipes/default.rb] --> [attributes/default.rb] : reads configuration
[recipes/default.rb] --> [recipes/java_installation.rb] : includes
[recipes/default.rb] --> [recipes/wso2_apim_installation.rb] : includes
[recipes/default.rb] --> [recipes/apply_template.rb] : includes

' Template Application
[recipes/apply_template.rb] --> [ERB Templates] : uses
[attributes/default.rb] --> [ERB Templates] : provides values

' Java Installation
[recipes/java_installation.rb] --> [Java JDK] : downloads & installs

' WSO2 Installation
[recipes/wso2_apim_installation.rb] --> [WSO2 APIM 2.2.0 Distribution] : downloads & installs

' Configuration Generation - Key Manager
[ERB Templates] --> [carbon.xml - KM] : generates
[ERB Templates] --> [axis2.xml - KM] : generates
[ERB Templates] --> [master-datasources.xml - KM] : generates

' Configuration Generation - Publisher
[ERB Templates] --> [carbon.xml - PUB] : generates
[ERB Templates] --> [axis2.xml - PUB] : generates
[ERB Templates] --> [master-datasources.xml - PUB] : generates

' Configuration Generation - Store
[ERB Templates] --> [carbon.xml - ST] : generates
[ERB Templates] --> [axis2.xml - ST] : generates
[ERB Templates] --> [master-datasources.xml - ST] : generates

' Configuration Generation - Traffic Manager
[ERB Templates] --> [carbon.xml - TM] : generates
[ERB Templates] --> [axis2.xml - TM] : generates
[ERB Templates] --> [master-datasources.xml - TM] : generates

' Configuration Generation - Gateway Manager
[ERB Templates] --> [carbon.xml - GM] : generates
[ERB Templates] --> [axis2.xml - GM] : generates
[ERB Templates] --> [master-datasources.xml - GM] : generates

' Configuration Generation - Gateway Worker
[ERB Templates] --> [carbon.xml - GW] : generates
[ERB Templates] --> [axis2.xml - GW] : generates
[ERB Templates] --> [master-datasources.xml - GW] : generates

' Database Connectivity
[Key Manager Instance] --> [API Manager DB] : JDBC
[Key Manager Instance] --> [User Management DB] : JDBC
[Key Manager Instance] --> [Registry DB] : JDBC

[Publisher Instance] --> [API Manager DB] : JDBC
[Publisher Instance] --> [Registry DB] : JDBC

[Store Instance] --> [API Manager DB] : JDBC
[Store Instance] --> [Registry DB] : JDBC

[Traffic Manager Instance] --> [API Manager DB] : JDBC
[Traffic Manager Instance] --> [Registry DB] : JDBC

[Gateway Manager Instance] --> [API Manager DB] : JDBC
[Gateway Manager Instance] --> [Registry DB] : JDBC

[Gateway Worker Instance] --> [API Manager DB] : JDBC
[Gateway Worker Instance] --> [Registry DB] : JDBC

' Clustering Connectivity
[Key Manager Instance] --> [Hazelcast] : cluster membership
[Publisher Instance] --> [Hazelcast] : cluster membership
[Store Instance] --> [Hazelcast] : cluster membership
[Traffic Manager Instance] --> [Hazelcast] : cluster membership
[Gateway Manager Instance] --> [Hazelcast] : cluster membership
[Gateway Worker Instance] --> [Hazelcast] : cluster membership

[Key Manager Instance] --> [Axis2 Clustering] : message exchange
[Publisher Instance] --> [Axis2 Clustering] : message exchange
[Store Instance] --> [Axis2 Clustering] : message exchange
[Traffic Manager Instance] --> [Axis2 Clustering] : message exchange
[Gateway Manager Instance] --> [Axis2 Clustering] : message exchange
[Gateway Worker Instance] --> [Axis2 Clustering] : message exchange

' Inter-component Communication
[Publisher Instance] ..> [Key Manager Instance] : OAuth/Authentication
[Store Instance] ..> [Key Manager Instance] : OAuth/Authentication
[Gateway Manager Instance] ..> [Key Manager Instance] : OAuth/Authentication
[Gateway Worker Instance] ..> [Key Manager Instance] : OAuth/Authentication

[Gateway Manager Instance] ..> [Traffic Manager Instance] : throttling events
[Gateway Worker Instance] ..> [Traffic Manager Instance] : throttling events

[Publisher Instance] ..> [Gateway Manager Instance] : API deployment
[Store Instance] ..> [Publisher Instance] : API metadata

note right of [Cluster Network]
  Hazelcast: Distributed caching
  and cluster coordination

  Axis2: Message-based
  communication between nodes
end note

note bottom of [MySQL Database]
  Centralized data storage
  for all WSO2 APIM profiles

  Configured via
  master-datasources.xml
end note

@enduml
