@startuml
!define COMPONENT_BG_COLOR #E8F5E9
!define INTERFACE_COLOR #4CAF50

skinparam component {
  BackgroundColor COMPONENT_BG_COLOR
  BorderColor #2E7D32
  ArrowColor #1B5E20
}

skinparam interface {
  BackgroundColor INTERFACE_COLOR
  BorderColor #2E7D32
}

title ARGAEL System - Component Architecture

package "GUI Layer" {
  component [ArgaelForm] as GUI {
    [Simple View]
    [Assisted View]
    [Evaluation View]
  }
  component [ReportFormatter] as Report
}

package "Data Management Layer" {
  component [DataManager] as DataMgr
  component [ArgumentModel] as ArgModel
  component [TreeNode] as Tree
  component [SelectedItems] as Selected
  component [InitParams] as InitParam
}

package "IO Layer" {
  component [IOManager] as IOMgr
  component [FileUtils] as FileUtil
  component [StringUtils] as StrUtil
}

package "Configuration" {
  file "params.json" as ParamsJSON
  file "users.txt" as UsersTXT
}

package "Data Storage" {
  database "JSONL Files" as JSONL {
    folder "proposals/*.jsonl" as Proposals
  }
  folder "HTML Templates" as Templates {
    file "views/*.html" as Views
  }
}

package "External Output" {
  file "HTML Reports" as HTMLReport
}

' GUI Layer relationships
GUI --> DataMgr : manages data
GUI --> Report : generates reports
GUI --> InitParam : reads configuration
GUI --> IOMgr : read/write operations

' Data Management relationships
DataMgr --> ArgModel : uses
DataMgr --> Tree : manages threads
DataMgr --> Selected : tracks selections
DataMgr --> IOMgr : persistence

InitParam --> ParamsJSON : reads

ArgModel ..> ParamsJSON : configured by
Tree --> ArgModel : contains

' IO Layer relationships
IOMgr --> FileUtil : file operations
IOMgr --> StrUtil : string processing
IOMgr --> JSONL : read/write
IOMgr --> UsersTXT : manages users

FileUtil --> JSONL : access
FileUtil --> UsersTXT : access
FileUtil --> ParamsJSON : access

' Report generation
Report --> Templates : uses templates
Report --> HTMLReport : generates
Report --> DataMgr : retrieves data

' Data flow
ParamsJSON ..> ArgModel : defines model
JSONL --> DataMgr : loads data
DataMgr --> JSONL : saves annotations

' User management
UsersTXT ..> GUI : authenticates

note right of GUI
  Main desktop application interface
  Supports multiple annotation views
  Multi-user annotation support
end note

note right of DataMgr
  Manages argument annotations
  Handles evaluation metrics
  Supports inter-annotator agreement
end note

note right of IOMgr
  Handles all I/O operations
  Supports JSONL and CSV formats
  Factory pattern for readers/writers
end note

note right of ParamsJSON
  Configures argument models
  Defines evaluation metrics
  Supports user-defined parameters
end note

note right of JSONL
  Proposal-centric organization
  Flat file database structure
  One file per proposal with comments
end note

note bottom of ArgModel
  Defines argumentative components:
  - Claims and premises
  - Support/attack relationships
  - Quality assessment metrics
end note

@enduml
