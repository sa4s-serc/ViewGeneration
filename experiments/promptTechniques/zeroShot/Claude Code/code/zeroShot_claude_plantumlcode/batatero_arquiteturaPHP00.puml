@startuml

skinparam component {
    BackgroundColor<<framework>> LightBlue
    BackgroundColor<<application>> LightGreen
    BackgroundColor<<orm>> LightYellow
    BackgroundColor<<external>> LightGray
}

package "CodeIgniter Framework" <<framework>> {
    component [Front Controller\n(index.php)] as FrontController

    package "Core Libraries" {
        component [Input/Security] as InputSecurity
        component [Session] as Session
        component [Email] as Email
        component [Upload] as Upload
        component [Image Library] as ImageLib
        component [Cart] as Cart
        component [Other Libraries] as OtherLibs
    }

    package "Database Layer" {
        component [CI_DB_driver] as DBDriver
        component [Active Record] as ActiveRecord
        component [DB_forge] as DBForge
        component [DB_utility] as DBUtility
    }

    component [Helper Functions] as Helpers
    component [Configuration] as Config
}

package "Application Layer" <<application>> {
    component [Controller] as Controller
    component [Facade] as Facade
    component [Business Logic] as Business

    package "DAO Layer" {
        component [GenericDAO] as GenericDAO
        component [Specific DAOs] as SpecificDAOs
    }

    component [Factory Business] as FactoryBusiness
    component [Factory DAO] as FactoryDAO
}

package "Doctrine ORM" <<orm>> {
    component [EntityManager] as EntityManager
    component [Unit of Work] as UnitOfWork
    component [Entity Repository] as EntityRepository
    component [ClassMetadata] as ClassMetadata

    package "Annotation Parser" {
        component [AnnotationReader] as AnnotationReader
    }

    package "Query System" {
        component [DQL Parser] as DQLParser
        component [SQL Generator] as SQLGenerator
        component [Hydrator] as Hydrator
    }

    component [Schema Manager] as SchemaManager

    package "Platform Abstraction" {
        component [MySqlPlatform] as MySqlPlatform
        component [PostgreSqlPlatform] as PostgreSqlPlatform
        component [Other Platforms] as OtherPlatforms
    }

    package "DBAL Drivers" {
        component [PDO MySQL] as PDOMySQL
        component [PDO SQLServer] as PDOSqlSrv
        component [Other Drivers] as OtherDrivers
    }

    component [Cache System] as CacheSystem

    package "Persisters" {
        component [EntityPersister] as EntityPersister
        component [CollectionPersister] as CollectionPersister
    }
}

package "Symfony Components" <<external>> {
    component [YAML Parser] as YAML
    component [Console Component] as Console
}

database "Database" as DB

FrontController --> Controller : routes request
Controller ..> Config : reads
Controller ..> InputSecurity : uses
Controller ..> Session : uses
Controller ..> Email : uses
Controller --> Facade : delegates to

Facade --> Business : calls

Business ..> FactoryBusiness : created by
Business --> GenericDAO : uses
Business --> SpecificDAOs : uses
Business ..> InputSecurity : uses

GenericDAO <|-- SpecificDAOs : extends
GenericDAO ..> FactoryDAO : created by
SpecificDAOs ..> FactoryDAO : created by

GenericDAO --> EntityManager : uses
SpecificDAOs --> EntityManager : uses

EntityManager --> UnitOfWork : manages
EntityManager --> EntityRepository : provides
EntityManager ..> ClassMetadata : uses
UnitOfWork --> EntityPersister : uses
UnitOfWork --> CollectionPersister : uses

EntityPersister --> MySqlPlatform : uses
EntityPersister --> PostgreSqlPlatform : uses
CollectionPersister --> MySqlPlatform : uses
CollectionPersister --> PostgreSqlPlatform : uses

ClassMetadata <.. AnnotationReader : reads and generates

EntityManager --> DQLParser : executes queries
DQLParser --> SQLGenerator : converts
SQLGenerator --> Hydrator : passes results
Hydrator ..> EntityManager : returns entities

SchemaManager --> MySqlPlatform : uses
SchemaManager --> PostgreSqlPlatform : uses
MySqlPlatform --> PDOMySQL : uses
PostgreSqlPlatform --> OtherDrivers : uses

DQLParser ..> CacheSystem : caches results
EntityPersister --> PDOMySQL : persists via
CollectionPersister --> PDOMySQL : persists via

DBDriver --> DB : connects
ActiveRecord --|> DBDriver : extends

EntityManager ..> YAML : configuration
Console ..> SchemaManager : CLI commands

Helpers ..> Controller : assists
Session ..> Controller : state management

note right of FrontController
    Entry point for all requests
    .htaccess for URL rewriting
end note

note right of Facade
    Simplified interface
    to business layer
end note

note bottom of GenericDAO
    Data Access Layer
    Low coupling, High cohesion
end note

note right of EntityManager
    Tracks entity lifecycle:
    new, managed, detached, removed
end note

note bottom of MySqlPlatform
    Database abstraction
    for vendor-specific SQL
end note

@enduml
