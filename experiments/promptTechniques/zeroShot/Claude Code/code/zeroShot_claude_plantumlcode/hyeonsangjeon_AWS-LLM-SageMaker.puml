@startuml
!define RECTANGLE class

participant "User" as user
participant "Streamlit UI" as streamlit
participant "streamlit_util" as streamlit_util
participant "inference_lib" as inference_lib
participant "Prompter" as prompter
participant "OpenSearch" as opensearch
participant "FAISS VectorStore" as faiss
participant "SageMaker\nEmbedding Endpoint" as embedding_endpoint
participant "KoLLMSageMakerEndpoint" as kollm_endpoint
participant "SageMaker\nLLM Endpoint" as llm_endpoint
participant "DJLServing" as djl
participant "DeepSpeed" as deepspeed
participant "KULLM Model" as model

title RAG-based Korean Financial Q&A Chatbot - Control Flow

== Initialization Phase ==
streamlit -> streamlit_util: initialize_content_handlers()
activate streamlit_util
streamlit_util --> streamlit: handlers_ready
deactivate streamlit_util

streamlit -> embedding_endpoint: create_embedding_model()
activate embedding_endpoint
embedding_endpoint --> streamlit: embedding_model_ready
deactivate embedding_endpoint

streamlit -> opensearch: connect_to_opensearch()
activate opensearch
opensearch --> streamlit: connection_established
deactivate opensearch

streamlit -> faiss: initialize_vector_store()
activate faiss
faiss --> streamlit: vector_store_ready
deactivate faiss

== Document Indexing Phase ==
streamlit -> streamlit_util: transform_documents()
activate streamlit_util
streamlit_util --> streamlit: transformed_documents
deactivate streamlit_util

streamlit -> embedding_endpoint: generate_embeddings(documents)
activate embedding_endpoint
embedding_endpoint --> streamlit: document_embeddings
deactivate embedding_endpoint

streamlit -> opensearch: index_documents(documents, embeddings)
activate opensearch
opensearch --> streamlit: indexing_complete
deactivate opensearch

streamlit -> faiss: add_vectors(embeddings)
activate faiss
faiss --> streamlit: vectors_added
deactivate faiss

== Query Processing Phase ==
user -> streamlit: submit_question(query)
activate streamlit

streamlit -> inference_lib: preprocess_query(query)
activate inference_lib
inference_lib --> streamlit: preprocessed_query
deactivate inference_lib

streamlit -> embedding_endpoint: generate_query_embedding(query)
activate embedding_endpoint
embedding_endpoint --> streamlit: query_embedding
deactivate embedding_endpoint

== Document Retrieval Phase ==
streamlit -> opensearch: search_similar_documents(query_embedding)
activate opensearch
opensearch --> streamlit: retrieved_documents
deactivate opensearch

alt Local Search Testing
    streamlit -> faiss: similarity_search(query_embedding)
    activate faiss
    faiss --> streamlit: similar_vectors
    deactivate faiss
end

== Prompt Generation Phase ==
streamlit -> prompter: build_prompt(query, context)
activate prompter
prompter -> prompter: load_template()
prompter -> prompter: format_prompt(query, retrieved_documents)
prompter --> streamlit: formatted_prompt
deactivate prompter

== LLM Inference Phase ==
streamlit -> kollm_endpoint: invoke_endpoint(formatted_prompt)
activate kollm_endpoint

kollm_endpoint -> llm_endpoint: send_request(prompt)
activate llm_endpoint

llm_endpoint -> djl: process_inference(prompt)
activate djl

djl -> deepspeed: optimize_inference()
activate deepspeed
deepspeed --> djl: optimized_config
deactivate deepspeed

djl -> model: generate_response(prompt)
activate model
model -> model: apply_lora_weights()
model -> model: generate_text()
model --> djl: generated_text
deactivate model

djl --> llm_endpoint: inference_result
deactivate djl

llm_endpoint --> kollm_endpoint: response_data
deactivate llm_endpoint

kollm_endpoint -> inference_lib: parse_response(response_data)
activate inference_lib
inference_lib --> kollm_endpoint: parsed_response
deactivate inference_lib

kollm_endpoint --> streamlit: final_answer
deactivate kollm_endpoint

== Streaming Output Phase ==
streamlit -> streamlit_util: stream_response(final_answer)
activate streamlit_util

loop for each token in response
    streamlit_util -> streamlit: stream_token(token)
    streamlit -> user: display_token(token)
end

streamlit_util --> streamlit: streaming_complete
deactivate streamlit_util

streamlit --> user: display_complete_answer()
deactivate streamlit

== Fine-tuning Flow (Optional) ==
note over user, model
  Alternative flow for model fine-tuning with QLoRA
end note

user -> streamlit: initiate_fine_tuning()
activate streamlit

streamlit -> inference_lib: prepare_training_data()
activate inference_lib
inference_lib --> streamlit: prepared_dataset
deactivate inference_lib

streamlit -> llm_endpoint: submit_training_job(dataset, qlora_config)
activate llm_endpoint

llm_endpoint -> model: fine_tune_with_peft()
activate model
model -> model: apply_qlora()
model -> model: distributed_training()
model --> llm_endpoint: fine_tuned_model
deactivate model

llm_endpoint --> streamlit: training_complete
deactivate llm_endpoint

streamlit --> user: model_updated
deactivate streamlit

@enduml
