@startuml
!define COMPONENT_COLOR #E8F5E9
!define DIALECT_COLOR #FFF3E0
!define BACKEND_COLOR #E3F2FD
!define FRONTEND_COLOR #F3E5F5

skinparam component {
  BackgroundColor COMPONENT_COLOR
  BorderColor #333333
  ArrowColor #333333
}

skinparam package {
  BackgroundColor #FAFAFA
  BorderColor #666666
}

title Torch-MLIR System Architecture - Component Diagram

package "Frontend Layer" <<FRONTEND_COLOR>> {
  component "TorchScript Importer" as TSImporter
  component "FX Graph Importer" as FXImporter {
    component "FxImporterHooks" as FXHooks
  }
  component "Lazy Tensor Core (LTC)" as LTC
  component "ONNX Importer" as ONNXImporter
}

package "Core MLIR Dialects" <<DIALECT_COLOR>> {
  component "Torch Dialect" as TorchDialect {
    component "Torch Operations" as TorchOps
    component "Torch Types" as TorchTypes
    portin ITorchIn
    portout ITorchOut
  }

  component "TMTensor Dialect" as TMTensorDialect {
    portin ITMTensorIn
    portout ITMTensorOut
  }

  component "TorchConversion Dialect" as TorchConvDialect {
    portin IConvIn
    portout IConvOut
  }
}

package "Transformation Passes" as TransformPasses {
  component "Reify Shape/Dtype\nCalculations" as ReifyPass {
    component "ShapeCalculateOp" as ShapeCalc
    component "DtypeCalculateOp" as DtypeCalc
    component "Abstract Interpretation\nLibrary" as AbstractLib
  }

  component "Adjust Calling\nConventions" as AdjustConvPass
  component "Globalize Object\nGraph" as GlobalizePass
  component "Fuse Quantized Ops" as FuseQuantPass
  component "Scalarize Shapes" as ScalarizePass
  component "Lower To Backend\nContract" as LowerBackendPass
}

package "Backend Targets" <<BACKEND_COLOR>> {
  component "Linalg-on-Tensors\nBackend" as LinalgBackend {
    component "Linalg Dialect" as LinalgDialect
    component "RefBackend" as RefBackend
  }

  component "TOSA Backend" as TOSABackend {
    component "TOSA Dialect" as TOSADialect
  }

  component "StableHLO Backend" as StableHLOBackend {
    component "StableHLO Dialect" as StableHLODialect
    component "Dynamic Shape\nHandling" as DynamicShape
  }
}

package "Code Generation & Infrastructure" {
  component "TableGen\nDefinitions" as TableGen {
    component "Op Definitions" as OpDefs
    component "Type Definitions" as TypeDefs
    component "Pass Definitions" as PassDefs
  }

  component "Abstract Interpretation\nGenerator" as AbstractGen
}

package "Language Bindings" {
  component "Python Bindings" as PyBindings {
    component "TorchMLIRModule" as PyModule
  }

  component "C-API" as CAPI
}

package "Testing Framework" {
  component "End-to-End Tests" as E2ETests {
    component "Test Decorators" as TestDecorators
  }
  component "LIT Tests" as LITTests
  component "Unit Tests" as UnitTests
}

' Frontend connections
TSImporter --> ITorchIn : imports to
FXImporter --> ITorchIn : imports to
FXHooks --> FXImporter : customizes
LTC --> ITorchIn : generates
ONNXImporter --> ITorchIn : converts to

' Torch Dialect internal
TorchOps -down-> TorchTypes : uses

' Transformation flow
ITorchOut --> ReifyPass : processes
ReifyPass --> AdjustConvPass
AdjustConvPass --> GlobalizePass
GlobalizePass --> FuseQuantPass
FuseQuantPass --> ScalarizePass
ScalarizePass --> LowerBackendPass

' Abstract interpretation
AbstractGen ..> AbstractLib : generates
AbstractLib --> ShapeCalc : provides functions
AbstractLib --> DtypeCalc : provides functions

' Dialect conversions
LowerBackendPass --> IConvIn : uses
IConvOut --> ITMTensorIn : lowers to

' Backend connections
ITMTensorOut --> LinalgBackend : lowers to
ITMTensorOut --> TOSABackend : lowers to
ITMTensorOut --> StableHLOBackend : lowers to

' Linalg backend internal
LinalgDialect --> RefBackend : executes on

' StableHLO internal
DynamicShape --> StableHLODialect : supports

' TableGen generation
TableGen ..> TorchDialect : generates
TableGen ..> TMTensorDialect : generates
TableGen ..> TransformPasses : generates
OpDefs ..> TorchOps : defines
TypeDefs ..> TorchTypes : defines
PassDefs ..> TransformPasses : defines

' Language bindings
TorchDialect --> PyBindings : exposes
TorchDialect --> CAPI : exposes
PyModule --> CAPI : wraps

' Testing connections
E2ETests --> TSImporter : tests
E2ETests --> FXImporter : tests
E2ETests --> LinalgBackend : validates
E2ETests --> TOSABackend : validates
E2ETests --> StableHLOBackend : validates
RefBackend <-- E2ETests : uses for validation
LITTests --> TransformPasses : tests
UnitTests --> TransformPasses : tests

' Backend contract verification
LowerBackendPass ..> LinalgBackend : verifies contract
LowerBackendPass ..> TOSABackend : verifies contract
LowerBackendPass ..> StableHLOBackend : verifies contract

note right of TorchDialect
  Core dialect with:
  - !torch.tensor
  - !torch.vtensor
  - !torch.list
  - !torch.dict
  - !torch.Optional
  - !torch.nn.Module
end note

note right of ReifyPass
  Makes shape/dtype
  computations explicit
  in IR using generated
  inference functions
end note

note bottom of LowerBackendPass
  Restricts IR to backend-supported
  ops and types:
  - Value semantics
  - Known shapes/dtypes
end note

note left of TableGen
  Automated code generation
  for dialects, operations,
  types, and passes
end note

@enduml
