@startuml
!define RECTANGLE_COLOR #E3F2FD
!define DATABASE_COLOR #FFF3E0
!define INFRA_COLOR #F3E5F5

skinparam component {
    BackgroundColor RECTANGLE_COLOR
    BorderColor #1976D2
    ArrowColor #424242
}

skinparam database {
    BackgroundColor DATABASE_COLOR
    BorderColor #F57C00
}

skinparam node {
    BackgroundColor INFRA_COLOR
    BorderColor #7B1FA2
}

title Arclytics SimCCT - Deployment Architecture

' Kubernetes Cluster
node "Kubernetes Cluster" as k8s {

    ' Frontend Pod
    node "Frontend Pod" {
        component "React Client" as react {
            component "Redux Store" as redux
            component "React Router" as router
            component "Plotly Charts" as plotly
            component "API Helpers" as apihelpers
        }
        component "Nginx" as nginx
    }

    ' SimCCT Service Pod
    node "SimCCT Service Pod" {
        component "Flask Application" as flask {
            component "API Routes" as routes
            component "REST Resources" as resources
            component "Authentication Service" as auth
            component "User Management" as usermgmt
            component "Middleware" as middleware
            component "Schemas" as schemas
        }
        component "arc_simulation Package" as arcsim
        component "arc_logging Library" as arclog
        component "Swagger Documentation" as swagger
    }

    ' Arclytics Analytics Service Pod
    node "Arclytics Service Pod" {
        component "Analytics Microservice" as analytics
        component "Elastic APM Agent" as apm_agent
    }

    ' Celery Worker Pod
    node "Celery Worker Pod" {
        component "Celery Worker" as celery
        component "Task Queue Handler" as taskhandler
    }

    ' Jupyter Service Pod
    node "Jupyter Service Pod" {
        component "Jupyter Notebook Server" as jupyter
    }

    ' Logging Infrastructure Pod
    node "Logging Pod" {
        component "Fluentd" as fluentd
    }

    ' Monitoring Pod
    node "Monitoring Pod" {
        component "Elasticsearch" as elastic
        component "Kibana" as kibana
        component "Elastic APM Server" as apm_server
    }
}

' External Data Layer
cloud "Data Layer" {
    database "MongoDB" as mongodb {
        component "User Data" as userdata
        component "Simulation Data" as simdata
        component "Alloy Data" as alloydata
    }

    database "Redis" as redis {
        component "Session Store" as sessions
        component "Cache" as cache
        component "Celery Queue" as celeryqueue
    }
}

' Container Registry
cloud "Container Registry" as registry {
    component "Docker Images" as images
}

' CI/CD Pipeline
cloud "CI/CD" as cicd {
    component "Bitbucket Pipelines" as bitbucket
    component "Google Cloud Build" as cloudbuild
}

' Build Tools
node "Development Tools" {
    component "Docker Compose" as dockercompose
    component "Skaffold" as skaffold
    component "arc_cli.sh" as arccli
}

' Client connections
nginx --> react : "serves"
react --> apihelpers : "uses"

' API Gateway pattern
apihelpers --> flask : "HTTP/REST API"
apihelpers --> analytics : "HTTP/REST API"

' Flask internal structure
routes --> resources : "delegates to"
resources --> auth : "uses"
resources --> middleware : "protected by"
middleware --> auth : "validates JWT"
resources --> schemas : "validates with"
resources --> arcsim : "executes simulations"
flask --> arclog : "logs via"

' User management
usermgmt --> auth : "uses JWT"
flask --> usermgmt : "contains"

' Database connections
flask --> mongodb : "mongoengine/pymongo"
flask --> redis : "Flask-Redis\n(sessions)"
analytics --> mongodb : "queries"

' Celery architecture
flask --> celeryqueue : "enqueues tasks"
celery --> celeryqueue : "consumes from"
celery --> mongodb : "reads/writes"
taskhandler --> arcsim : "executes"

' Logging pipeline
flask --> fluentd : "streams logs"
analytics --> fluentd : "streams logs"
celery --> fluentd : "streams logs"
fluentd --> elastic : "forwards to"
elastic --> kibana : "visualized in"

' APM monitoring
flask --> apm_agent : "instruments"
apm_agent --> apm_server : "sends traces"
apm_server --> elastic : "stores in"

' Jupyter integration
jupyter --> mongodb : "accesses"
jupyter --> flask : "API calls"

' Deployment pipeline
cicd --> images : "builds & pushes"
bitbucket --> cloudbuild : "triggers"
cloudbuild --> registry : "pushes to"
registry --> k8s : "pulls images"

' Development workflow
arccli --> dockercompose : "manages"
arccli --> skaffold : "manages"
dockercompose --> images : "builds locally"
skaffold --> k8s : "deploys to"

' Documentation
swagger --> flask : "documents"

' User access
actor "End User" as user
user --> nginx : "HTTPS"

' Admin access
actor "Administrator" as admin
admin --> kibana : "monitors"
admin --> jupyter : "analyzes"

' Deployment configuration
component "Kubernetes YAML" as k8syaml
component "Environment Variables" as envvars
k8syaml --> k8s : "configures"
envvars --> flask : "configures"
envvars --> analytics : "configures"
envvars --> celery : "configures"

legend right
    |= Symbol |= Description |
    | Component | Microservice/Application Component |
    | Database | Data Storage Layer |
    | Node | Deployment Unit/Pod |
    | Cloud | External Service/Infrastructure |

    **Deployment Technologies:**
    - Kubernetes for orchestration
    - Docker for containerization
    - Google Cloud Build for CI/CD
    - Fluentd/ELK stack for logging
    - Redis for caching & queuing
    - MongoDB for persistence
endlegend

@enduml
