@startuml
actor User
participant "Nuxt.js Frontend" as Frontend
participant "Vuex Store" as Vuex
participant "Web3 Plugin" as Web3
participant "Ethereum Contract\n(Flibra.sol)" as Ethereum
participant "Libra Blockchain" as Libra
participant "Firebase/Firestore" as Firestore
participant "IPFS" as IPFS
participant "Elasticsearch Node" as ESNode
database "Elasticsearch" as ES

== User Registration ==
User -> Frontend: Sign Up
activate Frontend
Frontend -> Firestore: Create User Profile
activate Firestore
Firestore --> Frontend: User Created
deactivate Firestore
Frontend -> Web3: Generate Ethereum Wallet
activate Web3
Web3 --> Frontend: Wallet Address
deactivate Web3
Frontend -> Libra: Create Libra Wallet
activate Libra
Libra --> Frontend: Wallet Created
deactivate Libra
Frontend -> Vuex: Store User Data
activate Vuex
Vuex --> Frontend: Updated
deactivate Vuex
Frontend --> User: Registration Complete
deactivate Frontend

== Post Item for Sale ==
User -> Frontend: Create Item
activate Frontend
Frontend -> IPFS: Upload Item Photos
activate IPFS
IPFS --> Frontend: Photo Hash
deactivate IPFS
Frontend -> Web3: Post Item to Contract
activate Web3
Web3 -> Ethereum: createItem(details)
activate Ethereum
Ethereum --> Web3: Transaction Hash
deactivate Ethereum
Web3 --> Frontend: Item Posted to Blockchain
deactivate Web3
Frontend -> Firestore: Save Item Details
activate Firestore
Firestore --> Frontend: Item Saved
Firestore -> ESNode: onSnapshot Trigger
activate ESNode
ESNode -> ES: Register Item
activate ES
ES --> ESNode: Indexed
deactivate ES
deactivate ESNode
deactivate Firestore
Frontend -> Vuex: Update Item State
activate Vuex
Vuex --> Frontend: State Updated
deactivate Vuex
Frontend --> User: Item Posted
deactivate Frontend

== Search Items ==
User -> Frontend: Search by Keyword
activate Frontend
Frontend -> ESNode: Search Request
activate ESNode
ESNode -> ES: Query Items
activate ES
ES --> ESNode: Search Results
deactivate ES
ESNode --> Frontend: Item List
deactivate ESNode
Frontend -> Vuex: Store Search Results
activate Vuex
Vuex --> Frontend: Updated
deactivate Vuex
Frontend --> User: Display Items
deactivate Frontend

== Purchase Item ==
User -> Frontend: Buy Item
activate Frontend
Frontend -> Web3: Verify Item Availability
activate Web3
Web3 -> Ethereum: getItemDetails(itemId)
activate Ethereum
Ethereum --> Web3: Item Status
deactivate Ethereum
Web3 --> Frontend: Available
deactivate Web3
Frontend -> Libra: Transfer Coins to Escrow
activate Libra
Libra --> Frontend: Transfer Complete
deactivate Libra
Frontend -> Web3: Update Item Status
activate Web3
Web3 -> Ethereum: purchaseItem(itemId)
activate Ethereum
Ethereum --> Web3: Transaction Hash
deactivate Ethereum
Web3 --> Frontend: Purchase Recorded
deactivate Web3
Frontend -> Firestore: Update Item Status
activate Firestore
Firestore --> Frontend: Updated
deactivate Firestore
Frontend -> Vuex: Update State
activate Vuex
Vuex --> Frontend: State Updated
deactivate Vuex
Frontend --> User: Purchase Confirmed
deactivate Frontend

== Mark Item as Delivered ==
User -> Frontend: Confirm Delivery
activate Frontend
Frontend -> Web3: Mark Delivered
activate Web3
Web3 -> Ethereum: markDelivered(itemId)
activate Ethereum
Ethereum --> Web3: Transaction Hash
deactivate Ethereum
Web3 --> Frontend: Status Updated
deactivate Web3
Frontend -> Libra: Release Payment to Seller
activate Libra
Libra --> Frontend: Payment Released
deactivate Libra
Frontend -> Firestore: Update Item Status
activate Firestore
Firestore --> Frontend: Updated
Firestore -> ESNode: onSnapshot Trigger
activate ESNode
ESNode -> ES: Delete Item
activate ES
ES --> ESNode: Item Removed
deactivate ES
deactivate ESNode
deactivate Firestore
Frontend -> Vuex: Update State
activate Vuex
Vuex --> Frontend: State Updated
deactivate Vuex
Frontend --> User: Delivery Confirmed
deactivate Frontend

== Leave Review ==
User -> Frontend: Submit Review
activate Frontend
Frontend -> IPFS: Upload Profile Picture (if new)
activate IPFS
IPFS --> Frontend: Image Hash
deactivate IPFS
Frontend -> Web3: Post Review
activate Web3
Web3 -> Ethereum: addReview(userId, rating, comment)
activate Ethereum
Ethereum --> Web3: Review Stored
deactivate Ethereum
Web3 --> Frontend: Review Posted
deactivate Web3
Frontend -> Firestore: Save Review Data
activate Firestore
Firestore --> Frontend: Review Saved
deactivate Firestore
Frontend -> Vuex: Update User Reviews
activate Vuex
Vuex --> Frontend: State Updated
deactivate Vuex
Frontend --> User: Review Submitted
deactivate Frontend

== Real-time Synchronization ==
Firestore -> ESNode: onSnapshot (Item Changes)
activate ESNode
ESNode -> ES: Update Index
activate ES
ES --> ESNode: Synchronized
deactivate ES
deactivate ESNode

Firestore -> Frontend: onSnapshot (Data Changes)
activate Frontend
Frontend -> Vuex: Update State
activate Vuex
Vuex --> Frontend: State Updated
deactivate Vuex
Frontend -> User: UI Auto-Updated
deactivate Frontend

@enduml
