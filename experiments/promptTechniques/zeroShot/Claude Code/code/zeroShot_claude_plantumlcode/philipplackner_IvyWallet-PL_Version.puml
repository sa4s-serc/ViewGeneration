@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<ui>> LightBlue
    BackgroundColor<<domain>> LightGreen
    BackgroundColor<<data>> LightYellow
    BackgroundColor<<infrastructure>> LightGray
}

package "UI Layer" {
    [HomeViewModel] <<ui>>
    [TransactionUI] <<ui>>
    [AccountsUI] <<ui>>
    [CategoriesUI] <<ui>>
    [ExchangeRatesUI] <<ui>>
    [BackupUI] <<ui>>
    [SyncUI] <<ui>>
    [FormulaUI] <<ui>>
    [DesignSystem] <<ui>>
    [Navigator] <<ui>>
}

package "Domain Layer" {
    package "Transaction Management" {
        [TrnsFlow] <<domain>>
        [WriteTrnsAct] <<domain>>
    }

    package "Account Management" {
        [WriteAccountsAct] <<domain>>
        [AccountActions] <<domain>>
    }

    package "Category Management" {
        [CategoryActions] <<domain>>
    }

    package "Sync Module" {
        [SyncAct] <<domain>>
        [CalculateDiff] <<domain>>
        [ApplyDiff] <<domain>>
    }

    package "Backup Module" {
        [BackupDataAct] <<domain>>
        [ImportBackupDataAct] <<domain>>
    }

    package "Exchange Rates" {
        [RatesStateFlow] <<domain>>
        [ExchangeRatesViewModel] <<domain>>
    }

    package "Formula Engine" {
        [FormulaFlow] <<domain>>
        [CompileFunction] <<domain>>
    }
}

package "Data Layer" {
    [TransactionRepository] <<data>>
    [AccountRepository] <<data>>
    [CategoryRepository] <<data>>
    [BackupRepository] <<data>>
    [ExchangeRateRepository] <<data>>
    [FormulaRepository] <<data>>
    [RemoteBackupSource] <<data>>
    [RoomDatabase] <<data>>
}

package "Infrastructure" {
    [HiltDI] <<infrastructure>>
    [FileSystem] <<infrastructure>>
    [NotificationManager] <<infrastructure>>
    [BiometricAuth] <<infrastructure>>
    [GoogleDriveAPI] <<infrastructure>>
}

' UI to ViewModel Control Flow
HomeViewModel --> Navigator : "navigate to screen"
TransactionUI --> HomeViewModel : "user actions"
AccountsUI --> HomeViewModel : "user actions"
CategoriesUI --> HomeViewModel : "user actions"
ExchangeRatesUI --> ExchangeRatesViewModel : "user actions"
BackupUI --> HomeViewModel : "user actions"
SyncUI --> HomeViewModel : "user actions"
FormulaUI --> HomeViewModel : "user actions"

' ViewModel to Domain Control Flow
HomeViewModel --> TrnsFlow : "request transactions"
HomeViewModel --> WriteTrnsAct : "write transaction"
HomeViewModel --> WriteAccountsAct : "write account"
HomeViewModel --> CategoryActions : "manage categories"
HomeViewModel --> BackupDataAct : "export data"
HomeViewModel --> ImportBackupDataAct : "import data"
HomeViewModel --> SyncAct : "trigger sync"
HomeViewModel --> FormulaFlow : "execute formula"
ExchangeRatesViewModel --> RatesStateFlow : "get rates"

' Domain to Domain Control Flow
SyncAct --> CalculateDiff : "calculate changes"
SyncAct --> ApplyDiff : "apply changes"
BackupDataAct --> TrnsFlow : "fetch transactions"
ImportBackupDataAct --> WriteTrnsAct : "write transactions"
FormulaFlow --> CompileFunction : "compile formula"
FormulaFlow --> TrnsFlow : "query transactions"

' Domain to Data Control Flow
TrnsFlow --> TransactionRepository : "query transactions"
WriteTrnsAct --> TransactionRepository : "persist transaction"
WriteAccountsAct --> AccountRepository : "persist account"
AccountActions --> AccountRepository : "CRUD operations"
CategoryActions --> CategoryRepository : "CRUD operations"
BackupDataAct --> BackupRepository : "get backup data"
ImportBackupDataAct --> BackupRepository : "restore data"
SyncAct --> RemoteBackupSource : "sync with remote"
RatesStateFlow --> ExchangeRateRepository : "get/update rates"
FormulaFlow --> FormulaRepository : "persist formula"

' Data to Infrastructure Control Flow
TransactionRepository --> RoomDatabase : "DB operations"
AccountRepository --> RoomDatabase : "DB operations"
CategoryRepository --> RoomDatabase : "DB operations"
BackupRepository --> FileSystem : "file operations"
BackupRepository --> RoomDatabase : "DB operations"
ExchangeRateRepository --> RoomDatabase : "DB operations"
FormulaRepository --> RoomDatabase : "DB operations"
RemoteBackupSource --> GoogleDriveAPI : "remote sync"

' Infrastructure Control Flow
HiltDI --> HomeViewModel : "inject dependencies"
HiltDI --> TrnsFlow : "inject dependencies"
HiltDI --> TransactionRepository : "inject dependencies"
NotificationManager --> HomeViewModel : "notify user"
BiometricAuth --> HomeViewModel : "authenticate"
FileSystem --> BackupRepository : "read/write files"

' UI Design System Flow
TransactionUI --> DesignSystem : "use components"
AccountsUI --> DesignSystem : "use components"
CategoriesUI --> DesignSystem : "use components"
ExchangeRatesUI --> DesignSystem : "use components"
BackupUI --> DesignSystem : "use components"
SyncUI --> DesignSystem : "use components"
FormulaUI --> DesignSystem : "use components"

' Navigator Control Flow
Navigator --> TransactionUI : "navigate"
Navigator --> AccountsUI : "navigate"
Navigator --> CategoriesUI : "navigate"
Navigator --> ExchangeRatesUI : "navigate"
Navigator --> BackupUI : "navigate"
Navigator --> SyncUI : "navigate"
Navigator --> FormulaUI : "navigate"

note right of HomeViewModel
  MVVM Pattern:
  ViewModels orchestrate
  control flow between
  UI and Domain layers
end note

note right of TrnsFlow
  Action Pattern:
  Pure functions handle
  domain logic with
  unidirectional flow
end note

note right of RoomDatabase
  Data Layer:
  Repository pattern
  abstracts data access
end note

note right of HiltDI
  Dependency Injection:
  Hilt manages component
  lifecycle and dependencies
end note

@enduml
