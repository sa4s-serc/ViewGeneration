@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<reactive>> LightGreen
    BackgroundColor<<internal>> LightYellow
    BackgroundColor<<ui>> LightPink
}

package "VueFlux Framework" {

    package "VueFlux Core" <<core>> {
        component Store <<core>> {
            [State]
            [Mutations]
            [Actions]
            [Computed]
        }

        component Executor <<core>>
    }

    package "VueFluxReactive" <<reactive>> {
        component "Reactive Primitives" {
            [Variable]
            [Constant]
            [Sink]
            [Signal]
        }

        component Binder <<reactive>>
    }

    package "VueFluxInternalCore" <<internal>> {
        component Storage <<internal>>
        component CancelableProcedure <<internal>>
        component AtomicReference <<internal>>
    }
}

package "UI Layer" <<ui>> {
    component "View Components" as UI <<ui>>
}

' Core relationships within Store
Actions --> Mutations : triggers
Mutations --> State : modifies
State --> Computed : derives from
Computed --> UI : provides read-only view

' Store to Executor
Actions ..> Executor : uses for\nconcurrency control

' Reactive system relationships
Variable --> Signal : emits
Constant --> Signal : provides
Sink --> Signal : produces
Signal --> Binder : binds to
Binder --> UI : updates

' Store uses Reactive system
Computed ..> Signal : implements with
State ..> Variable : backed by

' Internal core support
Store ..> Storage : uses
Store ..> AtomicReference : thread-safe access
Actions ..> CancelableProcedure : cancellable execution

' UI observes state
UI --> Computed : observes
UI ..> Binder : uses for binding

' Thread safety
AtomicReference ..> State : protects
AtomicReference ..> Variable : protects

' Unidirectional data flow (highlighted)
note top of Store
  **Unidirectional Data Flow:**
  Actions → Mutations → State → Computed → UI
end note

note right of "Reactive Primitives"
  Reactive building blocks:
  - Variable: mutable state
  - Constant: read-only value
  - Sink: custom streams
  - Signal: observable streams
end note

note bottom of Executor
  Controls execution context:
  - Main thread
  - Background queue
  - Custom queue
end note

@enduml
