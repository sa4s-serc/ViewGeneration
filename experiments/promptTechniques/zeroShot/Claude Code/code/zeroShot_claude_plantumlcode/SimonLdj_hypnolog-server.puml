@startuml
!define RECTANGLE class

skinparam component {
  BackgroundColor<<server>> LightBlue
  BackgroundColor<<client>> LightGreen
  BackgroundColor<<external>> LightYellow
}

title HypnoLog Server - Component Diagram (Connectivity Focus)

package "External Applications" {
  [Application] as App <<external>>
  [Command Line Utility\n(hypnolog.sh)] as CLI <<external>>
}

package "HypnoLog Server" <<server>> {
  [Express Server\n(app.js)] as Express
  [HTTP Server\n(bin/www)] as HTTPServer
  [Logger Route\n(routes/logger.js)] as LoggerRoute
  [Index Route\n(routes/index.js)] as IndexRoute
  [Socket.IO Server] as SocketIOServer
  [Ajv Validator] as Validator

  HTTPServer --> Express : uses
  Express --> LoggerRoute : registers
  Express --> IndexRoute : registers
  LoggerRoute --> Validator : validates data
  LoggerRoute --> SocketIOServer : broadcasts
  HTTPServer --> SocketIOServer : integrates
}

package "Web UI Client" <<client>> {
  [client.html] as HTML
  [client.js] as ClientJS
  [Socket.IO Client] as SocketIOClient
  [WindowsDispatcher] as WinDispatcher
  [WindowsFilter] as WinFilter
  [VisualizerDispatcher] as VisDispatcher
  [ConfigFactory] as Config

  package "Visualizers" {
    [String Visualizer] as VisString
    [Object Visualizer] as VisObject
    [Image Visualizer] as VisImage
    [Heatmap Visualizer] as VisHeatmap
    [Code Visualizer] as VisCode
    [Other Visualizers] as VisOther
  }

  HTML --> ClientJS : loads
  ClientJS --> SocketIOClient : manages
  ClientJS --> WinDispatcher : creates
  ClientJS --> Config : uses
  WinDispatcher --> WinFilter : manages
  WinFilter --> VisDispatcher : uses
  VisDispatcher --> Config : gets config
  VisDispatcher --> VisString : dispatches
  VisDispatcher --> VisObject : dispatches
  VisDispatcher --> VisImage : dispatches
  VisDispatcher --> VisHeatmap : dispatches
  VisDispatcher --> VisCode : dispatches
  VisDispatcher --> VisOther : dispatches
}

interface "HTTP POST /log" as HTTPLog
interface "HTTP GET /status" as HTTPStatus
interface "HTTP GET /" as HTTPRoot
interface "WebSocket" as WS

App --> HTTPLog : JSON data
CLI --> HTTPLog : JSON data via curl

HTTPLog -- LoggerRoute
HTTPStatus -- LoggerRoute
HTTPRoot -- IndexRoute

SocketIOServer -down- WS
WS -down- SocketIOClient

note right of HTTPLog
  Applications send log data
  as JSON via HTTP POST
end note

note right of WS
  Real-time bidirectional
  communication for
  broadcasting log data
  to all connected clients
end note

note bottom of VisDispatcher
  Selects appropriate visualizer
  based on data type and
  configuration
end note

@enduml
