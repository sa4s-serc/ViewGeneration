@startuml
title Express.js Application with Promise-based Asynchronous Control Flow

actor Client
participant "Express App" as Express
participant "Middleware Pipeline" as Middleware
participant Router
participant "Route Handler" as Handler
participant "Body Parser" as BodyParser
participant "$Promise" as Promise
participant "Async Operation" as AsyncOp
participant View
participant "Static Files" as Static

== HTTP Request Processing ==
Client -> Express: HTTP Request
activate Express

Express -> Middleware: Process Request
activate Middleware

Middleware -> BodyParser: Parse Request Body
activate BodyParser
BodyParser -> BodyParser: Parse JSON/Form Data
BodyParser --> Middleware: Parsed Data
deactivate BodyParser

Middleware -> Middleware: Execute Middleware Chain
Middleware -> Middleware: Modify Request/Response
Middleware --> Express: Next Middleware
deactivate Middleware

Express -> Router: Route Request
activate Router

Router -> Router: Match URL Pattern
Router -> Handler: Dispatch to Handler
deactivate Router
activate Handler

== Asynchronous Promise-based Processing ==
Handler -> Promise: Create $Promise
activate Promise
Promise -> Promise: Set State to Pending

Handler -> AsyncOp: Initiate Async Operation
activate AsyncOp

AsyncOp -> AsyncOp: Execute Operation
AsyncOp -> Promise: Resolve/Reject
Promise -> Promise: Update State (Fulfilled/Rejected)
deactivate AsyncOp

Promise -> Promise: Execute .then() Chain
Promise -> Handler: Return Result
deactivate Promise

== Response Generation ==
alt Success Path
    Handler -> View: Render View (if applicable)
    activate View
    View -> View: Generate HTML/JSON
    View --> Handler: Rendered Content
    deactivate View
    Handler --> Express: Response Data
else Static File Request
    Handler -> Static: Serve Static File
    activate Static
    Static --> Handler: File Content
    deactivate Static
    Handler --> Express: Response Data
end

deactivate Handler

Express --> Client: HTTP Response
deactivate Express

== Promise.all() Pattern ==
Client -> Express: Complex Request
activate Express
Express -> Handler: Route to Handler
activate Handler

Handler -> Promise: $Promise.all([promises])
activate Promise

Promise -> AsyncOp: Execute Multiple Async Ops
activate AsyncOp
AsyncOp -> AsyncOp: Operation 1
AsyncOp -> AsyncOp: Operation 2
AsyncOp -> AsyncOp: Operation 3
AsyncOp --> Promise: All Results
deactivate AsyncOp

Promise -> Promise: Aggregate Results
Promise --> Handler: Combined Results
deactivate Promise

Handler --> Express: Response
deactivate Handler
Express --> Client: HTTP Response
deactivate Express

@enduml
