@startuml
!define RECTANGLE package

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<service>> LightGreen
    BackgroundColor<<data>> LightYellow
    BackgroundColor<<infra>> LightGray
}

' Core Services
component "Product Mixer" <<core>> as ProductMixer {
    component "Product Pipelines" as ProductPipeline
    component "Mixer Pipelines" as MixerPipeline
    component "Recommendation Pipelines" as RecommendationPipeline
    component "Candidate Pipelines" as CandidatePipeline
}

component "Cr-Mixer\n(Content Recommendation Mixer)" <<core>> as CrMixer {
    component "Candidate Retrieval" as CandidateRetrieval
    component "Filtering Engine" as FilteringEngine
    component "Ranking Engine" as RankingEngine
}

component "Follow Recommendations Service\n(FRS)" <<core>> as FRS {
    component "Account Candidate Sources" as AccountSources
    component "ML Ranking Models" as MLRanking
    component "Impression Fatigue Ranker" as FatigueRanker
}

component "Home Mixer" <<core>> as HomeMixer {
    component "Timeline Construction" as TimelineConstruction
    component "Personalization Engine" as PersonalizationEngine
}

' Pipeline Components
package "Reusable Components" {
    component "Candidate Sources" as CandidateSources {
        component "SimClustersANN" as SimClusters
        component "UserTweetGraph" as UserTweetGraph
        component "Earlybird" as Earlybird
        component "Timeline Service" as TimelineService
    }

    component "Feature Hydrators" as FeatureHydrators {
        component "TweetypieFeatureHydrator" as TweetypieHydrator
        component "InNetworkFeatureHydrator" as InNetworkHydrator
        component "GizmoduckUserQueryFeatureHydrator" as GizmoduckHydrator
    }

    component "Filters" as Filters {
        component "UrtUnorderedExcludeIdsCursorFilter" as CursorFilter
        component "ExcludedIdsFilter" as ExcludedIds
        component "TweetLanguageFilter" as LanguageFilter
    }

    component "Scorers" as Scorers {
        component "ML Model Scorers" as MLScorers
        component "Heuristic Scorers" as HeuristicScorers
    }

    component "Transformers" as Transformers {
        component "Deduplication" as Dedup
        component "Social Proof" as SocialProof
        component "Tracking Tokens" as Tracking
    }

    component "Gates" as Gates {
        component "Feature Flags" as FeatureFlags
        component "A/B Testing Gates" as ABTesting
    }
}

' ML Infrastructure
component "Navi Serving Server" <<infra>> as NaviServer {
    component "TensorFlow Runtime" as TensorFlow
    component "ONNX Runtime" as ONNX
    component "PyTorch Runtime" as PyTorch
}

' External Services
component "User Signal Service\n(USS)" <<service>> as USS
component "Real Graph" <<service>> as RealGraph
component "TweetyPie" <<service>> as TweetyPie
component "Strato" <<service>> as Strato

' Data Stores
database "Manhattan" <<data>> as Manhattan
database "Memcached" <<data>> as Memcached

' Infrastructure Components
component "Finagle\n(RPC Framework)" <<infra>> as Finagle
component "Storehaus\n(Data Abstraction)" <<infra>> as Storehaus
component "Stitch\n(Async Processing)" <<infra>> as Stitch

' Configuration & Control
component "Feature Switches & Deciders" <<infra>> as FeatureSwitches

' Data Models
package "Data Structures" {
    component "Candidates" as Candidates {
        component "TweetCandidate" as TweetCandidate
        component "UserCandidates" as UserCandidates
        component "AdsCandidates" as AdsCandidates
    }
    component "Features" as Features
    component "Queries" as Queries
    component "Presentation Models" as PresentationModels
}

' Core Service Relationships
ProductMixer --> CrMixer : "uses"
ProductMixer --> FRS : "uses"
ProductMixer --> HomeMixer : "uses"

' Pipeline Component Usage
ProductPipeline --> CandidatePipeline : "orchestrates"
CandidatePipeline --> CandidateSources : "uses"
CandidatePipeline --> FeatureHydrators : "uses"
CandidatePipeline --> Filters : "uses"
CandidatePipeline --> Scorers : "uses"
CandidatePipeline --> Transformers : "uses"
CandidatePipeline --> Gates : "controls"

' Cr-Mixer Internal Flow
CandidateRetrieval --> SimClusters : "fetches from"
CandidateRetrieval --> UserTweetGraph : "fetches from"
CandidateRetrieval --> Earlybird : "fetches from"
FilteringEngine --> Filters : "applies"
RankingEngine --> Scorers : "applies"

' Home Mixer Relationships
HomeMixer --> CandidateSources : "uses"
HomeMixer --> FeatureHydrators : "uses"
HomeMixer --> Filters : "uses"
HomeMixer --> Scorers : "uses"

' FRS Relationships
FRS --> RealGraph : "queries"
AccountSources --> RealGraph : "fetches from"

' ML Infrastructure
MLScorers --> NaviServer : "invokes"
MLRanking --> NaviServer : "invokes"

' External Service Dependencies
FeatureHydrators --> USS : "fetches signals"
FeatureHydrators --> TweetyPie : "fetches tweet data"
TweetypieHydrator --> TweetyPie : "queries"
GizmoduckHydrator --> USS : "queries"

' Data Store Access
Storehaus --> Manhattan : "reads/writes"
Storehaus --> Memcached : "caches"
Storehaus --> Strato : "accesses"

' Infrastructure Usage
ProductMixer --> Finagle : "communicates via"
CrMixer --> Finagle : "communicates via"
FRS --> Finagle : "communicates via"
HomeMixer --> Finagle : "communicates via"

ProductMixer --> Stitch : "async processing"
CrMixer --> Stitch : "async processing"
FRS --> Stitch : "async processing"

CandidateSources --> Storehaus : "data access"
FeatureHydrators --> Storehaus : "data access"

' Configuration Control
Gates --> FeatureSwitches : "reads from"
FeatureFlags --> Strato : "configured in"
ABTesting --> Strato : "configured in"

' Data Structure Usage
CandidateSources ..> Candidates : "produces"
Queries ..> CandidatePipeline : "inputs to"
Features ..> FeatureHydrators : "enriches"
PresentationModels ..> ProductMixer : "outputs"

@enduml
