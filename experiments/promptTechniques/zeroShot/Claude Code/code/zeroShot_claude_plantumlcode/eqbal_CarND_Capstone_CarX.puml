@startuml

skinparam component {
    BackgroundColor<<perception>> LightBlue
    BackgroundColor<<planning>> LightGreen
    BackgroundColor<<control>> LightCoral
    BackgroundColor<<infrastructure>> LightGray
    BackgroundColor<<external>> LightYellow
}

package "Perception Layer" {
    component "Traffic Light Detection Node" as TLD <<perception>>
    component "tl_classifier.py" as TLClassifier
    component "Camera Info Publisher" as CameraInfo <<perception>>
    component "grasshopper_calibration.yml" as CalibData
}

package "Planning Layer" {
    component "Waypoint Loader" as WPLoader <<planning>>
    component "waypoint_loader.py" as WPLoaderScript
    component "wp_yaw.txt" as WaypointData
    component "Waypoint Updater" as WPUpdater <<planning>>
    component "waypoint_updater.py" as WPUpdaterScript
    component "Waypoint Follower" as WPFollower <<planning>>
    component "libwaypoint_follower.cpp" as WPLib
    component "pure_pursuit.cpp" as PurePursuit
    component "pure_pursuit_core.cpp" as PurePursuitCore
}

package "Control Layer" {
    component "DBW Node" as DBW <<control>>
    component "dbw_node.py" as DBWScript
    component "PID Controller" as PID
    component "Yaw Controller" as YawCtrl
    component "LowPass Filter" as LowPass
    component "pid.py" as PIDImpl <<control>>
    component "yaw_controller.py" as YawImpl <<control>>
    component "lowpass.py" as LowPassImpl <<control>>
}

package "Infrastructure" {
    component "Bridge Node" as Bridge <<infrastructure>>
    component "server.py" as Server
    component "bridge.py" as BridgeScript
    component "conf.py" as Config
    component "ROS Launch Files" as Launch <<infrastructure>>
    component "styx.launch" as StyxLaunch
    component "site.launch" as SiteLaunch
}

package "External Systems" {
    component "Unity Simulator" as Simulator <<external>>
    component "CARLA (Real Car)" as CARLA <<external>>
    component "RVIZ Visualizer" as RVIZ <<external>>
    component "visualizer.rviz" as RVIZConfig
}

interface "Camera Images" as CameraFeed
interface "/traffic_waypoint" as TrafficWP
interface "/base_waypoints" as BaseWP
interface "/current_pose" as CurrentPose
interface "/final_waypoints" as FinalWP
interface "/twist_cmd" as TwistCmd
interface "/vehicle/steering_cmd" as SteerCmd
interface "/vehicle/throttle_cmd" as ThrottleCmd
interface "/vehicle/brake_cmd" as BrakeCmd
interface "/current_velocity" as CurrentVel
interface "SocketIO" as Socket

TLClassifier -up-> TLD
CalibData -up-> CameraInfo
WPLoaderScript -up-> WPLoader
WaypointData -up-> WPLoader
WPUpdaterScript -up-> WPUpdater
WPLib -up-> WPFollower
PurePursuit -up-> WPFollower
PurePursuitCore -up-> WPFollower
DBWScript -up-> DBW
PID -up-> DBW
YawCtrl -up-> DBW
LowPass -up-> DBW
Server -up-> Bridge
BridgeScript -up-> Bridge
Config -up-> Bridge
StyxLaunch -up-> Launch
SiteLaunch -up-> Launch
RVIZConfig -up-> RVIZ

CameraInfo --> CameraFeed
CameraFeed --> TLD
TLD --> TrafficWP

WPLoader --> BaseWP
BaseWP --> WPUpdater
TrafficWP --> WPUpdater
CurrentPose --> WPUpdater
WPUpdater --> FinalWP

FinalWP --> WPFollower
CurrentPose --> WPFollower
WPFollower --> TwistCmd

TwistCmd --> DBW
CurrentVel --> DBW
DBW --> SteerCmd
DBW --> ThrottleCmd
DBW --> BrakeCmd

PIDImpl ..> PID
YawImpl ..> YawCtrl
LowPassImpl ..> LowPass

SteerCmd --> Bridge
ThrottleCmd --> Bridge
BrakeCmd --> Bridge
Bridge --> Socket
Socket --> Simulator
Socket --> CARLA

StyxLaunch ..> Bridge
StyxLaunch ..> TLD
StyxLaunch ..> WPLoader
StyxLaunch ..> WPUpdater
StyxLaunch ..> WPFollower

SiteLaunch ..> DBW
SiteLaunch ..> TLD
SiteLaunch ..> WPLoader
SiteLaunch ..> WPUpdater
SiteLaunch ..> WPFollower

BaseWP --> RVIZ
FinalWP --> RVIZ
CurrentPose --> RVIZ
TwistCmd --> RVIZ

note right of DBW
  Control Flow:
  1. Receives target velocity from twist_cmd
  2. PID controls throttle based on velocity error
  3. Yaw controller computes steering angle
  4. LowPass filter smooths control signals
  5. Outputs actuator commands
end note

note right of WPUpdater
  Control Flow:
  1. Receives base waypoints
  2. Gets current position
  3. Checks traffic light status
  4. Adjusts waypoint velocities
  5. Publishes final waypoints
end note

note right of WPFollower
  Control Flow:
  1. Receives final waypoints
  2. Gets current pose
  3. Pure pursuit algorithm computes
     target linear/angular velocity
  4. Publishes twist commands
end note

@enduml
