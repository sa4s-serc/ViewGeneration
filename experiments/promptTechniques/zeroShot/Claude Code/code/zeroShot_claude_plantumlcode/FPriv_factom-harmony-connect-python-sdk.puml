@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
    BackgroundColor<<client>> LightBlue
    BackgroundColor<<utility>> LightGreen
    BackgroundColor<<handler>> LightYellow
    BackgroundColor<<external>> LightGray
    BackgroundColor<<sample>> Wheat
}

package "Factom Harmony Connect Python SDK" {

    package "Entry Point" {
        [FactomSDK] <<client>>
    }

    package "Client Layer" {
        [FactomClient] <<client>>
        [ChainsClient] <<client>>
        [EntriesClient] <<client>>
        [IdentitiesClient] <<client>>
        [ApiInfoClient] <<client>>
        [ReceiptsClient] <<client>>
        [AnchorsClient] <<client>>
    }

    package "Request/Response Handler" {
        [RequestHandler] <<handler>>
    }

    package "Utilities" {
        [Utils] <<utility>>
        [KeyCommon] <<utility>>
        [ValidateSignatureUtil] <<utility>>
        [CommonUtil] <<utility>>
    }

    package "Sample Application" {
        [SimulateNotary] <<sample>>
    }
}

package "External Services" {
    [Factom Harmony Connect API] <<external>>
}

' Entry Point relationships
[FactomSDK] --> [FactomClient] : manages

' FactomClient (Facade) relationships
[FactomClient] --> [ChainsClient] : provides access
[FactomClient] --> [EntriesClient] : provides access
[FactomClient] --> [IdentitiesClient] : provides access
[FactomClient] --> [ApiInfoClient] : provides access
[FactomClient] --> [ReceiptsClient] : provides access
[FactomClient] --> [AnchorsClient] : provides access
[FactomClient] --> [RequestHandler] : uses

' Client classes use Request Handler
[ChainsClient] --> [RequestHandler] : uses
[EntriesClient] --> [RequestHandler] : uses
[IdentitiesClient] --> [RequestHandler] : uses
[ApiInfoClient] --> [RequestHandler] : uses
[ReceiptsClient] --> [RequestHandler] : uses
[AnchorsClient] --> [RequestHandler] : uses

' Client classes use Utilities
[ChainsClient] --> [CommonUtil] : encodes/decodes
[ChainsClient] --> [ValidateSignatureUtil] : validates signatures
[ChainsClient] --> [KeyCommon] : signs data

[EntriesClient] --> [CommonUtil] : encodes/decodes
[EntriesClient] --> [ValidateSignatureUtil] : validates signatures
[EntriesClient] --> [KeyCommon] : signs data

[IdentitiesClient] --> [Utils] : generates keys
[IdentitiesClient] --> [KeyCommon] : manages keys

' Utility interdependencies
[Utils] --> [KeyCommon] : uses
[ValidateSignatureUtil] --> [KeyCommon] : uses

' Request Handler to External API
[RequestHandler] --> [Factom Harmony Connect API] : HTTP requests

' Sample Application dependencies
[SimulateNotary] --> [FactomSDK] : uses
[SimulateNotary] --> [Utils] : uses

note right of [FactomClient]
  Facade Pattern
  Central access point for
  all SDK functionalities
end note

note right of [ValidateSignatureUtil]
  Strategy Pattern
  Supports custom validation
  logic via parameters
end note

note right of [ChainsClient]
  Factory Pattern
  Creates objects representing
  Factom blockchain resources
end note

note bottom of [RequestHandler]
  Handles HTTP communication,
  authentication, headers,
  and error handling
end note

@enduml
