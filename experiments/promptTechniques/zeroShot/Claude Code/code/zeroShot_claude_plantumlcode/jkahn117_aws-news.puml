@startuml
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v14.0/dist
!include AWSPuml/AWSCommon.puml

title AWS News Aggregator - General Sequence Diagram

actor User
participant "CloudFront\nCDN" as CloudFront
participant "Next.js\nFrontend" as Frontend
participant "AppSync\nGraphQL API" as AppSync
participant "ElastiCache\nRedis" as Cache
participant "Lambda\nContent Service" as ContentService
participant "DynamoDB\nArticles Table" as DynamoDB
participant "EventBridge\nSchedule" as EventBridge
participant "Step Functions\nIngestion Workflow" as StepFunctions
participant "Lambda\nProcess Blog" as ProcessBlog
participant "S3\nContent Bucket" as S3
participant "Lambda\nProcess Image" as ProcessImage
participant "Amazon Pinpoint\nAnalytics" as Pinpoint
participant "Kinesis Firehose\nData Stream" as Firehose

== News Ingestion (Scheduled) ==
EventBridge -> StepFunctions: Trigger RSS feed ingestion
activate StepFunctions
StepFunctions -> ProcessBlog: Execute for each blog
activate ProcessBlog
ProcessBlog -> ProcessBlog: Parse RSS feed
ProcessBlog -> S3: Store article content
ProcessBlog -> DynamoDB: Save article metadata
ProcessBlog -> EventBridge: Publish article_created event
deactivate ProcessBlog
StepFunctions --> EventBridge: Ingestion complete
deactivate StepFunctions

== Image Processing (Event-Driven) ==
EventBridge -> ProcessImage: article_created event
activate ProcessImage
ProcessImage -> S3: Fetch original image
ProcessImage -> ProcessImage: Resize and convert\n(WebP/JPEG)
ProcessImage -> S3: Store processed images
ProcessImage -> DynamoDB: Update article with\nimage URLs
deactivate ProcessImage

== User Content Request ==
User -> CloudFront: Request news page
activate CloudFront
CloudFront -> Frontend: Serve static site
activate Frontend
Frontend --> CloudFront: HTML/JS/CSS
deactivate Frontend
CloudFront --> User: Cached content
deactivate CloudFront

User -> Frontend: Load application
activate Frontend
Frontend -> AppSync: GraphQL query\n(get articles)
activate AppSync
AppSync -> ContentService: Resolve query
activate ContentService
ContentService -> Cache: Check cache
activate Cache
alt Cache Hit
    Cache --> ContentService: Return cached articles
else Cache Miss
    Cache --> ContentService: Cache miss
    ContentService -> DynamoDB: Query articles
    activate DynamoDB
    DynamoDB --> ContentService: Article metadata
    deactivate DynamoDB
    ContentService -> S3: Fetch content if needed
    activate S3
    S3 --> ContentService: Article content
    deactivate S3
    ContentService -> Cache: Store in cache
end
deactivate Cache
ContentService --> AppSync: Article data
deactivate ContentService
AppSync --> Frontend: GraphQL response
deactivate AppSync
Frontend --> User: Display articles
deactivate Frontend

== User Analytics ==
User -> Frontend: Interact with article
activate Frontend
Frontend -> Pinpoint: Track user event
activate Pinpoint
Pinpoint -> Firehose: Stream analytics data
activate Firehose
Firehose -> S3: Store analytics data
activate S3
S3 --> Firehose: Stored
deactivate S3
deactivate Firehose
deactivate Pinpoint
Frontend --> User: Content interaction
deactivate Frontend

== Statistics Request ==
User -> Frontend: Request statistics
activate Frontend
Frontend -> AppSync: GraphQL query\n(get statistics)
activate AppSync
AppSync -> ContentService: Resolve statistics
activate ContentService
ContentService -> Cache: Check statistics cache
activate Cache
alt Cache Hit
    Cache --> ContentService: Return cached stats
else Cache Miss
    Cache --> ContentService: Cache miss
    ContentService -> DynamoDB: Aggregate statistics
    activate DynamoDB
    DynamoDB --> ContentService: Stats data
    deactivate DynamoDB
    ContentService -> Cache: Cache statistics
end
deactivate Cache
ContentService --> AppSync: Statistics data
deactivate ContentService
AppSync --> Frontend: GraphQL response
deactivate AppSync
Frontend --> User: Display statistics
deactivate Frontend

@enduml
