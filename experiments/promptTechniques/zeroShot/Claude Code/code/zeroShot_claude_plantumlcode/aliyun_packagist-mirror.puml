@startuml
!define COMPONENT_COLOR #ADD8E6
!define EXTERNAL_COLOR #FFE4B5
!define STORAGE_COLOR #90EE90

skinparam component {
  BackgroundColor COMPONENT_COLOR
  BorderColor #000000
}

skinparam database {
  BackgroundColor STORAGE_COLOR
  BorderColor #000000
}

package "Packagist Mirror System" {

  package "Core Components" {
    component [Main Entry Point\n(main.go)] as Main
    component [Configuration Manager\n(config.go)] as Config
    component [Context Manager\n(context.go)] as Context
    component [Utility Functions\n(util.go)] as Utils
  }

  package "Synchronization Components" {
    component [Provider Sync\n(sync_providers.go)] as ProviderSync
    component [Package V2 Sync\n(sync_packages_v2.go)] as PackageV2Sync
    component [Package V1 Sync\n(sync_packages_p1.go)] as PackageV1Sync
    component [Distribution Sync\n(sync_dists.go)] as DistSync
    component [Composer Phar Sync\n(sync_composer_phar.go)] as ComposerSync
    component [Status Generator\n(sync_status.go)] as StatusSync
  }

  package "Integration Components" {
    component [Packagist API Client\n(packagist.go)] as PackagistClient
    component [GitHub API Client\n(github.go)] as GitHubClient
    component [CDN Warmup\n(cdn.go)] as CDNClient
  }

  package "Queue Management" {
    component [Entry/Queue Manager\n(entry.go)] as QueueManager
  }

  package "Data Structures" {
    component [Mirror Models\n(mirror.go)] as MirrorModels
  }
}

package "External Storage" {
  database "Alibaba Cloud OSS\n(Object Storage)" as OSS
  database "Redis Cache\n(Queue & Metadata)" as Redis
}

package "External Services" {
  component [Packagist.org] as Packagist <<external>>
  component [GitHub API] as GitHub <<external>>
  component [Alibaba Cloud CDN] as CDN <<external>>
}

package "User Interface" {
  component [index.html] as WebUI
}

Main --> Config : loads
Main --> Context : initializes
Main --> QueueManager : starts

Context --> OSS : manages connection
Context --> Redis : manages connection
Context --> PackagistClient : provides access
Context --> GitHubClient : provides access
Context --> CDNClient : provides access

QueueManager --> ProviderSync : spawns goroutine
QueueManager --> PackageV2Sync : spawns goroutine
QueueManager --> PackageV1Sync : spawns goroutine
QueueManager --> DistSync : spawns goroutine
QueueManager --> ComposerSync : spawns goroutine
QueueManager --> StatusSync : spawns goroutine

ProviderSync --> Redis : read/write queue
ProviderSync --> PackagistClient : fetch providers
ProviderSync --> OSS : store providers
ProviderSync --> MirrorModels : uses

PackageV2Sync --> Redis : read/write queue
PackageV2Sync --> PackagistClient : fetch packages
PackageV2Sync --> OSS : store metadata
PackageV2Sync --> MirrorModels : uses

PackageV1Sync --> Redis : read/write queue
PackageV1Sync --> PackagistClient : fetch packages
PackageV1Sync --> OSS : store metadata
PackageV1Sync --> MirrorModels : uses

DistSync --> Redis : read/write queue
DistSync --> GitHubClient : download dists
DistSync --> OSS : store distributions
DistSync --> Utils : calculate checksums
DistSync --> MirrorModels : uses

ComposerSync --> PackagistClient : fetch composer.phar
ComposerSync --> OSS : store composer.phar

StatusSync --> Redis : read status
StatusSync --> OSS : write status.json

PackagistClient --> Packagist : HTTP requests
GitHubClient --> GitHub : API requests
CDNClient --> CDN : warmup requests

OSS ..> WebUI : serves
OSS ..> Packagist : mirrors

Redis --> QueueManager : provides queues

note right of Redis
  Stores:
  - Provider Queue
  - Package V1 Queue
  - Package V2 Queue
  - Distribution Queue
  - Sync Status
  - Checksums
end note

note right of OSS
  Stores:
  - Package Metadata
  - Provider Lists
  - Distributions (zip)
  - composer.phar
  - status.json
end note

note top of QueueManager
  Manages Redis Keys:
  - distQueue
  - providerQueue
  - packageP1Queue
  - packageV2Queue
  - distQueueRetry
end note

@enduml
