@startuml
skinparam component {
    BackgroundColor<<extraction>> LightBlue
    BackgroundColor<<transformation>> LightGreen
    BackgroundColor<<storage>> LightYellow
    BackgroundColor<<visualization>> LightPink
    BackgroundColor<<external>> LightGray
    BackgroundColor<<config>> Wheat
}

package "Azure DevOps Platform" <<external>> {
    component [Azure DevOps Services] as AzureDevOps
    component [Users & Access] as Users
    component [Projects & Process] as Projects
    component [Code Repositories] as Repos
    component [Build Pipelines] as Builds
    component [Release Pipelines] as Releases
    component [Teams & Boards] as Teams
    component [Artifacts & Packages] as Artifacts
    component [Environments] as Environments
    component [Service Hooks] as Hooks
    component [Extensions] as Extensions
}

package "Data Extraction Layer" <<extraction>> {
    component [PowerShell Scripts] as PSScripts
    component [User Management Scripts] as UserScripts
    component [Project Management Scripts] as ProjectScripts
    component [Repository Scripts] as RepoScripts
    component [Pipeline Scripts] as PipelineScripts
    component [Team Config Scripts] as TeamScripts
    component [Artifact Scripts] as ArtifactScripts
    component [Environment Scripts] as EnvScripts
    component [Azure DevOps CLI] as AzDevOpsCLI
    component [REST API Client] as RestAPI
}

package "Data Transformation Layer" <<transformation>> {
    component [JSON Parser] as JSONParser
    component [Data Filter] as DataFilter
    component [PSObject Builder] as PSObjBuilder
    component [String Manipulator] as StringManip
}

package "Data Storage Layer" <<storage>> {
    database "Azure SQL Database" as SQLDatabase
    component [AreaPermissions Table] as AreaPerms
    component [VariableGroups Table] as VarGroups
    component [FeedPackageVersions Table] as FeedPkgs
    component [EnvironmentsDeploys Table] as EnvDeploys
    component [ProcessesWorkItemsFields Table] as ProcessFields
    component [TeamSettingsBoards Table] as TeamBoards
    component [PersonalAccessTokens Table] as PATs
    component [ReleaseDefinitionsClassic Table] as ReleaseDefs
    component [Build Definitions Table] as BuildDefs
    component [Repository Info Table] as RepoInfo
}

package "Visualization Layer" <<visualization>> {
    component [Power BI Reports] as PowerBI
    component [Data Model] as DataModel
    component [Queries] as Queries
    component [Visualizations] as Visuals
    component [Custom Visual 1] as CV1
    component [Custom Visual 2] as CV2
    component [Custom Visual N] as CVN
    component [CY20SU09 Theme] as Theme1
    component [CY21SU04 Theme] as Theme2
    component [CY21SU11 Theme] as Theme3
}

package "Configuration & Governance" <<config>> {
    component [Configuration Parameters] as Config
    component [PAT Token] as PAT
    component [Organization Name] as Org
    component [Connection String] as ConnStr
    component [GitHub Actions Workflow] as Actions
    component [PSScriptAnalyzer] as Analyzer
    component [README] as Readme
    component [Contributing Guide] as Contributing
    component [Security Policy] as Security
    component [Bug Report Template] as BugTemplate
}

AzureDevOps ..> Users
AzureDevOps ..> Projects
AzureDevOps ..> Repos
AzureDevOps ..> Builds
AzureDevOps ..> Releases
AzureDevOps ..> Teams
AzureDevOps ..> Artifacts
AzureDevOps ..> Environments
AzureDevOps ..> Hooks
AzureDevOps ..> Extensions

Users --> AzDevOpsCLI : extract via CLI
Projects --> AzDevOpsCLI : extract via CLI
Repos --> RestAPI : extract via API
Builds --> RestAPI : extract via API
Releases --> RestAPI : extract via API
Teams --> RestAPI : extract via API
Artifacts --> RestAPI : extract via API
Environments --> RestAPI : extract via API
Hooks --> RestAPI : extract via API
Extensions --> RestAPI : extract via API

AzDevOpsCLI --> UserScripts : data
AzDevOpsCLI --> ProjectScripts : data
RestAPI --> RepoScripts : data
RestAPI --> PipelineScripts : data
RestAPI --> TeamScripts : data
RestAPI --> ArtifactScripts : data
RestAPI --> EnvScripts : data

PSScripts ..> UserScripts
PSScripts ..> ProjectScripts
PSScripts ..> RepoScripts
PSScripts ..> PipelineScripts
PSScripts ..> TeamScripts
PSScripts ..> ArtifactScripts
PSScripts ..> EnvScripts

UserScripts --> JSONParser : raw data
ProjectScripts --> JSONParser : raw data
RepoScripts --> JSONParser : raw data
PipelineScripts --> JSONParser : raw data
TeamScripts --> JSONParser : raw data
ArtifactScripts --> JSONParser : raw data
EnvScripts --> JSONParser : raw data

JSONParser --> DataFilter : parsed data
DataFilter --> StringManip : filtered data
StringManip --> PSObjBuilder : manipulated data

PSObjBuilder --> SQLDatabase : insert DTOs

SQLDatabase ..> AreaPerms
SQLDatabase ..> VarGroups
SQLDatabase ..> FeedPkgs
SQLDatabase ..> EnvDeploys
SQLDatabase ..> ProcessFields
SQLDatabase ..> TeamBoards
SQLDatabase ..> PATs
SQLDatabase ..> ReleaseDefs
SQLDatabase ..> BuildDefs
SQLDatabase ..> RepoInfo

SQLDatabase --> DataModel : query data

DataModel --> Queries : define
Queries --> Visuals : populate

PowerBI ..> DataModel
PowerBI ..> Queries
PowerBI ..> Visuals

Visuals --> CV1 : use
Visuals --> CV2 : use
Visuals --> CVN : use

Theme1 --> PowerBI : apply styling
Theme2 --> PowerBI : apply styling
Theme3 --> PowerBI : apply styling

Config ..> PAT
Config ..> Org
Config ..> ConnStr

PAT --> PSScripts : authenticate
Org --> PSScripts : target
ConnStr --> SQLDatabase : connect

Actions ..> Analyzer
Analyzer --> PSScripts : analyze code quality

note right of PSScripts
  ETL Pattern:
  - Extract from Azure DevOps
  - Transform to PSObjects
  - Load to SQL Database
end note

note right of SQLDatabase
  Central staging area
  for efficient querying
  and reporting
end note

note right of PowerBI
  Modular, component-based
  UI with custom visuals
  for specialized Azure
  DevOps visualizations
end note

@enduml
