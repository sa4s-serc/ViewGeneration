@startuml
!define RECTANGLE class

skinparam componentStyle rectangle
skinparam monochrome false
skinparam shadowing false

title Hive Architecture (Deployment View)

package "Hive Layer" as HiveLayer #lightgreen {
  component "Command Line Interface" as CLI #orange
  component "JDBC" as JDBC #green
  component "Web UI" as WebUI #red
  component "Metastore" as Metastore #lightblue

  component "Driver\n(Compiler, Optimizer, Executor)" as Driver #pink
}

cloud "Hadoop Platform\n(MapReduce + HDFS)" as Hadoop #lightblue {
  component "Yarn\nResource\nManager" as YARN #pink
  component "Map\nReduce" as MapReduce #lightgreen

  database "Data Node\nTask Tracker" as DataNode #lightblue
}

CLI -down-> Driver
JDBC -down-> Driver
WebUI -down-> Driver
Metastore -down-> Driver

Driver -down-> Hadoop : Query Execution
Driver -down-> YARN
Driver -down-> MapReduce

YARN -down-> DataNode
MapReduce -down-> DataNode

@enduml
