@startuml

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<analysis>> LightGreen
    BackgroundColor<<external>> LightGray
    BorderColor Black
}

skinparam interface {
    BackgroundColor Yellow
    BorderColor Black
}

skinparam database {
    BackgroundColor LightYellow
    BorderColor Black
}

package "Xen Environment" {
    [Xen Hypervisor] as XenHyper <<external>>
}

package "Main Controller" {
    component [Xentrace-analysis.c\nMain Entry Point] as MainCtrl <<core>>
}

package "Data Capture Layer" {
    component [xentrace\nChild Process] as Xentrace <<external>>
}

package "Core Processing Layer" {
    component [Reader.c\nEvent Parser] as Reader <<core>>
    component [Event.c\nEvent Structure] as EventStruct <<core>>
    component [EventHandler.c\nHandler Registry] as EventHandler <<core>>
    database "eventList\nMemory Buffer" as EventList
}

package "Analysis Tools Layer" {
    component [cpu_time_sharing\nCPU Utilization] as CPUTime <<analysis>>
    component [cpu_wait\nScheduling Latency] as CPUWait <<analysis>>
    component [xen_dom_time_sharing\nHypervisor Time] as XenTime <<analysis>>
    component [blk_io_queues\nDisk I/O Monitor] as BlkIO <<analysis>>
    component [xen_stats\nEvent Statistics] as XenStats <<analysis>>
    component [trap\nCustom Analysis] as Trap <<analysis>>
}

package "Common Handlers" {
    component [Lost_records.c\nState Reset] as LostRecords <<core>>
    component [Switch_sched.c\nScheduling] as SwitchSched <<core>>
}

package "Supporting Components" {
    component [Trace.h\nEvent ID Mapping] as TraceH <<core>>
    component [list.h\nLinked List] as ListH <<core>>
}

interface "Trace File" as TraceFile
interface "Event Stream" as EventStream
interface "Handler Registration" as HandlerReg
interface "Analysis Results" as Results

XenHyper -down-> Xentrace : generates\ntrace data
MainCtrl -down-> Xentrace : spawns &\nmanages
Xentrace -down-> TraceFile : writes
TraceFile -down-> Reader : reads

Reader -right-> EventStruct : uses for\nparsing
Reader -down-> EventList : stores &\nsorts events
EventList -down-> Reader : retrieves\nsorted events

Reader -down-> EventStream : produces
EventStream -down-> EventHandler : consumes

EventHandler -down-> HandlerReg : manages

HandlerReg -down-> CPUTime : dispatches to
HandlerReg -down-> CPUWait : dispatches to
HandlerReg -down-> XenTime : dispatches to
HandlerReg -down-> BlkIO : dispatches to
HandlerReg -down-> XenStats : dispatches to
HandlerReg -down-> Trap : dispatches to

MainCtrl -down-> CPUTime : forks to execute
MainCtrl -down-> CPUWait : forks to execute
MainCtrl -down-> XenTime : forks to execute
MainCtrl -down-> BlkIO : forks to execute
MainCtrl -down-> XenStats : forks to execute
MainCtrl -down-> Trap : forks to execute

LostRecords -up-> EventHandler : registers with
SwitchSched -up-> EventHandler : registers with

CPUTime -down-> Results : outputs
CPUWait -down-> Results : outputs
XenTime -down-> Results : outputs
BlkIO -down-> Results : outputs
XenStats -down-> Results : outputs
Trap -down-> Results : outputs

TraceH ..> EventHandler : provides\nevent mapping
ListH ..> EventHandler : provides\ndata structures
ListH ..> Reader : provides\ndata structures

note right of Reader
  Data Flow Processing:
  - Reads trace file
  - Parses trace events
  - Sorts by timestamp (qsort)
  - Buffers in memory
  - Distributes to handlers
end note

note right of EventHandler
  Event Distribution:
  - Observer pattern
  - Handler registration
  - Event dispatch
  - Init/finalize hooks
end note

note bottom of "Analysis Tools Layer"
  Deployment: Modular design
  allows easy addition/removal
  of analysis tools. Each tool
  runs as separate process.
end note

note left of MainCtrl
  Deployment Coordinator:
  - Argument parsing
  - Process management
  - Signal handling
  - Analysis tool selection
  - Fork analysis processes
end note

note top of EventList
  Data Flow Buffer:
  - In-memory storage
  - Sorted by timestamp
  - Dynamic allocation
end note

@enduml
