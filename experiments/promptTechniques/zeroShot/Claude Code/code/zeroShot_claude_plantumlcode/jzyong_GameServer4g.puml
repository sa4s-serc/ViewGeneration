@startuml
title GameServer4g - Service Deployment and Connectivity Flow

actor Client
participant "Gate\n(Gateway)" as Gate
participant "ZooKeeper" as ZK
participant "Hall\n(Game Logic)" as Hall
participant "World\n(Game Simulation)" as World
participant "Resource\n(Support Services)" as Resource
participant "Manager\n(Admin HTTP)" as Manager

== Service Initialization and Registration ==

Gate -> Gate: Initialize GateManager\n(Singleton)
activate Gate
Gate -> Gate: Load Config\n(JSON)
Gate -> Gate: Start ClientManager
Gate -> Gate: Start UserManager
Gate -> Gate: Start GameManager

Gate -> ZK: Register Gate Service\n(Service Discovery)
activate ZK
ZK --> Gate: Registration Confirmed
deactivate ZK

Hall -> Hall: Initialize HallManager
activate Hall
Hall -> Hall: Load Config\n(JSON)
Hall -> Hall: Start ClientManager

Hall -> ZK: Register Hall Service\n(Service Discovery)
activate ZK
ZK --> Hall: Registration Confirmed
deactivate ZK

Hall -> ZK: Watch Gate Services
activate ZK
ZK --> Hall: Gate Service List
deactivate ZK

Hall -> ZK: Watch World Services
activate ZK
ZK --> Hall: World Service List
deactivate ZK

World -> World: Initialize WorldManager
activate World
World -> World: Load Config\n(JSON)
World -> World: Start gRPC Server\n(player.go)

World -> ZK: Register World Service\n(Service Discovery)
activate ZK
ZK --> World: Registration Confirmed
deactivate ZK

Resource -> Resource: Initialize Resource Service
activate Resource
Resource -> Resource: Load Config

Resource -> ZK: Register Resource Service
activate ZK
ZK --> Resource: Registration Confirmed
deactivate ZK
deactivate Resource

Manager -> Manager: Initialize HTTP Services
activate Manager
Manager -> Manager: Load Admin Config
deactivate Manager

== Client Connection and Authentication ==

Client -> Gate: TCP Connect\n(Custom Protocol)
activate Gate
Gate -> Gate: ClientManager\nHandle Connection

Client -> Gate: Login Request\n(Protobuf Message)
Gate -> Gate: UserManager\nCreate Session

Gate -> ZK: Query Hall Services
activate ZK
ZK --> Gate: Available Hall List
deactivate ZK

Gate -> Hall: Forward Login\n(gRPC)
activate Hall
Hall -> Hall: Validate User
Hall -> Hall: Create User Session

Hall -> ZK: Query World Services
activate ZK
ZK --> Hall: Available World List
deactivate ZK

Hall -> World: Player Login\n(gRPC player.go)
activate World
World -> World: WorldManager\nCreate Player Entity
World --> Hall: Login Success
deactivate World

Hall --> Gate: Login Response
deactivate Hall

Gate --> Client: Login Success\n(TCP Response)
deactivate Gate

== Runtime Game Communication ==

Client -> Gate: Game Action Request\n(Protobuf)
activate Gate
Gate -> Gate: GameManager\nRoute Message

Gate -> Hall: Forward Action\n(gRPC)
activate Hall
Hall -> Hall: Process Game Logic

Hall -> World: World Action\n(gRPC)
activate World
World -> World: Update Game World
World -> World: Simulate Entities
World --> Hall: Action Result
deactivate World

Hall --> Gate: Response
deactivate Hall

Gate --> Client: Action Result\n(TCP)
deactivate Gate

== Service Discovery Update ==

ZK -> Hall: Service Change Event\n(World Added/Removed)
activate Hall
Hall -> Hall: Update ClientManager\nConnections
Hall -> World: Establish New\ngRPC Connection
activate World
World --> Hall: Connection Established
deactivate World
deactivate Hall

ZK -> Gate: Service Change Event\n(Hall Added/Removed)
activate Gate
Gate -> Gate: Update GameManager\nConnections
Gate -> Hall: Establish New\ngRPC Connection
activate Hall
Hall --> Gate: Connection Established
deactivate Hall
deactivate Gate

== Administrative Operations ==

Manager -> ZK: Query Service Status
activate ZK
ZK --> Manager: Service Registry Data
deactivate ZK

Manager -> Hall: Admin Command\n(HTTP/gRPC)
activate Hall
Hall -> Hall: Execute Admin Action
Hall --> Manager: Command Result
deactivate Hall

@enduml
