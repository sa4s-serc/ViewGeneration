@startuml
!define RECTANGLE class

title Teamgram Server - Component Diagram (Deployment & Connectivity)

package "Client Layer" {
  [Mobile Client] as mobile
  [Web Client] as web
  [Desktop Client] as desktop
}

package "BFF Layer" {
  [BFF Messages] as bff_msg
  [BFF Privacy Settings] as bff_privacy
  [BFF App Layer] as bff_app
}

package "Core Services" {
  [Message Service] as msg
  [Chat Service] as chat
  [User Service] as user
  [Media Service] as media
  [Dialog Service] as dialog
  [Updates Service] as updates
  [Username Service] as username
  [Auth Session Service] as authsession
  [Code Service] as code
}

package "Infrastructure Services" {
  [DFS Service] as dfs
  [ID Generator Service] as idgen
}

package "Data Storage Layer" {
  database "MySQL" as mysql
  database "Redis Cache" as redis
  database "MinIO Object Storage" as minio
}

package "Message Queue" {
  queue "Kafka" as kafka
}

package "Service Discovery" {
  [Etcd] as etcd
}

package "External Services" {
  [SMS Gateway] as sms
  [FFMPEG] as ffmpeg
}

mobile -down-> bff_app : gRPC
web -down-> bff_app : gRPC
desktop -down-> bff_app : gRPC

bff_app -down-> bff_msg : Internal
bff_app -down-> bff_privacy : Internal

bff_msg -down-> msg : gRPC
bff_msg -down-> chat : gRPC
bff_msg -down-> user : gRPC
bff_msg -down-> dialog : gRPC

bff_privacy -down-> user : gRPC

msg -down-> mysql : JDBC/SQL
msg -down-> redis : Redis Protocol
msg -down-> kafka : Kafka Protocol
msg --> updates : gRPC

chat -down-> mysql : JDBC/SQL
chat -down-> redis : Redis Protocol
chat --> user : gRPC
chat --> msg : gRPC

user -down-> mysql : JDBC/SQL
user -down-> redis : Redis Protocol
user --> idgen : gRPC

media -down-> dfs : gRPC
media -down-> mysql : JDBC/SQL
media --> ffmpeg : Library Call

dfs -down-> minio : S3 API
dfs -down-> mysql : JDBC/SQL

dialog -down-> mysql : JDBC/SQL
dialog -down-> redis : Redis Protocol
dialog --> updates : gRPC

updates -down-> redis : Redis Protocol
updates -down-> kafka : Kafka Producer

username -down-> mysql : JDBC/SQL
username -down-> redis : Redis Protocol

authsession -down-> mysql : JDBC/SQL
authsession -down-> redis : Redis Protocol
authsession --> user : gRPC
authsession --> code : gRPC

code -down-> redis : Redis Protocol
code --> sms : HTTP/REST

idgen -down-> redis : Redis Protocol

msg --> etcd : Service Registration
chat --> etcd : Service Registration
user --> etcd : Service Registration
media --> etcd : Service Registration
dialog --> etcd : Service Registration
updates --> etcd : Service Registration
username --> etcd : Service Registration
authsession --> etcd : Service Registration
code --> etcd : Service Registration
dfs --> etcd : Service Registration
idgen --> etcd : Service Registration

bff_msg --> etcd : Service Discovery
bff_privacy --> etcd : Service Discovery

note right of etcd
  Service Discovery
  for all microservices
end note

note right of kafka
  Asynchronous messaging
  for sync updates
end note

note right of redis
  Caching layer for:
  - User profiles
  - Phone codes
  - Session data
  - ID generation
end note

note right of mysql
  Persistent storage
  for all services
  using DAL/DAO pattern
end note

note right of minio
  Distributed file storage
  for media files
end note

@enduml
