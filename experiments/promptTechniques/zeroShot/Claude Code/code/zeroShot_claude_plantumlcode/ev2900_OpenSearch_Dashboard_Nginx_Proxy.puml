@startuml
skinparam componentStyle rectangle
skinparam linetype ortho

actor "User" as user

package "AWS Cloud" {

    rectangle "VPC" {

        rectangle "Public Subnet" as public_subnet {
            component "Internet Gateway" as igw <<Gateway>>
            component "Elastic IP" as eip <<Network>>

            rectangle "EC2 Instance" as ec2_instance {
                component "Nginx Proxy Server" as nginx <<Proxy>>
                component "SSL/TLS Certificate\n(Self-signed)" as ssl <<Security>>
            }

            component "Security Group (EC2)" as sg_ec2 <<Security>>
        }

        rectangle "Private Subnet" as private_subnet {
            rectangle "OpenSearch Domain" as os_domain {
                component "OpenSearch Service" as opensearch <<Analytics>>
                component "OpenSearch Dashboard" as dashboard <<UI>>
            }

            component "Security Group (OpenSearch)" as sg_os <<Security>>
        }

        component "Route Table" as route_table <<Routing>>
    }

    component "IAM Role & Instance Profile" as iam <<Identity>>
    component "S3 Bucket\n(CloudFormation Templates)" as s3 <<Storage>>
}

user -down-> eip : HTTPS (443)
eip -down-> igw : Routes through
igw -down-> nginx : Forwards to
nginx ..> ssl : Uses
nginx -down-> sg_ec2 : Protected by
nginx -right-> dashboard : Reverse Proxy\nHTTPS
dashboard -up-> opensearch : Part of
opensearch -right-> sg_os : Protected by
sg_ec2 -down-> sg_os : Allows traffic
ec2_instance -up-> iam : Assumes role
route_table -up-> igw : Routes public traffic
s3 ..> VPC : Deploys infrastructure\nvia CloudFormation

note right of nginx
  Acts as reverse proxy
  Forwards HTTPS requests
  to OpenSearch Dashboard
  in private subnet
end note

note right of opensearch
  Deployed in private subnet
  Not directly accessible
  from public internet
  Accessed only via Nginx
end note

note top of ssl
  Self-signed certificate
  Encrypts traffic between
  user and Nginx proxy
end note

note bottom of sg_ec2
  Controls inbound traffic
  Allows HTTPS (443)
  from public internet
end note

note bottom of sg_os
  Controls OpenSearch access
  Allows traffic only from
  EC2 security group
end note

note top of s3
  GitHub Actions workflow
  uploads CloudFormation
  template to S3
end note

@enduml
