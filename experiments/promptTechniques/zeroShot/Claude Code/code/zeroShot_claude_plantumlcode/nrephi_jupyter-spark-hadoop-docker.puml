@startuml
!define RECTANGLE package

title Dockerized Jupyter Spark Hadoop Cluster - Deployment Architecture

skinparam componentStyle rectangle
skinparam linetype ortho

package "Docker Host" {

    package "Custom Docker Network (my_network)" {

        package "Spark Cluster Services" {
            component "JupyterLab\nContainer" as jupyter {
                [JupyterLab Interface]
                [Spark Client APIs]
                [Scala/Python/R Kernels]
            }

            component "Spark Master\nContainer" as master {
                [Spark Master Process]
                [Cluster Manager]
                [Task Scheduler]
            }

            component "Spark Worker\nContainer(s)" as worker {
                [Spark Worker Process]
                [Task Executor]
            }
        }

        package "Hadoop Ecosystem Services" {
            component "Hadoop NameNode\nContainer" as namenode {
                [HDFS NameNode]
                [Namespace Manager]
            }

            component "Hadoop DataNode\nContainer" as datanode {
                [HDFS DataNode]
                [Block Storage]
            }

            component "Hive Server\nContainer" as hiveserver {
                [Hive Server Process]
                [Thrift Interface]
            }

            component "Hive Metastore\nContainer" as metastore {
                [Metastore Service]
            }

            component "PostgreSQL\nContainer" as postgres {
                [PostgreSQL DB]
                [Metastore Storage]
            }

            component "Hue\nContainer" as hue {
                [Hue Web Interface]
                [Hadoop UI]
            }

            component "MySQL\nContainer" as mysql {
                [MySQL DB]
                [Hue Metadata]
            }
        }
    }

    folder "Shared Volumes" {
        storage "shared-workspace" as workspace
        storage "hadoop-data" as hadoopdata
        storage "hive-data" as hivedata
    }

    folder "Configuration Files" {
        file "docker-compose.yml" as dc1
        file "docker-compose-hadoop.yml" as dc2
        file "hadoop.env" as henv
        file "hadoop-hive.env" as hhenv
        file "hue-overrides.ini" as hueconf
    }

    folder "Docker Images" {
        artifact "Base Image" as baseimg
        artifact "Spark Base Image" as sparkbaseimg
        artifact "Spark Master Image" as masterimg
        artifact "Spark Worker Image" as workerimg
        artifact "JupyterLab Image" as jupyterimg
    }
}

' Image build relationships
baseimg --> sparkbaseimg : extends
sparkbaseimg --> masterimg : extends
sparkbaseimg --> workerimg : extends
sparkbaseimg --> jupyterimg : extends

' Container deployment relationships
dc1 ..> jupyter : deploys
dc1 ..> master : deploys
dc1 ..> worker : deploys
dc2 ..> namenode : deploys
dc2 ..> datanode : deploys
dc2 ..> hiveserver : deploys
dc2 ..> metastore : deploys
dc2 ..> postgres : deploys
dc2 ..> hue : deploys
dc2 ..> mysql : deploys

' Configuration usage
henv ..> namenode : configures
henv ..> datanode : configures
hhenv ..> hiveserver : configures
hhenv ..> metastore : configures
hueconf ..> hue : configures

' Service interactions
jupyter --> master : submits jobs
master --> worker : distributes tasks
jupyter --> namenode : HDFS access
jupyter --> hiveserver : query execution

master ..> namenode : reads/writes data
worker ..> datanode : reads/writes data

hiveserver --> metastore : metadata access
metastore --> postgres : stores metadata
hiveserver --> namenode : HDFS access

hue --> mysql : stores config
hue --> namenode : HDFS UI
hue --> hiveserver : query interface

' Volume mounts
jupyter --> workspace : mounts
master --> workspace : mounts
worker --> workspace : mounts
namenode --> hadoopdata : mounts
datanode --> hadoopdata : mounts
hiveserver --> hivedata : mounts

note right of jupyter
  Entry point for users
  Port: 8888
  Languages: Scala, Python, R
end note

note right of master
  Cluster coordination
  Port: 8080 (UI)
  Port: 7077 (Master)
end note

note right of namenode
  HDFS metadata management
  Port: 9870 (UI)
end note

note right of hue
  Web UI for Hadoop
  Port: 8888
end note

note bottom of workspace
  Shared volume for
  data exchange between
  containers
end note

@enduml
