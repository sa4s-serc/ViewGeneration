@startuml
!define AWSPUML https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v14.0/dist
!include AWSPUML/AWSCommon.puml

title AWS Data Lake Training - Control Flow Sequence Diagram

actor User
participant "CloudFormation" as CF
participant "S3 Raw Bucket" as S3Raw
participant "S3 Landing Bucket" as S3Landing
participant "S3 Curated Bucket" as S3Curated
participant "EMR Spark\n(fda.01.land.py)" as SparkLand
participant "EMR Spark\n(fda.02.curate.py)" as SparkCurate
participant "AWS Glue" as Glue
participant "AWS Athena" as Athena
participant "Step Functions" as StepFunc
participant "Lambda\n(configure_count)" as LambdaConfig
participant "Lambda\n(query_athena)" as LambdaQuery
participant "Lambda\n(call_comprehend)" as LambdaComprehend
participant "Lambda\n(iterator)" as LambdaIterator
participant "Comprehend Medical" as ComprehendMed
participant "EMR Spark\n(fda.indications.py)" as SparkIndications

== Infrastructure Setup ==
User -> CF : Deploy CloudFormation templates
activate CF
CF -> S3Raw : Create raw bucket
activate S3Raw
CF -> S3Landing : Create landing bucket
activate S3Landing
CF -> S3Curated : Create curated bucket
activate S3Curated
CF --> User : Infrastructure deployed
deactivate CF

== Data Ingestion ==
User -> S3Raw : Ingest FDA drug label data\n(from public FDA S3)
S3Raw --> User : Data ingested

== Data Transformation - Landing ==
User -> SparkLand : Execute fda.01.land.py
activate SparkLand
SparkLand -> S3Raw : Read raw data
S3Raw --> SparkLand : Raw zipped JSON data
SparkLand -> SparkLand : Deflate zipped files
SparkLand -> SparkLand : Explode JSON arrays
SparkLand -> SparkLand : Initial transformations
SparkLand -> S3Landing : Write transformed data
S3Landing --> SparkLand : Write confirmation
SparkLand --> User : Landing transformation complete
deactivate SparkLand

== Data Transformation - Curation ==
User -> SparkCurate : Execute fda.02.curate.py
activate SparkCurate
SparkCurate -> S3Landing : Read landing data
S3Landing --> SparkCurate : Landing data
SparkCurate -> SparkCurate : Convert data types
SparkCurate -> SparkCurate : Partition data
SparkCurate -> S3Curated : Write curated data
S3Curated --> SparkCurate : Write confirmation
SparkCurate --> User : Curation complete
deactivate SparkCurate

== Data Cataloging ==
User -> Glue : Run Glue crawler
activate Glue
Glue -> S3Curated : Crawl curated data
S3Curated --> Glue : Data schema
Glue -> Glue : Create/update metadata catalog
Glue --> User : Catalog created
deactivate Glue

== Data Querying ==
User -> Athena : Query curated data (SQL)
activate Athena
Athena -> Glue : Retrieve metadata
Glue --> Athena : Table schema
Athena -> S3Curated : Execute query
S3Curated --> Athena : Query results
Athena --> User : Query results
deactivate Athena

== NLP Processing - Comprehend Medical Pipeline ==
User -> StepFunc : Deploy serverless.yml (SAM)
activate StepFunc
User -> StepFunc : Start Step Function execution
StepFunc -> LambdaConfig : Invoke configure_count
activate LambdaConfig
LambdaConfig -> LambdaConfig : Set processing counts
LambdaConfig --> StepFunc : Count configuration
deactivate LambdaConfig

loop While more data to process
    StepFunc -> LambdaQuery : Invoke query_athena
    activate LambdaQuery
    LambdaQuery -> Athena : Query drug indications
    activate Athena
    Athena -> S3Curated : Retrieve data
    S3Curated --> Athena : Drug label data
    Athena --> LambdaQuery : Query results (chunks)
    deactivate Athena
    LambdaQuery --> StepFunc : Drug label text chunks
    deactivate LambdaQuery

    StepFunc -> LambdaComprehend : Invoke call_comprehend
    activate LambdaComprehend
    LambdaComprehend -> ComprehendMed : Extract medical entities\n(indications)
    activate ComprehendMed
    ComprehendMed -> ComprehendMed : NLP processing
    ComprehendMed --> LambdaComprehend : Extracted entities
    deactivate ComprehendMed
    LambdaComprehend -> S3Curated : Store extracted indications
    S3Curated --> LambdaComprehend : Write confirmation
    LambdaComprehend --> StepFunc : Processing complete
    deactivate LambdaComprehend

    StepFunc -> LambdaIterator : Invoke iterator
    activate LambdaIterator
    LambdaIterator -> LambdaIterator : Check if more chunks\nto process
    LambdaIterator --> StepFunc : Continue/Stop flag
    deactivate LambdaIterator
end

StepFunc --> User : Comprehend pipeline complete
deactivate StepFunc

== Combine Results ==
User -> SparkIndications : Execute fda.indications.py
activate SparkIndications
SparkIndications -> S3Curated : Read FDA product labels
S3Curated --> SparkIndications : Product label data
SparkIndications -> S3Curated : Read extracted indications
S3Curated --> SparkIndications : Indication data
SparkIndications -> SparkIndications : Join and combine data
SparkIndications -> S3Curated : Write final combined dataset
S3Curated --> SparkIndications : Write confirmation
SparkIndications --> User : Final dataset ready
deactivate SparkIndications

== Final Analysis ==
User -> Athena : Query final combined dataset
activate Athena
Athena -> S3Curated : Query combined data
S3Curated --> Athena : Results
Athena --> User : Analysis results
deactivate Athena

deactivate S3Raw
deactivate S3Landing
deactivate S3Curated

@enduml
