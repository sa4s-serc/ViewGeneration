@startuml
!define RECTANGLE class

title Event Tracking System - Control Flow Sequence Diagram

actor User
participant "React Frontend" as Frontend
participant "Gateway Service" as Gateway
participant "User Service" as UserService
participant "Tracking Service" as TrackingService
participant "Redis Pub/Sub" as Redis
participant "PostgreSQL" as Database

== User Registration ==
User -> Frontend: Register
activate Frontend
Frontend -> Gateway: POST /users/register
activate Gateway
Gateway -> UserService: POST /users
activate UserService
UserService -> Database: Create User
activate Database
Database --> UserService: User Created
deactivate Database
UserService --> Gateway: User Data + Tokens
deactivate UserService
Gateway --> Frontend: User Data + Tokens
deactivate Gateway
Frontend --> User: Registration Success
deactivate Frontend

== User Login ==
User -> Frontend: Login
activate Frontend
Frontend -> Gateway: POST /auth/login
activate Gateway
Gateway -> UserService: POST /auth/login
activate UserService
UserService -> Database: Validate Credentials
activate Database
Database --> UserService: User Data
deactivate Database
UserService -> UserService: Generate Access & Refresh Tokens
UserService --> Gateway: Tokens
deactivate UserService
Gateway --> Frontend: Access & Refresh Tokens
deactivate Gateway
Frontend -> Frontend: Store Tokens
Frontend --> User: Login Success
deactivate Frontend

== SDK Integration Setup ==
User -> Frontend: Request SDK Snippet
activate Frontend
Frontend -> Frontend: Generate SDK Code Snippet
Frontend --> User: Display SDK Code
deactivate Frontend

== Event Tracking Flow ==
User -> Frontend: User Action on Integrated App
activate Frontend
Frontend -> Frontend: Execute Tracking SDK
Frontend -> Gateway: POST /events (with API key)
activate Gateway
Gateway -> Gateway: Validate API Key
Gateway -> Redis: Publish Event to "events" channel
activate Redis
Redis --> Gateway: Event Published
deactivate Redis
Gateway --> Frontend: Event Received (202 Accepted)
deactivate Gateway
Frontend --> User: Action Completed
deactivate Frontend

Redis -> TrackingService: Subscribe: New Event Message
activate TrackingService
TrackingService -> TrackingService: Process Event Data
TrackingService -> Database: Store Event
activate Database
Database --> TrackingService: Event Stored
deactivate Database
deactivate TrackingService

== Dashboard - View Overview ==
User -> Frontend: Access Dashboard
activate Frontend
Frontend -> Gateway: GET /events/overview (with Auth Token)
activate Gateway
Gateway -> Gateway: Validate Access Token
Gateway -> TrackingService: GET /events/overview
activate TrackingService
TrackingService -> Database: Query Overview Statistics\n(Active Users, Event Counts, Page Visits)
activate Database
Database --> TrackingService: Aggregated Data
deactivate Database
TrackingService --> Gateway: Overview Data
deactivate TrackingService
Gateway --> Frontend: Overview Data
deactivate Gateway
Frontend -> Frontend: Render Dashboard Components\n(Chart, EventTable, Overview)
Frontend --> User: Display Dashboard
deactivate Frontend

== User Profile Management ==
User -> Frontend: Update Profile
activate Frontend
Frontend -> Gateway: PUT /users/profile (with Auth Token)
activate Gateway
Gateway -> Gateway: Validate Access Token
Gateway -> UserService: PUT /users/profile
activate UserService
UserService -> Database: Update User Data
activate Database
Database --> UserService: Updated User
deactivate Database
UserService --> Gateway: Updated Profile
deactivate UserService
Gateway --> Frontend: Updated Profile
deactivate Gateway
Frontend --> User: Profile Updated
deactivate Frontend

== Token Refresh ==
Frontend -> Gateway: POST /auth/refresh (with Refresh Token)
activate Frontend
activate Gateway
Gateway -> UserService: POST /auth/refresh
activate UserService
UserService -> UserService: Validate Refresh Token
UserService -> UserService: Generate New Access Token
UserService --> Gateway: New Access Token
deactivate UserService
Gateway --> Frontend: New Access Token
deactivate Gateway
Frontend -> Frontend: Update Stored Token
deactivate Frontend

== User Logout ==
User -> Frontend: Logout
activate Frontend
Frontend -> Gateway: POST /auth/logout (with Refresh Token)
activate Gateway
Gateway -> UserService: POST /auth/logout
activate UserService
UserService -> Database: Invalidate Refresh Token
activate Database
Database --> UserService: Token Invalidated
deactivate Database
UserService --> Gateway: Logout Success
deactivate UserService
Gateway --> Frontend: Logout Success
deactivate Gateway
Frontend -> Frontend: Clear Stored Tokens
Frontend --> User: Logout Complete
deactivate Frontend

== View Active Users ==
User -> Frontend: Request Active Users
activate Frontend
Frontend -> Gateway: GET /events/active-users (with Auth Token)
activate Gateway
Gateway -> Gateway: Validate Access Token
Gateway -> TrackingService: GET /events/active-users
activate TrackingService
TrackingService -> Database: Query Active Users
activate Database
Database --> TrackingService: Active User Data
deactivate Database
TrackingService --> Gateway: Active User List
deactivate TrackingService
Gateway --> Frontend: Active User List
deactivate Gateway
Frontend -> Frontend: Render Active User Components
Frontend --> User: Display Active Users
deactivate Frontend

@enduml
