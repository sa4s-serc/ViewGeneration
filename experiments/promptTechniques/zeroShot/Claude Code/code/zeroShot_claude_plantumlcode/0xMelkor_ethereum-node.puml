@startuml
skinparam rectangle {
    BackgroundColor<<external>> LightBlue
    BackgroundColor<<kubernetes>> LightGreen
    BackgroundColor<<storage>> LightYellow
}

title Ethereum Node Deployment on GKE - Component Diagram

cloud "Google Cloud Platform" {

    package "Google Cloud Services" {
        component "Cloud Build" as CloudBuild
        component "Secret Manager" as SecretManager
        database "Container Registry" as ContainerRegistry
    }

    package "Google Kubernetes Engine (GKE)" {

        node "Kubernetes Cluster" {

            package "Ingress Layer" {
                component "Ingress Controller" as Ingress
            }

            package "Reverse Proxy Layer" {
                component "Nginx\n(Reverse Proxy)" as Nginx
                component "Nginx Service\n(LoadBalancer/NodePort)" as NginxService
            }

            package "Ethereum Node Components" {
                component "Geth Pod\n(Execution Layer)" as Geth {
                    portin "RPC HTTP" as GethHTTP
                    portin "RPC WebSocket" as GethWS
                    portin "Metrics" as GethMetrics
                    portout "P2P" as GethP2P
                }

                component "Lighthouse Pod\n(Consensus Layer)" as Lighthouse {
                    portin "Beacon API" as LighthouseAPI
                    portout "P2P" as LighthouseP2P
                }

                component "Geth Service\n(ClusterIP)" as GethService
                component "Lighthouse Service\n(ClusterIP)" as LighthouseService
            }

            package "Monitoring Layer" {
                component "InfluxDB StatefulSet" as InfluxDB {
                    portin "HTTP API" as InfluxHTTP
                }
                component "InfluxDB Service\n(Headless)" as InfluxDBService
            }

            package "Persistent Storage" {
                storage "Geth PVC\n(2000Gi)" as GethPVC
                storage "Lighthouse PVC\n(500Gi)" as LighthousePVC
                storage "InfluxDB PVC" as InfluxDBPVC
            }

            package "Configuration" {
                component "JWT Secret" as JWTSecret
                component "InfluxDB Credentials" as InfluxCreds
                component "ConfigMaps/Secrets" as K8sSecrets
            }
        }
    }

    cloud "External Networks" {
        actor "External Users" as Users
        cloud "Ethereum P2P Network" as EthNetwork
    }
}

' CI/CD Flow
CloudBuild --> SecretManager : fetch secrets
CloudBuild --> ContainerRegistry : build & push images
CloudBuild --> Nginx : deploy
CloudBuild --> Geth : deploy
CloudBuild --> Lighthouse : deploy
CloudBuild --> InfluxDB : deploy

' Secret Management
SecretManager --> K8sSecrets : inject secrets
K8sSecrets --> JWTSecret : provide
K8sSecrets --> InfluxCreds : provide
K8sSecrets --> Nginx : CRYSTAL_MEV_API_KEY

' External Access
Users --> Ingress : HTTPS requests
Ingress --> NginxService : route traffic
NginxService --> Nginx : forward

' Nginx Reverse Proxy Routing
Nginx --> GethService : proxy RPC HTTP
Nginx --> GethService : proxy RPC WebSocket
Nginx --> InfluxDBService : proxy metrics API

' Service to Pod Communication
GethService --> Geth : route
LighthouseService --> Lighthouse : route
InfluxDBService --> InfluxDB : route

' Inter-component Communication
Geth --> Lighthouse : JWT authenticated\nEngine API
Lighthouse --> Geth : JWT authenticated\nExecution requests
Geth --> InfluxDBService : push metrics
GethMetrics --> InfluxDB : metrics data

' P2P Network Communication
Geth --> EthNetwork : sync blocks\nP2P protocol
Lighthouse --> EthNetwork : sync beacon chain\nP2P protocol

' Storage Mounts
Geth --> GethPVC : mount data directory
Lighthouse --> LighthousePVC : mount data directory
InfluxDB --> InfluxDBPVC : mount data directory

' Authentication
JWTSecret ..> Geth : authenticate
JWTSecret ..> Lighthouse : authenticate
InfluxCreds ..> InfluxDB : configure
InfluxCreds ..> Geth : configure metrics

note right of Nginx
  Exposes:
  - Geth RPC HTTP
  - Geth WebSocket
  - InfluxDB API
  Uses envsubst for
  API key injection
end note

note right of Geth
  Execution Layer
  Resources: CPU/Memory limits
  Port: 8545 (HTTP)
  Port: 8546 (WebSocket)
  Port: 30303 (P2P)
end note

note right of Lighthouse
  Consensus Layer
  Beacon Chain sync
  Port: 9000 (P2P)
  Port: 5052 (API)
end note

note right of InfluxDB
  StatefulSet deployment
  Headless service for
  stable network identity
  Collects Geth metrics
end note

note left of CloudBuild
  Automated CI/CD
  - Secret substitution
  - Apply K8s manifests
  - Infrastructure setup
end note

@enduml
