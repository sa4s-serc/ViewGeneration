@startuml

skinparam component {
    BackgroundColor<<client>> LightBlue
    BackgroundColor<<server>> LightGreen
    BackgroundColor<<infrastructure>> LightYellow
    BorderColor Black
    ArrowColor Black
}

skinparam package {
    BackgroundColor White
    BorderColor Black
}

package "Client-Side (Browser)" <<client>> {
    component [Game\n(Game Loop, Rendering,\nScene Manager)] as Game
    component [GameClient\n(WebSocket Handler,\nMessage Parser)] as GameClient
    component [GameDOMHandler\n(UI Controller,\nDisplay Updater)] as DOMHandler
    component [GameElements\n(Object Factories)] as GameElements
    component [TextureLoader\n(Texture Cache)] as TextureLoader
}

package "Communication Layer" <<infrastructure>> {
    component [WebSocket Connection] as WebSocket
    interface "WebSocket Protocol" as WSProtocol
}

package "Server-Side (Erlang/OTP)" <<server>> {
    component [earth_defender_app\n(Cowboy Server,\nApp Controller)] as App
    component [websocket_handler\n(Connection Manager,\nMessage Router)] as WSHandler
    component [earth_defender_sup\n(Process Monitor,\nRestart Strategy)] as Supervisor
    component [room\n(Game Logic,\nState Manager,\nCollision Detection)] as Room
    component [local_rooms_state\n(Room Registry,\nState Synchronizer)] as RoomsState
    component [player\n(Player State,\nAction Handler)] as Player
    component [monitor_mesh\n(Node Monitor,\nFailover Manager)] as MonitorMesh
    component [slave_handler\n(Replication Logic,\nSync Handler)] as SlaveHandler
}

package "Distributed Erlang Cluster" <<infrastructure>> {
    component [Master Node] as MasterNode
    component [Slave Node 1] as SlaveNode1
    component [Slave Node 2] as SlaveNode2
    interface "Erlang Distribution\nProtocol" as ErlangDistribution
}

Game --> GameClient : sends player\nactions
Game --> DOMHandler : updates UI
Game --> GameElements : creates objects
GameElements --> TextureLoader : loads textures
GameClient --> Game : receives game\nstate
DOMHandler --> GameClient : triggers\ncommands

GameClient --> WSProtocol : connects via
WSProtocol --> WebSocket : establishes
WebSocket --> WSHandler : routes messages

App --> Supervisor : starts
Supervisor --> WSHandler : supervises
Supervisor --> Room : supervises
Supervisor --> RoomsState : supervises
Supervisor --> MonitorMesh : supervises

WSHandler --> RoomsState : queries room\nstate
WSHandler --> Player : manages
WSHandler --> Room : forwards events

Room --> Player : updates player\nstate
Room --> RoomsState : registers with
RoomsState --> Room : broadcasts state

MonitorMesh --> Supervisor : reports failures
MonitorMesh --> SlaveHandler : coordinates with

Room --> ErlangDistribution : replicates via
RoomsState --> ErlangDistribution : syncs via
SlaveHandler --> ErlangDistribution : communicates via

ErlangDistribution --> MasterNode : connects
ErlangDistribution --> SlaveNode1 : connects
ErlangDistribution --> SlaveNode2 : connects

MasterNode --> SlaveNode1 : replicates to
MasterNode --> SlaveNode2 : replicates to
SlaveNode1 ..> MasterNode : failover
SlaveNode2 ..> MasterNode : failover

WSHandler --> WebSocket : sends game state
WebSocket --> GameClient : delivers updates

note right of WebSocket
    Real-time bidirectional
    communication protocol
    for low-latency game state
    synchronization
end note

note right of ErlangDistribution
    Distributed Erlang protocol
    enables node-to-node
    communication for
    replication and failover
end note

note bottom of MonitorMesh
    Monitors cluster health
    and triggers automatic
    failover on node failure
end note

note left of GameClient
    Single WebSocket connection
    per client for all
    game communications
end note

@enduml
