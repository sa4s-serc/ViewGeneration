@startuml
!define RECTANGLE component

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<builder>> LightGreen
    BackgroundColor<<storage>> LightYellow
    BackgroundColor<<monitoring>> LightPink
    BackgroundColor<<external>> LightGray
}

package "Foundry Application" {
    [Main Application] <<core>> as Main
    [Configuration] <<core>> as Config
    [Logging] <<monitoring>> as Logging
}

package "Furnace Core" {
    [Furnace Service] <<core>> as Furnace
    [Package Map\n(pkgMap)] <<core>> as PkgMap
    [Build Scheduler] <<core>> as Scheduler
    [Build Queue\n(Channel)] <<core>> as BuildQueue
    [Worker Pool] <<core>> as WorkerPool
}

package "gRPC Interface" {
    [gRPC Server] <<core>> as GRPC
    [Furnace Proto\n(furnacepb)] <<core>> as Proto
}

package "Builder System" {
    interface "Builder Interface" as IBuilder
    [MakepkgBuilder] <<builder>> as Makepkg
    [NoOpBuilder] <<builder>> as NoOp
    [BuilderWithMetrics] <<builder>> as MetricsBuilder
}

package "Monitoring & Health" {
    [Internal HTTP Server] <<monitoring>> as HTTPServer
    [Health Checks] <<monitoring>> as Health
    [Prometheus Metrics] <<monitoring>> as Metrics
    [pprof Profiling] <<monitoring>> as Profiling
}

package "External Systems" {
    [Object Storage\n(Bucket)] <<storage>> as Storage
    [Arch User Repository\n(AUR)] <<external>> as AUR
    [Arch Build System\n(makepkg)] <<external>> as ArchBuild
}

package "Client Layer" {
    [gRPC Clients] <<external>> as Clients
}

' Main application connections
Main --> Config : uses
Main --> Logging : initializes
Main --> HTTPServer : starts
Main --> Furnace : creates & runs

' Furnace core connections
Furnace --> GRPC : registers service
Furnace --> PkgMap : manages state
Furnace --> BuildQueue : enqueues builds
Furnace --> Scheduler : schedules builds
Furnace ..> Proto : implements

' Build queue and scheduler
BuildQueue --> Scheduler : feeds requests
Scheduler --> WorkerPool : dispatches to
WorkerPool --> IBuilder : executes build

' Builder relationships
IBuilder <|.. Makepkg : implements
IBuilder <|.. NoOp : implements
MetricsBuilder --> IBuilder : decorates
Furnace --> MetricsBuilder : uses

' Builder to external systems
Makepkg --> AUR : fetches package info
Makepkg --> ArchBuild : invokes makepkg
Makepkg --> Storage : uploads package

' Monitoring connections
HTTPServer --> Health : exposes /health
HTTPServer --> Metrics : exposes /metrics
HTTPServer --> Profiling : exposes /debug/pprof
MetricsBuilder --> Metrics : records build metrics
Furnace --> Metrics : records queue metrics

' Client interactions
Clients --> GRPC : BuildRequest
Clients --> GRPC : QueueStatus
GRPC --> Furnace : delegates

' Package state management
PkgMap --> Furnace : tracks build states\n(queued, building, built, error)

note right of Furnace
  Stateless design enables
  horizontal scaling
end note

note right of BuildQueue
  Asynchronous processing
  via Go channels
end note

note right of WorkerPool
  Parallel processing
  using goroutines
end note

note bottom of IBuilder
  Pluggable builder strategy
  for different build types
end note

note right of Storage
  Scalable object storage
  for built packages
end note

@enduml
