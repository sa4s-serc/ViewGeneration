@startuml
!define RECTANGLE class

title BTCPay Server - Deployment Architecture

package "Deployment Options" {
  component [Docker Deployment] as Docker
  component [Azure Deployment] as Azure
  component [LunaNode Deployment] as LunaNode
  component [Manual Deployment] as Manual
  component [Web Deployment] as WebDeploy
  component [Hardware Deployment\n(Raspberry Pi 4)] as Hardware
  component [Third-Party Hosting] as ThirdParty
}

package "BTCPay Server Instance" {
  component [BTCPay Server Core] as BTCPayCore
  component [Plugin System] as Plugins
  component [Greenfield API] as GreenfieldAPI
  component [BitPay API] as BitPayAPI
  component [Theme Engine] as ThemeEngine
  component [Web Interface] as WebUI
}

package "Core Services" {
  component [Bitcoin Core] as BitcoinCore
  component [NBXplorer] as NBXplorer
  component [Lightning Network Daemon\n(LND)] as LND
  component [Altcoin Nodes] as Altcoins
}

package "Data Layer" {
  database [PostgreSQL/SQLite] as Database
  storage [Blockchain Data] as BlockchainData
  storage [Configuration Files] as ConfigFiles
}

package "External Integrations" {
  component [WooCommerce] as WooCommerce
  component [Shopify] as Shopify
  component [PrestaShop] as PrestaShop
  component [Drupal] as Drupal
  component [Custom Applications] as CustomApps
}

package "Setup & Maintenance" {
  component [btcpay-setup.sh] as SetupScript
  component [setup-deps.sh] as DepsScript
  component [rpi4-install.sh] as RPiScript
}

package "User Applications" {
  component [Point of Sale App] as POS
  component [Crowdfunding App] as Crowdfund
  component [Payment Buttons] as PayButtons
}

package "Documentation Site" {
  component [VuePress] as VuePress
  component [Markdown Content] as MarkdownDocs
  component [Theme Components] as ThemeComponents
  component [Build Pipeline\n(GitHub Actions)] as BuildPipeline
}

' Deployment relationships
Docker --> BTCPayCore : deploys
Azure --> BTCPayCore : deploys
LunaNode --> BTCPayCore : deploys
Manual --> BTCPayCore : deploys
WebDeploy --> BTCPayCore : deploys
Hardware --> BTCPayCore : deploys
ThirdParty --> BTCPayCore : hosts

' Setup script relationships
SetupScript --> Docker : configures
DepsScript --> Manual : prepares
RPiScript --> Hardware : installs

' BTCPay Server internal relationships
BTCPayCore --> Plugins : loads
BTCPayCore --> GreenfieldAPI : exposes
BTCPayCore --> BitPayAPI : exposes
BTCPayCore --> ThemeEngine : uses
BTCPayCore --> WebUI : serves
BTCPayCore --> Database : persists data

' Core service dependencies
BTCPayCore --> BitcoinCore : connects to
BTCPayCore --> NBXplorer : uses
BTCPayCore --> LND : integrates
BTCPayCore --> Altcoins : supports
NBXplorer --> BitcoinCore : monitors
NBXplorer --> BlockchainData : reads
BitcoinCore --> BlockchainData : stores
LND --> BitcoinCore : requires

' Configuration
BTCPayCore --> ConfigFiles : reads

' External integrations
WooCommerce --> GreenfieldAPI : uses
Shopify --> GreenfieldAPI : uses
PrestaShop --> GreenfieldAPI : uses
Drupal --> GreenfieldAPI : uses
CustomApps --> GreenfieldAPI : integrates

' User applications
POS --> BTCPayCore : uses
Crowdfund --> BTCPayCore : uses
PayButtons --> BTCPayCore : uses

' Documentation site relationships
BuildPipeline --> VuePress : builds
VuePress --> MarkdownDocs : processes
VuePress --> ThemeComponents : renders
ThemeComponents --> ThemeEngine : documents

note right of Docker
  Preferred deployment method
  Uses Docker Compose
  Includes all services
end note

note right of SetupScript
  Initial configuration
  Automated setup
  Environment preparation
end note

note bottom of BTCPayCore
  Self-hosted payment processor
  Plugin-based architecture
  API-centric design
end note

note right of GreenfieldAPI
  Primary integration API
  RESTful interface
  Modern API standard
end note

note left of NBXplorer
  Blockchain indexer
  Transaction monitoring
  Microservice component
end note

@enduml
