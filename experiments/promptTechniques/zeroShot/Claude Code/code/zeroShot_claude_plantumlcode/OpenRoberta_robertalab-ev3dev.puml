@startuml
title Open Roberta Lab EV3 Connector - Connectivity Architecture

package "EV3 Brick" {
    package "UI Layer" {
        component [Brickman UI] as BrickmanUI
    }

    package "Service Layer" {
        component [Service\nroberta.lab.Service] as Service
    }

    package "Network Layer" {
        component [Connector\nroberta.lab.Connector] as Connector
    }

    package "Execution Layer" {
        component [Code Executor] as Executor
        component [AbortHandler\nroberta.lab.AbortHandler] as AbortHandler
    }

    package "HAL Layer" {
        component [Hal\nroberta.ev3.Hal] as HAL
        component [GfxMode\nroberta.lab.GfxMode] as GfxMode
    }

    package "ev3dev Layer" {
        component [ev3dev Library\nev3dev.auto] as EV3Dev
    }
}

cloud "Internet" {
    component [Open Roberta Lab Server] as RobertaServer
}

interface "DBus Protocol" as DBus
interface "HTTP/HTTPS" as HTTP
interface "Thread Communication" as ThreadComm
interface "Python Execution" as PyExec
interface "Hardware Access" as HwAccess

BrickmanUI -down- DBus
DBus -down- Service

Service -down- ThreadComm
ThreadComm -down- Connector

Connector -down- HTTP
HTTP -down- RobertaServer

Connector -down-> Executor : downloads & executes
Executor -down-> HAL : uses
HAL -down-> EV3Dev : controls hardware
GfxMode -down-> EV3Dev : manages display
AbortHandler -down-> EV3Dev : monitors keys

Connector .right.> Connector : retry\nmechanism

note right of Service
  Entry point for external interaction
  Manages connection state
  Emits DBus signals
end note

note right of Connector
  Handles HTTP communication
  Implements retry logic
  Downloads Python code
  Manages registration
end note

note right of HTTP
  Connection Protocol:
  - Registration requests
  - State polling
  - Code download
  - Status updates
end note

note left of DBus
  Local IPC:
  - Connection requests
  - Status notifications
  - Control commands
end note

note bottom of HAL
  Hardware Abstraction:
  - Motors, Sensors
  - Display, LEDs, Sound
end note

@enduml
