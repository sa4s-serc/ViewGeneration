@startuml
!define RECTANGLE class

actor User
participant "Frontend\n(ReactJS)" as Frontend
participant "Webserver\n(Nginx)" as Webserver
participant "Gateway\n(Spring Boot)" as Gateway
participant "Employee Service\n(Golang/Gin)" as EmployeeService
participant "Attendance Service\n(Golang/Gin)" as AttendanceService
participant "Salary Service\n(Golang/Gin)" as SalaryService
participant "Notification Service\n(Python)" as NotificationService
database "MySQL" as MySQL
database "Elasticsearch" as Elasticsearch

== Employee Creation Flow ==
User -> Frontend: Create Employee Request
Frontend -> Webserver: HTTP Request
Webserver -> Gateway: Forward Request
activate Gateway
Gateway -> EmployeeService: POST /employee
activate EmployeeService
EmployeeService -> Elasticsearch: Store Employee Data
Elasticsearch --> EmployeeService: Confirmation
EmployeeService --> Gateway: Employee Created Response
deactivate EmployeeService
Gateway --> Webserver: Response
Webserver --> Frontend: Response
Frontend --> User: Display Success

== Attendance Creation Flow ==
User -> Frontend: Record Attendance
Frontend -> Webserver: HTTP Request
Webserver -> Gateway: Forward Request
activate Gateway
Gateway -> AttendanceService: POST /attendance
activate AttendanceService
AttendanceService -> MySQL: Insert Attendance Record
MySQL --> AttendanceService: Confirmation
AttendanceService --> Gateway: Attendance Created Response
deactivate AttendanceService
Gateway --> Webserver: Response
Webserver --> Frontend: Response
Frontend --> User: Display Success

== Employee Search Flow ==
User -> Frontend: Search Employee
Frontend -> Webserver: HTTP Request
Webserver -> Gateway: Forward Request
activate Gateway
Gateway -> EmployeeService: GET /employee/search
activate EmployeeService
EmployeeService -> Elasticsearch: Query Employee Data
Elasticsearch --> EmployeeService: Employee Records
EmployeeService --> Gateway: Employee Data Response
deactivate EmployeeService
Gateway --> Webserver: Response
Webserver --> Frontend: Response
Frontend --> User: Display Results

== Attendance Search Flow ==
User -> Frontend: Search Attendance
Frontend -> Webserver: HTTP Request
Webserver -> Gateway: Forward Request
activate Gateway
Gateway -> AttendanceService: GET /attendance/search
activate AttendanceService
AttendanceService -> MySQL: Query Attendance Records
MySQL --> AttendanceService: Attendance Data
AttendanceService --> Gateway: Attendance Data Response
deactivate AttendanceService
Gateway --> Webserver: Response
Webserver --> Frontend: Response
Frontend --> User: Display Results

== Salary Calculation Flow ==
User -> Frontend: Fetch Salary
Frontend -> Webserver: HTTP Request
Webserver -> Gateway: Forward Request
activate Gateway
Gateway -> SalaryService: GET /salary
activate SalaryService
SalaryService -> Elasticsearch: Retrieve Salary Data
Elasticsearch --> SalaryService: Salary Information
SalaryService --> Gateway: Salary Response
deactivate SalaryService
Gateway --> Webserver: Response
Webserver --> Frontend: Response
Frontend --> User: Display Salary

== Notification Flow ==
NotificationService -> Elasticsearch: Retrieve Employee Data
activate NotificationService
Elasticsearch --> NotificationService: Employee Information
NotificationService -> Elasticsearch: Retrieve Salary Data
Elasticsearch --> NotificationService: Salary Information
NotificationService -> NotificationService: Generate Salary Slip
NotificationService -> User: Send Email Notification
deactivate NotificationService

@enduml
