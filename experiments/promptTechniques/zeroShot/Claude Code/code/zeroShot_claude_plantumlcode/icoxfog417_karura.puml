@startuml
title Karura Machine Learning Platform - Control Flow

actor User
participant "Kintone Client\n(Browser)" as Client
participant "Karura Plugin\n(karura.client.js)" as Plugin
participant "Karura Master App\n(karura.master.js)" as Master
participant "Tornado Server\n(app.py)" as Server
participant "Model Manager\n(model_manager.py)" as Manager
participant "Dataset\n(dataset.py)" as Dataset
participant "Field Manager\n(field_manager.py)" as FieldMgr
participant "Feature Builder\n(feature_builder.py)" as FeatureBuilder
participant "Model Builder\n(model_builder.py)" as ModelBuilder
database "Kintone API" as KintoneAPI
database "Model Storage\n(store/)" as Storage

== Configuration Phase ==
User -> Client: Configure ML task
Client -> Master: Setup fields and target
Master -> Plugin: Define feature fields
Plugin -> Client: Display configuration

== Training Flow ==
User -> Client: Trigger model training
Client -> Plugin: Initiate training request
Plugin -> Server: POST /train\n(app_id, target_field)
activate Server

Server -> Manager: train(app_id, target_field)
activate Manager

Manager -> Dataset: load_dataset(app_id)
activate Dataset
Dataset -> KintoneAPI: Fetch data records
KintoneAPI --> Dataset: Return records
Dataset -> Dataset: Validate data sufficiency
Dataset --> Manager: Return DataSet object
deactivate Dataset

Manager -> FieldMgr: load(fields)
activate FieldMgr
FieldMgr -> FieldMgr: Define field types\n(features, target)
FieldMgr --> Manager: Return field definitions
deactivate FieldMgr

Manager -> FeatureBuilder: Select relevant features
activate FeatureBuilder
FeatureBuilder -> FeatureBuilder: Feature selection analysis
FeatureBuilder --> Manager: Return selected features
deactivate FeatureBuilder

Manager -> ModelBuilder: build(dataset, target_type)
activate ModelBuilder
ModelBuilder -> ModelBuilder: Select model type\n(SVC/SVR/ElasticNet)
ModelBuilder -> ModelBuilder: Hyperparameter tuning\n(GridSearchCV)
ModelBuilder -> ModelBuilder: Train model
ModelBuilder --> Manager: Return trained model
deactivate ModelBuilder

Manager -> Storage: Save model (joblib)
Manager -> Storage: Save field config (json)
Manager --> Server: Return training result\n(metrics, status)
deactivate Manager

Server --> Plugin: Training complete\n(model_id, metrics)
deactivate Server
Plugin --> Client: Display training results
Client --> User: Show model metrics

== Prediction Flow ==
User -> Client: Request prediction
Client -> Plugin: Trigger prediction
Plugin -> Server: POST /predict\n(model_id, input_data)
activate Server

Server -> Manager: predict(model_id, data)
activate Manager

Manager -> Storage: Load model (joblib)
Manager -> Storage: Load field config (json)

Manager -> FieldMgr: Format input data
activate FieldMgr
FieldMgr -> FieldMgr: Convert values\nto proper types
FieldMgr --> Manager: Return formatted data
deactivate FieldMgr

Manager -> ModelBuilder: predict(formatted_data)
activate ModelBuilder
ModelBuilder -> ModelBuilder: Generate prediction
ModelBuilder --> Manager: Return prediction result
deactivate ModelBuilder

Manager --> Server: Return prediction
deactivate Manager

Server --> Plugin: Prediction response
deactivate Server
Plugin --> Client: Display prediction
Client --> User: Show prediction result

== Health Check ==
Server -> Server: GET /ping
Server --> Server: Return "ok"

@enduml
