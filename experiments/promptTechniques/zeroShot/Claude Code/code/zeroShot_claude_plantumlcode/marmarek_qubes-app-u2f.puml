@startuml
!define RECTANGLE_STYLE skinparam rectangleBackgroundColor<<security>> LightYellow

title Qubes OS CTAP Proxy - Security Architecture

package "Browser VM (Untrusted)" {
    component [Web Browser] as Browser
    component [CTAP Client] as CTAPClient

    package "qubesctap.client" {
        component [HID Emulator\n(CTAPHIDDevice)] as HIDEmu
        component [CTAP1/U2F Handler] as CTAP1Client
        component [CTAP2 Handler] as CTAP2Client
    }
}

package "Qrexec Secure Communication Layer" <<security>> {
    component [Qrexec Transport] as QrexecTransport
    component [Policy Enforcement] as PolicyEngine

    interface "qubes.CTAP" as CTAPInterface
    interface "qubes.CTAP2" as CTAP2Interface
}

package "sys-usb VM (Hardware Access)" {
    package "qubesctap.sys_usb" {
        component [CTAP Protocol Parser] as ProtocolParser
        component [CTAP1 Request Handler] as CTAP1Server
        component [CTAP2 Request Handler] as CTAP2Server
        component [USB HID Driver] as USBDriver
    }
}

package "Physical Hardware" {
    component [CTAP HID Token\n(USB Security Key)] as HIDToken
}

package "Configuration & Security Policy" <<security>> {
    file "/etc/qubes/qubes-rpc-policy" as PolicyFiles
    file "/etc/qubes/ctap-version" as VersionConfig
    file "/usr/local/etc/qubes" as LocalConfig
}

package "System Services" {
    component [systemd daemon] as SystemdDaemon
    component [udev rules\n(60-qctap-hidraw)] as UdevRules
}

' Browser VM interactions
Browser --> CTAPClient : CTAP Authentication Request
CTAPClient --> HIDEmu : HID Device Interface
HIDEmu --> CTAP1Client : U2F/CTAP1 Protocol
HIDEmu --> CTAP2Client : CTAP2 Protocol

' Secure communication through Qrexec
CTAP1Client --> CTAPInterface : Authentication Request
CTAP2Client --> CTAP2Interface : Authentication Request

CTAPInterface --> QrexecTransport : Secure IPC Channel
CTAP2Interface --> QrexecTransport : Secure IPC Channel

QrexecTransport --> PolicyEngine : Enforce Access Control
PolicyEngine --> PolicyFiles : Read Policies

' sys-usb VM processing
QrexecTransport --> ProtocolParser : Forward Request
ProtocolParser --> CTAP1Server : CTAP1 Message
ProtocolParser --> CTAP2Server : CTAP2 Message

CTAP1Server --> USBDriver : USB HID Communication
CTAP2Server --> USBDriver : USB HID Communication
USBDriver --> HIDToken : Physical USB Access

' Configuration and system services
PolicyEngine ..> VersionConfig : Read Protocol Version
SystemdDaemon ..> HIDEmu : Manage Service
UdevRules ..> HIDToken : Device Permissions\n(qubes group)

note right of QrexecTransport
  **Security Boundary**
  - VM Isolation enforced
  - All communication through qrexec
  - No direct VM-to-VM access
end note

note left of PolicyEngine
  **Policy Enforcement**
  - Controls which VMs can access token
  - Validates authentication requests
  - Prevents unauthorized access
end note

note bottom of HIDToken
  **Secret Protection**
  - Private keys never leave token
  - Only accessible via sys-usb VM
  - Isolated from browser VM compromise
end note

note top of HIDEmu
  **HID Emulation**
  - Browser sees virtual USB device
  - No direct hardware access
  - Requests proxied securely
end note

legend right
  |<#LightYellow> Security Component |
  | Standard Component |
  | === |
  **Security Features:**
  - VM isolation prevents browser compromise
  - Qrexec provides secure IPC
  - Policy-based access control
  - Secrets isolated in sys-usb VM
  - Physical token access restricted
endlegend

@enduml
