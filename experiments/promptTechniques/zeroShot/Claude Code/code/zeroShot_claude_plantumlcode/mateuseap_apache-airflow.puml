@startuml
!define RECTANGLE_COMPONENT

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<executor>> LightGreen
    BackgroundColor<<storage>> LightYellow
    BackgroundColor<<processing>> LightCoral
    BackgroundColor<<monitoring>> LightPink
    BackgroundColor<<logging>> Lavender
    BackgroundColor<<integration>> LightGray
}

package "Apache Airflow Core" {
    component [Web Server] <<core>>
    component [Scheduler] <<core>>
    component [DAG Processor] <<core>>
    component [Metadata Database\n(PostgreSQL)] <<storage>>

    interface "HTTP API" as API
    interface "UI" as UI

    [Web Server] -up- UI
    [Web Server] -up- API
}

package "Executors" {
    component [Sequential Executor] <<executor>>
    component [Local Executor] <<executor>>
    component [Celery Executor] <<executor>>
    component [Kubernetes Executor] <<executor>>
}

package "Celery Infrastructure" {
    component [Redis\n(Message Broker)] <<integration>>
    component [Celery Worker] <<executor>>
    component [Flower\n(Monitoring)] <<monitoring>>
}

package "DAGs & Tasks" {
    component [Forex Data Pipeline DAG] <<core>>
    component [HttpSensor] <<core>>
    component [FileSensor] <<core>>
    component [PythonOperator] <<core>>
    component [BashOperator] <<core>>
    component [HiveOperator] <<core>>
    component [SparkSubmitOperator] <<core>>
    component [EmailOperator] <<core>>
    component [SlackWebhookOperator] <<core>>
}

package "Hadoop Ecosystem" {
    component [HDFS Namenode] <<storage>>
    component [HDFS Datanode] <<storage>>
    component [Hive Metastore] <<processing>>
    component [Hive Server] <<processing>>
    component [Spark Master] <<processing>>
    component [Spark Worker] <<processing>>
    component [Livy] <<processing>>
}

package "Data Processing" {
    component [Forex Processing\n(PySpark)] <<processing>>
}

package "Monitoring Stack (TIG)" {
    component [Telegraf] <<monitoring>>
    component [InfluxDB] <<storage>>
    component [Grafana] <<monitoring>>
}

package "Logging Stack (ELK)" {
    component [Elasticsearch] <<logging>>
    component [Logstash] <<logging>>
    component [Kibana] <<logging>>
}

package "Docker Infrastructure" {
    component [Docker Compose] <<integration>>
    component [Airflow Dockerfile] <<integration>>
    component [Service Containers] <<integration>>
}

package "Configuration Management" {
    component [airflow.cfg] <<core>>
    component [Environment Variables] <<core>>
    component [hive-site.xml] <<processing>>
    component [yarn-site.xml] <<processing>>
}

package "External Services" {
    component [HTTP API Endpoint] <<integration>>
    component [File System] <<storage>>
    component [Email Server] <<integration>>
    component [Slack] <<integration>>
}

' Core Airflow Relationships
[Scheduler] --> [Metadata Database\n(PostgreSQL)] : reads/writes
[Web Server] --> [Metadata Database\n(PostgreSQL)] : reads
[DAG Processor] --> [Scheduler] : submits tasks
[Scheduler] --> [Sequential Executor] : task execution
[Scheduler] --> [Local Executor] : task execution
[Scheduler] --> [Celery Executor] : task execution
[Scheduler] --> [Kubernetes Executor] : task execution

' Celery Executor Relationships
[Celery Executor] --> [Redis\n(Message Broker)] : queue tasks
[Celery Worker] --> [Redis\n(Message Broker)] : consume tasks
[Flower\n(Monitoring)] --> [Redis\n(Message Broker)] : monitor

' DAG Relationships
[DAG Processor] --> [Forex Data Pipeline DAG] : processes
[Forex Data Pipeline DAG] --> [HttpSensor] : contains
[Forex Data Pipeline DAG] --> [FileSensor] : contains
[Forex Data Pipeline DAG] --> [PythonOperator] : contains
[Forex Data Pipeline DAG] --> [BashOperator] : contains
[Forex Data Pipeline DAG] --> [HiveOperator] : contains
[Forex Data Pipeline DAG] --> [SparkSubmitOperator] : contains
[Forex Data Pipeline DAG] --> [EmailOperator] : contains
[Forex Data Pipeline DAG] --> [SlackWebhookOperator] : contains

' Operator to External Service Relationships
[HttpSensor] --> [HTTP API Endpoint] : checks availability
[FileSensor] --> [File System] : checks file
[EmailOperator] --> [Email Server] : sends email
[SlackWebhookOperator] --> [Slack] : sends notification

' Hadoop Integration
[SparkSubmitOperator] --> [Livy] : submits jobs
[Livy] --> [Spark Master] : executes
[Spark Master] --> [Spark Worker] : distributes
[HiveOperator] --> [Hive Server] : executes queries
[Hive Server] --> [Hive Metastore] : metadata
[Forex Processing\n(PySpark)] --> [HDFS Namenode] : read/write
[HDFS Namenode] --> [HDFS Datanode] : manages
[Hive Server] --> [HDFS Namenode] : data storage
[Spark Worker] --> [HDFS Datanode] : read/write data

' Monitoring Relationships
[Telegraf] --> [Scheduler] : collects metrics
[Telegraf] --> [Web Server] : collects metrics
[Telegraf] --> [InfluxDB] : stores metrics
[Grafana] --> [InfluxDB] : visualizes metrics

' Logging Relationships
[Scheduler] --> [Logstash] : sends logs
[Web Server] --> [Logstash] : sends logs
[Celery Worker] --> [Logstash] : sends logs
[Logstash] --> [Elasticsearch] : indexes logs
[Kibana] --> [Elasticsearch] : visualizes logs

' Docker Infrastructure
[Docker Compose] --> [Service Containers] : orchestrates
[Airflow Dockerfile] --> [Service Containers] : builds
[Service Containers] --> [Web Server] : runs
[Service Containers] --> [Scheduler] : runs
[Service Containers] --> [Celery Worker] : runs

' Configuration
[airflow.cfg] --> [Web Server] : configures
[airflow.cfg] --> [Scheduler] : configures
[Environment Variables] --> [airflow.cfg] : overrides
[hive-site.xml] --> [Hive Server] : configures
[yarn-site.xml] --> [Spark Master] : configures

note right of [Celery Executor]
  Microservices Architecture
  - Separate containers for
    web, scheduler, worker
end note

note right of [Forex Data Pipeline DAG]
  ETL Pipeline Pattern
  - Extract: HTTP/File Sensors
  - Transform: Spark/Hive
  - Load: HDFS
end note

note bottom of [Docker Compose]
  Infrastructure as Code
  - Declarative deployment
  - Reproducible environments
end note

@enduml
