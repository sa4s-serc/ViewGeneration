@startuml
!define RECTANGLE class

participant "User" as User
participant "ESServlet/BingServlet" as Servlet
participant "AdRetrieval" as AdRetrieval
participant "RewritingHandler" as RewritingHandler
participant "QueryRewritingService\n(Thrift)" as QueryRewritingService
participant "ESHandler" as ESHandler
participant "Elasticsearch" as ES
participant "*Matcher" as Matcher
participant "RankingService\n(Thrift)" as RankingService
participant "DBPool" as DBPool
participant "MariaDB" as DB
participant "Log4j/Flume" as Logger

== Search Request Flow ==
User -> Servlet: HTTP Search Request
activate Servlet
Servlet -> ESHandler: Search Query
activate ESHandler
ESHandler -> ESHandler: Check LRU Cache
alt Cache Hit
    ESHandler --> Servlet: Cached Results
else Cache Miss
    ESHandler -> ES: Query Elasticsearch
    activate ES
    ES --> ESHandler: Search Results
    deactivate ES
    ESHandler -> ESHandler: Store in LRU Cache
    ESHandler --> Servlet: Search Results
end
deactivate ESHandler
Servlet -> Logger: Log Search Request
activate Logger
deactivate Logger
Servlet --> User: Display Search Results
deactivate Servlet

== Ad Retrieval and Delivery Flow ==
User -> Servlet: Request Ads
activate Servlet
Servlet -> AdRetrieval: Retrieve Ads for Query
activate AdRetrieval

AdRetrieval -> RewritingHandler: Rewrite Query
activate RewritingHandler
RewritingHandler -> QueryRewritingService: Request Query Rewriting
activate QueryRewritingService
QueryRewritingService --> RewritingHandler: Rewritten Queries
deactivate QueryRewritingService
RewritingHandler --> AdRetrieval: Expanded Query Terms
deactivate RewritingHandler

AdRetrieval -> ESHandler: Retrieve Ad IDs by Keywords
activate ESHandler
ESHandler -> ESHandler: Check LRU Cache
alt Cache Hit
    ESHandler --> AdRetrieval: Cached Ad IDs
else Cache Miss
    ESHandler -> ES: Query Ad Keywords
    activate ES
    ES --> ESHandler: Ad IDs
    deactivate ES
    ESHandler -> ESHandler: Store in LRU Cache
    ESHandler --> AdRetrieval: Ad IDs
end
deactivate ESHandler

AdRetrieval -> DBPool: Get Database Connection
activate DBPool
DBPool -> DB: Retrieve Ad Details
activate DB
DB --> DBPool: Advertisement Data
deactivate DB
DBPool --> AdRetrieval: Advertisement Objects
deactivate DBPool

AdRetrieval -> Matcher: Match Ads to Query
activate Matcher
Matcher --> AdRetrieval: Candidate Ads
deactivate Matcher

AdRetrieval -> RankingService: Rank Ads by CTR
activate RankingService
RankingService --> AdRetrieval: Ranked Ads
deactivate RankingService

AdRetrieval -> AdRetrieval: Generate Impression IDs
AdRetrieval -> AdRetrieval: Assign Ad Positions

AdRetrieval -> DBPool: Update Advertiser Budget
activate DBPool
DBPool -> DB: Charge for Ad Display
activate DB
DB --> DBPool: Budget Updated
deactivate DB
deactivate DBPool

AdRetrieval -> Logger: Log Ad Impressions
activate Logger
deactivate Logger

AdRetrieval --> Servlet: Ranked Ads with Metadata
deactivate AdRetrieval

Servlet --> User: Display Ads
deactivate Servlet

== Click Tracking Flow ==
User -> Servlet: Click on Ad
activate Servlet
Servlet -> Logger: Log Click Event
activate Logger
deactivate Logger
Servlet --> User: Redirect to Ad Target
deactivate Servlet

== Application Initialization ==
participant "InitListener" as InitListener
participant "Config" as Config

InitListener -> Config: Load Property Files
activate InitListener
activate Config
Config --> InitListener: Configuration Loaded
deactivate Config

InitListener -> RewritingHandler: Initialize Thrift Connection
activate RewritingHandler
RewritingHandler --> InitListener: Connection Established
deactivate RewritingHandler

InitListener -> RankingService: Initialize Thrift Connection
activate RankingService
RankingService --> InitListener: Connection Established
deactivate RankingService

InitListener -> DBPool: Initialize Connection Pool
activate DBPool
DBPool -> DB: Establish Connections
activate DB
DB --> DBPool: Connections Ready
deactivate DB
DBPool --> InitListener: Pool Ready
deactivate DBPool
deactivate InitListener

@enduml
