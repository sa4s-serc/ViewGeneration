@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<channel>> LightBlue
    BackgroundColor<<core>> LightGreen
    BackgroundColor<<data>> LightYellow
    BackgroundColor<<external>> LightGray
    BackgroundColor<<display>> LightPink
}

' External Channels
component "Emulator Channel" as emulator <<channel>>
component "Webchat Channel" as webchat <<channel>>
component "Email Channel" as email <<channel>>

' Core Bot Components
package "Bot Application" {
    component "index.js\n(Entry Point)" as index <<core>>
    component "bot.js\n(Core Logic)" as bot <<core>>
    component "botdisplay.js\n(Presentation Layer)" as display <<display>>

    package "Dialog System" {
        component "Authentication Dialog" as authDialog
        component "Data Entry Dialog" as entryDialog
        component "Batch Input Dialog" as batchDialog
        component "Company Matching" as companyMatch
    }
}

' Data Layer
package "Data Storage" {
    database "Azure SQL Database\n(Conversation Data)" as sqlConv <<data>>
    database "Azure SQL Database\n(Auth Codes)" as sqlAuth <<data>>
}

' External Services
component "Power BI Dashboard" as powerbi <<external>>
component "Bot Framework Service" as botframework <<external>>

' Configuration
component ".env Configuration" as envconfig <<external>>

' Data Flow - Incoming
emulator -down-> botframework : User Messages
webchat -down-> botframework : User Messages
email -down-> botframework : Email/Templates

botframework -down-> index : HTTP Requests\n(Conversation Activity)

index -down-> bot : Route Messages

' Authentication Flow
bot -down-> authDialog : PIN Verification
authDialog -right-> sqlAuth : Query Auth Code
sqlAuth -up-> authDialog : Validate User

' Data Entry Flow
bot -down-> entryDialog : Interactive Input
bot -down-> batchDialog : Template Parsing
bot -down-> companyMatch : Fuzzy Matching

entryDialog -down-> display : Format Data
batchDialog -down-> display : Format Data
companyMatch -right-> sqlConv : Query Companies
sqlConv -up-> companyMatch : Existing Companies

' Data Storage Flow
bot -down-> sqlConv : Store Conversation Data\n(INSERT/UPDATE)

' Display Flow
display -up-> bot : Adaptive Cards\nMarkdown Text
bot -up-> index : Bot Response
index -up-> botframework : HTTP Response
botframework -up-> emulator : Rendered UI
botframework -up-> webchat : Rendered UI
botframework -up-> email : Formatted Email

' Power BI Integration
sqlConv -down-> powerbi : Data Sync
powerbi -up-> bot : Dashboard URL
bot -up-> display : Embed Dashboard Link

' Configuration Flow
envconfig -right-> index : Environment Variables\n(DB Credentials, App IDs)
index -down-> bot : Configuration Data

' Notes for Data Flow
note right of bot
  Core data processing:
  - Parse user input
  - Validate data
  - Authenticate users
  - Match company names
  - Store conversations
end note

note right of display
  Adaptive rendering:
  - Adaptive Cards (Emulator, Webchat)
  - Markdown (Email)
  - Summary Cards
  - Editable Cards
end note

note bottom of sqlConv
  Conversation attributes:
  - Customer details
  - Notes & insights
  - Timestamps
  - User metadata
end note

note bottom of companyMatch
  Fuzzy matching ensures
  data consistency across
  conversation records
end note

@enduml
