@startuml
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title MLOps System - Control Flow Sequence Diagram

actor "ML Developer" as Dev
participant "Client Tools" as Client
participant "Nginx Reverse Proxy" as Nginx
participant "MLflow Tracking Server" as MLflow
database "MySQL Database" as MySQL
database "AWS S3" as S3

== Experiment Tracking Workflow ==

Dev -> Client: Configure MLflow tracking URI
activate Client
Client -> Client: Set experiment parameters\nand metrics
Dev -> Client: Start ML training run
Client -> Nginx: POST /api/2.0/mlflow/runs/create
activate Nginx
Nginx -> MLflow: Forward create run request
activate MLflow
MLflow -> MySQL: INSERT experiment metadata
activate MySQL
MySQL --> MLflow: Confirm metadata stored
deactivate MySQL
MLflow --> Nginx: Return run_id
deactivate MLflow
Nginx --> Client: Return run_id
deactivate Nginx

Client -> Client: Execute training code\nand log metrics
Client -> Nginx: POST /api/2.0/mlflow/runs/log-metric
activate Nginx
Nginx -> MLflow: Forward log metric request
activate MLflow
MLflow -> MySQL: UPDATE run metrics
activate MySQL
MySQL --> MLflow: Confirm update
deactivate MySQL
MLflow --> Nginx: Success response
deactivate MLflow
Nginx --> Client: Success response
deactivate Nginx

Client -> Nginx: POST /api/2.0/mlflow/runs/log-artifact
activate Nginx
Nginx -> MLflow: Forward log artifact request
activate MLflow
MLflow -> S3: PUT artifact file
activate S3
S3 --> MLflow: Confirm artifact stored
deactivate S3
MLflow -> MySQL: UPDATE artifact location
activate MySQL
MySQL --> MLflow: Confirm update
deactivate MySQL
MLflow --> Nginx: Success response
deactivate MLflow
Nginx --> Client: Success response
deactivate Nginx

Dev -> Client: End training run
Client -> Nginx: POST /api/2.0/mlflow/runs/update
activate Nginx
Nginx -> MLflow: Forward update run request
activate MLflow
MLflow -> MySQL: UPDATE run status to FINISHED
activate MySQL
MySQL --> MLflow: Confirm update
deactivate MySQL
MLflow --> Nginx: Success response
deactivate MLflow
Nginx --> Client: Success response
deactivate Nginx
deactivate Client

== Model Registration and Versioning ==

Dev -> Client: Register trained model
activate Client
Client -> Nginx: POST /api/2.0/mlflow/model-versions/create
activate Nginx
Nginx -> MLflow: Forward model registration request
activate MLflow
MLflow -> MySQL: INSERT model version metadata
activate MySQL
MySQL --> MLflow: Confirm registration
deactivate MySQL
MLflow -> S3: GET model artifact location
activate S3
S3 --> MLflow: Return artifact path
deactivate S3
MLflow --> Nginx: Return model version
deactivate MLflow
Nginx --> Client: Return model version
deactivate Nginx

Client -> Nginx: POST /api/2.0/mlflow/model-versions/set-tag
activate Nginx
Nginx -> MLflow: Forward set tag request
activate MLflow
MLflow -> MySQL: UPDATE model version tags
activate MySQL
MySQL --> MLflow: Confirm tag update
deactivate MySQL
MLflow --> Nginx: Success response
deactivate MLflow
Nginx --> Client: Success response
deactivate Nginx
deactivate Client

== Model Deployment Workflow ==

Dev -> Dev: Build Docker image from model
activate Dev
Dev -> S3: GET model artifacts
activate S3
S3 --> Dev: Return model files
deactivate S3
Dev -> Dev: Package model in Docker container
Dev -> Dev: Deploy containerized model
deactivate Dev

Dev -> Client: Track deployed model
activate Client
Client -> Nginx: POST /api/2.0/mlflow/runs/create\n(deployment tracking)
activate Nginx
Nginx -> MLflow: Forward deployment run request
activate MLflow
MLflow -> MySQL: INSERT deployment metadata
activate MySQL
MySQL --> MLflow: Confirm metadata stored
deactivate MySQL
MLflow --> Nginx: Return deployment run_id
deactivate MLflow
Nginx --> Client: Return deployment run_id
deactivate Nginx
deactivate Client

== System Initialization ==

participant "Docker Compose" as Docker
participant "run.sh" as Script

note over Docker: Server Startup Sequence

Docker -> MySQL: Start MySQL container
activate MySQL
MySQL -> MySQL: Initialize database schema
Docker -> MLflow: Start MLflow container
activate MLflow
MLflow -> Script: Execute run.sh
activate Script
Script -> Script: Configure environment variables\n(DB URI, S3 bucket)
Script -> MLflow: mlflow server --backend-store-uri\n--default-artifact-root
MLflow -> MySQL: Verify database connection
MySQL --> MLflow: Connection established
MLflow -> S3: Verify S3 access
activate S3
S3 --> MLflow: Access confirmed
deactivate S3
deactivate Script
Docker -> Nginx: Start Nginx container
activate Nginx
Nginx -> Nginx: Load default.conf
Nginx -> MLflow: Health check
MLflow --> Nginx: Server ready
deactivate MLflow
deactivate MySQL
deactivate Nginx

@enduml
