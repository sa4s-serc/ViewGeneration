@startuml
!define RECTANGLE_COMPONENT

skinparam component {
  BackgroundColor<<syntax>> LightBlue
  BackgroundColor<<execution>> LightGreen
  BackgroundColor<<library>> LightYellow
  BorderColor Black
  ArrowColor Black
}

package "Visual Programming Environment Library" {

  package "Syntax Representation" <<syntax>> {
    component "Element API" as ElementAPI {
      [IElementSpecification]
      [Prototype Properties]
    }

    component "Specification" as Spec {
      [Element Specifications Table]
    }

    component "Warehouse" as Warehouse {
      [Element Instances Manager]
    }

    component "Syntax Tree" as SyntaxTree {
      [AST Structure]
      [Hierarchical Relationships]
    }
  }

  package "Execution Engine" <<execution>> {
    component "Symbol Table" as SymbolTable {
      [Variables Manager]
      [Program State]
    }

    component "Parser" as Parser {
      [Syntax Tree Parser]
    }

    component "Interpreter" as Interpreter {
      [Element Executor]
    }

    component "Scheduler" as Scheduler {
      [Concurrent Execution Orchestrator]
    }
  }

  package "Library" <<library>> {
    package "Values" {
      component "Boolean" as BoolValue
      component "Number" as NumValue
      component "String" as StrValue
    }

    package "Variables" {
      component "Box" as Box
      component "Box Identifier" as BoxId
    }

    package "Math Operators" {
      component "Addition (+)" as Add
      component "Subtraction (-)" as Sub
      component "Multiplication (*)" as Mul
      component "Division (/)" as Div
      component "Modulo (%)" as Mod
    }

    package "Control Flow" {
      component "Conditional (if)" as If
      component "Loop (repeat)" as Repeat
    }

    package "Program Structures" {
      component "Process" as Process
      component "Routine" as Routine
    }

    package "Miscellaneous" {
      component "Print" as Print
    }
  }

}

' Entry Point
component "index.ts" as Entry {
  [Main Export Point]
}

' Relationships within Syntax Representation
ElementAPI ..> Spec : defines specifications
Spec --> Warehouse : provides specifications
Warehouse --> SyntaxTree : creates instances for
ElementAPI .up.> SyntaxTree : elements form

' Relationships between Syntax and Execution
SyntaxTree --> Parser : parsed by
Parser --> Interpreter : prepares for
Interpreter --> Scheduler : coordinates with
SymbolTable <-- Interpreter : manages state via
SymbolTable <-- Scheduler : accesses

' Library to Syntax Representation
BoolValue .up.> ElementAPI : implements
NumValue .up.> ElementAPI : implements
StrValue .up.> ElementAPI : implements
Box .up.> ElementAPI : implements
BoxId .up.> ElementAPI : implements
Add .up.> ElementAPI : implements
Sub .up.> ElementAPI : implements
Mul .up.> ElementAPI : implements
Div .up.> ElementAPI : implements
Mod .up.> ElementAPI : implements
If .up.> ElementAPI : implements
Repeat .up.> ElementAPI : implements
Process .up.> ElementAPI : implements
Routine .up.> ElementAPI : implements
Print .up.> ElementAPI : implements

BoolValue --> Spec : registered in
NumValue --> Spec : registered in
StrValue --> Spec : registered in
Box --> Spec : registered in
BoxId --> Spec : registered in
Add --> Spec : registered in
Sub --> Spec : registered in
Mul --> Spec : registered in
Div --> Spec : registered in
Mod --> Spec : registered in
If --> Spec : registered in
Repeat --> Spec : registered in
Process --> Spec : registered in
Routine --> Spec : registered in
Print --> Spec : registered in

' Entry point relationships
Entry --> ElementAPI : exports
Entry --> Spec : exports
Entry --> Warehouse : exports
Entry --> SyntaxTree : exports
Entry --> SymbolTable : exports
Entry --> Parser : exports
Entry --> Interpreter : exports
Entry --> Scheduler : exports

note right of ElementAPI
  Factory Pattern:
  Creates element instances
  based on specifications
end note

note right of SyntaxTree
  Tree Data Structure:
  Hierarchical parent-child
  relationships for program blocks
end note

note right of Interpreter
  Component Pattern:
  Separates syntax definition
  from runtime execution
end note

note bottom of "Library"
  Plugin Architecture:
  Core framework with
  extensible syntax elements
end note

@enduml
