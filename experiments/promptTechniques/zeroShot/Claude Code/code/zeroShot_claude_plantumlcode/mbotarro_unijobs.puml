@startuml

skinparam componentStyle rectangle
skinparam component {
    BackgroundColor<<frontend>> LightBlue
    BackgroundColor<<backend>> LightGreen
    BackgroundColor<<database>> LightYellow
    BackgroundColor<<external>> LightGray
}

package "Frontend Layer" {
    package "React Native App" <<frontend>> {
        package "Navigation" {
            component [AppNavigator] as AppNav
            component [FeedNavigator] as FeedNav
            component [SideDrawer] as Drawer
        }

        package "Screens" {
            component [LoginScreen] as Login
            component [RegisterScreen] as Register
            component [FeedScreen] as Feed
            component [OfferScreen] as Offer
            component [RequestScreen] as Request
            component [ProfileScreen] as Profile
            component [SettingsScreen] as Settings
        }

        package "UI Components" {
            component [Button] as Btn
            component [FeedCard] as Card
            component [Forms] as Frm
        }

        package "Actions" {
            component [LoginActions] as LoginAct
            component [FeedActions] as FeedAct
            component [UserActions] as UserAct
        }

        package "Constants" {
            component [UniStyles] as Styles
            component [UniText] as Text
            component [UniColors] as Colors
            component [UniData] as Data
        }
    }
}

package "Backend Layer" {
    package "Go Backend" <<backend>> {
        component [HTTP Server] as Server
        component [Router] as Router

        package "Handlers" {
            component [UserHandler] as UserH
            component [OfferHandler] as OfferH
            component [RequestHandler] as RequestH
            component [CategoryHandler] as CategoryH
        }

        package "Use Cases" {
            component [UserCases] as UserUC
            component [OfferCases] as OfferUC
            component [RequestCases] as RequestUC
            component [CategoryCases] as CategoryUC
            component [MatchCases] as MatchUC
        }

        package "Data Access Layer" {
            component [UserDAL] as UserDAL
            component [OfferDAL] as OfferDAL
            component [RequestDAL] as RequestDAL
            component [CategoryDAL] as CategoryDAL
            component [MatchDAL] as MatchDAL
        }

        package "Models" {
            component [User] as UserModel
            component [Offer] as OfferModel
            component [Request] as RequestModel
            component [Category] as CategoryModel
            component [Match] as MatchModel
        }

        component [Migrations] as Migrations
    }
}

package "Data Layer" {
    database "PostgreSQL" <<database>> as DB {
        component [Users Table] as UsersTable
        component [Offers Table] as OffersTable
        component [Requests Table] as RequestsTable
        component [Categories Table] as CategoriesTable
        component [Matches Table] as MatchesTable
    }

    component [Elasticsearch] <<database>> as ES {
        component [Offers Index] as OffersIndex
        component [Requests Index] as RequestsIndex
    }
}

package "External Services" {
    component [Facebook Auth] <<external>> as FB
    component [Twitter Auth] <<external>> as TW
}

AppNav --> Drawer
AppNav --> FeedNav
FeedNav --> Feed
FeedNav --> Offer
FeedNav --> Request
Drawer --> Profile
Drawer --> Settings

Login ..> Btn : uses
Register ..> Btn : uses
Feed ..> Card : uses
Offer ..> Frm : uses
Request ..> Frm : uses

Login --> LoginAct : triggers
Register --> LoginAct : triggers
Feed --> FeedAct : triggers
Profile --> UserAct : triggers

LoginAct ..> Data : uses
FeedAct ..> Data : uses
UserAct ..> Data : uses

Btn ..> Styles : uses
Btn ..> Colors : uses
Card ..> Styles : uses
Card ..> Colors : uses

LoginAct --> Server : HTTP/REST API
FeedAct --> Server : HTTP/REST API
UserAct --> Server : HTTP/REST API

Login --> FB : authenticates
Login --> TW : authenticates
Register --> FB : registers
Register --> TW : registers

Server --> Router : routes requests
Router --> UserH : dispatches
Router --> OfferH : dispatches
Router --> RequestH : dispatches
Router --> CategoryH : dispatches

UserH --> UserUC : invokes
OfferH --> OfferUC : invokes
RequestH --> RequestUC : invokes
CategoryH --> CategoryUC : invokes

UserUC --> UserDAL : accesses data
OfferUC --> OfferDAL : accesses data
RequestUC --> RequestDAL : accesses data
CategoryUC --> CategoryDAL : accesses data
MatchUC --> MatchDAL : accesses data

UserDAL ..> UserModel : uses
OfferDAL ..> OfferModel : uses
RequestDAL ..> RequestModel : uses
CategoryDAL ..> CategoryModel : uses
MatchDAL ..> MatchModel : uses

UserH ..> UserModel : serializes
OfferH ..> OfferModel : serializes
RequestH ..> RequestModel : serializes
CategoryH ..> CategoryModel : serializes

UserDAL --> UsersTable : queries
OfferDAL --> OffersTable : queries
OfferDAL --> OffersIndex : searches
RequestDAL --> RequestsTable : queries
RequestDAL --> RequestsIndex : searches
CategoryDAL --> CategoriesTable : queries
MatchDAL --> MatchesTable : queries

Migrations --> DB : manages schema

note right of "React Native App"
  Mobile application built with
  React Native and React Navigation.
  Provides user interface for
  job offers and requests.
end note

note right of "Go Backend"
  RESTful API server with
  layered architecture:
  Handlers -> Use Cases -> DAL
  Supports authentication, CRUD
  operations, and search.
end note

note bottom of DB
  Primary data store for
  users, offers, requests,
  categories, and matches.
end note

note bottom of ES
  Full-text search engine
  for offers and requests.
  Reduces load on PostgreSQL.
end note

@enduml
