@startuml
!define RECTANGLE class

title Movalytics Data Warehouse - ETL Data Flow Sequence Diagram

actor User
participant "Airflow Scheduler" as Scheduler
participant "Airflow DAG\n(movies_dwh_dag)" as DAG
participant "BashOperator" as BashOp
participant "bash_scripts/\nload_staging_table.sh" as BashScript
participant "Apache Spark" as Spark
participant "python_scripts/\nload_staging_*.py" as PyScript
participant "Kaggle API" as Kaggle
participant "St. Louis FRED API" as FRED
participant "Amazon S3" as S3
participant "PostgresOperator" as PostgresOp
participant "DataQualityOperator" as DataQualityOp
participant "Amazon Redshift" as Redshift
database "Staging Tables\n(Redshift)" as StagingTables
database "Dimension Tables\n(Redshift)" as DimTables

User -> Scheduler: Trigger DAG execution
activate Scheduler

Scheduler -> DAG: Initialize DAG execution
activate DAG

== Data Extraction Phase ==

DAG -> BashOp: Execute data download task
activate BashOp

BashOp -> Kaggle: kaggle datasets download\n(MovieLens dataset)
activate Kaggle
Kaggle --> BashOp: Return movie data
deactivate Kaggle

BashOp -> FRED: wget CPI dataset
activate FRED
FRED --> BashOp: Return CPI data
deactivate FRED

BashOp -> S3: Upload raw data files
activate S3
S3 --> BashOp: Confirm upload
deactivate BashOp

== Data Transformation Phase ==

DAG -> BashOp: Execute load_staging_table.sh
activate BashOp

BashOp -> BashScript: Run with parameters\n(S3 bucket, key, credentials)
activate BashScript

BashScript -> Spark: Submit Spark job
activate Spark

Spark -> PyScript: Execute load_staging_ratings.py
activate PyScript

PyScript -> S3: Read raw ratings data
S3 --> PyScript: Return raw data

PyScript -> PyScript: Transform data\n(clean, enforce schema)

PyScript -> Redshift: Write to staging_ratings table
activate Redshift
Redshift --> PyScript: Confirm write
deactivate PyScript

Spark -> PyScript: Execute load_staging_movies.py
activate PyScript

PyScript -> S3: Read raw movies data
S3 --> PyScript: Return raw data

PyScript -> PyScript: Transform data\n(clean, enforce schema,\ncreate date dimension)

PyScript -> Redshift: Write to staging_movies table
Redshift --> PyScript: Confirm write
deactivate PyScript

deactivate Spark
deactivate BashScript
deactivate BashOp

== Data Loading Phase ==

DAG -> PostgresOp: Execute SQL scripts\n(create tables)
activate PostgresOp

PostgresOp -> Redshift: CREATE TABLE IF NOT EXISTS\n(dimension tables)
Redshift --> PostgresOp: Tables created
deactivate PostgresOp

DAG -> PostgresOp: Execute upsert operations
activate PostgresOp

PostgresOp -> Redshift: Read from staging_ratings
activate StagingTables
StagingTables --> PostgresOp: Return staging data

PostgresOp -> Redshift: UPSERT into dim_ratings
activate DimTables
DimTables --> PostgresOp: Data loaded

PostgresOp -> Redshift: Read from staging_movies
StagingTables --> PostgresOp: Return staging data

PostgresOp -> Redshift: UPSERT into dim_movies
DimTables --> PostgresOp: Data loaded
deactivate DimTables
deactivate StagingTables
deactivate PostgresOp

== Data Quality Check Phase ==

DAG -> DataQualityOp: Execute data quality checks
activate DataQualityOp

DataQualityOp -> Redshift: Query dimension tables\n(validate data integrity)
Redshift --> DataQualityOp: Return query results

DataQualityOp -> DataQualityOp: Validate results\n(check row counts, nulls)

alt Data Quality Passed
    DataQualityOp --> DAG: Quality checks passed
else Data Quality Failed
    DataQualityOp --> DAG: Quality checks failed\n(raise exception)
end

deactivate DataQualityOp
deactivate Redshift
deactivate S3

DAG --> Scheduler: DAG execution completed
deactivate DAG

Scheduler --> User: Pipeline execution status
deactivate Scheduler

@enduml
