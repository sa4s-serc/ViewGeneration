@startuml

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<data>> LightGreen
  BackgroundColor<<utility>> LightYellow
  BackgroundColor<<external>> LightCoral
  BackgroundColor<<observer>> LightPink
}

package "Core Entity Layer" <<core>> {
  component [HKEntity] as HKEntity <<abstract>>
  component [Node] as Node
  component [Context] as Context
  component [Link] as Link
  component [Connector] as Connector
  component [Reference] as Reference
  component [Trail] as Trail
  component [VirtualNode] as VirtualNode
  component [VirtualContext] as VirtualContext
  component [VirtualLink] as VirtualLink
  component [HKGraph] as HKGraph
}

package "Data Access Layer" <<data>> {
  component [HKDatasource] as HKDatasource
  component [Deserialize] as Deserialize
  component [Hyperify] as Hyperify
  component [Graph Builder] as GraphBuilder
}

package "Utility Layer" <<utility>> {
  component [FI] as FIComponent
  component [FIAnchor] as FIAnchor
  component [FIOperator] as FIOperator
  component [Stored Queries] as StoredQueries
  component [Authentication] as Auth
  component [Types & Constants] as Types
}

package "Observer Pattern Layer" <<observer>> {
  component [HKObserverFactory] as ObserverFactory
  component [ObserverClient] as ObserverClient <<abstract>>
  component [REST Observer] as RESTObserver
  component [RabbitMQ Observer] as RabbitMQObserver
}

package "External Data Integration" <<external>> {
  component [Wordnet Connector] as Wordnet
  component [DBpedia Connector] as DBpedia
  component [External Datasources] as ExternalDS
}

database "HKBase Repository" as HKBase

interface "Query Interface" as QueryInterface
interface "Entity Management" as EntityManagement
interface "Observer Interface" as ObserverInterface
interface "JSON Serialization" as JSONInterface

HKEntity <|-- Node
HKEntity <|-- Context
HKEntity <|-- Link
HKEntity <|-- Connector
HKEntity <|-- Reference
HKEntity <|-- Trail
Node <|-- VirtualNode
Context <|-- VirtualContext
Link <|-- VirtualLink

HKGraph *-- HKEntity : contains

HKDatasource --> HKBase : connects to
HKDatasource ..> QueryInterface : provides
HKDatasource ..> EntityManagement : provides
HKDatasource --> HKEntity : manages
HKDatasource --> HKGraph : creates/retrieves

Deserialize --> HKEntity : creates
Deserialize ..> JSONInterface : implements
Hyperify --> HKGraph : converts to
GraphBuilder --> HKGraph : builds
GraphBuilder --> HKEntity : creates

FIComponent --> Link : references parts of
FIAnchor --> FIComponent : uses
FIOperator --> FIComponent : operates on

ObserverFactory --> ObserverClient : creates
ObserverClient <|-- RESTObserver
ObserverClient <|-- RabbitMQObserver
ObserverClient ..> ObserverInterface : implements
ObserverClient --> HKBase : subscribes to
HKDatasource --> ObserverClient : notifies via

VirtualNode --> ExternalDS : references
VirtualContext --> ExternalDS : references
VirtualLink --> ExternalDS : references
ExternalDS <|-- Wordnet
ExternalDS <|-- DBpedia

StoredQueries --> HKDatasource : uses
Auth --> HKDatasource : secures

component [index.js\nEntry Point] as IndexJS
IndexJS --> HKEntity : exports
IndexJS --> HKDatasource : exports
IndexJS --> ObserverFactory : exports
IndexJS --> Types : exports
IndexJS --> FIComponent : exports

note right of HKBase
  Supports HyQL and
  SPARQL queries
end note

note right of HKGraph
  In-memory representation
  of Hyperknowledge graph
end note

note bottom of ObserverClient
  Notifications via
  REST or RabbitMQ
end note

note left of VirtualNode
  Virtual entities for
  external datasources
end note

@enduml
