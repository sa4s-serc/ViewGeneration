@startuml
!define RECTANGLE class

skinparam componentStyle rectangle

package "Client Layer" {
    [Web Browser] as browser
    [API Client] as apiclient
}

package "Load Balancing Layer" {
    [Nginx Load Balancer] as nginx
}

package "Application Layer" {
    component "App Instance 1" {
        [REST Controller] as controller1
        [URL Shortener Service] as service1
        [Key Generator] as keygen1
        [URL Validator] as validator1
        [Short URL Repository] as repo1
    }

    component "App Instance 2" {
        [REST Controller] as controller2
        [URL Shortener Service] as service2
        [Key Generator] as keygen2
        [URL Validator] as validator2
        [Short URL Repository] as repo2
    }
}

package "Caching Layer" {
    database "Redis Cache" as redis {
        [Cache Manager]
    }
}

package "Persistence Layer" {
    database "MongoDB" as mongodb {
        [Short URL Collection]
    }
}

package "Security Layer" {
    [Spring Security] as security
    [Basic Auth] as auth
}

browser --> nginx : HTTP Request\n(Shorten URL/Redirect)
apiclient --> nginx : REST API Calls\n(/api/v1/shortener,\n/api/v1/status)

nginx --> controller1 : Load Balanced\nHTTP Traffic
nginx --> controller2 : Load Balanced\nHTTP Traffic

controller1 --> security : Authentication\nCheck
controller2 --> security : Authentication\nCheck

security --> auth : Validate\nCredentials

controller1 --> service1 : Service\nInvocation
controller2 --> service2 : Service\nInvocation

service1 --> validator1 : Validate URL
service2 --> validator2 : Validate URL

service1 --> keygen1 : Generate\nShort Key
service2 --> keygen2 : Generate\nShort Key

service1 --> repo1 : CRUD\nOperations
service2 --> repo2 : CRUD\nOperations

repo1 --> redis : @Cacheable\n@CachePut\nCache Lookup
repo2 --> redis : @Cacheable\n@CachePut\nCache Lookup

redis --> mongodb : Cache Miss\nFetch Data
repo1 --> mongodb : Persist/Query\nShort URLs
repo2 --> mongodb : Persist/Query\nShort URLs

mongodb --> redis : Store in\nCache
redis --> repo1 : Return\nCached Data
redis --> repo2 : Return\nCached Data

repo1 --> service1 : Return\nEntity
repo2 --> service2 : Return\nEntity

service1 --> controller1 : Response\nData
service2 --> controller2 : Response\nData

controller1 --> nginx : HTTP Response\n(Short URL/Redirect)
controller2 --> nginx : HTTP Response\n(Short URL/Redirect)

nginx --> browser : HTTP Response
nginx --> apiclient : JSON Response

note right of nginx
  Routes traffic to
  multiple app instances
  for load balancing
end note

note right of redis
  Caches frequently
  accessed short URLs
  to reduce DB load
end note

note right of mongodb
  Stores URL mappings
  and visit statistics
  persistently
end note

note left of service1
  Core business logic:
  - URL shortening
  - Statistics tracking
  - Redirection handling
end note

@enduml
