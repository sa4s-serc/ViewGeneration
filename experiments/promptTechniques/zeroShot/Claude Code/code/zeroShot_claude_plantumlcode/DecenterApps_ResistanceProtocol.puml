@startuml
!define COMPONENT_COLOR #E8F5E9
!define INTERFACE_COLOR #FFF9C4

skinparam component {
    BackgroundColor COMPONENT_COLOR
    BorderColor #2E7D32
    ArrowColor #424242
}

skinparam interface {
    BackgroundColor INTERFACE_COLOR
    BorderColor #F57C00
}

title NOI Stablecoin System - Component Architecture

package "Smart Contracts Layer" {
    component [NOI Stablecoin\nContract] as NOI
    component [CDP Manager\nContract] as CDPManager
    component [Liquidation\nMechanism] as Liquidation
    component [MultiSig Wallet\nContract] as MultiSig
    component [Price Controller\n(PID)] as PriceController
    component [Uniswap V2\nIntegration] as Uniswap

    interface "ERC20" as IERC20
    interface "CDP Operations" as ICDPOps
    interface "Price Feed" as IPriceFeed
    interface "Liquidation Events" as ILiquidation

    NOI -up- IERC20
    CDPManager -up- ICDPOps
    CDPManager -down-> ILiquidation
}

package "Backend Services" {
    component [Blockchain\nConnector] as BlockchainConn
    component [Event Monitor] as EventMonitor
    component [Liquidation Bot] as LiqBot
    component [Update Bot] as UpdateBot
    component [Contract Deployer] as Deployer

    interface "Web3 RPC" as IWeb3
    interface "Contract Events" as IEvents

    BlockchainConn -up- IWeb3
    EventMonitor -up- IEvents
}

package "Frontend Layer" {
    component [React Application] as ReactApp
    component [Dashboard\nComponent] as Dashboard
    component [CDP Management\nComponent] as CDPComponent
    component [Web3 Connector\nService] as Web3Service
    component [Blockchain\nInteraction Service] as BlockchainService

    interface "User Interface" as IUI
    interface "Wallet Connection" as IWallet

    ReactApp -up- IUI
    Web3Service -up- IWallet
}

package "Simulation Environment" {
    component [Simulation Engine] as SimEngine
    component [Agent Models] as Agents
    component [External Data\nSimulator] as ExtData
    component [Price Station] as PriceStation
    component [Pool Manager] as PoolMgr
    component [CDP Position\nSimulator] as CDPSim
    component [PID Controller\nSimulator] as PIDSim

    interface "Agent Behavior" as IAgentBehavior
    interface "Market Data" as IMarketData

    Agents -up- IAgentBehavior
    ExtData -up- IMarketData
}

package "External Systems" {
    component [Ethereum Network] as EthNetwork
    component [Price Oracle\n(ETH/USD)] as PriceOracle
    component [CPI Data Feed] as CPIFeed
    component [Firebase] as Firebase

    interface "Oracle Data" as IOracleData
    interface "CPI Data" as ICPIData

    PriceOracle -up- IOracleData
    CPIFeed -up- ICPIData
}

' Smart Contract Relationships
NOI --> CDPManager : manages collateral
CDPManager --> Liquidation : triggers liquidation
PriceController --> NOI : adjusts redemption rate
PriceController --> Uniswap : monitors market price
MultiSig --> CDPManager : governance control
Uniswap --> NOI : provides liquidity

' Backend to Smart Contracts
BlockchainConn --> IWeb3
IWeb3 --> EthNetwork
EventMonitor --> IEvents
IEvents --> CDPManager
LiqBot --> ICDPOps : execute liquidations
UpdateBot --> PriceController : update parameters
Deployer --> EthNetwork : deploy contracts
BlockchainConn --> Firebase : store data

' Frontend to Backend/Contracts
ReactApp --> Dashboard
ReactApp --> CDPComponent
CDPComponent --> BlockchainService
BlockchainService --> Web3Service
Web3Service --> IWallet
Web3Service --> IWeb3
Dashboard --> BlockchainService

' External Oracles to Smart Contracts
PriceOracle --> IPriceFeed
IPriceFeed --> PriceController
CPIFeed --> ICPIData
ICPIData --> PriceController

' Simulation Environment Relationships
SimEngine --> Agents : coordinates agents
SimEngine --> ExtData : receives market data
Agents --> CDPSim : simulates positions
Agents --> PoolMgr : interacts with pools
PriceStation --> PIDSim : calculates adjustments
ExtData --> PriceStation : provides price/CPI
PoolMgr --> CDPSim : manages collateral
PIDSim --> PriceStation : feedback control

' Simulation to Smart Contracts (validation)
SimEngine ..> PriceController : validates behavior
PIDSim ..> PriceController : tests controller logic
CDPSim ..> CDPManager : validates CDP logic

note right of PriceController
  Uses dual PID controllers:
  - Market price deviation
  - CPI-based adjustment
  - Noise barrier filtering
end note

note right of Agents
  Agent Types:
  - Rate Traders
  - Price Traders
  - Leveragers
  - Safe Owners
end note

note bottom of MultiSig
  Centralized control point
  for governance decisions
end note

note right of SimEngine
  Simulation-driven development
  validates protocol behavior
  before deployment
end note

@enduml
