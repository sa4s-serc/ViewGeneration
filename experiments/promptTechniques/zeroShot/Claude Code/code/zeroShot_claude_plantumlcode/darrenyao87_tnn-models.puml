@startuml
!define RECTANGLE class

skinparam component {
  BackgroundColor<<framework>> LightBlue
  BackgroundColor<<model>> LightGreen
  BackgroundColor<<hardware>> LightGray
  BackgroundColor<<data>> LightYellow
}

package "HiAI Developer Development Kit (DDK)" {
  component "Model Manager Service" as ModelMgr {
    [Model Loader]
    [Model Processor]
    [Compatibility Checker]
    [Tensor Dimension Retriever]
  }

  component "AIPP Pre-Processor" as AIPP {
    [Image Cropping]
    [Image Resizing]
    [Image Padding]
    [Color Space Conversion]
    [Data Type Conversion]
    [Channel Swapping]
  }

  component "Tensor Handler" as TensorHandler {
    [AiTensor Manager]
    [TensorDimension]
  }

  component "Native Handle Manager" as NativeHandle {
    [ION Buffer Manager]
    [Hardware Memory]
  }

  component "Graph Engine" as GraphEngine {
    [Graph Builder]
    [Operator Executor]
  }
}

package "TNN Framework" {
  component "Model Deployment" as TNNDeploy {
    [Model Serialization]
    [Model Optimization]
    [RapidNet Backend]
  }

  component "Neural Network Layers" as NNLayers {
    [Convolutional Layers]
    [Activation Functions]
    [Pooling Layers]
    [Normalization Layers]
    [Upsampling Layers]
    [Fully Connected]
  }
}

package "AI Models" {
  component "Object Detection" as ObjDetection <<model>> {
    [YOLOv5s]
    [NanoDet]
    [SSDLite]
  }

  component "Face Detection" as FaceDetection <<model>> {
    [BlazeFace]
    [Face Detector]
  }

  component "OCR Models" as OCR <<model>> {
    [CRNN]
    [DBNet]
  }

  component "BERT Models" as BERT <<model>> {
    [BERT QA]
    [TinyBERT]
  }

  component "Image Segmentation" as Segmentation <<model>> {
    [Hair Segmentation]
    [Skeleton Extraction]
  }

  component "Depth Estimation" as Depth <<model>> {
    [Monodepth Pydnet]
  }

  component "Image Translation" as ImgTranslation <<model>> {
    [Gray to Color]
  }

  component "Image Classification" as Classification <<model>> {
    [MobileNetV2]
    [ShuffleNetV2]
  }
}

package "Model Definitions" {
  component "TNN Model Files" as TNNFiles <<data>> {
    [*.tnnproto]
    [*.tnnmodel]
  }

  component "Optimized Models" as RapidFiles <<data>> {
    [*.rapidproto]
    [*.rapidmodel]
  }

  component "ONNX Models" as ONNXFiles <<data>> {
    [*.onnx]
  }
}

package "Supporting Data" {
  component "Vocabulary Files" as Vocab <<data>> {
    [vocab.txt]
    [keys.txt]
  }

  component "Configuration Files" as Config <<data>> {
    [blazeface_anchors.txt]
    [mean_face_points.txt]
  }
}

package "Hardware Layer" {
  component "NPU Accelerator" as NPU <<hardware>> {
    [Neural Processing Unit]
  }
}

interface "IModelManager" as IModelMgr
interface "IAIPPConfig" as IAIPPConfig
interface "ITensorIO" as ITensorIO
interface "IGraphOps" as IGraphOps
interface "IModelListener" as IListener

ModelMgr -up- IModelMgr
AIPP -up- IAIPPConfig
TensorHandler -up- ITensorIO
GraphEngine -up- IGraphOps
ModelMgr -down- IListener

ModelMgr --> TNNDeploy : "loads models"
ModelMgr --> GraphEngine : "builds graph"
ModelMgr --> TensorHandler : "manages I/O"
AIPP --> TensorHandler : "preprocesses"
TensorHandler --> NativeHandle : "allocates memory"
NativeHandle --> NPU : "allocates buffers"
GraphEngine --> NNLayers : "executes layers"
GraphEngine --> NPU : "accelerates computation"

TNNDeploy --> TNNFiles : "loads"
TNNDeploy --> RapidFiles : "optimizes to"
TNNDeploy --> ONNXFiles : "converts from"

ObjDetection --> NNLayers : "uses"
ObjDetection --> TNNFiles : "defined by"
FaceDetection --> NNLayers : "uses"
FaceDetection --> TNNFiles : "defined by"
FaceDetection --> Config : "uses anchors"
OCR --> NNLayers : "uses"
OCR --> TNNFiles : "defined by"
OCR --> Vocab : "uses keys.txt"
BERT --> NNLayers : "uses"
BERT --> TNNFiles : "defined by"
BERT --> Vocab : "uses vocab.txt"
Segmentation --> NNLayers : "uses"
Segmentation --> TNNFiles : "defined by"
Depth --> NNLayers : "uses"
Depth --> TNNFiles : "defined by"
ImgTranslation --> NNLayers : "uses"
ImgTranslation --> TNNFiles : "defined by"
Classification --> NNLayers : "uses"
Classification --> TNNFiles : "defined by"

ModelMgr --> ObjDetection : "loads & executes"
ModelMgr --> FaceDetection : "loads & executes"
ModelMgr --> OCR : "loads & executes"
ModelMgr --> BERT : "loads & executes"
ModelMgr --> Segmentation : "loads & executes"
ModelMgr --> Depth : "loads & executes"
ModelMgr --> ImgTranslation : "loads & executes"
ModelMgr --> Classification : "loads & executes"

note right of ModelMgr
  Client-Server Architecture
  Implements PIMPL pattern
  Listener pattern for callbacks
end note

note right of NNLayers
  Modular layer design:
  - Depthwise Separable Convolutions
  - Feature Pyramid Networks
  - Residual Connections
  - Encoder-Decoder Structures
  - Attention Mechanisms
end note

note bottom of TNNDeploy
  Model Serialization Pattern
  Cross-Framework Support
end note

@enduml
