@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<proxy>> LightGreen
    BackgroundColor<<protocol>> LightYellow
    BackgroundColor<<crypto>> LightPink
    BackgroundColor<<observability>> LightCyan
    BackgroundColor<<storage>> Wheat
}

package "IceFireDB Core" {
    [IceFireDB Database] <<core>> as DB
    [Redis Protocol Layer] <<core>> as Redis
    [Uhaha Raft Consensus] <<core>> as Raft
    [Data Structures Manager] <<core>> as DataStruct
    [Server Commands] <<core>> as ServerCmd
    [Global Config] <<core>> as Config

    DB --> Redis : provides
    DB --> Raft : uses
    DB --> DataStruct : manages
    DB --> ServerCmd : implements
    DB --> Config : reads
    Redis --> DataStruct : operates on
}

package "Storage Backends" {
    [LevelDB] <<storage>> as LevelDB
    [BoltDB] <<storage>> as BoltDB
    [Storage Interface] <<storage>> as StorageIF

    StorageIF <|.. LevelDB : implements
    StorageIF <|.. BoltDB : implements
}

package "IceFireDB-SQLProxy" {
    [MySQL Proxy] <<proxy>> as MySQLProxy
    [SQL Agent] <<proxy>> as SQLAgent
    [Connection Pool] <<proxy>> as ConnPool
    [Authentication] <<proxy>> as Auth
    [Query Cache] <<proxy>> as Cache
    [Write Batcher] <<proxy>> as Batcher
    [Config Manager] <<proxy>> as ProxyConfig

    MySQLProxy --> SQLAgent : manages
    MySQLProxy --> ConnPool : uses
    MySQLProxy --> Auth : authenticates
    MySQLProxy --> Cache : caches
    MySQLProxy --> Batcher : batches
    MySQLProxy --> ProxyConfig : reads
}

package "P2P Network Layer" {
    [libp2p Core] <<protocol>> as LibP2P
    [Peer Discovery] <<protocol>> as Discovery
    [Data Sync] <<protocol>> as Sync

    LibP2P --> Discovery : discovers
    LibP2P --> Sync : synchronizes
}

package "Storage Engines" {
    [LevelDB Store] <<storage>> as LevelDBStore
    [CRDT Store] <<storage>> as CRDT
    [IPFS Store] <<storage>> as IPFS
    [OSS Store] <<storage>> as OSS
    [HybridDB Store] <<storage>> as HybridDB
    [Storage Driver Interface] <<storage>> as DriverIF

    DriverIF <|.. LevelDBStore : implements
    DriverIF <|.. CRDT : implements
    DriverIF <|.. IPFS : implements
    DriverIF <|.. OSS : implements
    DriverIF <|.. HybridDB : implements
}

package "Communication Layer" {
    [gRPC Server] <<protocol>> as gRPCServer
    [gRPC Client] <<protocol>> as gRPCClient
    [HTTP/2 Transport] <<protocol>> as HTTP2
    [Interceptors] <<protocol>> as Interceptors
    [Load Balancer] <<protocol>> as LB
    [Stream Handler] <<protocol>> as StreamHandler

    gRPCServer --> HTTP2 : uses
    gRPCClient --> HTTP2 : uses
    gRPCServer --> Interceptors : applies
    gRPCClient --> Interceptors : applies
    gRPCClient --> LB : balances
    gRPCServer --> StreamHandler : handles
}

package "Protocol Buffers" {
    [Proto Definitions] <<protocol>> as ProtoDef
    [Code Generator] <<protocol>> as ProtoGen
    [Message Serializer] <<protocol>> as Serializer
    [Reflection API] <<protocol>> as Reflection
    [Well-Known Types] <<protocol>> as WellKnown

    ProtoDef --> ProtoGen : generates
    ProtoGen --> Serializer : creates
    Serializer --> Reflection : supports
    Serializer --> WellKnown : includes
}

package "Cryptography & Security" {
    [BLAKE2b] <<crypto>> as Blake2
    [SHA-3] <<crypto>> as SHA3
    [Poly1305] <<crypto>> as Poly1305
    [Curve25519] <<crypto>> as Curve25519
    [HKDF] <<crypto>> as HKDF
    [ChaCha20Poly1305] <<crypto>> as ChaCha
    [SecretBox] <<crypto>> as SecretBox
    [Random Generator] <<crypto>> as RNG

    ChaCha --> Poly1305 : uses
    SecretBox --> ChaCha : uses
    HKDF --> SHA3 : derives from
}

package "Observability" {
    [OpenTelemetry API] <<observability>> as OTelAPI
    [Tracing SDK] <<observability>> as Tracing
    [Metrics SDK] <<observability>> as Metrics
    [Logs SDK] <<observability>> as Logs
    [Exporters] <<observability>> as Exporters
    [Auto Instrumentation] <<observability>> as AutoInstr

    OTelAPI --> Tracing : provides
    OTelAPI --> Metrics : provides
    OTelAPI --> Logs : provides
    Tracing --> Exporters : exports to
    Metrics --> Exporters : exports to
    Logs --> Exporters : exports to
    AutoInstr --> OTelAPI : uses
}

package "Tooling & Build" {
    [AST Manipulation] <<protocol>> as AST
    [Code Formatter] <<protocol>> as Formatter
    [Package Manager] <<protocol>> as PkgMgr
    [System Calls] <<protocol>> as SysCalls
}

' Core relationships
DB --> StorageIF : persists to
MySQLProxy --> DriverIF : writes to
MySQLProxy --> LibP2P : synchronizes via
SQLAgent --> Discovery : discovers peers
SQLAgent --> Sync : syncs data

' Protocol relationships
DB --> Serializer : serializes with
MySQLProxy --> Serializer : serializes with
gRPCServer --> Serializer : encodes with
gRPCClient --> Serializer : decodes with

' Communication relationships
Raft --> gRPCServer : communicates via
Raft --> gRPCClient : connects via
MySQLProxy --> gRPCClient : calls remote

' Security relationships
MySQLProxy --> Auth : secures with
Auth --> Blake2 : hashes with
ConnPool --> ChaCha : encrypts with

' Observability relationships
DB --> AutoInstr : instrumented by
MySQLProxy --> AutoInstr : instrumented by
gRPCServer --> Tracing : traces
gRPCClient --> Metrics : measures

' External interfaces
interface "Redis Protocol" as IRedis
interface "MySQL Protocol" as IMySQL
interface "Backend MySQL" as IBackendMySQL

Redis -up- IRedis
MySQLProxy -up- IMySQL
ConnPool --> IBackendMySQL : connects to

note right of DB
  Core distributed database
  with Redis compatibility
  and Raft consensus
end note

note right of MySQLProxy
  MySQL proxy with P2P
  synchronization and
  pluggable storage engines
end note

note bottom of DriverIF
  Supports multiple storage
  backends: LevelDB, CRDT,
  IPFS, OSS, HybridDB
end note

@enduml
