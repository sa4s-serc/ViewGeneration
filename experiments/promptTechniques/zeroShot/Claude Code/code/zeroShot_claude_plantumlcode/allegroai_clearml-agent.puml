@startuml
skinparam componentStyle rectangle
skinparam linetype ortho

title ClearML Agent - Deployment Architecture

package "ClearML Backend" {
    component "ClearML Server" as Server
    interface "API Services" as API
    component "Task Queue Manager" as TaskQueue
    component "Experiment Tracker" as ExpTracker
    component "Model Registry" as ModelReg
    component "Authentication Service" as AuthSvc

    database "ClearML Storage" as Storage
    component "Task Metadata" as TaskMeta
    component "Model Artifacts" as ModelArt
    component "Metrics & Logs" as MetricsLogs

    Server -down- API
    Server -down-> TaskQueue
    Server -down-> ExpTracker
    Server -down-> ModelReg
    Server -down-> AuthSvc
    Server -down-> Storage
    Storage -down-> TaskMeta
    Storage -down-> ModelArt
    Storage -down-> MetricsLogs
}

package "Execution Environment Layer" {
    node "Physical/VM Host" {
        component "ClearML Agent" as Agent
        component "Worker" as Worker
        component "Task Executor" as TaskExec
        component "Environment Manager" as EnvMgr
        component "ResourceMonitor" as ResMon
        component "RequirementsManager" as ReqMgr
        component "Config System" as ConfigSys

        component "Docker Runtime" as Docker
        component "Container Manager" as ContMgr
        component "Image Registry" as ImgReg

        component "Python Environment" as PyEnv
        component "venv" as Venv
        component "conda" as Conda
        component "poetry" as Poetry
        component "uv" as Uv

        Agent -down-> Worker
        Worker -down-> TaskExec
        TaskExec -down-> EnvMgr
        EnvMgr -down-> ReqMgr
        ResMon -up-> TaskExec
        ConfigSys -up-> Agent

        Agent -down-> Docker
        Docker -down-> ContMgr
        Docker -down-> ImgReg

        Agent -down-> PyEnv
        EnvMgr -down-> Docker
        EnvMgr -down-> PyEnv
        PyEnv -down-> Venv
        PyEnv -down-> Conda
        PyEnv -down-> Poetry
        PyEnv -down-> Uv
    }

    node "Kubernetes Cluster" as K8s {
        component "K8s Integration" as K8sInt
        component "K8s Glue Mode" as K8sGlue
        component "Pod Manager" as PodMgr
        component "Resource Scheduler" as K8sResSched

        component "ClearML Agent Pods" as AgentPods
        component "Agent Pod 1" as Pod1
        component "Agent Pod 2" as Pod2
        component "Agent Pod N" as PodN

        K8sInt -down-> K8sGlue
        K8sInt -down-> PodMgr
        K8sInt -down-> K8sResSched
        K8sInt -down-> AgentPods
        AgentPods -down-> Pod1
        AgentPods -down-> Pod2
        AgentPods -down-> PodN
    }

    node "SLURM Cluster" as SLURM {
        component "SLURM Integration" as SLURMInt
        component "Job Submitter" as JobSub
        component "Queue Manager" as QueueMgr

        component "Compute Nodes" as ComputeNodes
        component "Node 1" as Node1
        component "Node 2" as Node2
        component "Node N" as NodeN

        SLURMInt -down-> JobSub
        SLURMInt -down-> QueueMgr
        SLURMInt -down-> ComputeNodes
        ComputeNodes -down-> Node1
        ComputeNodes -down-> Node2
        ComputeNodes -down-> NodeN
    }
}

package "Infrastructure Services" {
    component "GPU Resources" as GPU
    component "NVML Wrapper" as NVML
    component "GPU Allocator" as GPUAlloc
    component "Dynamic GPU Manager" as DynGPU

    component "System Resources" as SysRes
    component "CPU Monitor" as CPUMon
    component "Memory Monitor" as MemMon
    component "Disk Monitor" as DiskMon

    component "Configuration Store" as ConfigStore
    component "HOCON Files" as HOCON
    component "Environment Variables" as EnvVars

    GPU -down-> NVML
    GPU -down-> GPUAlloc
    GPU -down-> DynGPU

    SysRes -down-> CPUMon
    SysRes -down-> MemMon
    SysRes -down-> DiskMon

    ConfigStore -down-> HOCON
    ConfigStore -down-> EnvVars
}

package "External Integrations" {
    interface "ClearML UI" as UI
    component "Package Repositories" as PkgRepo
    component "Docker Registry" as DockerReg
    component "Git Repositories" as GitRepo
}

Agent -up-> API : Pull Tasks\nReport Status
API -down-> Agent : Task Definitions\nCommands
K8sInt -up-> API : Pull Tasks
AgentPods -up-> API : Execute Tasks\nReport Results
SLURMInt -up-> API : Pull Tasks
ComputeNodes -up-> API : Execute Tasks\nReport Results

ReqMgr -right-> PkgRepo : Download Packages
Docker -right-> DockerReg : Pull/Push Images
TaskExec -right-> GitRepo : Clone Code
Server -up-> UI : Web Interface

Agent -down-> GPU : Allocate GPUs
Agent -down-> SysRes : Monitor Resources
GPU -up-> ResMon
SysRes -up-> ResMon
K8sInt -down-> GPU
K8sInt -down-> SysRes

ConfigStore -up-> Agent : Load Config
ConfigStore -up-> K8sInt : Load Config
ConfigStore -up-> SLURMInt : Load Config

AgentPods -down-> Docker : Use Container Runtime

note right of Agent
Main execution agent running
in daemon or services mode.
Supports multiple package managers
and virtual environment types.
end note

note right of K8sInt
Kubernetes integration for
cloud-native deployment.
Manages agent pods dynamically.
end note

note right of SLURMInt
Optional SLURM integration
for HPC cluster deployment.
end note

note bottom of GPU
Supports dynamic and fractional
GPU allocation per task.
end note

@enduml
