@startuml
!define RECTANGLE component

skinparam component {
    BackgroundColor<<container>> LightBlue
    BackgroundColor<<config>> LightYellow
    BackgroundColor<<interface>> LightGreen
    BackgroundColor<<service>> LightCoral
}

package "Emulator Host Environment" {
    component "wtemulator\n(Python Script)" as WTE <<service>>

    component "Configuration Manager" as CM {
        [topology.json] <<config>>
        [config.json] <<config>>
    }

    component "Link Emulator\n(veth pairs)" as LinkEmu <<service>>
}

package "Docker Container Network" {
    node "Network Element 1\n(Docker Container)" <<container>> {
        component "OpenYuma NETCONF Server" as NETCONF1 <<service>>
        component "SIL Layer" as SIL1 <<service>>
        component "YANG Engine" as YANG1 {
            [YANG Models]
            [Data Validation]
            [XPath Processor]
        }
        component "XML Backend" as XML1 {
            [microwave-model-status.xml] <<config>>
        }
        component "SNMP Agent\n(AgentX)" as SNMP1 <<service>>
        component "Notification Handler" as NH1 <<service>>

        interface "NETCONF Interface" as NCIF1
        interface "SNMP Interface" as SNMPIF1
        interface "Network Interface" as NETIF1
    }

    node "Network Element 2\n(Docker Container)" <<container>> {
        component "OpenYuma NETCONF Server" as NETCONF2 <<service>>
        component "SIL Layer" as SIL2 <<service>>
        component "YANG Engine" as YANG2 {
            [YANG Models]
            [Data Validation]
            [XPath Processor]
        }
        component "XML Backend" as XML2 {
            [microwave-model-status.xml] <<config>>
        }
        component "SNMP Agent\n(AgentX)" as SNMP2 <<service>>
        component "Notification Handler" as NH2 <<service>>

        interface "NETCONF Interface" as NCIF2
        interface "SNMP Interface" as SNMPIF2
        interface "Network Interface" as NETIF2
    }

    node "Network Element N\n(Docker Container)" <<container>> {
        component "OpenYuma NETCONF Server" as NETCONFN <<service>>
        component "SIL Layer" as SILN <<service>>
        component "YANG Engine" as YANGN {
            [YANG Models]
            [Data Validation]
            [XPath Processor]
        }
        component "XML Backend" as XMLN {
            [microwave-model-status.xml] <<config>>
        }
        component "SNMP Agent\n(AgentX)" as SNMPN <<service>>
        component "Notification Handler" as NHN <<service>>

        interface "NETCONF Interface" as NCIFN
        interface "SNMP Interface" as SNMPIFN
        interface "Network Interface" as NETIFN
    }
}

cloud "External Clients" {
    component "SDN Controller" as SDN <<service>>
    component "yangcli\n(CLI Tool)" as YCLI <<interface>>
    component "SNMP Manager" as SNMPM <<service>>
}

' Internal connections within NE1
NETCONF1 --> SIL1 : callback
SIL1 --> YANG1 : data access
YANG1 --> XML1 : read/write
NETCONF1 --> NH1 : events
NETCONF1 ..> NCIF1 : exposes
SNMP1 ..> SNMPIF1 : exposes
NETCONF1 --> NETIF1

' Internal connections within NE2
NETCONF2 --> SIL2 : callback
SIL2 --> YANG2 : data access
YANG2 --> XML2 : read/write
NETCONF2 --> NH2 : events
NETCONF2 ..> NCIF2 : exposes
SNMP2 ..> SNMPIF2 : exposes
NETCONF2 --> NETIF2

' Internal connections within NEN
NETCONFN --> SILN : callback
SILN --> YANGN : data access
YANGN --> XMLN : read/write
NETCONFN --> NHN : events
NETCONFN ..> NCIFN : exposes
SNMPN ..> SNMPIFN : exposes
NETCONFN --> NETIFN

' Emulator orchestration
WTE --> CM : reads
WTE --> LinkEmu : creates
WTE ..> "Network Element 1\n(Docker Container)" : deploys
WTE ..> "Network Element 2\n(Docker Container)" : deploys
WTE ..> "Network Element N\n(Docker Container)" : deploys

' Link connectivity via veth pairs
LinkEmu -down- NETIF1 : veth
LinkEmu -down- NETIF2 : veth
LinkEmu -down- NETIFN : veth

' External connectivity
SDN --> NCIF1 : NETCONF/SSH
SDN --> NCIF2 : NETCONF/SSH
SDN --> NCIFN : NETCONF/SSH

YCLI --> NCIF1 : NETCONF/SSH
YCLI --> NCIF2 : NETCONF/SSH

SNMPM --> SNMPIF1 : SNMP
SNMPM --> SNMPIF2 : SNMP
SNMPM --> SNMPIFN : SNMP

' Notification flows
NH1 ..> SDN : notifications
NH2 ..> SDN : notifications
NHN ..> SDN : notifications

note right of LinkEmu
  veth pairs create virtual
  links between NE containers
  for topology emulation
end note

note bottom of "Docker Container Network"
  Each Docker container represents
  an independent Network Element
  with full NETCONF/SNMP stack
end note

note top of CM
  topology.json: NE definitions,
  interfaces, and link topology

  config.json: SDN controller
  details and IP ranges
end note

@enduml
