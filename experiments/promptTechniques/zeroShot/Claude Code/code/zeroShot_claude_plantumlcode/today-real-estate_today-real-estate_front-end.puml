@startuml
!define RECTANGLE_COLOR #E8F5E9
!define COMPONENT_COLOR #C8E6C9
!define INTERFACE_COLOR #81C784

skinparam component {
    BackgroundColor COMPONENT_COLOR
    BorderColor #2E7D32
}

skinparam rectangle {
    BackgroundColor RECTANGLE_COLOR
    BorderColor #388E3C
}

skinparam interface {
    BackgroundColor INTERFACE_COLOR
    BorderColor #43A047
}

title Component Diagram - Today Real Estate Front-End\nDeployment View

node "Browser Environment" {
    rectangle "Vue.js Application" {

        component "main.js\n[Entry Point]" as Main {
        }

        component "App.vue\n[Root Component]" as App {
        }

        package "Router Layer" {
            component "Vue Router\n[Navigation]" as Router
            component "routes/index.js\n[Route Config]" as Routes
        }

        package "State Management" {
            component "Vuex Store" as Store
            component "userStore\n[User State]" as UserStore
            component "searchStore\n[Search State]" as SearchStore
        }

        package "View Components" {
            component "MainPage" as MainPage
            component "LoginPage" as LoginPage
            component "SearchPage" as SearchPage
            component "AccountLikedPage" as AccountPage
            component "404Page" as NotFound
        }

        package "Reusable Components" {
            component "Header" as Header
            component "Footer" as Footer
            component "LoginForm" as LoginForm
            component "SignupForm" as SignupForm
            component "KakaoMap" as KakaoMap
            component "AptItem" as AptItem
        }

        package "API Layer" {
            component "api/index.js\n[Axios Config]" as ApiConfig
            component "auth.js\n[Auth API]" as AuthApi
            component "user.js\n[User API]" as UserApi
            component "search.js\n[Search API]" as SearchApi
            component "news.js\n[News API]" as NewsApi
            component "inquiry.js\n[Inquiry API]" as InquiryApi
        }

        package "Utilities" {
            component "cookies.js\n[Cookie Manager]" as Cookies
            component "eventBus.js\n[Event Bus]" as EventBus
            component "filters.js\n[Data Format]" as Filters
        }

        package "UI Libraries" {
            component "Ant Design Vue" as AntDesign
            component "VueSweetalert2" as SweetAlert
        }
    }
}

node "Configuration" {
    component ".env.development\n[Dev Config]" as EnvDev
    component ".env.production\n[Prod Config]" as EnvProd
}

cloud "External Services" {
    interface "REST API" as BackendAPI
    interface "Kakao Maps API" as KakaoAPI
    interface "News API" as NewsAPI
}

node "Backend Server" {
    component "Real Estate API\n[Backend Service]" as Backend
}

' Main Application Flow
Main --> App
Main --> Router
Main --> Store
Main --> AntDesign
Main --> SweetAlert
Main --> Filters

App --> Header
App --> Footer
App --> Router

' Router connections
Router --> Routes
Routes --> MainPage
Routes --> LoginPage
Routes --> SearchPage
Routes --> AccountPage
Routes --> NotFound

' View to Store connections
MainPage --> Store
LoginPage --> Store
SearchPage --> Store
AccountPage --> Store

' Store modules
Store --> UserStore
Store --> SearchStore

' View to Component connections
MainPage --> AptItem
MainPage --> KakaoMap
SearchPage --> AptItem
SearchPage --> KakaoMap
LoginPage --> LoginForm
AccountPage --> AptItem

' Component to Store connections
Header --> Store
LoginForm --> Store
SignupForm --> Store
KakaoMap --> Store
AptItem --> Store

' API Layer connections
ApiConfig --> AuthApi
ApiConfig --> UserApi
ApiConfig --> SearchApi
ApiConfig --> NewsApi
ApiConfig --> InquiryApi

' Store to API connections
UserStore --> AuthApi
UserStore --> UserApi
UserStore --> InquiryApi
SearchStore --> SearchApi
SearchStore --> NewsApi

' Utility connections
ApiConfig --> Cookies
UserStore --> Cookies
EventBus --> Header
EventBus --> LoginForm

' Configuration to API
EnvDev --> ApiConfig
EnvProd --> ApiConfig

' External API connections
AuthApi --> BackendAPI
UserApi --> BackendAPI
SearchApi --> BackendAPI
NewsApi --> BackendAPI
InquiryApi --> BackendAPI

BackendAPI --> Backend

KakaoMap --> KakaoAPI
NewsApi --> NewsAPI

note right of Main
  Application bootstrapping
  Plugin registration
  Global filters setup
end note

note bottom of Store
  Centralized state management
  User authentication & search state
end note

note bottom of ApiConfig
  Axios interceptors
  Authorization headers
  Base URL configuration
end note

note right of Backend
  Deployed separately
  Handles business logic
  Database operations
end note

@enduml
