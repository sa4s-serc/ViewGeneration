@startuml
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title Back to Work Solution - Control Flow Sequence Diagram

actor Employee
participant "Healthcare Bot\n(Web Chat)" as Bot
participant "Azure Functions" as Functions
participant "DbHelper" as DbHelper
participant "Azure SQL\nDatabase" as Database
participant "NotificationHelper" as NotificationHelper
participant "SendGrid" as SendGrid
participant "QR Code\nGenerator" as QRGen

== User Registration ==
Employee -> Bot: Start conversation
activate Bot
Bot -> Functions: POST /PostUserInfo
activate Functions
Functions -> DbHelper: SaveUserInfo(userInfo)
activate DbHelper
DbHelper -> Database: EXEC sp_InsertUpdateUserInfo
activate Database
Database --> DbHelper: Success
deactivate Database
DbHelper --> Functions: Result
deactivate DbHelper
Functions --> Bot: User data saved
deactivate Functions
Bot --> Employee: Registration confirmed
deactivate Bot

== Symptom Assessment ==
Employee -> Bot: Report symptoms
activate Bot
Bot -> Bot: Execute health\nassessment scenario
Bot -> Functions: POST /PostSymptomsInfo
activate Functions
Functions -> DbHelper: SaveSymptomsInfo(symptomsInfo)
activate DbHelper
DbHelper -> Database: EXEC sp_InsertUpdateSymptomsInfo
activate Database
Database --> DbHelper: Success
deactivate Database
DbHelper --> Functions: Result
deactivate DbHelper
Functions --> Bot: Symptoms recorded
deactivate Functions
Bot --> Employee: Symptoms recorded
deactivate Bot

== Lab Test Submission ==
Employee -> Bot: Submit lab results
activate Bot
Bot -> Functions: POST /PostLabTestInfo
activate Functions
Functions -> DbHelper: SaveLabTestInfo(labTestInfo)
activate DbHelper
DbHelper -> Database: EXEC sp_InsertUpdateLabTestInfo
activate Database
Database --> DbHelper: Success
deactivate Database
DbHelper --> Functions: Result
deactivate DbHelper
Functions --> Bot: Lab results saved
deactivate Functions
Bot --> Employee: Lab results recorded
deactivate Bot

== Return to Work Request ==
Employee -> Bot: Request return to work
activate Bot
Bot -> Bot: Evaluate clearance criteria\n(symptoms, exposure, lab results)
Bot -> Functions: GET /GetSymptomsInfo
activate Functions
Functions -> DbHelper: GetSymptomsInfo(userId)
activate DbHelper
DbHelper -> Database: EXEC sp_GetSymptomsInfo
activate Database
Database --> DbHelper: Symptoms data
deactivate Database
DbHelper --> Functions: Symptoms data
deactivate DbHelper
Functions --> Bot: Symptoms data
deactivate Functions

Bot -> Functions: GET /GetLabTestInfo
activate Functions
Functions -> DbHelper: GetLabTestInfo(userId)
activate DbHelper
DbHelper -> Database: EXEC sp_GetLabTestInfo
activate Database
Database --> DbHelper: Lab test data
deactivate Database
DbHelper --> Functions: Lab test data
deactivate DbHelper
Functions --> Bot: Lab test data
deactivate Functions

Bot -> Bot: Determine clearance status
Bot -> Functions: POST /PostRequestStatus
activate Functions
Functions -> DbHelper: SaveRequestStatus(requestStatus)
activate DbHelper
DbHelper -> Database: EXEC sp_InsertUpdateRequestStatus
activate Database
Database --> DbHelper: Success
deactivate Database
DbHelper --> Functions: Result
deactivate DbHelper
Functions --> Bot: Request status saved
deactivate Functions

alt Employee Cleared
    Bot -> Functions: Trigger notification
    activate Functions
    Functions -> NotificationHelper: SendNotification(userId, status)
    activate NotificationHelper
    NotificationHelper -> QRGen: GenerateQRCode(userId)
    activate QRGen
    QRGen --> NotificationHelper: QR Code image
    deactivate QRGen
    NotificationHelper -> SendGrid: Send email with\nQR code and clearance
    activate SendGrid
    SendGrid --> NotificationHelper: Email sent
    deactivate SendGrid
    NotificationHelper --> Functions: Notification sent
    deactivate NotificationHelper
    Functions --> Bot: Notification confirmed
    deactivate Functions
    Bot --> Employee: Cleared to return\n(check email for QR code)
else Employee Not Cleared
    Bot -> Functions: Trigger notification
    activate Functions
    Functions -> NotificationHelper: SendNotification(userId, status)
    activate NotificationHelper
    NotificationHelper -> SendGrid: Send email with\ndenial and guidance
    activate SendGrid
    SendGrid --> NotificationHelper: Email sent
    deactivate SendGrid
    NotificationHelper --> Functions: Notification sent
    deactivate NotificationHelper
    Functions --> Bot: Notification confirmed
    deactivate Functions
    Bot --> Employee: Not cleared\n(check email for details)
end
deactivate Bot

== Scheduled Notification Trigger ==
participant "Timer Trigger" as Timer
Timer -> Functions: TriggerNotification\n(scheduled execution)
activate Functions
Functions -> DbHelper: GetPendingNotifications()
activate DbHelper
DbHelper -> Database: EXEC sp_GetPendingRequests
activate Database
Database --> DbHelper: Pending requests
deactivate Database
DbHelper --> Functions: Pending requests list
deactivate DbHelper

loop For each pending request
    Functions -> NotificationHelper: SendScheduledNotification(request)
    activate NotificationHelper
    NotificationHelper -> SendGrid: Send reminder/update email
    activate SendGrid
    SendGrid --> NotificationHelper: Email sent
    deactivate SendGrid
    NotificationHelper --> Functions: Notification sent
    deactivate NotificationHelper
end
Functions -> DbHelper: UpdateNotificationStatus()
activate DbHelper
DbHelper -> Database: EXEC sp_UpdateNotificationStatus
activate Database
Database --> DbHelper: Success
deactivate Database
DbHelper --> Functions: Updated
deactivate DbHelper
deactivate Functions

== Data Retrieval for Monitoring ==
actor Administrator
Administrator -> Functions: GET /GetRequestStatus
activate Functions
Functions -> DbHelper: GetRequestStatus(filters)
activate DbHelper
DbHelper -> Database: EXEC sp_GetRequestStatus
activate Database
Database --> DbHelper: Request status data
deactivate Database
DbHelper --> Functions: Request status data
deactivate DbHelper
Functions --> Administrator: Request status report
deactivate Functions

@enduml
