@startuml
!define RECTANGLE class

title 2WAY_Design - Secure Private Data Exchange Architecture

package "Trust Network Layer" {
    [Trust Manager] as TrustMgr
    [Authorization Service] as AuthService
    [Authentication Service] as AuthnService
}

package "Data Exchange Layer" {
    [Private Data Exchange Service] as DataExchange
    [Data Encryption/Decryption] as Crypto
    [Data Storage] as Storage
}

package "Identifi Integration" {
    [Identifi Core] as Identifi
    [Identity Management] as IdentityMgr
}

package "External Entities" {
    [Trusted Party A] as PartyA
    [Trusted Party B] as PartyB
    [Trusted Party N] as PartyN
}

package "Privacy Layer" {
    [Differential Privacy Engine] as DiffPrivacy
    [Privacy Policy Enforcer] as PrivacyPolicy
}

' Relationships - Trust Network
TrustMgr --> AuthService : validates
TrustMgr --> AuthnService : authenticates
TrustMgr --> IdentityMgr : manages identities

' Relationships - Data Exchange
DataExchange --> Crypto : encrypts/decrypts
DataExchange --> Storage : stores/retrieves
DataExchange --> TrustMgr : verifies trust
DataExchange --> PrivacyPolicy : enforces policies

' Relationships - Privacy
DiffPrivacy --> DataExchange : protects data
PrivacyPolicy --> DiffPrivacy : applies techniques

' Relationships - Identifi Integration
Identifi --> IdentityMgr : provides identity services
IdentityMgr --> TrustMgr : supplies identity data

' External Entity Interactions
PartyA --> AuthnService : authenticates
PartyB --> AuthnService : authenticates
PartyN --> AuthnService : authenticates

PartyA --> DataExchange : exchanges data
PartyB --> DataExchange : exchanges data
PartyN --> DataExchange : exchanges data

' Authorization Flow
AuthService --> DataExchange : authorizes access
AuthnService --> AuthService : provides credentials

' Notes
note right of TrustMgr
  Manages trust relationships
  between parties in the network
end note

note right of DataExchange
  Core service for secure
  private data exchange
  among trusted parties
end note

note right of Identifi
  Based on Identifi project
  for identity management
end note

note bottom of DiffPrivacy
  Potential differential privacy
  implementation for data protection
end note

@enduml
