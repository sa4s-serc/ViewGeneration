@startuml
title Train Detection System - Control Flow Sequence Diagram

participant "Main System" as Main
participant "Video_Camera" as Camera
participant "input_deque" as InputQueue
participant "Video_Sensor" as Sensor
participant "Mask\n(Background Subtraction)" as Mask
participant "Video_Detector" as Detector
participant "TensorFlow Model" as TF
participant "ROI Analyzer" as ROI
participant "Direction Detector" as Direction
participant "Data Storage\n(DataFrame/Deque)" as Storage
participant "Visualization" as Viz

activate Main

Main -> Camera: initialize()
activate Camera
Camera -> Camera: configure camera settings
Camera -> InputQueue: create input_deque
activate InputQueue
Camera --> Main: ready

Main -> Sensor: initialize(input_deque)
activate Sensor
Sensor -> Mask: create mask (KNN/MOG2)
activate Mask
Sensor --> Main: ready

Main -> Detector: initialize()
activate Detector
Detector -> TF: load pre-trained model
activate TF
TF --> Detector: model loaded
Detector --> Main: ready

Main -> Camera: start_capture()
Camera -> Camera: start thread

loop Video Capture Loop
    Camera -> Camera: capture frame
    Camera -> Camera: adjust exposure\n(day/night detection)
    Camera -> InputQueue: add frame

    par Parallel Processing
        Sensor -> InputQueue: get frame
        InputQueue --> Sensor: frame

        Sensor -> Mask: apply background subtraction
        Mask -> Mask: KNN/MOG2 algorithm
        Mask --> Sensor: foreground mask

        Sensor -> Sensor: noise reduction
        Sensor -> ROI: extract ROIs
        activate ROI
        ROI -> ROI: analyze motion in ROIs

        alt Motion Detected
            ROI --> Sensor: motion data
            Sensor -> Detector: send ROI data

            Detector -> Direction: analyze motion sequence
            activate Direction
            Direction -> Direction: compare ROI timestamps

            alt Consecutive ROI Activation
                Direction -> Direction: determine direction\n(North/South)
                Direction --> Detector: direction result

                Detector -> Storage: store detection event
                activate Storage
                Storage -> Storage: add to DataFrame
                Storage --> Detector: stored

                Detector -> Detector: sample frames\naround event
                Detector -> Storage: store sampled frames
                Storage --> Detector: stored

                Detector -> TF: classify object
                TF -> TF: run inference
                TF --> Detector: classification\n(train/car/truck)

                alt Train Detected
                    Detector -> Storage: store train event\nwith direction
                    Storage --> Detector: stored

                    Detector -> Viz: trigger visualization
                    activate Viz
                    Viz -> Viz: generate plots
                    Viz -> Viz: create motion graphs
                    Viz --> Detector: visualization ready
                    deactivate Viz
                end

                deactivate Direction
            else No Consecutive Activation
                Direction --> Detector: no direction
                deactivate Direction
            end

        else No Motion
            ROI --> Sensor: no motion
        end

        deactivate ROI
        Sensor -> Storage: store frame metadata
        Storage --> Sensor: stored

    end
end

Main -> Camera: stop_capture()
Camera -> Camera: stop thread
Camera --> Main: stopped

Main -> Storage: finalize data
Storage -> Storage: export results
Storage --> Main: data exported

deactivate Storage
deactivate TF
deactivate Detector
deactivate Mask
deactivate Sensor
deactivate InputQueue
deactivate Camera
deactivate Main

@enduml
