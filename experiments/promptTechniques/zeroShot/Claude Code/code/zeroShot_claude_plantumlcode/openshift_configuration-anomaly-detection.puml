@startuml

skinparam rectangle {
    BackgroundColor<<External>> LightBlue
    BackgroundColor<<Security>> LightCoral
    BackgroundColor<<Core>> LightGreen
    BackgroundColor<<Auth>> LightYellow
}

skinparam componentStyle rectangle

title OpenShift Configuration Anomaly Detection - Security & Control Flow

package "External Alert Sources" {
    component [PagerDuty] <<External>> as PD
}

package "Security Gateway Layer" <<Security>> {
    component [Tekton Interceptor] as Interceptor
    component [Webhook Validator] as Validator
    component [Signature Verifier] as SigVerifier
    component [Handler Resolver] as HandlerResolver
}

package "CI/CD Pipeline" {
    component [Tekton PipelineRun] as Pipeline
}

package "Core Investigation Engine" <<Core>> {
    component [cadctl CLI] as CADCTL
    component [Investigate Command] as InvestCmd
    component [Investigation Strategy Selector] as StrategySelector
    component [NoteWriter] as NoteWriter

    interface "Investigation Interface" as IInvestigation

    component [chgm Investigation] as CHGM
    component [apierrorbudgetburn Investigation] as APIEBB
    component [insightsoperatordown Investigation] as IOD
    component [ccam Investigation] as CCAM
    component [upgradeconfigsyncfailureover4hr Investigation] as UCSF
    component [cpd Investigation] as CPD
    component [clustermonitoringerrorbudgetburn Investigation] as CMEBB
    component [machinehealthcheckunterminatedshortcircuitsre Investigation] as MHCUSS

    component [Resources Container] as Resources
    component [Client Dependencies] as Clients
    component [Investigation Data] as Data
}

package "Authentication & Authorization" <<Auth>> {
    component [Backplane CLI] as Backplane
    component [Dynamic Service Accounts] as SA
    component [RBAC Manager] as RBAC
}

package "External Service Integrations" <<External>> {
    component [OCM Client] as OCM
    component [AWS Client] as AWS
    component [CloudTrail] as CloudTrail
    component [Instance Info] as InstanceInfo
    component [Kubernetes Client] as K8S
    component [Network Verifier] as NetVerifier
}

PD -down-> Interceptor : "1. Webhook Alert\n(HTTPS)"
Interceptor -down-> Validator : "2. Validate"
Validator -down-> SigVerifier : "3. Verify Signature"
SigVerifier -down-> HandlerResolver : "4. Resolve Handler"

HandlerResolver -down-> Pipeline : "5. Trigger Pipeline\n(if handler exists)"
Pipeline -down-> CADCTL : "6. Execute cadctl"

CADCTL -down-> InvestCmd : "7. Invoke investigate"
InvestCmd -down-> StrategySelector : "8. Select Strategy"
StrategySelector -down-> IInvestigation : "9. Route to Investigation"

IInvestigation <|.. CHGM
IInvestigation <|.. APIEBB
IInvestigation <|.. IOD
IInvestigation <|.. CCAM
IInvestigation <|.. UCSF
IInvestigation <|.. CPD
IInvestigation <|.. CMEBB
IInvestigation <|.. MHCUSS

Resources --> Clients : "contains"
Resources --> Data : "contains"
Resources -up-> IInvestigation : "10. Inject Dependencies"

Backplane --> SA : "manages"
SA --> RBAC : "configures"
RBAC --> K8S : "enforces access"

CADCTL -down-> Backplane : "11. Request Credentials"
CADCTL -down-> OCM : "12. Fetch Cluster Info"
CADCTL -down-> AWS : "13. Query AWS"
AWS --> CloudTrail : "queries"
AWS --> InstanceInfo : "retrieves"
CADCTL -down-> K8S : "14. Inspect Resources"
CADCTL -down-> NetVerifier : "15. Verify Network"

IInvestigation --> NoteWriter : "16. Format Results"
NoteWriter -up-> PD : "17. Update Incident"
CADCTL --> OCM : "18. Set Support Reason"

note right of SigVerifier
  **Security Controls:**
  - Webhook signature verification
  - Handler existence validation
  - HTTPS transport security
  - Request authentication
end note

note right of Backplane
  **Security Controls:**
  - Dynamic Service Accounts
  - Least privilege RBAC
  - Time-limited credentials
  - Cluster access isolation
end note

note bottom of Resources
  **Dependency Injection:**
  Provides isolated, testable
  access to external services
  enabling secure client management
end note

@enduml
