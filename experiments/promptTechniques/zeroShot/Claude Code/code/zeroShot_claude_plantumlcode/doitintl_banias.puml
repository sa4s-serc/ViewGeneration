@startuml
!define RECTANGLE_COLOR #4A90E2
!define CLOUD_COLOR #87CEEB
!define STORAGE_COLOR #98D8C8

title Banias Event Analytics Pipeline - Deployment & Control Flow

skinparam component {
  BackgroundColor RECTANGLE_COLOR
  BorderColor #2C5F8D
  FontColor white
}

skinparam cloud {
  BackgroundColor CLOUD_COLOR
  BorderColor #5F9EA0
}

skinparam database {
  BackgroundColor STORAGE_COLOR
  BorderColor #4F7F6F
}

' External Sources
actor "Web/Mobile Apps" as clients

' Frontend Components
package "Frontend (Go Service)" {
  component "HTTP API\n/track endpoint" as api
  component "Event Validator\n(Collector)" as collector
  component "Event Batcher" as batcher
  component "Async Publisher\n(GoPool)" as publisher
  component "Prometheus\n/metrics" as metrics
  component "Configuration\n(Viper)" as config
}

' Google Cloud Platform Infrastructure
cloud "Google Cloud Platform" {
  queue "Google Pub/Sub\nTopic" as pubsub

  component "Dataflow Pipeline\n(Java)" as dataflow {
    component "Message Reader" as reader
    component "Event Mapper\n(Strategy Pattern)" as mapper
    component "Schema Loader" as schemaLoader
    component "Error Handler" as errorHandler
  }

  database "BigQuery\nDynamic Tables" as bigquery
  database "BigQuery\nError Table" as errorTable
  storage "GCS Bucket\nSchema Store" as gcs
}

' Kubernetes Deployment
package "Kubernetes Cluster" {
  component "Frontend Pods\n(Autoscaling)" as k8sPods
  component "Service\nLoad Balancer" as k8sService
}

' Monitoring & CI/CD
cloud "External Services" {
  component "Stackdriver\nMonitoring" as stackdriver
  component "Travis CI" as travis
  component "Docker Registry" as dockerRegistry
}

' Control Flow - Event Path
clients -down-> k8sService : "1. POST /track\n(JSON events)"
k8sService -down-> k8sPods
k8sPods -down-> api : "HTTP Request"
api -right-> collector : "2. Validate Event"
collector -down-> batcher : "3. Add to Batch"
batcher -right-> publisher : "4. Batch Ready\n(configurable size/delay)"
publisher -down-> pubsub : "5. Async Publish\n(goroutines)"

pubsub -down-> reader : "6. Pull Messages"
reader -right-> schemaLoader : "7. Load Schema"
schemaLoader -up-> gcs : "8. Fetch Schema"
reader -down-> mapper : "9. Map Event"
mapper -down-> bigquery : "10. Write to\nDynamic Table"
mapper -right-> errorHandler : "Malformed Events"
errorHandler -down-> errorTable : "11. Write Errors"

' Configuration & Monitoring Flows
config -up-> api : "Env Variables"
config -up-> publisher : "Batch Config"
metrics -up-> stackdriver : "Metrics Export"

' Deployment Flow
travis -down-> dockerRegistry : "Build & Push\nDocker Images"
dockerRegistry -down-> k8sPods : "Deploy Containers"

' Notes for deployment concerns
note right of k8sPods
  Deployment Characteristics:
  - Horizontal autoscaling
  - Container-based deployment
  - Load balanced requests
  - Health checks via /metrics
end note

note bottom of dataflow
  Dataflow Deployment:
  - Managed by Makefile
  - Maven dependencies (pom.xml)
  - Dynamic schema loading
  - Separate error handling pipeline
end note

note left of pubsub
  Decoupling Layer:
  - Asynchronous communication
  - Scalability buffer
  - Event persistence
end note

@enduml
