@startuml
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor User
participant "Node-RED UI" as UI
participant "DOM Util" as DOMUtil
participant "Resource Dist" as ResourceDist
participant "State IO" as StateIO
participant "Provider Node\n(Pull/Push)" as Provider
participant "Inference Node\n(Classify/Detect/Extract)" as Inference
participant "Peekaboo Service" as Service
participant "External Inference\nService" as ExternalService
participant "Filter Node\n(Select/Noisify/Spoof)" as Filter
participant "FFmpeg" as FFmpeg
participant "Network Node\n(Post)" as Network
participant "Cloud Service" as Cloud
participant "Sensor\n(ESP8266/ESP32)" as Sensor
participant "MQTT Broker" as MQTT
participant "Utility Node\n(Aggregate/Join)" as Utility

== Configuration Phase ==
User -> UI: Configure Node
activate UI
UI -> DOMUtil: Generate UI Elements
activate DOMUtil
DOMUtil -> ResourceDist: Request models.json
activate ResourceDist
ResourceDist --> DOMUtil: Return model definitions
deactivate ResourceDist
DOMUtil -> ResourceDist: Request ontology.json
activate ResourceDist
ResourceDist --> DOMUtil: Return ontology data
deactivate ResourceDist
DOMUtil --> UI: Render dynamic UI
deactivate DOMUtil
User -> UI: Set node parameters
UI -> StateIO: Save configuration
activate StateIO
StateIO --> UI: Configuration saved
deactivate StateIO
deactivate UI

== Sensor Setup Phase ==
User -> Sensor: Configure WiFi
activate Sensor
Sensor -> MQTT: Connect to broker
activate MQTT
MQTT --> Sensor: Connection established
Sensor -> MQTT: Subscribe to topics
MQTT --> Sensor: Subscription confirmed
deactivate Sensor

== Data Flow Phase ==
Sensor -> MQTT: Publish sensor data
MQTT -> Provider: Push data message
activate Provider
Provider -> Utility: Forward message
activate Utility
Utility --> Provider: Aggregated data
deactivate Utility
Provider -> Inference: Send data for analysis
deactivate Provider

activate Inference
Inference -> Service: Request inference
activate Service
Service -> ExternalService: Call inference API
activate ExternalService
ExternalService -> ExternalService: Process data\n(ML model execution)
ExternalService --> Service: Return inference results
deactivate ExternalService
Service --> Inference: Return processed data
deactivate Service
Inference -> Filter: Send inference results
deactivate Inference

activate Filter
alt Image Filtering
    Filter -> Filter: Apply image filters\n(select/spoof)
else Audio Noisification
    Filter -> FFmpeg: Add noise to audio
    activate FFmpeg
    FFmpeg --> Filter: Return noisified audio
    deactivate FFmpeg
else Data Selection
    Filter -> Filter: Select/remove data fields
end
Filter -> Network: Send filtered data
deactivate Filter

activate Network
Network -> Cloud: HTTP POST request
activate Cloud
Cloud --> Network: Response
deactivate Cloud
deactivate Network
deactivate MQTT

== Pull-Based Data Flow ==
Provider -> Provider: Timer trigger (Pull mode)
activate Provider
Provider -> Sensor: Request sensor data
activate Sensor
Sensor --> Provider: Return sensor data
deactivate Sensor
Provider -> Inference: Send data for analysis
activate Inference
Inference -> Service: Request inference
activate Service
Service -> Service: Execute custom rule service
Service --> Inference: Return results
deactivate Service
Inference -> Utility: Send results
deactivate Inference
activate Utility
Utility -> Utility: Join/aggregate data
Utility -> Network: Forward processed data
deactivate Utility
activate Network
Network -> Cloud: POST processed data
activate Cloud
Cloud --> Network: Acknowledgment
deactivate Cloud
deactivate Network
deactivate Provider

== State Recovery Phase ==
User -> UI: Load saved flow
activate UI
UI -> StateIO: Load configuration
activate StateIO
StateIO --> UI: Return saved state
deactivate StateIO
UI -> Provider: Restore node state
activate Provider
Provider --> UI: State restored
deactivate Provider
UI -> Inference: Restore node state
activate Inference
Inference --> UI: State restored
deactivate Inference
UI -> Filter: Restore node state
activate Filter
Filter --> UI: State restored
deactivate Filter
deactivate UI

@enduml
