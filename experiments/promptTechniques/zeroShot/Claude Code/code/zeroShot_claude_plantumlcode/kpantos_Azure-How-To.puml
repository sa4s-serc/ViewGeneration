@startuml
!define AZURE_BLUE #0078D4
!define ONPREM_GRAY #666666
!define SECURITY_RED #D13438

title Azure-How-To Architecture - Deployment and Connectivity

package "Scenario 1: Secure Bot with WAF" {

    package "External" as Ext1 {
        component [Internet Users] as Users1
        component [Let's Encrypt\nCA] as LetsEncrypt
    }

    package "Azure Cloud - Bot Security" as AzureBot {
        component [Azure Application\nGateway] as AppGW1 AZURE_BLUE
        component [Web Application\nFirewall (WAF)] as WAF SECURITY_RED
        component [Azure App Service] as AppService1 AZURE_BLUE
        component [Bot Application\n(.NET Core)] as BotApp
        component [Azure Bot Service] as BotService AZURE_BLUE
    }

    Users1 -down-> AppGW1 : HTTPS
    LetsEncrypt .up.> AppGW1 : SSL/TLS Certificate
    AppGW1 -down-> WAF : Traffic Inspection
    WAF -down-> AppService1 : Filtered Traffic
    AppService1 -down-> BotApp : Hosts
    BotApp <--> BotService : Bot Framework\nProtocol
}

package "Scenario 2: Kerberos API with APIM" {

    package "On-Premises Environment" as OnPrem {
        component [Active Directory] as AD ONPREM_GRAY
        component [On-Prem API\n(IIS Web Farm)] as OnPremAPI ONPREM_GRAY
        component [Azure AD Connect] as ADConnect
    }

    package "Azure Cloud - API Management" as AzureAPIM {
        component [Azure Active\nDirectory] as AzureAD AZURE_BLUE
        component [Azure AD\nApplication Proxy] as AppProxy AZURE_BLUE
        component [Application Proxy\nConnector] as ProxyConnector
        component [Azure API\nManagement (APIM)] as APIM AZURE_BLUE
    }

    package "External" as Ext2 {
        component [API Consumers] as APIUsers
    }

    AD <-up-> ADConnect : Synchronization
    ADConnect <-up-> AzureAD : Identity Sync
    OnPremAPI -up-> AD : Kerberos\nAuthentication
    OnPremAPI <-up-> ProxyConnector : Internal\nConnection
    ProxyConnector <-up-> AppProxy : Secure\nOutbound Channel
    AppProxy -up-> AzureAD : Azure AD\nAuthentication
    AppProxy <-left-> APIM : Backend\nAPI Connection
    APIM -up-> AzureAD : Token\nValidation
    APIUsers -down-> APIM : HTTPS/API Calls

    note right of OnPremAPI
        Service Principal Name (SPN)
        configured for Kerberos
    end note
}

cloud "Management & Security" {
    component [Rate Limiting] as RateLimit
    component [Analytics] as Analytics
    component [Security Policies] as SecPolicies

    APIM .down.> RateLimit
    APIM .down.> Analytics
    WAF .up.> SecPolicies
}

note bottom of WAF
    Protects against:
    - SQL Injection
    - XSS
    - OWASP Top 10
end note

note bottom of AppProxy
    Enables remote access
    without VPN requirement
end note

legend right
    |= Color |= Meaning |
    | <back:AZURE_BLUE>   </back> | Azure Services |
    | <back:ONPREM_GRAY>   </back> | On-Premises |
    | <back:SECURITY_RED>   </back> | Security Layer |
endlegend

@enduml
