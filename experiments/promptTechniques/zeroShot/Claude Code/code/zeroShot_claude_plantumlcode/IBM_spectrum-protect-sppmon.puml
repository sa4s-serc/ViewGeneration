@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<external>> LightBlue
    BackgroundColor<<storage>> LightYellow
    BackgroundColor<<visualization>> LightGreen
    BackgroundColor<<core>> Pink
}

title IBM Spectrum Protect Plus Monitoring System - Component Diagram\nConnectivity and Control Flow

package "SPPMon System" {

    package "Core Engine" {
        component "SPPMon\n(sppmon.py)" as SPPMon <<core>>
        component "SPPCheck\n(sppcheck.py)" as SPPCheck <<core>>
    }

    package "Connection Layer" {
        component "REST Client\n(rest_client.py)" as RestClient
        component "SSH Client\n(ssh_client.py)" as SshClient
        component "API Queries\n(api_queries.py)" as ApiQueries
    }

    package "Data Collection Methods" {
        component "System Methods" as SystemMethods
        component "Job Methods" as JobMethods
        component "Protection Methods" as ProtectionMethods
        component "SSH Methods" as SshMethods
    }

    package "Data Processing" {
        component "InfluxDB Client\n(influx_client.py)" as InfluxClient
        component "Database Definitions" as DbDefinitions
        component "Continuous Queries" as ContinuousQueries
    }

    package "SPPCheck Components" {
        component "Excel Reader" as ExcelReader
        component "Data Generator" as DataGenerator
        component "Predictor" as Predictor
        component "Report Generator" as ReportGenerator
    }

    package "Utilities" {
        component "SPP Utils" as SppUtils
        component "Method Utils" as MethodUtils
        component "Connection Utils" as ConnectionUtils
        component "Influx Utils" as InfluxUtils
    }

    package "Configuration & Installation" {
        component "Installer Script\n(installer.sh)" as Installer
        component "Config Generator\n(addConfigFile.py)" as ConfigGen
        component "Crontab Config\n(addCrontabConfig.py)" as CrontabConfig
        component "Dashboard Tool\n(generifyDashboard.py)" as DashboardTool
    }
}

package "External Systems" {
    component "IBM Spectrum Protect Plus\nServer" as SPPServer <<external>>
    component "vSnap Servers" as vSnap <<external>>
    component "VADP Proxies" as VADP <<external>>
    component "Microsoft 365 Proxies" as M365 <<external>>
}

database "InfluxDB\n(Time-Series Database)" as InfluxDB <<storage>>

component "Grafana\n(Visualization)" as Grafana <<visualization>>

' Control Flow: SPPMon Core
SPPMon --> ApiQueries : uses for\ndata collection
SPPMon --> SshMethods : uses for\nremote data
SPPMon --> InfluxClient : ingests data
SPPMon --> SppUtils : utility functions
SPPMon --> MethodUtils : method helpers

' Control Flow: SPPCheck Core
SPPCheck --> ExcelReader : reads sizing sheets
SPPCheck --> DataGenerator : generates test data
SPPCheck --> Predictor : predicts consumption
SPPCheck --> ReportGenerator : creates PDF reports
SPPCheck --> InfluxClient : reads historical data

' Connection Layer Control Flow
ApiQueries --> RestClient : wraps/delegates
RestClient --> ConnectionUtils : uses utilities
SshClient --> MethodUtils : command execution

' Data Collection Methods Control Flow
SystemMethods --> ApiQueries : queries system data
JobMethods --> ApiQueries : queries job data
ProtectionMethods --> ApiQueries : queries protection data
SshMethods --> SshClient : executes SSH commands

' Connectivity: REST API
RestClient --> SPPServer : REST API\n(login/logout/query)

' Connectivity: SSH
SshClient --> vSnap : SSH connection\n(commands)
SshClient --> VADP : SSH connection\n(commands)
SshClient --> M365 : SSH connection\n(commands)

' Data Processing Control Flow
InfluxClient --> DbDefinitions : table schemas
InfluxClient --> ContinuousQueries : query definitions
InfluxClient --> InfluxUtils : utility functions

' Connectivity: InfluxDB
InfluxClient --> InfluxDB : write/read\ntime-series data

' Connectivity: Grafana Visualization
Grafana --> InfluxDB : queries data\nfor dashboards

' Installation & Configuration Control Flow
Installer --> ConfigGen : generates config files
Installer --> CrontabConfig : sets up automation
ConfigGen ..> SPPMon : configures
CrontabConfig ..> SPPMon : schedules
DashboardTool ..> Grafana : prepares dashboards

' SPPCheck Internal Flow
ExcelReader --> Predictor : provides sizing data
DataGenerator --> Predictor : provides test data
Predictor --> ReportGenerator : analysis results

' Configuration Dependencies
SPPMon ..> ConfigGen : reads config
SPPCheck ..> ConfigGen : reads config

note right of RestClient
  Handles:
  - Authentication
  - Retry logic
  - Page size adjustment
  - Error handling
end note

note right of SshClient
  Executes remote commands
  on vSnap, VADP, M365
  proxies with type-specific
  parsing
end note

note bottom of InfluxDB
  Stores:
  - System metrics
  - Job statistics
  - Protection data
  - Historical trends
end note

note left of SPPMon
  Main orchestrator:
  1. Collects data via REST/SSH
  2. Processes metrics
  3. Ingests to InfluxDB
  4. Scheduled via cron
end note

note left of SPPCheck
  Analysis tool:
  1. Verifies setup
  2. Predicts consumption
  3. Generates reports
end note

@enduml
