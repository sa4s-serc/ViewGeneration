@startuml
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title Marlowe Starter Kit - Contract Lifecycle Control Flow

actor User
participant "Browser\ndApp" as dApp
participant "controller.js" as Controller
participant "CIP30/CIP45\nWallet" as Wallet
participant "Marlowe Runtime\nWeb Server" as WebServer
participant "Marlowe Runtime\nProxy" as Proxy
participant "Marlowe Runtime\nContract Service" as Contract
participant "Marlowe Runtime\nTx Service" as Tx
participant "Chain Sync" as ChainSync
participant "Chain Indexer" as Indexer
participant "Cardano Node" as Node
database "PostgreSQL" as DB

== Initialization Phase ==
User -> dApp: Access dApp
activate dApp
dApp -> Controller: Initialize
activate Controller
Controller -> WebServer: Health Check
activate WebServer
WebServer --> Controller: Runtime Status
deactivate WebServer
Controller -> Wallet: Request Connection (CIP30/CIP45)
activate Wallet
Wallet --> User: Authorization Request
User --> Wallet: Approve Connection
Wallet --> Controller: Wallet Connected
Controller -> Wallet: Get Address
Wallet --> Controller: Return Address
deactivate Wallet
Controller --> dApp: Initialization Complete
deactivate Controller
dApp --> User: Display Interface
deactivate dApp

== Contract Creation Phase ==
User -> dApp: Create Marlowe Contract
activate dApp
dApp -> Controller: createContract(contractSpec)
activate Controller
Controller -> WebServer: POST /contracts
activate WebServer
WebServer -> Proxy: Forward Contract Request
activate Proxy
Proxy -> Contract: Process Contract
activate Contract
Contract -> Contract: Validate Contract Terms
Contract -> DB: Store Contract Metadata
activate DB
DB --> Contract: Confirm Storage
deactivate DB
Contract --> Proxy: Contract Created
deactivate Contract
Proxy --> WebServer: Contract Details + TxBody
deactivate Proxy
WebServer --> Controller: Return TxBody
deactivate WebServer
Controller -> Wallet: Sign Transaction
activate Wallet
Wallet --> User: Request Signature
User --> Wallet: Approve Signature
Wallet --> Controller: Signed Tx
deactivate Wallet
Controller -> WebServer: POST /contracts/{contractId}/transactions
activate WebServer
WebServer -> Tx: Submit Transaction
activate Tx
Tx -> Node: Submit to Blockchain
activate Node
Node --> Tx: Tx Accepted
deactivate Node
Tx -> DB: Update Tx Status
activate DB
DB --> Tx: Confirmed
deactivate DB
Tx --> WebServer: Tx Submitted
deactivate Tx
WebServer --> Controller: Transaction ID
deactivate WebServer
Controller -> Controller: Poll Transaction Status
Controller --> dApp: Contract Created
deactivate Controller
dApp --> User: Display Contract ID
deactivate dApp

== Chain Synchronization (Background) ==
activate ChainSync
ChainSync -> Node: Monitor Blockchain
activate Node
Node --> ChainSync: New Block Events
deactivate Node
ChainSync -> Indexer: Index Block Data
activate Indexer
Indexer -> DB: Update UTxO Set
activate DB
DB --> Indexer: Confirmed
deactivate DB
Indexer --> ChainSync: Indexing Complete
deactivate Indexer
deactivate ChainSync

== Contract Deposit Phase ==
User -> dApp: Make Deposit
activate dApp
dApp -> Controller: applyInputs(contractId, deposit)
activate Controller
Controller -> WebServer: GET /contracts/{contractId}
activate WebServer
WebServer -> DB: Query Contract State
activate DB
DB --> WebServer: Current State
deactivate DB
WebServer --> Controller: Contract State
deactivate WebServer
Controller -> WebServer: POST /contracts/{contractId}/transactions
activate WebServer
WebServer -> Contract: Apply Input
activate Contract
Contract -> Contract: Evaluate State Transition
Contract -> DB: Update Contract State
activate DB
DB --> Contract: State Updated
deactivate DB
Contract --> WebServer: New State + TxBody
deactivate Contract
WebServer --> Controller: Return TxBody
deactivate WebServer
Controller -> Wallet: Sign Transaction
activate Wallet
Wallet --> User: Request Signature
User --> Wallet: Approve Signature
Wallet --> Controller: Signed Tx
deactivate Wallet
Controller -> WebServer: Submit Signed Transaction
activate WebServer
WebServer -> Tx: Process Transaction
activate Tx
Tx -> Node: Submit to Blockchain
activate Node
Node --> Tx: Tx Accepted
deactivate Node
Tx -> DB: Record Transaction
activate DB
DB --> Tx: Confirmed
deactivate DB
Tx --> WebServer: Tx Submitted
deactivate Tx
WebServer --> Controller: Transaction ID
deactivate WebServer
Controller -> Controller: Poll for Confirmation
Controller -> WebServer: GET /contracts/{contractId}/transactions/{txId}
activate WebServer
WebServer -> DB: Query Transaction Status
activate DB
DB --> WebServer: Transaction Status
deactivate DB
WebServer --> Controller: Status: Confirmed
deactivate WebServer
Controller --> dApp: Deposit Complete
deactivate Controller
dApp --> User: Display Success
deactivate dApp

== Contract Release/Withdrawal Phase ==
User -> dApp: Release Funds
activate dApp
dApp -> Controller: applyInputs(contractId, release)
activate Controller
Controller -> WebServer: POST /contracts/{contractId}/transactions
activate WebServer
WebServer -> Contract: Apply Release Input
activate Contract
Contract -> Contract: Validate Release Conditions
Contract -> Contract: Calculate Payouts
Contract -> DB: Update Contract State (Closed)
activate DB
DB --> Contract: State Updated
deactivate DB
Contract --> WebServer: Payout TxBody
deactivate Contract
WebServer --> Controller: Return TxBody
deactivate WebServer
Controller -> Wallet: Sign Transaction
activate Wallet
Wallet --> User: Request Signature
User --> Wallet: Approve Signature
Wallet --> Controller: Signed Tx
deactivate Wallet
Controller -> WebServer: Submit Signed Transaction
activate WebServer
WebServer -> Tx: Process Payout
activate Tx
Tx -> Node: Submit to Blockchain
activate Node
Node --> Tx: Tx Accepted
deactivate Node
Tx -> DB: Record Final Transaction
activate DB
DB --> Tx: Confirmed
deactivate DB
Tx --> WebServer: Tx Submitted
deactivate Tx
WebServer --> Controller: Transaction ID
deactivate WebServer
Controller -> Controller: Poll for Confirmation
Controller --> dApp: Release Complete
deactivate Controller
dApp --> User: Funds Released
deactivate dApp

== Query and Monitoring ==
User -> dApp: View Contract Status
activate dApp
dApp -> Controller: getContractStatus(contractId)
activate Controller
Controller -> WebServer: GET /contracts/{contractId}
activate WebServer
WebServer -> DB: Query Contract Details
activate DB
DB --> WebServer: Contract State & History
deactivate DB
WebServer --> Controller: Contract Information
deactivate WebServer
Controller --> dApp: Format Contract Data
deactivate Controller
dApp --> User: Display Contract Status
deactivate dApp

@enduml
