@startuml

skinparam component {
    BackgroundColor<<frontend>> LightBlue
    BackgroundColor<<backend>> LightGreen
    BackgroundColor<<infrastructure>> LightGray
    BackgroundColor<<storage>> LightYellow
    BackgroundColor<<monitoring>> LightCoral
}

package "Frontend Layer" {
    component [React Application] <<frontend>> as ReactApp
    component [Routing (react-router-dom)] <<frontend>> as Routing
    component [Form Handling (Ant Design)] <<frontend>> as Forms
    component [Upload/Download Components] <<frontend>> as Upload
    component [State Management (Redux)] <<frontend>> as Redux
    component [Mock Data (mockjs)] <<frontend>> as MockData
    component [Blazor Server UI (SIT Testing)] <<frontend>> as BlazorUI
}

package "API Gateway Layer" {
    component [.NET Core API Gateway] <<backend>> as APIGateway
    component [Authentication Middleware] <<backend>> as AuthMiddleware
    component [Custom Middleware Pipeline] <<backend>> as CustomMiddleware
}

package "Microservices Layer" {
    component [Authentication Service (.NET 6.0)] <<backend>> as AuthService
    component [OAuth/OIDC Provider] <<backend>> as OAuthProvider
    component [JWT Handler] <<backend>> as JWTHandler
    component [Token Refresh] <<backend>> as TokenRefresh
    component [ASP.NET Core Identity] <<backend>> as Identity

    component [File Storage Service (.NET Core)] <<backend>> as FileService
    component [S3 API] <<backend>> as S3API
    component [MinIO Client] <<backend>> as MinIOClient

    component [Business Service (.NET 5)] <<backend>> as BusinessService
    component [Controllers] <<backend>> as Controllers
    component [Business Logic] <<backend>> as BusinessLogic
    component [Models] <<backend>> as Models

    component [Spring Boot Service] <<backend>> as SpringService
    component [Node.js Service] <<backend>> as NodeService
}

package "Data Access Layer" {
    component [Entity Framework Core] <<backend>> as EFCore
    component [DbContext] <<backend>> as DbContext
    component [Migrations] <<backend>> as Migrations
    component [Database Initializer] <<backend>> as DBInit
    component [Repository Pattern] <<backend>> as Repository
}

package "Storage Layer" {
    database "Database" <<storage>> as Database
    storage "MinIO Object Storage (Distributed Cluster)" <<storage>> as MinIO
}

package "Observability & Monitoring" {
    component [Centralized Logging (EFK Stack)] <<monitoring>> as EFKStack
    component [Elasticsearch] <<monitoring>> as Elasticsearch
    component [Fluentd] <<monitoring>> as Fluentd
    component [Kibana] <<monitoring>> as Kibana

    component [Distributed Tracing] <<monitoring>> as Tracing
    component [SkyWalking] <<monitoring>> as SkyWalking
    component [OpenTelemetry] <<monitoring>> as OpenTelemetry
    component [Zipkin] <<monitoring>> as Zipkin

    component [Logging Framework] <<monitoring>> as Logging
    component [Serilog] <<monitoring>> as Serilog
    component [ILogger] <<monitoring>> as ILogger
}

package "Testing Infrastructure" {
    component [System Integration Testing (SIT)] <<infrastructure>> as SITFramework
    component [Jest] <<infrastructure>> as Jest
    component [Puppeteer] <<infrastructure>> as Puppeteer
    component [Data-Driven Tests] <<infrastructure>> as DDTests

    component [Unit & Integration Tests] <<infrastructure>> as UnitTests
    component [MSTest] <<infrastructure>> as MSTest
    component [xUnit] <<infrastructure>> as xUnit
}

package "External Identity Providers" {
    component [Hydra] <<infrastructure>> as Hydra
    component [IdentityServer4] <<infrastructure>> as IdentityServer4
}

package "Container Orchestration" {
    component [Kubernetes Cluster] <<infrastructure>> as K8s
    component [Deployments] <<infrastructure>> as K8sDeployments
    component [Services] <<infrastructure>> as K8sServices
    component [ConfigMaps] <<infrastructure>> as ConfigMaps
    component [Docker] <<infrastructure>> as Docker
}

ReactApp --> Routing
ReactApp --> Forms
ReactApp --> Upload
ReactApp --> Redux
Redux --> MockData

ReactApp --> APIGateway : HTTP/REST
BlazorUI --> APIGateway : HTTP/REST

APIGateway --> AuthMiddleware
APIGateway --> CustomMiddleware

APIGateway --> AuthService : OAuth/OIDC
APIGateway --> FileService : HTTP/REST
APIGateway --> BusinessService : HTTP/REST

AuthMiddleware --> AuthService : Validate JWT

AuthService --> OAuthProvider
OAuthProvider --> JWTHandler
JWTHandler --> TokenRefresh
AuthService --> Identity

FileService --> S3API
S3API --> MinIOClient
MinIOClient --> MinIO : S3 Protocol

BusinessService --> Controllers
Controllers --> BusinessLogic
BusinessLogic --> Models
BusinessService --> Repository : Data Access

Repository --> EFCore
EFCore --> DbContext
EFCore --> Migrations
EFCore --> DBInit
DbContext --> Database
Migrations --> Database
DBInit --> Database

AuthService --> Logging : Write Logs
BusinessService --> Logging : Write Logs
FileService --> Logging : Write Logs
SpringService --> Logging : Write Logs
NodeService --> Logging : Write Logs

Logging --> Serilog
Logging --> ILogger

Logging --> Fluentd : Forward Logs
Fluentd --> Elasticsearch : Store Logs
Elasticsearch --> Kibana : Visualize

EFKStack --> Elasticsearch
EFKStack --> Fluentd
EFKStack --> Kibana

AuthService --> Tracing : Trace Data
BusinessService --> Tracing : Trace Data
SpringService --> Tracing : Trace Data
NodeService --> Tracing : Trace Data
FileService --> Tracing : Trace Data

Tracing --> SkyWalking
Tracing --> OpenTelemetry
Tracing --> Zipkin
OpenTelemetry --> Zipkin : Export Traces
SkyWalking --> Zipkin : Export Traces

SITFramework --> Jest
SITFramework --> Puppeteer
SITFramework --> DDTests
SITFramework --> ReactApp : UI Tests
SITFramework --> APIGateway : API Tests

UnitTests --> MSTest
UnitTests --> xUnit
UnitTests --> BusinessService : Test
UnitTests --> AuthService : Test
UnitTests --> FileService : Test

AuthService --> Hydra : OAuth/OIDC
AuthService --> IdentityServer4 : OAuth/OIDC

K8s --> K8sDeployments
K8s --> K8sServices
K8s --> ConfigMaps
K8s --> Docker : Container Runtime

K8sDeployments --> AuthService : Deploy
K8sDeployments --> BusinessService : Deploy
K8sDeployments --> FileService : Deploy
K8sDeployments --> SpringService : Deploy
K8sDeployments --> NodeService : Deploy
K8sDeployments --> EFKStack : Deploy
K8sDeployments --> Tracing : Deploy

Docker --> MinIO : Container Deployment

note right of APIGateway
  API Gateway Pattern
  - Client Authentication
  - Request Routing
  - Token Management
end note

note right of AuthService
  Client Credentials Flow
  - Service-to-Service Auth
  - JWT Token Generation
  - Policy-based Authorization
end note

note right of EFKStack
  Centralized Logging
  for Kubernetes
  Microservices
end note

note bottom of K8s
  Microservice Architecture
  - Containerized Services
  - Scalable Deployment
  - Service Discovery
end note

@enduml
