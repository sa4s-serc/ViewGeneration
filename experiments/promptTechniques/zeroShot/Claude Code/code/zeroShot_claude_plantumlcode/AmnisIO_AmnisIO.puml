@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
    BackgroundColor<<cli>> LightBlue
    BackgroundColor<<transpiler>> LightGreen
    BackgroundColor<<library>> LightYellow
    BackgroundColor<<abstraction>> LightCoral
    BackgroundColor<<config>> LightGray
    BackgroundColor<<external>> WhiteSmoke
}

package "AmnisIO System" {

    package "CLI Layer" {
        [AmnisIO CLI] <<cli>> as CLI
        [Command Parser] <<cli>> as Parser
        [Init Command] <<cli>> as InitCmd
        [Build Command] <<cli>> as BuildCmd
        [Clean Command] <<cli>> as CleanCmd
        [Deploy Command] <<cli>> as DeployCmd
    }

    package "Configuration Layer" {
        [Configuration Manager] <<config>> as ConfigMgr
        [Board Configurations] <<config>> as BoardConfigs
        [Arduino UNO Config] <<config>> as UNOConfig
        [Type Definitions] <<config>> as TypeDefs
    }

    package "Transpilation Layer" {
        [typewriter Transpiler] <<transpiler>> as Typewriter
        [TypeScript Parser] <<transpiler>> as TSParser
        [C Code Generator] <<transpiler>> as CCodeGen
    }

    package "Reactive Programming Layer" {
        [rivulet Stream Library] <<library>> as Rivulet
        [Stream Operations] <<library>> as StreamOps
        [Event Handlers] <<library>> as EventHandlers
    }

    package "Hardware Abstraction Layer" {
        [gyrus Board Abstraction] <<abstraction>> as Gyrus
        [Arduino UNO Interface] <<abstraction>> as UNOInterface
        [Hardware Peripherals API] <<abstraction>> as HardwareAPI
    }

    package "Application Layer" {
        [TypeScript Application Code] as TSApp
        [Generated C Code] as CCode
    }

}

package "External Systems" {
    [PlatformIO] <<external>> as PIO
    [Target Device\n(Arduino UNO)] <<external>> as Device
}

' CLI relationships
CLI --> Parser : uses
Parser --> InitCmd : delegates
Parser --> BuildCmd : delegates
Parser --> CleanCmd : delegates
Parser --> DeployCmd : delegates

' Configuration relationships
InitCmd --> ConfigMgr : loads config
BuildCmd --> ConfigMgr : loads config
DeployCmd --> ConfigMgr : loads config
ConfigMgr --> BoardConfigs : reads
BoardConfigs --> UNOConfig : includes
BoardConfigs --> TypeDefs : uses
ConfigMgr ..> TypeDefs : implements

' Build process relationships
BuildCmd --> Typewriter : invokes
Typewriter --> TSParser : uses
Typewriter --> CCodeGen : uses
TSParser --> TSApp : parses
CCodeGen --> CCode : generates

' Application code relationships
TSApp --> Rivulet : imports
TSApp --> Gyrus : imports
TSApp ..> TypeDefs : uses types

' Transpiler relationships
Typewriter --> Rivulet : includes in output
Typewriter --> Gyrus : includes in output

' Reactive programming relationships
Rivulet --> StreamOps : provides
Rivulet --> EventHandlers : provides

' Hardware abstraction relationships
Gyrus --> UNOInterface : provides
Gyrus --> HardwareAPI : exposes
UNOInterface ..> Rivulet : uses streams
HardwareAPI --> CCode : included in

' PlatformIO integration
BuildCmd --> PIO : orchestrates build
DeployCmd --> PIO : orchestrates deploy
PIO --> CCode : compiles
PIO --> Device : flashes firmware
CleanCmd --> PIO : cleans build

' Configuration to platform
ConfigMgr --> PIO : provides config
UNOConfig --> Gyrus : configures

' Legend
legend right
    |<back:LightBlue>   </back>| CLI Components |
    |<back:LightGreen>   </back>| Transpiler Components |
    |<back:LightYellow>   </back>| Library Components |
    |<back:LightCoral>   </back>| Abstraction Components |
    |<back:LightGray>   </back>| Configuration Components |
    |<back:WhiteSmoke>   </back>| External Systems |
endlegend

@enduml
