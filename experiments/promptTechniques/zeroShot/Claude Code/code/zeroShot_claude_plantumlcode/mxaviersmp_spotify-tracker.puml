@startuml
!define RECTANGLE_STYLE #LightBlue
!define DATABASE_STYLE #LightGreen
!define EXTERNAL_STYLE #LightYellow

skinparam componentStyle rectangle
skinparam linetype ortho

' External Systems
package "External Services" {
    component [Spotify API] as SpotifyAPI EXTERNAL_STYLE
    component [GitHub] as GitHub EXTERNAL_STYLE
}

' AWS Cloud Infrastructure
package "AWS Cloud" {
    ' Serverless Components
    package "Serverless Layer" {
        component [API Gateway] as APIGateway RECTANGLE_STYLE
        component [Lambda Function\n(FastAPI App)] as Lambda RECTANGLE_STYLE
    }

    ' Database
    package "Data Layer" {
        database [PostgreSQL\n(AWS RDS)] as RDS DATABASE_STYLE
    }
}

' Application Components
package "Application Layer" {
    ' API Components
    package "FastAPI Application" {
        component [Authentication\n(OAuth2)] as Auth RECTANGLE_STYLE
        component [User Management] as UserMgmt RECTANGLE_STYLE
        component [Data Retrieval] as DataRetrieval RECTANGLE_STYLE
        component [Admin Functions] as Admin RECTANGLE_STYLE
        component [Repository Pattern\n(CRUD)] as Repository RECTANGLE_STYLE
        component [ORM Layer\n(ormar/SQLAlchemy)] as ORM RECTANGLE_STYLE
    }

    ' ETL Components
    package "ETL Pipeline (Apache Airflow)" {
        component [Airflow Scheduler] as Scheduler RECTANGLE_STYLE
        component [Token Update Task] as TokenTask RECTANGLE_STYLE
        component [Fetch Tracks Task] as FetchTask RECTANGLE_STYLE
        component [Enrich Data Task] as EnrichTask RECTANGLE_STYLE
        component [DAG Definition] as DAG RECTANGLE_STYLE
    }

    ' Supporting Infrastructure
    package "Supporting Services" {
        component [Redis\n(Message Broker)] as Redis DATABASE_STYLE
        component [Database Migration\n(Alembic)] as Alembic RECTANGLE_STYLE
    }
}

' CI/CD Components
package "CI/CD Pipeline" {
    component [GitHub Actions\n(Deploy)] as GHADeploy RECTANGLE_STYLE
    component [GitHub Actions\n(DB Migration)] as GHAMigrate RECTANGLE_STYLE
    component [Serverless Framework] as Serverless RECTANGLE_STYLE
}

' User Interfaces
package "User Interface" {
    component [Streamlit App] as Streamlit RECTANGLE_STYLE
}

' Utility Components
package "Utilities" {
    component [Logging Utils] as Logging RECTANGLE_STYLE
    component [HTTP Client\n(httpx/asyncio)] as HTTPClient RECTANGLE_STYLE
    component [Spotify Client] as SpotifyClient RECTANGLE_STYLE
}

' Relationships - External to AWS
SpotifyAPI --> APIGateway : API Requests
GitHub --> GHADeploy : Trigger on Release
GitHub --> GHAMigrate : Trigger on Release

' Relationships - AWS Layer
APIGateway --> Lambda : Route Requests
Lambda --> RDS : Database Operations

' Relationships - FastAPI Internal
Lambda ..> Auth : contains
Lambda ..> UserMgmt : contains
Lambda ..> DataRetrieval : contains
Lambda ..> Admin : contains
Lambda ..> Repository : contains
Lambda ..> ORM : contains

Auth --> SpotifyAPI : OAuth2 Flow
UserMgmt --> Repository : User CRUD
DataRetrieval --> Repository : Data Access
Admin --> Repository : Admin Operations
Repository --> ORM : Data Access
ORM --> RDS : SQL Queries

' Relationships - ETL Components
Scheduler --> DAG : Execute
DAG --> TokenTask : Schedule
DAG --> FetchTask : Schedule
DAG --> EnrichTask : Schedule
TokenTask --> SpotifyClient : Update Tokens
FetchTask --> SpotifyClient : Fetch Listening History
EnrichTask --> SpotifyClient : Enrich Metadata
SpotifyClient --> SpotifyAPI : API Calls
TokenTask --> RDS : Update DB
FetchTask --> RDS : Store Data
EnrichTask --> RDS : Store Data
Scheduler --> Redis : Task Queue

' Relationships - CI/CD
GHADeploy --> Serverless : Deploy
Serverless --> Lambda : Deploy Function
Serverless --> APIGateway : Configure
GHAMigrate --> Alembic : Run Migrations
Alembic --> RDS : Schema Updates

' Relationships - Streamlit
Streamlit --> APIGateway : API Requests
Streamlit --> RDS : Direct Queries (optional)

' Relationships - Utilities
Lambda ..> Logging : uses
Lambda ..> HTTPClient : uses
SpotifyClient --> HTTPClient : HTTP Requests
DataRetrieval --> SpotifyClient : Spotify Data

' Docker Support
package "Container Infrastructure" {
    component [Docker\n(FastAPI)] as DockerAPI RECTANGLE_STYLE
    component [Docker\n(Airflow Worker)] as DockerAirflow RECTANGLE_STYLE
    component [Docker Compose\n(ETL Stack)] as DockerCompose RECTANGLE_STYLE
}

DockerAPI ..> Lambda : Deployment Package
DockerAirflow ..> Scheduler : Container
DockerCompose ..> Scheduler : Orchestration
DockerCompose ..> Redis : Orchestration

' Configuration
component [Environment Variables] as EnvVars RECTANGLE_STYLE
EnvVars --> Lambda : Configuration
EnvVars --> Scheduler : Configuration
EnvVars --> Streamlit : Configuration

note right of Lambda
  Serverless deployment
  Handles authentication,
  data retrieval, and
  user management
end note

note right of Scheduler
  Scheduled ETL tasks
  for extracting, transforming,
  and loading Spotify data
end note

note bottom of RDS
  Stores: users, tracks,
  artists, play history,
  genres, audio features
end note

note top of APIGateway
  Entry point for all
  API requests with
  routing and CORS
end note

@enduml
