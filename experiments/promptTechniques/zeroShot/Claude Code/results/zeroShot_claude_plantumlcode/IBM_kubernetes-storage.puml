@startuml
!define RECTANGLE class

participant "User/Workshop Participant" as User
participant "kubectl CLI" as kubectl
participant "Kubernetes API Server" as K8sAPI
participant "Scheduler" as Scheduler
participant "Controller Manager" as Controller
participant "Kubelet (Worker Node)" as Kubelet
participant "Storage Provisioner\n(IBM Cloud)" as Provisioner
participant "IBM Cloud\nBlock Storage" as BlockStorage
participant "IBM Cloud\nObject Storage" as ObjectStorage
participant "Container Runtime" as Runtime

== Lab Setup: Deploy Guestbook with Persistent Storage ==

User -> kubectl: Apply YAML manifests\n(deployment, service, PVC)
kubectl -> K8sAPI: Create PVC for MongoDB

activate K8sAPI
K8sAPI -> Controller: PVC created event
activate Controller

Controller -> Provisioner: Request volume provisioning
activate Provisioner

Provisioner -> BlockStorage: Create persistent volume
activate BlockStorage
BlockStorage --> Provisioner: Volume created
deactivate BlockStorage

Provisioner --> Controller: PV created and bound
deactivate Provisioner
Controller --> K8sAPI: Update PVC status (Bound)
deactivate Controller

kubectl -> K8sAPI: Create Deployment\n(MongoDB, Guestbook)
K8sAPI -> Controller: Deployment created
activate Controller

Controller -> K8sAPI: Create ReplicaSet
K8sAPI -> Controller: ReplicaSet created
Controller -> K8sAPI: Create Pods
deactivate Controller

K8sAPI -> Scheduler: Schedule MongoDB Pod
activate Scheduler
Scheduler -> Scheduler: Evaluate storage\nconstraints and topology
Scheduler -> K8sAPI: Bind Pod to Node
deactivate Scheduler

K8sAPI -> Kubelet: Pod assignment
activate Kubelet

Kubelet -> Provisioner: Attach volume to node
activate Provisioner
Provisioner -> BlockStorage: Attach volume
BlockStorage --> Provisioner: Volume attached
Provisioner --> Kubelet: Volume ready
deactivate Provisioner

Kubelet -> Runtime: Pull MongoDB image
activate Runtime
Runtime --> Kubelet: Image ready
deactivate Runtime

Kubelet -> Runtime: Create container\nwith volume mount
activate Runtime
Runtime --> Kubelet: Container started
deactivate Runtime

Kubelet --> K8sAPI: Pod status: Running
deactivate Kubelet

K8sAPI -> Scheduler: Schedule Guestbook Pods
activate Scheduler
Scheduler -> K8sAPI: Bind Pods to Nodes
deactivate Scheduler

K8sAPI -> Kubelet: Pod assignments
activate Kubelet
Kubelet -> Runtime: Deploy Guestbook containers
activate Runtime
Runtime --> Kubelet: Containers running
deactivate Runtime
Kubelet --> K8sAPI: Pods status: Running
deactivate Kubelet

deactivate K8sAPI

== Lab 5: Object Storage with S3FS ==

User -> kubectl: Apply ConfigMap\n(S3 credentials)
kubectl -> K8sAPI: Create ConfigMap/Secret

User -> kubectl: Deploy Pod with\nS3FS volume mount
kubectl -> K8sAPI: Create Pod with flexVolume

K8sAPI -> Scheduler: Schedule Pod
activate Scheduler
Scheduler -> K8sAPI: Bind Pod to Node
deactivate Scheduler

K8sAPI -> Kubelet: Pod assignment
activate Kubelet

Kubelet -> Kubelet: Execute flexVolume driver
Kubelet -> ObjectStorage: Mount S3 bucket\nvia S3FS/FUSE
activate ObjectStorage
ObjectStorage --> Kubelet: Bucket mounted
deactivate ObjectStorage

Kubelet -> Runtime: Create container\nwith S3FS mount
activate Runtime
Runtime --> Kubelet: Container started
deactivate Runtime

Kubelet --> K8sAPI: Pod status: Running
deactivate Kubelet

== Lab 6: StatefulSet with Portworx ==

User -> kubectl: Install Portworx\nvia Helm/Operator
kubectl -> K8sAPI: Deploy Portworx DaemonSet

K8sAPI -> Scheduler: Schedule Portworx\nPods on all nodes
activate Scheduler
Scheduler -> K8sAPI: Bind to all nodes
deactivate Scheduler

K8sAPI -> Kubelet: Deploy Portworx agents
activate Kubelet
Kubelet -> Runtime: Start Portworx containers
Runtime --> Kubelet: Portworx running
Kubelet --> K8sAPI: DaemonSet ready
deactivate Kubelet

User -> kubectl: Create StatefulSet\nwith volumeClaimTemplates
kubectl -> K8sAPI: Create StatefulSet

activate K8sAPI
K8sAPI -> Controller: StatefulSet created
activate Controller

loop For each replica (0 to N-1)
    Controller -> K8sAPI: Create PVC for replica-i
    K8sAPI -> Provisioner: Provision volume
    activate Provisioner
    Provisioner --> K8sAPI: Volume ready
    deactivate Provisioner

    Controller -> K8sAPI: Create Pod replica-i
    K8sAPI -> Scheduler: Schedule Pod
    activate Scheduler
    Scheduler -> K8sAPI: Bind to Node
    deactivate Scheduler

    K8sAPI -> Kubelet: Deploy Pod replica-i
    activate Kubelet
    Kubelet -> Runtime: Start container
    Runtime --> Kubelet: Running
    Kubelet --> K8sAPI: Pod ready
    deactivate Kubelet

    Controller -> Controller: Wait for Pod\nready before next
end

deactivate Controller
deactivate K8sAPI

== Lab 7: IBM Cloud Operator Pattern ==

User -> kubectl: Deploy IBM Cloud Operator
kubectl -> K8sAPI: Create Operator Deployment

K8sAPI -> Scheduler: Schedule Operator Pod
activate Scheduler
Scheduler -> K8sAPI: Bind to Node
deactivate Scheduler

K8sAPI -> Kubelet: Deploy Operator
activate Kubelet
Kubelet -> Runtime: Start Operator container
Runtime --> Kubelet: Operator running
Kubelet --> K8sAPI: Operator ready
deactivate Kubelet

User -> kubectl: Create Service CRD\n(ObjectStorage instance)
kubectl -> K8sAPI: Create Custom Resource

K8sAPI -> Controller: CR created (Operator watches)
activate Controller

Controller -> ObjectStorage: Provision Cloud\nObject Storage service
activate ObjectStorage
ObjectStorage --> Controller: Service provisioned
deactivate ObjectStorage

Controller -> K8sAPI: Create Secret with\nservice credentials
Controller --> User: Service ready
deactivate Controller

@enduml
