@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<microservice>> LightSkyBlue
    BackgroundColor<<gateway>> LightGreen
    BackgroundColor<<infrastructure>> LightGray
    BackgroundColor<<buildingblock>> LightYellow
}

package "External Clients" {
    [Web Client] as WebClient
    [Mobile Client] as MobileClient
}

package "API Gateway Layer" {
    component "API Gateway\n(YARP)" as ApiGateway <<gateway>> {
        [Reverse Proxy]
        [Request Router]
        [Load Balancer]
    }
}

package "Microservices" {
    component "Identity Service" as IdentityService <<microservice>> {
        package "API Layer" {
            [Identity.API]
        }
        package "Application Layer" {
            [CQRS Commands]
            [CQRS Queries]
            [MediatR Handlers]
            [Validators]
        }
        package "Domain Layer" {
            [User Aggregates]
            [Domain Events]
        }
        package "Infrastructure Layer" {
            [Identity DbContext]
            [IdentityServer]
            [JWT Provider]
        }
    }

    component "Flight Service" as FlightService <<microservice>> {
        package "API Layer" as FlightAPI {
            [Flight.API]
        }
        package "Application Layer" as FlightApp {
            [Flight Commands]
            [Flight Queries]
            [Flight Handlers]
            [Flight Validators]
        }
        package "Domain Layer" as FlightDomain {
            [Flight Aggregates]
            [Seat Aggregates]
            [Flight Domain Events]
        }
        package "Infrastructure Layer" as FlightInfra {
            [Flight DbContext]
            [Flight Repository]
        }
    }

    component "Passenger Service" as PassengerService <<microservice>> {
        package "API Layer" as PassengerAPI {
            [Passenger.API]
        }
        package "Application Layer" as PassengerApp {
            [Passenger Commands]
            [Passenger Queries]
            [Passenger Handlers]
            [Passenger Validators]
        }
        package "Domain Layer" as PassengerDomain {
            [Passenger Aggregates]
            [Passenger Domain Events]
        }
        package "Infrastructure Layer" as PassengerInfra {
            [Passenger DbContext]
            [Passenger Repository]
        }
    }

    component "Reservation Service" as ReservationService <<microservice>> {
        package "API Layer" as ReservationAPI {
            [Reservation.API]
        }
        package "Application Layer" as ReservationApp {
            [Reservation Commands]
            [Reservation Queries]
            [Reservation Handlers]
            [Reservation Validators]
        }
        package "Domain Layer" as ReservationDomain {
            [Reservation Aggregates]
            [Reservation Domain Events]
        }
        package "Infrastructure Layer" as ReservationInfra {
            [Reservation DbContext]
            [Reservation Repository]
        }
    }
}

package "Building Blocks" as BuildingBlocks <<buildingblock>> {
    [Exception Handling]
    [Logging (Serilog)]
    [Swagger Config]
    [Data Access Interfaces]
    [Messaging Abstractions]
    [Security Utilities]
    [API Versioning]
    [Health Checks]
    [ProblemDetails Middleware]
}

package "Infrastructure Services" {
    database "Identity DB" as IdentityDB <<infrastructure>>
    database "Flight DB" as FlightDB <<infrastructure>>
    database "Passenger DB" as PassengerDB <<infrastructure>>
    database "Reservation DB" as ReservationDB <<infrastructure>>

    component "Message Broker\n(RabbitMQ)" as RabbitMQ <<infrastructure>> {
        [Message Queue]
        [Event Bus]
    }

    component "MassTransit" as MassTransit <<infrastructure>> {
        [Integration Events Publisher]
        [Integration Events Consumer]
    }
}

package "Container Orchestration" {
    [Docker] <<infrastructure>>
    [Kubernetes] <<infrastructure>>
    [Docker Compose] <<infrastructure>>
}

' External Client Connections
WebClient --> ApiGateway : HTTPS
MobileClient --> ApiGateway : HTTPS

' API Gateway Routing
ApiGateway --> IdentityService : Route /identity
ApiGateway --> FlightService : Route /flights
ApiGateway --> PassengerService : Route /passengers
ApiGateway --> ReservationService : Route /reservations

' Service to Database Connections
IdentityService --> IdentityDB : EF Core
FlightService --> FlightDB : EF Core
PassengerService --> PassengerDB : EF Core
ReservationService --> ReservationDB : EF Core

' Event-Driven Communication
FlightService --> MassTransit : Publish Domain Events
PassengerService --> MassTransit : Publish Domain Events
ReservationService --> MassTransit : Publish Domain Events
IdentityService --> MassTransit : Publish Domain Events

MassTransit --> RabbitMQ : Message Transport
RabbitMQ --> MassTransit : Message Delivery

MassTransit --> FlightService : Consume Integration Events
MassTransit --> PassengerService : Consume Integration Events
MassTransit --> ReservationService : Consume Integration Events
MassTransit --> IdentityService : Consume Integration Events

' Building Blocks Usage
IdentityService ..> BuildingBlocks : uses
FlightService ..> BuildingBlocks : uses
PassengerService ..> BuildingBlocks : uses
ReservationService ..> BuildingBlocks : uses
ApiGateway ..> BuildingBlocks : uses

' Authentication Flow
ReservationService --> IdentityService : Validate JWT Token
FlightService --> IdentityService : Validate JWT Token
PassengerService --> IdentityService : Validate JWT Token

' Container Orchestration
Docker --> IdentityService : Containerize
Docker --> FlightService : Containerize
Docker --> PassengerService : Containerize
Docker --> ReservationService : Containerize
Docker --> ApiGateway : Containerize

[Docker Compose] --> Docker : Orchestrate
Kubernetes --> Docker : Orchestrate

note right of BuildingBlocks
  Shared library providing:
  - Exception handling
  - Logging (Serilog)
  - Swagger configuration
  - Data access interfaces
  - Messaging abstractions
  - Security utilities
  - API versioning
  - Health checks
end note

note right of IdentityService
  Authentication & Authorization
  - IdentityServer
  - JWT tokens
  - User management
end note

note right of FlightService
  Flight Management
  - Flight data
  - Seat availability
  - Flight operations
end note

note right of PassengerService
  Passenger Management
  - Passenger information
  - Passenger profiles
end note

note right of ReservationService
  Reservation Management
  - Flight ticket reservations
  - Booking operations
end note

note left of ApiGateway
  YARP Reverse Proxy
  - Request routing
  - Load balancing
  - API composition
end note

note bottom of MassTransit
  Event-Driven Communication
  - Asynchronous messaging
  - Integration events
  - Domain events translation
end note

@enduml
