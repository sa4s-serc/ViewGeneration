@startuml
title Opium Protocol v2 - Derivative Creation and Settlement Flow

actor User
participant "Core" as Core
participant "Registry" as Registry
participant "TokenSpender" as TokenSpender
participant "SyntheticAggregator" as SyntheticAgg
participant "OpiumProxyFactory" as Factory
participant "Position Tokens\n(LONG/SHORT)" as Tokens
participant "OracleAggregator" as OracleAgg
participant "Oracle" as Oracle
participant "Synthetic Contract" as Synthetic

== Initialization ==
User -> Registry: initialize(governor)
activate Registry
Registry -> Registry: setupRole(GOVERNOR_ROLE, governor)
Registry -> Registry: setupRole(PROTOCOL_ADDRESSES_SPENDER_ROLE)
Registry --> User: Registry initialized
deactivate Registry

User -> Core: initialize(registry)
activate Core
Core -> Registry: getAddress(key)
activate Registry
Registry --> Core: addresses
deactivate Registry
Core --> User: Core initialized
deactivate Core

== Derivative Creation ==
User -> Core: create(derivative, margin, buyer, seller)
activate Core

Core -> Registry: pause() check
activate Registry
Registry --> Core: not paused
deactivate Registry

Core -> SyntheticAgg: getMargin(derivative)
activate SyntheticAgg
SyntheticAgg -> Synthetic: getMargin(derivative)
activate Synthetic
Synthetic --> SyntheticAgg: margin requirement
deactivate Synthetic
SyntheticAgg -> SyntheticAgg: cache derivative data
SyntheticAgg --> Core: cached margin
deactivate SyntheticAgg

Core -> TokenSpender: claimTokens(collateralToken, buyer, margin)
activate TokenSpender
TokenSpender -> TokenSpender: check whitelist
TokenSpender -> User: transferFrom(buyer, Core, margin)
activate User
User --> TokenSpender: tokens transferred
deactivate User
TokenSpender --> Core: tokens claimed
deactivate TokenSpender

Core -> TokenSpender: claimTokens(collateralToken, seller, margin)
activate TokenSpender
TokenSpender -> User: transferFrom(seller, Core, margin)
activate User
User --> TokenSpender: tokens transferred
deactivate User
TokenSpender --> Core: tokens claimed
deactivate TokenSpender

Core -> Factory: getPositionTokenAddress(derivative, LONG)
activate Factory
Factory -> Factory: check if exists
alt Position tokens not created
    Factory -> Factory: create new proxy
    Factory -> Tokens: deploy(LONG)
    activate Tokens
    Tokens --> Factory: LONG token created
    deactivate Tokens
    Factory -> Tokens: deploy(SHORT)
    activate Tokens
    Tokens --> Factory: SHORT token created
    deactivate Tokens
end
Factory --> Core: token addresses
deactivate Factory

Core -> Tokens: mint(buyer, LONG position)
activate Tokens
Tokens --> Core: LONG minted
deactivate Tokens

Core -> Tokens: mint(seller, SHORT position)
activate Tokens
Tokens --> Core: SHORT minted
deactivate Tokens

Core --> User: positions created
deactivate Core

== Oracle Data Provision ==
Oracle -> OracleAgg: __callback(timestamp, data)
activate OracleAgg
OracleAgg -> OracleAgg: cache oracle data
OracleAgg --> Oracle: data stored
deactivate OracleAgg

== Settlement at Maturity ==
User -> Core: execute(derivative, positionOwner)
activate Core

Core -> Registry: pause() check
activate Registry
Registry --> Core: not paused
deactivate Registry

Core -> Core: check maturity timestamp

Core -> OracleAgg: getData(oracleId, timestamp)
activate OracleAgg
OracleAgg -> OracleAgg: retrieve cached data
OracleAgg --> Core: oracle data
deactivate OracleAgg

Core -> SyntheticAgg: getExecutionPayout(derivative, oracleData)
activate SyntheticAgg
SyntheticAgg -> Synthetic: getExecutionPayout(derivative, oracleData)
activate Synthetic
Synthetic -> Synthetic: calculate payout
Synthetic --> SyntheticAgg: payout amounts
deactivate Synthetic
SyntheticAgg --> Core: cached payout
deactivate SyntheticAgg

Core -> Tokens: burn(positionOwner, amount)
activate Tokens
Tokens --> Core: tokens burned
deactivate Tokens

Core -> Core: calculate protocol reserve
Core -> Core: calculate author reserve

Core -> TokenSpender: transfer(collateralToken, positionOwner, payout)
activate TokenSpender
TokenSpender -> User: transfer(positionOwner, payout)
activate User
User --> TokenSpender: payout transferred
deactivate User
TokenSpender --> Core: transfer complete
deactivate TokenSpender

Core --> User: position settled
deactivate Core

== Reserve Claiming ==
User -> Core: claimReserve(derivative, amount, recipient)
activate Core

Core -> Registry: getProtocolRedemptionReservePart()
activate Registry
Registry --> Core: reserve percentage
deactivate Registry

Core -> Core: calculate claimable reserve

Core -> TokenSpender: transfer(collateralToken, recipient, reserve)
activate TokenSpender
TokenSpender -> User: transfer(recipient, reserve)
activate User
User --> TokenSpender: reserve transferred
deactivate User
TokenSpender --> Core: transfer complete
deactivate TokenSpender

Core --> User: reserve claimed
deactivate Core

== Emergency Pause ==
User -> Registry: pause()
activate Registry
Registry -> Registry: check GUARDIAN_ROLE
Registry -> Registry: set paused state
Registry --> User: protocol paused
deactivate Registry

User -> Core: create(derivative, margin, buyer, seller)
activate Core
Core -> Registry: pause() check
activate Registry
Registry --> Core: paused
deactivate Registry
Core --> User: revert: protocol paused
deactivate Core

@enduml
