@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<driver>> LightGreen
    BackgroundColor<<external>> LightYellow
    BackgroundColor<<client>> LightPink
    BackgroundColor<<protocol>> LightGray
}

title MATRIX MALOS Z-Wave Architecture - Component Diagram

package "MATRIX MALOS Z-Wave Service" {
    component "malos_zwave\n(Main Application)" as MalosZwave <<core>> {
        component "Driver Manager" as DriverMgr
        component "Service Controller" as ServiceCtrl
    }

    component "Z-Wave Driver\n(driver_zwave)" as ZWaveDriver <<driver>> {
        component "Device Management" as DeviceMgmt
        component "Command Handler" as CmdHandler
        component "Security Manager" as SecMgr
        component "Schedule Manager" as SchMgr
        component "Sensor Controller" as SensorCtrl
        component "Switch Controller" as SwitchCtrl
    }

    component "libzwaveip\n(Z-Wave IP Library)" as LibZWaveIP <<driver>>

    component "Protocol Buffers\nDefinitions" as ProtoBuf <<protocol>> {
        component "Command Class\nMessages" as CCMessages
        component "Configuration\nMessages" as ConfigMsg
        component "MALOS Messages" as MalosMsg
    }
}

package "Communication Layer" {
    component "ZeroMQ (0MQ)\nMessaging" as ZMQ <<protocol>> {
        interface "PUB Socket" as PubSocket
        interface "SUB Socket" as SubSocket
        interface "REQ/REP Socket" as ReqRepSocket
    }
}

package "External Systems" {
    component "Z/IP Gateway" as ZIPGateway <<external>> {
        component "IP to Z-Wave RF\nTranslator" as IPTranslator
    }

    component "Z-Wave Module\n(/dev/ttyMATRIX0)" as ZWaveModule <<external>>

    component "MATRIX Core\n(MALOS)" as MATRIXCore <<external>> {
        component "Hardware\nAbstraction Layer" as HAL
        component "IMU Sensor" as IMU
    }
}

package "Client Applications" {
    component "JavaScript Clients" as JSClients <<client>> {
        component "addnode.js" as AddNode
        component "removenode.js" as RemoveNode
        component "list.js" as ListNodes
        component "simpleTest.js" as SimpleTest
        component "test_zwave_accel.js" as AccelTest
    }
}

package "Build & Deployment" {
    component "CMake Build System" as CMake
    component "Drone CI Pipeline" as DroneCI
    component "Debian Packaging" as DebianPkg
    component "Systemd Service\n(matrixio-malos-zwave)" as SystemdService
}

package "Configuration & Tools" {
    component "XML Command Class\nDefinitions" as XMLConfig
    component "zwave_proto_gen\n(Proto Generator)" as ProtoGen
    component "zwave_json_gen\n(JSON Generator)" as JSONGen
}

' Main application relationships
MalosZwave --> ZWaveDriver : manages
DriverMgr --> ZWaveDriver : initializes
ServiceCtrl --> SystemdService : controlled by

' Z-Wave Driver internal relationships
ZWaveDriver --> LibZWaveIP : uses
DeviceMgmt --> CmdHandler : delegates
CmdHandler --> SecMgr : uses
CmdHandler --> SchMgr : uses
CmdHandler --> SensorCtrl : uses
CmdHandler --> SwitchCtrl : uses

' Protocol Buffer relationships
ZWaveDriver ..> ProtoBuf : serializes/deserializes
MalosZwave ..> ProtoBuf : uses
JSClients ..> ProtoBuf : uses

' ZeroMQ communication
MalosZwave --> ZMQ : publishes/subscribes
ZWaveDriver --> ZMQ : sends/receives
JSClients --> ZMQ : connects
ZMQ --> PubSocket : provides
ZMQ --> SubSocket : provides
ZMQ --> ReqRepSocket : provides

' External system connections
LibZWaveIP --> ZIPGateway : communicates via IP
ZIPGateway --> IPTranslator : translates
IPTranslator --> ZWaveModule : serial (/dev/ttyMATRIX0)
MalosZwave --> MATRIXCore : integrates with
AccelTest --> IMU : subscribes to events

' Z-Wave device interaction
ZWaveDriver --> ZIPGateway : sends commands
ZIPGateway --> ZWaveDriver : receives events

' Client interactions
AddNode --> MalosZwave : add node command
RemoveNode --> MalosZwave : remove node command
ListNodes --> MalosZwave : list devices
SimpleTest --> ZWaveDriver : test commands
AccelTest --> ZWaveDriver : event-driven control

' Build and deployment relationships
CMake --> MalosZwave : builds
DroneCI --> CMake : triggers
DroneCI --> DebianPkg : creates
DebianPkg --> SystemdService : installs

' Configuration and tools
XMLConfig --> ProtoGen : input
ProtoGen --> ProtoBuf : generates
XMLConfig --> JSONGen : input
JSONGen --> CCMessages : generates descriptions

' Command class support
CCMessages ..> DeviceMgmt : COMMAND_CLASS_SWITCH_BINARY\nCOMMAND_CLASS_SENSOR_MULTILEVEL\nCOMMAND_CLASS_SCHEDULE\nCOMMAND_CLASS_SECURITY\nCOMMAND_CLASS_SECURITY_2\nCOMMAND_CLASS_SCREEN_ATTRIBUTES

note right of MalosZwave
  Microservice architecture
  Event-driven design
  Runs as systemd service
end note

note right of ZWaveDriver
  Implements Observer pattern
  Handles Z-Wave command classes:
  - Binary/Multilevel Sensors
  - Binary/Multilevel Switches
  - Schedule Management
  - Security (v1 & v2)
  - Screen Management
end note

note bottom of ZMQ
  Implements Observer pattern
  Provides pub/sub messaging
  Enables loose coupling
end note

note right of ProtoBuf
  Data Transfer Object pattern
  Efficient serialization
  Cross-language support
end note

note left of MATRIXCore
  Facade pattern
  Hardware abstraction
  Simplifies hardware access
end note

note bottom of ZIPGateway
  Adapter/Wrapper pattern
  IP to RF translation
  Bridge between IP and Z-Wave
end note

@enduml
