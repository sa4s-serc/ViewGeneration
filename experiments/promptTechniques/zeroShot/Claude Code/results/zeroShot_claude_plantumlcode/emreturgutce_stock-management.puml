@startuml
!define RECTANGLE_COLOR #4A90E2
!define DATABASE_COLOR #50C878
!define EXTERNAL_COLOR #FF6B6B

skinparam component {
    BackgroundColor RECTANGLE_COLOR
    BorderColor #2E5C8A
}

skinparam database {
    BackgroundColor DATABASE_COLOR
    BorderColor #2E8B57
}

skinparam cloud {
    BackgroundColor EXTERNAL_COLOR
    BorderColor #CC5555
}

title Stock Management Application - Deployment Architecture

package "Client Layer" {
    [Web Browser] as browser
}

node "Application Server Docker Container" as appserver {
    package "Express.js Application" {
        [API Controllers] as controllers
        [Middleware Layer] as middleware
        [Business Logic] as logic
        [Configuration] as config
    }
}

node "Database Server Docker Container" as dbserver {
    database "PostgreSQL" as postgres
}

node "Cache Server Docker Container" as cacheserver {
    database "Redis" as redis
}

cloud "AWS Services" as aws {
    [S3 Bucket] as s3
}

cloud "Email Service" as email {
    [SMTP Server] as smtp
}

browser --> controllers : HTTPS/REST API

controllers ..> middleware : uses
middleware ..> logic : uses
logic ..> config : uses

logic --> postgres : SQL Queries
logic --> redis : Session/Cache
logic --> s3 : Image Upload
logic --> smtp : Send Emails

config --> postgres : Connection Pool
config --> redis : Session Management
config --> s3 : AWS Credentials

note right of appserver
  Environment Variables:
  - Database credentials
  - Redis connection
  - AWS S3 credentials
  - Session secrets
  - CORS settings

  Components:
  - API Controllers (Personnel, Supplier,
    Car, Customer, Sales, Awaiting List)
  - Middleware (Auth, Authorization,
    Validation, Error Handler, Rate Limiter)
  - Business Logic (DB Queries, Utils,
    PDF Generator, Email Service,
    Image Upload, Excel Import)
  - Configuration (DB, Redis, S3,
    Session, CORS)
end note

note right of middleware
  Security Features:
  - bcryptjs password hashing
  - express-session management
  - Rate limiting protection
  - Input validation
  - CORS configuration
end note

note bottom of postgres
  Persistent Volume:
  Data persisted across
  container restarts

  Tables: Users, Suppliers,
  Cars, Customers, Sales,
  Awaiting List
end note

note bottom of redis
  In-Memory Store:
  - Fast session access
  - Rate limit tracking
end note

@enduml
