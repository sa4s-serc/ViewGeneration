@startuml
!define RECTANGLE class

actor "User (Web)" as WebUser
actor "API Client" as APIClient
participant "Bottle Web Server\n(youtube-dl-server.py)" as WebServer
participant "Auth.json" as AuthStore
participant "Download Queue" as Queue
participant "Download Worker Thread" as Worker
participant "WebSocket (WSAddr)" as WebSocket
participant "yt-dlp/youtube-dl" as Downloader
database "downfolder/" as Storage
participant "APScheduler\n(upd_schedule.py)" as Scheduler

== Initialization ==
WebServer -> Scheduler: Start daily update scheduler
activate Scheduler
Scheduler -> Downloader: Schedule daily updates
deactivate Scheduler

WebServer -> Worker: Start worker thread
activate Worker

== Web Interface Authentication Flow ==
WebUser -> WebServer: GET /
activate WebServer
WebServer -> WebUser: Redirect to /login
deactivate WebServer

WebUser -> WebServer: GET /login
activate WebServer
WebServer -> WebUser: Return login.tpl
deactivate WebServer

WebUser -> WebServer: POST /login (username, password)
activate WebServer
WebServer -> AuthStore: Read credentials
activate AuthStore
AuthStore -> WebServer: Return stored credentials
deactivate AuthStore

alt Valid Credentials
    WebServer -> WebServer: Set session cookie
    WebServer -> WebUser: Redirect to /index
else Invalid Credentials
    WebServer -> WebUser: Return error message
end
deactivate WebServer

== WebSocket Connection for Real-time Updates ==
WebUser -> WebServer: WS /websocket
activate WebServer
WebServer -> WebSocket: Store connection in WSAddr
activate WebSocket
WebSocket -> WebUser: Connection established
deactivate WebServer

== Download Request via Web Interface ==
WebUser -> WebServer: POST /download (URL)
activate WebServer
WebServer -> WebServer: Check session authentication
alt Authenticated
    WebServer -> Queue: Add download request
    activate Queue
    Queue -> WebServer: Request queued
    deactivate Queue
    WebServer -> WebSocket: Send queue update
    WebSocket -> WebUser: Queue status update
    WebServer -> WebUser: Success response
else Not Authenticated
    WebServer -> WebUser: Redirect to /login
end
deactivate WebServer

== Download Request via REST API ==
APIClient -> WebServer: POST /api/download\n(URL, id, password)
activate WebServer
WebServer -> AuthStore: Validate API credentials
activate AuthStore
AuthStore -> WebServer: Return validation result
deactivate AuthStore

alt Valid API Credentials
    WebServer -> Queue: Add download request
    activate Queue
    Queue -> WebServer: Request queued
    deactivate Queue
    WebServer -> WebSocket: Send queue update
    WebSocket -> WebUser: Queue status update (if connected)
    WebServer -> APIClient: JSON response (success)
else Invalid API Credentials
    WebServer -> APIClient: JSON response (error)
end
deactivate WebServer

== Download Processing (Worker Thread) ==
loop Continuous Processing
    Worker -> Queue: Get next download request
    activate Queue
    Queue -> Worker: Return download request
    deactivate Queue

    alt Queue Not Empty
        Worker -> WebSocket: Send status update (processing)
        WebSocket -> WebUser: Download started notification

        Worker -> Worker: build_youtube_dl_cmd()
        note right
            Apply proxy settings if configured
            Add authentication options
        end note

        Worker -> Downloader: Execute download command
        activate Downloader
        Downloader -> Storage: Save downloaded file
        activate Storage
        Storage -> Downloader: File saved
        deactivate Storage
        Downloader -> Worker: Download complete
        deactivate Downloader

        Worker -> WebSocket: Send completion notification
        WebSocket -> WebUser: Download complete + queue length

    else Queue Empty
        Worker -> Worker: Wait for next request
    end
end

== Query Status via REST API ==
APIClient -> WebServer: GET /api/status (id, password)
activate WebServer
WebServer -> AuthStore: Validate API credentials
activate AuthStore
AuthStore -> WebServer: Return validation result
deactivate AuthStore

alt Valid API Credentials
    WebServer -> Queue: Get queue status
    activate Queue
    Queue -> WebServer: Queue length
    deactivate Queue
    WebServer -> APIClient: JSON response (queue status)
else Invalid API Credentials
    WebServer -> APIClient: JSON response (error)
end
deactivate WebServer

== Scheduled Update ==
Scheduler -> Downloader: pip install --upgrade yt-dlp/youtube-dl
activate Downloader
Downloader -> Scheduler: Update complete
deactivate Downloader

== Error Handling ==
Worker -> Downloader: Execute download command
activate Downloader
Downloader -> Worker: Download error
deactivate Downloader

Worker -> WebSocket: Send error notification
note right
    Thread safety concern:
    WebSocket connection may be closed
    Catch exceptions when sending
end note

alt WebSocket Connected
    WebSocket -> WebUser: Error message
else WebSocket Disconnected
    Worker -> Worker: Log error silently
end

deactivate Worker
deactivate WebSocket

@enduml
