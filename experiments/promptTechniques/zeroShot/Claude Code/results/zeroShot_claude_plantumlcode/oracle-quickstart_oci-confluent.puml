@startuml
!define RECTANGLE_COLOR #E3F2FD
!define COMPONENT_COLOR #90CAF9
!define SECURITY_COLOR #FFCCBC
!define DATABASE_COLOR #C8E6C9
!define STORAGE_COLOR #FFF9C4

skinparam component {
    BackgroundColor COMPONENT_COLOR
    BorderColor #1976D2
    ArrowColor #424242
}

skinparam rectangle {
    BackgroundColor RECTANGLE_COLOR
    BorderColor #1976D2
}

skinparam database {
    BackgroundColor DATABASE_COLOR
    BorderColor #388E3C
}

skinparam package {
    BackgroundColor RECTANGLE_COLOR
    BorderColor #1976D2
}

title Confluent Platform on OCI - Deployment and Security Architecture

package "Oracle Cloud Infrastructure (OCI)" {

    rectangle "Virtual Cloud Network (VCN)" as VCN #RECTANGLE_COLOR {

        component "Security Lists" as SecurityLists #SECURITY_COLOR
        component "Firewall Rules" as Firewall #SECURITY_COLOR
        component "Network ACLs" as ACLs #SECURITY_COLOR

        component "Zookeeper Instance 1" as ZK1
        component "Zookeeper Instance 2" as ZK2
        component "Zookeeper Instance 3" as ZK3
        database "ZK Config Data" as ZKData

        component "Broker Instance 1" as B1
        component "Broker Instance 2" as B2
        component "Broker Instance 3" as B3
        database "Block Volume 1" as BV1 #STORAGE_COLOR
        database "Block Volume 2" as BV2 #STORAGE_COLOR
        database "Block Volume 3" as BV3 #STORAGE_COLOR

        component "Schema Registry" as SR
        component "REST Proxy" as REST
        component "Kafka Connect" as Connect
        component "KSQL Server" as KSQL
        component "Control Center" as CC
    }

    database "Object Storage S3" as ObjStorage #STORAGE_COLOR
    database "Autonomous Database" as ADB #DATABASE_COLOR
    component "S3 Compatibility API" as S3API
    component "Secure Wallet" as Wallet #SECURITY_COLOR
}

package "Infrastructure as Code" {
    component "Terraform Engine" as Terraform
    component "Enterprise Module" as TF_Ent
    component "Community Module" as TF_Comm
    component "Variables Config" as TF_Vars
    component "Network Config" as TF_Net
    component "Component Configs" as TF_Comp
}

package "Bootstrap Configuration" {
    component "Cloud-Init" as CloudInit #SECURITY_COLOR
    component "User Data Scripts" as UserData
    component "install.sh" as InstallScript
    component "firewall.sh" as FirewallScript
    component "disks.sh" as DisksScript
    component "zookeeper.sh" as ZKScript
    component "broker.sh" as BrokerScript
    component "service scripts" as ServiceScripts
}

Terraform --> VCN : provisions
Terraform --> SecurityLists : configures
Terraform --> Firewall : configures
Terraform --> ZK1 : deploys
Terraform --> ZK2 : deploys
Terraform --> ZK3 : deploys
Terraform --> B1 : deploys
Terraform --> B2 : deploys
Terraform --> B3 : deploys
Terraform --> SR : deploys
Terraform --> REST : deploys
Terraform --> Connect : deploys
Terraform --> KSQL : deploys
Terraform --> CC : deploys
Terraform --> BV1 : attaches
Terraform --> BV2 : attaches
Terraform --> BV3 : attaches

TF_Ent ..> Terraform : uses
TF_Comm ..> Terraform : uses
TF_Vars ..> Terraform : configures
TF_Net ..> Terraform : configures
TF_Comp ..> Terraform : configures

CloudInit --> ZK1 : initializes
CloudInit --> ZK2 : initializes
CloudInit --> ZK3 : initializes
CloudInit --> B1 : initializes
CloudInit --> B2 : initializes
CloudInit --> B3 : initializes
CloudInit --> SR : initializes
CloudInit --> REST : initializes
CloudInit --> Connect : initializes
CloudInit --> KSQL : initializes
CloudInit --> CC : initializes

UserData ..> CloudInit : provides config
InstallScript ..> CloudInit : executed by
FirewallScript ..> CloudInit : executed by
DisksScript ..> CloudInit : executed by
ZKScript ..> CloudInit : executed by
BrokerScript ..> CloudInit : executed by
ServiceScripts ..> CloudInit : executed by

B1 --> ZK1 : coordinates
B1 --> ZK2 : coordinates
B1 --> ZK3 : coordinates
B2 --> ZK1 : coordinates
B2 --> ZK2 : coordinates
B2 --> ZK3 : coordinates
B3 --> ZK1 : coordinates
B3 --> ZK2 : coordinates
B3 --> ZK3 : coordinates

SR --> B1 : connects
SR --> B2 : connects
SR --> B3 : connects

REST --> B1 : connects
REST --> B2 : connects
REST --> B3 : connects

Connect --> B1 : connects
Connect --> B2 : connects
Connect --> B3 : connects

KSQL --> B1 : connects
KSQL --> B2 : connects
KSQL --> B3 : connects

CC --> B1 : monitors
CC --> B2 : monitors
CC --> B3 : monitors
CC --> ZK1 : monitors
CC --> ZK2 : monitors
CC --> ZK3 : monitors

B1 --> BV1 : mounts iSCSI
B2 --> BV2 : mounts iSCSI
B3 --> BV3 : mounts iSCSI

ZK1 --> ZKData : stores
ZK2 --> ZKData : stores
ZK3 --> ZKData : stores

SecurityLists --> ZK1 : protects
SecurityLists --> B1 : protects
SecurityLists --> SR : protects
Firewall --> VCN : secures
ACLs --> VCN : controls access

Connect --> S3API : uses
S3API --> ObjStorage : writes to
Connect --> Wallet : authenticates with
Wallet --> ADB : secure connection

note right of CC
  Enterprise Edition Only
  Monitoring & Management
end note

note right of Wallet
  Secure wallet files for
  encrypted ADW/ATP connections
end note

note left of SecurityLists
  Network security enforced at
  VCN and subnet levels
end note

note bottom of DisksScript
  Implements retry logic for
  transient iSCSI failures
end note

note top of Terraform
  Modular IaC approach
  Externalized configuration
  Repeatable deployment
end note

@enduml
