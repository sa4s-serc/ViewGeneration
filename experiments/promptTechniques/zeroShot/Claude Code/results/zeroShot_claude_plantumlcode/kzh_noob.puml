@startuml
!define RECTANGLE_COMPONENT

skinparam component {
    BackgroundColor<<infrastructure>> LightBlue
    BackgroundColor<<microservice>> LightGreen
    BackgroundColor<<gateway>> Orange
}

package "Kubernetes Cluster" {

    component "API Gateway\n(Nginx Ingress)" as gateway <<gateway>>

    package "Microservices Layer" {
        component "Frontend Service" as frontend <<microservice>> {
            portin http_in
            portout static_assets
            portout html_templates
        }

        component "Auth Service" as auth <<microservice>> {
            portin auth_api
            portout auth_logic
        }

        component "Problems Service" as problems <<microservice>> {
            portin problems_api
            portout problem_management
        }

        component "Submissions Service" as submissions <<microservice>> {
            portin submissions_api
            portout websocket
            portout mq_publisher
        }

        component "Executor Service" as executor <<microservice>> {
            portin mq_consumer
            portout docker_exec
        }
    }

    package "Infrastructure Services" {
        database "MongoDB" as mongo <<infrastructure>> {
            port db_port
        }

        queue "RabbitMQ" as rabbitmq <<infrastructure>> {
            port mq_port
        }

        database "Redis" as redis <<infrastructure>> {
            port cache_port
        }

        component "Jaeger" as jaeger <<infrastructure>> {
            port tracing_port
        }
    }

    component "Docker Runtime" as docker <<infrastructure>> {
        port docker_api
    }
}

package "External" {
    actor "User/Browser" as user
}

' Gateway routing
user --> gateway : HTTPS
gateway --> frontend : /
gateway --> auth : /auth/*
gateway --> problems : /problems/*
gateway --> submissions : /submissions/*

' Service to infrastructure dependencies
frontend --> redis : Session Storage
frontend --> mongo : Read Static Data

auth --> mongo : User Data
auth --> redis : Session Management

problems --> mongo : Problem Definitions\n& Test Cases

submissions --> mongo : Store Submissions
submissions --> rabbitmq : Publish Submission\nMessages
submissions --> redis : Session Validation

executor --> rabbitmq : Consume Submission\nMessages
executor --> rabbitmq : Publish Results
executor --> docker : Execute Code\nin Containers
executor --> mongo : Update Results

' Monitoring
frontend -[hidden]-> jaeger
auth --> jaeger : Distributed Tracing
problems --> jaeger : Distributed Tracing
submissions --> jaeger : Distributed Tracing
executor --> jaeger : Distributed Tracing

' WebSocket communication
user ..> submissions : WebSocket\n(Real-time feedback)

note right of gateway
  Routes traffic based on
  URL paths to appropriate
  microservices
end note

note bottom of executor
  Uses Docker-in-Docker
  for sandboxed code
  execution
end note

note top of rabbitmq
  Asynchronous message queue
  for submission workflow:
  1. Submissions publishes
  2. Executor consumes
  3. Executor publishes results
end note

note bottom of mongo
  Persistent storage for:
  - User accounts
  - Problem definitions
  - Test cases
  - Submission results
end note

note bottom of redis
  Session storage for
  stateless service design
end note

@enduml
