@startuml
!define COMPONENT_COLOR #E3F2FD
!define INTERFACE_COLOR #B3E5FC
!define EXTERNAL_COLOR #FFE0B2

title Angular Interview Questions & Answers Repository - Component Architecture

package "Content Repository System" {

    package "Core Content Components" <<COMPONENT_COLOR>> {
        [Q&A Collection Module] as QA
        [Code Examples Library] as Code
        [Documentation Manager] as Docs

        QA ..> Code : includes
        Docs ..> QA : organizes
    }

    package "Navigation & Structure" <<COMPONENT_COLOR>> {
        [Table of Contents] as TOC
        [README Manager] as README
        [Content Indexer] as Index

        TOC ..> Index : uses
        README ..> TOC : provides
    }

    package "Content Categories" <<COMPONENT_COLOR>> {
        [Basic Angular Concepts] as Basic
        [Advanced Angular Topics] as Advanced
        [RxJS Questions] as RxJS
        [Angular CLI Module] as CLI
        [Angular Material] as Material
        [Components & Directives] as Components
        [Services & Dependency Injection] as Services
        [Routing Module] as Routing
        [AOT Compilation] as AOT
        [Security Module] as Security

        Basic -down-> QA
        Advanced -down-> QA
        RxJS -down-> QA
        CLI -down-> QA
        Material -down-> QA
        Components -down-> QA
        Services -down-> QA
        Routing -down-> QA
        AOT -down-> QA
        Security -down-> QA
    }

    package "Distribution & Access" <<COMPONENT_COLOR>> {
        [Export Manager] as Export
        [PDF Generator] as PDF
        [EPUB Generator] as EPUB

        Export --> PDF : generates
        Export --> EPUB : generates
    }

    package "Legal & Licensing" <<COMPONENT_COLOR>> {
        [License Manager] as License
    }

    interface "Content Access Interface" as CAI
    interface "Navigation Interface" as NI
    interface "Export Interface" as EI

    QA -up- CAI
    TOC -up- NI
    Export -up- EI
}

package "External Resources" <<EXTERNAL_COLOR>> {
    [YouTube Content] as YouTube
    [External Websites] as Websites
    [Author Social Media] as Social
}

actor "Interview Candidate" as User
actor "Angular Developer" as Developer
actor "Content Contributor" as Contributor

User --> NI : navigates
User --> CAI : reads
Developer --> CAI : studies
Developer --> EI : downloads
Contributor --> QA : adds content

README --> YouTube : links to
README --> Websites : references
README --> Social : provides

note right of QA
  Knowledge Repository Pattern:
  - Modular content organization
  - Independent Q&A units
  - Easy updates and additions
end note

note right of Code
  Practical Application Focus:
  - Illustrative code snippets
  - Real-world examples
  - Hands-on learning support
end note

note bottom of "Content Categories"
  Comprehensive Coverage:
  - Basic to Advanced levels
  - Framework-wide topics
  - Best practices included
end note

note right of License
  Apache 2.0 License:
  - Usage rights
  - Distribution terms
  - Reproduction restrictions
end note

@enduml
