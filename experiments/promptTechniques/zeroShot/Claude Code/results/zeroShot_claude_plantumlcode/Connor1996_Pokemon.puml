@startuml
skinparam componentStyle rectangle

package "Client Layer" {
    [GUI Components] as GUI
    [Widget Manager] as WidgetMgr
    [Client Socket] as ClientSocket

    component "Qt GUI Widgets" {
        [Login Widget] as Login
        [Stack Widget] as Stack
        [Game Lobby] as Lobby
        [User List Widget] as UserList
        [Bag Widget] as Bag
        [Fight Widget] as Fight
        [Fight Room] as FightRoom
        [Scratch Widget] as Scratch
    }

    GUI --> WidgetMgr
    WidgetMgr --> Login
    WidgetMgr --> Stack
    WidgetMgr --> Lobby
    WidgetMgr --> UserList
    WidgetMgr --> Bag
    WidgetMgr --> Fight
    WidgetMgr --> FightRoom
    WidgetMgr --> Scratch
}

package "Communication Layer" {
    [Socket Interface] as SocketInterface
    [JSON Processor] as JSON
    [Request/Response Handler] as ReqResp

    SocketInterface --> JSON
    JSON --> ReqResp
}

package "Server Layer" {
    [Server Socket] as ServerSocket
    [Multi-threaded Handler] as MTHandler
    [Dispatcher] as Dispatcher
    [Request Router] as Router

    ServerSocket --> MTHandler
    MTHandler --> Dispatcher
    Dispatcher --> Router
}

package "Business Logic Layer" {
    [Pokemon Factory] as Factory
    [Pokemon Classes] as PokemonClasses
    [Battle Logic] as BattleLogic
    [Reflector] as Reflector

    Factory --> PokemonClasses
    Factory --> Reflector
    BattleLogic --> PokemonClasses
}

package "Data Access Layer" {
    [ORM (ORMLite)] as ORM
    [Model Classes] as Models
    [Database Manager] as DBManager

    component "Model Entities" {
        [UserInfo] as UserInfo
        [UserBag] as UserBag
        [PokemonList] as PokemonList
        [PokemonInfo] as PokemonInfo
    }

    ORM --> Models
    Models --> UserInfo
    Models --> UserBag
    Models --> PokemonList
    Models --> PokemonInfo
    ORM --> DBManager
}

package "Persistence Layer" {
    [SQLite Database] as SQLite
    [Virtual File System] as VFS

    SQLite --> VFS
}

package "Testing Framework" {
    [Catch2 Tests] as Tests
}

' Client to Communication
GUI --> ClientSocket
ClientSocket --> SocketInterface

' Server to Communication
ServerSocket --> SocketInterface

' Server to Business Logic
Router --> Factory
Router --> BattleLogic

' Business Logic to Data Access
Factory --> ORM
BattleLogic --> ORM
Dispatcher --> ORM

' Data Access to Persistence
DBManager --> SQLite

' Testing
Tests --> ORM
Tests --> Factory

' Cross-layer dependencies
Reflector --> ORM

interface "Socket API" as SocketAPI
interface "Database API" as DBAPI
interface "JSON API" as JSONAPI

ClientSocket -up- SocketAPI
ServerSocket -up- SocketAPI
SocketInterface ..> SocketAPI : implements

DBManager -down- DBAPI
SQLite ..> DBAPI : implements

JSON -up- JSONAPI
ReqResp ..> JSONAPI : uses

note right of SocketInterface
  Handles client-server
  communication via sockets
end note

note right of ORM
  Maps C++ objects to
  database records using
  reflection
end note

note right of Dispatcher
  Implements Command pattern
  Routes requests to handlers
  Maintains user state
end note

note right of Factory
  Factory pattern for
  creating Pokemon instances
  Supports polymorphism
end note

note left of SQLite
  Persistent storage
  Uses VFS for OS abstraction
end note

note top of GUI
  Qt-based GUI
  Signal/Slot mechanism
  Event-driven architecture
end note

@enduml
