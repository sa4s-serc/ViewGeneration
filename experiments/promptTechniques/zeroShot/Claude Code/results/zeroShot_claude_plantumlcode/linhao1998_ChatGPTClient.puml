@startuml

skinparam component {
    BackgroundColor<<UI>> LightBlue
    BackgroundColor<<ViewModel>> LightGreen
    BackgroundColor<<Repository>> LightYellow
    BackgroundColor<<Database>> LightCoral
    BackgroundColor<<Model>> LightGray
    BackgroundColor<<External>> Wheat
    BackgroundColor<<DAO>> Pink
}

package "Presentation Layer" {
    component [ChatActivity] <<UI>>
    component [SettingsActivity] <<UI>>
    component [ChatAdapter] <<UI>>
    component [MsgAdapter] <<UI>>
    component [activity_chat.xml] <<UI>>
    component [activity_settings.xml] <<UI>>
    component [chat_item.xml] <<UI>>
    component [msg_item.xml] <<UI>>
}

package "ViewModel Layer" {
    component [ChatViewModel] <<ViewModel>>
    component [ChatListViewModel] <<ViewModel>>
    component [MsgListViewModel] <<ViewModel>>
}

package "Domain Layer" {
    component [Repository] <<Repository>>
    component [ChatGPTClientApplication] <<Repository>>
}

package "Data Layer" {
    component [AppDatabase] <<Database>>
    component [ChatDao] <<DAO>>
    component [MsgDao] <<DAO>>
    component [Chat] <<Model>>
    component [Msg] <<Model>>
    component [SharedPreferences] <<Database>>
}

package "External Libraries" {
    component [Room Library] <<External>>
    component [Markwon Library] <<External>>
    component [LiveData] <<External>>
    component [Flow] <<External>>
    component [Coroutines] <<External>>
}

package "External Services" {
    component [OpenAI ChatGPT API] <<External>>
}

[ChatActivity] --> [activity_chat.xml] : uses
[SettingsActivity] --> [activity_settings.xml] : uses
[ChatAdapter] --> [chat_item.xml] : inflates
[MsgAdapter] --> [msg_item.xml] : inflates

[ChatActivity] --> [ChatViewModel] : observes
[ChatActivity] --> [ChatListViewModel] : observes
[ChatActivity] --> [MsgListViewModel] : observes
[ChatActivity] --> [ChatAdapter] : uses
[ChatActivity] --> [MsgAdapter] : uses

[SettingsActivity] --> [SharedPreferences] : reads/writes

[ChatViewModel] --> [Repository] : requests data
[ChatListViewModel] --> [Repository] : requests data
[MsgListViewModel] --> [Repository] : requests data

[Repository] --> [AppDatabase] : accesses
[Repository] --> [ChatDao] : queries
[Repository] --> [MsgDao] : queries
[Repository] --> [OpenAI ChatGPT API] : calls API
[Repository] --> [Coroutines] : uses

[AppDatabase] --> [ChatDao] : provides
[AppDatabase] --> [MsgDao] : provides
[AppDatabase] --> [Room Library] : built on

[ChatDao] --> [Chat] : manages
[MsgDao] --> [Msg] : manages

[ChatGPTClientApplication] --> [AppDatabase] : initializes
[ChatGPTClientApplication] --> [SharedPreferences] : initializes

[MsgAdapter] --> [Markwon Library] : renders markdown

[ChatViewModel] --> [LiveData] : uses
[ChatViewModel] --> [Flow] : uses
[ChatListViewModel] --> [LiveData] : uses
[ChatListViewModel] --> [Flow] : uses
[MsgListViewModel] --> [LiveData] : uses
[MsgListViewModel] --> [Flow] : uses

note right of [Repository]
  Repository Pattern
  - Abstracts data sources
  - Manages API calls
  - Handles local storage
  - Returns Result types
end note

note right of [AppDatabase]
  Singleton Pattern
  - Single instance
  - Thread-safe access
  - SQLite backend via Room
end note

note left of [ChatViewModel]
  MVVM Pattern
  - Survives config changes
  - Manages UI state
  - Handles user interactions
end note

note bottom of [OpenAI ChatGPT API]
  External Service
  - Requires API key
  - Configurable temperature
  - Supports conversations
end note

@enduml
