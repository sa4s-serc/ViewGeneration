@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<python>> LightGreen
    BackgroundColor<<utility>> LightYellow
    BackgroundColor<<external>> LightGray
}

package "GNU Radio Framework" <<external>> {
    component [GNU Radio Core] as GNURadio
    component [GNU Radio Companion (GRC)] as GRC
}

package "gr-corrsounder Module" {

    package "C++ Signal Processing Layer" <<core>> {
        component [FZC Source Block\n(corrsounder_fzc_source_c)] as FZCSource
        component [FZC Correlator Block\n(corrsounder_fzc_correlator_c)] as FZCCorrelator
        component [Sequence Gate Block\n(sequence_gate_cc)] as SeqGate
        component [Correlation Block] as Correlator
        component [Error Correction Block] as ErrorCorrection
        component [Moving Average Block] as MovingAvg
        component [Ramdisk File Sink Block] as RamdiskSink
        component [IR SNR Block] as IRSNR
        component [MLS Generator] as MLSGen
    }

    package "Python Wrapper Layer" <<python>> {
        component [SWIG Bindings\n(corrsounder_swig)] as SWIG
        component [Python Block Wrappers] as PyWrappers
    }

    package "Standalone Python Package" <<utility>> {
        component [pycorrsounder\nAlgorithms] as PyCorr {
            component [FZC Sequence Gen] as PyFZC
            component [Cross-Correlation] as PyCrossCorr
        }
    }

    package "GRC Integration Layer" <<python>> {
        component [GRC Block Definitions\n(XML)] as GRCBlocks
    }

    package "Documentation Layer" <<utility>> {
        component [Doxygen XML Parser\n(doxyxml)] as DoxyParser
    }

    package "Testing Layer" <<utility>> {
        component [C++ Unit Tests\n(qa_corrsounder)] as CppTests
        component [Python Unit Tests\n(qa_*.py)] as PyTests
    }

    package "Applications Layer" <<python>> {
        component [Python Applications] as Apps
        component [Example Flowgraphs] as Examples
    }

    package "Build System" <<utility>> {
        component [CMake Configuration] as CMake
    }
}

package "External Dependencies" <<external>> {
    component [Boost Libraries] as Boost
    component [SWIG Tool] as SWIGTool
    component [Doxygen] as Doxygen
}

' Core C++ block relationships
FZCSource ..> PyCorr : uses
MLSGen ..> PyCorr : uses
SeqGate --> FZCSource : triggers
FZCCorrelator --> FZCSource : correlates with
Correlator --> SeqGate : processes
IRSNR --> FZCCorrelator : analyzes
RamdiskSink --> IRSNR : stores results
ErrorCorrection --> Correlator : corrects
MovingAvg --> ErrorCorrection : filters

' SWIG binding relationships
SWIG --> FZCSource : wraps
SWIG --> FZCCorrelator : wraps
SWIG --> SeqGate : wraps
SWIG --> Correlator : wraps
SWIG --> ErrorCorrection : wraps
SWIG --> MovingAvg : wraps
SWIG --> RamdiskSink : wraps
SWIG --> IRSNR : wraps
SWIG --> MLSGen : wraps

' Python wrapper relationships
PyWrappers --> SWIG : uses
PyWrappers ..> GNURadio : integrates with

' GRC integration
GRCBlocks --> PyWrappers : exposes
GRC --> GRCBlocks : loads

' Application layer
Apps --> PyWrappers : uses
Apps --> PyCorr : uses
Examples --> GRCBlocks : demonstrates

' Testing relationships
CppTests --> FZCSource : tests
CppTests --> FZCCorrelator : tests
CppTests --> SeqGate : tests
PyTests --> PyWrappers : tests
PyTests --> PyCorr : tests

' Documentation
DoxyParser --> Doxygen : parses
Doxygen ..> FZCSource : documents
Doxygen ..> FZCCorrelator : documents
Doxygen ..> SeqGate : documents

' External dependencies
FZCSource ..> Boost : depends on
FZCCorrelator ..> Boost : depends on
SeqGate ..> Boost : depends on
SWIG ..> SWIGTool : generated by
CMake --> SWIGTool : invokes
CMake --> Doxygen : invokes

' GNU Radio integration
PyWrappers --> GNURadio : extends
GRC --> GNURadio : part of

' Tagged stream mechanism
SeqGate ..[#red]> GNURadio : uses tagged\nstream mechanism

note right of PyCorr
    Standalone package
    Can be used independently
    of GNU Radio framework
end note

note bottom of SWIG
    Factory Pattern:
    static sptr make()

    Adapter Pattern:
    C++ to Python wrapper
end note

note top of SeqGate
    Handles overflow detection
    using GNU Radio's
    tagged stream mechanism
end note

note left of CMake
    Build System Controls:
    - Dependency resolution
    - Compilation flags
    - Installation targets
    - Uninstall targets
end note

@enduml
