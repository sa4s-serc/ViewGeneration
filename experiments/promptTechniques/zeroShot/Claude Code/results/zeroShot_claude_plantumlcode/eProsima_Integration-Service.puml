@startuml
title eProsima Integration Service - Control Flow Sequence Diagram

actor User
participant "Integration Service\nCore" as Core
participant "Configuration\nParser" as ConfigParser
participant "System Handle\nFactory" as Factory
participant "System Handle\n(Fast DDS)" as SH_DDS
participant "System Handle\n(ROS2)" as SH_ROS2
participant "System Handle\n(WebSocket)" as SH_WS
participant "JSON to xtypes\nConverter" as Converter
participant "nlohmann_json\nLibrary" as JSON
participant "Message Router" as Router
participant "Service Router" as ServiceRouter
participant "Middleware\n(Fast DDS)" as MW_DDS
participant "Middleware\n(ROS2)" as MW_ROS2
participant "Middleware\n(WebSocket)" as MW_WS

== Initialization Phase ==
User -> Core: Start Integration Service\nwith config.yaml
activate Core

Core -> ConfigParser: Parse YAML configuration
activate ConfigParser
ConfigParser -> ConfigParser: Read types, systems,\nroutes, topics, services
ConfigParser --> Core: Configuration data
deactivate ConfigParser

Core -> Factory: Create System Handles\nfor each middleware
activate Factory
Factory -> SH_DDS: Create Fast DDS System Handle
activate SH_DDS
SH_DDS -> MW_DDS: Initialize DDS Participant
activate MW_DDS
MW_DDS --> SH_DDS: Participant created
deactivate MW_DDS
SH_DDS --> Factory: Handle ready
deactivate SH_DDS

Factory -> SH_ROS2: Create ROS2 System Handle
activate SH_ROS2
SH_ROS2 -> MW_ROS2: Initialize ROS2 Node
activate MW_ROS2
MW_ROS2 --> SH_ROS2: Node created
deactivate MW_ROS2
SH_ROS2 --> Factory: Handle ready
deactivate SH_ROS2

Factory -> SH_WS: Create WebSocket System Handle
activate SH_WS
SH_WS -> MW_WS: Initialize WebSocket Server
activate MW_WS
MW_WS --> SH_WS: Server ready
deactivate MW_WS
SH_WS --> Factory: Handle ready
deactivate SH_WS

Factory --> Core: All handles created
deactivate Factory

Core -> Router: Setup message routes\n(pub-sub patterns)
activate Router
Router -> SH_DDS: Configure publishers/subscribers
activate SH_DDS
SH_DDS --> Router: Configured
deactivate SH_DDS
Router -> SH_ROS2: Configure publishers/subscribers
activate SH_ROS2
SH_ROS2 --> Router: Configured
deactivate SH_ROS2
Router --> Core: Routes established
deactivate Router

Core -> ServiceRouter: Setup service routes\n(client-server patterns)
activate ServiceRouter
ServiceRouter -> SH_DDS: Configure service clients/servers
activate SH_DDS
SH_DDS --> ServiceRouter: Configured
deactivate SH_DDS
ServiceRouter -> SH_WS: Configure service endpoints
activate SH_WS
SH_WS --> ServiceRouter: Configured
deactivate SH_WS
ServiceRouter --> Core: Service routes ready
deactivate ServiceRouter

Core --> User: Integration Service running
deactivate Core

== Message Routing Phase ==
MW_DDS -> SH_DDS: Receive message\n(DDS topic)
activate SH_DDS
SH_DDS -> Converter: Convert DDS data\nto xtypes::DynamicData
activate Converter
Converter -> JSON: Serialize to JSON
activate JSON
JSON -> JSON: Perform lexical analysis
JSON -> JSON: Parse tokens
JSON --> Converter: JSON representation
deactivate JSON
Converter --> SH_DDS: xtypes::DynamicData
deactivate Converter

SH_DDS -> Router: Forward message
activate Router
Router -> Router: Determine target\nsystem (ROS2)
Router -> Converter: Convert xtypes::DynamicData\nto target format
activate Converter
Converter -> JSON: Deserialize from JSON
activate JSON
JSON -> JSON: Parse input
JSON -> JSON: Build basic_json object
JSON --> Converter: Parsed data
deactivate JSON
Converter --> Router: Target format data
deactivate Converter

Router -> SH_ROS2: Send message
activate SH_ROS2
SH_ROS2 -> MW_ROS2: Publish to ROS2 topic
activate MW_ROS2
MW_ROS2 --> SH_ROS2: Published
deactivate MW_ROS2
SH_ROS2 --> Router: Message delivered
deactivate SH_ROS2
Router --> SH_DDS: Message routed
deactivate Router
deactivate SH_DDS

== Service Request/Response Phase ==
MW_WS -> SH_WS: Service request\n(AddTwoInts)
activate SH_WS
SH_WS -> Converter: Convert JSON request\nto xtypes::DynamicData
activate Converter
Converter -> JSON: Parse JSON request
activate JSON
JSON -> JSON: Lexer tokenization
JSON -> JSON: Parser builds structure
JSON --> Converter: Parsed request
deactivate JSON
Converter --> SH_WS: xtypes request data
deactivate Converter

SH_WS -> ServiceRouter: Route service request
activate ServiceRouter
ServiceRouter -> ServiceRouter: Identify target\nservice (DDS)
ServiceRouter -> Converter: Convert to DDS format
activate Converter
Converter -> JSON: Serialize parameters
activate JSON
JSON --> Converter: JSON formatted
deactivate JSON
Converter --> ServiceRouter: DDS request format
deactivate Converter

ServiceRouter -> SH_DDS: Forward service call
activate SH_DDS
SH_DDS -> MW_DDS: Invoke DDS service\n(AddTwoInts)
activate MW_DDS
MW_DDS -> MW_DDS: Process request
MW_DDS --> SH_DDS: Service response
deactivate MW_DDS

SH_DDS -> Converter: Convert response\nto xtypes::DynamicData
activate Converter
Converter -> JSON: Parse DDS response
activate JSON
JSON --> Converter: Parsed response
deactivate JSON
Converter --> SH_DDS: xtypes response
deactivate Converter

SH_DDS --> ServiceRouter: Response data
deactivate SH_DDS

ServiceRouter -> Converter: Convert to JSON format
activate Converter
Converter -> JSON: Serialize response
activate JSON
JSON -> JSON: Create JSON object
JSON -> JSON: Serialize to string
JSON --> Converter: JSON response
deactivate JSON
Converter --> ServiceRouter: Formatted response
deactivate Converter

ServiceRouter --> SH_WS: Return response
deactivate ServiceRouter

SH_WS -> MW_WS: Send response
activate MW_WS
MW_WS --> SH_WS: Sent
deactivate MW_WS
deactivate SH_WS

== Shutdown Phase ==
User -> Core: Stop Integration Service
activate Core
Core -> Router: Shutdown routes
activate Router
Router -> SH_DDS: Stop message routing
activate SH_DDS
SH_DDS --> Router: Stopped
deactivate SH_DDS
Router -> SH_ROS2: Stop message routing
activate SH_ROS2
SH_ROS2 --> Router: Stopped
deactivate SH_ROS2
Router --> Core: Routes shut down
deactivate Router

Core -> ServiceRouter: Shutdown services
activate ServiceRouter
ServiceRouter -> SH_DDS: Close service endpoints
activate SH_DDS
SH_DDS --> ServiceRouter: Closed
deactivate SH_DDS
ServiceRouter -> SH_WS: Close service endpoints
activate SH_WS
SH_WS --> ServiceRouter: Closed
deactivate SH_WS
ServiceRouter --> Core: Services shut down
deactivate ServiceRouter

Core -> SH_DDS: Cleanup resources
activate SH_DDS
SH_DDS -> MW_DDS: Destroy participant
activate MW_DDS
MW_DDS --> SH_DDS: Destroyed
deactivate MW_DDS
SH_DDS --> Core: Cleaned
deactivate SH_DDS

Core -> SH_ROS2: Cleanup resources
activate SH_ROS2
SH_ROS2 -> MW_ROS2: Shutdown node
activate MW_ROS2
MW_ROS2 --> SH_ROS2: Shut down
deactivate MW_ROS2
SH_ROS2 --> Core: Cleaned
deactivate SH_ROS2

Core -> SH_WS: Cleanup resources
activate SH_WS
SH_WS -> MW_WS: Close server
activate MW_WS
MW_WS --> SH_WS: Closed
deactivate MW_WS
SH_WS --> Core: Cleaned
deactivate SH_WS

Core --> User: Integration Service stopped
deactivate Core

@enduml
