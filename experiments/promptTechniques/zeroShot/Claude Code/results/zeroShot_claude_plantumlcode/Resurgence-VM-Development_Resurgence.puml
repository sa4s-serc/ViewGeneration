@startuml

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<bytecode>> LightGreen
    BackgroundColor<<ffi>> LightYellow
    BackgroundColor<<internal>> LightGray
    BackgroundColor<<external>> LightCoral
    BackgroundColor<<error>> LightPink
}

package "Resurgence VM" {

    package "Core VM Components" <<core>> {
        [Interpreter] as interpreter
        [Execution Engine] as exec_engine
        [Memory Manager] as memory
        [Stack Frames] as stack_frames
        [Registers] as registers
        [Constant Pool] as const_pool
        [Instruction Processor] as inst_processor
    }

    package "Bytecode Handling" <<bytecode>> {
        [Code Reader] as code_reader
        [Code Writer] as code_writer
        [CodeHolder] as code_holder
        [Code Generator] as codegen
    }

    package "FFI Layer" <<ffi>> {
        [FFI Interpreter] as ffi_interpreter
        [resurgence.h C Header] as c_header
        [Native Function Registry] as native_registry
    }

    package "Instruction Set" <<core>> {
        [Instruction Enum] as instruction_enum
        [Arithmetic Ops] as arith_ops
        [Memory Ops] as mem_ops
        [Control Flow Ops] as control_ops
        [Comparison Ops] as comp_ops
    }

    package "Error Handling" <<error>> {
        [ResurgenceError] as error_handler
        [ResurgenceContext] as context
        [Error Macros] as error_macros
    }

    package "External Function Interface" <<external>> {
        [ResurgenceState] as res_state
        [Import Manager] as import_manager
    }

    package "Internal Implementation" <<internal>> {
        [ExecutionEngine Trait] as exec_trait
        [Interpreter Execution Engine Impl] as interpreter_exec_impl
        [Instruction Modules] as inst_modules
    }
}

package "External Code" {
    [C/C++ Application] as cpp_app
    [Rust Application] as rust_app
    [External Native Functions] as ext_functions
}

package "Build System" {
    [Cargo.toml] as cargo
    [cdylib Dynamic Library] as cdylib
    [lib Rust Library] as rust_lib
}

' Core VM relationships
interpreter --> exec_engine : uses
interpreter --> memory : manages
memory --> stack_frames : contains
memory --> registers : contains
memory --> const_pool : contains
exec_engine --> inst_processor : executes
inst_processor --> instruction_enum : processes
instruction_enum --> arith_ops : includes
instruction_enum --> mem_ops : includes
instruction_enum --> control_ops : includes
instruction_enum --> comp_ops : includes
registers --> const_pool : references
stack_frames --> registers : contains
inst_processor --> memory : operates on

' Bytecode relationships
code_reader --> code_holder : reads into
code_writer --> code_holder : writes from
interpreter --> code_holder : loads
codegen --> code_holder : generates

' FFI relationships
ffi_interpreter --> interpreter : wraps
c_header --> ffi_interpreter : exposes
native_registry --> import_manager : registers
ffi_interpreter --> res_state : provides

' External function interface
res_state --> memory : accesses
res_state --> stack_frames : reads/writes
import_manager --> interpreter : integrates with
import_manager --> ext_functions : resolves
interpreter --> import_manager : uses

' Internal implementation
exec_trait ..> interpreter_exec_impl : <<implements>>
interpreter_exec_impl --> exec_engine : realizes
inst_modules --> inst_processor : implements

' Error handling
interpreter --> error_handler : throws
exec_engine --> error_handler : throws
error_handler --> context : contains
error_macros --> error_handler : creates

' External application integration
cpp_app --> c_header : includes
cpp_app --> cdylib : links
rust_app --> rust_lib : uses
cpp_app --> ext_functions : provides
rust_app --> ext_functions : provides
ext_functions --> res_state : receives

' Build system
cargo --> cdylib : produces
cargo --> rust_lib : produces
cdylib --> cpp_app : distributes to
rust_lib --> rust_app : distributes to

note right of interpreter
Register-based VM
Embeddable design
Stack-based argument passing
end note

note right of exec_trait
Trait-based design pattern
Defines contract for
instruction execution
end note

note right of res_state
Passed to external functions
Provides VM interaction
Stack and memory access
end note

note bottom of cargo
Dual output for flexibility:
cdylib for C/C++ embedding
lib for Rust embedding
end note

@enduml
