@startuml
title TALOS Robot Locomotion Control Flow

actor User
participant "ROS Controller" as ROS
participant "Safety Layer" as Safety
participant "State Estimator" as StateEst
participant "DCM Controller" as DCM
participant "WBC Plugin Loader" as PluginLoader
participant "WBC Implementation" as WBC
participant "Task Manager" as TaskMgr
participant "TALOS Robot" as Robot
participant "Simulator (Gazebo/PAL)" as Sim

User -> ROS: Start Locomotion Controller
activate ROS

ROS -> ROS: Load Configuration (YAML)
ROS -> PluginLoader: Initialize WBC Plugin
activate PluginLoader

PluginLoader -> PluginLoader: Read biped_wbc.xml
PluginLoader -> WBC: Load WBC Implementation\n(e.g., WbcWeightedDynamicCopTALOS)
activate WBC
PluginLoader --> ROS: WBC Instance Ready
deactivate PluginLoader

ROS -> StateEst: Initialize State Estimators
activate StateEst
StateEst --> ROS: Estimators Ready

ROS -> DCM: Initialize DCM Controller
activate DCM
DCM --> ROS: Controller Ready

ROS -> Safety: Initialize Safety Layer
activate Safety
Safety --> ROS: Safety Layer Active

ROS -> Robot: Initialize Robot Interface
activate Robot
Robot --> ROS: Robot Ready

loop Walking Control Loop

    Robot -> StateEst: Send Joint States & Sensor Data
    StateEst -> StateEst: Estimate Robot Pose & Velocity
    StateEst --> ROS: Current State Estimate

    ROS -> Safety: Check Safety Conditions
    Safety -> Safety: Monitor COM Position
    Safety -> Safety: Check Foot Contact
    Safety -> Safety: Verify Joint Limits

    alt Safety Violation Detected
        Safety --> ROS: Stop Command
        ROS -> Robot: Emergency Stop
    else Safe to Continue
        Safety --> ROS: Safe to Proceed

        ROS -> DCM: Request Walking Pattern
        DCM -> DCM: Generate Reference Trajectory\n(Desired Capture Point)
        DCM --> ROS: Reference Trajectory

        ROS -> WBC: Execute Control Cycle\n(State + Reference)
        activate WBC

        WBC -> TaskMgr: Define Tasks\n(Balance, Stepping, Manipulation)
        activate TaskMgr
        TaskMgr --> WBC: Task Priorities & Constraints
        deactivate TaskMgr

        WBC -> WBC: Solve WBC Problem\n(Task Prioritization & Constraints)
        WBC -> WBC: Compute Joint Commands
        WBC --> ROS: Joint Torques/Positions
        deactivate WBC

        ROS -> Robot: Send Joint Commands
        Robot -> Robot: Execute Commands

        alt Simulation Mode
            Robot -> Sim: Apply Commands
            activate Sim
            Sim -> Sim: Simulate Dynamics
            Sim --> Robot: Simulated Response
            deactivate Sim
        else Real Robot Mode
            Robot -> Robot: Actuate Joints
        end

        Robot --> StateEst: Updated Sensor Data
    end

end

User -> ROS: Stop Controller
ROS -> Safety: Deactivate Safety Layer
deactivate Safety
ROS -> DCM: Stop DCM Controller
deactivate DCM
ROS -> WBC: Unload WBC
deactivate WBC
ROS -> StateEst: Stop Estimators
deactivate StateEst
ROS -> Robot: Shutdown Robot Interface
deactivate Robot
deactivate ROS

@enduml
