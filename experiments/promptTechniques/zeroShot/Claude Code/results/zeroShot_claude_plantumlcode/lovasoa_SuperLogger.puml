@startuml
!define COMPONENT_COLOR #ADD8E6
!define INTERFACE_COLOR #90EE90

skinparam component {
    BackgroundColor COMPONENT_COLOR
    BorderColor #000000
}

skinparam interface {
    BackgroundColor INTERFACE_COLOR
    BorderColor #000000
}

title SuperLogger System - Component Diagram (Connectivity Focus)

package "Agent (Java)" {
    component [SystemInfo] as SystemInfo
    component [TCPServer] as TCPServer

    SystemInfo -down-> TCPServer : produces data
}

package "ELK Stack" {
    component [Logstash] as Logstash {
        portin " " as LogstashTCP
    }

    component [Elasticsearch] as Elasticsearch {
        portin " " as ElasticsearchAPI
    }

    component [Kibana] as Kibana
}

interface "TCP\n(Port 5000)" as TCPInterface
interface "HTTP/REST\n(Port 9200)" as ElasticsearchInterface
interface "HTTP\n(Port 5601)" as KibanaInterface

TCPServer -right-( TCPInterface : sends system\ninfo (JSON)
TCPInterface -right- LogstashTCP

Logstash -down-( ElasticsearchInterface : forwards enriched\ndata (JSON)
ElasticsearchInterface -down- ElasticsearchAPI

Kibana -left-> Elasticsearch : queries data\n(HTTP/REST)

note right of TCPServer
  Collects:
  - CPU load
  - Memory usage
  - Computer name
  - IP address
end note

note right of Logstash
  tcp2elastic.conf
  - Input: TCP
  - Codec: JSON
  - Output: Elasticsearch
end note

note bottom of Elasticsearch
  Stores and indexes
  system metrics
end note

note bottom of Kibana
  Visualizes data via
  dashboards
end note

@enduml
