@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<container>> LightBlue
    BackgroundColor<<external>> LightGray
    BorderColor Black
}

skinparam node {
    BackgroundColor LightYellow
    BorderColor Black
}

title AadApiGatekeeper - Deployment Architecture (Sidecar Pattern)

cloud "Azure Active Directory" as AAD {
    component "Authentication Service" as AuthService
    component "Token Service" as TokenService
}

node "Kubernetes Cluster / Service Fabric Mesh" {
    package "Pod / Application Instance" {
        node "Gatekeeper Container" <<container>> {
            component "AuthProxyMiddleware" as Middleware
            component "LoginController" as LoginCtrl
            component "MeController" as MeCtrl
            component "AuthBackChannelHandler" as BackChannel
            component "InMemoryTokenCache" as TokenCache
            component "OpenID Connect Auth" as OIDC
            component "JWT Bearer Auth" as JWT

            interface "HTTP :80" as GatewayHTTP
            interface "HTTPS :443" as GatewayHTTPS
        }

        node "Backend API Container" <<container>> {
            component "MyApi Application" as BackendAPI
            component "EchoController" as EchoCtrl

            interface "HTTP :8080" as BackendHTTP
        }
    }
}

actor "Client / User" as Client
actor "Browser" as Browser

' External connections
Client --> GatewayHTTP : HTTP Request
Browser --> GatewayHTTPS : HTTPS Request

' Internal container connections
GatewayHTTP -down-> Middleware : Process Request
GatewayHTTPS -down-> Middleware : Process Request
Middleware --> LoginCtrl : /login
Middleware --> MeCtrl : /me
Middleware --> BackChannel : Forward Authenticated Request

BackChannel --> BackendHTTP : Proxied Request with Token
BackendHTTP --> BackendAPI
BackendAPI --> EchoCtrl

' AAD Integration
LoginCtrl ..> OIDC : Initiate Auth Flow
OIDC ..> AuthService : Authenticate User
MeCtrl ..> TokenCache : Get Cached Token
MeCtrl ..> TokenService : Acquire Token (OBO Flow)
JWT ..> TokenService : Validate Token
TokenCache ..> TokenService : Cache AAD Tokens

' Configuration
component "Environment Variables" as EnvVars <<external>> {
    note right
        - AAD_CLIENT_ID
        - AAD_CLIENT_SECRET
        - AAD_TENANT
        - PROXY_PORT
        - PROXY_FORWARD_PORT
        - ANONYMOUS_PATHS
        - REDIRECT_URI
    end note
}

EnvVars .down.> Middleware : Configure
EnvVars .down.> OIDC : Configure
EnvVars .down.> JWT : Configure

' Deployment artifacts
node "Container Registry" <<external>> {
    artifact "Gatekeeper Image" as GKImage
    artifact "Backend API Image" as APIImage
}

GKImage .up.> "Gatekeeper Container" : deploys
APIImage .up.> "Backend API Container" : deploys

node "Deployment Configuration" <<external>> {
    artifact "deployment.yaml" as K8sDeployment
    artifact "Dockerfile (Multi-stage)" as Dockerfile
}

K8sDeployment .up.> "Pod / Application Instance" : orchestrates
Dockerfile .up.> GKImage : builds

legend right
    **Sidecar Pattern Deployment**

    The Gatekeeper runs as a sidecar container
    alongside the Backend API, intercepting and
    securing all incoming traffic.

    **Key Deployment Aspects:**
    - Containers deployed in same Pod/Instance
    - Gatekeeper exposes public endpoints
    - Backend API only accessible via Gatekeeper
    - AAD integration for authentication
    - Environment-based configuration
endlegend

@enduml
