@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<frontend>> LightBlue
    BackgroundColor<<backend>> LightGreen
    BackgroundColor<<ml>> LightYellow
    BackgroundColor<<storage>> LightCoral
    BackgroundColor<<cache>> LightPink
    BackgroundColor<<database>> LightGray
}

package "Deep Deblurring System" {

    component "Vue.js Frontend" as frontend <<frontend>> {
        portin ui_interaction
        portout api_requests
    }

    component "Flask Backend\n(API Gateway)" as backend <<backend>> {
        portin http_api
        portout model_inference_requests
        portout storage_requests
        portout cache_requests
        portout db_requests
    }

    component "TensorFlow Serving" as serving <<ml>> {
        portin inference_api
        portout model_access
    }

    component "Model Repository\n(DeblurGAN-V2)" as model <<ml>> {
        portin model_request
    }

    component "Cloudinary\n(Static Assets)" as cloudinary <<storage>> {
        portin asset_api
    }

    component "Redis\n(Cache & Session)" as redis <<cache>> {
        portin cache_api
    }

    component "PostgreSQL\n(Database)" as postgres <<database>> {
        portin db_api
    }
}

cloud "Heroku\n(Free Tier)" as heroku {
}

cloud "Google Colab\n(Model Training)" as colab {
}

actor User

User --> ui_interaction : Upload\nBlurred Image
frontend --> http_api : API Calls
backend --> inference_api : Deblur\nRequest
serving --> model_request : Load Model
backend --> asset_api : Store/Retrieve\nAssets
backend --> cache_api : Cache\nOperations
backend --> db_api : Data\nPersistence
backend ..> User : Deblurred\nImage Response

frontend .up.> heroku : deployed on
backend .up.> heroku : deployed on
serving .up.> heroku : deployed on
model ..> colab : trained on

backend ..> model : Collect Data\nfor Retraining

note right of backend
  Acts as API Gateway
  Orchestrates communication
  Handles data collection
end note

note right of serving
  Exposes trained
  DeblurGAN-V2 model
  for inference
end note

note bottom of cloudinary
  Used due to Heroku
  free tier limitations
  for static storage
end note

note bottom of model
  DeblurGAN-V2 Model
  Training scripts included
end note

@enduml
