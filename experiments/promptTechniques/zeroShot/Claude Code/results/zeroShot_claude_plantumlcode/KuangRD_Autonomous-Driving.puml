@startuml
!define COMPONENT_COLOR #ADD8E6
!define LIBRARY_COLOR #90EE90
!define INTERFACE_COLOR #FFB6C1

skinparam component {
  BackgroundColor COMPONENT_COLOR
  BorderColor #000000
}

skinparam interface {
  BackgroundColor INTERFACE_COLOR
  BorderColor #000000
}

package "Core Libraries" {
  [Eigen Library] <<library>> #90EE90
  [nlohmann::json] <<library>> #90EE90
  [uWS] <<library>> #90EE90
  [TensorFlow/Keras] <<library>> #90EE90
  [BLAS/LAPACK] <<library>> #90EE90
}

package "ROS Framework" {
  interface "Publisher/Subscriber" as PubSub
  [ROS Core] <<framework>>
}

package "Autonomous Driving Subsystem" {
  component "Waypoint Loader" {
    [Waypoint Loader Node]
  }

  component "Waypoint Updater" {
    [Waypoint Updater Node]
    [Path Planning Logic]
  }

  component "Traffic Light Detection" {
    [Traffic Light Detector Node]
    [CNN Classifier]
    [Image Processor]
  }

  component "DBW Controller" {
    [DBW Node]
    [PID Controller]
    [Steering Control]
    [Throttle Control]
    [Brake Control]
  }

  component "Communication Layer" {
    [JSON Message Handler]
    [WebSocket Manager]
  }
}

package "External Systems" {
  [Simulator/Vehicle] <<external>>
}

package "Data Processing Layer" {
  [Linear Algebra Engine]
  [Matrix Operations]
  [Sparse Solvers]
  [Geometric Transformations]
}

package "Deep Learning Pipeline" {
  [Model Loader]
  [HDF5 Parser]
  [CUDA Accelerator]
}

' Control Flow - Main Pipeline
[Simulator/Vehicle] --> [WebSocket Manager] : sensor data
[WebSocket Manager] --> [JSON Message Handler] : raw messages
[JSON Message Handler] --> [Waypoint Loader Node] : initialize waypoints
[JSON Message Handler] --> [Traffic Light Detector Node] : camera images
[JSON Message Handler] --> [DBW Node] : vehicle state

' Traffic Light Detection Control Flow
[Traffic Light Detector Node] --> [Image Processor] : image data
[Image Processor] --> [CNN Classifier] : preprocessed image
[CNN Classifier] --> [Traffic Light Detector Node] : classification result
[Traffic Light Detector Node] --> PubSub : traffic light state

' Waypoint Management Control Flow
[Waypoint Loader Node] --> PubSub : base waypoints
[Waypoint Updater Node] --> [Path Planning Logic] : current position
PubSub --> [Waypoint Updater Node] : traffic light state
PubSub --> [Waypoint Updater Node] : base waypoints
[Path Planning Logic] --> [Waypoint Updater Node] : updated path
[Waypoint Updater Node] --> PubSub : final waypoints

' DBW Control Flow
PubSub --> [DBW Node] : final waypoints
[DBW Node] --> [PID Controller] : trajectory error
[PID Controller] --> [Steering Control] : steering command
[PID Controller] --> [Throttle Control] : throttle command
[PID Controller] --> [Brake Control] : brake command
[Steering Control] --> [DBW Node] : control output
[Throttle Control] --> [DBW Node] : control output
[Brake Control] --> [DBW Node] : control output

' Output Control Flow
[DBW Node] --> [JSON Message Handler] : vehicle commands
[JSON Message Handler] --> [WebSocket Manager] : formatted commands
[WebSocket Manager] --> [Simulator/Vehicle] : actuator commands

' Library Dependencies for Control Flow
[CNN Classifier] ..> [TensorFlow/Keras] : uses
[CNN Classifier] ..> [CUDA Accelerator] : accelerates
[CUDA Accelerator] ..> [Model Loader] : loads model
[Model Loader] ..> [HDF5 Parser] : parses weights

[PID Controller] ..> [Linear Algebra Engine] : uses
[Path Planning Logic] ..> [Geometric Transformations] : uses
[Geometric Transformations] ..> [Linear Algebra Engine] : uses
[Linear Algebra Engine] ..> [Matrix Operations] : uses
[Matrix Operations] ..> [Eigen Library] : uses
[Linear Algebra Engine] ..> [BLAS/LAPACK] : optimizes

[Image Processor] ..> [Matrix Operations] : uses
[Sparse Solvers] ..> [Eigen Library] : uses

[WebSocket Manager] ..> [uWS] : uses
[JSON Message Handler] ..> [nlohmann::json] : uses

[Waypoint Loader Node] ..> [ROS Core] : node
[Waypoint Updater Node] ..> [ROS Core] : node
[Traffic Light Detector Node] ..> [ROS Core] : node
[DBW Node] ..> [ROS Core] : node

PubSub --> [ROS Core] : messaging

note right of [DBW Controller]
  Control Loop:
  1. Receive waypoints
  2. Calculate error
  3. PID computation
  4. Generate commands
end note

note right of [Traffic Light Detection]
  Detection Pipeline:
  1. Receive image
  2. Preprocess
  3. CNN inference
  4. Publish state
end note

note right of [Waypoint Updater]
  Path Planning:
  1. Get base waypoints
  2. Check traffic lights
  3. Adjust trajectory
  4. Publish updates
end note

@enduml
