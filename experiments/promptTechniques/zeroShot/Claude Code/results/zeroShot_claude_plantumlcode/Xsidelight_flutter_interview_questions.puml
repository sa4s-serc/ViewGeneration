@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<documentation>> LightBlue
    BackgroundColor<<content>> LightGreen
    BackgroundColor<<framework>> LightYellow
    BackgroundColor<<runtime>> LightCoral
}

package "Flutter Interview Questions Repository" {

    component "README.md" <<documentation>> as readme {
        [Overview]
        [Table of Contents]
        [Navigation Links]
    }

    package "Interview Questions Content" <<content>> {
        component "Software Development & Architecture" as sd_arch {
            [OOP Principles]
            [SOLID Principles]
            [CUPID Principles]
            [Design Patterns]
            [Clean Architecture]
        }

        component "Dart Questions" as dart_q {
            [Dart VM]
            [Data Structures]
            [Async/Await]
            [Streams]
            [Language Features]
        }

        component "Flutter Questions" as flutter_q {
            [Framework Architecture]
            [Widget System]
            [Build Modes]
            [State Management]
            [Testing]
        }
    }

    package "Internal Documentation" {
        component "flutter_internals.md" <<documentation>> as flutter_internals {
            [Flutter Engine]
            [RenderObjects]
            [Bindings Layer]
            [SchedulerBinding]
            [GestureBinding]
            [GestureRecognizer]
            [Element Tree]
            [Widget-Element Interaction]
        }

        component "dart_internals.md" <<documentation>> as dart_internals {
            [Event Loop]
            [Futures]
            [Async/Await Details]
            [Isolates]
            [Concurrency Model]
        }
    }

    package "Design Patterns Reference" <<content>> {
        component "Creational Patterns" as creational {
            [Singleton]
            [Factory]
            [Abstract Factory]
            [Builder]
            [Prototype]
        }

        component "Structural Patterns" as structural {
            [Adapter]
            [Bridge]
            [Decorator]
            [Facade]
        }

        component "Behavioral Patterns" as behavioral {
            [Observer]
        }

        component "Dependency Injection" as di {
            [Injectable Library]
            [GetIt Library]
        }
    }

    package "External Resources" {
        component "Flutter.dev" <<external>> as flutter_dev
        component "Package Documentation" <<external>> as pkg_docs
    }
}

package "Flutter Framework Concepts" <<framework>> {
    component "Framework Layer" as framework_layer {
        [Widgets]
        [Elements]
        [State Management]
        [Ephemeral State]
        [App State]
    }

    component "Engine Layer" as engine_layer {
        [Rendering Pipeline]
        [Native Engine]
        [Skia Graphics]
    }
}

package "Dart Runtime Concepts" <<runtime>> {
    component "Dart VM" as dart_vm {
        [Execution Model]
        [Memory Management]
    }

    component "Concurrency" as concurrency {
        [Event Loop]
        [Isolates]
        [Async Operations]
    }
}

' Main relationships
readme --> sd_arch : "links to"
readme --> dart_q : "links to"
readme --> flutter_q : "links to"
readme --> flutter_internals : "links to"
readme --> dart_internals : "links to"

sd_arch --> creational : "explains"
sd_arch --> structural : "explains"
sd_arch --> behavioral : "explains"
sd_arch --> di : "recommends"

flutter_q --> flutter_internals : "detailed by"
flutter_q --> framework_layer : "covers"
flutter_q --> engine_layer : "covers"

dart_q --> dart_internals : "detailed by"
dart_q --> dart_vm : "covers"
dart_q --> concurrency : "covers"

flutter_internals --> framework_layer : "documents"
flutter_internals --> engine_layer : "documents"

dart_internals --> dart_vm : "documents"
dart_internals --> concurrency : "documents"

' External references
flutter_q --> flutter_dev : "references"
flutter_q --> pkg_docs : "references"
dart_q --> flutter_dev : "references"

di --> pkg_docs : "references"

' Framework architecture relationships
framework_layer --> engine_layer : "renders via"
framework_layer ..> dart_vm : "runs on"
engine_layer ..> dart_vm : "runs on"

@enduml
