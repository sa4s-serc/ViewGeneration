@startuml
title IBM_torc_py - Task Scheduling and Load Balancing Flow

participant "User Application" as App
participant "Master Process\n(Rank 0)" as Master
participant "Task Queue\n(torc_q)" as Queue
participant "Server Thread" as Server
participant "Worker Thread 1" as Worker1
participant "Worker Thread 2" as Worker2
participant "Worker Process\n(Rank 1)" as WorkerP1
participant "Worker Process\n(Rank N)" as WorkerPN

== Initialization ==
App -> Master: start()
activate Master
Master -> Master: init()
Master -> Server: start torc_server_thread()
activate Server
Master -> Worker1: spawn worker thread
activate Worker1
Master -> Worker2: spawn worker thread
activate Worker2
Master -> WorkerP1: MPI init (mpi4py)
activate WorkerP1
Master -> WorkerPN: MPI init (mpi4py)
activate WorkerPN

== Task Submission ==
App -> Master: submit(task_func, args)
Master -> Master: create TaskT future
Master -> Queue: enqueue task (round-robin)
activate Queue
Master --> App: return TaskT

== Task Distribution ==
Master -> Server: MPI send task
Server -> WorkerP1: distribute task (round-robin)
Server -> WorkerPN: distribute task (round-robin)

== Local Task Execution ==
Worker1 -> Queue: dequeue task
Queue --> Worker1: task
deactivate Queue
Worker1 -> Worker1: execute task_func(args)
activate Worker1 #LightBlue
Worker1 -> Worker1: compute result
deactivate Worker1

== Remote Task Execution ==
WorkerP1 -> WorkerP1: receive task via Server Thread
activate WorkerP1 #LightBlue
WorkerP1 -> WorkerP1: enqueue to local torc_q
WorkerP1 -> WorkerP1: worker thread executes task
WorkerP1 -> WorkerP1: compute result
deactivate WorkerP1
WorkerP1 -> Server: MPI send result back
Server -> Master: receive result

== Nested Task Submission ==
Worker1 -> Master: submit(child_task, args)
Master -> Queue: enqueue child task
activate Queue
Master -> Server: MPI send child task
Server -> WorkerPN: distribute child task

== Work Stealing (Load Balancing) ==
WorkerP1 -> WorkerP1: detect idle state
WorkerP1 -> Server: send steal request
Server -> WorkerPN: MPI forward steal request
WorkerPN -> WorkerPN: check task queue
alt Has tasks to steal
    WorkerPN -> Server: MPI send stolen task
    Server -> WorkerP1: forward stolen task
    WorkerP1 -> WorkerP1: execute stolen task
    activate WorkerP1 #LightBlue
    WorkerP1 -> WorkerP1: compute result
    deactivate WorkerP1
else No tasks available
    WorkerPN -> Server: send empty response
    Server -> WorkerP1: no tasks available
end

== Task Completion with Callback ==
Worker2 -> Queue: dequeue task with callback
Queue --> Worker2: task
deactivate Queue
Worker2 -> Worker2: execute task_func(args)
activate Worker2 #LightBlue
Worker2 -> Worker2: compute result
Worker2 -> Worker2: execute callback(result)
deactivate Worker2
Worker2 -> Master: notify completion

== Wait for Children ==
App -> Master: wait()
Master -> Master: check child tasks status
loop Until all children complete
    Master -> Server: check for results
    Server --> Master: task results
    Master -> Master: update TaskT futures
end
Master --> App: all children completed

== Map Operation ==
App -> Master: map(func, args_list)
Master -> Master: submit multiple tasks
loop For each arg in args_list
    Master -> Queue: enqueue task
    activate Queue
    Master -> Server: MPI send task (round-robin)
    Server -> WorkerP1: distribute task
    Server -> WorkerPN: distribute task
end
Master -> Master: wait for all tasks
Master --> App: return results list

== SPMD Mode ==
App -> Master: spmd(func, args)
Master -> WorkerP1: MPI broadcast SPMD command
Master -> WorkerPN: MPI broadcast SPMD command
activate Master #LightGreen
activate WorkerP1 #LightGreen
activate WorkerPN #LightGreen
Master -> Master: execute func(args)
WorkerP1 -> WorkerP1: execute func(args)
WorkerPN -> WorkerPN: execute func(args)
WorkerP1 -> Master: MPI barrier/sync
WorkerPN -> Master: MPI barrier/sync
deactivate Master
deactivate WorkerP1
deactivate WorkerPN
Master --> App: SPMD complete

== Shutdown ==
App -> Master: shutdown()
Master -> Server: stop server thread
deactivate Server
Master -> Worker1: terminate
deactivate Worker1
Master -> Worker2: terminate
deactivate Worker2
Master -> WorkerP1: MPI finalize
deactivate WorkerP1
Master -> WorkerPN: MPI finalize
deactivate WorkerPN
deactivate Master
Master --> App: cleanup complete

@enduml
