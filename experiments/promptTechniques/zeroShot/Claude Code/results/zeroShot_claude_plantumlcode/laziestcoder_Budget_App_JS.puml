@startuml
!theme plain
title Budget App JS - Control Flow Sequence Diagram

actor User
participant "UI (Browser)" as UI
participant controller
participant UIController
participant budgetController

== Application Initialization ==
User -> UI: Load Page
activate UI
UI -> controller: Initialize App
activate controller
controller -> controller: setupEventListeners()
controller --> UI: Ready
deactivate controller
deactivate UI

== Add Income/Expense Item ==
User -> UI: Enter description & value
User -> UI: Click Add Button / Press Enter
activate UI
UI -> controller: Event: Add Item
activate controller
controller -> UIController: getInput()
activate UIController
UIController --> controller: {type, description, value}
deactivate UIController

controller -> controller: Validate Input
alt Valid Input
    controller -> budgetController: addItem(type, description, value)
    activate budgetController
    budgetController -> budgetController: Create new Income/Expense object
    budgetController -> budgetController: Add to data structure
    budgetController --> controller: newItem
    deactivate budgetController

    controller -> UIController: addListItem(newItem, type)
    activate UIController
    UIController -> UIController: Build HTML string
    UIController -> UI: Insert HTML into DOM
    UIController --> controller: Success
    deactivate UIController

    controller -> UIController: clearFields()
    activate UIController
    UIController -> UI: Clear input fields
    UIController --> controller: Success
    deactivate UIController

    controller -> controller: updateBudget()
    activate controller

    controller -> budgetController: calculateBudget()
    activate budgetController
    budgetController -> budgetController: Calculate total income
    budgetController -> budgetController: Calculate total expenses
    budgetController -> budgetController: Calculate budget (income - expenses)
    budgetController -> budgetController: Calculate expense percentage
    budgetController --> controller: Success
    deactivate budgetController

    controller -> budgetController: getBudget()
    activate budgetController
    budgetController --> controller: {budget, totalInc, totalExp, percentage}
    deactivate budgetController

    controller -> UIController: displayBudget(budgetData)
    activate UIController
    UIController -> UI: Update budget display
    UIController -> UI: Update income display
    UIController -> UI: Update expenses display
    UIController -> UI: Update percentage display
    UIController --> controller: Success
    deactivate UIController

    deactivate controller

    controller -> controller: updatePercentages()
    activate controller

    controller -> budgetController: calculatePercentages()
    activate budgetController
    budgetController -> budgetController: Calculate percentage for each expense
    budgetController --> controller: Success
    deactivate budgetController

    controller -> budgetController: getPercentages()
    activate budgetController
    budgetController --> controller: [percentages array]
    deactivate budgetController

    controller -> UIController: displayPercentages(percentages)
    activate UIController
    UIController -> UI: Update individual expense percentages
    UIController --> controller: Success
    deactivate UIController

    deactivate controller

else Invalid Input
    controller -> controller: Do nothing
end

deactivate controller
deactivate UI

== Delete Income/Expense Item ==
User -> UI: Click Delete Button
activate UI
UI -> controller: Event: Delete Item (itemID)
activate controller
controller -> controller: Parse itemID (type, ID)

controller -> budgetController: deleteItem(type, ID)
activate budgetController
budgetController -> budgetController: Find item in data structure
budgetController -> budgetController: Remove item from array
budgetController --> controller: Success
deactivate budgetController

controller -> UIController: deleteListItem(itemID)
activate UIController
UIController -> UI: Remove element from DOM
UIController --> controller: Success
deactivate UIController

controller -> controller: updateBudget()
activate controller

controller -> budgetController: calculateBudget()
activate budgetController
budgetController -> budgetController: Recalculate totals and budget
budgetController --> controller: Success
deactivate budgetController

controller -> budgetController: getBudget()
activate budgetController
budgetController --> controller: {budget, totalInc, totalExp, percentage}
deactivate budgetController

controller -> UIController: displayBudget(budgetData)
activate UIController
UIController -> UI: Update all budget displays
UIController --> controller: Success
deactivate UIController

deactivate controller

controller -> controller: updatePercentages()
activate controller

controller -> budgetController: calculatePercentages()
activate budgetController
budgetController -> budgetController: Recalculate percentages
budgetController --> controller: Success
deactivate budgetController

controller -> budgetController: getPercentages()
activate budgetController
budgetController --> controller: [percentages array]
deactivate budgetController

controller -> UIController: displayPercentages(percentages)
activate UIController
UIController -> UI: Update percentage displays
UIController --> controller: Success
deactivate UIController

deactivate controller

deactivate controller
deactivate UI

@enduml
