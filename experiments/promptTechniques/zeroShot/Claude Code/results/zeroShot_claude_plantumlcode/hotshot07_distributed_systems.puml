@startuml
!define RECTANGLE rectangle
!define COMPONENT component

skinparam componentStyle rectangle
skinparam {
    BackgroundColor white
    ArrowColor black
    BorderColor black
}

cloud "AWS Cloud" {
    database "DynamoDB" as dynamo {
        component [Users Table] as users_table
        component [Athletes Table] as athletes_table
        component [Tests Table] as tests_table
        component [Results Table] as results_table
    }
}

node "Kubernetes Cluster" {

    package "Frontend Layer" {
        node "Frontend Pod(s)" {
            component [React UI] as react_ui
            component [Material UI] as mui
        }
    }

    package "Backend Services Layer" {
        node "Auth Service Pod(s)" {
            component [Flask App\nauth.py] as auth_service
            component [JWT Middleware] as jwt
            component [gunicorn] as auth_gunicorn
        }

        node "Account Service Pod(s)" {
            component [Flask App\napp.py] as account_service
            component [Account Models] as account_models
            component [gunicorn] as account_gunicorn
        }

        node "Availability Service Pod(s)" {
            component [Flask App\napp.py] as availability_service
            component [Availability Models] as availability_models
            component [gunicorn] as avail_gunicorn
        }

        node "Testing Service Pod(s)" {
            component [Flask App\napp.py] as testing_service
            component [Testing Models] as testing_models
            component [gunicorn] as testing_gunicorn
        }
    }

    package "Data Access Layer" {
        component [DynamoDB Handler] as dynamo_handler
    }

    package "Kubernetes Services" {
        component [Frontend Service] as frontend_svc
        component [Auth Service] as auth_svc
        component [Account Service] as account_svc
        component [Availability Service] as avail_svc
        component [Testing Service] as testing_svc
    }

    package "Ingress" {
        component [API Gateway/\nIngress Controller] as ingress
    }
}

node "CI/CD Pipeline" {
    component [GitHub Actions] as github_actions
    component [Docker Build] as docker_build
}

node "Container Registry" {
    database "DockerHub" as dockerhub {
        component [Frontend Image] as frontend_image
        component [Auth Image] as auth_image
        component [Account Image] as account_image
        component [Availability Image] as avail_image
        component [Testing Image] as testing_image
    }
}

' Frontend relationships
react_ui --> mui
react_ui --> ingress : HTTP/HTTPS

' Ingress to services
ingress --> frontend_svc : Route
ingress --> auth_svc : Route /auth
ingress --> account_svc : Route /account
ingress --> avail_svc : Route /availability
ingress --> testing_svc : Route /testing

' Services to pods
frontend_svc --> react_ui
auth_svc --> auth_service
account_svc --> account_service
avail_svc --> availability_service
testing_svc --> testing_service

' Backend services internal structure
auth_gunicorn --> auth_service
auth_service --> jwt
account_gunicorn --> account_service
account_service --> account_models
avail_gunicorn --> availability_service
availability_service --> availability_models
testing_gunicorn --> testing_service
testing_service --> testing_models

' Backend to data access
auth_service --> dynamo_handler
account_service --> dynamo_handler
availability_service --> dynamo_handler
testing_service --> dynamo_handler

' Data access to DynamoDB
dynamo_handler --> users_table : AWS SDK
dynamo_handler --> athletes_table : AWS SDK
dynamo_handler --> tests_table : AWS SDK
dynamo_handler --> results_table : AWS SDK

' Backend auth flow
account_service ..> auth_service : Verify JWT
availability_service ..> auth_service : Verify JWT
testing_service ..> auth_service : Verify JWT

' CI/CD relationships
github_actions --> docker_build : Trigger
docker_build --> dockerhub : Push Images

' Deployment relationships
dockerhub --> frontend_svc : Pull & Deploy
dockerhub --> auth_svc : Pull & Deploy
dockerhub --> account_svc : Pull & Deploy
dockerhub --> avail_svc : Pull & Deploy
dockerhub --> testing_svc : Pull & Deploy

note right of ingress
  Entry point for all
  external traffic
end note

note right of dynamo_handler
  Repository pattern
  implementation for
  data persistence
end note

note bottom of dockerhub
  Container images built
  via GitHub Actions and
  deployed to Kubernetes
end note

note left of "Kubernetes Cluster"
  Deployment scripts:
  - deploy-cluster.sh
  - deploy-local.sh
end note

@enduml
