@startuml ArnBaudzus_FluxSurfer

package "FluxSurfer Library" {
  [QuantumSystem] as QS
  [ODE Solvers] as ODE
  [MonteCarloWanderer] as MCW
  [Experiment] as EXP
  [DataStorage] as DS
  [Utilities] as UTIL

  interface "Solver" as SOLVER
  interface "SingleStepScheme" as SSS

  QS --> DS : saves data
  ODE ..|> SOLVER
  MCW ..|> SOLVER
  ODE --> SSS : uses
  EXP --> SOLVER : uses
  EXP --> QS : manages
  EXP --> DS : coordinates
  UTIL --> DS : parses files
}

package "External Libraries" {
  [Armadillo]
  [pthread]
  [jsoncpp]
}

cloud "Parallel Execution" {
  [WorkSource]
  [ThreadSynchronization]
}

FluxSurfer Library --> External Libraries : uses
EXP --> Parallel Execution : manages

@enduml