@startuml
participant "Main (tap.py)" as Main
participant "ConfigVPC" as ConfigVPC
participant "EC2ApiClient" as EC2ApiClient
participant "SpileTapper" as SpileTapper
participant "Spile" as Spile
participant "NlbFactory" as NlbFactory
participant "NlbTargetFactory" as NlbTargetFactory

Main -> ConfigVPC: Configure VPCs
ConfigVPC -> EC2ApiClient: Get VPC information
EC2ApiClient --> ConfigVPC: Return VPC data
ConfigVPC --> Main: Return VPC configuration

loop For each configured VPC
    Main -> SpileTapper: Discover eligible instances
    SpileTapper -> EC2ApiClient: List instances in VPC
    EC2ApiClient --> SpileTapper: Return instance list
    SpileTapper -> SpileTapper: Filter Nitro-based instances
    
    alt Auto enrollment mode
        SpileTapper -> Spile: Create/update sessions for all instances
    else Whitelist enrollment mode
        SpileTapper -> EC2ApiClient: Get whitelisted instances
        EC2ApiClient --> SpileTapper: Return whitelisted instances
        SpileTapper -> Spile: Create/update sessions for whitelisted instances
    end
    
    Spile -> EC2ApiClient: Check existing mirroring sessions
    EC2ApiClient --> Spile: Return session data
    
    alt Session needs creation
        Spile -> NlbTargetFactory: Create mirror target
        NlbTargetFactory -> NlbFactory: Create NLB if needed
        NlbFactory --> NlbTargetFactory: Return NLB
        NlbTargetFactory --> Spile: Return mirror target
        Spile -> EC2ApiClient: Create mirroring session
    else Session needs update
        Spile -> EC2ApiClient: Update mirroring session
    else Session needs removal
        Spile -> EC2ApiClient: Remove mirroring session
    end
    
    Spile --> SpileTapper: Return session status
    SpileTapper --> Main: Return VPC mirroring status
end

Main -> EC2ApiClient: Update VPC and instance tags
EC2ApiClient --> Main: Confirm tag updates
@enduml