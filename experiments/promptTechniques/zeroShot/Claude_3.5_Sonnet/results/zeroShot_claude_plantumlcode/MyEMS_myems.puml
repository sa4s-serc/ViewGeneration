@startuml

!define RECTANGLE class

skinparam component {
  BackgroundColor<<API>> LightBlue
  BackgroundColor<<Service>> LightGreen
  BackgroundColor<<Database>> LightYellow
  BackgroundColor<<Frontend>> LightPink
}

component "MyEMS API" <<API>> as API
component "Data Acquisition Service" <<Service>> as DataAcquisition
component "Data Cleaning Service" <<Service>> as DataCleaning
component "Data Normalization Service" <<Service>> as DataNormalization
component "Data Aggregation Service" <<Service>> as DataAggregation
component "Reporting Service" <<Service>> as Reporting
component "Fault Detection Service" <<Service>> as FaultDetection
component "Billing Service" <<Service>> as Billing
component "User Management Service" <<Service>> as UserManagement
component "System Database" <<Database>> as SystemDB
component "Energy Database" <<Database>> as EnergyDB
component "Billing Database" <<Database>> as BillingDB
component "Historical Database" <<Database>> as HistoricalDB
component "Carbon Database" <<Database>> as CarbonDB
component "Admin UI" <<Frontend>> as AdminUI
component "User UI" <<Frontend>> as UserUI

API --> DataAcquisition
API --> DataCleaning
API --> DataNormalization
API --> DataAggregation
API --> Reporting
API --> FaultDetection
API --> Billing
API --> UserManagement

DataAcquisition --> SystemDB
DataCleaning --> EnergyDB
DataNormalization --> EnergyDB
DataAggregation --> EnergyDB
Reporting --> EnergyDB
Reporting --> HistoricalDB
Reporting --> CarbonDB
FaultDetection --> EnergyDB
Billing --> BillingDB
UserManagement --> SystemDB

AdminUI --> API
UserUI --> API

@enduml