@startuml redbadger_crux

skinparam component {
  BackgroundColor<<Core>> LightBlue
  BackgroundColor<<Shell>> LightGreen
  BackgroundColor<<Utility>> LightYellow
}

component "Crux Core" <<Core>> {
  [App]
  [Core]
  [Bridge]
  [Effect]
  [Capability]
  [Command]
}

component "Shell (iOS)" <<Shell>>
component "Shell (Android)" <<Shell>>
component "Shell (Web)" <<Shell>>

component "crux_http" <<Utility>> {
  [Http]
  [RequestBuilder]
}

component "crux_time" <<Utility>> {
  [Time]
  [TimeRequest]
}

[App] --> [Core] : defines
[Core] --> [Effect] : requests
[Core] --> [Capability] : uses
[Capability] --> [Command] : builds
[Bridge] --> [Core] : manages
[Bridge] <--> [Shell (iOS)] : communicates
[Bridge] <--> [Shell (Android)] : communicates
[Bridge] <--> [Shell (Web)] : communicates

[Shell (iOS)] --> [Http] : executes
[Shell (Android)] --> [Http] : executes
[Shell (Web)] --> [Http] : executes

[Shell (iOS)] --> [Time] : provides
[Shell (Android)] --> [Time] : provides
[Shell (Web)] --> [Time] : provides

[Http] --> [RequestBuilder] : uses
[Time] --> [TimeRequest] : uses

@enduml