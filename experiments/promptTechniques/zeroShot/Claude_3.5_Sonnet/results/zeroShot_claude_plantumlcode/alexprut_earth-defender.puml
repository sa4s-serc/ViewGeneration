@startuml alexprut_earth-defender

!define RECTANGLE class

skinparam component {
    BackgroundColor<<Client>> LightBlue
    BackgroundColor<<Server>> LightGreen
}

component "Client" <<Client>> {
    [Game]
    [GameClient]
    [GameDOMHandler]
    [GameElements]
    [TextureLoader]
}

component "Server" <<Server>> {
    [WebSocket Handler]
    [Player Manager]
    [Room Manager]
    [Slave Handler]
    [Monitor Mesh]
}

cloud "WebSocket" {
    [WebSocket Protocol]
}

[Game] --> [GameClient] : uses
[Game] --> [GameDOMHandler] : uses
[Game] --> [GameElements] : uses
[GameElements] --> [TextureLoader] : uses

[GameClient] --> [WebSocket Protocol] : connects via
[WebSocket Handler] --> [WebSocket Protocol] : handles

[WebSocket Handler] --> [Player Manager] : manages
[WebSocket Handler] --> [Room Manager] : manages
[Slave Handler] <--> [Monitor Mesh] : monitors
[Room Manager] --> [Slave Handler] : replicates state

@enduml