@startuml NatalieLouise91_T3A2-Skemi-FrontEnd

[App] as app
[StateContext] as stateContext
[StateReducer] as stateReducer
[Navigation] as nav
[EventManagement] as eventMgmt
[RosterManagement] as rosterMgmt
[UserAuthentication] as auth
[UserProfiles] as profiles
[APIClient] as apiClient
[Services] as services

cloud "Backend API" as backend

app --> stateContext : uses
app --> stateReducer : uses
app --> nav : includes
app --> eventMgmt : includes
app --> rosterMgmt : includes
app --> auth : includes
app --> profiles : includes

stateContext --> stateReducer : uses

nav --> auth : uses
eventMgmt --> services : uses
rosterMgmt --> services : uses
auth --> services : uses
profiles --> services : uses

services --> apiClient : uses
apiClient --> backend : communicates with

@enduml