@startuml meshery_meshery

!define RECTANGLE class

skinparam component {
    BackgroundColor<<UI>> LightBlue
    BackgroundColor<<Server>> LightGreen
    BackgroundColor<<CLI>> Yellow
    BackgroundColor<<Operator>> Orange
    BackgroundColor<<Adapter>> Pink
}

cloud "Kubernetes Cluster" {
    [Meshery Operator] <<Operator>> as operator
    [MeshSync] as meshsync
    [NATS Broker] as broker
}

node "Host Machine" {
    [Meshery Server] <<Server>> as server
    [Meshery UI] <<UI>> as ui
    [mesheryctl] <<CLI>> as cli
}

database "Database" as db

[Service Mesh Adapter 1] <<Adapter>> as adapter1
[Service Mesh Adapter 2] <<Adapter>> as adapter2
[Service Mesh Adapter N] <<Adapter>> as adapterN

[Remote Provider] as remoteprovider

server -- db : Persists data
server -- ui : Serves
cli -- server : Manages
operator -- meshsync : Manages
operator -- broker : Manages
server -- adapter1 : Communicates via gRPC
server -- adapter2 : Communicates via gRPC
server -- adapterN : Communicates via gRPC
server -- remoteprovider : Integrates with
server -- broker : Publishes/Subscribes

@enduml