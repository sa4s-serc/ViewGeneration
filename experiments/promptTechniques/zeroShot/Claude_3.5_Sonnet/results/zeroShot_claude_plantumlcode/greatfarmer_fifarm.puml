```plantuml
@startuml greatfarmer_fifarm

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Application>> LightBlue
  BackgroundColor<<Database>> LightGreen
  BackgroundColor<<ExternalAPI>> LightYellow
}

rectangle "FIFArm Application" <<Application>> {
  [Web Server] as WebServer
  [Spring Boot Application] as SpringBoot
  [MongoDB Driver] as MongoDriver
  [HTTP Client] as HttpClient
}

database "MongoDB" <<Database>> {
  [Player Data] as PlayerData
}

cloud "EA Sports FUT API" <<ExternalAPI>> as FUTAPI

WebServer - SpringBoot
SpringBoot - MongoDriver
SpringBoot - HttpClient
MongoDriver -- PlayerData
HttpClient -- FUTAPI

@enduml
```