```plantuml
@startuml heli-os_member-invitation-java-springboot

!define RECTANGLE class

package "Interface Layer" {
    RECTANGLE "REST Controllers" as controllers
    RECTANGLE "DTOs" as dtos
    RECTANGLE "Mappers" as mappers
}

package "Domain Layer" {
    RECTANGLE "Use Cases" as usecases
    RECTANGLE "Services" as services
    RECTANGLE "Domain Objects" as domainobjects
}

package "Infrastructure Layer" {
    RECTANGLE "Database Persistence" as dbpersistence
    RECTANGLE "Redis Persistence" as redispersistence
}

package "Commons" {
    RECTANGLE "Common Models" as commonmodels
    RECTANGLE "Common Utils" as commonutils
}

controllers --> dtos
controllers --> mappers
controllers --> usecases

mappers --> domainobjects
mappers --> dtos

usecases <|.. services
services --> domainobjects

services --> dbpersistence
services --> redispersistence

dbpersistence --> domainobjects
redispersistence --> domainobjects

domainobjects --> commonmodels
services --> commonutils

@enduml
