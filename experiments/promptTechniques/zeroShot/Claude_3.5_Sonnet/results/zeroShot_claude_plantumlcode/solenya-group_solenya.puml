@startuml
participant "User Interface" as UI
participant "Component" as Component
participant "Virtual DOM" as VDOM
participant "App" as App
participant "Router" as Router
participant "Storage" as Storage
participant "Validator" as Validator

UI -> Component: User interaction
Component -> Component: Update state
Component -> VDOM: Generate virtual DOM
VDOM -> VDOM: Diff and patch
VDOM -> UI: Update real DOM

Component -> App: Notify state change
App -> Storage: Serialize state
Storage -> Storage: Store in local storage

UI -> Router: Navigate to new route
Router -> App: Update current route
App -> Component: Create/update components

Component -> Validator: Validate input
Validator -> Component: Return validation result

App -> Storage: Load serialized state
Storage -> App: Return deserialized state
App -> Component: Update component state

@enduml