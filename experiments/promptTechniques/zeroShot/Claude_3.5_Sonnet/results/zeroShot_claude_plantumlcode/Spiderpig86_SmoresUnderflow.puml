```plantuml
@startuml
!define RECTANGLE class

participant "User" as user
participant "Nginx Load Balancer" as nginx
participant "su-frontend" as frontend
participant "su-users" as users
participant "su-accounts" as accounts
participant "su-questions" as questions
participant "su-answers" as answers
participant "su-search" as search
participant "su-media" as media
participant "RabbitMQ" as rabbitmq
participant "Redis Cache" as redis
participant "MongoDB" as mongodb
participant "ElasticSearch" as elasticsearch

user -> nginx : Request
nginx -> frontend : Route request
frontend -> users : Authenticate
users -> redis : Check cached token
users -> mongodb : Verify user if not in cache
users --> frontend : Auth response
frontend -> questions : Fetch questions
questions -> redis : Check cache
questions -> mongodb : Fetch from DB if not cached
questions --> frontend : Questions data
frontend -> answers : Fetch answers
answers -> redis : Check cache
answers -> mongodb : Fetch from DB if not cached
answers --> frontend : Answers data
frontend -> search : Search request
search -> elasticsearch : Query
elasticsearch --> search : Search results
search --> frontend : Search response
frontend -> media : Upload media
media -> mongodb : Store media metadata
media --> frontend : Upload confirmation
frontend -> questions : Post new question
questions -> rabbitmq : Enqueue question
rabbitmq -> mongodb : Persist question
rabbitmq -> elasticsearch : Index question
frontend -> nginx : Response
nginx -> user : Render page
@enduml
```