@startuml gapfish_deployer

actor User
participant "depctl CLI" as CLI
participant "Deployer Service" as Deployer
participant "Kubernetes API" as K8s
participant "Docker Registry" as Registry
participant "Git Repository" as Git

User -> CLI : Initiate deployment
activate CLI

CLI -> Deployer : Send deployment request
activate Deployer

Deployer -> Git : Fetch latest code
activate Git
Git --> Deployer : Return code
deactivate Git

Deployer -> Registry : Pull Docker image
activate Registry
Registry --> Deployer : Return image
deactivate Registry

Deployer -> Deployer : Modify K8s resource definitions

Deployer -> K8s : Apply modified resources
activate K8s
K8s --> Deployer : Confirm application
deactivate K8s

alt Canary Deployment
    Deployer -> K8s : Create canary resources
    activate K8s
    K8s --> Deployer : Confirm canary creation
    deactivate K8s
end

Deployer -> Deployer : Log deployment events

Deployer --> CLI : Return deployment status
deactivate Deployer

CLI --> User : Display deployment result
deactivate CLI

@enduml