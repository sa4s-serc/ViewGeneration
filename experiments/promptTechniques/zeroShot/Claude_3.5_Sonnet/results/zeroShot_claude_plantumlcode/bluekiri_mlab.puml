@startuml bluekiri_mlab

package "Dashboard" {
  [Flask Core]
  [Data Access Layer]
  [Interactors]
  [API Endpoints]
  [Frontend]
  [Model Publisher]
}

package "Worker Service" {
  [Model Loader]
  [ZK Integration]
  [HTTP API]
  [Error Handler]
}

[ZooKeeper]
[MongoDB]
[Docker]

Dashboard --> [Flask Core]
Dashboard --> [Data Access Layer]
Dashboard --> [Interactors]
Dashboard --> [API Endpoints]
Dashboard --> [Frontend]
Dashboard --> [Model Publisher]

[Worker Service] --> [Model Loader]
[Worker Service] --> [ZK Integration]
[Worker Service] --> [HTTP API]
[Worker Service] --> [Error Handler]

[Data Access Layer] --> ZooKeeper : Reads/Writes
[Data Access Layer] --> MongoDB : Stores Data
[ZK Integration] --> ZooKeeper : Communicates
[Model Loader] --> MongoDB : Loads Models

Dashboard --> ZooKeeper : Real-time Updates
[Worker Service] --> ZooKeeper : Status Updates

Docker --> Dashboard : Containerizes
Docker --> [Worker Service] : Containerizes

@enduml