```plantuml
@startuml intel_edge-insights-vision

[eiv_install.sh] as Install
[eiv_setup.py] as Setup
[eiv_callbacks.sh] as Callbacks
[launch_notebooks.sh] as LaunchNotebooks
[adl_scripts] as AdlScripts

package "Core Components" {
  [OpenVINO Toolkit] as OpenVINO
  [Docker] as Docker
  [Intel Graphics Drivers] as GraphicsDrivers
  [Jupyter Notebooks] as Jupyter
}

package "Hardware" {
  [CPU]
  [iGPU]
  [dGPU]
  [MIPI Camera] as MIPICamera
}

cloud "Docker Hub" as DockerHub

Install --> Setup : executes
Install --> Callbacks : uses
Install --> LaunchNotebooks : executes
Install --> AdlScripts : executes (if Alder Lake N)

Setup --> OpenVINO : installs & configures
Setup --> Docker : installs & configures
Setup --> GraphicsDrivers : installs
Setup --> Jupyter : sets up

Callbacks --> DockerHub : pulls images
Callbacks --> Docker : manages containers

LaunchNotebooks --> Jupyter : starts

AdlScripts --> MIPICamera : enables support

OpenVINO --> CPU : optimized for
OpenVINO --> iGPU : optimized for
OpenVINO --> dGPU : optimized for

@enduml
```