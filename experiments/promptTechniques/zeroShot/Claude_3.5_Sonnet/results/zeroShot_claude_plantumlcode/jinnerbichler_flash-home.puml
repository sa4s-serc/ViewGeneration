@startuml

participant "Home Assistant" as HA
participant "MQTT Broker" as MQTT
participant "Coffee Machine Client" as CMC
participant "Coffee Machine Flash Server" as CMFS
participant "Provider Flash Server" as PFS
participant "IOTA Testnet" as IOTA

HA -> MQTT: Publish coffee request
MQTT -> CMC: Receive coffee request
CMC -> CMFS: Initiate payment
CMFS -> PFS: Send flash transaction
PFS --> CMFS: Confirm transaction
CMFS --> CMC: Payment confirmed
CMC -> MQTT: Publish coffee status
MQTT -> HA: Update coffee status
CMC -> MQTT: Publish channel balance
MQTT -> HA: Update channel balance

alt Channel closing
    HA -> MQTT: Publish close channel request
    MQTT -> CMC: Receive close channel request
    CMC -> CMFS: Request channel closure
    CMFS -> PFS: Send closure bundle
    PFS -> IOTA: Submit closure bundle
    IOTA --> PFS: Confirm bundle
    PFS --> CMFS: Closure confirmed
    CMFS --> CMC: Channel closed
    CMC -> MQTT: Publish channel closed status
    MQTT -> HA: Update channel status
end

@enduml