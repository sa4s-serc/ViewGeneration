@startuml orchsym_runtime

[NiFi Core] as core
[Flow Controller] as flowcontroller
[Process Scheduler] as scheduler
[Flow Synchronizer] as flowsync
[State Manager] as statemanager
[Repositories] as repos
[Controller Services] as services
[REST API] as api
[User Interface] as ui
[Authentication] as auth
[Authorization] as authz
[NAR Bundles] as nar
[Clustering] as cluster
[Orchsym Branding] as branding
[Orchsym Identity Providers] as orchsymauth
[Usage Data Collection] as udc

core --> flowcontroller
core --> scheduler
core --> flowsync
core --> statemanager
core --> repos
core --> services
core --> api
core --> auth
core --> authz
core --> nar
core --> cluster

flowcontroller --> scheduler
flowcontroller --> flowsync
flowcontroller --> statemanager

api --> ui

auth --> orchsymauth
authz --> orchsymauth

branding --> core
udc --> core

@enduml