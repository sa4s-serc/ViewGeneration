@startuml gustavung_Graphrec

component "Android Application" as AndroidApp {
  [MainActivity]
  [CameraActivity]
  [ResultActivity]
  [ImageUploadTask]
  [CameraPreview]
  [SurfaceOverlay]
}

component "Flask Server" as Server {
  [server.py]
  [graph_classifier.py]
  [graph_images.py]
  [generate_data.py]
  [cn.py]
}

component "TensorFlow CNN" as CNN

AndroidApp --> Server : HTTP POST
Server --> CNN : Invokes
CNN --> Server : Classification Result
Server --> AndroidApp : Returns Result

@enduml