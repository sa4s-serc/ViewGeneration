@startuml
!theme plain
skinparam sequenceMessageAlign center

actor User
participant "Angular Frontend" as Frontend
participant "NGINX Load Balancer" as LoadBalancer
participant "ASP.NET Core Web API" as Backend
database "PostgreSQL" as DB

User -> Frontend : Interacts with UI
Frontend -> LoadBalancer : HTTP Request
LoadBalancer -> Backend : Route Request

alt User Authentication
    Backend -> DB : Validate Credentials
    DB --> Backend : User Data
    Backend -> Backend : Generate JWT
    Backend --> LoadBalancer : JWT Response
    LoadBalancer --> Frontend : JWT
    Frontend -> Frontend : Store JWT
end

alt Contact Management
    Frontend -> LoadBalancer : CRUD Request (with JWT)
    LoadBalancer -> Backend : Route Request
    Backend -> Backend : Validate JWT
    Backend -> DB : Execute CRUD Operation
    DB --> Backend : Operation Result
    Backend --> LoadBalancer : API Response
    LoadBalancer --> Frontend : Updated Data
    Frontend -> Frontend : Update UI
end

@enduml