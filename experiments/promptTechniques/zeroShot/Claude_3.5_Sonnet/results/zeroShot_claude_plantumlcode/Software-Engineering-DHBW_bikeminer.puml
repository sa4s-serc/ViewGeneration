  [Map Page]
  [Login/Registration Page]
  [Wallet Page]
  [Rides Page]
  [API Connector]
  [Storage Adapter]
}

FlutterApp ..> FlutterComponents

component "Android App Components" as AndroidComponents {
  [Maps Activity]
  [GPS Tracker]
  [Reward System]
}

AndroidApp ..> AndroidComponents

component "Backend Components" as BackendComponents {
  [User Management]
  [Ride Data Management]
  [Authentication/Authorization]
  [Distance Calculator]
}

Backend ..> BackendComponents

note right of API
