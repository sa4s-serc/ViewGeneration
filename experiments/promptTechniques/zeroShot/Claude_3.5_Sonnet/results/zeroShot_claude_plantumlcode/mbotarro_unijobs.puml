@startuml mbotarro_unijobs

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<Database>> LightYellow
  BackgroundColor<<Search>> LightPink
}

component "React Native Frontend" <<Frontend>> {
  [Authentication]
  [Offer/Request Feed]
  [Profile Management]
  [Navigation]
}

component "Go Backend" <<Backend>> {
  [RESTful API]
  [Business Logic]
  [Data Access Layer]
}

database "PostgreSQL" <<Database>>
component "Elasticsearch" <<Search>>

[React Native Frontend] --> [Go Backend] : HTTP Requests
[Go Backend] --> [PostgreSQL] : CRUD Operations
[Go Backend] --> [Elasticsearch] : Full-text Search

@enduml