```plantuml
@startuml aliyun_packagist-mirror

[Packagist API] as PackagistAPI
[GitHub API] as GitHubAPI
[Alibaba Cloud OSS] as OSS
[Redis] as Redis
[CDN] as CDN

package "Aliyun Packagist Mirror" {
  [Configuration] as Config
  [Main Controller] as Main
  [Packagist Sync] as PackagistSync
  [GitHub Integration] as GitHubIntegration
  [Distribution Sync] as DistSync
  [Package Sync V1] as PackageSyncV1
  [Package Sync V2] as PackageSyncV2
  [Provider Sync] as ProviderSync
  [Status Monitor] as StatusMonitor
  [CDN Warm-up] as CDNWarmup
  [Composer Phar Sync] as ComposerPharSync
}

Main --> Config : reads
Main --> PackagistSync : initiates
Main --> GitHubIntegration : initiates
Main --> DistSync : initiates
Main --> PackageSyncV1 : initiates
Main --> PackageSyncV2 : initiates
Main --> ProviderSync : initiates
Main --> StatusMonitor : initiates
Main --> CDNWarmup : initiates
Main --> ComposerPharSync : initiates

PackagistSync --> PackagistAPI : fetches data
GitHubIntegration --> GitHubAPI : interacts
DistSync --> OSS : stores distributions
PackageSyncV1 --> OSS : stores package info
PackageSyncV2 --> OSS : stores package info
ProviderSync --> OSS : stores provider lists
StatusMonitor --> OSS : writes status.json
CDNWarmup --> CDN : warms up cache
ComposerPharSync --> OSS : stores composer.phar

PackagistSync --> Redis : caches sync status
DistSync --> Redis : uses queues
PackageSyncV1 --> Redis : uses queues
PackageSyncV2 --> Redis : uses queues
ProviderSync --> Redis : uses queues

@enduml
```