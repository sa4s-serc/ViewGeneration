@startuml gcba-iris_iris

participant "Client" as C
participant "Dock" as D
participant "Dispatcher" as DP
participant "Hook (Input)" as HI
participant "Handler" as H
participant "Hook (Output)" as HO
participant "Thread Pool" as TP

C -> D: Send message
activate D
D -> D: Parse message
D -> DP: Forward parsed message
activate DP

DP -> TP: Allocate thread
activate TP

TP -> HI: Execute input hook
activate HI
HI --> TP: Return modified message
deactivate HI

TP -> H: Process message
activate H
H --> TP: Return processed result
deactivate H

TP -> HO: Execute output hook
activate HO
HO --> TP: Return final result
deactivate HO

TP --> DP: Return result
deactivate TP

DP -> D: Send response
deactivate DP

D -> D: Encode response
D --> C: Send encoded response
deactivate D

@enduml