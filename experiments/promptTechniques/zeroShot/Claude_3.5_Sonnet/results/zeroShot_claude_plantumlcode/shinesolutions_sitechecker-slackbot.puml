@startuml shinesolutions_sitechecker-slackbot

!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v15.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/ApplicationIntegration/APIGateway.puml
!include AWSPuml/Compute/Lambda.puml
!include AWSPuml/General/InternetGateway.puml

component "Slack" as slack
component "API Gateway" as apigw <<$APIGateway>>
component "Master Lambda" as master <<$Lambda>>
component "Worker Lambda (US-East-1)" as worker1 <<$Lambda>>
component "Worker Lambda (US-West-2)" as worker2 <<$Lambda>>
component "Worker Lambda (EU-West-1)" as worker3 <<$Lambda>>
component "Target Website" as website <<$InternetGateway>>

slack --> apigw : Outgoing Webhook
apigw --> master : Trigger
master --> worker1 : Distribute task
master --> worker2 : Distribute task
master --> worker3 : Distribute task
worker1 --> website : Check availability
worker2 --> website : Check availability
worker3 --> website : Check availability
worker1 --> master : Return result
worker2 --> master : Return result
worker3 --> master : Return result
master --> slack : Send report

@enduml