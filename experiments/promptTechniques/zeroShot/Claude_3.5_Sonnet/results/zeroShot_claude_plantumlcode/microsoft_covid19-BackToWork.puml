@startuml microsoft_covid19-BackToWork

participant "Client" as C
participant "Azure Function\nHTTP Trigger" as AF
participant "DbHelper" as DB
participant "Azure SQL Database" as SQL
participant "NotificationHelper" as NH
participant "SendGrid" as SG
participant "Healthcare Bot" as HB
participant "QR Code Generator" as QR

C -> AF : Submit health data
activate AF

AF -> DB : Store data
activate DB
DB -> SQL : Execute stored procedure
SQL --> DB : Return result
DB --> AF : Confirm storage
deactivate DB

AF -> HB : Request assessment
activate HB
HB -> HB : Evaluate health status
HB --> AF : Return assessment result
deactivate HB

alt Cleared for work
    AF -> QR : Generate QR code
    QR --> AF : Return QR code
end

AF -> NH : Send notification
activate NH
NH -> SG : Send email with result (and QR if cleared)
SG --> NH : Confirm sent
NH --> AF : Notification sent
deactivate NH

AF --> C : Return assessment result
deactivate AF

@enduml