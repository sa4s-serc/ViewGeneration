@startuml
!define RECTANGLE class

package "Application Layer" {
    RECTANGLE ScreeningApplicationService
}

package "Domain Layer" {
    RECTANGLE Screening
    RECTANGLE Interview
    RECTANGLE ScreeningStatus
    RECTANGLE EmailAddress
    RECTANGLE ScreeningId
    RECTANGLE Interviews
    RECTANGLE ScreeningStepResult
}

package "Infrastructure Layer" {
    RECTANGLE ScreeningRepository
    RECTANGLE ScreeningDao
    RECTANGLE InterviewDao
}

package "Shared" {
    RECTANGLE ApplicationException
    RECTANGLE Const
}

ScreeningApplicationService --> Screening : uses
ScreeningApplicationService --> ScreeningRepository : uses

Screening --> Interview : contains
Screening --> ScreeningStatus : has
Screening --> EmailAddress : uses
Screening --> ScreeningId : uses
Screening --> Interviews : contains
Screening --> ScreeningStepResult : uses

ScreeningRepository --> ScreeningDao : uses
ScreeningRepository --> InterviewDao : uses

ScreeningApplicationService ..> ApplicationException : throws
Screening ..> ApplicationException : throws

@enduml