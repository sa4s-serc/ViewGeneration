@startuml anvasquezre_sabiduria_asegurada_experiments

actor User
participant "Chainlit Frontend" as Frontend
participant "Langchain Agent" as Agent
participant "Policy Search Tool" as PolicyTool
participant "Web Search Tool" as WebTool
participant "Greeting Tool" as GreetingTool
database "Qdrant Vector DB" as Qdrant
cloud "Google Search API" as GoogleSearch
cloud "S3 Bucket" as S3

User -> Frontend : Ask question
Frontend -> Agent : Process question

alt Greeting
    Agent -> GreetingTool : Use greeting tool
    GreetingTool --> Agent : Return greeting
else Policy Search
    Agent -> PolicyTool : Search policy information
    PolicyTool -> Qdrant : Query vector database
    Qdrant --> PolicyTool : Return relevant policy info
    PolicyTool --> Agent : Return policy answer
else Web Search
    Agent -> WebTool : Search web for current info
    WebTool -> GoogleSearch : Perform web search
    GoogleSearch --> WebTool : Return search results
    WebTool --> Agent : Return web-based answer
end

Agent --> Frontend : Provide answer
Frontend -> User : Display response

User -> Frontend : Provide feedback
Frontend -> Qdrant : Store feedback

@enduml