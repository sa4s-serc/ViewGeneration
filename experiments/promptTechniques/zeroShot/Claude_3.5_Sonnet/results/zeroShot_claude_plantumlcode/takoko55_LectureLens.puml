@startuml takoko55_LectureLens

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<Database>> LightYellow
}

component "Frontend" <<Frontend>> {
  [React App]
  [React Router]
  [React Query]
  [Axios]
  [Zustand Store]
}

component "Backend" <<Backend>> {
  [Echo Web Framework]
  [GORM]
  [JWT Authentication]
  [Controllers]
  [Usecases]
  [Repositories]
}

database "PostgreSQL" <<Database>> {
  [User Data]
  [Lecture Information]
  [Reviews]
}

[React App] --> [React Router] : uses
[React App] --> [React Query] : uses
[React App] --> [Axios] : uses
[React App] --> [Zustand Store] : uses

[Echo Web Framework] --> [Controllers] : routes to
[Controllers] --> [Usecases] : uses
[Usecases] --> [Repositories] : uses
[Repositories] --> [GORM] : uses
[GORM] --> [PostgreSQL] : interacts with

[React App] --> [Echo Web Framework] : REST API calls
[JWT Authentication] - [Echo Web Framework] : secures

@enduml