@startuml ra1028_VueFlux

[VueFlux] as VF
[VueFluxReactive] as VFR
[Store] as S
[State] as ST
[Actions] as A
[Mutations] as M
[Computed] as C
[Executor] as E
[AtomicReference] as AR
[UI Components] as UI

package "VueFluxReactive" {
  [Variable] as V
  [Constant] as CO
  [Sink] as SI
  [Signal] as SG
  [Binder] as B
}

VF --> S : contains
S --> ST : manages
S --> A : handles
S --> M : applies
S --> C : provides
VF --> E : uses
VF --> AR : uses for thread safety

VFR --> V
VFR --> CO
VFR --> SI
VFR --> SG
VFR --> B

A --> M : triggers
M --> ST : modifies
C --> ST : derives from

UI --> S : observes
UI --> B : binds to

VF ..> VFR : uses

@enduml