@startuml matrix-io_matrix-malos-zwave

!define RECTANGLE class

RECTANGLE "MATRIX Creator/Voice" as MatrixHW
RECTANGLE "MALOS Core" as MALOSCore
RECTANGLE "Z-Wave Abstraction Layer" as ZWaveLayer
RECTANGLE "Z/IP Gateway" as ZIPGateway
RECTANGLE "Z-Wave RF Module" as ZWaveModule
RECTANGLE "0MQ" as ZeroMQ
RECTANGLE "Protocol Buffers" as ProtoBuf
RECTANGLE "JavaScript Utilities" as JSUtils
RECTANGLE "Systemd Service" as SystemdService

MatrixHW -- MALOSCore : provides hardware access
MALOSCore -- ZWaveLayer : integrates
ZWaveLayer -- ZIPGateway : communicates via
ZIPGateway -- ZWaveModule : controls
ZWaveLayer -- ZeroMQ : uses for IPC
ZWaveLayer -- ProtoBuf : uses for serialization
JSUtils -- ZeroMQ : interacts via
SystemdService -- ZWaveLayer : manages

note right of ZWaveLayer
  Handles Z-Wave device management,
  schedules, sensors, and security
end note

note right of MALOSCore
  Abstracts hardware complexities
end note

note bottom of JSUtils
  addnode.js, list.js, removenode.js, etc.
end note

note left of ZIPGateway
  Translates IP commands to Z-Wave RF
end note

@enduml