@startuml
participant "Cron Job" as Cron
participant "fetch_security_posture_and_upload_to_ES.sh" as FetchScript
participant "Spectrum Scale Cluster" as Cluster
participant "security_posture.py" as CollectorScript
participant "split_json_for_kibana.py" as SplitScript
participant "Elasticsearch" as ES
participant "Kibana" as Kibana

Cron -> FetchScript : Trigger execution
activate FetchScript

FetchScript -> Cluster : SSH connection
activate Cluster

FetchScript -> CollectorScript : Execute
activate CollectorScript

CollectorScript -> Cluster : Gather security data (mm commands)
Cluster --> CollectorScript : Return security data
CollectorScript --> FetchScript : Return JSON data
deactivate CollectorScript

FetchScript -> FetchScript : SCP JSON to local machine

FetchScript -> SplitScript : Execute
activate SplitScript
SplitScript -> SplitScript : Split JSON into multiple files
SplitScript --> FetchScript : Return split JSON files
deactivate SplitScript

loop for each JSON file
    FetchScript -> ES : Upload data (curl)
    ES --> FetchScript : Confirm upload
end

FetchScript -> FetchScript : Delete temporary files

deactivate FetchScript
deactivate Cluster

ES -> Kibana : Index data
Kibana -> Kibana : Update dashboard
@enduml