@startuml philipplackner_IvyWallet-PL_Version

!define RECTANGLE class

RECTANGLE "Home Module" as Home {
    [HomeViewModel]
}

RECTANGLE "Transaction Module" as Transaction {
    [TrnsFlow]
    [WriteTrnsAct]
}

RECTANGLE "Account Module" as Account {
    [WriteAccountsAct]
}

RECTANGLE "Category Module" as Category {
    [CategoryManagement]
}

RECTANGLE "Sync Module" as Sync {
    [SyncAct]
    [RemoteBackupSource]
}

RECTANGLE "Backup Module" as Backup {
    [BackupDataAct]
    [ImportBackupDataAct]
}

RECTANGLE "Exchange Rates Module" as ExchangeRates {
    [RatesStateFlow]
    [ExchangeRatesViewModel]
}

RECTANGLE "Formula Module" as Formula {
    [FormulaFlow]
    [CompileFunction]
}

RECTANGLE "Design System" as DesignSystem {
    [IvyTheme]
}

RECTANGLE "Navigation" as Navigation {
    [Navigator]
}

Home --> Transaction : uses
Home --> Account : uses
Home --> Category : uses
Home --> ExchangeRates : uses
Home --> Formula : uses

Transaction --> Sync : triggers
Account --> Sync : triggers
Category --> Sync : triggers

Sync --> Backup : uses

Home --> Navigation : uses
Transaction --> Navigation : uses
Account --> Navigation : uses
Category --> Navigation : uses

Home --> DesignSystem : applies
Transaction --> DesignSystem : applies
Account --> DesignSystem : applies
Category --> DesignSystem : applies

@enduml