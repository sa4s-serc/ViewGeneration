@startuml nikmis_xentrace-analysis

!define RECTANGLE class

rectangle "Xen Hypervisor" as xen
rectangle "Virtual Machines" as vms

component "Xentrace-analysis Tool" {
    [Xentrace-analysis.c] as main
    [Reader] as reader
    [EventHandler] as handler
    [Event Parser] as parser
    
    package "Analysis Modules" {
        [CPU Utilization] as cpu
        [CPU Scheduling Latency] as latency
        [Time in Hypervisor] as hypervisor
        [Disk I/O] as io
        [Xen Event Statistics] as stats
        [Trap Counting] as trap
    }
}

database "Trace Data File" as tracefile

xen --> tracefile : generates
main --> xen : spawns xentrace
main --> reader : initiates
reader --> tracefile : reads
reader --> parser : feeds data
parser --> handler : dispatches events
handler --> cpu
handler --> latency
handler --> hypervisor
handler --> io
handler --> stats
handler --> trap

cpu --> vms : analyzes
latency --> vms : analyzes
hypervisor --> vms : analyzes
io --> vms : analyzes
stats --> vms : analyzes
trap --> vms : analyzes

@enduml