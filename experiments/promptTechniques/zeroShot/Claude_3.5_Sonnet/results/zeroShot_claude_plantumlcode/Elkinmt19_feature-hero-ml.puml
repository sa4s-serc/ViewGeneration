@startuml Elkinmt19_feature-hero-ml

actor User
participant "Data Pipeline" as DataPipeline
participant "Feature Store (Feast)" as Feast
database "Redis (Online Store)" as Redis
database "Parquet (Offline Store)" as Parquet
participant "Feature Server" as FeatureServer

User -> DataPipeline : Initiate data ingestion
DataPipeline -> DataPipeline : Fetch and transform data
DataPipeline -> Feast : Ingest features
Feast -> Parquet : Store offline features
Feast -> Redis : Store online features

User -> FeatureServer : Request online features
FeatureServer -> Feast : Retrieve features
Feast -> Redis : Fetch online features
Redis --> Feast : Return online features
Feast --> FeatureServer : Serve features
FeatureServer --> User : Return online features

User -> FeatureServer : Request offline features
FeatureServer -> Feast : Retrieve features
Feast -> Parquet : Fetch offline features
Parquet --> Feast : Return offline features
Feast --> FeatureServer : Serve features
FeatureServer --> User : Return offline features

User -> FeatureServer : Train model
FeatureServer -> Feast : Retrieve training data
Feast -> Parquet : Fetch offline features
Parquet --> Feast : Return offline features
Feast --> FeatureServer : Serve training data
FeatureServer --> User : Return training data

@enduml