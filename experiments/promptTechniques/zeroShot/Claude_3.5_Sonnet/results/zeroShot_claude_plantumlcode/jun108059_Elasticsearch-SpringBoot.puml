@startuml jun108059_Elasticsearch-SpringBoot

[Web Browser] as WebBrowser
[REST Client] as RESTClient

package "Spring Boot Application" {
  [Admin Controllers]
  [API Controller]
  [Index Service]
  [Service Repository]
  [Bulk Repository]
  [Elasticsearch Client]
}

database "MySQL" as MySQL
database "Elasticsearch" as Elasticsearch

WebBrowser --> [Admin Controllers] : HTTP
RESTClient --> [API Controller] : HTTP

[Admin Controllers] --> [Index Service]
[API Controller] --> [Index Service]

[Index Service] --> [Service Repository]
[Index Service] --> [Bulk Repository]
[Index Service] --> [Elasticsearch Client]

[Service Repository] --> MySQL : JDBC
[Bulk Repository] --> MySQL : JDBC

[Elasticsearch Client] --> Elasticsearch : REST

@enduml