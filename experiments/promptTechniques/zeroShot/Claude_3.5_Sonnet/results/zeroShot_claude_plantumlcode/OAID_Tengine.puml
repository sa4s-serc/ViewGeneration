@startuml OAID_Tengine

[Model Conversion] as MC
[Inference Engine] as IE
[Operator Library] as OL
[Testing Framework] as TF
[Device Abstraction Layer] as DAL
[Graph Representation] as GR
[Memory Management] as MM
[Shader Management] as SM
[Online Reporting] as OR
[Python Bindings] as PB

MC --> IE : Provides converted models
IE --> OL : Uses operators
IE --> DAL : Executes on devices
IE --> GR : Uses graph representation
IE --> MM : Manages memory
IE --> SM : Uses shaders (Vulkan)
IE --> OR : Reports metrics

DAL --> [CPU]
DAL --> [GPU]
DAL --> [NPU]

OL --> [Convolution]
OL --> [ReLU]
OL --> [Pooling]
OL --> [Softmax]
OL --> [GEMM]

TF --> IE : Validates
TF --> OL : Tests operators

PB --> IE : Interfaces with

@enduml