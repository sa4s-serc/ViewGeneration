@startuml victorshinya_serverless-chatbot

actor User
participant "IBM Cloud Functions" as ICF
participant "Watson Assistant" as WA
database "MongoDB" as DB

User -> ICF : Send message
activate ICF

ICF -> WA : Process message
activate WA
WA --> ICF : Return response
deactivate WA

ICF -> DB : Store conversation data
activate DB
DB --> ICF : Confirm storage
deactivate DB

ICF --> User : Deliver chatbot response
deactivate ICF

@enduml