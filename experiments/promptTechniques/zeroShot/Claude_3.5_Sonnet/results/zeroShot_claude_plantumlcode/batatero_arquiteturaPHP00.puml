@startuml batatero_arquiteturaPHP00

package "CodeIgniter Application" {
  [Controller]
  [Facade]
  [Business Logic]
  [DAO]
  [FactoryBusiness]
  [FactoryDAO]
}

package "CodeIgniter Core" {
  [Front Controller]
  [Libraries]
  [Helpers]
  [Database Access]
}

package "Doctrine ORM" {
  [EntityManager]
  [UnitOfWork]
  [QueryBuilder]
  [DBAL]
}

package "External Components" {
  [Symfony YAML]
  [Symfony Console]
}

[Controller] --> [Facade]
[Facade] --> [Business Logic]
[Business Logic] --> [DAO]
[Business Logic] --> [FactoryBusiness]
[DAO] --> [FactoryDAO]

[Front Controller] --> [Controller]
[Controller] --> [Libraries]
[Controller] --> [Helpers]
[DAO] --> [Database Access]

[Business Logic] --> [EntityManager]
[EntityManager] --> [UnitOfWork]
[EntityManager] --> [QueryBuilder]
[EntityManager] --> [DBAL]

[Controller] --> [Symfony YAML]
[Controller] --> [Symfony Console]

@enduml