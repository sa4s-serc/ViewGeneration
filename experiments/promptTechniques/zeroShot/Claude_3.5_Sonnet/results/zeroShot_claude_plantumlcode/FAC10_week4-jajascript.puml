@startuml FAC10_week4-jajascript

[Client Browser] as Client
[Front-end] as Frontend
[Server] as Server
[Router] as Router
[Handler] as Handler
[Algorithm] as Algorithm
[Data Store] as DataStore

Client -> Frontend : User Input
Frontend -> Server : HTTP Request
Server -> Router : Route Request
Router -> Handler : Handle Request
Handler -> Algorithm : Process Query
Algorithm -> DataStore : Fetch Data
DataStore --> Algorithm : Return Data
Algorithm --> Handler : Return Results
Handler --> Router : Send Response
Router --> Server : Format Response
Server --> Frontend : HTTP Response
Frontend --> Client : Display Results

@enduml