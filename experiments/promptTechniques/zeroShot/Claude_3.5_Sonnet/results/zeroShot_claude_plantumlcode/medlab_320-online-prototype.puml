@startuml medlab_320-online-prototype

component "Frontend" {
  [React Router]
  [Redux]
  [Ant Design]
  [Mock.js]
}

component "Backend" {
  [ASP.NET Core]
  [Entity Framework Core]
  [JWT Authentication]
  [Custom Middleware]
}

component "Authentication Service" {
  [Hydra]
  [IdentityServer4]
}

component "Logging Service" {
  [EFK Stack]
}

component "Tracing Service" {
  [SkyWalking]
  [Zipkin]
}

component "Object Storage" {
  [MinIO]
}

component "System Integration Testing" {
  [Jest]
  [Puppeteer]
}

database "Database"

cloud "Kubernetes" {
  [API Gateway]
}

Frontend --> API Gateway : HTTP/HTTPS
API Gateway --> Backend : Routes requests
Backend --> Database : Entity Framework Core
Backend --> Authentication Service : OAuth/OIDC
Backend --> Object Storage : S3 compatible
Backend --> Logging Service : Centralized logging
Backend --> Tracing Service : Distributed tracing

System Integration Testing --> Frontend : UI Testing
System Integration Testing --> Backend : API Testing

@enduml