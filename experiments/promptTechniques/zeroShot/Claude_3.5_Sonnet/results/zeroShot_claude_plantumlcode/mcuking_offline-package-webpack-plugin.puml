@startuml
participant Webpack
participant OfflinePackagePlugin
participant JSZip
participant MimeTypes
participant FileSystem

Webpack -> OfflinePackagePlugin : apply(compiler)
activate OfflinePackagePlugin

OfflinePackagePlugin -> Webpack : tap 'emit' hook
activate Webpack

Webpack -> OfflinePackagePlugin : emit hook callback
activate OfflinePackagePlugin

OfflinePackagePlugin -> JSZip : new JSZip()
activate JSZip

loop for each asset
    OfflinePackagePlugin -> OfflinePackagePlugin : filterAsset(asset)
    alt asset passes filter
        OfflinePackagePlugin -> JSZip : file(assetPath, assetContent)
        OfflinePackagePlugin -> MimeTypes : lookup(assetPath)
        MimeTypes --> OfflinePackagePlugin : mimeType
        OfflinePackagePlugin -> OfflinePackagePlugin : updateManifest(asset, mimeType)
    end
end

OfflinePackagePlugin -> JSZip : generateAsync({type: 'nodebuffer'})
JSZip --> OfflinePackagePlugin : zipBuffer

OfflinePackagePlugin -> FileSystem : writeFileSync(zipFilePath, zipBuffer)
OfflinePackagePlugin -> FileSystem : writeFileSync(manifestFilePath, manifestJSON)

OfflinePackagePlugin --> Webpack : done
deactivate OfflinePackagePlugin
deactivate Webpack
deactivate OfflinePackagePlugin
deactivate JSZip

@enduml