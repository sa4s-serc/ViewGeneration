@startuml IBM_spectrum-protect-sppmon

component "SPPMon Core Engine" as SPPMon
component "SPPCheck" as SPPCheck
component "InfluxDB" as InfluxDB
component "Grafana" as Grafana
component "REST API Client" as RestAPI
component "SSH Client" as SSH
component "Installer Script" as Installer

package "SPP Environment" {
    component "SPP Server"
    component "vSnap"
    component "VADP"
    component "Microsoft 365 Proxies"
}

SPPMon --> RestAPI : uses
SPPMon --> SSH : uses
SPPMon --> InfluxDB : stores data
Grafana --> InfluxDB : reads data

RestAPI --> "SPP Server" : queries
SSH --> "vSnap" : executes commands
SSH --> "VADP" : executes commands
SSH --> "Microsoft 365 Proxies" : executes commands

SPPCheck --> InfluxDB : reads data
SPPCheck --> "SPP Environment" : analyzes

Installer --> SPPMon : installs
Installer --> InfluxDB : installs
Installer --> Grafana : installs
Installer --> SPPCheck : installs

@enduml