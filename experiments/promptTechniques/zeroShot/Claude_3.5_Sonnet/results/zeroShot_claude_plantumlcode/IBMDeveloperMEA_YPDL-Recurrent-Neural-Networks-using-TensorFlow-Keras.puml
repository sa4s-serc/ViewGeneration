@startuml
participant "User" as U
participant "Jupyter Notebook" as JN
participant "TensorFlow Keras" as TFK
participant "DataLoader" as DL
participant "LSTM Model" as LSTM
participant "Evaluation" as E

U -> JN: Open notebook
JN -> DL: Load Penn Treebank dataset
DL --> JN: Return processed data
JN -> TFK: Create LSTM model
TFK -> LSTM: Initialize layers
JN -> LSTM: Configure model (embedding, LSTM, dense layers)
JN -> LSTM: Compile model
JN -> LSTM: Train model
LSTM -> DL: Request batches
DL --> LSTM: Provide data batches
LSTM --> JN: Return training metrics
JN -> E: Evaluate model
E -> LSTM: Request predictions
LSTM --> E: Provide predictions
E --> JN: Return evaluation metrics (perplexity)
JN -> U: Display results and visualizations
@enduml