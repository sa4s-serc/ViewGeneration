@startuml tarhses_esp-alarm-clock

participant "Main" as Main
participant "Network" as Network
participant "Storage" as Storage
participant "Display" as Display
participant "Alarm" as Alarm
participant "Sound" as Sound
participant "Potentiometer" as Pot

Main -> Storage : Initialize SD card and NVS
Main -> Network : Initialize WiFi and SNTP
Main -> Pot : Initialize and calibrate potentiometers
Main -> Sound : Initialize audio system
Main -> Display : Initialize E-Paper display
Main -> Alarm : Initialize alarm system

loop Main Event Loop
    Network -> Network : Maintain WiFi connection
    Network -> Network : Synchronize time with NTP server
    
    Pot -> Alarm : Send potentiometer readings
    Alarm -> Alarm : Update alarm time
    
    Alarm -> Display : Send updated alarm status
    Display -> Display : Update E-Paper display
    
    alt Alarm triggered
        Alarm -> Sound : Trigger alarm sound
        Sound -> Sound : Play random audio file
    end
    
    alt User interaction (button press/switch change)
        Alarm -> Alarm : Handle alarm action (stop/snooze)
        Alarm -> Sound : Stop alarm sound if necessary
        Alarm -> Display : Update alarm status
    end
end

@enduml