@startuml gpsnmeajp_VirtualMotionTracker

component "VirtualMotionTracker" {
    [Core Module]
    [Driver Module]
    [UI Module]
    [Network Module]
}

component "SteamVR"
component "OpenVR"
component "Windows OS"
component "VR Applications"

[Core Module] --> [Driver Module]
[Core Module] --> [UI Module]
[Core Module] --> [Network Module]

[Driver Module] --> OpenVR : interfaces with
OpenVR --> SteamVR : integrates

[UI Module] --> [Windows OS] : runs on
[Network Module] --> [Windows OS] : uses TCP/IP

[VR Applications] --> SteamVR : uses

note right of [Core Module]
  Manages overall system functionality
end note

note right of [Driver Module]
  Handles VR device emulation
end note

note right of [UI Module]
  Provides user interface
end note

note right of [Network Module]
  Manages network communication
end note

@enduml