@startuml jquku_Matrix-Chatbot

actor User
participant "Matrix Client" as MC
participant "Main Module" as Main
participant "Message Evaluation" as ME
participant "NLP Module" as NLP
participant "Response Management" as RM
database "Knowledge Base" as KB
participant "Database Service" as DS

User -> MC: Send message
MC -> Main: Receive message event
Main -> NLP: Process user input
NLP --> Main: Processed text
Main -> ME: Evaluate message
ME -> DS: Query knowledge base
DS -> KB: Retrieve relevant information
KB --> DS: Return information
DS --> ME: Return query results
ME --> Main: Return evaluation results
Main -> RM: Generate response
RM -> DS: Update statistics
DS -> KB: Store statistics
KB --> DS: Confirm update
DS --> RM: Confirm statistics update
RM --> Main: Return formatted response
Main -> MC: Send response
MC -> User: Display response

@enduml