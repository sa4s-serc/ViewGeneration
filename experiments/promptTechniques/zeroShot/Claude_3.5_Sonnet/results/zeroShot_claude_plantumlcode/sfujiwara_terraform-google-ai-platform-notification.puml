@startuml
participant "AI Platform" as AI
participant "Cloud Logging" as CL
participant "Log Sink" as LS
participant "AI Platform Log Topic" as LT
participant "Cloud Function" as CF
participant "Notification Topic" as NT

AI -> CL : Generate logs
CL -> LS : Forward logs
LS -> LT : Publish log message
LT -> CF : Trigger function
CF -> CF : Parse log message
CF -> CF : Determine job state
CF -> NT : Publish notification
@enduml