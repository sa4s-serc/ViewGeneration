@startuml openshift_configuration-anomaly-detection

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Security>> LightYellow
  BorderColor<<Security>> Orange
}

[PagerDuty] as PD
[OpenShift Cluster Manager] as OCM
[AWS] as AWS
[Kubernetes] as K8S

package "OpenShift Configuration Anomaly Detection" {
  [Tekton Interceptor] as TI <<Security>>
  [cadctl CLI] as CLI
  [Investigation Framework] as IF
  [AWS Client] as AWSC
  [OCM Client] as OCMC
  [K8S Client] as K8SC
  [PagerDuty Client] as PDC
  [Network Verifier] as NV
  
  database "Investigations" {
    [chgm]
    [apierrorbudgetburn]
    [insightsoperatordown]
    [ccam]
    [upgradeconfigsyncfailureover4hr]
    [cpd]
    [clustermonitoringerrorbudgetburn]
    [machinehealthcheckunterminatedshortcircuitsre]
  }
}

PD -right-> TI : Alerts
TI -down-> CLI : Triggers
CLI -down-> IF : Uses
IF --> AWSC
IF --> OCMC
IF --> K8SC
IF --> PDC
IF --> NV
IF --> Investigations

AWSC -up-> AWS : Interacts
OCMC -up-> OCM : Interacts
K8SC -up-> K8S : Interacts
PDC -up-> PD : Updates

note right of TI
  Validates signatures
  and filters alerts
end note

note right of CLI
  Handles alert remediation
  and pre-investigations
end note

note right of IF
  Extensible framework
  for investigations
end note

@enduml