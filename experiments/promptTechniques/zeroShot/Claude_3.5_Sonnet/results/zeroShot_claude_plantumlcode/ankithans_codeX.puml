```plantuml
@startuml ankithans_codeX

[Frontend] as FE
[Backend] as BE
[HackerEarth API] as HE
[Google Translate] as GT
[SQLite Database] as DB

package "Frontend Components" {
  [App.js] as App
  [Navbar] 
  [PseudoCode]
  [Warnings]
  [Compile]
}

package "Backend Services" {
  [Pseudocode Converter] as PC
  [Code Compiler] as CC
  [Code Analyzer] as CA
  [Translator] as TR
  [Code Sharer] as CS
  [Flowchart Generator] as FG
}

FE --> BE : API Calls
BE --> HE : Compilation Requests
BE --> GT : Translation Requests
BE --> DB : CRUD Operations

App --> Navbar
App --> PseudoCode
App --> Warnings
App --> Compile

BE --> PC
BE --> CC
BE --> CA
BE --> TR
BE --> CS
BE --> FG

@enduml
```