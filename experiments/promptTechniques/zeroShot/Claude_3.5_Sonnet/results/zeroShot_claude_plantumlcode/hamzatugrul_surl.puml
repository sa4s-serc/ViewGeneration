@startuml hamzatugrul_surl

!define RECTANGLE class

RECTANGLE "Nginx Load Balancer" as nginx
RECTANGLE "Spring Boot Application" as app {
    RECTANGLE "ShortURLController" as controller
    RECTANGLE "UrlShortenerService" as service
    RECTANGLE "ShortUrlRepository" as repo
    RECTANGLE "KeyGenerator" as keygen
}
RECTANGLE "Redis Cache" as redis
RECTANGLE "MongoDB" as mongodb

nginx -down-> controller : HTTP requests
controller -down-> service : API calls
service -down-> repo : Data access
service -right-> keygen : Generate keys
repo -down-> mongodb : Persist data
repo <-right-> redis : Cache data

@enduml