@startuml zalando-incubator_fabric-gateway

participant "Kubernetes API Server" as K8s
participant "Fabric Gateway Operator" as Operator
participant "Admission Webhook" as Webhook
participant "IngressDerivationChain" as IDC
participant "StackSetOperations" as SSO
participant "Skipper" as Skipper

-> Operator : Start

loop Continuous Watch
    Operator -> K8s : Watch FabricGateway CRDs
    K8s --> Operator : FabricGateway Event
    
    alt New or Updated FabricGateway
        Operator -> Webhook : Validate FabricGateway
        Webhook --> Operator : Validation Result
        
        alt Valid FabricGateway
            Operator -> IDC : Derive Ingress
            IDC -> SSO : Check StackSet
            SSO --> IDC : StackSet Info
            IDC --> Operator : Derived Ingress
            
            Operator -> K8s : Create/Update Ingress
            K8s --> Operator : Ingress Created/Updated
            
            Operator -> Skipper : Update Routes
            Skipper --> Operator : Routes Updated
        else Invalid FabricGateway
            Operator -> K8s : Reject FabricGateway
        end
    else Deleted FabricGateway
        Operator -> K8s : Delete Associated Ingress
        K8s --> Operator : Ingress Deleted
        
        Operator -> Skipper : Remove Routes
        Skipper --> Operator : Routes Removed
    end
end

@enduml