@startuml itselavia_edge-computing-platform-for-deep-learning-apps

actor User
participant "React Frontend" as Frontend
participant "Flask Backend" as Backend
participant "Model Manager" as ModelManager
participant "Kubernetes/KubeEdge" as K8s
participant "Google Cloud Storage" as GCS
participant "Cloud Function" as CloudFunction
participant "TensorRT Inference" as TensorRT

User -> Frontend : Upload model
Frontend -> Backend : POST /api/models
Backend -> GCS : Store model
Backend -> CloudFunction : Trigger TFLite conversion
CloudFunction -> GCS : Store TFLite model
CloudFunction --> Backend : Conversion complete
Backend -> ModelManager : Deploy model
ModelManager -> K8s : Create namespace and service account
ModelManager -> K8s : Deploy model as service
K8s -> GCS : Pull TFLite model
K8s -> TensorRT : Initialize inference engine
Backend --> Frontend : Deployment status
Frontend --> User : Display deployment result

User -> Frontend : Request inference
Frontend -> Backend : POST /api/inference
Backend -> K8s : Forward inference request
K8s -> TensorRT : Perform inference
TensorRT --> K8s : Inference result
K8s --> Backend : Return result
Backend --> Frontend : Send inference result
Frontend --> User : Display inference result

@enduml