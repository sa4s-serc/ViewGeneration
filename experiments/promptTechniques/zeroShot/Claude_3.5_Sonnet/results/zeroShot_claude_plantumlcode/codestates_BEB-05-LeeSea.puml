```plantuml
@startuml codestates_BEB-05-LeeSea

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Smart Contract>> LightBlue
  BackgroundColor<<Frontend>> LightGreen
  BackgroundColor<<State Management>> Yellow
  BackgroundColor<<Blockchain>> Pink
}

rectangle "LeeSeaNFT System" {
  [Web3.js] as Web3 <<Blockchain>>
  [Redux Store] as Redux <<State Management>>
  
  package "Smart Contracts" {
    [LeeSeaNFT.sol] as NFTContract <<Smart Contract>>
    [LeeSeaMarket.sol] as MarketContract <<Smart Contract>>
    [#utility.yul] as YulUtility <<Smart Contract>>
  }
  
  package "Frontend (React)" {
    [App.js] as App <<Frontend>>
    [Components] as Components <<Frontend>>
    [Redux Slices] as Slices <<State Management>>
  }
  
  cloud "Ethereum Blockchain" as Blockchain
}

App --> Components : uses
App --> Slices : uses
Slices --> Redux : manages state
Components --> Web3 : interacts
Web3 --> NFTContract : calls
Web3 --> MarketContract : calls
NFTContract --> YulUtility : uses
MarketContract --> YulUtility : uses
Web3 --> Blockchain : connects

@enduml
```