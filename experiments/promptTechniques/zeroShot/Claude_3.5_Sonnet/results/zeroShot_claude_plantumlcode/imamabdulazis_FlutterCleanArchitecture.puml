@startuml imamabdulazis_FlutterCleanArchitecture

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Core>> LightBlue
  BackgroundColor<<Feature>> LightGreen
  BackgroundColor<<External>> LightYellow
}

package "Core" {
  [Networking] <<Core>>
  [Error Handling] <<Core>>
  [Device Specific] <<Core>>
}

package "Features" {
  [Data Layer] <<Feature>>
  [Domain Layer] <<Feature>>
  [Presentation Layer] <<Feature>>
}

package "External Dependencies" {
  [flutter_bloc] <<External>>
  [get_it] <<External>>
  [dio] <<External>>
  [shared_preferences] <<External>>
  [Firebase Messaging] <<External>>
  [Sentry] <<External>>
}

[Main App] --> [Core]
[Main App] --> [Features]
[Main App] --> [External Dependencies]

[Data Layer] --> [Networking]
[Domain Layer] --> [Data Layer]
[Presentation Layer] --> [Domain Layer]
[Presentation Layer] --> [flutter_bloc]

[Core] --> [dio]
[Core] --> [Sentry]
[Core] --> [Firebase Messaging]

[Data Layer] --> [shared_preferences]
[Features] --> [get_it]

note right of [Main App]
  Initializes app, DI, and error handling
end note

note right of [Core]
  Handles networking, error management,
  and device-specific operations
end note

note right of [Features]
  Implements Clean Architecture layers
end note

note right of [External Dependencies]
  Third-party libraries for various functionalities
end note

@enduml