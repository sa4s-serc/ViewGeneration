@startuml OpenIPC_motors

participant "Camera Application" as App
participant "Motors Daemon" as Daemon
participant "Driver Wrapper" as Wrapper
participant "Kernel Driver" as KernelDriver
participant "Hardware" as Hardware

App -> Daemon : Initialize connection
Daemon -> Wrapper : Load appropriate driver
Wrapper -> KernelDriver : Open device file
KernelDriver -> Hardware : Initialize hardware

App -> Daemon : Send motor control command
Daemon -> Wrapper : Translate command
Wrapper -> KernelDriver : Issue ioctl call
KernelDriver -> Hardware : Control motor

Hardware --> KernelDriver : Motor status
KernelDriver --> Wrapper : Read status
Wrapper --> Daemon : Process status
Daemon --> App : Return command result

App -> Daemon : Request motor position
Daemon -> Wrapper : Get position
Wrapper -> KernelDriver : Read position
KernelDriver -> Hardware : Query position
Hardware --> KernelDriver : Return position
KernelDriver --> Wrapper : Position data
Wrapper --> Daemon : Format position
Daemon --> App : Return position

App -> Daemon : Close connection
Daemon -> Wrapper : Unload driver
Wrapper -> KernelDriver : Close device file
KernelDriver -> Hardware : Shutdown hardware

@enduml