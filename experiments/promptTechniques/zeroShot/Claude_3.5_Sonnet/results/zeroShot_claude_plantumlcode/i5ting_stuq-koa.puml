@startuml i5ting_stuq-koa

participant Client
participant "Koa.js Server" as Server
participant "Middleware Chain" as Middleware
participant "Router" as Router
participant "Controller" as Controller
participant "Model" as Model
database MongoDB

Client -> Server: HTTP Request
activate Server

Server -> Middleware: Pass request
activate Middleware

Middleware -> Router: Route request
activate Router

Router -> Controller: Handle request
activate Controller

Controller -> Model: Query/Update data
activate Model

Model -> MongoDB: Perform database operation
activate MongoDB

MongoDB --> Model: Return data
deactivate MongoDB

Model --> Controller: Return result
deactivate Model

Controller --> Router: Send response
deactivate Controller

Router --> Middleware: Pass response
deactivate Router

Middleware --> Server: Finalize response
deactivate Middleware

Server --> Client: HTTP Response
deactivate Server

@enduml