@startuml marklogic_cloud-enablement-aws

!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v15.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/Compute/EC2.puml
!include AWSPuml/Compute/Lambda.puml
!include AWSPuml/NetworkingContentDelivery/VPC.puml
!include AWSPuml/NetworkingContentDelivery/ElasticLoadBalancing.puml
!include AWSPuml/Storage/EBS.puml
!include AWSPuml/Database/DynamoDB.puml
!include AWSPuml/ManagementGovernance/CloudFormation.puml
!include AWSPuml/SecurityIdentityCompliance/IAM.puml

component "CloudFormation Stack" as CFStack {
    EC2(MarkLogicNodes, "MarkLogic EC2 Instances", "Multi-AZ deployment")
    EBS(DataVolumes, "EBS Volumes", "Distributed storage")
    VPC(Network, "VPC & Subnets", "Isolated network")
    ElasticLoadBalancing(ALB, "Application Load Balancer", "Traffic distribution")
    IAM(IAMRoles, "IAM Roles", "Access control")
    DynamoDB(StateTable, "DynamoDB State Table", "Cluster coordination")
}

Lambda(ManagedENI, "ManagedENI Lambda", "ENI management")
Lambda(NodeManager, "NodeManager Lambda", "Lifecycle events")

CloudFormation(NestedStack, "Nested Stacks", "Modular deployment")

CFStack --> ManagedENI : Invokes
CFStack --> NodeManager : Invokes
CFStack --> NestedStack : Includes

MarkLogicNodes --> DataVolumes : Uses
MarkLogicNodes --> Network : Deployed in
ALB --> MarkLogicNodes : Routes traffic
MarkLogicNodes --> StateTable : Coordinates state

note right of CFStack
  Deployment:
  - Multi-AZ for high availability
  - Modular stack design
  - Parameterized resources
end note

note bottom of NodeManager
  Performance:
  - Event-driven architecture
  - Efficient ENI management
  - Auto Scaling integration
end note

@enduml