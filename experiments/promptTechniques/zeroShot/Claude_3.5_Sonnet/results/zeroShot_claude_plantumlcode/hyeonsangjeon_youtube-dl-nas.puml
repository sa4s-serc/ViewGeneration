@startuml
!theme plain
skinparam maxMessageSize 250

actor User
participant "Web Interface" as WebUI
participant "REST API" as API
participant "Web Server" as Server
participant "Authentication" as Auth
participant "Download Queue" as Queue
participant "Download Worker" as Worker
participant "WebSocket" as WS
participant "yt-dlp/youtube-dl" as YTDLPTool

User -> WebUI : Access web interface
WebUI -> Auth : Authenticate user
Auth --> WebUI : Authentication result

alt Authentication successful
    User -> WebUI : Submit download request
    WebUI -> Server : Send download request
    Server -> Auth : Verify authentication
    Auth --> Server : Authentication verified
    Server -> Queue : Add download to queue
    Queue --> Server : Confirm queue addition
    Server --> WebUI : Request accepted
    WebUI --> User : Display confirmation

    Worker -> Queue : Poll for new downloads
    Queue --> Worker : Provide next download
    Worker -> YTDLPTool : Execute download
    YTDLPTool --> Worker : Download progress
    Worker -> WS : Send progress updates
    WS --> WebUI : Real-time progress
    WebUI --> User : Display progress

    YTDLPTool --> Worker : Download complete
    Worker -> WS : Send completion notification
    WS --> WebUI : Notify completion
    WebUI --> User : Display completion
else Authentication failed
    WebUI --> User : Display error
end

User -> API : Send REST API request
API -> Auth : Authenticate request
Auth --> API : Authentication result

alt API Authentication successful
    API -> Server : Process API request
    Server -> Queue : Add download to queue
    Queue --> Server : Confirm queue addition
    Server --> API : Request accepted
    API --> User : Return success response
else API Authentication failed
    API --> User : Return error response
end

@enduml