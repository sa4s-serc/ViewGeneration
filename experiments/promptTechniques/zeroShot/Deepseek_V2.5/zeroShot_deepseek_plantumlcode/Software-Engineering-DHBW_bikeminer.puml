```plantuml
@startuml Software-Engineering-DHBW_bikeminer

skinparam componentStyle uml2
skinparam monochrome true
skinparam nodesep 10
skinparam ranksep 20

title Bikeminer Data Flow Architecture

component "Flutter App" as flutter {
    component "UI Pages" as flutter_ui
    component "API Connector" as flutter_api
    component "Local Storage" as flutter_storage
}

component "Android App" as android {
    component "MapsActivity" as android_maps
    component "GPS Service" as android_gps
    component "Reward System" as android_rewards
}

component "Backend API" as backend {
    component "FastAPI Server" as fastapi
    component "Auth Service" as auth
    component "Ride Service" as ride_service
    component "Wallet Service" as wallet_service
}

component "Database" as db {
    component "MariaDB" as mariadb
}

flutter_ui --> flutter_api : "API calls"
flutter_api --> fastapi : "REST requests"
flutter_storage --> flutter_ui : "Local data"

android_maps --> android_gps : "Location data"
android_rewards --> android_maps : "Ride data"
android_gps --> fastapi : "GPS coordinates"
android_rewards --> fastapi : "Reward updates"

fastapi --> auth : "Authentication"
fastapi --> ride_service : "Ride processing"
fastapi --> wallet_service : "Wallet operations"
ride_service --> mariadb : "Store ride data"
wallet_service --> mariadb : "Update balances"
auth --> mariadb : "User credentials"

note right of flutter
Handles user interactions,
displays maps/rides/wallet,
stores local preferences
end note

note left of android
Legacy app tracking GPS,
calculating rewards,
sending data to backend
end note

note bottom of backend
Processes API requests,
manages authentication,
calculates BikeCoins,
stores ride history
end note

@enduml
```