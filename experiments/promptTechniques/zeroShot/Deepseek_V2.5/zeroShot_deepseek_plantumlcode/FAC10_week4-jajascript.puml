```plantuml
@startuml FAC10_week4-jajascript

component "Frontend" as frontend {
    component "index.html" as html
    component "main.css" as css
    component "main.js" as mainjs
}

component "Backend" as backend {
    component "server.js" as server
    component "router.js" as router
    component "handler.js" as handler
    component "algorithm.js" as algorithm
    component "data.json" as data
}

component "Testing" as testing {
    component "qunit.html" as qunit
    component "frontendTests.js" as frontTests
    component "backendTests.js" as backTests
}

frontend --> backend : HTTP requests
mainjs --> server : fetch(/search/:query)
server --> router : routes requests
router --> handler : handles static files
router --> algorithm : handles /search
algorithm --> data : reads laureate data

testing --> frontend : tests UI components
testing --> backend : tests API logic

@enduml
```