```plantuml
@startuml krishnaprasadkv_Linux-Commands

skinparam componentStyle uml2
skinparam monochrome true

package "Linux Command Tutorial System" {
    component "README.md" as readme {
        [Main Index]
        [OS Concepts]
        [Linux Architecture]
        [File System Hierarchy]
    }

    component "Basic Commands" as basic {
        [pwd]
        [ls]
        [cd]
    }

    component "Filter Commands" as filter {
        [less]
        [grep]
        [sed]
        [head/tail]
    }

    component "File Management" as files {
        [find]
        [ln]
        [chmod]
        [chown]
    }

    component "Process Management" as process {
        [top]
        [kill]
        [ps]
    }

    component "User/Group Admin" as admin {
        [useradd]
        [usermod]
        [groupadd]
    }

    component "Editors" as editors {
        [VI/VIM]
    }

    component "Jekyll Config" as jekyll {
        [_config.yml]
    }
}

readme --> basic : links to
readme --> filter : links to
readme --> files : links to
readme --> process : links to
readme --> admin : links to
readme --> editors : links to

basic --> files : related
filter --> files : operates on
process --> admin : manages
admin --> files : manages permissions

jekyll ..> readme : renders
jekyll ..> basic : renders
jekyll ..> filter : renders

@enduml
```