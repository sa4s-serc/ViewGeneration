```plantuml
@startuml OpenRoberta_robertalab-ev3dev

package "Open Roberta Lab EV3 Connector" {
    [Brickman UI] as ui
    [roberta.lab.Service] as service
    [roberta.lab.Connector] as connector
    [roberta.ev3.Hal] as hal
    [roberta.lab.AbortHandler] as abort
    [roberta.lab.GfxMode] as gfx
    [ev3dev.auto] as ev3dev
    [Open Roberta Lab Server] as server

    ui -[dashed]-> service : DBus interface
    service --> connector : manages
    service --> abort : manages
    service --> gfx : manages
    connector --> server : HTTP requests
    connector --> hal : uses
    hal --> ev3dev : hardware access
    abort --> ev3dev : key press detection
    gfx --> ev3dev : display control

    note right of connector
        Handles network communication,
        code download/execution,
        and retry mechanisms
    end note

    note left of hal
        Hardware Abstraction Layer
        for motors, sensors,
        display, LEDs, sound
    end note
}

@enduml
```