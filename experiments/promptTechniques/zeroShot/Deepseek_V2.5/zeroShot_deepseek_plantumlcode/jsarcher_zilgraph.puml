```plantuml
@startuml jsarcher_zilgraph

skinparam componentStyle uml2
skinparam monochrome true
skinparam nodesep 10
skinparam ranksep 20

title Zilgraph Deployment and Data Flow Architecture

component "Zilliqa Blockchain" as zilliqa {
    [Zilswap Smart Contract]
}

component "Zilcrawler" as crawler {
    [pyzil Client]
    [Crawler Service]
}

component "Elasticsearch" as elastic {
    [Raw Data Storage]
}

component "MongoDB" as mongo {
    [Aggregated Data]
}

component "Data Processing" as processing {
    [Zilswap Aggregator]
    [Zillog Service]
}

component "Bokeh Server" as bokeh {
    [Dashboard UI]
    [Interactive Charts]
}

component "Kibana" as kibana {
    [Analytics Dashboard]
}

component "Nginx" as nginx {
    [Reverse Proxy]
    [SSL Termination]
}

[Zilswap Smart Contract] --> [pyzil Client] : Fetch transactions
[pyzil Client] --> [Crawler Service] : Process raw data
[Crawler Service] --> [Raw Data Storage] : Store raw transactions

[Raw Data Storage] --> [Zilswap Aggregator] : Query raw data
[Zilswap Aggregator] --> [Aggregated Data] : Store processed data
[Zillog Service] --> [Aggregated Data] : Read/Write

[Aggregated Data] --> [Dashboard UI] : Serve aggregated data
[Aggregated Data] --> [Analytics Dashboard] : Serve analytics data

[Interactive Charts] --> [Reverse Proxy] : HTTP/HTTPS
[Analytics Dashboard] --> [Reverse Proxy] : HTTP/HTTPS
[Reverse Proxy] --> [SSL Termination] : Secure traffic

@enduml
```