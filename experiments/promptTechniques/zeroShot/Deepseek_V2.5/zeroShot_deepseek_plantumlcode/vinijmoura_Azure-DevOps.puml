```plantuml
@startuml vinijmoura_Azure-DevOps

component "Azure DevOps" as azuredevops {
    [Azure DevOps REST APIs]
    [Azure DevOps CLI]
}

component "PowerShell Scripts" as powershell {
    [Extract Data]
    [Transform Data]
    [Load Data]
}

component "Azure SQL Database" as sqldb {
    [AreaPermissions]
    [VariableGroups]
    [FeedPackageVersions]
    [EnvironmentsDeploys]
    [ProcessesWorkItemsFields]
    [TeamSettingsBoards]
    [PersonalAccessTokens]
    [ReleaseDefinitionsClassic]
}

component "Power BI" as powerbi {
    [Power BI Desktop (.pbix)]
    [Custom Visuals]
    [Data Model]
    [Reports]
}

azuredevops --> powershell : "Extracts data via\nREST APIs & CLI"
powershell --> sqldb : "Transforms & loads data\nvia SQL queries"
sqldb --> powerbi : "Connects to\nvisualize data"

@enduml
```