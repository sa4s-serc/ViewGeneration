```plantuml
@startuml argrecsys_argael

package "ARGAEL Application" {
    [ArgaelForm] as GUI
    [DataManager] as Data
    [IOManager] as IO
    [ArgumentModel] as Model
    [ReportFormatter] as Report
    [InitParams] as Config

    GUI --> Data : manages
    GUI --> IO : uses
    GUI --> Report : generates
    Data --> Model : stores
    Config --> IO : reads params.json
    Report --> IO : uses templates
}

[users.txt] as Users
[params.json] as Params
[HTML Templates] as Templates
[Proposals Data] as Proposals

IO --> Users : reads
IO --> Params : reads
IO --> Templates : reads
IO --> Proposals : reads/writes

@enduml
```