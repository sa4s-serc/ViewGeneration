```plantuml
@startuml teamgram_teamgram-server

skinparam componentStyle uml2
skinparam monochrome true
skinparam nodesep 20
skinparam ranksep 30

rectangle "Client Layer" as clients {
    component "Mobile App" as mobile
    component "Web App" as web
    component "Desktop App" as desktop
}

rectangle "Edge Layer" as edge {
    component "Load Balancer" as lb
    component "API Gateway" as gateway
}

rectangle "BFF Layer" as bff {
    component "Messages BFF" as messages_bff
    component "Privacy BFF" as privacy_bff
}

rectangle "Core Services" as core {
    component "msg" as msg
    component "chat" as chat
    component "user" as user
    component "authsession" as authsession
    component "media" as media
    component "username" as username
    component "dialog" as dialog
    component "updates" as updates
}

rectangle "Infrastructure Services" as infra {
    component "idgen" as idgen
    component "dfs" as dfs
    component "code" as code
}

database "MySQL" as mysql {
    component "User Tables" as user_tables
    component "Chat Tables" as chat_tables
    component "Message Tables" as msg_tables
}

database "Redis" as redis {
    component "Session Cache" as session_cache
    component "Phone Code Cache" as phone_cache
}

queue "Kafka" as kafka {
    component "Message Events" as msg_events
    component "Update Events" as update_events
}

storage "MinIO" as minio {
    component "Media Storage" as media_storage
}

node "Etcd" as etcd {
    component "Service Registry" as registry
}

' Connections
clients --> lb : HTTP/HTTPS
lb --> gateway : HTTP/HTTPS
gateway --> bff : HTTP/HTTPS

bff --> core : gRPC
core --> infra : gRPC

core --> mysql : SQL
core --> redis : Key-Value
core --> kafka : Pub/Sub
infra --> minio : S3 API
core --> etcd : Service Discovery

' Internal connections
mobile -up-> web
web -up-> desktop

messages_bff -up-> privacy_bff

msg -up-> chat
chat -up-> user
user -up-> authsession
authsession -up-> media
media -up-> username
username -up-> dialog
dialog -up-> updates

idgen -up-> dfs
dfs -up-> code

user_tables -up-> chat_tables
chat_tables -up-> msg_tables

session_cache -up-> phone_cache
msg_events -up-> update_events

@enduml
```