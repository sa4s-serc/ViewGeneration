```plantuml
@startuml microsoft_azure-realtime-fraud-detection

skinparam componentStyle uml2
skinparam monochrome true
skinparam nodesep 20
skinparam ranksep 30

title Fraud Detection Platform Deployment Architecture

component "Event Generator" as generator {
    [Transaction Simulator]
}

node "Azure Cloud" {
    component "Azure Event Hub" as eventhub {
        [Real-time Ingest]
    }

    component "Azure Stream Analytics" as streamanalytics {
        [Event Processing]
        [Data Enrichment]
    }

    component "Azure Machine Learning" as ml {
        [Model Training]
        [Fraud Scoring]
    }

    component "Azure Functions" as functions {
        [Orchestration]
        [Benford's Law]
        [Fraud Ring Detection]
    }

    database "Azure Cosmos DB" as cosmosdb {
        [SQL API] as sqlapi
        [Gremlin API] as gremlinapi
    }

    database "Azure Synapse Analytics" as synapse {
        [Data Warehouse]
    }
}

[Transaction Simulator] --> [Real-time Ingest] : JSON events
[Real-time Ingest] --> [Event Processing] : Stream
[Event Processing] --> [Data Enrichment] : Enriched events
[Data Enrichment] --> [Fraud Scoring] : Score requests
[Fraud Scoring] --> [Data Enrichment] : Fraud scores
[Data Enrichment] --> [SQL API] : Transaction data
[Data Enrichment] --> [Data Warehouse] : Historical data
[Orchestration] --> [Benford's Law] : Trigger
[Orchestration] --> [Fraud Ring Detection] : Trigger
[Fraud Ring Detection] --> [Gremlin API] : Graph queries
[SQL API] --> [Orchestration] : Transaction data
[Gremlin API] --> [Fraud Ring Detection] : Relationship data

note top of eventhub
High-throughput event ingestion
for real-time processing
end note

note right of streamanalytics
Low-latency stream processing
with windowed aggregations
end note

note left of ml
Model deployed as web service
for real-time scoring
end note

note bottom of functions
Serverless execution
for cost-efficient scaling
end note

@enduml
```