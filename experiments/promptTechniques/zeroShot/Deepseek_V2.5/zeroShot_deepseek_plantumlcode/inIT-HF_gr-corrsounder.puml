    }

    component "Python Bindings (SWIG)" as swig_bindings

    component "pycorrsounder" {
        component "Core Algorithms" as core_algs
        component "Utilities" as utils
    }

    component "GRC Block Definitions" as grc_defs
    component "Unit Tests" as unit_tests
    component "Documentation Parser" as doc_parser
}

component "User Applications" as user_apps {
    component "Example Flowgraphs" as examples
    component "Custom Scripts" as scripts
}

gr_runtime --> cpp_blocks : uses
grc --> grc_defs : loads
cpp_blocks <-- swig_bindings : exposes
swig_bindings --> pycorrsounder : integrates
