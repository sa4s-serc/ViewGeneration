```plantuml
@startuml SimonLdj_hypnolog-server

package "HypnoLog Server" {
    component "Express Web Server" as express {
        component "Routes" as routes {
            component "logger.js" as logger
            component "index.js" as index
        }
        component "app.js" as app
        component "bin/www" as bin
    }

    component "Socket.IO" as socketio

    component "Data Processing" as processing {
        component "Ajv Validator" as ajv
    }

    database "Config Files" as config {
        component "config.json" as configjson
    }
}

package "Client Web UI" {
    component "Web Browser" as browser {
        component "client.html" as clienthtml
        component "client.js" as clientjs
        component "SystemJS" as systemjs
        component "jQuery" as jquery

        package "Visualization" {
            component "WindowsDispatcher" as windowsdispatcher
            component "VisualizerDispatcher" as visualizerdispatcher
            component "ConfigFactory" as configfactory
            component "WindowsFilter" as windowsfilter

            folder "Visualizers" as visualizers {
                component "StringVisualizer" as stringviz
                component "NumberVisualizer" as numberviz
                component "ObjectVisualizer" as objectviz
            }
        }
    }
}

express --> socketio : "broadcasts data"
socketio --> browser : "real-time updates"
browser --> express : "HTTP requests"

logger --> processing : "validates data"
processing --> ajv : "uses"
ajv --> configjson : "reads schema"

clientjs --> windowsdispatcher : "manages"
clientjs --> visualizerdispatcher : "manages"
windowsdispatcher --> windowsfilter : "extends"
visualizerdispatcher --> visualizers : "selects"
configfactory --> configjson : "reads"

clienthtml --> systemjs : "module loader"
clienthtml --> jquery : "DOM manipulation"

@enduml
```