```plantuml
@startuml SafeBreach-Labs_hAFL2

package "Host Machine (Linux)" {
    component "KVM" {
        component "Modified KVM Module" as kvm_module
        component "Intel PT Support" as intel_pt
    }

    component "QEMU" {
        component "Modified QEMU" as qemu
        component "Hypercall Handler" as hypercall
        component "Redqueen" as redqueen
    }

    component "kAFL Fuzzer" {
        component "Master" as master
        component "Slave" as slave
        component "GUI" as gui
    }
}

package "Root Partition (Windows)" {
    component "Hyper-V Root" as hyperv_root {
        component "VMSwitch" as vmswitch
        component "CrashMonitoringDriver" as crash_driver
    }
}

package "Child Partition (Windows)" {
    component "Hyper-V Child" as hyperv_child {
        component "CPHarness" as cpharness
        component "Fuzzing Harness" as harness
    }
}

' Connections
kvm_module --> intel_pt : "Intel PT\nTracing"
qemu --> kvm_module : "KVM API"
master --> slave : "Task Distribution"
slave --> qemu : "Execute Target"
hyperv_root --> hyperv_child : "Nested Virtualization"
cpharness --> vmswitch : "RNDIS Packets"
vmswitch --> crash_driver : "Crash Reports"
crash_driver --> qemu : "Hypercalls"
qemu --> hypercall : "Process Hypercalls"
hypercall --> redqueen : "Feedback"
redqueen --> slave : "Mutation Guidance"
gui --> master : "Monitoring"

note right of kvm_module
    Modified for hypercall handling
    and Intel PT support
end note

note right of qemu
    Custom modifications for
    hAFL2 fuzzing support
end note

@enduml
```