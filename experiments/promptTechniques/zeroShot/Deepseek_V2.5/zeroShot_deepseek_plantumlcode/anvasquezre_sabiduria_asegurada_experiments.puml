```plantuml
@startuml anvasquezre_sabiduria_asegurada_experiments

actor User
participant "Chainlit UI" as UI
participant "Langchain Agent" as Agent
participant "Qdrant DB" as Qdrant
participant "Google Search API" as Google
participant "S3 Storage" as S3
participant "Data Preloader" as Preloader

User -> UI : Ask policy question
UI -> Agent : Forward question
activate Agent

alt Policy Question
    Agent -> Qdrant : Semantic search
    Qdrant --> Agent : Policy chunks
else News/Current Events
    Agent -> Google : Search query
    Google --> Agent : Search results
end

Agent --> UI : Formatted response
deactivate Agent
UI -> User : Display answer

group Data Loading (Periodic/Initial)
    Preloader -> S3 : Download PDFs
    S3 --> Preloader : Policy documents
    Preloader -> Preloader : Split into chunks
    Preloader -> Preloader : Generate embeddings
    Preloader -> Qdrant : Store vectors
end

@enduml
```