```plantuml
@startuml GoogleCloudPlatform_datacatalog-tag-engine

component "Cloud Run (UI Service)" as ui_service {
    component "Web UI" as web_ui
    component "Jinja2 Templates" as templates
}

component "Cloud Run (API Service)" as api_service {
    component "Flask API" as flask_api
    component "TagEngineStoreHandler" as store_handler
    component "DataCatalogController" as dc_controller
    component "DataplexController" as dp_controller
    component "BigQueryUtils" as bq_utils
    component "TaskManager" as task_manager
    component "JobManager" as job_manager
    component "Access Control" as access
}

database "Firestore" as firestore {
    component "Configurations" as configs
    component "Job Status" as job_status
}

queue "Cloud Tasks" as cloud_tasks {
    component "Async Jobs" as async_jobs
}

database "BigQuery" as bigquery {
    component "Tag History" as tag_history
    component "Exported Tags" as exported_tags
}

cloud "Google Cloud Data Catalog" as data_catalog
cloud "Google Cloud Dataplex" as dataplex
cloud "Google Cloud Storage" as gcs

web_ui --> templates
web_ui --> flask_api : API calls

flask_api --> store_handler : CRUD operations
flask_api --> dc_controller : Tag operations
flask_api --> dp_controller : Aspect operations
flask_api --> bq_utils : Metadata queries
flask_api --> task_manager : Job creation
flask_api --> job_manager : Job tracking
flask_api --> access : Auth validation

store_handler --> firestore : Read/write configs
job_manager --> firestore : Update job status
task_manager --> cloud_tasks : Create tasks

dc_controller --> data_catalog : API calls
dp_controller --> dataplex : API calls
bq_utils --> bigquery : Query metadata

cloud_tasks --> api_service : Trigger jobs
api_service --> bigquery : Write tag history
api_service --> gcs : Import/export files

@enduml
```