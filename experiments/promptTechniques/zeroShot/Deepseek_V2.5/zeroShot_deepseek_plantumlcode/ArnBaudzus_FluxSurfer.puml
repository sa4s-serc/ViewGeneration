```plantuml
@startuml ArnBaudzus_FluxSurfer

package "Core Quantum System" {
    [QuantumSystem] as QuantumSystem
    [State] as State
    [Edge] as Edge
    QuantumSystem *-- State
    QuantumSystem *-- Edge
}

package "Solvers" {
    interface "Solver" <<interface>> as Solver
    abstract "SingleStepScheme" <<abstract>> as SingleStepScheme
    [EulerForward] as EulerForward
    [RichardsonSolver] as RichardsonSolver
    [MonteCarloWanderer] as MonteCarloWanderer
    [SingleStepODESolver] as SingleStepODESolver
    
    Solver <|-- SingleStepODESolver
    Solver <|-- MonteCarloWanderer
    SingleStepScheme <|-- EulerForward
    SingleStepScheme <|-- RichardsonSolver
    SingleStepODESolver --> SingleStepScheme
}

package "Parallel Processing" {
    [Experiment] as Experiment
    [WorkSource] as WorkSource
    Experiment --> WorkSource
    Experiment --> QuantumSystem
    Experiment --> Solver
}

package "Data Management" {
    [DataSet] as DataSet
    [GraphML Writer] as GraphMLWriter
    [JSON Metadata] as JSONMetadata
    [CSV Metadata] as CSVMetadata
    
    DataSet --> GraphMLWriter
    DataSet --> JSONMetadata
    DataSet --> CSVMetadata
}

package "Utilities" {
    [BinaryNumberUtility] as BinaryNumberUtility
    [XML Parser] as XMLParser
}

package "Python Tools" {
    [fileUtility.py] as FileUtility
    [quantities.py] as Quantities
    [plotChargeCurve.py] as Plotter
    [menu.py] as Menu
}

' Core relationships
QuantumSystem --> DataSet
QuantumSystem --> GraphMLWriter

' Experiment relationships
Experiment --> DataSet
Experiment --> JSONMetadata
Experiment --> CSVMetadata

' Utilities usage
QuantumSystem ..> BinaryNumberUtility
GraphMLWriter ..> XMLParser

' Python tools interaction
FileUtility ..> GraphMLWriter
Quantities ..> DataSet
Plotter ..> DataSet

note right of QuantumSystem
    Represents quantum system as graph
    (states = nodes, transitions = edges)
end note

note left of Solvers
    Implements Strategy pattern
    for different solving approaches
end note

note bottom of Parallel\ Processing
    Uses Producer-Consumer pattern
    with WorkSource queue
end note

@enduml
```