```plantuml
@startuml nightingaleproject_Reference-Client

actor User
participant "React UI" as UI
participant "RecordController" as Controller
participant "TimedHostedService" as Service
participant "VRDR.Client" as VRDR
participant "NVSS API Server" as NVSS
participant "PostgreSQL" as DB

User -> UI : Uploads VRDR Record
UI -> Controller : POST /api/record (JSON)
Controller -> DB : Store MessageItem
Controller -> UI : 200 OK

group Background Processing [Security Context]
    Service -> DB : Poll for new messages (Auth Token)
    DB -> Service : Return pending messages
    Service -> VRDR : Create FHIR message (Signed)
    VRDR -> Service : Return signed message
    Service -> NVSS : Submit message (HTTPS/TLS)
    NVSS -> Service : Return Acknowledgement (Signed)
    Service -> DB : Store ResponseItem
    Service -> NVSS : Poll for responses (Auth Token)
    NVSS -> Service : Return signed responses
    Service -> DB : Update Message status
end

User -> UI : Check message status
UI -> Controller : GET /api/record/status
Controller -> DB : Query MessageItems
DB -> Controller : Return status data
Controller -> UI : Return status JSON

@enduml
```