```plantuml
@startuml cordon-thiago_airflow-spark

skinparam componentStyle uml2
skinparam monochrome true
skinparam nodesep 20
skinparam ranksep 30

package "Deployment Environment" {
  [Kubernetes Cluster] as k8s <<container>> {
    component "Airflow Scheduler" as airflow_scheduler <<Airflow>> #lightgreen
    component "Airflow Workers" as airflow_workers <<Airflow>> #lightgreen
    component "Spark Driver" as spark_driver <<Spark>> #lightblue
    component "Spark Executors" as spark_executors <<Spark>> #lightblue
  }

  database "PostgreSQL" as postgres <<database>> #pink
  queue "Kafka" as kafka <<message queue>> #orange
}

[External Data Sources] as ext_data <<data source>> #grey
[HDFS] as hdfs <<distributed storage>> #darkblue

airflow_scheduler --> airflow_workers : Orchestrates tasks
airflow_workers --> spark_driver : Submits Spark jobs
spark_driver --> spark_executors : Distributes tasks
spark_executors --> postgres : Reads/Writes data
spark_driver --> ext_data : Ingests data
spark_driver --> hdfs : Reads/Writes files
spark_executors --> kafka : Streams data

note right of k8s
  Containerized deployment includes:
  - Airflow with CeleryExecutor
  - Spark on Kubernetes
  - PostgreSQL for metadata
end note

@enduml
```