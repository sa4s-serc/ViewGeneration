```plantuml
@startuml nforge_devnote

package "NForge DevNote" {
    [Main Application] as app
    [Express Server] as express
    [Socket.IO] as socketio
    [Git Repository] as git

    package "Core Modules" {
        [Wiki Module] as wiki
        [User Management] as users
        [File Attachment] as files
        [Admin Tasks] as admin
        [Localization] as i18n
    }

    package "Client Side" {
        [Markdown Editor] as editor
        [Real-time Updates] as realtime
        [UI Components] as ui
    }

    package "Supporting Libraries" {
        [CodeMirror] as codemirror
        [jQuery] as jquery
        [Bootstrap] as bootstrap
        [Underscore.js] as underscore
    }
}

app --> express
app --> socketio
app --> git

express --> wiki
express --> users
express --> files
express --> admin
express --> i18n

socketio --> realtime

wiki --> editor
users --> ui
files --> ui
admin --> ui
i18n --> ui

editor --> codemirror
ui --> jquery
ui --> bootstrap
ui --> underscore

@enduml
```