```plantuml
@startuml afonsocastro_larcc_interface

package "ROS Ecosystem" {
    [ROS Master] as ros_master
    [MoveIt!] as moveit
    [RViz] as rviz
    [RealSense2 Camera] as realsense
}

package "UR10e Robot System" {
    [UR10e Controller] as ur10e_controller
    [ROBOTIQ 2F-140 Gripper] as gripper
    [UR Kinematics Solver] as ur_kinematics
}

package "LARCC Workcell" {
    [Workcell Description (URDF/Xacro)] as workcell_desc
    [3D Models (.DAE)] as dae_models
}

package "Interface Components" {
    [URCap Files] as urcap
    [Configuration Files] as config
    [Python Wrappers] as python_wrappers
}

ros_master -- moveit
moveit -- ur10e_controller
moveit -- rviz
realsense -- ros_master
ur10e_controller -- gripper
ur10e_controller -- ur_kinematics
workcell_desc -- moveit
workcell_desc -- dae_models
urcap -- ur10e_controller
config -- ur10e_controller
python_wrappers -- ur_kinematics

note right of ros_master
    Central communication hub
    for all ROS components
end note

note bottom of moveit
    Motion planning framework
    with IK/FK capabilities
end note

note left of ur_kinematics
    Analytical kinematics solver
    (C++ with Python wrappers)
end note

@enduml
```