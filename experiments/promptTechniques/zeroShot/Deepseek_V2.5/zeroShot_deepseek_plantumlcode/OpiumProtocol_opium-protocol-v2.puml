```plantuml
@startuml OpiumProtocol_opium-protocol-v2

actor User
participant "Registry" as Registry
participant "Core" as Core
participant "SyntheticAggregator" as SyntheticAggregator
participant "OracleAggregator" as OracleAggregator
participant "OpiumProxyFactory" as OpiumProxyFactory
participant "TokenSpender" as TokenSpender

User -> Registry: getCoreAddress()
Registry --> User: Core address

User -> Core: createDerivative(derivativeData)
Core -> Registry: getSyntheticAggregatorAddress()
Registry --> Core: SyntheticAggregator address

Core -> SyntheticAggregator: validateDerivative(derivativeData)
SyntheticAggregator -> Registry: getOracleAggregatorAddress()
Registry --> SyntheticAggregator: OracleAggregator address

SyntheticAggregator -> OracleAggregator: validateOracleId(derivativeData.oracleId)
OracleAggregator --> SyntheticAggregator: validation result
SyntheticAggregator --> Core: validation result

Core -> Registry: getOpiumProxyFactoryAddress()
Registry --> Core: OpiumProxyFactory address

Core -> OpiumProxyFactory: createPositionTokens(derivativeData)
OpiumProxyFactory --> Core: (longToken, shortToken)

Core -> Registry: getTokenSpenderAddress()
Registry --> Core: TokenSpender address

Core -> TokenSpender: transferFrom(user, core, marginAmount)
TokenSpender --> Core: transfer result

Core --> User: derivativeCreated(longToken, shortToken)

@enduml
```