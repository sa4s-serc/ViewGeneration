```plantuml
@startuml marklogic_cloud-enablement-aws

!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v16.0/dist
!includeurl AWSPuml/AWSCommon.puml
!includeurl AWSPuml/Compute/all.puml
!includeurl AWSPuml/Database/all.puml
!includeurl AWSPuml/NetworkingContentDelivery/all.puml
!includeurl AWSPuml/ManagementGovernance/all.puml
!includeurl AWSPuml/SecurityIdentityCompliance/all.puml

skinparam componentStyle uml2
skinparam monochrome true
skinparam defaultFontName Arial
skinparam defaultTextAlignment center

package "MarkLogic Cluster on AWS" {
    component "CloudFormation Templates" as cft {
        component "mlcluster.template" as mlcluster
        component "mlcluster-vpc.template" as mlvpc
    }

    component "Lambda Functions" as lambda {
        component "managedeni.py" as eni
        component "nodemanager.py" as nodemgr
        component "utils.py" as utils
    }

    component "AWS Resources" as aws {
        EC2 -right-> EBS
        EC2 -right-> AutoScaling
        EC2 -right-> IAM

        VPC -down-> Subnet
        VPC -down-> SecurityGroup
        Subnet -down-> ENI

        DynamoDB -up-> "MarkLogicDDBTable"
        ALB -up-> TargetGroups
    }

    component "MarkLogic Nodes" as ml {
        component "Node 1" as node1
        component "Node 2" as node2
        component "Node N" as nodeN
    }
}

' Relationships
mlcluster --> eni : "Custom::ManagedEni"
mlcluster --> nodemgr : "Lifecycle Hook"
mlvpc --> VPC : "Creates"
eni --> ENI : "Manages"
nodemgr --> ENI : "Attaches"
nodemgr --> DynamoDB : "Updates state"
AutoScaling --> node1 : "Launches"
AutoScaling --> node2 : "Launches"
AutoScaling --> nodeN : "Launches"
ALB --> node1 : "Routes traffic"
ALB --> node2 : "Routes traffic"
ALB --> nodeN : "Routes traffic"
node1 --> DynamoDB : "Cluster state"
node2 --> DynamoDB : "Cluster state"
nodeN --> DynamoDB : "Cluster state"

' Deployment & Performance Notes
note top of cft
  **Deployment**:
  - Templates support both new/existing VPCs
  - Multi-AZ deployments
  - Auto-scaling configuration
end note

note right of lambda
  **Performance**:
  - Dedicated ENIs per node
  - Lifecycle event handling
  - State coordination via DynamoDB
end note

note bottom of aws
  **Scalability**:
  - ALB for traffic distribution
  - Auto-scaling group management
  - EBS volumes for storage
end note

@enduml
```