@startuml lkmSasanga_fas-web-app

skinparam component {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
}

package "Firebase Hosting" #FFA611 {
    component "Web App" as webapp
}

package "React Frontend" #61DAFB {
    component "App (Router)" as app
    component "Login/Signup" as auth
    component "InputControl (Search)" as search
    component "RequestData (API Client)" as api
    component "Dashboard" as dashboard
    component "Charts" as charts
    component "UI Components" as ui {
        component "Backdrop"
        component "Spinner"
        component "Cards"
        component "Navigation"
    }
}

package "Bootstrap CSS" #7952B3 {
    component "Styles" as bootstrap
}

package "Heroku Backend" #430098 {
    component "Sentiment API" as sentimentapi
}

webapp --> app : hosts
app --> auth : routes to
app --> search : routes to
search --> api : triggers
api --> sentimentapi : GET /sentiment
dashboard --> charts : renders
dashboard --> api : consumes data
app --> ui : uses
ui --> bootstrap : applies styles
charts --> api : fetches data

@enduml