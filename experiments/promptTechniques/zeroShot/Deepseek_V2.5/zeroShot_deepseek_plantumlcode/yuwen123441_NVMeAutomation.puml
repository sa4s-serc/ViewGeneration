```plantuml
@startuml yuwen123441_NVMeAutomation

package "Test Layer" {
    [Test Cases] as TestCases
    [Test Suites] as TestSuites
}

package "Logic Layer" {
    [Admin Commands] as AdminCommands
    [IO Commands] as IOCommands
    [Buffer Management] as BufferManagement
}

package "Driver Layer" {
    [Python Wrapper] as PythonWrapper
    [Data Structures] as DataStructures
    [Dynamic Library] as DynamicLibrary
}

package "System Layer" {
    [Linux Kernel] as LinuxKernel
    [NVMe Driver] as NVMeDriver
    [ioctl Interface] as ioctlInterface
}

TestCases --> AdminCommands
TestCases --> IOCommands
TestSuites --> TestCases

AdminCommands --> PythonWrapper
IOCommands --> PythonWrapper
BufferManagement --> PythonWrapper

PythonWrapper --> DynamicLibrary
PythonWrapper --> DataStructures

DynamicLibrary --> ioctlInterface
DataStructures --> ioctlInterface

ioctlInterface --> NVMeDriver
NVMeDriver --> LinuxKernel

@enduml
```