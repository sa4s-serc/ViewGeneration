```plantuml
@startuml alexandredev3_nodejs-clean-architeture

skinparam componentStyle uml2
skinparam monochrome true

package "External Systems" {
  [PostgreSQL] as postgres
  [Redis] as redis
}

package "Infrastructure Layer" {
  component "Express" as express {
    [Routes]
    [Middlewares]
  }

  component "TypeORM" as typeorm {
    [Entities]
    [Migrations]
  }

  component "Redis Client" as redisClient
}

package "Application Layer" {
  component "User Services" as userServices {
    [CreateUserService]
    [AuthenticateUserService]
    [ListAllUsersService]
  }

  component "Cache Provider" as cacheProvider {
    interface "ICacheProvider" as iCache
    [RedisCacheProvider]
    [FakeCacheProvider]
  }

  component "Hash Provider" as hashProvider {
    interface "IHashProvider" as iHash
    [BcryptHashProvider]
    [FakeHashProvider]
  }
}

package "Domain Layer" {
  component "User Repository" as userRepo {
    interface "IUserRepository" as iUserRepo
    [TypeORMUserRepository]
    [FakeUserRepository]
  }

  component "User Entity" as userEntity
  component "DTOs" as dtos
  component "AppError" as appError
}

package "Configuration" {
  component "Dependency Injection" as di {
    [Tsyringe Container]
  }

  component "Environment" as env
  component "Auth Config" as authConfig
  component "Redis Config" as redisConfig
  component "ORM Config" as ormConfig
}

' Relationships
express --> userServices : uses
userServices --> iUserRepo
userServices --> iCache
userServices --> iHash
userServices --> dtos
userServices --> appError

iUserRepo <|.. TypeORMUserRepository
iUserRepo <|.. FakeUserRepository

iCache <|.. RedisCacheProvider
iCache <|.. FakeCacheProvider

iHash <|.. BcryptHashProvider
iHash <|.. FakeHashProvider

TypeORMUserRepository --> userEntity
TypeORMUserRepository --> typeorm

typeorm --> postgres
redisClient --> redis

di --> userServices
di --> cacheProvider
di --> hashProvider
di --> userRepo

env --> authConfig
env --> redisConfig
env --> ormConfig

@enduml
```