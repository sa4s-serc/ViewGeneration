```plantuml
@startuml chsakell_planet-scale-azure

!define AZURE_COLOR #007FFF
!define DATABASE_COLOR #FF9900
!define SERVICE_COLOR #00AA00
!define CLIENT_COLOR #FF6600

skinparam componentStyle uml2
skinparam monochrome false
skinparam defaultFontName Arial

package "Azure Cloud Services" {
    component "Azure Traffic Manager" <<Azure>> #AZURE_COLOR
    component "Azure CDN" <<Azure>> #AZURE_COLOR
    component "Azure Redis Cache" <<Azure>> #AZURE_COLOR
    component "Azure Service Bus" <<Azure>> #AZURE_COLOR
    component "Azure SQL Server" <<Database>> #DATABASE_COLOR
    component "Azure Cosmos DB" <<Database>> #DATABASE_COLOR
    component "Azure Search" <<Azure>> #AZURE_COLOR
}

package "Application Components" {
    component "Web Frontend (Angular)" <<Client>> #CLIENT_COLOR
    component "API Services (.NET Core)" <<Service>> #SERVICE_COLOR
    component "DocumentDB Repository" <<Service>> #SERVICE_COLOR
    component "Redis Cache Repository" <<Service>> #SERVICE_COLOR
    component "Service Bus Repository" <<Service>> #SERVICE_COLOR
    component "SQL Server Context" <<Service>> #SERVICE_COLOR
    component "Azure Search Service" <<Service>> #SERVICE_COLOR
    component "WebJob Processor" <<Service>> #SERVICE_COLOR
}

"Web Frontend (Angular)" --> "API Services (.NET Core)" : HTTP/HTTPS
"API Services (.NET Core)" --> "DocumentDB Repository" : Read Operations
"API Services (.NET Core)" --> "Redis Cache Repository" : Cache Operations
"API Services (.NET Core)" --> "Service Bus Repository" : Message Publishing
"API Services (.NET Core)" --> "SQL Server Context" : Write Operations
"API Services (.NET Core)" --> "Azure Search Service" : Search Queries

"DocumentDB Repository" --> "Azure Cosmos DB" : Document Operations
"Redis Cache Repository" --> "Azure Redis Cache" : Cache Operations
"Service Bus Repository" --> "Azure Service Bus" : Message Queue
"SQL Server Context" --> "Azure SQL Server" : Data Persistence
"Azure Search Service" --> "Azure Search" : Search Indexing
"WebJob Processor" --> "Azure Service Bus" : Message Processing

"Azure Traffic Manager" --> "Web Frontend (Angular)" : Global Routing
"Azure CDN" --> "Web Frontend (Angular)" : Static Content

@enduml
```