```plantuml
@startuml ebu_PlugIt

component "Client Application" as client {
    [Web Interface]
    [Mobile Interface]
}

component "API Gateway" as gateway {
    [REST API]
    [WebSocket]
}

component "Rate Limiter" as rateLimiter {
    [Token Bucket]
    [Quota Management]
}

component "Gemini API" as gemini {
    [Generate Content]
    [Model: gemini-2.0-flash]
}

component "Cache" as cache {
    [Redis]
    [Response Cache]
}

component "Error Handler" as errorHandler {
    [429 Handler]
    [Retry Logic]
}

client --> gateway : HTTP/WebSocket
gateway --> rateLimiter : API calls
rateLimiter --> gemini : Limited requests
gemini --> errorHandler : 429 errors
errorHandler --> gemini : Retry after delay
gateway --> cache : Cached responses
cache --> client : Fast responses

note right of rateLimiter
    Quota ID: GenerateContentInputTokensPerModelPerMinute-FreeTier
    Metric: generativelanguage.googleapis.com/generate_content_free_tier_input_token_count
end note

note bottom of errorHandler
    Implements exponential backoff
    Retry delays: 10-12 seconds
end note

@enduml
```