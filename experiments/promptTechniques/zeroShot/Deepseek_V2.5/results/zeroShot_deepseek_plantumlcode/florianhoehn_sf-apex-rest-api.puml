```plantuml
@startuml florianhoehn_sf-apex-rest-api

package "Salesforce REST/JSON Integration" {
    [RestWrapper] as RestWrapper
    [RestResponse] as RestResponse
    [RestCallout] as RestCallout
    [RestLogBuilder] as RestLogBuilder
    [Rest_Log__c] as RestLogObject

    package "Example Implementation" {
        [ExampleRatingRestResource] as ExampleRestResource
        [ExampleRatingCallout] as ExampleCallout
    }

    package "Testing" {
        [Test Classes] as TestClasses
    }
}

RestWrapper <|-- RestResponse
RestWrapper <|-- ExampleRestResource
RestCallout <|-- ExampleCallout

RestLogBuilder --> RestLogObject
ExampleRestResource --> RestLogBuilder
ExampleCallout --> RestLogBuilder
ExampleCallout --> RestResponse

TestClasses --> ExampleRestResource
TestClasses --> ExampleCallout
TestClasses --> RestWrapper
TestClasses --> RestCallout

@enduml
