```plantuml
@startuml allegroai_clearml-agent

component "ClearML Server" {
    [Task Queue]
    [Experiment Tracking]
    [Resource Monitoring]
}

component "ClearML Agent" {
    [Task Executor] 
    [Environment Manager]
    [Docker Integration]
    [K8s/SLURM Integration]
    [Requirements Manager]
    [Resource Monitor]
}

component "External Systems" {
    [Kubernetes]
    [SLURM]
    [Docker Registry]
}

[Task Queue] --> [Task Executor] : Pulls tasks
[Task Executor] --> [Environment Manager] : Sets up execution env
[Environment Manager] --> [Docker Integration] : Uses for containerization
[Environment Manager] --> [Requirements Manager] : Handles dependencies
[Task Executor] --> [Resource Monitor] : Reports metrics
[Resource Monitor] --> [Resource Monitoring] : Sends utilization data
[Task Executor] --> [Experiment Tracking] : Reports status

[K8s/SLURM Integration] --> [Kubernetes] : Orchestrates tasks
[K8s/SLURM Integration] --> [SLURM] : Submits jobs
[Docker Integration] --> [Docker Registry] : Pulls images

@enduml
```