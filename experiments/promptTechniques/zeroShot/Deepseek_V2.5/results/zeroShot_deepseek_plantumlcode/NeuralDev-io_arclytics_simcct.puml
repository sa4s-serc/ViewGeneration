```plantuml
@startuml NeuralDev-io_arclytics_simcct

!define K8sPods #FFD700
!define DockerContainers #87CEEB
!define ExternalServices #90EE90

node "Kubernetes Cluster" {
    component "SimCCT Service" as simcct <<DockerContainers>> {
        component "Flask API" as flask
        component "Celery Worker" as celery
        component "Redis Client" as redis_client
        component "MongoEngine" as mongoengine
    }

    component "Client (React)" as client <<DockerContainers>> {
        component "React App" as react
        component "Redux Store" as redux
    }

    component "User Management" as user_mgmt <<DockerContainers>> {
        component "Auth Service" as auth
    }

    component "Analytics Service" as analytics <<DockerContainers>> {
        component "Elastic APM" as elastic_apm
    }

    component "Logging Service" as logging <<DockerContainers>> {
        component "Fluentd" as fluentd
    }
}

database "MongoDB" as mongo <<ExternalServices>>
database "Redis" as redis <<ExternalServices>>
database "Elasticsearch" as elastic <<ExternalServices>>
component "Kibana" as kibana <<ExternalServices>>

flask --> mongo : "Data persistence"
flask --> redis : "Session/Caching"
celery --> redis : "Message Queue"
redis_client --> redis : "Session Management"
mongoengine --> mongo : "ODM"
auth --> mongo : "User data"
client --> flask : "REST API"
fluentd --> elastic : "Log shipping"
elastic_apm --> elastic : "Performance data"
kibana --> elastic : "Visualization"

@enduml
```