```plantuml
@startuml nikmis_xentrace-analysis

component "xentrace" as xentrace {
    [xentrace process]
}

component "Xentrace-analysis" as xentrace_analysis {
    [Main Program]
    [Argument Parser]
    [Process Manager]
}

component "Reader" as reader {
    [Event Parser]
    [Event Buffer]
    [Event Sorter]
}

component "EventHandler" as event_handler {
    [Handler Registry]
    [Event Dispatcher]
}

component "Analysis Tools" as analysis_tools {
    [CPU Utilization]
    [Scheduling Latency]
    [Hypervisor Time]
    [Disk I/O]
    [Xen Stats]
    [Trap Counting]
}

database "Trace Data" as trace_data {
    [Trace File]
}

xentrace --> trace_data : writes
trace_data --> reader : reads
reader --> event_handler : dispatches events
event_handler --> analysis_tools : notifies handlers

xentrace_analysis --> xentrace : spawns/manages
xentrace_analysis --> reader : controls
xentrace_analysis --> event_handler : initializes
xentrace_analysis --> analysis_tools : selects/executes

@enduml
```