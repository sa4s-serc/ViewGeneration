```plantuml
@startuml AndreasM009_AadApiGatekeeper

component "Kubernetes Cluster" {
    component "API Gatekeeper (Sidecar)" as gatekeeper {
        [AuthProxyMiddleware] as middleware
        [Token Cache] as cache
        [Azure AD Integration] as aad
        [Configuration] as config
    }

    component "Backend API" as backend {
        [API Endpoints]
    }
}

cloud "Azure Active Directory" as azuread

gatekeeper --> azuread : Authenticates/Authorizes\n(Client ID/Secret)
gatekeeper --> backend : Proxies requests\n(ForwardPort)
middleware --> cache : Uses
middleware --> aad : Validates tokens
middleware --> config : Reads settings
config --> "Environment Variables" : Port, ClientID,\nClientSecret, etc.

@enduml
```