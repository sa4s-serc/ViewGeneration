```plantuml
@startuml lvyahui8_http-proxy

package "HTTP Proxy System" {
    [HttpProxyServer] as server
    [ClientToProxyHandler] as clientHandler
    [ProxyToServerInboundHandler] as serverHandler
    [EntitysManager] as entityManager
    [GlobalExceptionHandler] as exceptionHandler

    package "Filters" {
        [ProxyRequestFilter] as requestFilter
        [ProxyResponseFilter] as responseFilter
        [AttackRequestFilter] as attackFilter
        [DefaultProxyResponseFilter] as defaultFilter
    }

    package "Networking" {
        [Netty Framework] as netty
        [EventLoopGroup] as eventLoop
        [ChannelHandler] as channelHandler
        [Bootstrap] as bootstrap
    }

    package "Configuration" {
        [entitys.json] as configFile
        [MsgTranslater] as msgTranslater
        [MsgCode] as msgCode
    }

    package "Test Components" {
        [test-client] as testClient
        [test-server] as testServer
        [proxy-sdk] as sdk
    }
}

server --> clientHandler : handles
server --> serverHandler : handles
clientHandler --> entityManager : queries
clientHandler --> requestFilter : applies
serverHandler --> responseFilter : applies
entityManager --> configFile : monitors
exceptionHandler --> msgTranslater : uses
exceptionHandler --> msgCode : uses
clientHandler --> netty : uses
serverHandler --> netty : uses
netty --> eventLoop : manages
netty --> channelHandler : processes
netty --> bootstrap : configures
testClient --> server : tests
testServer --> server : backend
sdk --> server : provides API

@enduml
```