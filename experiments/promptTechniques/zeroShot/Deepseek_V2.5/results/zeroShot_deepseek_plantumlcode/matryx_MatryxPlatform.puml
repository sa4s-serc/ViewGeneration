```plantuml
@startuml matryx_MatryxPlatform

component "MatryxPlatform" {
    component "MatryxPlatform.sol" as platform
    component "MatryxSystem.sol" as system
    component "MatryxForwarder.sol" as forwarder
    component "MatryxToken.sol" as token
}

component "Libraries" {
    component "LibPlatform.sol" as libPlatform
    component "LibCommit.sol" as libCommit
    component "LibTournament.sol" as libTournament
}

component "JavaScript Layer" {
    component "utils.js" as utils
    component "test.js" as test
    component "benchmark.js" as benchmark
}

component "Documentation" {
    component "index.rst" as docs
    component "searchtools.js" as search
}

platform --> libPlatform : delegatecall
platform --> libCommit : delegatecall
platform --> libTournament : delegatecall
platform --> system : version management
platform --> forwarder : inherits
platform --> token : uses MTX

utils --> platform : interacts
test --> platform : tests
benchmark --> platform : benchmarks

docs --> search : uses
search --> platform : references

@enduml
```