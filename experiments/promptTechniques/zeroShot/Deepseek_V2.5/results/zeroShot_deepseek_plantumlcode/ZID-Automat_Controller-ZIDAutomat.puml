```plantuml
@startuml ZIDAutomat

component "ZID-Automat Controller" {
    component "Main123" as main {
        [Main Loop]
    }

    component "BorrowM" as borrow {
        [QR Validation]
        [Item Ejection Logic]
    }

    component "Requestsi" as api {
        [JWT Management]
        [API Communication]
    }

    component "DataCollect" as datacollect {
        [Event Logging]
    }

    component "Eject" as eject {
        [GPIO Control]
    }

    component "QRCodeReader" as qr {
        [Serial Communication]
    }

    component "ScreenOutput" as screen {
        [LCD Display]
    }

    component "Configuration" as config {
        [Settings Loader]
    }

    main --> borrow : orchestrates
    main --> api : initializes
    main --> datacollect : initializes
    main --> screen : initializes
    main --> config : reads

    borrow --> api : validates QR
    borrow --> eject : triggers
    borrow --> datacollect : logs events
    borrow --> qr : reads codes
    borrow --> screen : updates UI

    api --> datacollect : submits logs
    eject --> screen : status feedback
    qr --> screen : scan feedback
}

@enduml
```