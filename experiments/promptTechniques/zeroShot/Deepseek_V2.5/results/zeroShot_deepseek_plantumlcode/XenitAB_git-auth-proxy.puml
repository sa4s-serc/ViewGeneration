```plantuml
@startuml XenitAB_git-auth-proxy

actor "Git Client" as client
participant "Git Auth Proxy" as proxy
participant "Kubernetes API" as k8s
participant "GitHub API" as github
participant "Azure DevOps API" as azure

box "Kubernetes Cluster"
    participant "Helm" as helm
    participant "Proxy Pod" as pod
    participant "Metrics Service" as metrics
end

== Initialization ==
helm -> pod: Deploy git-auth-proxy
pod -> k8s: Watch for Secret changes
pod -> metrics: Expose /metrics endpoint

== Authentication Flow ==
client -> proxy: Git Request (with token)
proxy -> k8s: Validate token against Secrets
k8s --> proxy: Token validation response

alt Token valid
    proxy -> proxy: Check repository authorization
    proxy -> proxy: Identify Git provider (from config)
    
    alt GitHub provider
        proxy -> github: Forward request (with provider token)
        github --> proxy: Repository data
    else Azure DevOps provider
        proxy -> azure: Forward request (with provider token)
        azure --> proxy: Repository data
    end
    
    proxy --> client: Return repository data
else Token invalid
    proxy --> client: Return 401 Unauthorized
end

== Security Monitoring ==
metrics -> metrics: Collect proxy metrics\n(requests, auth failures)
k8s -> proxy: Secret change notification
proxy -> k8s: Fetch updated secrets
proxy -> proxy: Update token cache

@enduml
```