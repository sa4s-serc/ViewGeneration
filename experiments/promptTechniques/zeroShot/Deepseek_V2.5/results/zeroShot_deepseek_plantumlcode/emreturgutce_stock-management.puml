```plantuml
@startuml emreturgutce_stock-management

node "Application Server" {
    component "Express API" {
        component "Controllers" as controllers
        component "Middlewares" as middlewares
    }
    component "DatabaseClient" as dbclient
    component "RedisClient" as redisclient
    component "S3Client" as s3client
    component "Utils" as utils
}

database "PostgreSQL" as postgres {
    component "Suppliers" as suppliers
    component "Cars" as cars
    component "Customers" as customers
    component "Sales" as sales
    component "Users" as users
}

cloud "AWS S3" as s3 {
    component "Image Storage" as images
}

queue "Redis" as redis {
    component "Session Store" as sessions
    component "Rate Limiting" as ratelimit
}

controllers --> middlewares
middlewares --> controllers
controllers --> dbclient
dbclient --> postgres
controllers --> redisclient
redisclient --> redis
controllers --> s3client
s3client --> s3
controllers --> utils

postgres -[hidden]-> suppliers
postgres -[hidden]-> cars
postgres -[hidden]-> customers
postgres -[hidden]-> sales
postgres -[hidden]-> users

redis -[hidden]-> sessions
redis -[hidden]-> ratelimit

@enduml
```