```plantuml
@startuml kzh_noob

node "Kubernetes Cluster" {
  [API Gateway\n(Nginx Ingress)] as ingress

  package "Frontend" {
    [Frontend Service] as frontend
  }

  package "Auth Service" {
    [Auth Service] as auth
  }

  package "Problems Service" {
    [Problems Service] as problems
  }

  package "Submissions Service" {
    [Submissions Service] as submissions
  }

  package "Executor Service" {
    [Executor Service] as executor
    [Docker-in-Docker] as dind
  }

  database "MongoDB" as mongo {
    [Problems DB]
    [Submissions DB]
    [Users DB]
  }

  database "Redis" as redis {
    [Session Store]
  }

  queue "RabbitMQ" as rabbitmq {
    [Submission Queue]
    [Result Queue]
  }

  [Jaeger] as jaeger
}

ingress --> frontend
ingress --> auth
ingress --> problems
ingress --> submissions

frontend --> auth
frontend --> problems
frontend --> submissions

auth --> redis
auth --> mongo

problems --> mongo

submissions --> rabbitmq
submissions --> mongo

executor --> rabbitmq
executor --> dind
executor --> mongo

rabbitmq --> executor

dind --> executor

jaeger --> frontend
jaeger --> auth
jaeger --> problems
jaeger --> submissions
jaeger --> executor

@enduml
