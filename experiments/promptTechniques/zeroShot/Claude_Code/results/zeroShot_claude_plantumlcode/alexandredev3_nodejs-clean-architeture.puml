@startuml
!define RECTANGLE_COLOR #E3F2FD
!define COMPONENT_COLOR #BBDEFB
!define INTERFACE_COLOR #90CAF9

skinparam component {
  BackgroundColor COMPONENT_COLOR
  BorderColor #1976D2
  ArrowColor #424242
}

skinparam interface {
  BackgroundColor INTERFACE_COLOR
  BorderColor #1565C0
}

skinparam rectangle {
  BackgroundColor RECTANGLE_COLOR
  BorderColor #0D47A1
}

title Node.js Clean Architecture - User Authentication and Management API

package "HTTP Layer" {
  component [Express Server] as Server
  component [Routes] as Routes
  component [Rate Limiter\nMiddleware] as RateLimiter
  component [Authentication\nMiddleware] as AuthMiddleware
}

package "Controllers" {
  component [Users Controller] as UsersController
  component [Sessions Controller] as SessionsController
}

package "Services (Business Logic)" {
  component [Create User\nService] as CreateUserService
  component [Authenticate User\nService] as AuthenticateUserService
  component [List All Users\nService] as ListAllUsersService
}

package "Providers" {
  interface "IHashProvider" as IHashProvider
  component [BCrypt Hash\nProvider] as BCryptHashProvider
  component [Fake Hash\nProvider] as FakeHashProvider

  interface "ICacheProvider" as ICacheProvider
  component [Redis Cache\nProvider] as RedisCacheProvider
  component [Fake Cache\nProvider] as FakeCacheProvider
}

package "Repositories" {
  interface "IUsersRepository" as IUsersRepository
  component [TypeORM Users\nRepository] as TypeORMUsersRepository
  component [Fake Users\nRepository] as FakeUsersRepository
}

package "Infrastructure" {
  component [TypeORM] as TypeORM
  component [User Entity] as UserEntity
  database "PostgreSQL" as Postgres
  database "Redis" as Redis
}

package "Dependency Injection" {
  component [Tsyringe\nContainer] as Container
}

package "Configuration" {
  component [Auth Config] as AuthConfig
  component [Redis Config] as RedisConfig
  component [ORM Config] as ORMConfig
  component [Environment] as Environment
}

package "Validation & Error Handling" {
  component [Celebrate\nValidator] as Validator
  component [AppError] as AppError
}

package "Security & Utilities" {
  component [JWT\n(jsonwebtoken)] as JWT
  component [UUID\nGenerator] as UUID
}

' HTTP Layer Relationships
Server --> Routes
Routes --> RateLimiter
Routes --> AuthMiddleware
Routes --> UsersController
Routes --> SessionsController
Routes --> Validator

' Controllers to Services
UsersController --> CreateUserService
UsersController --> ListAllUsersService
SessionsController --> AuthenticateUserService

' Services to Providers and Repositories
CreateUserService --> IHashProvider
CreateUserService --> IUsersRepository
CreateUserService --> ICacheProvider
CreateUserService --> UUID

AuthenticateUserService --> IHashProvider
AuthenticateUserService --> IUsersRepository
AuthenticateUserService --> JWT

ListAllUsersService --> IUsersRepository
ListAllUsersService --> ICacheProvider

' Provider Implementations
IHashProvider <|.. BCryptHashProvider
IHashProvider <|.. FakeHashProvider

ICacheProvider <|.. RedisCacheProvider
ICacheProvider <|.. FakeCacheProvider

' Repository Implementations
IUsersRepository <|.. TypeORMUsersRepository
IUsersRepository <|.. FakeUsersRepository

' Infrastructure Relationships
TypeORMUsersRepository --> TypeORM
TypeORMUsersRepository --> UserEntity
TypeORM --> Postgres
RedisCacheProvider --> Redis

' Dependency Injection
Container ..> CreateUserService : registers
Container ..> AuthenticateUserService : registers
Container ..> ListAllUsersService : registers
Container ..> BCryptHashProvider : registers
Container ..> RedisCacheProvider : registers
Container ..> TypeORMUsersRepository : registers

' Configuration
AuthConfig --> JWT
RedisConfig --> Redis
ORMConfig --> TypeORM
Environment --> AuthConfig
Environment --> RedisConfig

' Error Handling
CreateUserService --> AppError
AuthenticateUserService --> AppError
ListAllUsersService --> AppError
UsersController --> AppError
SessionsController --> AppError

' Middleware Dependencies
AuthMiddleware --> JWT
RateLimiter --> Redis

note right of Container
  Tsyringe manages all
  dependencies using
  Singleton pattern
end note

note bottom of "Services (Business Logic)"
  Services implement business logic
  following SOLID principles and
  depend on abstractions (interfaces)
end note

note bottom of "Providers"
  Provider pattern allows
  swapping implementations
  (Real vs Fake for testing)
end note

note bottom of "Repositories"
  Repository pattern abstracts
  data access from business logic
end note

@enduml
