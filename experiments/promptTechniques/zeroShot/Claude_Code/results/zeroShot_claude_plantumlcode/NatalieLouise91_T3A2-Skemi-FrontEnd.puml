@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<UI>> LightBlue
    BackgroundColor<<Core>> LightGreen
    BackgroundColor<<State>> LightYellow
    BackgroundColor<<Service>> LightCoral
    BackgroundColor<<Config>> LightGray
    BackgroundColor<<External>> WhiteSmoke
}

package "Skemi Front-End Application" {

    package "Entry Point" {
        component [index.js] <<Core>>
        component [App.js] <<Core>>
    }

    package "UI Components" {
        package "Navigation" {
            component [Nav.js] <<UI>>
        }

        package "User Management" {
            component [Login.js] <<UI>>
            component [NewUser.js] <<UI>>
            component [UserProfile] <<UI>>
        }

        package "Occasion Management" {
            component [CreateOccasion.js] <<UI>>
            component [ViewOccasion.js] <<UI>>
            component [OccasionList.js] <<UI>>
            component [EditOccasion] <<UI>>
        }

        package "Roster Management" {
            component [CreateRoster.js] <<UI>>
            component [ViewRoster.js] <<UI>>
            component [EditRoster.js] <<UI>>
            component [RosterList] <<UI>>
        }

        package "Schedule" {
            component [EventSchedule] <<UI>>
        }

        package "Common UI" {
            component [ConfirmDialog] <<UI>>
            component [LoadingIndicator] <<UI>>
            component [Notification] <<UI>>
        }
    }

    package "State Management" {
        component [stateContext.js] <<State>>
        component [stateReducer.js] <<State>>
    }

    package "Services Layer" {
        component [authServices.js] <<Service>>
        component [occasionServices.js] <<Service>>
        component [rosterServices.js] <<Service>>
        component [userServices.js] <<Service>>
    }

    package "Configuration" {
        component [api.js] <<Config>>
    }

    package "External Libraries" {
        component [React Router] <<External>>
        component [Material UI] <<External>>
        component [Axios] <<External>>
    }
}

package "Backend" {
    component [Rails API Backend] <<External>>
    database [Database] <<External>>
}

package "Browser" {
    storage [sessionStorage\n(JWT Token)] <<External>>
}

' Entry Point Relationships
[index.js] --> [App.js] : renders

' App.js Dependencies
[App.js] --> [React Router] : uses
[App.js] --> [stateContext.js] : provides context
[App.js] --> [stateReducer.js] : manages state
[App.js] --> [occasionServices.js] : fetches occasions
[App.js] --> [rosterServices.js] : fetches rosters
[App.js] --> [userServices.js] : fetches users

' Navigation
[App.js] --> [Nav.js] : routes to
[Nav.js] --> [Material UI] : uses
[Nav.js] --> [stateContext.js] : reads state
[Nav.js] --> [authServices.js] : logout

' User Components
[App.js] --> [Login.js] : routes to
[App.js] --> [NewUser.js] : routes to
[App.js] --> [UserProfile] : routes to
[Login.js] --> [authServices.js] : sign in
[Login.js] --> [stateContext.js] : updates state
[Login.js] --> [sessionStorage\n(JWT Token)] : stores token
[NewUser.js] --> [authServices.js] : sign up
[UserProfile] --> [userServices.js] : manages profile

' Occasion Components
[App.js] --> [OccasionList.js] : routes to
[App.js] --> [CreateOccasion.js] : routes to
[App.js] --> [ViewOccasion.js] : routes to
[CreateOccasion.js] --> [occasionServices.js] : creates
[CreateOccasion.js] --> [stateContext.js] : updates state
[ViewOccasion.js] --> [occasionServices.js] : reads
[ViewOccasion.js] --> [stateContext.js] : reads state
[EditOccasion] --> [occasionServices.js] : updates
[OccasionList.js] --> [stateContext.js] : reads state
[OccasionList.js] --> [occasionServices.js] : deletes

' Roster Components
[App.js] --> [CreateRoster.js] : routes to
[App.js] --> [ViewRoster.js] : routes to
[App.js] --> [EditRoster.js] : routes to
[CreateRoster.js] --> [rosterServices.js] : creates
[CreateRoster.js] --> [stateContext.js] : updates state
[ViewRoster.js] --> [rosterServices.js] : reads
[ViewRoster.js] --> [stateContext.js] : reads state
[EditRoster.js] --> [rosterServices.js] : updates
[RosterList] --> [rosterServices.js] : deletes
[RosterList] --> [stateContext.js] : reads state

' Schedule
[App.js] --> [EventSchedule] : routes to
[EventSchedule] --> [stateContext.js] : reads state
[EventSchedule] --> [occasionServices.js] : fetches

' Common UI Components
[CreateOccasion.js] --> [ConfirmDialog] : uses
[EditOccasion] --> [ConfirmDialog] : uses
[CreateRoster.js] --> [ConfirmDialog] : uses
[EditRoster.js] --> [ConfirmDialog] : uses
[App.js] --> [LoadingIndicator] : uses
[App.js] --> [Notification] : uses

' Services to Config
[authServices.js] --> [api.js] : uses
[occasionServices.js] --> [api.js] : uses
[rosterServices.js] --> [api.js] : uses
[userServices.js] --> [api.js] : uses

' API Configuration
[api.js] --> [Axios] : configures
[api.js] --> [sessionStorage\n(JWT Token)] : reads token
[api.js] --> [Rails API Backend] : HTTP requests

' Backend
[Rails API Backend] --> [Database] : persists data

' State Management Flow
[stateReducer.js] ..> [stateContext.js] : state logic

note right of [stateContext.js]
  Global State:
  - Occasions
  - Rosters
  - Users
  - Authentication
end note

note right of [api.js]
  Axios Interceptor:
  - Adds JWT token to
    Authorization header
end note

note right of [Nav.js]
  Role-Based Access:
  - Admin menu
  - Standard user menu
  - Responsive design
end note

note bottom of [Rails API Backend]
  Backend API:
  - Authentication (JWT)
  - CRUD operations
  - Data persistence
end note

@enduml
