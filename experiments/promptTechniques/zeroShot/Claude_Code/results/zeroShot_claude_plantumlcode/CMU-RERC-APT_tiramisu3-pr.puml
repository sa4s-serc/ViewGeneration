@startuml
!define RECTANGLE class

skinparam component {
  BackgroundColor<<mobile>> LightBlue
  BackgroundColor<<frontend>> LightGreen
  BackgroundColor<<backend>> LightYellow
  BackgroundColor<<predictor>> LightCoral
  BackgroundColor<<infrastructure>> LightGray
  BackgroundColor<<external>> Wheat
}

package "Mobile Client Layer" {
  component "App Component" as AppComponent <<mobile>> {
    [Platform Readiness Handler]
    [Push Notification Manager]
    [Network Monitor]
    [Alarm Initializer]
  }

  component "Home Page" as HomePage <<mobile>> {
    [Route Display Controller]
    [Map Integration]
    [Search Handler]
  }

  component "Route Page" as RoutePage <<mobile>>
  component "Stop Page" as StopPage <<mobile>>

  component "Services Layer" as ClientServices <<mobile>> {
    [LocationService]
    [FavRoutesService]
    [FavStopsService]
    [AlarmService]
    [SchedulesFromStopService]
    [HandleSettingsService]
  }

  component "Local Storage" as LocalStorage <<mobile>>
  component "Push/Local Notifications" as Notifications <<mobile>>
}

package "Frontend Layer (Java/Tomcat)" {
  component "SchedulesForLocationServlet" as ScheduleServlet <<frontend>>
  component "WriteFavRouteServlet" as WriteFavServlet <<frontend>>
  component "ReadFavRouteServlet" as ReadFavServlet <<frontend>>
  component "StatusLogServlet" as StatusLogServlet <<frontend>>
  component "ButtonLogServlet" as ButtonLogServlet <<frontend>>
  component "FocusLogServlet" as FocusLogServlet <<frontend>>
  component "AlarmServlet" as AlarmServlet <<frontend>>
  component "Database Singleton" as DBSingleton <<frontend>>
}

package "Backend Layer (Java)" {
  component "FeedGrabberPAAC" as FeedGrabberPAAC <<backend>>
  component "FeedGrabberMTA" as FeedGrabberMTA <<backend>>
  component "ObservationProcessor" as ObsProcessor <<backend>>
  component "DynamoCleaner" as DynamoCleaner <<backend>>
  component "AlarmProcessor" as AlarmProcessor <<backend>> {
    [Alarm Manager]
    [AWSSendEmail Strategy]
    [Platform Detector]
  }
}

package "Predictor Layer (Python)" {
  component "Route Prediction Engine" as Predictor <<predictor>> {
    [Random Forest Model]
    [Historical Data Analyzer]
    [Context Processor]
  }
}

package "AWS Infrastructure" {
  component "SQS Queue" as SQS <<infrastructure>>
  component "DynamoDB" as DynamoDB <<infrastructure>>
  component "SNS/Push Services" as SNS <<infrastructure>>
}

package "External Services" {
  component "OneBusAway (OBA)" as OBA <<external>>
  component "PAAC GTFS Feed" as PAAC <<external>>
  component "MTA GTFS Feed" as MTA <<external>>
  component "PostgreSQL" as Postgres <<external>>
  component "Google Maps API" as GoogleMaps <<external>>
}

' Control Flow: User Interaction
AppComponent --> HomePage : initializes
HomePage --> ClientServices : requests data
ClientServices --> ScheduleServlet : HTTP request (schedules)
ClientServices --> ReadFavServlet : HTTP request (favorites)
ClientServices --> AlarmServlet : HTTP request (alarms)

' Control Flow: Route/Stop Navigation
HomePage --> RoutePage : navigates to route
HomePage --> StopPage : navigates to stop
RoutePage --> ClientServices : requests route data
StopPage --> ClientServices : requests stop data

' Control Flow: User Action Logging
ClientServices --> WriteFavServlet : logs favorite action
ClientServices --> StatusLogServlet : logs status
ClientServices --> ButtonLogServlet : logs button press
ClientServices --> FocusLogServlet : logs focus event

' Control Flow: Frontend to Data Sources
ScheduleServlet --> OBA : fetches real-time data
ScheduleServlet --> DynamoDB : queries transit data
ScheduleServlet --> DBSingleton : accesses database
WriteFavServlet --> DBSingleton : writes to database
ReadFavServlet --> DBSingleton : reads from database
StatusLogServlet --> DBSingleton : logs to database
ButtonLogServlet --> DBSingleton : logs to database
FocusLogServlet --> DBSingleton : logs to database
DBSingleton --> Postgres : persists user data

' Control Flow: Real-time Data Processing
PAAC --> FeedGrabberPAAC : provides GTFS feed
MTA --> FeedGrabberMTA : provides GTFS feed
FeedGrabberPAAC --> SQS : publishes observations
FeedGrabberMTA --> SQS : publishes observations
SQS --> ObsProcessor : delivers messages
ObsProcessor --> DynamoDB : stores processed data
DynamoCleaner --> DynamoDB : removes old data

' Control Flow: Prediction
Predictor --> Postgres : queries historical data
Predictor --> ClientServices : provides predictions
ClientServices --> HomePage : displays predictions

' Control Flow: Alarm/Notification System
ClientServices --> AlarmService : sets alarm
AlarmService --> AlarmServlet : registers alarm
AlarmServlet --> AlarmProcessor : processes alarm
AlarmProcessor --> SNS : sends notification (iOS/Android)
SNS --> Notifications : delivers push
Notifications --> AppComponent : triggers local alarm

' Control Flow: Map Integration
HomePage --> GoogleMaps : displays routes
RoutePage --> GoogleMaps : shows route path

' Control Flow: Local Storage
ClientServices --> LocalStorage : saves preferences
LocalStorage --> ClientServices : loads preferences

@enduml
