@startuml
title Resilience4j-Helloworld - Control Flow Sequence Diagram

actor Client
participant "Service A\n(GreetingController)" as ServiceA
participant "Resilience4j\nCircuit Breaker" as CircuitBreaker
participant "Resilience4j\nRate Limiter" as RateLimiter
participant "Resilience4j\nBulkhead" as Bulkhead
participant "Resilience4j\nRetry" as Retry
participant "Resilience4j\nTime Limiter" as TimeLimiter
participant "Service B\n(GreetingController)" as ServiceB
participant "Prometheus" as Prometheus
participant "Grafana" as Grafana

== Normal Request Flow ==
Client -> ServiceA: HTTP GET /greeting
activate ServiceA
ServiceA -> RateLimiter: Check rate limit
activate RateLimiter
RateLimiter -> RateLimiter: Evaluate request count\nwithin time window
RateLimiter --> ServiceA: Allow request
deactivate RateLimiter

ServiceA -> CircuitBreaker: Check circuit state
activate CircuitBreaker
CircuitBreaker -> CircuitBreaker: Evaluate circuit state\n(CLOSED/OPEN/HALF_OPEN)
CircuitBreaker --> ServiceA: Circuit CLOSED\nAllow request
deactivate CircuitBreaker

ServiceA -> Bulkhead: Acquire semaphore
activate Bulkhead
Bulkhead -> Bulkhead: Check concurrent\ncall limit
Bulkhead --> ServiceA: Semaphore acquired
deactivate Bulkhead

ServiceA -> TimeLimiter: Start timer
activate TimeLimiter

ServiceA -> ServiceB: REST API call\nGET /greeting
activate ServiceB
ServiceB -> ServiceB: Process request
ServiceB --> ServiceA: Response: "Hello"
deactivate ServiceB

TimeLimiter --> ServiceA: Within time limit
deactivate TimeLimiter

ServiceA -> Bulkhead: Release semaphore
activate Bulkhead
Bulkhead --> ServiceA: Semaphore released
deactivate Bulkhead

ServiceA -> Prometheus: Export metrics
activate Prometheus
Prometheus --> ServiceA: Metrics recorded
deactivate Prometheus

ServiceA --> Client: Response: "Hello from Service A"
deactivate ServiceA

Prometheus -> Grafana: Scrape metrics
activate Grafana
Grafana --> Prometheus: Display dashboard
deactivate Grafana

== Circuit Breaker - Error Scenario ==
Client -> ServiceA: HTTP GET /greeting
activate ServiceA
ServiceA -> RateLimiter: Check rate limit
activate RateLimiter
RateLimiter --> ServiceA: Allow request
deactivate RateLimiter

ServiceA -> CircuitBreaker: Check circuit state
activate CircuitBreaker
CircuitBreaker --> ServiceA: Circuit CLOSED
deactivate CircuitBreaker

ServiceA -> Retry: Execute with retry
activate Retry
loop maxAttempts times
    Retry -> ServiceB: REST API call
    activate ServiceB
    ServiceB --> Retry: Error 500\nInternal Server Error
    deactivate ServiceB
    Retry -> Retry: Wait (waitDuration)
end

Retry --> ServiceA: All retries failed
deactivate Retry

ServiceA -> CircuitBreaker: Record failure
activate CircuitBreaker
CircuitBreaker -> CircuitBreaker: Increment error count\nCheck error threshold
CircuitBreaker -> CircuitBreaker: State transition:\nCLOSED -> OPEN
CircuitBreaker --> ServiceA: Circuit OPEN
deactivate CircuitBreaker

ServiceA -> ServiceA: Execute fallback method
ServiceA --> Client: Fallback response
deactivate ServiceA

== Circuit Breaker - Slow Call Scenario ==
Client -> ServiceA: HTTP GET /greeting
activate ServiceA
ServiceA -> CircuitBreaker: Check circuit state
activate CircuitBreaker
CircuitBreaker --> ServiceA: Circuit CLOSED
deactivate CircuitBreaker

ServiceA -> TimeLimiter: Start timer\n(slowCallDurationThreshold)
activate TimeLimiter

ServiceA -> ServiceB: REST API call
activate ServiceB
ServiceB -> ServiceB: Slow processing...
ServiceB --> ServiceA: Delayed response
deactivate ServiceB

TimeLimiter -> TimeLimiter: Check duration\nexceeds threshold
TimeLimiter --> ServiceA: Slow call detected
deactivate TimeLimiter

ServiceA -> CircuitBreaker: Record slow call
activate CircuitBreaker
CircuitBreaker -> CircuitBreaker: Increment slow call count\nCheck slowCallRateThreshold
CircuitBreaker -> CircuitBreaker: State transition:\nCLOSED -> OPEN
CircuitBreaker --> ServiceA: Circuit OPEN
deactivate CircuitBreaker

ServiceA -> ServiceA: Execute fallback method
ServiceA --> Client: Fallback response
deactivate ServiceA

== Rate Limiter - Limit Exceeded ==
Client -> ServiceA: HTTP GET /greeting
activate ServiceA
ServiceA -> RateLimiter: Check rate limit
activate RateLimiter
RateLimiter -> RateLimiter: Evaluate request count\nexceeds limit
RateLimiter --> ServiceA: Reject request\nRate limit exceeded
deactivate RateLimiter

ServiceA --> Client: HTTP 429\nToo Many Requests
deactivate ServiceA

== Bulkhead - Concurrency Limit ==
Client -> ServiceA: HTTP GET /greeting
activate ServiceA
ServiceA -> Bulkhead: Acquire semaphore
activate Bulkhead
Bulkhead -> Bulkhead: Max concurrent\ncalls reached
Bulkhead --> ServiceA: Semaphore unavailable
deactivate Bulkhead

ServiceA -> ServiceA: Execute fallback method
ServiceA --> Client: Fallback response
deactivate ServiceA

== Circuit Breaker - Half Open State ==
Client -> ServiceA: HTTP GET /greeting\n(after wait duration)
activate ServiceA
ServiceA -> CircuitBreaker: Check circuit state
activate CircuitBreaker
CircuitBreaker -> CircuitBreaker: Transition:\nOPEN -> HALF_OPEN
CircuitBreaker --> ServiceA: Circuit HALF_OPEN\nAllow test request
deactivate CircuitBreaker

ServiceA -> ServiceB: REST API call\n(test call)
activate ServiceB
ServiceB --> ServiceA: Successful response
deactivate ServiceB

ServiceA -> CircuitBreaker: Record success
activate CircuitBreaker
CircuitBreaker -> CircuitBreaker: Evaluate success rate\nTransition: HALF_OPEN -> CLOSED
CircuitBreaker --> ServiceA: Circuit CLOSED
deactivate CircuitBreaker

ServiceA --> Client: Response: "Hello from Service A"
deactivate ServiceA

== Combined Pattern - Rate Limiter + Circuit Breaker ==
Client -> ServiceA: HTTP GET /greeting
activate ServiceA
ServiceA -> RateLimiter: Check rate limit
activate RateLimiter
RateLimiter --> ServiceA: Allow request
deactivate RateLimiter

ServiceA -> CircuitBreaker: Check circuit state
activate CircuitBreaker
CircuitBreaker --> ServiceA: Circuit CLOSED
deactivate CircuitBreaker

ServiceA -> ServiceB: REST API call
activate ServiceB
ServiceB --> ServiceA: Response
deactivate ServiceB

ServiceA -> Prometheus: Export combined\npattern metrics
activate Prometheus
Prometheus --> ServiceA: Metrics recorded
deactivate Prometheus

ServiceA --> Client: Response
deactivate ServiceA

@enduml
