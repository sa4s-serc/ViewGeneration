@startuml
!theme plain
title Data Visualization with IBM Cognos Analytics - Control Flow

actor User
participant "Node.js\nRuntime" as NodeJS
participant "generate-product-\nbusiness-data.js" as Generator
participant "create-product-\ndata.js" as DataCreator
participant "data-util.js" as DataUtil
participant "database-util.js" as DatabaseUtil
participant "save-product-\nreviews.js" as ReviewsSaver
participant "query-constants.js" as QueryConstants
database "Db2 Warehouse/\nNetezza" as Database
participant "IBM Cognos\nAnalytics" as Cognos

== Data Generation Phase ==

User -> NodeJS: Execute data generation script
activate NodeJS

NodeJS -> Generator: Run generate-product-business-data.js
activate Generator

Generator -> DataCreator: Call to generate sample data
activate DataCreator

DataCreator -> DataUtil: Request random sales data
activate DataUtil
DataUtil --> DataCreator: Return sales data
deactivate DataUtil

DataCreator -> DataUtil: Request random order data
activate DataUtil
DataUtil --> DataCreator: Return order data
deactivate DataUtil

DataCreator -> DataUtil: Request random warehouse data
activate DataUtil
DataUtil --> DataCreator: Return warehouse data
deactivate DataUtil

DataCreator -> DataCreator: Generate stores data
DataCreator -> DataCreator: Generate products data
DataCreator -> DataCreator: Export to CSV files
DataCreator --> Generator: CSV files created
deactivate DataCreator

== Data Loading Phase ==

Generator -> DatabaseUtil: Initialize database connection
activate DatabaseUtil

DatabaseUtil -> DatabaseUtil: Load .env configuration
DatabaseUtil -> Database: Establish connection
activate Database
Database --> DatabaseUtil: Connection established
deactivate Database

DatabaseUtil --> Generator: Connection ready
deactivate DatabaseUtil

Generator -> QueryConstants: Get table creation queries
activate QueryConstants
QueryConstants --> Generator: Return SQL CREATE statements
deactivate QueryConstants

Generator -> DatabaseUtil: Execute CREATE TABLE queries
activate DatabaseUtil
DatabaseUtil -> Database: Create STORES table
activate Database
Database --> DatabaseUtil: Table created
deactivate Database

DatabaseUtil -> Database: Create PRODUCTS table
activate Database
Database --> DatabaseUtil: Table created
deactivate Database

DatabaseUtil -> Database: Create SALES_ORDERS table
activate Database
Database --> DatabaseUtil: Table created
deactivate Database

DatabaseUtil -> Database: Create WAREHOUSE_INVENTORY table
activate Database
Database --> DatabaseUtil: Table created
deactivate Database

DatabaseUtil --> Generator: Tables created
deactivate DatabaseUtil

Generator -> QueryConstants: Get data insertion queries
activate QueryConstants
QueryConstants --> Generator: Return SQL INSERT statements
deactivate QueryConstants

Generator -> DatabaseUtil: Execute INSERT queries with CSV data
activate DatabaseUtil

DatabaseUtil -> Database: Insert stores data
activate Database
Database --> DatabaseUtil: Data inserted
deactivate Database

DatabaseUtil -> Database: Insert products data
activate Database
Database --> DatabaseUtil: Data inserted
deactivate Database

DatabaseUtil -> Database: Insert sales orders data
activate Database
Database --> DatabaseUtil: Data inserted
deactivate Database

DatabaseUtil -> Database: Insert warehouse inventory data
activate Database
Database --> DatabaseUtil: Data inserted
deactivate Database

DatabaseUtil --> Generator: Business data loaded
deactivate DatabaseUtil

== Product Reviews Loading Phase ==

Generator -> ReviewsSaver: Load product reviews and keywords
activate ReviewsSaver

ReviewsSaver -> ReviewsSaver: Read out-reviews.csv
ReviewsSaver -> ReviewsSaver: Read out-keywords.csv

ReviewsSaver -> DatabaseUtil: Execute review data queries
activate DatabaseUtil

DatabaseUtil -> Database: Insert product reviews
activate Database
Database --> DatabaseUtil: Reviews inserted
deactivate Database

DatabaseUtil -> Database: Insert keywords/sentiment data
activate Database
Database --> DatabaseUtil: Keywords inserted
deactivate Database

DatabaseUtil --> ReviewsSaver: Review data loaded
deactivate DatabaseUtil

ReviewsSaver --> Generator: Reviews saved successfully
deactivate ReviewsSaver

Generator --> NodeJS: Data generation complete
deactivate Generator

NodeJS --> User: Data loaded successfully
deactivate NodeJS

== Cognos Analytics Visualization Phase ==

User -> Cognos: Access Cognos Analytics
activate Cognos

Cognos -> Database: Connect to data warehouse
activate Database
Database --> Cognos: Connection established
deactivate Database

User -> Cognos: Create data module
Cognos -> Database: Query available tables
activate Database
Database --> Cognos: Return table metadata
deactivate Database

Cognos -> Cognos: Build data module from tables

User -> Cognos: Build dashboards
Cognos -> Database: Execute analytical queries
activate Database
Database --> Cognos: Return aggregated data
deactivate Database

Cognos -> Cognos: Generate visualizations
Cognos --> User: Display interactive dashboard
deactivate Cognos

@enduml
