@startuml
title Nightingale Reference Client - Security-Focused Sequence Diagram

actor Jurisdiction as jurisdiction
participant "React UI" as ui
participant "RecordController\n(API)" as controller
participant "Authentication\nMiddleware" as auth
participant "Configuration\nValidation" as config
participant "TimedHostedService" as service
participant "AppDbContext\n(Database)" as db
participant "NVSS API Server" as nvss

== Configuration and Authentication Setup ==
config -> config: ValidateDataAnnotations()
config -> config: ValidateOnStart()
note right: Validates authentication\ncredentials from appsettings.json

== Secure Record Submission ==
jurisdiction -> ui: Upload VRDR Record
ui -> controller: POST /api/record\n(VRDR JSON)
activate controller

controller -> auth: Validate Request
activate auth
auth -> auth: Check Authentication\nCredentials
alt Authentication Failed
    auth --> controller: 401 Unauthorized
    controller --> ui: Authentication Error
    ui --> jurisdiction: Error: Unauthorized
else Authentication Successful
    auth --> controller: Authorized
    deactivate auth

    controller -> controller: Validate VRDR\nMessage Format
    alt Invalid Format
        controller --> ui: 400 Bad Request
        ui --> jurisdiction: Validation Error
    else Valid Format
        controller -> db: Store MessageItem\n(Encrypted if configured)
        activate db
        db --> controller: Message Stored
        deactivate db
        controller --> ui: 202 Accepted
        deactivate controller
        ui --> jurisdiction: Submission Confirmed
    end
end

== Secure Message Retrieval and Status Query ==
jurisdiction -> ui: Query Message Status
ui -> controller: GET /api/record/{id}
activate controller

controller -> auth: Validate Request
activate auth
auth -> auth: Verify Authentication\nCredentials
alt Authentication Failed
    auth --> controller: 401 Unauthorized
    controller --> ui: Authentication Error
    ui --> jurisdiction: Error: Unauthorized
else Authentication Successful
    auth --> controller: Authorized
    deactivate auth

    controller -> db: Query MessageItem\nand ResponseItem
    activate db
    db -> db: Verify Record Ownership\n(Jurisdiction Check)
    alt Unauthorized Access
        db --> controller: Access Denied
        controller --> ui: 403 Forbidden
        ui --> jurisdiction: Error: Forbidden
    else Authorized Access
        db --> controller: Message Status
        deactivate db
        controller --> ui: Status Response
        deactivate controller
        ui --> jurisdiction: Display Status
    end
end

== Secure Background Processing ==
service -> service: Scheduled Poll
activate service
service -> db: Retrieve Pending Messages
activate db
db --> service: Message List
deactivate db

service -> nvss: POST VRDR Message\n(With Auth Credentials)
activate nvss
nvss -> nvss: Validate Client\nAuthentication
alt Authentication Failed
    nvss --> service: 401 Unauthorized
    service -> db: Log Authentication\nFailure
    activate db
    db --> service: Logged
    deactivate db
    service -> service: Schedule Retry
else Authentication Successful
    nvss -> nvss: Validate Message\nIntegrity & Schema
    alt Message Validation Failed
        nvss --> service: Extraction Error\nMessage
        service -> db: Store Error Response
        activate db
        db --> service: Stored
        deactivate db
    else Message Valid
        nvss -> nvss: Process VRDR Message
        nvss --> service: Acknowledgement Message
        service -> db: Store Acknowledgement
        activate db
        db --> service: Stored
        deactivate db
    end
end
deactivate nvss

== Secure Response Polling ==
service -> nvss: GET /api/messages\n(With Auth Credentials)
activate nvss
nvss -> nvss: Validate Client\nAuthentication
alt Authentication Failed
    nvss --> service: 401 Unauthorized
    service -> db: Log Auth Failure
    activate db
    db --> service: Logged
    deactivate db
else Authentication Successful
    nvss --> service: Response Messages\n(Coding, Status, etc.)
    deactivate nvss

    service -> service: Validate Response\nSignature/Integrity
    service -> db: Store ResponseItem\n(Securely)
    activate db
    db --> service: Stored
    deactivate db
end
deactivate service

== Secure Configuration Access ==
note over config, db
    Security Considerations:
    - Authentication credentials stored in appsettings.json
    - Validation enforced at startup
    - Database connections use secure connection strings
    - HTTPS enforced for NVSS API communication
    - Message integrity validated through FHIR schema
end note

@enduml
