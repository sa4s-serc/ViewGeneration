@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<App>> LightBlue
    BackgroundColor<<Domain>> LightGreen
    BackgroundColor<<Data>> LightYellow
    BackgroundColor<<External>> LightGray
}

package "App Layer" <<App>> {
    component [AppDelegate] as AppDelegate
    component [AppCoordinator] as AppCoordinator

    package "Scenes" {
        component [NowPlayingVC] as NowPlayingVC
        component [TopRatedVC] as TopRatedVC
        component [SearchVC] as SearchVC
        component [MovieDetailsVC] as MovieDetailsVC
        component [BrowseVM] as BrowseVM
        component [SearchVM] as SearchVM
        component [MovieDetailsVM] as MovieDetailsVM
        component [MovieCell] as MovieCell
        component [GenreCell] as GenreCell
    }

    package "Core" {
        component [BaseViewController] as BaseVC
        component [ViewModel] as ViewModelProtocol
        component [StateView] as StateView
        component [TextyTabBar] as TextyTabBar
    }

    package "Utilities" {
        component [UIExtensions] as UIExtensions
        component [DesignSystem] as DesignSystem
    }
}

package "Domain Layer" <<Domain>> {
    component [MoviesRepository] as MoviesRepoInterface

    package "Use Cases" {
        component [BrowseUseCase] as BrowseUseCase
        component [SearchUseCase] as SearchUseCase
        component [MovieDetailsUseCase] as MovieDetailsUseCase
    }

    package "Entities" {
        component [Movie] as Movie
        component [MovieDetails] as MovieDetails
        component [Genre] as Genre
        component [AppError] as AppError
        component [Page] as Page
    }
}

package "Data Layer" <<Data>> {
    component [MoviesRepositoryImpl] as MoviesRepoImpl

    package "Remote Data Sources" {
        component [RemoteMoviesDataSource] as RemoteDataSource
        component [MoviesService] as MoviesService
        component [RxMoyaExtensions] as RxMoyaExt
    }
}

package "External" <<External>> {
    component [TMDB API] as TMDBAPI
    component [RxSwift] as RxSwift
    component [RxCocoa] as RxCocoa
    component [Moya] as Moya
    component [RxMoya] as RxMoya
}

' App Layer relationships
AppDelegate --> AppCoordinator : initializes
AppCoordinator --> NowPlayingVC : creates
AppCoordinator --> TopRatedVC : creates
AppCoordinator --> SearchVC : creates
AppCoordinator --> MovieDetailsVC : navigates to
AppCoordinator --> TextyTabBar : manages

NowPlayingVC --> BrowseVM : uses
TopRatedVC --> BrowseVM : uses
SearchVC --> SearchVM : uses
MovieDetailsVC --> MovieDetailsVM : uses

NowPlayingVC --|> BaseVC : extends
TopRatedVC --|> BaseVC : extends
SearchVC --|> BaseVC : extends
MovieDetailsVC --|> BaseVC : extends

BrowseVM ..|> ViewModelProtocol : implements
SearchVM ..|> ViewModelProtocol : implements
MovieDetailsVM ..|> ViewModelProtocol : implements

BaseVC --> StateView : uses
BaseVC --> ViewModelProtocol : depends on
NowPlayingVC --> MovieCell : displays
TopRatedVC --> MovieCell : displays
SearchVC --> MovieCell : displays
MovieDetailsVC --> GenreCell : displays

' ViewModel to Use Case relationships
BrowseVM --> BrowseUseCase : invokes
SearchVM --> SearchUseCase : invokes
MovieDetailsVM --> MovieDetailsUseCase : invokes

' Use Case to Repository relationships
BrowseUseCase --> MoviesRepoInterface : uses
SearchUseCase --> MoviesRepoInterface : uses
MovieDetailsUseCase --> MoviesRepoInterface : uses

' Use Case to Entity relationships
BrowseUseCase --> Movie : returns
BrowseUseCase --> Page : returns
SearchUseCase --> Movie : returns
SearchUseCase --> Page : returns
MovieDetailsUseCase --> MovieDetails : returns
MovieDetailsUseCase --> Genre : uses
BrowseUseCase --> AppError : handles
SearchUseCase --> AppError : handles
MovieDetailsUseCase --> AppError : handles

' Data Layer relationships
MoviesRepoImpl ..|> MoviesRepoInterface : implements
MoviesRepoImpl --> RemoteDataSource : uses
RemoteDataSource --> MoviesService : uses
RemoteDataSource --> RxMoyaExt : uses
MoviesService --> Moya : uses

' External dependencies
RemoteDataSource --> RxMoya : uses
MoviesService --> RxMoya : uses
BrowseVM --> RxSwift : uses
SearchVM --> RxSwift : uses
MovieDetailsVM --> RxSwift : uses
NowPlayingVC --> RxCocoa : uses
TopRatedVC --> RxCocoa : uses
SearchVC --> RxCocoa : uses
MovieDetailsVC --> RxCocoa : uses

' API connection
MoviesService --> TMDBAPI : requests

' Utility usage
BaseVC --> UIExtensions : uses
BaseVC --> DesignSystem : uses
StateView --> DesignSystem : uses

@enduml
