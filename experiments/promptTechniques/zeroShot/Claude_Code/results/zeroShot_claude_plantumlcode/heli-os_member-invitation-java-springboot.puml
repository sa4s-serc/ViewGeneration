@startuml
!define RECTANGLE class

skinparam component {
  BackgroundColor<<interface>> LightBlue
  BackgroundColor<<domain>> LightGreen
  BackgroundColor<<infrastructure>> LightYellow
  BorderColor Black
}

package "Interface/API Layer" <<interface>> {
  component [MemberInvitationApplication] as app
  component [InvitationRestController] as invitationCtrl
  component [MemberRestController] as memberCtrl
  component [DTOs] as dtos
  component [Mappers] as mappers
  component [GlobalExceptionHandler] as exceptionHandler
}

package "Domain Layer" <<domain>> {
  component [Member] as memberDomain
  component [Invitation] as invitationDomain

  package "Use Cases (Ports)" {
    interface "CreateInvitationUseCase" as createInvitationUC
    interface "GetInvitationUseCase" as getInvitationUC
    interface "AcceptInvitationUseCase" as acceptInvitationUC
    interface "GetMemberUseCase" as getMemberUC
  }

  component [InvitationService] as invitationService
  component [MemberService] as memberService
}

package "Infrastructure Layer" <<infrastructure>> {
  package "Database Persistence" {
    component [MemberJpaEntity] as memberEntity
    component [MemberJpaRepository] as memberRepo
    component [DatabaseMemberService] as dbMemberService
  }

  package "Redis Persistence" {
    component [RedisInvitationRepository] as redisRepo
    component [RedisInvitationService] as redisService
  }
}

package "Commons" {
  component [CommonModels] as commonModels
  component [CommonUtils] as commonUtils
}

database "PostgreSQL/H2" as db
database "Redis" as redis

' Interface Layer relationships
app --> invitationCtrl
app --> memberCtrl
invitationCtrl --> dtos
memberCtrl --> dtos
invitationCtrl --> mappers
memberCtrl --> mappers
invitationCtrl ..> exceptionHandler : throws
memberCtrl ..> exceptionHandler : throws

' Interface to Domain connections
invitationCtrl --> createInvitationUC : uses
invitationCtrl --> getInvitationUC : uses
invitationCtrl --> acceptInvitationUC : uses
memberCtrl --> getMemberUC : uses
mappers --> memberDomain : maps
mappers --> invitationDomain : maps

' Domain Layer relationships
invitationService ..|> createInvitationUC : implements
invitationService ..|> getInvitationUC : implements
invitationService ..|> acceptInvitationUC : implements
memberService ..|> getMemberUC : implements
invitationService --> invitationDomain : manages
memberService --> memberDomain : manages
invitationService --> memberService : collaborates

' Domain to Infrastructure connections
invitationService --> redisService : uses
memberService --> dbMemberService : uses

' Infrastructure Layer relationships
redisService --> redisRepo : uses
dbMemberService --> memberRepo : uses
memberRepo --> memberEntity : persists
redisRepo --> redis : stores/retrieves
memberRepo --> db : stores/retrieves

' Commons relationships
invitationDomain --> commonModels : uses
memberDomain --> commonModels : uses
invitationService --> commonUtils : uses
memberService --> commonUtils : uses

note right of redis
  - TTL-based expiration
  - Single-use invitation codes
  - Fast in-memory storage
end note

note right of db
  - Member persistence
  - Candidate member accounts
  - Member status management
end note

note top of "Use Cases (Ports)"
  Hexagonal Architecture:
  Ports define domain contracts
end note

note bottom of "Infrastructure Layer"
  Adapters implement ports
  Strategy pattern for persistence
end note

note top of app
  API Endpoints:
  POST /api/v1/workspace/{workspaceId}/invitation
  GET /api/v1/invitation/{code}
  POST /api/v1/invitation/{code}/accept
  GET /api/v1/member/{memberId}
end note

@enduml
