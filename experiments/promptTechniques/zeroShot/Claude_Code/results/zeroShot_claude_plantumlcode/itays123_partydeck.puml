@startuml
!define COMPONENT_COLOR #4A90E2
!define INTERFACE_COLOR #7ED321
!define DATABASE_COLOR #F5A623

skinparam component {
    BackgroundColor COMPONENT_COLOR
    BorderColor #2C3E50
    ArrowColor #34495E
}

skinparam interface {
    BackgroundColor INTERFACE_COLOR
    BorderColor #27AE60
}

skinparam database {
    BackgroundColor DATABASE_COLOR
    BorderColor #E67E22
}

package "Frontend Layer" {
    component "Panel (React)" as Panel {
        component "Authentication Module" as PanelAuth
        component "Deck Management" as DeckMgmt
        component "Game Library" as GameLib
        component "Game Initiator" as GameInit
        component "UI Components" as PanelUI
    }

    component "Game (React)" as GameFE {
        component "Game Interface" as GameUI
        component "Player Actions" as PlayerActions
        component "Real-time Display" as RTDisplay
        component "WebSocket Client" as WSClient
    }
}

package "Backend Layer" {
    component "Server (Java/Spring Boot)" as Server {
        component "GameController" as GameCtrl
        component "WebSocket Handler" as WSHandler
        component "Game Service" as GameService
        component "State Builder" as StateBuilder
        component "Security Config" as SecurityConfig
    }

    database "Data Repositories" as DataRepo {
        component "Player Repository" as PlayerRepo
        component "Game Repository" as GameRepo
        component "Card Repository" as CardRepo
    }
}

package "External Services" {
    cloud "Google Cloud Platform" as GCP {
        component "Cloud Run" as CloudRun
        component "Cloud Build (CI/CD)" as CloudBuild
    }
}

interface "REST API" as RestAPI
interface "WebSocket API" as WSApi
interface "Authentication API" as AuthAPI
interface "Deck Management API" as DeckAPI
interface "Game Management API" as GameMgmtAPI

Panel --> RestAPI : HTTP Requests
Panel --> AuthAPI : Login/Register
Panel --> DeckAPI : CRUD Operations
Panel --> GameMgmtAPI : Create/Validate Game

RestAPI -- Server

GameFE --> WSApi : Real-time Communication
WSApi -- Server

PanelAuth ..> SecurityConfig : Authenticate
DeckMgmt ..> GameService : Manage Decks
GameLib ..> GameService : Browse Games
GameInit ..> GameCtrl : Initiate Game

GameCtrl --> GameService : Delegate Logic
GameCtrl --> DataRepo : Data Access

WSHandler --> GameService : Handle Game Events
WSHandler ..> WSClient : Push State Updates

GameService --> StateBuilder : Build Game State
GameService --> DataRepo : Persist Data

StateBuilder --> PlayerRepo : Initialize Players
StateBuilder --> GameRepo : Create Game
StateBuilder --> CardRepo : Load Cards

PlayerActions ..> WSHandler : Send Actions
RTDisplay ..> WSHandler : Receive Updates

Panel -down-> CloudBuild : Deploy
GameFE -down-> CloudBuild : Deploy
Server -down-> CloudBuild : Deploy

CloudBuild --> CloudRun : Deploy to

note right of Panel
  - User authentication
  - Deck creation & editing
  - Game library browsing
  - Uses Context API & Hooks
  - Tailwind CSS styling
end note

note right of GameFE
  - Real-time gameplay UI
  - Player interaction
  - WebSocket client
  - Component-based architecture
end note

note right of Server
  - Spring Boot application
  - WebSocket server
  - Game logic & state management
  - RESTful endpoints
  - Observer pattern for events
end note

note bottom of DataRepo
  Spring Data repositories
  for data persistence
end note

note bottom of GCP
  Microservices deployment
  on Cloud Run with
  automated CI/CD pipeline
end note

@enduml
