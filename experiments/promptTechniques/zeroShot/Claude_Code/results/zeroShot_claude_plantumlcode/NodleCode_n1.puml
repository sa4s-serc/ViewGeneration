@startuml
!define RECTANGLE_STYLE #LightBlue
!define DATABASE_STYLE #LightGreen
!define INTERFACE_STYLE #LightYellow

skinparam componentStyle rectangle
skinparam linetype ortho

package "Device Tier" {
    node "Dialog DA14531 Dev Kit" as DA14531 {
        component "iBeacon Firmware" as Firmware {
            component "ibeacon.c/h" as iBeacon
            component "BLE Stack" as BLEStack
            component "Peripheral Drivers" as Drivers
            component "Platform Drivers" as Platform
            component "Configuration" as Config
        }

        database "External SPI Flash" as SPIFlash {
            component "Beacon Data\n(UUID, Major, Minor)" as BeaconData
        }

        component "Hardware Peripherals" as Peripherals {
            component "GPIO" as GPIO
            component "UART" as UART
            component "SPI" as SPI
        }
    }

    component "Nodle PCB Hardware" as PCB {
        component "Top Copper Layer (GTL)" as TopCopper
        component "Bottom Copper Layer (GBL)" as BottomCopper
        component "Solder Mask (GTS/GBS)" as SolderMask
        component "Mechanical Layers (GM1/13/15)" as Mechanical
    }
}

package "Application Tier" {
    node "Mobile Device" as MobileDevice {
        component "Nodle Mobile App" as MobileApp {
            component "Beacon Detector" as Detector
            component "Location Services" as Location
            component "Data Relay" as Relay
        }
    }
}

package "Data Tier (Cloud)" {
    cloud "Nodle Cloud" as NodleCloud {
        component "Beacon Storage Service" as Storage
        component "REST API" as API
        component "Authentication Service" as Auth
        database "Beacon Database" as BeaconDB {
            component "Location Data" as LocationData
            component "Beacon Attributes" as Attributes
            component "Fleet Information" as Fleet
        }
    }
}

package "Client Tools" {
    node "Client Machine" as ClientMachine {
        component "getBeaconInformation.py" as PythonScript
    }
}

package "Development Environment" {
    node "Development PC" as DevPC {
        component "Keil uVision IDE" as KeilIDE
        component "SDK 6.0" as SDK
        component "Build Tools" as BuildTools
    }
}

package "Manufacturing" {
    node "PCB Manufacturing" as Manufacturing {
        component "Gerber Files" as Gerber
        component "NC Drill Files" as Drill
        component "DRC Rules" as DRC
    }
}

' Firmware Internal Relationships
iBeacon --> BLEStack : uses
iBeacon --> Drivers : controls
Drivers --> Platform : uses
Config --> iBeacon : configures
Config --> BLEStack : configures

' Device Tier Relationships
Firmware --> SPIFlash : reads beacon data
Firmware --> Peripherals : initializes
SPI --> SPIFlash : communication
Firmware ..> PCB : deployed on

' Device to Application
DA14531 --> MobileApp : BLE Advertisement\n(iBeacon Protocol)

' Application Tier Relationships
Detector --> Location : uses
Detector --> Relay : sends data
Relay --> API : HTTPS

' Cloud Tier Relationships
API --> Storage : manages
Storage --> BeaconDB : stores/retrieves
API --> Auth : validates token
Auth --> Fleet : manages

' Client Tools Relationships
PythonScript --> API : HTTPS GET\n(token auth)
PythonScript --> Auth : authentication

' Development Relationships
SDK --> BuildTools : compiles
BuildTools --> Firmware : generates binary
KeilIDE --> SDK : uses

' Manufacturing Relationships
Gerber --> PCB : fabricates
Drill --> PCB : drilling specs
DRC --> Gerber : validates

note right of DA14531
  Hardware: Dialog DA14531/DA14585/DA14586
  Protocol: BLE (Bluetooth Low Energy)
  Power: DCDC converter support
  Memory: External SPI Flash
end note

note right of MobileApp
  Function: Beacon Detection
  Relays: Location + Beacon Info
  Target: Nodle Cloud Backend
end note

note right of NodleCloud
  Storage: Beacon fleet data
  API: REST interface
  Auth: Token-based
  Access: UUID, Major, Minor, Location
end note

note bottom of Manufacturing
  Format: Gerber files
  Layers: Multi-layer PCB
  Date: 122321 (Dec 23, 2021)
  Panel Design: Optimized for manufacturing
end note

@enduml
