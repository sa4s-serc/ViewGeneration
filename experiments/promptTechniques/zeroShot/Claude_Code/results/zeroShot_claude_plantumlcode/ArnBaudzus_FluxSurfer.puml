@startuml

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<solver>> LightGreen
  BackgroundColor<<processing>> LightYellow
  BackgroundColor<<utility>> LightGray
  BackgroundColor<<storage>> LightCoral
}

package "FluxSurfer Library" {

  package "Core Components" {
    component "QuantumSystem" <<core>> as QS
    component "State" <<core>> as State
    component "Edge" <<core>> as Edge
  }

  package "Solver Framework" {
    interface "Solver" <<solver>> as ISolver
    interface "SingleStepScheme" <<solver>> as IScheme
    component "SingleStepODESolver" <<solver>> as ODESolver
    component "EulerForward" <<solver>> as Euler
    component "RichardsonSolver" <<solver>> as Richardson
    component "MonteCarloWanderer" <<solver>> as MC
  }

  package "Parallel Processing" {
    component "Experiment" <<processing>> as Exp
    component "WorkSource" <<processing>> as WS
    component "DataSet" <<processing>> as DS
  }

  package "Data Storage" {
    component "GraphML Files" <<storage>> as GraphML
    component "METADATA.json" <<storage>> as MetaJSON
    component "METADATA.csv" <<storage>> as MetaCSV
  }

  package "Utilities" {
    component "fileUtility.py" <<utility>> as FileUtil
    component "quantities.py" <<utility>> as Quantities
    component "plotChargeCurve.py" <<utility>> as PlotCC
    component "binaryNumberUtility.py" <<utility>> as BinUtil
    component "physicalFormulas" <<utility>> as Physics
  }
}

package "External Libraries" {
  component "Armadillo" as Arma
  component "pthread" as PThread
  component "jsoncpp" as JSON
}

QS *-- State : contains
QS *-- Edge : contains
State -- Edge : connects

ISolver <|.. ODESolver : implements
ISolver <|.. MC : implements
IScheme <|.. Euler : implements
IScheme <|.. Richardson : implements
ODESolver o-- IScheme : uses
ODESolver --> QS : simulates
MC --> QS : simulates

Exp --> ISolver : coordinates
Exp --> QS : manages
Exp o-- WS : uses
Exp --> DS : collects
Exp --> MetaJSON : writes
Exp --> MetaCSV : writes

QS --> GraphML : saves to
Exp --> GraphML : manages

FileUtil --> GraphML : parses
Quantities --> GraphML : reads
PlotCC --> Quantities : uses
BinUtil --> State : operates on
Physics --> QS : provides formulas

ODESolver --> Arma : matrix operations
Exp --> PThread : threading
Exp --> JSON : metadata
WS --> PThread : uses mutex

@enduml
