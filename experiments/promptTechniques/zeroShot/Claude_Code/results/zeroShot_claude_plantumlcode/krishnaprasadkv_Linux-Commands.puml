@startuml
!define RECTANGLE class

title Linux Command Tutorial Repository - Component Diagram

package "Repository Root" {
    [README.md] as readme
    [_config.yml] as config
}

package "Documentation Modules" {
    package "Basic Commands" {
        [Basic-commands.md] as basic
        [ls.md] as ls
        [grep.md] as grep
        [findcommand.md] as find
        [links.md] as links
    }

    package "Filter Commands" {
        [filtercommands.md] as filter
    }

    package "File Management" {
        [filepermissions.md] as permissions
        [changing-ownership-and-group.md] as ownership
    }

    package "Process Management" {
        [topcommand.md] as top
        [managingprocess.md] as process
        [signalsinlinux.md] as signals
    }

    package "User Administration" {
        [useradmin.md] as useradmin
        [groupadmin.md] as groupadmin
    }

    package "Editors" {
        [vi.md] as vi
    }
}

package "Presentation Layer" {
    [GitHub Pages Site] as ghpages
    component "Jekyll Engine" as jekyll
}

package "Core Concepts" {
    component "Linux File System" as filesystem
    component "User Types" as usertypes
    component "Process Types" as processtypes
    component "Signal Handling" as signalhandling
    component "Permission Model" as permmodel
}

readme --> basic : "links to"
readme --> ls : "links to"
readme --> grep : "links to"
readme --> find : "links to"
readme --> links : "links to"
readme --> filter : "links to"
readme --> permissions : "links to"
readme --> ownership : "links to"
readme --> top : "links to"
readme --> process : "links to"
readme --> signals : "links to"
readme --> useradmin : "links to"
readme --> groupadmin : "links to"
readme --> vi : "links to"
readme --> filesystem : "explains"
readme --> usertypes : "explains"
readme --> processtypes : "explains"

config --> jekyll : "configures"
jekyll --> ghpages : "generates"
ghpages --> readme : "renders"
ghpages --> basic : "renders"
ghpages --> ls : "renders"
ghpages --> grep : "renders"
ghpages --> find : "renders"
ghpages --> links : "renders"
ghpages --> filter : "renders"
ghpages --> permissions : "renders"
ghpages --> ownership : "renders"
ghpages --> top : "renders"
ghpages --> process : "renders"
ghpages --> signals : "renders"
ghpages --> useradmin : "renders"
ghpages --> groupadmin : "renders"
ghpages --> vi : "renders"

basic --> filesystem : "references"
ls --> filesystem : "references"
find --> filesystem : "references"
links --> filesystem : "references"

permissions --> permmodel : "explains"
ownership --> permmodel : "explains"
ownership --> usertypes : "references"

process --> processtypes : "references"
signals --> signalhandling : "explains"
process --> signalhandling : "uses"
top --> processtypes : "references"

useradmin --> usertypes : "manages"
groupadmin --> usertypes : "manages"
useradmin --> permmodel : "affects"
groupadmin --> permmodel : "affects"

filter ..> basic : "builds upon"
permissions ..> basic : "builds upon"
process ..> basic : "builds upon"
useradmin ..> basic : "builds upon"

note right of readme
  Central index providing
  navigation to all tutorials
  and core concept explanations
end note

note right of "Documentation Modules"
  Modular design with each
  command/concept in separate
  Markdown file for maintainability
end note

note left of "Core Concepts"
  Foundational Linux concepts
  referenced across multiple
  tutorial modules
end note

note bottom of ghpages
  Static site generation using
  Jekyll theme for web presentation
end note

@enduml
