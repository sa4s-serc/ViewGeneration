@startuml
!define AWSPUML https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v14.0/dist
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title Piattaforma Notifiche (PN) - Control Flow Sequence Diagram

actor "Client" as client
participant "API Gateway\n(with WAF)" as apigw
participant "Cognito" as cognito
participant "Lambda\nReverse Proxy" as proxy
participant "ECS Service\n(Microservice)" as ecs
participant "EventBridge" as eventbridge
participant "SNS Topic" as sns
participant "SQS Queue" as sqs
participant "Lambda\nProcessor" as lambda
participant "DynamoDB" as dynamo
participant "S3 Bucket" as s3
participant "Kinesis Stream" as kinesis
participant "CloudWatch\nLogs" as cwlogs
participant "CloudWatch\nAlarms" as cwalarms
participant "OpenSearch" as opensearch
participant "Athena" as athena

== Authentication and API Request ==
client -> apigw: HTTP Request
activate apigw
apigw -> cognito: Validate Token
activate cognito
cognito --> apigw: Token Valid
deactivate cognito

apigw -> proxy: Forward Request
activate proxy
proxy -> ecs: Route to Microservice\n(based on URL path)
activate ecs

== Notification Processing ==
ecs -> dynamo: Store Notification Data
activate dynamo
dynamo --> ecs: Data Stored
deactivate dynamo

ecs -> eventbridge: Publish State Change Event
activate eventbridge
eventbridge -> sns: Route Event to Topic
activate sns
sns -> sqs: Fan-out to Queue
activate sqs
sns --> eventbridge: Event Delivered
deactivate sns
eventbridge --> ecs: Event Published
deactivate eventbridge

ecs --> proxy: Response
deactivate ecs
proxy --> apigw: Response
deactivate proxy
apigw --> client: HTTP Response
deactivate apigw

== Asynchronous Processing ==
lambda -> sqs: Poll for Messages
activate lambda
sqs --> lambda: Message Received
deactivate sqs

lambda -> dynamo: Read/Update Data
activate dynamo
dynamo --> lambda: Data Retrieved
deactivate dynamo

lambda -> s3: Store Processed Data
activate s3
s3 --> lambda: Data Stored
deactivate s3

lambda -> eventbridge: Publish Processing Complete Event
activate eventbridge
eventbridge -> sqs: Route to Next Queue
activate sqs
sqs --> eventbridge: Message Queued
deactivate sqs
eventbridge --> lambda: Event Published
deactivate eventbridge
deactivate lambda

== Logging and Monitoring ==
ecs -> cwlogs: Send Application Logs
activate cwlogs
cwlogs -> kinesis: Stream Logs
activate kinesis
kinesis -> lambda: Trigger Log Processing
activate lambda
lambda -> opensearch: Index Logs
activate opensearch
opensearch --> lambda: Logs Indexed
deactivate opensearch
lambda --> kinesis: Processing Complete
deactivate lambda
kinesis -> s3: Archive Logs
s3 --> kinesis: Logs Archived
deactivate kinesis
deactivate cwlogs

== CDC Processing ==
dynamo -> kinesis: Stream Table Changes (CDC)
activate kinesis
kinesis -> lambda: Trigger CDC Processor
activate lambda
lambda -> s3: Write CDC Data
activate s3
s3 --> lambda: CDC Data Stored
deactivate s3

lambda -> athena: Update CDC Cache View
activate athena
athena -> s3: Query CDC Data
s3 --> athena: Data Retrieved
athena --> lambda: View Updated
deactivate athena
deactivate lambda
deactivate kinesis

== Alarm Triggering ==
cwalarms -> cwalarms: Evaluate Metrics\n(ECS, API Gateway, Lambda, SQS)
activate cwalarms
cwalarms -> sns: Send Alarm Notification
activate sns
sns -> client: Notify (e.g., Slack)
sns --> cwalarms: Notification Sent
deactivate sns
deactivate cwalarms

== Data Export to Celonis ==
note over s3, athena
Scheduled CodeBuild Job
end note
s3 -> s3: Copy Data to Celonis Bucket
s3 -> client: Data Available for Celonis

== Cost Optimization ==
note over lambda
Scheduled Lambda (Cron)
end note
lambda -> ecs: Stop ECS Services\n(Off-peak hours)
activate lambda
activate ecs
ecs --> lambda: Services Stopped
deactivate ecs
deactivate lambda

@enduml
