@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<module>> LightGreen
    BackgroundColor<<external>> LightYellow
    BackgroundColor<<device>> LightCoral
    BackgroundColor<<backend>> Pink
}

package "Eigen Library Core" {
    component "Core Module" <<core>> as Core {
        component "Matrix/Array Classes"
        component "Expression Templates Engine"
        component "Memory Allocator"
        component "SIMD Vectorization Layer"
    }

    component "Evaluator System" <<core>> as Evaluator
    component "Traits & Metaprogramming" <<core>> as Traits
}

package "Functional Modules" {
    component "Dense Module" <<module>> as Dense
    component "Sparse Module" <<module>> as Sparse
    component "Geometry Module" <<module>> as Geometry
    component "Eigenvalues Module" <<module>> as Eigenvalues
    component "Tensor Module\n(Unsupported)" <<module>> as Tensor
}

package "Solver Modules" {
    component "Direct Solvers" <<module>> as DirectSolvers {
        component "LU Decomposition"
        component "Cholesky (LLT/LDLT)"
        component "QR Decomposition"
        component "SVD"
    }

    component "Iterative Solvers" <<module>> as IterativeSolvers {
        component "Conjugate Gradient"
        component "BiCGSTAB"
        component "GMRES"
        component "Preconditioners"
    }
}

package "External Library Integration" {
    component "BLAS Interface" <<external>> as BLAS
    component "LAPACK Interface" <<external>> as LAPACK
    component "LAPACKE C Wrapper" <<external>> as LAPACKE
}

package "Hardware/Device Backends" {
    component "CPU Backend" <<device>> as CPU {
        component "SSE Instructions"
        component "AVX Instructions"
    }

    component "ARM Backend" <<device>> as ARM {
        component "NEON Instructions"
    }

    component "PowerPC Backend" <<device>> as PowerPC {
        component "AltiVec Instructions"
    }

    component "CUDA Backend" <<backend>> as CUDA
    component "SYCL Backend" <<backend>> as SYCL
}

package "Third-Party Libraries" {
    component "Intel MKL" <<external>> as MKL
    component "OpenBLAS" <<external>> as OpenBLAS
}

' Core connectivity
Core --> Evaluator : uses
Core --> Traits : uses
Evaluator --> Traits : queries

' Module dependencies on Core
Dense --> Core : depends on
Sparse --> Core : depends on
Geometry --> Core : depends on
Eigenvalues --> Core : depends on
Tensor --> Core : depends on

' Solver dependencies
DirectSolvers --> Dense : operates on
DirectSolvers --> Sparse : operates on
IterativeSolvers --> Sparse : optimized for
IterativeSolvers --> Dense : operates on

' External library integration
Dense --> BLAS : delegates to
DirectSolvers --> LAPACK : delegates to
LAPACK --> LAPACKE : wrapped by
BLAS --> MKL : implementation
BLAS --> OpenBLAS : implementation
LAPACK --> MKL : implementation
LAPACK --> OpenBLAS : implementation

' SIMD Backend connectivity
Core --> CPU : deploys to
Core --> ARM : deploys to
Core --> PowerPC : deploys to

' Tensor backend connectivity
Tensor --> CPU : executes on
Tensor --> CUDA : executes on
Tensor --> SYCL : executes on

' Module interconnectivity
Eigenvalues --> DirectSolvers : uses
Geometry --> Dense : uses

note right of Core
  Expression templates enable
  compile-time optimization and
  lazy evaluation across modules
end note

note bottom of "External Library Integration"
  Bridge pattern allows seamless
  integration with optimized
  numerical libraries
end note

note bottom of "Hardware/Device Backends"
  Platform-specific SIMD
  vectorization for optimal
  performance deployment
end note

@enduml
