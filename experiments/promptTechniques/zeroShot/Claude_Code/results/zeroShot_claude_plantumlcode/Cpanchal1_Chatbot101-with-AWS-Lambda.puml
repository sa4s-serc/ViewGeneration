@startuml
!define AWSPUML https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v14.0/dist
!include AWSPUML/AWSCommon.puml

title Webex Teams Chatbot - Control Flow Sequence Diagram

actor "User" as User
participant "Webex Teams\nRoom" as WebexRoom
participant "Webex Teams\nWebhook" as Webhook
participant "AWS API\nGateway" as APIGateway
participant "AWS Lambda\n(main)" as Lambda
participant "getJoke()" as GetJoke
participant "icanhazdadjoke\nAPI" as JokeAPI
participant "postJoke()" as PostJoke
participant "Webex Teams\nAPI" as WebexAPI

User -> WebexRoom: Mention bot in room
activate WebexRoom

WebexRoom -> Webhook: Trigger mention event
activate Webhook

Webhook -> APIGateway: POST webhook request
activate APIGateway

APIGateway -> Lambda: Invoke Lambda function
activate Lambda

Lambda -> GetJoke: Call getJoke()
activate GetJoke

GetJoke -> JokeAPI: HTTP GET request\n(icanhazdadjoke.com)
activate JokeAPI

JokeAPI --> GetJoke: JSON response with joke
deactivate JokeAPI

GetJoke -> GetJoke: Parse JSON response\nExtract joke text

GetJoke --> Lambda: Return joke text
deactivate GetJoke

Lambda -> PostJoke: Call postJoke(joke, ROOMID, TOKEN)
activate PostJoke

PostJoke -> WebexAPI: POST message to room\n(Authorization: TOKEN)
activate WebexAPI

WebexAPI --> PostJoke: Success response
deactivate WebexAPI

PostJoke --> Lambda: Confirm message posted
deactivate PostJoke

Lambda --> APIGateway: Return success message
deactivate Lambda

APIGateway --> Webhook: HTTP 200 OK
deactivate APIGateway

Webhook --> WebexRoom: Acknowledge webhook processed
deactivate Webhook

WebexRoom -> User: Display joke in room
deactivate WebexRoom

@enduml
