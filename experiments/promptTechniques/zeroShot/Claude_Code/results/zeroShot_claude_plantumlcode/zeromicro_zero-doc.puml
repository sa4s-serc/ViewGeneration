@startuml

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<tool>> LightGreen
    BackgroundColor<<service>> LightYellow
    BackgroundColor<<infrastructure>> LightGray
    BackgroundColor<<observability>> LightPink
}

package "Go-Zero Framework" {

    package "Code Generation" <<tool>> {
        [goctl] <<core>>
        [API Generator] <<core>>
        [RPC Generator] <<core>>
        [Model Generator] <<core>>
        [Deployment Generator] <<core>>
        [Template Manager] <<core>>
    }

    package "API Layer" {
        [API Gateway] <<service>>
        [API Handler] <<service>>
        [Middleware] <<core>>
        [JWT Auth] <<core>>
        [Logging] <<core>>
        [Metrics Middleware] <<core>>
        [Tracing Middleware] <<core>>
    }

    package "RPC Framework" {
        [zRPC] <<core>>
        [gRPC Integration] <<core>>
        [Service Discovery Component] <<core>>
        [Load Balancing] <<core>>
        [RPC Interceptors] <<core>>
    }

    package "Business Logic Layer" {
        [Logic Layer] <<service>>
        [Service Context] <<core>>
        [Dependency Injection] <<core>>
        [Shared Resources] <<core>>
    }

    package "Data Access Layer" {
        [Model Layer] <<service>>
        [Cache Manager] <<core>>
        [SharedCalls Singleflight] <<core>>
        [Cache Stampede Prevention] <<core>>
        [Read-Through Write-Back] <<core>>
        [Primary Unique Indexes] <<core>>
    }

    package "Resilience and Performance" {
        [Adaptive Load Shedding] <<core>>
        [CPU Monitor] <<core>>
        [Concurrency Control] <<core>>
        [Sliding Window] <<core>>
        [Circuit Breaker] <<core>>
        [Google Breaker Algorithm] <<core>>
        [Rate Limiter] <<core>>
        [Token Bucket] <<core>>
        [Period-based Limiter] <<core>>
        [Token Limit Redis] <<core>>
    }

    package "Concurrency Utilities" {
        [MapReduce fx] <<core>>
        [SharedCalls] <<core>>
        [BulkExecutor] <<core>>
        [PeriodicalExecutor] <<core>>
    }

    package "Task Queue" {
        [go-queue] <<core>>
        [dq Beanstalkd] <<core>>
        [kq Kafka] <<core>>
    }

    package "Configuration Management" {
        [Config Loader] <<core>>
    }

    package "Service Discovery Backends" <<infrastructure>> {
        [Direct Connection] <<infrastructure>>
        [etcd Integration] <<infrastructure>>
        [Kubernetes Endpoints] <<infrastructure>>
    }

    package "Observability" <<observability>> {
        [Prometheus Integration] <<observability>>
        [Default Metrics] <<observability>>
        [Custom Metrics] <<observability>>
        [Grafana Visualization] <<observability>>
        [Distributed Tracing] <<observability>>
        [Jaeger Support] <<observability>>
        [Zipkin Support] <<observability>>
    }

    package "External Storage" <<infrastructure>> {
        database "Database" as db
        database "Redis" as redis
        queue "Message Queue" as mq
    }
}

package "Deployment Artifacts" {
    artifact ".api files" as api_files
    artifact ".proto files" as proto_files
    artifact ".yaml files" as yaml_files
    artifact ".sql files" as sql_files
    artifact "Dockerfiles" as docker
    artifact "K8s Manifests" as k8s
    artifact "CI/CD Scripts" as cicd
}

' Component containment relationships
[goctl] ..> [API Generator]
[goctl] ..> [RPC Generator]
[goctl] ..> [Model Generator]
[goctl] ..> [Deployment Generator]
[goctl] ..> [Template Manager]

[Middleware] ..> [JWT Auth]
[Middleware] ..> [Logging]
[Middleware] ..> [Metrics Middleware]
[Middleware] ..> [Tracing Middleware]

[zRPC] ..> [gRPC Integration]
[zRPC] ..> [Service Discovery Component]
[zRPC] ..> [Load Balancing]
[zRPC] ..> [RPC Interceptors]

[Service Context] ..> [Dependency Injection]
[Service Context] ..> [Shared Resources]

[Cache Manager] ..> [SharedCalls Singleflight]
[Cache Manager] ..> [Cache Stampede Prevention]
[Cache Manager] ..> [Read-Through Write-Back]
[Cache Manager] ..> [Primary Unique Indexes]

[Adaptive Load Shedding] ..> [CPU Monitor]
[Adaptive Load Shedding] ..> [Concurrency Control]
[Adaptive Load Shedding] ..> [Sliding Window]

[Circuit Breaker] ..> [Google Breaker Algorithm]

[Rate Limiter] ..> [Token Bucket]
[Rate Limiter] ..> [Period-based Limiter]
[Rate Limiter] ..> [Token Limit Redis]

[go-queue] ..> [dq Beanstalkd]
[go-queue] ..> [kq Kafka]

[Prometheus Integration] ..> [Default Metrics]
[Prometheus Integration] ..> [Custom Metrics]

[Distributed Tracing] ..> [Jaeger Support]
[Distributed Tracing] ..> [Zipkin Support]

' Code Generation Relationships
api_files --> [API Generator] : input
proto_files --> [RPC Generator] : input
sql_files --> [Model Generator] : input

[API Generator] --> [API Handler] : generates
[RPC Generator] --> [zRPC] : generates
[Model Generator] --> [Model Layer] : generates
[Deployment Generator] --> docker : generates
[Deployment Generator] --> k8s : generates

' Configuration Flow
yaml_files --> [Config Loader] : config
[Config Loader] --> [Service Context] : loads config

' Request Flow
[API Gateway] --> [Middleware] : HTTP Request
[Middleware] --> [API Handler] : filtered request
[API Handler] --> [Logic Layer] : call business logic
[Logic Layer] --> [Service Context] : access dependencies
[Logic Layer] --> [Model Layer] : data operations

' RPC Communication
[API Handler] --> [zRPC] : RPC calls
[Service Discovery Component] --> [Direct Connection] : direct
[Service Discovery Component] --> [etcd Integration] : etcd
[Service Discovery Component] --> [Kubernetes Endpoints] : k8s

' Data Access
[Model Layer] --> [Cache Manager] : check cache
[Cache Manager] --> redis : cache ops
[Model Layer] --> db : database ops

' Resilience Integration
[API Gateway] --> [Rate Limiter] : rate control
[API Handler] --> [Adaptive Load Shedding] : load management
[zRPC] --> [Circuit Breaker] : protect downstream
[Logic Layer] --> [Circuit Breaker] : protect calls

' Concurrency Support
[Logic Layer] --> [MapReduce fx] : concurrent processing
[Cache Manager] --> [SharedCalls] : deduplicate calls
[Model Layer] --> [BulkExecutor] : batch operations
[Model Layer] --> [PeriodicalExecutor] : scheduled tasks

' Task Queue Integration
[Logic Layer] --> [go-queue] : async tasks
[dq Beanstalkd] --> mq : Beanstalkd
[kq Kafka] --> mq : Kafka

' Rate Limiting Infrastructure
[Token Limit Redis] --> redis : distributed limiting

' Observability Integration
[Middleware] --> [Prometheus Integration] : collect metrics
[Middleware] --> [Distributed Tracing] : trace requests
[API Handler] --> [Prometheus Integration] : metrics
[Logic Layer] --> [Prometheus Integration] : metrics
[zRPC] --> [Distributed Tracing] : trace RPC
[Prometheus Integration] --> [Grafana Visualization] : visualize

' CI/CD Integration
cicd --> [goctl] : automated builds

note right of [goctl]
  Core tool for code generation
  Reduces boilerplate
  Ensures consistency
  Template-based customization
end note

note right of [Service Context]
  Dependency Injection pattern
  Singleton-like lifecycle
  Holds shared resources:
  - DB connections
  - RPC clients
  - Configuration
end note

note right of [Cache Manager]
  Prevents cache stampedes
  Uses singleflight pattern
  Expiration time deviation
  Hides cache complexity
end note

note bottom of [Adaptive Load Shedding]
  Dynamic request acceptance
  Based on CPU and concurrency
  Sliding window algorithm
  Prevents system overload
end note

note bottom of [Observability]
  Built-in monitoring
  Cloud-native focus
  Multiple tracing backends
  Custom and default metrics
end note

@enduml
