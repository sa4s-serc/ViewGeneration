@startuml
!define RECTANGLE class

skinparam componentStyle rectangle

package "UI Layer" {
    component [GpsMainActivity] as MainActivity
    component [MainPreferenceActivity] as PreferenceActivity
    component [LogViewingUI] as LogView
}

package "Core Service Layer" {
    component [GpsLoggingService] as LoggingService
    component [GeneralLocationListener] as LocationListener
    component [EventBus] as EventBus
}

package "Configuration Layer" {
    component [PreferenceHelper] as PrefHelper
    component [AppSettings] as AppSettings
    component [Session] as Session
}

package "Data Processing Layer" {
    component [FileLoggerFactory] as LoggerFactory
    component [GPXLogger] as GPXLogger
    component [KMLLogger] as KMLLogger
    component [CSVLogger] as CSVLogger
    component [GeoJSONLogger] as GeoJSONLogger
    component [NMEALogger] as NMEALogger
}

package "Background Job Layer" {
    component [WorkManager] as WorkManager
    component [GoogleDriveWorker] as DriveWorker
    component [DropboxWorker] as DropboxWorker
    component [FTPWorker] as FTPWorker
    component [SFTPWorker] as SFTPWorker
    component [EmailWorker] as EmailWorker
    component [CustomURLWorker] as URLWorker
}

package "External Service Integration" {
    component [FileSender] as FileSender
    component [GoogleDriveManager] as DriveManager
    component [DropboxManager] as DropboxManager
    component [OwnCloudManager] as OwnCloudManager
    component [OpenStreetMapManager] as OSMManager
    component [CustomURLManager] as URLManager
}

package "External Applications" {
    component [ContentProvider] as ContentProvider
    component [TaskerReceiver] as TaskerReceiver
}

package "External Services" {
    cloud "Google Drive API" as GoogleDrive
    cloud "Dropbox API" as Dropbox
    cloud "OpenStreetMap API" as OSM
    cloud "FTP/SFTP Server" as FTPServer
    cloud "OwnCloud API" as OwnCloud
    cloud "Email Server" as EmailServer
    cloud "Custom HTTP/HTTPS" as CustomURL
}

package "Platform Services" {
    component [LocationProviders] as LocationProviders
    component [FileStorage] as Storage
    component [Accelerometer] as Accelerometer
    component [Notifications] as Notifications
}

MainActivity --> LoggingService : controls
MainActivity --> EventBus : subscribes
PreferenceActivity --> PrefHelper : configures
LogView --> Storage : reads

LoggingService --> LocationListener : uses
LoggingService --> LoggerFactory : creates loggers
LoggingService --> EventBus : publishes
LoggingService --> WorkManager : schedules uploads
LoggingService --> Notifications : shows status

LocationListener --> LocationProviders : receives updates
LocationListener --> Accelerometer : motion detection
LocationListener --> LoggingService : notifies

LoggerFactory --> GPXLogger : creates
LoggerFactory --> KMLLogger : creates
LoggerFactory --> CSVLogger : creates
LoggerFactory --> GeoJSONLogger : creates
LoggerFactory --> NMEALogger : creates

GPXLogger --> Storage : writes
KMLLogger --> Storage : writes
CSVLogger --> Storage : writes
GeoJSONLogger --> Storage : writes
NMEALogger --> Storage : writes

WorkManager --> DriveWorker : executes
WorkManager --> DropboxWorker : executes
WorkManager --> FTPWorker : executes
WorkManager --> SFTPWorker : executes
WorkManager --> EmailWorker : executes
WorkManager --> URLWorker : executes

DriveWorker --> DriveManager : uses
DropboxWorker --> DropboxManager : uses
FTPWorker --> FileSender : uses
SFTPWorker --> FileSender : uses
EmailWorker --> FileSender : uses
URLWorker --> URLManager : uses

DriveManager --> GoogleDrive : OAuth 2.0
DropboxManager --> Dropbox : OAuth 2.0
OSMManager --> OSM : OAuth 2.0
FileSender --> FTPServer : FTP/SFTP
FileSender --> EmailServer : SMTP
OwnCloudManager --> OwnCloud : WebDAV
URLManager --> CustomURL : HTTP/HTTPS

DriveManager --> Storage : reads files
DropboxManager --> Storage : reads files
FileSender --> Storage : reads files
URLManager --> Storage : reads files

ContentProvider --> Storage : provides access
TaskerReceiver --> LoggingService : controls

PrefHelper ..> Session : provides config
AppSettings ..> PrefHelper : initializes
LoggingService ..> PrefHelper : reads config
LoggerFactory ..> PrefHelper : reads format preference
WorkManager ..> PrefHelper : reads upload settings

note right of LocationProviders
  GPS, Network, Passive
  Location Providers
end note

note right of FileSender
  Template Method Pattern
  for various upload strategies
end note

note right of LoggerFactory
  Factory Pattern creates
  appropriate file format logger
end note

note right of EventBus
  Event-Driven Architecture
  for component decoupling
end note

note right of WorkManager
  Ensures reliable background
  uploads with retry logic
end note

@enduml
