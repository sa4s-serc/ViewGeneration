@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<manipulator>> LightGreen
  BackgroundColor<<detector>> LightYellow
  BackgroundColor<<emitter>> LightCoral
  BackgroundColor<<logger>> Lavender
  BackgroundColor<<util>> WhiteSmoke
}

package "CLI Layer" {
  [index.ts] as CLI <<core>>
}

package "Orchestration Layer" {
  [runner.ts] as Runner <<core>>
}

package "Core Components" {
  [parser.ts] as Parser <<core>>
  [types.ts] as Types <<core>>
  component "Project\n(ts-morph)" as Project <<core>>
}

package "Error Detection" {
  [error_detector.ts] as BaseErrorDetector <<detector>>
  [prod_error_detector.ts] as ProdErrorDetector <<detector>>
}

package "Code Manipulation" {
  [Manipulators] as ManipulatorRegistry <<manipulator>>
  [no_implicit_returns_manipulator.ts] as NoImplicitReturnsManipulator <<manipulator>>
  [strict_null_checks_manipulator.ts] as StrictNullChecksManipulator <<manipulator>>
  [strict_property_initialization_manipulator.ts] as StrictPropertyInitManipulator <<manipulator>>
  [no_implicit_any_manipulator.ts] as NoImplicitAnyManipulator <<manipulator>>
}

package "Output Layer" {
  interface "Emitter" as IEmitter
  [in_place_emitter.ts] as InPlaceEmitter <<emitter>>
  [out_of_place_emitter.ts] as OutOfPlaceEmitter <<emitter>>
}

package "Logging Layer" {
  interface "Logger" as ILogger
  [console_logger.ts] as ConsoleLogger <<logger>>
  [stub_logger.ts] as StubLogger <<logger>>
}

package "Utilities" {
  [util] as Util <<util>>
}

package "External Dependencies" {
  component "TypeScript Compiler API" as TSCompiler
  component "ts-morph" as TSMorph
}

' CLI connections
CLI --> Runner : creates and invokes

' Runner orchestration
Runner --> Parser : uses
Runner --> ManipulatorRegistry : coordinates
Runner --> IEmitter : uses
Runner --> ILogger : uses
Runner --> Project : manages

' Parser connections
Parser --> Project : analyzes
Parser --> TSCompiler : retrieves diagnostics
Parser ..> Types : uses

' Error Detector hierarchy
ProdErrorDetector --|> BaseErrorDetector : extends
Runner --> BaseErrorDetector : uses
BaseErrorDetector --> Project : inspects

' Manipulator registry and implementations
ManipulatorRegistry --> NoImplicitReturnsManipulator : contains
ManipulatorRegistry --> StrictNullChecksManipulator : contains
ManipulatorRegistry --> StrictPropertyInitManipulator : contains
ManipulatorRegistry --> NoImplicitAnyManipulator : contains

NoImplicitReturnsManipulator --> Project : modifies
StrictNullChecksManipulator --> Project : modifies
StrictPropertyInitManipulator --> Project : modifies
NoImplicitAnyManipulator --> Project : modifies

NoImplicitReturnsManipulator ..> Types : uses
StrictNullChecksManipulator ..> Types : uses
StrictPropertyInitManipulator ..> Types : uses
NoImplicitAnyManipulator ..> Types : uses

' Emitter implementations
InPlaceEmitter ..|> IEmitter : implements
OutOfPlaceEmitter ..|> IEmitter : implements
IEmitter --> Project : writes changes

' Logger implementations
ConsoleLogger ..|> ILogger : implements
StubLogger ..|> ILogger : implements

' Utility usage
Parser ..> Util : uses
Runner ..> Util : uses
ManipulatorRegistry ..> Util : uses

' External dependency connections
Project --> TSMorph : wraps
TSMorph --> TSCompiler : uses

note right of Runner
  Coordinates the upgrade process:
  1. Parse project
  2. Detect errors
  3. Apply fixes iteratively
  4. Emit modified code
  5. Log progress
end note

note right of ManipulatorRegistry
  Strategy Pattern:
  Each manipulator handles
  a specific compiler flag
end note

note bottom of IEmitter
  Factory Pattern:
  Runner selects appropriate
  emitter based on arguments
end note

note bottom of ILogger
  Dependency Injection:
  Logger implementation can
  be swapped for testing
end note

@enduml
