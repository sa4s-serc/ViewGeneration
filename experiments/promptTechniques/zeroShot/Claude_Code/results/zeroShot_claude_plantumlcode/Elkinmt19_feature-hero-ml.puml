@startuml
!theme plain
title Feature Hero ML - Feature Store Interaction Flow

actor DataEngineer as DE
participant "Fetch Card\nTransdata Script" as FetchScript
participant "Get Train/Val\nScript" as SplitScript
participant "Feature Store\n(Feast)" as Feast
database "Parquet\n(Offline Store)" as Parquet
database "Redis\n(Online Store)" as Redis
participant "Feature Server" as FeatureServer
participant "ML Training\nService" as Training
participant "ML Prediction\nService" as Prediction

== Data Ingestion & Feature Definition ==
DE -> FetchScript: Execute fetch_card_transdata.py
activate FetchScript
FetchScript -> FetchScript: Fetch credit card dataset
FetchScript -> FetchScript: Transform data\n(add user_id, transaction_uuid)
FetchScript -> Parquet: Save raw data\n(train/val split)
deactivate FetchScript

DE -> SplitScript: Execute get_train_val_card_transdata.py
activate SplitScript
SplitScript -> Parquet: Read transaction data
SplitScript -> SplitScript: Split by day
SplitScript -> Parquet: Save train dataset
SplitScript -> Parquet: Save validation dataset
deactivate SplitScript

DE -> Feast: Define feature views\n(card_transdata_feature_definition.py)
activate Feast
Feast -> Feast: Register feature views\n(schema, entities, TTL)
Feast -> Feast: Configure data sources
deactivate Feast

== Feature Materialization ==
DE -> Feast: Execute materialize command
activate Feast
Feast -> Parquet: Read offline features
Feast -> Redis: Materialize features\n(with TTL)
activate Redis
Redis --> Feast: Confirmation
deactivate Redis
deactivate Feast

== Offline Feature Serving (Training) ==
Training -> Feast: Request historical features\n(entity IDs, time range)
activate Training
activate Feast
Feast -> Parquet: Query offline store
activate Parquet
Parquet --> Feast: Historical feature data
deactivate Parquet
Feast --> Training: Feature dataset
deactivate Feast
Training -> Training: Train ML model
deactivate Training

== Online Feature Serving (Real-time Prediction) ==
Prediction -> FeatureServer: Request online features\n(entity IDs)
activate Prediction
activate FeatureServer
FeatureServer -> Feast: Get online features
activate Feast
Feast -> Redis: Retrieve features
activate Redis
Redis --> Feast: Feature values
deactivate Redis
Feast --> FeatureServer: Feature response
deactivate Feast
FeatureServer --> Prediction: Feature data (JSON)
deactivate FeatureServer
Prediction -> Prediction: Generate prediction
Prediction --> Prediction: Return prediction result
deactivate Prediction

== Feature Store Management ==
DE -> Feast: Apply feature definitions
activate Feast
Feast -> Feast: Update registry
Feast -> Parquet: Validate offline store
Feast -> Redis: Validate online store
Feast --> DE: Configuration applied
deactivate Feast

@enduml
