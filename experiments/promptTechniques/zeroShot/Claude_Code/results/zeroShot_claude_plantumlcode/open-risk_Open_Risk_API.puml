@startuml
!define RECTANGLE_STEREOTYPE <<deployment>>

skinparam component {
    BackgroundColor<<server>> LightBlue
    BackgroundColor<<client>> LightGreen
    BackgroundColor<<database>> LightYellow
    BackgroundColor<<library>> LightGray
}

skinparam node {
    BackgroundColor LightSteelBlue
}

title Open Risk API - Deployment Architecture

node "Model Server Environment" {
    component "Model Server" <<server>> as ModelServer {
        component "Flask Application" as FlaskApp
        component "model_server.py" as ModelServerPy
        component "RDFlib" as RDFLib
        component "concentration_library.py" as ConcLib
    }

    component "OpenCPM Model Server" <<server>> as OpenCPMServer {
        component "Model_Server.py" as OpenCPMModelServerPy
        component "model.py" as ModelPy
        component "Compute.py" as ComputePy
    }

    folder "Model Metadata (RDF)" as ModelMetadata {
        file "model_list.rdf" as ModelList
        file "Gini_Index.rdf" as GiniRDF
        file "HHI_Index.rdf" as HHIRDF
        file "Shannon_Index.rdf" as ShannonRDF
    }
}

node "Data Server Environment" {
    component "Data Server" <<server>> as DataServer {
        component "Python-Eve" as PythonEve
        component "run.py" as RunPy
        component "settings.py" as SettingsPy
    }

    database "MongoDB" <<database>> as MongoDB {
    }
}

node "Client Environment" {
    component "API Explorer" <<client>> as APIExplorer {
        component "explorer.py" as ExplorerPy
    }

    component "LibreOffice Integration" <<client>> as LibreOffice {
        component "libreoffice_macros.py" as LibreofficeMacros
        file "NPL_Template_Calculation.ods" as Template
    }
}

component "ConcentrationMetrics Library" <<library>> as ConcentrationLib {
    component "HHI Calculator" as HHI
    component "Gini Index Calculator" as Gini
    component "Shannon Entropy Calculator" as Shannon
}

' Relationships for Model Server
FlaskApp --> ModelServerPy
ModelServerPy --> RDFLib
ModelServerPy --> ConcLib
RDFLib --> ModelMetadata
ConcLib --> ConcentrationLib

' Relationships for OpenCPM Server
OpenCPMServer --> ModelPy
OpenCPMServer --> ComputePy
ComputePy --> ConcentrationLib
ModelPy --> ModelMetadata

' Relationships for Data Server
DataServer --> PythonEve
PythonEve --> MongoDB
RunPy --> SettingsPy

' Client to Server Communications
APIExplorer ..> ModelServer : HTTP/REST\n(Model Descriptions &\nCalculations)
APIExplorer ..> DataServer : HTTP/REST\n(Portfolio Data)
APIExplorer ..> OpenCPMServer : HTTP/REST\n(NPL Concentration\nMetrics)

LibreOffice ..> ModelServer : HTTP/REST
LibreOffice ..> DataServer : HTTP/REST

' Deployment annotations
note right of ModelServer
  Provides RESTful endpoints for:
  - Model metadata (RDF/JSON-LD)
  - Concentration calculations
  - Model descriptions
end note

note right of DataServer
  Hosts portfolio data via
  Python-Eve RESTful API
  backed by MongoDB
end note

note left of APIExplorer
  Python client for:
  - Retrieving model info
  - Executing calculations
  - Accessing portfolio data
end note

note bottom of MongoDB
  NoSQL database storing
  financial portfolio data
end note

note top of ConcentrationLib
  Shared library providing
  concentration risk measures
end note

@enduml
