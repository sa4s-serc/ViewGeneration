@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
    BackgroundColor<<core>> LightBlue
    BackgroundColor<<abstraction>> LightGreen
    BackgroundColor<<application>> LightYellow
    BackgroundColor<<tool>> LightGray
    BorderColor Black
    ArrowColor Black
}

package "cFS Bundle" {

    package "Core Flight Executive (cFE)" <<core>> {
        component "Executive Services (ES)" as ES
        component "Event Services (EVS)" as EVS
        component "Software Bus (SB)" as SB
        component "Time Services (TIME)" as TIME
        component "Table Services (TBL)" as TBL
        component "File Services (FS)" as FS
    }

    package "Operating System Abstraction Layer (OSAL)" <<abstraction>> {
        component "OS API" as OSAPI
        component "Task Management" as TaskMgmt
        component "File System API" as FileAPI
        component "Network API" as NetAPI
        component "Timer API" as TimerAPI
    }

    package "Platform Support Package (PSP)" <<abstraction>> {
        component "Hardware Abstraction" as HWAbs
        component "Boot & Startup" as Boot
        component "Memory Management" as MemMgmt
    }

    package "Applications" <<application>> {
        component "Lab Applications" as LabApps
        component "CI Lab" as CI_Lab
        component "TO Lab" as TO_Lab
        component "SCH Lab" as SCH_Lab
        component "Custom Applications" as CustomApps
    }

    package "Tools" <<tool>> {
        component "Build Tools" as BuildTools
        component "Command Tools" as CmdTools
        component "Telemetry Tools" as TlmTools
    }

    package "CI/CD Pipeline" {
        component "Static Analysis\n(Cppcheck, CodeQL, MISRA)" as StaticAnalysis
        component "Unit Testing" as UnitTest
        component "Code Formatting\n(clang-format)" as CodeFormat
        component "Functional Testing" as FuncTest
        component "Cross-Platform Build" as CrossBuild
    }
}

package "Operating System" {
    component "Linux" as Linux
    component "RTEMS" as RTEMS
    component "Other OS" as OtherOS
}

package "Hardware Platform" {
    component "Target Hardware" as Hardware
}

' Core relationships within cFE
ES -down-> SB : manages
EVS -down-> SB : publishes events
TIME --> SB : time messages
TBL --> SB : table updates
FS --> SB : file operations

' Applications use cFE services
LabApps --> ES : register
LabApps --> SB : subscribe/publish
CI_Lab --> SB : command input
TO_Lab --> SB : telemetry output
SCH_Lab --> SB : scheduling
CustomApps --> SB : messaging
CustomApps --> TBL : table access
CustomApps --> EVS : event logging

' cFE uses OSAL
ES --> OSAPI : OS abstraction
SB --> TaskMgmt : task operations
FS --> FileAPI : file I/O
SB --> NetAPI : network comm
TIME --> TimerAPI : time services

' OSAL uses PSP
OSAPI --> HWAbs : hardware access
TaskMgmt --> MemMgmt : memory allocation
Boot --> HWAbs : initialization

' PSP interfaces with OS
HWAbs --> Linux : platform specific
HWAbs --> RTEMS : platform specific
HWAbs --> OtherOS : platform specific

' OS runs on Hardware
Linux --> Hardware
RTEMS --> Hardware
OtherOS --> Hardware

' Tools interact with system
BuildTools ..> cFE : builds
CmdTools ..> CI_Lab : sends commands
TO_Lab ..> TlmTools : sends telemetry

' CI/CD validates components
StaticAnalysis ..> cFE : analyzes
StaticAnalysis ..> Applications : analyzes
UnitTest ..> cFE : tests
UnitTest ..> Applications : tests
CodeFormat ..> cFE : formats
CodeFormat ..> Applications : formats
FuncTest ..> cFE : validates
CrossBuild ..> cFE : builds
CrossBuild ..> OSAL : builds

note right of cFE
  Microkernel Architecture
  Event-Driven Design
  Software Bus for messaging
end note

note right of OSAL
  Abstraction Pattern
  Promotes portability
  OS-independent API
end note

note right of Applications
  Component-Based Design
  Modular & Reusable
  Independent Development
end note

note bottom of "CI/CD Pipeline"
  Ensures Code Quality
  Cross-Platform Testing
  Automated Validation
end note

@enduml
