@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<web>> LightBlue
    BackgroundColor<<service>> LightGreen
    BackgroundColor<<data>> LightYellow
    BackgroundColor<<external>> LightGray
    BackgroundColor<<config>> LightPink
}

package "Client Tier" {
    [Web Browser] as browser <<web>>
}

package "Application Server" {
    package "Spring Boot Application" {
        component [SpiderApplication\n(Main)] as main <<web>>

        package "Controller Layer" {
            component [IndexController] as indexCtrl <<web>>
            component [PathController] as pathCtrl <<web>>
            component [JsonController\n(REST API)] as jsonCtrl <<web>>
        }

        package "Service Layer" {
            component [MongoService] as mongoSvc <<service>>
            component [LogService] as logSvc <<service>>
            component [HttpRequestService] as httpSvc <<service>>
        }

        package "Scheduled Jobs" {
            component [Scheduler\n(Data Refresh)] as scheduler <<service>>
        }

        package "Configuration" {
            component [RequestLoggingFilterConfig] as logFilter <<config>>
            component [application.yml] as appConfig <<config>>
            component [logback.xml] as logConfig <<config>>
        }

        package "Utilities" {
            component [FileUtils] as fileUtil <<service>>
            component [DateUtils] as dateUtil <<service>>
            component [JsonUtils] as jsonUtil <<service>>
        }

        package "Constants" {
            component [FifarmCV] as constants <<config>>
        }

        package "View Layer" {
            component [Thymeleaf Templates] as templates <<web>>
        }

        package "Static Resources" {
            component [CSS/JS/Images] as staticRes <<web>>
        }
    }

    component [Maven Wrapper] as maven <<config>>
}

package "Data Tier" {
    database "MongoDB" as mongodb <<data>> {
        component [Player Collection] as playerDB
        component [Spring Data MongoDB\nRepositories] as mongoRepo
    }
}

package "External Services" {
    cloud "EA Sports FUT API" as eaAPI <<external>>
}

package "Deployment Environment" {
    node "Local Profile" as localEnv <<config>>
    node "Production Profile" as prodEnv <<config>>
}

browser --> indexCtrl : HTTP Request
browser --> pathCtrl : HTTP Request
browser --> jsonCtrl : REST API Call

indexCtrl --> mongoSvc : Query Players
pathCtrl --> mongoSvc : Query Players
jsonCtrl --> mongoSvc : Query Players

indexCtrl --> templates : Render View
pathCtrl --> templates : Render View
jsonCtrl ..> constants : Use API URLs

templates --> staticRes : Include Assets

mongoSvc --> mongoRepo : Data Access
mongoRepo --> playerDB : CRUD Operations

scheduler --> httpSvc : Fetch Player Data
httpSvc --> eaAPI : API Request
httpSvc ..> constants : User-Agent & URLs

scheduler --> mongoSvc : Store/Update Data

logFilter --> logSvc : Log Requests
logSvc ..> logConfig : Use Configuration

main ..> appConfig : Load Configuration
appConfig ..> localEnv : Local Settings
appConfig ..> prodEnv : Production Settings

mongoSvc ..> appConfig : MongoDB Connection
httpSvc ..> jsonUtil : Parse JSON
mongoSvc ..> dateUtil : Date Operations
logSvc ..> fileUtil : File Operations

maven ..> main : Build & Run

note right of scheduler
  Scheduled task for
  periodic data refresh
  from EA Sports API
end note

note right of mongodb
  Stores FIFA Ultimate Team
  player data
end note

note right of eaAPI
  External EA Sports
  FUT API endpoint
end note

note bottom of appConfig
  Profile-based configuration:
  - MongoDB connection
  - Server port
  - Environment settings
end note

@enduml
