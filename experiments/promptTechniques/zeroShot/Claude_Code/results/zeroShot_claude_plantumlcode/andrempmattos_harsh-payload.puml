@startuml
!define COMPONENT_STYLE rectangle

skinparam component {
    BackgroundColor<<RTOS>> LightBlue
    BackgroundColor<<Driver>> LightGreen
    BackgroundColor<<Hardware>> LightGray
    BackgroundColor<<Application>> LightYellow
    BorderColor Black
}

package "Application Layer" {
    [Experiment Algorithms] <<Application>> as ExpAlgo
    [Memory Testing Tasks] <<Application>> as MemTest
    [Latch-up Detection] <<Application>> as LatchUp
    [OBC Communication] <<Application>> as OBC
}

package "FreeRTOS Kernel" <<RTOS>> {
    [Task Scheduler] <<RTOS>> as Scheduler
    [Priority Queue Manager] <<RTOS>> as PrioQueue
    [Task Manager] <<RTOS>> as TaskMgr
    [Timer Service] <<RTOS>> as TimerSvc
    [Event Groups] <<RTOS>> as EventGroups
    [Mutex & Semaphores] <<RTOS>> as Mutex
    [Queue Management] <<RTOS>> as QueueMgr
}

package "Driver Layer" {
    [Interrupt Controller] <<Driver>> as IntCtrl
    [PDMA Driver] <<Driver>> as PDMA
    [Watchdog Timer Driver] <<Driver>> as WDT
    [Timer Driver] <<Driver>> as Timer
    [UART Driver] <<Driver>> as UART
    [SPI Driver] <<Driver>> as SPI
    [GPIO Driver] <<Driver>> as GPIO
}

package "Hardware Layer" <<Hardware>> {
    [FPGA Fabric] <<Hardware>> as FPGA
    [AXI/AHB Interconnect] <<Hardware>> as BusInt
    [System Controller] <<Hardware>> as SysCtrl
    [Clock Generator (CCC)] <<Hardware>> as ClkGen
    [Reset Controller] <<Hardware>> as ResetCtrl
}

' Application to RTOS connections
ExpAlgo --> TaskMgr : creates tasks
MemTest --> TaskMgr : creates tasks
LatchUp --> TaskMgr : creates tasks
OBC --> TaskMgr : creates tasks

ExpAlgo --> QueueMgr : uses queues
MemTest --> EventGroups : waits on events
LatchUp --> TimerSvc : periodic checks
OBC --> Mutex : resource protection

' RTOS internal scheduling relationships
TaskMgr --> Scheduler : registers tasks
TimerSvc --> Scheduler : timer callbacks
Scheduler --> PrioQueue : priority-based scheduling
PrioQueue --> TaskMgr : task selection
EventGroups --> QueueMgr : implemented via queues
Mutex --> QueueMgr : implemented via queues

' RTOS to Driver connections
Scheduler --> IntCtrl : context switching
TimerSvc --> Timer : hardware timer
TaskMgr --> IntCtrl : ISR handling
Scheduler --> WDT : task monitoring

' Driver to Hardware connections
IntCtrl --> SysCtrl : interrupt routing
PDMA --> BusInt : DMA transfers
Timer --> FPGA : timer peripherals
WDT --> FPGA : watchdog peripheral
UART --> BusInt : peripheral access
SPI --> BusInt : peripheral access
GPIO --> BusInt : peripheral access

' Hardware layer internal connections
BusInt --> FPGA : fabric access
ClkGen --> Scheduler : system clock
ClkGen --> FPGA : clock distribution
ResetCtrl --> Scheduler : reset handling
SysCtrl --> BusInt : system services

' Key scheduling interfaces
interface "Task Execution" as ITaskExec
interface "Interrupt Service" as IISR
interface "Clock Tick" as IClkTick
interface "Priority Management" as IPriority

Scheduler -up- ITaskExec
IntCtrl -up- IISR
ClkGen -up- IClkTick
PrioQueue -up- IPriority

' Notes explaining scheduling concern
note right of Scheduler
  **Priority-Based Preemptive Scheduling**
  - Tasks scheduled based on priority
  - Context switching on interrupts
  - Tick-based time slicing
  - Supports static/dynamic allocation
end note

note left of TaskMgr
  **Task Types**
  - Experiment tasks
  - Communication tasks
  - Monitoring tasks
  - Timer callback tasks
end note

note bottom of IntCtrl
  **Interrupt-Driven Design**
  - Asynchronous event handling
  - ISR to task notifications
  - Deferred interrupt processing
end note

note top of ClkGen
  **Multiple Clock Domains**
  - System clock for RTOS
  - Peripheral clocks
  - Clock domain crossing handling
end note

@enduml
