@startuml
!define RECTANGLE class

skinparam component {
    BackgroundColor<<external>> LightBlue
    BackgroundColor<<api>> LightGreen
    BackgroundColor<<ui>> LightYellow
    BackgroundColor<<storage>> LightCoral
    BackgroundColor<<orchestration>> LightGray
    BackgroundColor<<processing>> Wheat
}

' External Data Sources
component "Reddit API" <<external>> as reddit

' Data Ingestion Layer
package "Data Ingestion" {
    component "PRAW Client\n(py_redditor)" as praw
}

' Orchestration Layer
package "Workflow Orchestration" {
    component "Apache Airflow" <<orchestration>> as airflow
    component "Data Gathering DAG" as dag_gather
    component "Processing DAG" as dag_process
    component "Backup DAG" as dag_backup
}

' Storage Layer
package "Data Storage" {
    database "PostgreSQL\nDatabase" <<storage>> as postgres
    component "Elasticsearch\nSearch Index" <<storage>> as elasticsearch
}

' AWS Infrastructure
package "AWS Services" {
    component "S3 Bucket\n(Backup Storage)" <<storage>> as s3
    component "EC2 Instances\n(Compute)" as ec2
    component "SNS\n(Messaging)" as sns
    component "Spark Cluster" as spark {
        component "Master Node" as spark_master
        component "Slave Nodes" as spark_slaves
    }
}

' Application Layer
package "Application Services" {
    component "R Plumber API\n(redditor-api)" <<api>> as plumber_api
    component "Shiny Application\n(UI)" <<ui>> as shiny_app
    component "NGINX\n(Reverse Proxy)" as nginx
}

' R Packages
package "Custom R Packages" {
    component "biggr\n(AWS Wrapper)" as biggr
    component "redditor\n(Reddit Wrapper)" as redditor
}

' Infrastructure Management
package "Infrastructure Management" {
    component "Docker Compose" as docker_compose
    component "Docker Containers" as docker {
        component "API Container" as api_container
        component "Rpy Container\n(Airflow)" as rpy_container
        component "Shiny Container" as shiny_container
    }
    component "EC2 Instance Manager\n(biggr scripts)" as ec2_manager
}

' Monitoring
package "System Monitoring" {
    component "Glances\n(Performance Monitor)" as glances
}

' Server Infrastructure
package "Server Infrastructure" {
    component "XPS Server" as xps_server
    component "Poweredge Server\n(Long-term Storage)" as poweredge_server
}

' Dependencies and Relationships

' Data Flow
reddit --> praw : "fetch data"
praw --> postgres : "store data"
praw ..> redditor : "uses wrapper"

' Orchestration
airflow --> dag_gather
airflow --> dag_process
airflow --> dag_backup
dag_gather --> praw : "triggers"
dag_process --> postgres : "reads/writes"
dag_backup --> s3 : "backup to"

' Storage relationships
postgres --> elasticsearch : "index data"
postgres --> s3 : "backup"
s3 --> poweredge_server : "archive"
xps_server --> s3 : "upload backup"

' AWS Infrastructure
biggr --> ec2 : "manages instances"
biggr --> s3 : "interacts"
biggr --> sns : "sends notifications"
ec2_manager --> spark : "launch/terminate"
spark_master --> spark_slaves : "coordinates"
ec2 --> spark : "hosts"

' Application Layer
nginx --> plumber_api : "routes traffic"
plumber_api --> postgres : "query data"
plumber_api --> elasticsearch : "search"
shiny_app --> plumber_api : "API calls"

' Docker Infrastructure
docker_compose --> docker : "orchestrates"
api_container --> plumber_api : "runs"
rpy_container --> airflow : "runs"
shiny_container --> shiny_app : "runs"

' R Package dependencies
plumber_api ..> biggr : "uses"
plumber_api ..> redditor : "uses"
shiny_app ..> biggr : "uses"

' Monitoring
glances --> ec2 : "monitors"
glances --> xps_server : "monitors"
glances --> poweredge_server : "monitors"

' Processing
dag_process --> spark : "executes jobs"
spark --> postgres : "read/write"

@enduml
