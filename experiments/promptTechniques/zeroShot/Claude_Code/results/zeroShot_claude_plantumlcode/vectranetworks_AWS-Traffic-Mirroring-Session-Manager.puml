@startuml
!pragma teoz true

title AWS VPC Traffic Mirroring Automation - Control Flow

actor Administrator
participant "tap.py" as Tap
participant "config_vpc.py" as ConfigVPC
participant "blacklist.py/\nwhitelist.py" as InstanceList
participant "ec2_api_client.py" as EC2API
participant "tag_config.py" as TagConfig
participant "spile_tapper.py" as SpileTapper
participant "spile.py" as Spile
participant "nlb_factory.py" as NLBFactory
participant "nlb_target_factory.py" as TargetFactory
participant "AWS EC2 API" as AWS

== VPC Configuration Phase ==
Administrator -> ConfigVPC: Configure VPC settings
activate ConfigVPC
ConfigVPC -> EC2API: Get VPC details
activate EC2API
EC2API -> AWS: DescribeVpcs()
activate AWS
AWS --> EC2API: VPC data
deactivate AWS
EC2API --> ConfigVPC: VPC information
deactivate EC2API

ConfigVPC -> Administrator: Prompt for enrollment mode\n(Auto/Whitelist)
Administrator --> ConfigVPC: Select enrollment mode

ConfigVPC -> Administrator: Prompt for mirror target\n(NLB/ENI)
Administrator --> ConfigVPC: Select target type

ConfigVPC -> TagConfig: Serialize VPC configuration
activate TagConfig
TagConfig --> ConfigVPC: Serialized config
deactivate TagConfig

ConfigVPC -> EC2API: Update VPC tags
activate EC2API
EC2API -> AWS: CreateTags()
activate AWS
AWS --> EC2API: Success
deactivate AWS
EC2API --> ConfigVPC: Tags updated
deactivate EC2API
deactivate ConfigVPC

== Instance List Management Phase ==
Administrator -> InstanceList: Manage blacklist/whitelist
activate InstanceList
InstanceList -> EC2API: List EC2 instances
activate EC2API
EC2API -> AWS: DescribeInstances()
activate AWS
AWS --> EC2API: Instance list
deactivate AWS
EC2API --> InstanceList: Instances
deactivate EC2API

InstanceList -> Administrator: Display instances
Administrator --> InstanceList: Select instances to add/remove

InstanceList -> EC2API: Update instance tags
activate EC2API
EC2API -> AWS: CreateTags()/DeleteTags()
activate AWS
AWS --> EC2API: Success
deactivate AWS
EC2API --> InstanceList: Tags updated
deactivate EC2API
deactivate InstanceList

== Traffic Mirroring Session Management Phase ==
Administrator -> Tap: Execute main process
activate Tap

Tap -> EC2API: Get configured VPCs
activate EC2API
EC2API -> AWS: DescribeVpcs(filters)
activate AWS
AWS --> EC2API: VPC list with tags
deactivate AWS
EC2API --> Tap: Configured VPCs
deactivate EC2API

loop For each configured VPC
    Tap -> TagConfig: Parse VPC configuration
    activate TagConfig
    TagConfig --> Tap: VPC_Props
    deactivate TagConfig

    alt Mirror target is NLB
        Tap -> NLBFactory: Create/get NLB
        activate NLBFactory
        NLBFactory -> EC2API: Check existing NLB
        activate EC2API
        EC2API -> AWS: DescribeLoadBalancers()
        activate AWS
        AWS --> EC2API: NLB data
        deactivate AWS
        EC2API --> NLBFactory: NLB info
        deactivate EC2API

        alt NLB doesn't exist
            NLBFactory -> EC2API: Create NLB
            activate EC2API
            EC2API -> AWS: CreateLoadBalancer()
            activate AWS
            AWS --> EC2API: NLB created
            deactivate AWS
            EC2API --> NLBFactory: NLB details
            deactivate EC2API
        end
        NLBFactory --> Tap: NLB target
        deactivate NLBFactory
    end

    Tap -> TargetFactory: Create mirror target
    activate TargetFactory
    TargetFactory -> EC2API: Create traffic mirror target
    activate EC2API
    EC2API -> AWS: CreateTrafficMirrorTarget()
    activate AWS
    AWS --> EC2API: Target created
    deactivate AWS
    EC2API --> TargetFactory: Target ID
    deactivate EC2API
    TargetFactory --> Tap: Mirror target
    deactivate TargetFactory

    Tap -> SpileTapper: Manage sessions for VPC
    activate SpileTapper

    SpileTapper -> EC2API: Discover eligible instances
    activate EC2API
    EC2API -> AWS: DescribeInstances(filters)
    activate AWS
    note right
        Filter for Nitro-based
        instances in VPC
    end note
    AWS --> EC2API: Instance list
    deactivate AWS
    EC2API --> SpileTapper: Eligible instances
    deactivate EC2API

    loop For each eligible instance
        SpileTapper -> TagConfig: Check instance tags
        activate TagConfig
        TagConfig --> SpileTapper: Tag configuration
        deactivate TagConfig

        alt Enrollment mode is Whitelist
            SpileTapper -> SpileTapper: Check if whitelisted
            alt Not whitelisted
                SpileTapper -> SpileTapper: Skip instance
            end
        else Enrollment mode is Auto
            SpileTapper -> SpileTapper: Check if blacklisted
            alt Blacklisted
                SpileTapper -> SpileTapper: Skip instance
            end
        end

        SpileTapper -> EC2API: Get instance ENIs
        activate EC2API
        EC2API -> AWS: DescribeNetworkInterfaces()
        activate AWS
        AWS --> EC2API: ENI list
        deactivate AWS
        EC2API --> SpileTapper: ENIs
        deactivate EC2API

        loop For each ENI
            SpileTapper -> Spile: Create Spile instance
            activate Spile

            Spile -> EC2API: Check existing mirror session
            activate EC2API
            EC2API -> AWS: DescribeTrafficMirrorSessions()
            activate AWS
            AWS --> EC2API: Session data
            deactivate AWS
            EC2API --> Spile: Existing sessions
            deactivate EC2API

            alt No session exists or needs update
                Spile -> EC2API: Create traffic mirror filter
                activate EC2API
                EC2API -> AWS: CreateTrafficMirrorFilter()
                activate AWS
                note right
                    Filter for all traffic
                    including DNS
                end note
                AWS --> EC2API: Filter created
                deactivate AWS
                EC2API --> Spile: Filter ID
                deactivate EC2API

                Spile -> EC2API: Create mirror session
                activate EC2API
                EC2API -> AWS: CreateTrafficMirrorSession()
                activate AWS
                AWS --> EC2API: Session created
                deactivate AWS
                EC2API --> Spile: Session ID
                deactivate EC2API

                Spile -> TagConfig: Update ENI tags
                activate TagConfig
                TagConfig --> Spile: Tags serialized
                deactivate TagConfig

                Spile -> EC2API: Tag ENI with session info
                activate EC2API
                EC2API -> AWS: CreateTags()
                activate AWS
                AWS --> EC2API: Success
                deactivate AWS
                EC2API --> Spile: Tags updated
                deactivate EC2API
            else Session exists and valid
                Spile -> Spile: Validate session state
            else Session needs removal
                Spile -> EC2API: Delete mirror session
                activate EC2API
                EC2API -> AWS: DeleteTrafficMirrorSession()
                activate AWS
                AWS --> EC2API: Session deleted
                deactivate AWS
                EC2API --> Spile: Success
                deactivate EC2API
            end

            Spile --> SpileTapper: Session managed
            deactivate Spile
        end
    end

    SpileTapper --> Tap: VPC sessions managed
    deactivate SpileTapper
end

Tap --> Administrator: All sessions managed
deactivate Tap

@enduml
