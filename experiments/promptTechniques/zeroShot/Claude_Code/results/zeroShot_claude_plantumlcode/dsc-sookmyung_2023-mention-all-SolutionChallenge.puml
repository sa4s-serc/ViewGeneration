@startuml
!define RECTANGLE rectangle
!define COMPONENT component

skinparam componentStyle rectangle
skinparam backgroundColor #FFFFFF
skinparam component {
    BackgroundColor<<mobile>> LightBlue
    BackgroundColor<<backend>> LightGreen
    BackgroundColor<<cloud>> LightYellow
    BackgroundColor<<external>> LightGray
}

title CPR2U System - Deployment Architecture

node "Mobile Devices" {
    RECTANGLE "Android Device" <<mobile>> {
        component "CPR2U Android App" as AndroidApp {
            component "UI Layer" as AndroidUI
            component "Presentation Layer\n(MVVM ViewModels)" as AndroidPresentation
            component "Data Layer" as AndroidData
            component "ML Kit\n(TensorFlow Lite)" as AndroidML
            component "Navigation Component" as AndroidNav
            component "Koin DI Framework" as AndroidDI
        }
    }

    RECTANGLE "iOS Device" <<mobile>> {
        component "CPR2U iOS App" as iOSApp {
            component "UI Layer\n(SwiftUI)" as iOSUI
            component "ViewModels\n(MVVM + Combine)" as iOSPresentation
            component "Data Layer" as iOSData
            component "TensorFlow Lite" as iOSML
        }
    }
}

node "Google Cloud Platform (GCP)" <<cloud>> {
    RECTANGLE "Kubernetes Engine (GKE)" {
        component "Spring Boot Backend" as Backend {
            component "AuthController\n& AuthService" as AuthService
            component "EducationController\n& EducationProgressService" as EducationService
            component "CprCallController\n& DispatchService" as DispatchService
            component "AddressService" as AddressService
            component "Repository Layer" as RepositoryLayer
            component "JWT Token Manager" as JWTManager
        }
    }

    RECTANGLE "Firebase Services" <<cloud>> {
        component "Firebase Authentication" as FirebaseAuth
        component "Firebase Cloud Messaging (FCM)" as FCM
        component "Firebase Realtime Database" as FirebaseDB
    }

    component "Cloud SQL / Database" as Database
}

node "External Services" <<external>> {
    component "Google Maps API" as GoogleMaps
    component "ML Kit API" as MLKitAPI
}

AndroidUI --> AndroidPresentation
AndroidPresentation --> AndroidData
AndroidData --> AndroidDI
AndroidML --> AndroidPresentation
AndroidNav --> AndroidUI

iOSUI --> iOSPresentation
iOSPresentation --> iOSData
iOSML --> iOSPresentation

AndroidData --> Backend : REST API\n(Retrofit)
iOSData --> Backend : REST API\n(URLSession)

AndroidApp --> FirebaseAuth : Authentication
AndroidApp --> FCM : Push Notifications
AndroidApp --> FirebaseDB : Real-time Updates
AndroidApp --> GoogleMaps : Location Services

iOSApp --> FirebaseAuth : Authentication
iOSApp --> FCM : Push Notifications
iOSApp --> FirebaseDB : Real-time Updates
iOSApp --> GoogleMaps : Location Services

AuthService --> JWTManager
AuthService --> FirebaseAuth
EducationService --> RepositoryLayer
DispatchService --> RepositoryLayer
DispatchService ..> FCM : Uses
AddressService --> GoogleMaps

RepositoryLayer --> Database

Backend --> FCM : FirebaseCloudMessageUtil

note right of Backend
  RESTful API endpoints
  JWT-based authentication
  Role-based access control
  Deployed on GKE
end note

note right of AndroidApp
  Built with Kotlin
  Data Binding
  Coroutines for async
  Pose estimation for CPR
end note

note right of iOSApp
  Built with Swift
  Combine for reactive UI
  Pose estimation for CPR
end note

note bottom of "Google Cloud Platform (GCP)"
  Deployment Platform
  Scalable microservices architecture
  Container orchestration via Kubernetes
end note

@enduml
