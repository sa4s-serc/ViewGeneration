```plantuml
@startuml pgrignaffini_AlgoCrowd

package "Frontend (Client)" {
  [Next.js Application] as frontend
  [pages] --> frontend
  [components] --> frontend
  [APIs/API.js] --> frontend
  [context/AppContext.js] --> frontend
  [constants] --> frontend
  [utils] --> frontend
}

package "Backend (Server)" {
  [Express.js Server] as backend
  [server.js] --> backend
  [db.js] --> backend
  [dao.js] --> backend
}

package "Smart Contracts" {
  [PyTeal Contracts] as smartContracts
  [contracts.py] --> smartContracts
  [operations.py] --> smartContracts
  [util.py] --> smartContracts
}

package "Algorand Blockchain" {
  [Algorand Network] as algorand
}

package "Database" {
  [SQLite] as sqlite
}

frontend --> backend : REST API
backend --> smartContracts : Interacts with
backend --> sqlite : Stores/Retrieves Data
smartContracts --> algorand : Deploys and Executes

@enduml
```