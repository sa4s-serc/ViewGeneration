```plantuml
@startuml KuangRD_Autonomous-Driving

package "Core Libraries" {
    component Eigen
    component "nlohmann::json"
    component uWS
    component "BLAS/LAPACK"
    component "TensorFlow/Keras"
}

package "Autonomous Driving System" {
    component "Traffic Light Classifier" {
        [Traffic Light Model]
    }
    component "ROS Nodes" {
        [Waypoint Loader]
        [Waypoint Updater]
        [DBW Controller]
    }
}

package "Control Systems" {
    component "PID Controller"
}

package "Data Handling" {
    component "HDF5"
    component "Matrix Market"
}

Eigen --> "Traffic Light Classifier" : uses
"nlohmann::json" --> "ROS Nodes" : communicates
uWS --> "ROS Nodes" : communicates
"BLAS/LAPACK" --> Eigen : enhances performance
"TensorFlow/Keras" --> "Traffic Light Classifier" : provides model

"Traffic Light Classifier" --> "ROS Nodes" : processes data
"ROS Nodes" --> "Control Systems" : controls
"ROS Nodes" --> "Data Handling" : stores data

@enduml
```