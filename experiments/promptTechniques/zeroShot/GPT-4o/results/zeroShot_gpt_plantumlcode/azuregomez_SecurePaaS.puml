```plantuml
@startuml azuregomez_SecurePaaS

package "Azure Environment" {
    
    [Azure App Service] --> [Azure SQL Database]
    [Azure App Service] --> [Azure Firewall]
    
    [Azure SQL Database] --> [Private Endpoint]
    [Azure Firewall] --> [Private Endpoint]
    
    [Web Application Firewall] --> [Azure App Service]
    
    [Azure Key Vault] --> [Azure App Service]
    
    [Azure Firewall] --> [Outbound Traffic Inspection]

    [Azure Key Vault] --> [Secret Management]
}

package "Security Components" {
    [Web Application Firewall] 
    [Azure Firewall]
    [Azure Key Vault] 
}

package "Connectivity Components" {
    [Private Endpoint]
    [Outbound Traffic Inspection]
}

@enduml
