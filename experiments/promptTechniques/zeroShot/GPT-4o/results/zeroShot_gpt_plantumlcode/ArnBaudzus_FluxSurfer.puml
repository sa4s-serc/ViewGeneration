```plantuml
@startuml ArnBaudzus_FluxSurfer

package "FluxSurfer" {
    [QuantumSystem] -- [Graph Structure]
    [QuantumSystem] ..> [Data Storage]

    package "Solvers" {
        [ODE Solvers] --|> [Solver]
        [MonteCarloWanderer] --|> [Solver]
        [SingleStepScheme] <|-- [ODE Solvers]
    }

    package "ParallelProcessing" {
        [Experiment] --> [WorkSource]
        [Experiment] ..> [QuantumSystem]
        [WorkSource] -> [Mutex]
    }

    package "Data Storage" {
        [GraphML Files] ..> [QuantumSystem]
        [METADATA.json] ..> [Experiment]
        [METADATA.csv] ..> [Experiment]
    }

    package "Utilities" {
        [FileUtility] ..> [Data Storage]
        [Quantities] ..> [QuantumSystem]
        [PlotChargeCurve] ..> [Data Storage]
        [Menu]
        [BinaryNumberUtility] ..> [QuantumSystem]
    }

    [Graph Structure] --> [States]
    [Graph Structure] --> [Transitions]

    [Solver] ..> [QuantumSystem]
    [Experiment] --> [ParallelProcessing]

    [Utilities] ..> [Data Storage]
}

@enduml
```