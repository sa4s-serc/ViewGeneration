```plantuml
@startuml yuwen123441_NVMeAutomation

package "Dynamic Library" {
    component "nvme-ioctl.c" as C_Lib
    component "nvme.h" as C_Header
    component "build.sh" as BuildScript
}

package "Driver Layer" {
    component "nvme.py" as PythonWrapper
    component "Buffer Management" as BufferMgmt
    component "Data Structures" as DataStructs
}

package "Logic Layer" {
    component "Logic Classes" as LogicClasses
}

package "Common Library" {
    component "Admin and IO Interfaces" as CommonLib
}

package "Test Suite" {
    component "Admin Test Cases" as AdminTests
    component "IO Test Cases" as IOTests
}

C_Lib --> C_Header
C_Lib --> PythonWrapper
BuildScript ..> C_Lib
PythonWrapper --> BufferMgmt
PythonWrapper --> DataStructs
PythonWrapper --> LogicClasses
LogicClasses --> CommonLib
CommonLib --> AdminTests
CommonLib --> IOTests

@enduml
```