```plantuml
@startuml elpapi42_deep-deblurring

package "ElPapi42 Deep Deblurring System" {
  
  [Frontend] <<Vue.js>> 
  [Backend] <<Flask>> 
  [Model Serving] <<TensorFlow Serving>> 
  [Model Repository] 
  [Data Storage] <<Cloudinary>> 
  [Redis]
  [PostgreSQL]

  [Frontend] --> [Backend] : RESTful API Calls

  [Backend] --> [Model Serving] : Inference Requests
  [Backend] --> [Model Repository] : Access Trained Models
  [Backend] --> [Data Storage] : Fetch/Store Static Assets
  [Backend] --> [Redis] : Cache Management
  [Backend] --> [PostgreSQL] : Database Queries

  [Model Serving] --> [Model Repository] : Load Model

}

@enduml
```
