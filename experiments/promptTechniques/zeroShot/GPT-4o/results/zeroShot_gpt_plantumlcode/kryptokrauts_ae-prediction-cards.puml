```plantuml
@startuml kryptokrauts_ae-prediction-cards

actor User
participant "React Frontend" as Frontend
participant "Smart Contract" as Contract
participant "Oracle Service" as OracleService
participant "Process Prediction Service" as PredictionService
participant "Aeternity Blockchain" as Blockchain

User -> Frontend: Create Prediction
Frontend -> Contract: create_prediction()
Contract -> Blockchain: Store prediction data

User -> Frontend: Rent NFT
Frontend -> Contract: rent_nft()
Contract -> Blockchain: Update NFT rental status

PredictionService -> Blockchain: Monitor for CLOSED predictions
PredictionService -> Contract: ask_for_winning_option()

Contract -> OracleService: Query oracle for price
OracleService -> Blockchain: Get actual price
OracleService -> Contract: Respond with price data

PredictionService -> Contract: process_oracle_response()
Contract -> Blockchain: Determine winning NFT

User -> Frontend: Claim Rewards
Frontend -> Contract: claim()
Contract -> Blockchain: Distribute rewards

User -> Frontend: View Holdings
Frontend -> Contract: Get user data
Contract -> Blockchain: Retrieve user holdings

@enduml
```