}

package "MetaStore Implementations" {
    component "ShmemMetaStore" as SMS
    component "SimpleMetaStore" as SiMS
    component "FDBMetaStore" as FDBMS

    MS --> SMS : implements
    MS --> SiMS : implements
    MS --> FDBMS : implements
}

package "Tiered Architecture" {
    component "Node" as N
    component "Broker" as B
    component "Executor" as E

    N --> B : coordinates
    B --> E : manages
    E --> EE : executes tasks
}

note "Data Locality and Asynchronous Execution" as Note1
note "Fault Tolerance and Rescheduling" as Note2
