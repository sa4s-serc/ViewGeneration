```plantuml
@startuml ballerina-platform_asyncapi-tools

package "ballerina-platform_asyncapi-tools" {

    component "AsyncApiCmd" <<CLI>> {
        [bal asyncapi]
    }

    component "AsyncApiToBallerinaGenerator" <<Generator>> 
    component "BallerinaToAsyncApiGenerator" <<Generator>> 

    component "WebSocket Support" {
        [zoom.yaml]
        [ably.yaml]
        [stripe.yaml]
    }

    component "Authentication Handling" <<Library>> 

    component "Data Structure Handling" <<Library>> 

    component "Error Handling" <<Library>> 

    component "Test Suite" <<Test>> {
        [*.yaml]
        [*.bal]
    }

    component "Ballerina Code Files" <<Code>> {
        [*.bal]
    }

    component "API Definition Files" <<Definition>> {
        [*.yaml]
    }

    component "Ballerina Project Config" <<Config>> {
        [Ballerina.toml]
        [Dependencies.toml]
    }

    component "Connection Management" <<Library>> 

    "AsyncApiCmd" --> "AsyncApiToBallerinaGenerator"
    "AsyncApiCmd" --> "BallerinaToAsyncApiGenerator"
    "AsyncApiToBallerinaGenerator" --> "WebSocket Support"
    "AsyncApiToBallerinaGenerator" --> "Authentication Handling"
    "AsyncApiToBallerinaGenerator" --> "Data Structure Handling"
    "AsyncApiToBallerinaGenerator" --> "API Definition Files"
    "BallerinaToAsyncApiGenerator" --> "Ballerina Code Files"
    "BallerinaToAsyncApiGenerator" --> "API Definition Files"
    "Test Suite" --> "AsyncApiToBallerinaGenerator"
    "Test Suite" --> "BallerinaToAsyncApiGenerator"
    "WebSocket Support" --> "Connection Management"
    "Error Handling" --> "Connection Management"
    "Authentication Handling" --> "Connection Management"
    "Ballerina Code Files" --> "Ballerina Project Config"
}

@enduml
