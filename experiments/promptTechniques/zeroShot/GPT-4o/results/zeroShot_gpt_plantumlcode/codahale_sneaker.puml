```plantuml
@startuml codahale_sneaker

actor User
participant CLI as "CLI"
participant Manager
participant ObjectStorage as "S3"
participant KeyManagement as "KMS"
participant Envelope
database "AWS S3" as S3
database "AWS KMS" as KMS

User -> CLI: Execute sneaker command
CLI -> Manager: Parse command and call appropriate function
activate Manager

alt Upload Secret
    Manager -> KeyManagement: Generate data key
    activate KeyManagement
    KeyManagement -> KMS: Request new data key
    KMS -> KeyManagement: Return encrypted data key
    deactivate KeyManagement

    Manager -> Envelope: Encrypt secret with data key
    activate Envelope
    Envelope -> Manager: Return encrypted secret
    deactivate Envelope
    
    Manager -> ObjectStorage: Upload encrypted secret to S3
    activate ObjectStorage
    ObjectStorage -> S3: Store encrypted secret
    deactivate ObjectStorage

else Download Secret
    Manager -> ObjectStorage: Retrieve encrypted secret from S3
    activate ObjectStorage
    ObjectStorage -> S3: Fetch encrypted secret
    deactivate ObjectStorage

    Manager -> KeyManagement: Decrypt data key
    activate KeyManagement
    KeyManagement -> KMS: Decrypt data key
    KMS -> KeyManagement: Return plaintext data key
    deactivate KeyManagement

    Manager -> Envelope: Decrypt secret with data key
    activate Envelope
    Envelope -> Manager: Return plaintext secret
    deactivate Envelope
end

deactivate Manager

@enduml
```