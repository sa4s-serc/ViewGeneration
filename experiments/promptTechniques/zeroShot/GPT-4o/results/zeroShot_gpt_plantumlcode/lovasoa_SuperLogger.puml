```plantuml
@startuml lovasoa_SuperLogger

package "Agent (Java)" {
    component SystemInfo
    component TCPServer
    SystemInfo --> TCPServer : Collects Data
}

package "Logstash" {
    component Logstash
    TCPServer --> Logstash : Sends Data via TCP
}

package "Elasticsearch" {
    component Elasticsearch
    Logstash --> Elasticsearch : Forwards Data
}

package "Kibana" {
    component Kibana
    Elasticsearch --> Kibana : Provides Data for Visualization
}

@enduml
```