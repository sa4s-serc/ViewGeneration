```plantuml
@startuml pacmacro_pm-server-spring

actor Client

participant "HomeController" as HC
participant "GameStateController" as GSC
participant "GameStateManager" as GSM
participant "GameStateRegistry" as GSR
participant "PlayerController" as PC
participant "PlayerManager" as PM
participant "PlayerRegistry" as PR
participant "PacdotController" as PDC
participant "PacdotManager" as PDM
participant "PacdotRegistry" as PDR
participant "TagController" as TC
participant "TagManager" as TM
participant "TagRegistry" as TR

Client -> HC: GET /
HC -> Client: HTTP 200 OK

Client -> GSC: POST /game/start
GSC -> GSM: startGame()
GSM -> GSR: initializeGameState()
GSR -> GSM: GameState
GSM -> Client: GameStateResponse

Client -> PC: POST /player
PC -> PM: createPlayer()
PM -> PR: addPlayer()
PR -> PM: Player
PM -> Client: PlayerDetailsResponse

Client -> PDC: GET /pacdots
PDC -> PDM: getAllPacdots()
PDM -> PDR: retrievePacdots()
PDR -> PDM: List<Pacdot>
PDM -> Client: List<Pacdot>

Client -> PC: PUT /player/location
PC -> PM: updatePlayerLocation()
PM -> PR: updateLocation()
PR -> PM: updatedPlayer
PM -> Client: PlayerDetailsResponse

Client -> TC: POST /tag
TC -> TM: registerTag()
TM -> TR: createTag()
TR -> TM: Tag
TM -> Client: TagResponse

Client -> GSC: GET /game/state
GSC -> GSM: getGameState()
GSM -> GSR: fetchCurrentState()
GSR -> GSM: GameState
GSM -> Client: GameStateResponse

@enduml
```