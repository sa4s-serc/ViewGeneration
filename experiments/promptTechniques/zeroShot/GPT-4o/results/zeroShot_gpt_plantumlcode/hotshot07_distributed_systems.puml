```plantuml
@startuml hotshot07_distributed_systems

package "Kubernetes Cluster" {
    component "Frontend" {
        [React UI] --> [User Authentication]
    }

    package "Backend Services" {
        component "User Authentication Service" as Auth
        component "Account Management Service" as Account
        component "Athlete Availability Tracking Service" as Availability
        component "Test Scheduling & Reporting Service" as Report

        Auth --> Account
        Account --> Availability
        Availability --> Report
    }

    component "DynamoDB" as DB

    [React UI] --> Auth : HTTP API
    Auth --> Account : HTTP API
    Account --> Availability : HTTP API
    Availability --> Report : HTTP API

    Auth --> DB : Read/Write
    Account --> DB : Read/Write
    Availability --> DB : Read/Write
    Report --> DB : Read/Write
}

package "Deployment" {
    node "CI/CD Pipeline" {
        [GitHub Actions] --> [DockerHub]
        [DockerHub] --> [Kubernetes Cluster]
    }

    component "Deployment Scripts" {
        [deploy-cluster.sh] --> [Kubernetes Cluster]
        [deploy-local.sh] --> [Local Environment]
    }
}

@enduml
```