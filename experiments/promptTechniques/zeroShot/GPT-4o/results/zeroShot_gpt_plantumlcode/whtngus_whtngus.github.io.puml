```plantuml
@startuml whtngus_whtngus.github.io

' Define components
component "Web Server" as WebServer
component "Application Server" as AppServer
component "Database Server" as DatabaseServer

' Define relationships
WebServer --> AppServer : HTTP/HTTPS
AppServer --> DatabaseServer : SQL

' Deployment nodes
node "AWS EC2 Instance" {
    [Web Server]
    [Application Server]
}

node "AWS RDS" {
    [Database Server]
}

@enduml
```