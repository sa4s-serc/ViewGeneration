```plantuml
@startuml IBM_torc_py

actor User
participant "TaskManager" as TM
participant "ApplicationControl" as AC
participant "LoadBalancer" as LB
participant "MPIProcess" as MP
participant "WorkerThread" as WT

User -> AC: start()
AC -> AC: init()
AC -> MP: launch(main_task)
MP -> TM: submit(task)
TM -> TM: create TaskT future
TM -> LB: distribute task
LB -> MP: assign task to WorkerThread
MP -> WT: execute task
WT -> WT: execute task logic
WT -> TM: task completed
TM -> TM: update TaskT future
TM -> User: notify task completion via callback

== Load Balancing ==
WT -> LB: request more tasks
LB -> MP: check task queues
alt Task available
    LB -> WT: assign new task
else No task available
    LB -> WT: task stealing
end

User -> AC: shutdown()
AC -> TM: finalize tasks
AC -> MP: release resources

@enduml
```