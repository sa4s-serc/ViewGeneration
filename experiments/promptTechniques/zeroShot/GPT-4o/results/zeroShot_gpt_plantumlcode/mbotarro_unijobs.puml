```plantuml
@startuml mbotarro_unijobs

package "UniJobs Application" {
    
    package "Frontend (React Native)" {
        component "User Authentication" as Auth
        component "Offer/Request Feed" as Feed
        component "Offer/Request Creation" as Creation
        component "User Profiles" as Profiles
        component "Navigation" as Navigation
        component "UI Design" as UI
        component "Interest Matching" as Matching
    }
    
    package "Backend (Go)" {
        component "RESTful API" as API
        component "PostgreSQL Database" as Postgres
        component "Elasticsearch Integration" as Elasticsearch
        component "Data Abstraction Layer (DAL)" as DAL
        component "Business Logic" as BusinessLogic
    }

    Auth --> API : "User Authentication"
    Feed --> API : "Fetch Offers/Requests"
    Creation --> API : "Post Offers/Requests"
    Profiles --> API : "User Data Management"
    Matching --> API : "Match Interests"
    
    API --> Postgres : "Database Interactions"
    API --> Elasticsearch : "Full-text Search"
    
    API --> DAL : "Data Access Logic"
    DAL --> Postgres : "Modular Database Access"
    
    API --> BusinessLogic : "Invoke Business Operations"
}

@enduml
```