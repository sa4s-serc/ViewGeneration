    [FileUtils]
    [StringUtils]
}

package "Configuration" {
    [InitParams] --> [params.json]
    [InitParams] --> [users.txt]
}

package "Resources" {
    [ReportFormatter] --> [HTML Templates]
    [IOManager] --> [JSONL Data Files]
}

package "Documentation" {
    [README.md]
    [LICENSE]
    [docs]
}

package "GitHub" {
    [.github/ISSUE_TEMPLATE]
}

package "Storage" {
    [JSONL Data Files]
    [CSV Files]
}

[ArgaelForm] ..> [FileUtils] : uses
