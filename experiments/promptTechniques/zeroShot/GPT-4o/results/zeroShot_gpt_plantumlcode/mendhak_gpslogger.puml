```plantuml
@startuml mendhak_gpslogger

' Define components
component "GpsLoggingService" as GpsService
component "FileLogger" as FileLogger
component "Data Upload" as DataUpload
component "User Interface" as UserInterface
component "PreferenceHelper" as PrefHelper
component "Event Bus" as EventBus
component "WorkManager" as WorkManager
component "Tasker Integration" as TaskerIntegration
component "ContentProvider" as ContentProvider

' Define connections
GpsService --> FileLogger : Logs GPS Data
GpsService --> DataUpload : Uploads Data
GpsService --> EventBus : Sends Events
DataUpload --> WorkManager : Uses for Background Tasks
UserInterface --> PrefHelper : Loads/Stores Preferences
UserInterface --> EventBus : Receives Events
TaskerIntegration --> GpsService : Controls Behavior
ContentProvider --> GpsService : Access Data

' External services
component "OpenStreetMap" as OSM
component "Google Drive" as GDrive
component "Dropbox" as Dropbox
component "SFTP/FTP" as SFTP_FTP

' Connections to external services
DataUpload --> OSM : Uploads Logs
DataUpload --> GDrive : Uploads Logs
DataUpload --> Dropbox : Uploads Logs
DataUpload --> SFTP_FTP : Uploads Logs

@enduml
```