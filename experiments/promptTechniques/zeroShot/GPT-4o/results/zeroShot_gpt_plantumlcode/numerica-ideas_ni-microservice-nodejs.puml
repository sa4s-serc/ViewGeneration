```plantuml
@startuml numerica-ideas_ni-microservice-nodejs

actor Client

participant "Express App" as Express
participant "Routes" as Routes
participant "Controllers" as Controllers
participant "Article Service" as ArticleService
participant "Redis Cache" as RedisCache
participant "MongoDB" as MongoDB
participant "Redis Pub/Sub" as RedisPubSub
participant "SNS Pub/Sub" as SNSPubSub

Client -> Express : HTTP Request (CRUD)
Express -> Routes : Forward Request
Routes -> Controllers : Call Controller
Controllers -> ArticleService : Perform Action
ArticleService -> RedisCache : Check Cache
alt Cache Hit
    RedisCache -> ArticleService : Return Cached Data
else Cache Miss
    ArticleService -> MongoDB : Query Database
    MongoDB -> ArticleService : Return Data
    ArticleService -> RedisCache : Update Cache
end

alt Inter-Service Comm (Server)
    ArticleService -> RedisPubSub : Publish Message
    RedisPubSub -> RedisPubSub : Handle Message
else Inter-Service Comm (Lambda)
    ArticleService -> SNSPubSub : Publish Message
    SNSPubSub -> SNSPubSub : Handle Message
end

ArticleService -> Controllers : Return Response
Controllers -> Routes : Return Data
Routes -> Express : Send Response
Express -> Client : HTTP Response

@enduml
```