digraph Visual_Programming_Environment {
	graph [rankdir=TB splines=ortho]
	subgraph cluster_0 {
		color=blue label="Syntax Representation" style=rounded
		element_api [label="Element API
(IElementSpecification)" shape=box]
		spec [label=Specification shape=box]
		warehouse [label=Warehouse shape=box]
		syntax_tree [label="Syntax Tree" shape=box]
		element_api -> spec
		spec -> warehouse
		warehouse -> syntax_tree
	}
	subgraph cluster_1 {
		color=red label="Execution Engine" style=rounded
		symbol_table [label="Symbol Table" shape=box]
		parser [label=Parser shape=box]
		interpreter [label=Interpreter shape=box]
		scheduler [label=Scheduler shape=box]
		parser -> interpreter
		interpreter -> scheduler
		symbol_table -> interpreter
	}
	subgraph cluster_2 {
		color=green label=Library style=rounded
		values [label="Values
(boolean, number, string)" shape=box]
		boxes [label="Boxes & Box Identifiers" shape=box]
		operators [label="Math Operators" shape=box]
		control [label="Control Structures
(if, repeat)" shape=box]
		program [label="Program Structures
(process, routine)" shape=box]
		values -> warehouse
		boxes -> warehouse
		operators -> warehouse
		control -> warehouse
		program -> warehouse
	}
	syntax_tree -> parser
}
