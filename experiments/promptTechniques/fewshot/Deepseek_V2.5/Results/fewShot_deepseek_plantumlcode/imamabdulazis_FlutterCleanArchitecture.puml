@startuml
skinparam rectangle {
  BackgroundColor<<presentation>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<core>> #fddddd
  BackgroundColor<<external>> #d4f0f0
  Style roundrect
}
skinparam linetype ortho
left to right direction

package "Presentation Layer" <<presentation>> {
  [UI Widgets] as UI
  [BLoCs] as BLoC
  [Screens] as Screens
}

package "Domain Layer" <<domain>> {
  [Entities] as Entities
  [Use Cases] as UseCases
  [Repository Interfaces] as RepoInterfaces
}

package "Data Layer" <<data>> {
  [Repositories] as Repositories
  [Data Sources] as DataSources
  [Models] as Models
}

package "Core" <<core>> {
  [Network Client] as Network
  [Error Handling] as Errors
  [Localization] as Localization
  [Theme Management] as Theme
}

package "External" <<external>> {
  [Firebase Messaging] as Firebase
  [Shared Preferences] as SharedPrefs
  [Sentry] as Sentry
  [Dio] as Dio
}

UI --> BLoC
BLoC --> UseCases
UseCases --> RepoInterfaces
RepoInterfaces --> Repositories
Repositories --> DataSources
DataSources --> Network
DataSources --> SharedPrefs
Network --> Dio
BLoC --> Errors
Errors --> Sentry
UI --> Localization
UI --> Theme
UI --> Firebase

@enduml