@startuml openshift_configuration-anomaly-detection
left to right direction
skinparam rectangle {
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<core>> #d8f5d3
  BackgroundColor<<cli>> #d9e7fd
  BackgroundColor<<integration>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "External Systems" <<external>> {
  rectangle "PagerDuty" as PagerDuty
  rectangle "OCM" as OCM
  rectangle "AWS" as AWS
  rectangle "Kubernetes" as K8s
}

package "Core Components" <<core>> {
  rectangle "Tekton Interceptor" as Interceptor {
    rectangle "Signature Validation"
    rectangle "Alert Filtering"
  }
  
  rectangle "Investigation Framework" as Framework {
    rectangle "Investigation Interface"
    rectangle "Resources Container"
  }
  
  rectangle "Ready Investigations" as Investigations {
    rectangle "chgm"
    rectangle "apierrorbudgetburn"
    rectangle "insightsoperatordown"
    rectangle "[...]"
  }
}

package "CLI Tool" <<cli>> {
  rectangle "cadctl" as CLI {
    rectangle "investigate"
    rectangle "remediate"
  }
}

package "Integrations" <<integration>> {
  rectangle "Network Verifier" as NetworkVerifier
  rectangle "Note Writer" as NoteWriter
  rectangle "Backplane CLI" as Backplane
}

PagerDuty --> Interceptor : Webhook
Interceptor --> CLI : Triggers
CLI --> Framework : Executes
Framework --> Investigations : Selects
Framework --> OCM : Cluster Info
Framework --> AWS : Instance Data
Framework --> K8s : Resource Inspection
Framework --> NetworkVerifier : Network Checks
Framework --> NoteWriter : PagerDuty Notes
Framework --> Backplane : RBAC Management
Investigations --> PagerDuty : Updates
@enduml