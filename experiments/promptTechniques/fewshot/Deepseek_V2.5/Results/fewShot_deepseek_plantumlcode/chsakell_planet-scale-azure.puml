@startuml chsakell_planet-scale-azure
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<azure>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Angular)" <<frontend>> {
  rectangle "Web App" as WebApp
  rectangle "Static Content" as StaticContent
}

package "Backend (.NET Core)" <<backend>> {
  rectangle "API Controllers" as Controllers
  rectangle "Business Services" as Services
  rectangle "WebJobs" as WebJobs
}

package "Azure Services" <<azure>> {
  rectangle "Azure Traffic Manager" as TrafficManager
  rectangle "Azure CDN" as CDN
  rectangle "Azure Redis Cache" as Redis
  rectangle "Azure Service Bus" as ServiceBus
  rectangle "Azure Search" as Search
}

package "Databases" <<db>> {
  database "Azure SQL Server" as SQL
  database "Cosmos DB" as CosmosDB
}

WebApp --> Controllers
StaticContent --> CDN
Controllers --> Services
Services --> Redis : Shopping Cart
Services --> SQL : Orders
Services --> CosmosDB : Product Catalog
Services --> Search : Product Search
Services --> ServiceBus : Order Processing
ServiceBus --> WebJobs : Process Messages
WebJobs --> SQL : Update Orders

TrafficManager --> WebApp : Route Traffic
TrafficManager --> CDN : Route Static Content

note right of TrafficManager
  Multi-region deployment
  with geo-replication
end note

note right of SQL
  Geo-replicated
  for DR
end note

note right of CosmosDB
  Geo-replicated
  for consistency
end note
@enduml