@startuml chrispiro_deploy_plotly_app_on_gcp
skinparam backgroundColor #ffffff
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor #333333
  Style roundrect
}
left to right direction

rectangle "User" as User

rectangle "GCP App Engine" as AppEngine {
  rectangle "Dash App" as DashApp #lightblue
  rectangle "Plotly Charts" as Plotly #lightgreen
}

rectangle "GCP Services" as GCPServices {
  rectangle "BigQuery" as BigQuery #orange
  rectangle "Cloud Storage" as CloudStorage #yellow
}

rectangle "Local Development" as LocalDev {
  rectangle "Jupyter Notebook" as Jupyter #pink
  rectangle "Python Scripts" as Scripts #lightgrey
}

User --> DashApp : Interacts with\nvisualizations
DashApp --> Plotly : Renders charts
Plotly --> BigQuery : Queries data
Plotly --> CloudStorage : Loads data
Scripts --> BigQuery : Test queries
Scripts --> CloudStorage : Test loads
Jupyter --> Scripts : Develops/test\nchart code
Scripts --> Jupyter : Copy final\nchart code

note right of AppEngine
  Deployed via app.yaml
  configuration
end note

note right of GCPServices
  Accessed via\ngoogle-cloud-* libraries
end note

note left of LocalDev
  Development workflow:
  1. Test in Jupyter
  2. Move to scripts
  3. Deploy to GCP
end note
@enduml