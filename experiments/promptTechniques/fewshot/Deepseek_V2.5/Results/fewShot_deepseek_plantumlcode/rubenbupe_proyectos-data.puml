@startuml rubenbupe_proyectos-data
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "Next.js App" as NextJS {
    [TensorFlow.js] as TFJS
    [React Components] as React
  }
}

package "Backend Services" <<backend>> {
  rectangle "Flask API" as Flask {
    [Image Processing] as ImageProc
    [Geospatial Search] as GeoSearch
    [WebSocket] as WS
  }
  
  rectangle "Metrics API" as Metrics {
    [Node.js] as Node
    [Grafana Integration] as Grafana
  }
}

package "Data & Messaging" <<db>> {
  database "MongoDB" as MongoDB
  queue "RabbitMQ" as RabbitMQ
}

package "Infrastructure" <<infra>> {
  rectangle "Kubernetes" as K8s {
    [Nginx Ingress] as Ingress
    [cert-manager] as CertManager
    [GKE Node Pool] as GKE
  }
  rectangle "GCP Services" as GCP
}

package "External Services" <<integration>> {
  rectangle "Positionstack API" as Positionstack
  rectangle "Let's Encrypt" as LetsEncrypt
}

NextJS --> Flask : HTTP/WebSocket
NextJS --> Positionstack : Geocoding
Flask --> MongoDB : Data Storage
Flask --> RabbitMQ : Events
Metrics --> RabbitMQ : Consume Events
Metrics --> MongoDB : Store Metrics
Metrics --> Grafana : Visualization
RabbitMQ --> Metrics : Event Notifications
K8s --> NextJS : Hosts
K8s --> Flask : Hosts
K8s --> Metrics : Hosts
K8s --> MongoDB : StatefulSet
K8s --> RabbitMQ : Deployment
Ingress --> NextJS : Routes Traffic
Ingress --> Flask : Routes Traffic
CertManager --> LetsEncrypt : Certificate Requests
GKE --> GCP : Cloud Integration
@enduml