@startuml GoogleCloudPlatform_analytics-componentized-patterns
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "User" as User

package "Data Sources" {
  rectangle "Retail Data" as RetailData
  rectangle "GA4 Data" as GA4Data
  rectangle "CRM Data" as CRMData
}

package "Data Processing" {
  rectangle "BigQuery" as BigQuery
  rectangle "Cloud Storage" as CloudStorage
  rectangle "Dataflow" as Dataflow
}

package "Model Training" {
  rectangle "BigQuery ML" as BQML
  rectangle "Kubeflow Pipelines" as KFP
  rectangle "Vertex AI" as VertexAI
}

package "Model Serving" {
  rectangle "AI Platform Prediction" as AIPrediction
  rectangle "Vertex AI Endpoints" as VertexEndpoints
  rectangle "Custom ScaNN Container" as ScaNN
}

package "Activation" {
  rectangle "Google Ads API" as AdsAPI
  rectangle "Data Studio" as DataStudio
}

User --> RetailData
User --> GA4Data
User --> CRMData

RetailData --> BigQuery
GA4Data --> BigQuery
CRMData --> BigQuery

BigQuery --> BQML
BigQuery --> Dataflow
Dataflow --> CloudStorage
CloudStorage --> BQML

BQML --> KFP
KFP --> VertexAI
VertexAI --> AIPrediction
VertexAI --> VertexEndpoints
VertexAI --> ScaNN

AIPrediction --> AdsAPI
VertexEndpoints --> AdsAPI
ScaNN --> AdsAPI

AdsAPI --> DataStudio
VertexEndpoints --> DataStudio
AIPrediction --> DataStudio

note right of BQML
  Training:
  - Recommendation models
  - Propensity models
  - LTV prediction
  - Time series forecasting
end note

note left of KFP
  Orchestration:
  - End-to-end pipelines
  - Model versioning
  - CI/CD
end note

note right of ScaNN
  Real-time serving:
  - Embedding lookup
  - ANN search
  - Custom container
end note
@enduml