@startuml fdrennan_ndexr-platform
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<infra>> #fddddd
  BackgroundColor<<external>> #d4f0f0
  Style roundrect
}

package "Frontend" <<frontend>> {
  [Shiny App] as Shiny
}

package "Backend" <<backend>> {
  [R Plumber API] as Plumber
  [Airflow Orchestration] as Airflow
  [Python Data Pipeline] as Python
}

package "Data Storage" <<data>> {
  [PostgreSQL] as Postgres
  [Elasticsearch] as ES
  [AWS S3] as S3
}

package "Infrastructure" <<infra>> {
  [AWS EC2] as EC2
  [AWS SNS] as SNS
  [NGINX] as Nginx
}

package "External" <<external>> {
  [Reddit API] as Reddit
}

Shiny --> Plumber
Plumber --> Postgres
Plumber --> ES

Python --> Reddit
Python --> Postgres
Python --> S3

Airflow --> Python
Airflow --> EC2
Airflow --> SNS

EC2 --> Postgres
EC2 --> S3

Nginx --> Plumber
Nginx --> Shiny

Postgres --> S3
S3 --> ES
@enduml