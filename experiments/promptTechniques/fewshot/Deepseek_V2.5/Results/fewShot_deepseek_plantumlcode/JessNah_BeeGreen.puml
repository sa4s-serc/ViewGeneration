@startuml JessNah_BeeGreen
left to right direction
skinparam rectangle {
  BackgroundColor<<extension>> #d9e7fd
  BackgroundColor<<client>> #d8f5d3
  BackgroundColor<<server>> #fff1c9
  BackgroundColor<<db>> #fddddd
  Style roundrect
}

package "Chrome Extension" <<extension>> {
  rectangle "Background Script" as Background
  rectangle "Content Script" as Content
  rectangle "Popup UI" as Popup
  rectangle "Side Tab" as SideTab
  rectangle "Webpack" as Webpack
  rectangle "Local Storage" as LocalStorage

  Background --> Content : injects
  Content --> SideTab : displays
  Popup --> Background : triggers
  Webpack --> Background : bundles
  Webpack --> Content : bundles
  Background --> LocalStorage : manages
}

package "Client Website" <<client>> {
  rectangle "React App" as ReactApp
  rectangle "Dashboard" as Dashboard
  rectangle "Contribute" as Contribute
  rectangle "Header" as Header
  rectangle "Welcome" as Welcome

  ReactApp --> Dashboard : routes
  ReactApp --> Contribute : routes
  ReactApp --> Header : includes
  ReactApp --> Welcome : routes
}

package "Server" <<server>> {
  rectangle "LoopBack 4" as LoopBack
  rectangle "REST API" as API
  rectangle "Controllers" as Controllers
  rectangle "Data Processing" as Processing
  rectangle "Models" as Models

  LoopBack --> API : exposes
  API --> Controllers : handles
  Controllers --> Processing : uses
  Processing --> Models : processes
}

database "IBM Cloudant" <<db>> as Cloudant
Models --> Cloudant : persists

Background --> API : fetches data
Content --> API : fetches data
ReactApp --> API : fetches data
@enduml