@startuml linhao1998_ChatGPTClient
left to right direction
skinparam rectangle {
  BackgroundColor<<view>> #d9e7fd
  BackgroundColor<<viewmodel>> #d8f5d3
  BackgroundColor<<model>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}

package "View Layer" <<view>> {
  [ChatActivity]
  [SettingsActivity]
  [ChatAdapter]
  [MsgAdapter]
}

package "ViewModel Layer" <<viewmodel>> {
  [ChatViewModel]
  [ChatListViewModel]
  [MsgListViewModel]
}

package "Model Layer" <<model>> {
  [Repository]
  [ChatDao]
  [MsgDao]
  [AppDatabase]
  [Chat]
  [Msg]
}

package "External Services" <<external>> {
  [OpenAI API]
  [Markwon Library]
}

ChatActivity --> ChatViewModel
SettingsActivity --> ChatViewModel
ChatViewModel --> Repository
ChatListViewModel --> Repository
MsgListViewModel --> Repository

Repository --> ChatDao
Repository --> MsgDao
ChatDao --> AppDatabase
MsgDao --> AppDatabase
AppDatabase --> Chat
AppDatabase --> Msg

Repository --> OpenAI API
ChatActivity --> Markwon Library
@enduml