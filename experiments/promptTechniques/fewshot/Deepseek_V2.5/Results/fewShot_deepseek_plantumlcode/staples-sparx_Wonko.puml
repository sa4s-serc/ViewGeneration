@startuml staples-sparx_Wonko
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor "SparX Services" as SparX

rectangle "Kafka" as Kafka #orange
rectangle "Wonko" {
  rectangle "Kafka Consumer" as Consumer #lightblue
  rectangle "Alert Processor" as Alert #lightblue
  rectangle "Prometheus Exporter" as PromExporter #lightblue
  rectangle "Web Server" as WebServer #lightblue
}

rectangle "PagerDuty" as PagerDuty #pink
rectangle "Prometheus" as Prometheus #pink

SparX --> Kafka : Publish events
Kafka --> Consumer : Consume events
Consumer --> Alert : Process events
Alert --> PagerDuty : Send alerts
Consumer --> PromExporter : Transform metrics
PromExporter --> WebServer : Expose metrics
WebServer --> Prometheus : Scrape metrics
@enduml