### Output:
@startuml oovk_dataengg-covid19-aws
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "AWS Open Data Registry" as OpenData #lightblue

rectangle "AWS Athena" as Athena #orange

rectangle "S3 Bucket (Raw Data)" as S3Raw #lightgreen

rectangle "Jupyter Notebook\n(covid19_project.ipynb)" as Notebook #pink {
  rectangle "Pandas DataFrames" as Pandas
  rectangle "ETL Logic" as ETL
}

rectangle "S3 Bucket (Transformed Data)" as S3Transformed #lightgreen

rectangle "Amazon Redshift" as Redshift #red

rectangle "Analytical Tools" as Analytics #purple

OpenData --> Athena : Query
Athena --> S3Raw : Store Results
S3Raw --> Notebook : Read Data
Notebook --> Pandas : Load Data
Pandas --> ETL : Transform
ETL --> S3Transformed : Save CSV
S3Transformed --> Redshift : Load Data
Redshift --> Analytics : Query

note right of Notebook
  Uses boto3 for AWS interactions
  Implements dimensional modeling
  (factCovid, dimRegion, dimHospital, dimDate)
end note

note right of Athena
  Executes SQL queries on S3 data
end note

note right of Redshift
  Star schema for optimized analytics
end note
@enduml