@startuml padok-team_dojo-terraform-aws-security
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "AWS Infrastructure" {
  rectangle "VPC" as vpc {
    rectangle "Public Subnet" as pub_subnet
    rectangle "Private Subnet" as priv_subnet
  }

  rectangle "EC2 Instances" as ec2 {
    rectangle "Dev Instance" as dev_instance
    rectangle "Prod Instance" as prod_instance
  }

  rectangle "Load Balancer" as lb
  rectangle "Security Groups" as sg
}

package "Terraform Configuration" {
  rectangle "main.tf" as main
  rectangle "network.tf" as network
  rectangle "variables.tf" as variables
  rectangle "prd.tfvars" as prd_vars
  rectangle "dev.tfvars" as dev_vars
  rectangle "bootstrap" as bootstrap
}

package "User Environment" {
  rectangle "VSCode Remote" as vscode
  rectangle "Terraform CLI" as tf_cli
}

vscode --> tf_cli
tf_cli --> main
tf_cli --> network
tf_cli --> variables
tf_cli --> prd_vars
tf_cli --> dev_vars
tf_cli --> bootstrap

main --> vpc
main --> ec2
main --> lb
network --> sg

variables --> prd_vars
variables --> dev_vars
bootstrap --> vpc

pub_subnet --> dev_instance
pub_subnet --> prod_instance
priv_subnet --> lb
lb --> dev_instance
lb --> prod_instance
sg --> dev_instance
sg --> prod_instance
sg --> lb

note right of sg
  IP Whitelisting
  Ingress/Egress Rules
end note
@enduml