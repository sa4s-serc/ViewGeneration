@startuml UnoSD_UnoCash
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<auth>> #fddddd
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}
left to right direction

actor User

package "Frontend" <<frontend>> {
  component "Blazor WebAssembly" as Blazor {
    [Pages]
    [Components]
  }
}

package "Backend" <<backend>> {
  component "Azure Functions" as Functions {
    [GetExpenses]
    [AddExpense]
    [ReceiptParser]
  }
}

package "Storage" <<storage>> {
  database "Azure Table Storage" as TableStorage
  database "Azure Blob Storage" as BlobStorage
}

package "Auth" <<auth>> {
  component "Azure AD" as AAD
  component "Azure AD B2C" as B2C
}

package "Infrastructure" <<infra>> {
  component "API Management" as APIM
  component "Pulumi IaC" as Pulumi
  component "Form Recognizer" as FormRec
}

User --> Blazor
Blazor --> APIM : API Calls
APIM --> Functions

Functions --> TableStorage : Expense Data
Functions --> BlobStorage : Receipt Images
Functions --> FormRec : Receipt Parsing

Blazor --> AAD : Authentication
Blazor --> B2C : Identity (Future)

Pulumi ..> APIM : Provisions
Pulumi ..> Functions : Provisions
Pulumi ..> TableStorage : Provisions
Pulumi ..> BlobStorage : Provisions
Pulumi ..> AAD : Configures
Pulumi ..> B2C : Configures (Future)

note right of Functions
  Event-driven processing
  for receipt parsing
end note
@enduml