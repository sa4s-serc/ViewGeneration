@startuml krishnaprasadkv_Linux-Commands
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "README.md" as readme {
}

rectangle "Basic Commands" as basic {
  [pwd]
  [ls]
  [cd]
}

rectangle "Filter Commands" as filter {
  [grep]
  [sed]
  [sort]
  [cut]
}

rectangle "File Operations" as files {
  [find]
  [ln]
  [chmod]
  [chown]
}

rectangle "Process Management" as process {
  [top]
  [ps]
  [kill]
}

rectangle "User/Group Admin" as admin {
  [useradd]
  [passwd]
  [groupadd]
}

rectangle "Editors" as editors {
  [vi]
}

rectangle "Concepts" as concepts {
  [File System]
  [Permissions]
  [Signals]
}

readme --> basic
readme --> filter
readme --> files
readme --> process
readme --> admin
readme --> editors
readme --> concepts

note right of readme
  Jekyll _config.yml
  controls site theme
end note
@enduml