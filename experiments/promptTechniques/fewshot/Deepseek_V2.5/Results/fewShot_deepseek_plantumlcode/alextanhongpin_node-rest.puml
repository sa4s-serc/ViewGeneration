### Actual Output:
@startuml alextanhongpin_node-rest
left to right direction
skinparam rectangle {
  BackgroundColor<<presentation>> #d9e7fd
  BackgroundColor<<application>> #d8f5d3
  BackgroundColor<<domain>> #fff1c9
  BackgroundColor<<infrastructure>> #fddddd
  BackgroundColor<<db>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Presentation Layer" <<presentation>> {
  [Express Router] as Router
  [Middleware] as Middleware
}

package "Application Layer" <<application>> {
  [FoodService] as FoodService
  [Helper Functions] as Helpers
}

package "Domain Layer" <<domain>> {
  [Food Model] as Model
  [Validation Schemas] as Schemas
}

package "Infrastructure Layer" <<infrastructure>> {
  [Food Store] as Store
  [Database Pool] as DB
  [Configuration] as Config
}

database "MySQL" <<db>> as MySQL

Router --> Middleware
Middleware --> FoodService
FoodService --> Model
Model --> Schemas
Model --> Store
Store --> DB
DB --> MySQL
Config --> DB
Config --> FoodService
Helpers --> Router
Helpers --> FoodService
@enduml