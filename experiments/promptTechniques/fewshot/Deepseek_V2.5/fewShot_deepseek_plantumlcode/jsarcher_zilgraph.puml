@startuml
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<blockchain>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

package "Zilliqa Blockchain" <<blockchain>> {
  rectangle "Zilswap Smart Contract"
  rectangle "ZRC-2 Tokens"
}

package "Data Acquisition" <<backend>> {
  rectangle "Zilcrawler" as crawler
  rectangle "pyzil Library"
}

package "Data Storage" <<storage>> {
  database "Elasticsearch" as es
  database "MongoDB" as mongo
}

package "Data Processing" <<backend>> {
  rectangle "Zillog Aggregator"
  rectangle "Zilswap Analytics"
}

package "Visualization" <<frontend>> {
  rectangle "Bokeh Server" as bokeh
  rectangle "Kibana Dashboards" as kibana
  rectangle "Nginx Reverse Proxy" as nginx
}

package "Users" {
  actor "Analyst"
  actor "Trader"
}

"Zilswap Smart Contract" --> crawler
"ZRC-2 Tokens" --> crawler
crawler --> es : Raw data
es --> "Zillog Aggregator" : Query
"Zillog Aggregator" --> mongo : Aggregated data
"Zilswap Analytics" --> mongo : Read
"Zilswap Analytics" --> bokeh : Charts
"Zilswap Analytics" --> kibana : Dashboards
bokeh --> nginx
kibana --> nginx
nginx --> "Analyst"
nginx --> "Trader"

note right of es
  Flexible querying and
  analysis of raw data
end note

note right of mongo
  Optimized storage for
  dashboard performance
end note
@enduml