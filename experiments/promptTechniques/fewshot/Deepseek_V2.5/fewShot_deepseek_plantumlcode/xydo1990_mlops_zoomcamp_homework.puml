@startuml
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as User

rectangle "Data Sources" {
  database "Kaggle Dataset" as Kaggle
  database "AWS S3" as S3
}

rectangle "Training Pipeline" {
  rectangle "Data Exploration\n(Jupyter Notebook)" as DataExp
  rectangle "Model Training\n(train_model.py)" as Train
  rectangle "MLflow Tracking" as MLflow
  rectangle "Model Registry" as Registry
}

rectangle "Serving" {
  rectangle "Batch Prediction\n(Docker)" as Batch
  rectangle "Stream Prediction\n(Docker)" as Stream
}

rectangle "Monitoring" {
  rectangle "Evidently" as Evidently
  rectangle "Prometheus" as Prometheus
  rectangle "Grafana" as Grafana
}

rectangle "Orchestration" {
  rectangle "Prefect" as Prefect
}

rectangle "CI/CD" {
  rectangle "GitHub Actions" as GitHubActions
}

User --> DataExp
Kaggle --> DataExp
DataExp --> Train
Train --> MLflow
MLflow --> Registry
Registry --> Batch
Registry --> Stream

Batch --> Evidently
Stream --> Evidently
Evidently --> Prometheus
Prometheus --> Grafana

Prefect --> Batch
GitHubActions --> Train
GitHubActions --> Batch
GitHubActions --> Stream

S3 --> Train
S3 --> Batch
S3 --> Stream
@enduml