### Output:
@startuml usds_justice40-tool
left to right direction
skinparam rectangle {
  BackgroundColor<<etl>> #d9e7fd
  BackgroundColor<<scoring>> #d8f5d3
  BackgroundColor<<frontend>> #fff1c9
  BackgroundColor<<storage>> #fddddd
  BackgroundColor<<external>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "External Data Sources" <<external>> {
  rectangle "Census API"
  rectangle "FEMA Data"
  rectangle "EPA Data"
  rectangle "First Street Foundation"
}

package "ETL Pipeline" <<etl>> {
  rectangle "ExtractTransformLoad\n(base.py)" as ETLBase
  rectangle "Data Sources\n(datasource.py)" as DataSource
  rectangle "ETL Runner\n(runner.py)" as ETLCoordinator
  rectangle "Data Validation"
  
  ETLBase --> DataSource
  ETLCoordinator --> ETLBase
  DataValidation --> ETLCoordinator
}

package "Scoring Engine" <<scoring>> {
  rectangle "ScoreA"
  rectangle "ScoreB"
  rectangle "ScoreN"
  rectangle "ScoreF"
  rectangle "Score Runner\n(score_runner.py)" as ScoreRunner
  
  ScoreRunner --> ScoreA
  ScoreRunner --> ScoreB
  ScoreRunner --> ScoreN
  ScoreRunner --> ScoreF
}

package "Data Storage" <<storage>> {
  database "S3 Data Lake"
  database "GeoJSON Files"
}

package "Client Application" <<frontend>> {
  rectangle "React Components" as React
  rectangle "Map Visualization\n(Maplibre GL)"
  rectangle "Comparison Tool"
  rectangle "Internationalization"
  
  React --> "Map Visualization\n(Maplibre GL)"
  React --> "Comparison Tool"
}

package "Map Tile Generation" {
  rectangle "Tippecanoe\n(generate.py)" as Tippecanoe
}

"Census API" --> DataSource
"FEMA Data" --> DataSource
"EPA Data" --> DataSource
"First Street Foundation" --> DataSource

ETLCoordinator --> "S3 Data Lake"
ScoreRunner --> "S3 Data Lake"
"S3 Data Lake" --> Tippecanoe
Tippecanoe --> "GeoJSON Files"
"GeoJSON Files" --> "Map Visualization\n(Maplibre GL)"

"S3 Data Lake" --> "Comparison Tool"
@enduml