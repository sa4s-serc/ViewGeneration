@startuml pacmacro_pm-server-spring
left to right direction
skinparam rectangle {
  BackgroundColor<<controller>> #d9e7fd
  BackgroundColor<<manager>> #d8f5d3
  BackgroundColor<<registry>> #fff1c9
  BackgroundColor<<repository>> #fddddd
  BackgroundColor<<model>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "API Layer" <<controller>> {
  [AdminController]
  [PlayerController]
  [GameStateController]
  [PacdotController]
  [TagController]
  [MetricsController]
  [HomeController]
}

package "Business Logic" <<manager>> {
  [AdminManager]
  [PlayerManager]
  [GameStateManager]
  [PacdotManager]
  [TagManager]
}

package "Data Management" <<registry>> {
  [PlayerRegistry]
  [GameStateRegistry]
  [PacdotRegistry]
  [TagRegistry]
}

package "Persistence" <<repository>> {
  [PlayerRepository]
  [PacdotRepository]
}

package "Domain Model" <<model>> {
  [Player]
  [Coordinate]
  [Pacdot]
  [GameState]
}

AdminController --> AdminManager
PlayerController --> PlayerManager
GameStateController --> GameStateManager
PacdotController --> PacdotManager
TagController --> TagManager

AdminManager --> GameStateRegistry
PlayerManager --> PlayerRegistry
PlayerManager --> TagRegistry
GameStateManager --> GameStateRegistry
PacdotManager --> PacdotRegistry
TagManager --> TagRegistry
TagManager --> PlayerRegistry

PlayerRegistry --> PlayerRepository
PacdotRegistry --> PacdotRepository

PlayerManager --> Player
GameStateManager --> GameState
PacdotManager --> Pacdot
TagManager --> Player
@enduml