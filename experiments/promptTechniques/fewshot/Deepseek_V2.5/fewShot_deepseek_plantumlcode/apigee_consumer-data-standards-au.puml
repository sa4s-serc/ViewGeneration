@startuml apigee_consumer-data-standards-au
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "External Systems" {
  rectangle "OIDC Provider" as OIDC
  rectangle "Banking Backends" as Banking
  rectangle "CDR Register" as CDR
}

package "Apigee Platform" {
  rectangle "API Proxies" as Proxies {
    rectangle "Banking APIs\n(Products/Accounts/Transactions)" as BankingAPI
    rectangle "OIDC Proxy" as OIDCProxy
    rectangle "Consent Mgmt Proxy" as ConsentProxy
    rectangle "Client Registration" as ClientReg
    rectangle "Admin APIs" as AdminAPI
  }

  rectangle "Shared Flows" as SharedFlows {
    rectangle "Request Validation" as Validation
    rectangle "JWT Verification" as JWT
    rectangle "Pagination" as Pagination
    rectangle "Traffic Control" as Traffic
  }

  database "Key Value Maps" as KVM
  database "Analytics" as Analytics
}

package "Additional Services" {
  rectangle "Metrics Service" as Metrics
  rectangle "Mock OIDC Provider" as MockOIDC
}

' Connections
OIDC --> OIDCProxy
Banking --> BankingAPI
CDR --> ClientReg

BankingAPI --> SharedFlows
OIDCProxy --> SharedFlows
ConsentProxy --> SharedFlows
ClientReg --> SharedFlows
AdminAPI --> SharedFlows

ConsentProxy --> KVM
OIDCProxy --> MockOIDC
Analytics --> Metrics

SharedFlows --> KVM
Proxies --> Analytics

note right of KVM
  Centralized Configuration
end note

note right of SharedFlows
  Reusable Components
end note
@enduml