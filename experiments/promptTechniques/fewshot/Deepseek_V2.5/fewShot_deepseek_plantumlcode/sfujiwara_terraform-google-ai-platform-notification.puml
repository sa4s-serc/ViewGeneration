@startuml sfujiwara_terraform-google-ai-platform-notification
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "AI Platform\nTraining Job" as AIJob

rectangle "Google Cloud\nLogging" as CloudLogging

rectangle "Pub/Sub\nLog Topic" as LogTopic

rectangle "Cloud\nFunction" as CloudFunction

rectangle "Pub/Sub\nNotification Topic" as NotifTopic

rectangle "Subscriber\n(Notification Consumer)" as Subscriber

AIJob --> CloudLogging : Emits logs
CloudLogging --> LogTopic : Forwards logs via sink
LogTopic --> CloudFunction : Triggers on new message
CloudFunction --> NotifTopic : Publishes notification
NotifTopic --> Subscriber : Delivers notification

note right of CloudFunction
  Parses logs\nDetects state changes\nValidates with Pydantic
end note

note left of CloudLogging
  Configured via\nTerraform log sink
end note

note right of NotifTopic
  Contains:\n- Job ID\n- Project ID\n- Timestamp\n- Job State
end note
@enduml