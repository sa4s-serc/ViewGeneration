### Actual Output:
@startuml anjuchamantha_EMonitor
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Sensors" {
  rectangle "DHT11\n(Temperature/Humidity)" as DHT11
  rectangle "BMP180/BMP085\n(Pressure)" as BMP
  rectangle "LDR\n(Light Intensity)" as LDR
}

package "ESP32 Device" {
  rectangle "Sensor Data\nAcquisition" as SensorRead
  rectangle "Data Buffering\n(Queue)" as Buffer
  rectangle "Data Processing\n(Mean/Std Dev)" as Process
  rectangle "XML Formatter\n(CAP Format)" as XML
  rectangle "WiFi Manager" as WiFi
  rectangle "HTTP Client" as HTTP
  rectangle "OLED Display" as OLED
  rectangle "Email Alert" as Email
  rectangle "NTP Client" as NTP
}

package "External Services" {
  rectangle "WiFi Network" as Network
  rectangle "Backend Server" as Server
  rectangle "SMTP Server" as SMTP
  rectangle "NTP Server" as NTPServer
}

DHT11 --> SensorRead
BMP --> SensorRead
LDR --> SensorRead

SensorRead --> Process
Process --> Buffer
Buffer --> XML
XML --> HTTP
HTTP --> Server

WiFi --> Network
Network --> WiFi
HTTP --> WiFi
WiFi --> OLED

SensorRead --> OLED
Process --> OLED
WiFi --> OLED

SensorRead --> Email : Temp Threshold
Email --> SMTP

NTP --> NTPServer
NTP --> OLED
@enduml