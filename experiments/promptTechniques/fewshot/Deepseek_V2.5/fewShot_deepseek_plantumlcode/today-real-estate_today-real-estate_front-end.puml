### Actual Output:
@startuml today-real-estate_today-real-estate_front-end
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<state>> #d8f5d3
  BackgroundColor<<api>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}

package "Frontend (Vue.js)" <<frontend>> {
  rectangle "App.vue" as App
  rectangle "Views" as Views
  rectangle "Components" as Components
  rectangle "Router" as Router
  App --> Views
  Views --> Components
  Router --> Views
}

package "State Management" <<state>> {
  rectangle "Vuex Store" as Store
  rectangle "userStore" as UserStore
  rectangle "searchStore" as SearchStore
  Store --> UserStore
  Store --> SearchStore
}

package "API Layer" <<api>> {
  rectangle "Axios" as Axios
  rectangle "API Modules" as APIModules
  Axios --> APIModules
}

package "External Services" <<external>> {
  rectangle "Backend API" as Backend
  rectangle "Kakao Maps" as KakaoMaps
}

Components --> Store
Components --> Axios
Store --> Axios
APIModules --> Backend
Components --> KakaoMaps

note right of Backend
  Handles:
  - Authentication
  - Apartment Data
  - News
  - Inquiries
end note
@enduml