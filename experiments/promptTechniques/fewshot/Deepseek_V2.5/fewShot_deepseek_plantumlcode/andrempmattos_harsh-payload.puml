### Actual Output:
@startuml andrempmattos_harsh-payload
left to right direction
skinparam rectangle {
  BackgroundColor<<hardware>> #d9e7fd
  BackgroundColor<<firmware>> #d8f5d3
  BackgroundColor<<os>> #fff1c9
  BackgroundColor<<interface>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Hardware Layer" <<hardware>> {
  rectangle "SmartFusion2 FPGA" as FPGA {
    rectangle "AXI/AHB Interconnect" as BUS
    rectangle "Memory Subsystem" as MEM
    rectangle "Peripheral Interfaces" as PERIPH
    rectangle "Clocking/Reset" as CLOCK
  }
}

package "Firmware Layer" <<firmware>> {
  rectangle "HAL" as HAL
  rectangle "Peripheral Drivers" as DRIVERS
  rectangle "System Services" as SERVICES
  rectangle "Experiment Algorithms" as EXPERIMENTS
}

package "OS Layer" <<os>> {
  rectangle "FreeRTOS" as RTOS {
    rectangle "Task Scheduler" as SCHED
    rectangle "Queues" as QUEUES
    rectangle "Timers" as TIMERS
  }
}

package "Interface Layer" <<interface>> {
  rectangle "OBC Communication (FSP)" as OBC
  rectangle "RPi Wrapper" as RPI
}

FPGA --> HAL
HAL --> DRIVERS
DRIVERS --> SERVICES
DRIVERS --> EXPERIMENTS
HAL --> RTOS
RTOS --> OBC
RTOS --> RPI

BUS --> MEM
BUS --> PERIPH
BUS --> CLOCK
@enduml