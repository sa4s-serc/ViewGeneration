@startuml IBM_vpc-flowlogs-log-analysis
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "IBM Cloud Object Storage (COS)" as COS {
  rectangle "Receiver Bucket" as Receiver
  rectangle "Archive Bucket" as Archive
}

rectangle "IBM Cloud Functions" as Functions {
  rectangle "handler.js" as Handler
  rectangle "index.js" as Index
  rectangle "local-handler.js" as LocalHandler
}

rectangle "IBM Log Analysis" as LogAnalysis

rectangle "VPC Flow Logs" as VPC

VPC --> Receiver : Writes logs
Receiver --> Handler : Triggers on new logs
Handler --> Receiver : Reads logs
Handler --> Archive : Copies processed logs
Handler --> Receiver : Deletes processed logs
Handler --> LogAnalysis : Forwards processed logs

Index --> Handler : Invokes for HTTP testing
LocalHandler --> Handler : Simulates COS triggers
@enduml