@startuml fecgov_fec-eregs
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<deploy>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "Django Templates" as Templates
  rectangle "SCSS/Styling" as SCSS
  rectangle "JavaScript" as JS
  rectangle "USWDS Components" as USWDS
}

package "Backend" <<backend>> {
  rectangle "Django App" as Django
  rectangle "Regulations Parser" as Parser
  rectangle "API Views" as API
}

package "Data Stores" <<db>> {
  database "PostgreSQL" as Postgres
  database "ElasticSearch" as ES
}

package "Integrations" <<integration>> {
  rectangle "CMS" as CMS
  rectangle "External API" as ExtAPI
}

package "Deployment" <<deploy>> {
  rectangle "Cloud Foundry" as CF
  rectangle "manifest.yml" as Manifest
  rectangle "tasks.py" as Tasks
}

Templates --> Django
SCSS --> Templates
JS --> Templates
USWDS --> SCSS

Django --> Parser
Django --> API
API --> Postgres
API --> ES
Parser --> Postgres

JS --> ExtAPI
Django --> CMS

Manifest --> CF
Tasks --> CF
CF --> Django
CF --> Postgres
CF --> ES

note right of Postgres
  MPTT structure for
  hierarchical regulations
end note

note right of ES
  Full-text search
  capabilities
end note
@enduml