@startuml
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Angular Interview\nQuestions & Answers" as Main {
  rectangle "Core Content" as Content {
    rectangle "Fundamental Concepts" as Fundamentals
    rectangle "Advanced Features" as Advanced
    rectangle "RxJS" as RxJS
    rectangle "Angular CLI" as CLI
    rectangle "Angular Material" as Material
  }

  rectangle "Supporting Elements" as Support {
    rectangle "Code Examples" as Code
    rectangle "Table of Contents" as TOC
    rectangle "License (Apache 2.0)" as License
  }

  rectangle "External Resources" as External {
    rectangle "YouTube Links" as YouTube
    rectangle "Author Website" as Website
  }
}

Fundamentals --> Code
Advanced --> Code
RxJS --> Code
CLI --> Code
Material --> Code

Content --> TOC
Main --> License
Main --> External

@enduml