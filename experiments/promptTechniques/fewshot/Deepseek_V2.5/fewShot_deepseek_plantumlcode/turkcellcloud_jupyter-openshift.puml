### Actual Output:
@startuml turkcellcloud_jupyter-openshift
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<auth>> #fddddd
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "User Interface" <<frontend>> {
  rectangle "JupyterLab" as JupyterLab
  rectangle "Notebook UI" as NotebookUI
}

package "Core Services" <<backend>> {
  rectangle "JupyterHub" as JupyterHub
  rectangle "KubeSpawner" as KubeSpawner
  rectangle "PostgreSQL" as PostgreSQL
}

package "Authentication" <<auth>> {
  rectangle "LDAP/AD" as LDAP
  rectangle "OAuth" as OAuth
}

package "Infrastructure" <<infra>> {
  rectangle "OpenShift 3.11" as OpenShift
  rectangle "Network Policies" as NetPol
  rectangle "Resource Quotas" as Quotas
}

package "Storage" <<storage>> {
  rectangle "Persistent Volumes" as PV
  rectangle "ConfigMaps" as ConfigMaps
}

JupyterLab --> JupyterHub
NotebookUI --> JupyterHub

JupyterHub --> KubeSpawner
JupyterHub --> PostgreSQL
JupyterHub --> LDAP
JupyterHub --> OAuth

KubeSpawner --> OpenShift
OpenShift --> NetPol
OpenShift --> Quotas
OpenShift --> PV

JupyterHub --> ConfigMaps

note right of ConfigMaps
  jupyterhub_config.py
  tcuser_profile_mappings
end note

note right of KubeSpawner
  Manages notebook pods
  with profile-based
  resource allocation
end note

note right of NetPol
  Restricts network
  traffic to notebook pods
end note
@enduml