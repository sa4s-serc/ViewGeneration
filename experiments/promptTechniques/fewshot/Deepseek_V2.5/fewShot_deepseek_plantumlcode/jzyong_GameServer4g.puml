@startuml jzyong_GameServer4g
skinparam backgroundColor #eeeeee
skinparam componentStyle rectangle
skinparam ArrowColor #333333
skinparam defaultTextAlignment center

left to right direction

rectangle "Client" as Client

rectangle "Gate" as Gate {
    component "UserManager" as UserManager
    component "GameManager" as GameManager
    component "ClientManager" as ClientManager
}

rectangle "Hall" as Hall {
    component "HallManager" as HallManager
}

rectangle "World" as World {
    component "WorldManager" as WorldManager
}

rectangle "Resource" as Resource
rectangle "Manager" as Manager
rectangle "ZooKeeper" as ZooKeeper

database "Configuration" as Config

Client -[#blue]-> Gate : TCP (custom protocol)
Gate -[#green]-> Hall : gRPC
Hall -[#green]-> World : gRPC
World -[#green]-> Resource : gRPC

Gate --> ZooKeeper : register/discover
Hall --> ZooKeeper : register/discover
World --> ZooKeeper : register/discover
Manager --> ZooKeeper : manage

Gate --> Config : load config
Hall --> Config : load config
World --> Config : load config

UserManager -[hidden]-> GameManager
GameManager -[hidden]-> ClientManager
HallManager -[hidden]-> WorldManager

note right of ZooKeeper
  Service Discovery
  Configuration
end note

note top of Config
  JSON Configuration
  Server IDs
  RPC URLs
end note
@enduml