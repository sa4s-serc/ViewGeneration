@startuml FAC10_week4-jajascript
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<test>> #fddddd
  Style roundrect
}

package "Frontend" <<frontend>> {
  [index.html] as HTML
  [main.css] as CSS
  [main.js] as JS
  HTML --> CSS
  HTML --> JS
}

package "Backend" <<backend>> {
  [server.js] as Server
  [router.js] as Router
  [handler.js] as Handler
  [algorithm.js] as Algorithm
  Server --> Router
  Router --> Handler
  Handler --> Algorithm
}

package "Data" <<data>> {
  [data.json] as Data
}

package "Testing" <<test>> {
  [qunit.html] as QUnit
  [frontendTests.js] as FrontTests
  [backendTests.js] as BackTests
  QUnit --> FrontTests
  QUnit --> BackTests
}

JS --> Server : fetch(/search/:query)
Algorithm --> Data : read
BackTests --> Algorithm : test
FrontTests --> JS : test
@enduml