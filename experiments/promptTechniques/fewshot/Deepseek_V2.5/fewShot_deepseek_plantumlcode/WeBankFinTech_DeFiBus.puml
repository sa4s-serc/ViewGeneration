@startuml WeBankFinTech_DeFiBus
skinparam rectangle {
  BackgroundColor<<broker>> #d9e7fd
  BackgroundColor<<client>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<rocketmq>> #fddddd
  Style roundrect
}
left to right direction

package "Clients" <<client>> {
  [Producer] as Producer
  [Consumer] as Consumer
}

package "DeFiBus Broker" <<broker>> {
  rectangle "DeFiBrokerController" as BrokerController
  rectangle "DeFiProducerManager" as ProducerManager
  rectangle "DeFiConsumerManager" as ConsumerManager
  rectangle "ConsumeQueueManager" as QueueManager
  rectangle "DeFiSendMessageProcessor" as SendProcessor
  rectangle "DeFiReplyMessageProcessor" as ReplyProcessor
  rectangle "MessageRedirectManager" as RedirectManager
  rectangle "AdjustQueueNumStrategy" as QueueStrategy
}

package "RocketMQ Core" <<rocketmq>> {
  rectangle "MessageStore" as MessageStore
  rectangle "BrokerController" as RocketMQController
}

package "Storage" <<storage>> {
  [CommitLog] as CommitLog
  [ConsumeQueue] as ConsumeQueue
}

Producer --> SendProcessor : Send Messages
Consumer --> SendProcessor : Pull Messages
SendProcessor --> ReplyProcessor : Request/Reply
BrokerController --> RocketMQController : Extends
BrokerController --> ProducerManager : Manages
BrokerController --> ConsumerManager : Manages
BrokerController --> QueueManager : Manages
QueueManager --> QueueStrategy : Uses
SendProcessor --> RedirectManager : Uses
SendProcessor --> QueueManager : Checks depth/isolation
ConsumerManager --> QueueManager : Updates offsets
ProducerManager --> QueueManager : Updates stats
MessageStore --> CommitLog : Writes
MessageStore --> ConsumeQueue : Reads
DeFiPluginMessageStore -[hidden]-> MessageStore : Decorates

note right of BrokerController
  Handles:
  - Fault tolerance
  - Dynamic queue management
  - Service proximity
  - Access control
end note
@enduml