@startuml Bytom-Community_Bytom-Server
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Network Layer" {
  rectangle "P2P Networking" as p2p #lightblue
  rectangle "Block Synchronization" as netsync #lightblue
  rectangle "SecretConnection" as secretconn #lightblue
}

package "Core Blockchain" {
  rectangle "Blockchain Protocol" as protocol #lightgreen
  rectangle "Transaction Pool" as txpool #lightgreen
  rectangle "Consensus" as consensus #lightgreen
  rectangle "Mining (Tensority)" as mining #lightgreen
}

package "Data Layer" {
  rectangle "Database (LevelDB)" as db #lightyellow
  rectangle "State Management" as state #lightyellow
  rectangle "UTXO Index" as utxo #lightyellow
}

package "VM & Smart Contracts" {
  rectangle "Bytom VM" as vm #pink
  rectangle "Transaction Builder" as txbuilder #pink
}

package "Security" {
  rectangle "Pseudohsm" as hsm #orange
  rectangle "Key Management" as keys #orange
  rectangle "Access Tokens" as tokens #orange
}

package "API Layer" {
  rectangle "gRPC API" as grpc #lavender
  rectangle "CLI Interface" as cli #lavender
}

p2p --> netsync
netsync --> protocol
protocol --> txpool
protocol --> consensus
protocol --> mining
protocol --> state
state --> db
state --> utxo
txpool --> vm
vm --> txbuilder
hsm --> keys
keys --> tokens
tokens --> grpc
grpc --> cli

secretconn --> p2p
mining --> db
txbuilder --> txpool
@enduml