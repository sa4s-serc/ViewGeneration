@startuml
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<auth>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "App.jsx" as App
  rectangle "SyllabusSearch.jsx" as Search
  rectangle "GlassCard.jsx" as Card
  rectangle "LecturePage.jsx" as Lecture
  rectangle "ReviewItem.jsx" as ReviewItem
  rectangle "ReviewPost.jsx" as ReviewPost
  rectangle "Auth.jsx" as Auth
  rectangle "React Query" as ReactQuery
  rectangle "Zustand Store" as Zustand

  App --> Search
  App --> Lecture
  App --> Auth
  Search --> Card
  Lecture --> ReviewItem
  Lecture --> ReviewPost
  ReviewPost --> Zustand
  Search --> ReactQuery
  Lecture --> ReactQuery
}

package "Backend (Go/Echo)" <<backend>> {
  rectangle "Router" as Router
  rectangle "Controllers" as Controllers
  rectangle "Usecases" as Usecases
  rectangle "Repositories" as Repositories
  rectangle "Models" as Models

  Router --> Controllers
  Controllers --> Usecases
  Usecases --> Repositories
  Repositories --> Models
}

package "Authentication" <<auth>> {
  rectangle "JWT" as JWT
  rectangle "CSRF Protection" as CSRF
  JWT --> CSRF
}

database "PostgreSQL" <<db>> as DB
Repositories --> DB

package "Docker" {
  rectangle "docker-compose.yml" as Docker
  Docker --> DB
}

Frontend --> Backend : REST API
Auth --> JWT
@enduml