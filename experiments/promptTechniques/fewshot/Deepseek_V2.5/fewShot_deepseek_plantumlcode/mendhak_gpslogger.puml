### Actual Output:
@startuml mendhak_gpslogger
left to right direction
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<service>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<config>> #d4f0f0
  Style roundrect
}

package "User Interface" <<ui>> {
  [Main Activity]
  [Preferences Activity]
  [Log Viewer]
  [Big View Mode]
}

package "Core Services" <<service>> {
  [GpsLoggingService]
  [GeneralLocationListener]
  [Event Bus]
  [WorkManager]
}

package "Data Management" <<data>> {
  [FileLoggerFactory]
  [GPXLogger]
  [KMLLogger]
  [CSVLogger]
  [Local Storage]
}

package "Upload Services" <<external>> {
  [GoogleDriveWorker]
  [DropboxWorker]
  [SFTPWorker]
  [HTTPWorker]
  [OSM Uploader]
}

package "Configuration" <<config>> {
  [AppSettings]
  [PreferenceHelper]
  [Session]
}

database "SharedPreferences" as Prefs

[Main Activity] --> [GpsLoggingService]
[Preferences Activity] --> [PreferenceHelper]
[GpsLoggingService] --> [GeneralLocationListener]
[GpsLoggingService] --> [Event Bus]
[GpsLoggingService] --> [WorkManager]
[GeneralLocationListener] --> [FileLoggerFactory]
[FileLoggerFactory] --> [GPXLogger]
[FileLoggerFactory] --> [KMLLogger]
[FileLoggerFactory] --> [CSVLogger]
[GPXLogger] --> [Local Storage]
[KMLLogger] --> [Local Storage]
[CSVLogger] --> [Local Storage]
[WorkManager] --> [GoogleDriveWorker]
[WorkManager] --> [DropboxWorker]
[WorkManager] --> [SFTPWorker]
[WorkManager] --> [HTTPWorker]
[WorkManager] --> [OSM Uploader]
[AppSettings] --> [PreferenceHelper]
[PreferenceHelper] --> Prefs
[Session] --> Prefs

[Event Bus] ..> [Main Activity] : Notifications
[Event Bus] ..> [Log Viewer] : Updates
@enduml