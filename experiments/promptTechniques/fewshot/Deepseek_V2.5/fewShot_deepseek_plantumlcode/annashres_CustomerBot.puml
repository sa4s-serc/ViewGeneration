@startuml annashres_CustomerBot
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Channels" <<frontend>> {
  rectangle "Bot Emulator"
  rectangle "Webchat"
  rectangle "Email"
}

package "Bot Framework" <<backend>> {
  rectangle "index.js" as Index
  rectangle "bot.js" as Bot
  rectangle "botdisplay.js" as Display
}

package "Integrations" <<integration>> {
  rectangle "Power BI" as PowerBI
  rectangle "Email Parser" as EmailParser
}

database "Azure SQL DB" <<db>> as SQLDB
database "Auth DB" <<db>> as AuthDB

"Bot Emulator" --> Index
"Webchat" --> Index
"Email" --> Index

Index --> Bot
Bot --> Display
Display --> "Bot Emulator"
Display --> "Webchat"
Display --> "Email"

Bot --> SQLDB : Stores\nconversations
Bot --> AuthDB : Verifies\npins

"Email" --> EmailParser
EmailParser --> Bot

Bot --> PowerBI : Visualizes\ndata
@enduml