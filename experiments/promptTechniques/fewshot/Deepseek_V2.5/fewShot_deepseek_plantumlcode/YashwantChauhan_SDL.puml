@startuml YashwantChauhan_SDL
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<ml>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as user

package "Frontend" <<frontend>> {
  rectangle "Web Interface" as web
  rectangle "Bootstrap UI" as bootstrap
  rectangle "Form Validation" as form
  rectangle "ScrollReveal" as scroll
  web --> bootstrap
  web --> form
  web --> scroll
}

package "Backend" <<backend>> {
  rectangle "Django Views" as views
  rectangle "URL Routing" as urls
  rectangle "Authentication" as auth
  views --> urls
  views --> auth
}

package "Machine Learning" <<ml>> {
  rectangle "Random Forest Classifier" as rf
  rectangle "Data Preprocessing" as preprocess
  rectangle "Attack Classification" as classify
  rf --> preprocess
  rf --> classify
}

package "Database" <<db>> {
  database "SQLite" as db {
    rectangle "User Data" as userdb
    rectangle "Detection History" as history
    rectangle "Results" as results
  }
}

user --> web
web --> views
views --> rf
views --> db
rf --> db
classify --> results
auth --> userdb
history --> userdb

rectangle "CI/CD Pipeline" as cicd {
  rectangle "Jenkins" as jenkins
  rectangle "Heroku Deployment" as heroku
  jenkins --> heroku
}

views --> cicd
@enduml