@startuml Scientific-Computing-Lab-NRCN_compar
left to right direction
skinparam rectangle {
  BackgroundColor<<editor>> #d9e7fd
  BackgroundColor<<compiler>> #d8f5d3
  BackgroundColor<<parallel>> #fff1c9
  BackgroundColor<<gui>> #fddddd
  Style roundrect
}

package "CodeMirror Editor" <<editor>> {
  component "Core Editor" as core
  component "Language Modes" as modes
  component "Keymaps" as keymaps
  component "Addons" as addons
  component "Event System" as events

  core --> modes
  core --> keymaps
  core --> addons
  core --> events
}

package "ComPar System" {
  component "GUI Framework" <<gui>> as gui
  component "Compiler Abstraction" <<compiler>> as compiler
  component "Parallelization Tools" <<parallel>> as parallel
  component "Runtime Analysis" <<parallel>> as runtime
  component "Database" as db

  gui --> compiler
  gui --> parallel
  gui --> runtime
  parallel --> runtime
  runtime --> db
}

note right of core
  Text editing, syntax highlighting,
  indentation, code folding,
  bracket matching
end note

note right of modes
  JavaScript, HTML, CSS, SQL,
  Python, XML, Clojure, etc.
end note

note right of addons
  Auto-completion, linting,
  merge functionality, search
end note

note right of compiler
  GCC, ICC, Cetus, Autopar,
  Par4all implementations
end note

note right of parallel
  Cetus, Autopar, Par4All
  source-to-source tools
end note

note right of runtime
  Performance analysis,
  optimal code selection
end note

"CodeMirror Editor" --> "ComPar System" : Embedded in GUI
@enduml