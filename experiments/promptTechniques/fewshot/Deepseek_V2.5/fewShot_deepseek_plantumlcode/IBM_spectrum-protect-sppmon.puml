@startuml IBM_spectrum-protect-sppmon
left to right direction
skinparam rectangle {
  BackgroundColor<<collection>> #d9e7fd
  BackgroundColor<<storage>> #d8f5d3
  BackgroundColor<<visualization>> #fff1c9
  BackgroundColor<<analysis>> #fddddd
  BackgroundColor<<automation>> #d4f0f0
  Style roundrect
}

package "Data Collection" <<collection>> {
  rectangle "SPP Server" as SPP
  rectangle "vSnap" as vSnap
  rectangle "VADP" as VADP
  rectangle "M365 Proxy" as M365
  
  component "REST API Client" as RESTClient
  component "SSH Client" as SSHClient
  
  SPP --> RESTClient
  vSnap --> SSHClient
  VADP --> SSHClient
  M365 --> SSHClient
}

package "Data Storage" <<storage>> {
  database "InfluxDB" as InfluxDB
  component "Influx Client" as InfluxClient
  RESTClient --> InfluxClient
  SSHClient --> InfluxClient
  InfluxClient --> InfluxDB
}

package "Visualization" <<visualization>> {
  component "Grafana" as Grafana
  InfluxDB --> Grafana
}

package "Analysis & Reporting" <<analysis>> {
  component "SPPCheck" as SPPCheck
  component "Report Generator" as ReportGen
  
  InfluxDB --> SPPCheck
  SPPCheck --> ReportGen
}

package "Automation" <<automation>> {
  component "Installer Script" as Installer
  component "Cron Jobs" as Cron
  
  Installer --> Cron
  Installer --> RESTClient
  Installer --> SSHClient
  Installer --> InfluxClient
  Installer --> Grafana
}

note right of SPPCheck
  Includes:
  - System Verification
  - Resource Prediction
  - Fake Data Generation
end note

note right of ReportGen
  Generates PDF reports
  with analysis results
end note
@enduml