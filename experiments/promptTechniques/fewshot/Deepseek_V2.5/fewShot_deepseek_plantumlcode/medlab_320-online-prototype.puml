@startuml medlab_320-online-prototype
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<testing>> #f0d9ff
  Style roundrect
}

package "Frontend (React)" <<frontend>> {
  rectangle "React Components" as ReactComp
  rectangle "Redux Store" as Redux
  rectangle "Ant Design UI" as AntD
  rectangle "React Router" as Router
  ReactComp --> Redux
  ReactComp --> AntD
  ReactComp --> Router
}

package "Backend (.NET Core)" <<backend>> {
  rectangle "API Controllers" as Controllers
  rectangle "Services" as Services
  rectangle "Entity Framework" as EF
  rectangle "Authentication (JWT/OAuth)" as Auth
  rectangle "Logging (Serilog)" as Logging
  Controllers --> Services
  Services --> EF
  Services --> Auth
  Services --> Logging
}

package "Integrations" <<integration>> {
  rectangle "MinIO (S3)" as MinIO
  rectangle "Kubernetes" as K8s
  rectangle "EFK Stack" as EFK
  rectangle "IdentityServer4" as IDS4
  rectangle "OpenTelemetry" as OT
  Logging --> EFK
  Auth --> IDS4
  Services --> MinIO
  Services --> OT
}

package "Testing" <<testing>> {
  rectangle "Jest/Puppeteer" as Jest
  rectangle "Blazor Test UI" as Blazor
  rectangle "xUnit/MSTest" as UnitTests
  Jest --> ReactComp
  UnitTests --> Services
}

database "SQL Database" <<db>> as SQL
EF --> SQL

ReactComp --> Controllers : HTTP
Blazor --> Controllers : HTTP
@enduml