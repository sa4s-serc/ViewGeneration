@startuml bluekiri_mlab
left to right direction
skinparam rectangle {
  BackgroundColor<<dashboard>> #d9e7fd
  BackgroundColor<<worker>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Dashboard" <<dashboard>> {
  rectangle "Flask App" as flask
  rectangle "API Endpoints" as api
  rectangle "Interactors" as interactors
  rectangle "Repositories" as repos
  rectangle "Admin UI" as adminui

  flask --> api
  api --> interactors
  interactors --> repos
  flask --> adminui
}

package "Worker Service" <<worker>> {
  rectangle "Falcon API" as falcon
  rectangle "Model Loader" as loader
  rectangle "ZooKeeper Client" as zk
  rectangle "Worker Interactors" as worker_interactors
  rectangle "Worker Repos" as worker_repos

  falcon --> loader
  loader --> worker_interactors
  worker_interactors --> worker_repos
  worker_repos --> zk
}

package "Storage" <<storage>> {
  database "MongoDB" as mongo
  database "ZooKeeper" as zookeeper
}

package "External" <<external>> {
  rectangle "LDAP" as ldap
  rectangle "Email Service" as email
}

flask --> ldap
interactors --> email
repos --> mongo
repos --> zookeeper
worker_repos --> mongo
worker_repos --> zookeeper

adminui --> flask
zk --> zookeeper
@enduml