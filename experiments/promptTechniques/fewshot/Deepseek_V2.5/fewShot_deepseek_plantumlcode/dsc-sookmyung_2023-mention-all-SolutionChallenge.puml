@startuml dsc-sookmyung_2023-mention-all-SolutionChallenge
left to right direction
skinparam rectangle {
  BackgroundColor<<mobile>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<services>> #fff1c9
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<db>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Mobile Clients" <<mobile>> {
  rectangle "Android App\n(Kotlin)" as Android
  rectangle "iOS App\n(Swift)" as iOS
}

package "Backend" <<backend>> {
  rectangle "Spring Boot\n(Java)" as SpringBoot
  rectangle "REST API" as API
  rectangle "Auth Service" as Auth
  rectangle "Education Service" as Education
  rectangle "Dispatch Service" as Dispatch
  rectangle "Notification Service" as Notification
}

package "External Services" <<external>> {
  rectangle "Firebase\n(Auth, FCM, DB)" as Firebase
  rectangle "Google Maps API" as Maps
  rectangle "TensorFlow Lite" as TFLite
  rectangle "GCP\n(Deployment)" as GCP
}

database "Database" <<db>> as DB

Android --> API
iOS --> API

API --> Auth
API --> Education
API --> Dispatch
API --> Notification

Auth --> Firebase
Notification --> Firebase
Dispatch --> Maps
Education --> TFLite

SpringBoot --> DB

Android --> TFLite
iOS --> TFLite

SpringBoot --> GCP : Deployed on
@enduml