@startuml btcpayserver_btcpayserver-doc
left to right direction
skinparam rectangle {
  BackgroundColor<<content>> #d9e7fd
  BackgroundColor<<build>> #d8f5d3
  BackgroundColor<<config>> #fff1c9
  BackgroundColor<<theme>> #fddddd
  BackgroundColor<<util>> #d4f0f0
  Style roundrect
}

package "Content" <<content>> {
  [User Guides]
  [Deployment Docs]
  [Development Docs]
  [API Integration]
  [Troubleshooting]
  [Theming Docs]
}

package "Build & Deployment" <<build>> {
  [create-redirects.js]
  [setup-deps.sh]
  [build.yml]
  [btcpayserver-rpi4-install.sh]
}

package "Configuration" <<config>> {
  [config.js]
  [.editorconfig]
}

package "Theme" <<theme>> {
  [theme/index.js]
  [Navbar.vue]
  [NavLinks.vue]
  [Sidebar.vue]
  [site.css]
}

package "Utilities" <<util>> {
  [slugify.js]
  [preprocessMarkdown.js]
  [themeSwitch.js]
  [enhanceApp.js]
}

[VuePress] as vuepress

User Guides --> vuepress
Deployment Docs --> vuepress
Development Docs --> vuepress
API Integration --> vuepress
Troubleshooting --> vuepress
Theming Docs --> vuepress

create-redirects.js --> vuepress
setup-deps.sh --> vuepress
build.yml --> vuepress
btcpayserver-rpi4-install.sh --> vuepress

config.js --> vuepress
.editorconfig --> vuepress

theme/index.js --> vuepress
Navbar.vue --> vuepress
NavLinks.vue --> vuepress
Sidebar.vue --> vuepress
site.css --> vuepress

slugify.js --> vuepress
preprocessMarkdown.js --> vuepress
themeSwitch.js --> vuepress
enhanceApp.js --> vuepress

[GitHub Pages] as ghpages
vuepress --> ghpages
@enduml