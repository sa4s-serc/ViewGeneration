@startuml calmato_gran-book
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Nuxt.js)" <<frontend>> {
  rectangle "Admin Panel" as AdminPanel
  rectangle "Vue Components" as Components
  rectangle "Vuex Store" as Vuex
  rectangle "Axios Client" as Axios
  Components --> Vuex
  Components --> Axios
  AdminPanel --> Components
}

package "API Gateway" <<backend>> {
  rectangle "Native Gateway" as NativeGateway
  rectangle "Admin Gateway" as AdminGateway
  rectangle "Request/Response\nTransformation" as Transform
  AdminGateway --> Transform
  NativeGateway --> Transform
}

package "Backend Services" <<backend>> {
  rectangle "Book Service" as BookService
  rectangle "User Service" as UserService
  rectangle "Review Service" as ReviewService
  rectangle "Chat Service" as ChatService
  rectangle "Auth Service" as AuthService
}

package "Integrations" <<integration>> {
  rectangle "Firebase Auth" as Firebase
  rectangle "Image Storage" as ImageStorage
  rectangle "gRPC" as gRPC
}

database "Database" <<db>> as DB

AdminPanel --> AdminGateway
AdminGateway --> BookService
AdminGateway --> UserService
AdminGateway --> ReviewService
AdminGateway --> ChatService
AdminGateway --> AuthService

BookService --> DB
UserService --> DB
ReviewService --> DB
ChatService --> DB
AuthService --> DB

AuthService --> Firebase
BookService --> ImageStorage
UserService --> ImageStorage

BookService --> gRPC
UserService --> gRPC
ReviewService --> gRPC
ChatService --> gRPC
AuthService --> gRPC
@enduml