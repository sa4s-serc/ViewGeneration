@startuml Nishu0_anime_nft_marketplace
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<contract>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<wallet>> #fddddd
  Style roundrect
}
left to right direction

actor User

package "Frontend (Next.js)" <<frontend>> {
  rectangle "UI Components" as UI
  rectangle "NFTContext" as Context
  rectangle "Pages" as Pages
  UI --> Pages
  Pages --> Context
}

package "Blockchain" <<contract>> {
  rectangle "NFTMarketplace.sol" as Contract
  rectangle "Ethers.js" as Ethers
  Context --> Ethers
  Ethers --> Contract
}

package "Storage" <<storage>> {
  rectangle "IPFS" as IPFS
  rectangle "Metadata" as Metadata
  IPFS --> Metadata
  Context --> IPFS
}

package "Wallet" <<wallet>> {
  rectangle "Metamask" as Wallet
  rectangle "Web3Modal" as Web3Modal
  Context --> Web3Modal
  Web3Modal --> Wallet
}

User --> UI
User --> Wallet
Wallet --> Contract
Contract --> IPFS
@enduml