@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Sample Node.js App" as NodeApp {
  rectangle "/metrics endpoint" as Metrics
}

rectangle "Prometheus" as Prometheus {
  rectangle "Scrape Config" as Scrape
  rectangle "Alert Rules" as Rules
}

rectangle "Alertmanager" as Alertmanager

rectangle "Grafana" as Grafana {
  rectangle "Dashboards" as Dash
}

rectangle "User" as User

NodeApp --> Metrics : Exposes
Prometheus --> Scrape : Reads config
Scrape --> Metrics : Pulls metrics
Prometheus --> Rules : Evaluates
Rules --> Alertmanager : Sends alerts
Alertmanager --> User : Notifies
Prometheus --> Grafana : Provides data
Grafana --> Dash : Renders
User --> Grafana : Views dashboards
@enduml