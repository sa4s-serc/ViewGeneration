@startuml teamgram_teamgram-server
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Clients" {
  [Web Client]
  [Mobile Client]
  [Desktop Client]
}

package "BFF Layer" {
  rectangle "Messages BFF"
  rectangle "Privacy BFF"
  rectangle "Other BFFs"
}

package "Core Services" {
  rectangle "Auth Service" as Auth
  rectangle "User Service" as User
  rectangle "Chat Service" as Chat
  rectangle "Message Service" as Msg
  rectangle "Media Service" as Media
  rectangle "DFS Service" as DFS
  rectangle "Username Service" as Username
  rectangle "Dialog Service" as Dialog
  rectangle "Updates Service" as Updates
  rectangle "ID Gen Service" as IDGen
}

package "Infrastructure" {
  rectangle "Kafka" as Kafka
  rectangle "Redis" as Redis
  rectangle "MySQL" as MySQL
  rectangle "MinIO" as MinIO
  rectangle "Etcd" as Etcd
}

[Web Client] --> [Messages BFF]
[Mobile Client] --> [Messages BFF]
[Desktop Client] --> [Messages BFF]

[Messages BFF] --> Msg
[Privacy BFF] --> User
[Other BFFs] --> Chat

Msg --> Kafka
Msg --> Redis
Msg --> MySQL

User --> Redis
User --> MySQL

Chat --> Redis
Chat --> MySQL

Media --> MinIO
Media --> Redis
Media --> MySQL

DFS --> MinIO

Username --> Redis
Username --> MySQL

Dialog --> Redis
Dialog --> MySQL

Updates --> Kafka
Updates --> Redis

IDGen --> Redis

Auth --> Redis
Auth --> MySQL

Etcd --> Auth
Etcd --> User
Etcd --> Chat
Etcd --> Msg
Etcd --> Media
Etcd --> DFS
Etcd --> Username
Etcd --> Dialog
Etcd --> Updates
Etcd --> IDGen

note right of MinIO
  Media Storage
end note

note right of Kafka
  Async Messaging
end note

note right of Etcd
  Service Discovery
end note
@enduml