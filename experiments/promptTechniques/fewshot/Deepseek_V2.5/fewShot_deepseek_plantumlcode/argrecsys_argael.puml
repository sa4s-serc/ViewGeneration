@startuml argrecsys_argael
left to right direction
skinparam rectangle {
  BackgroundColor<<gui>> #d9e7fd
  BackgroundColor<<data>> #d8f5d3
  BackgroundColor<<io>> #fff1c9
  BackgroundColor<<util>> #fddddd
  BackgroundColor<<config>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "GUI Layer" <<gui>> {
  rectangle "ArgaelForm" as GUI
  rectangle "ReportFormatter" as Report
  GUI --> Report
}

package "Data Layer" <<data>> {
  rectangle "DataManager" as Data
  rectangle "ArgumentModel" as Model
  rectangle "TreeNode" as TreeNode
  rectangle "SelectedItems" as SelectedItems
  Data --> Model
  Data --> TreeNode
  Data --> SelectedItems
}

package "IO Layer" <<io>> {
  rectangle "IOManager" as IO
  rectangle "FileUtils" as FileUtils
  IO --> FileUtils
}

package "Utility Layer" <<util>> {
  rectangle "StringUtils" as StringUtils
  rectangle "InitParams" as InitParams
}

package "Configuration" <<config>> {
  rectangle "params.json" as Params
  rectangle "users.txt" as Users
  rectangle "HTML Templates" as Templates
}

GUI --> Data
GUI --> IO
GUI --> InitParams
Data --> IO
IO --> FileUtils
IO --> StringUtils
InitParams --> Params
Report --> Templates
IO --> Users
IO --> "data/proposals/*.jsonl" as DataFiles
@enduml