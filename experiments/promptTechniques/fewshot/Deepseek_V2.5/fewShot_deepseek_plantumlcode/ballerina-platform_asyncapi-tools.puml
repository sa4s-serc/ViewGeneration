@startuml ballerina-platform_asyncapi-tools
left to right direction
skinparam rectangle {
  BackgroundColor<<input>> #d9e7fd
  BackgroundColor<<generator>> #d8f5d3
  BackgroundColor<<output>> #fff1c9
  BackgroundColor<<test>> #fddddd
  BackgroundColor<<cli>> #e6d9ff
  Style roundrect
}

package "Input Specifications" <<input>> {
  rectangle "AsyncAPI YAML" as asyncapi
  rectangle "OpenAPI YAML" as openapi
}

package "Core Generators" <<generator>> {
  rectangle "AsyncApiToBallerinaGenerator" as toBallerina
  rectangle "BallerinaToAsyncApiGenerator" as toAsyncAPI
}

package "Output Artifacts" <<output>> {
  rectangle "Ballerina Client" as ballerinaClient
  rectangle "Ballerina Service" as ballerinaService
  rectangle "AsyncAPI Spec" as asyncapiOutput
}

package "CLI Interface" <<cli>> {
  rectangle "AsyncApiCmd" as cli
  rectangle "bal asyncapi" as balCommand
}

package "Testing" <<test>> {
  rectangle "Test Cases" as tests
  rectangle "Expected Outputs" as expected
}

asyncapi --> toBallerina
openapi --> toBallerina
toBallerina --> ballerinaClient
toBallerina --> ballerinaService

ballerinaService --> toAsyncAPI
toAsyncAPI --> asyncapiOutput

cli --> toBallerina
cli --> toAsyncAPI
balCommand --> cli

tests --> asyncapi
tests --> openapi
tests --> ballerinaClient
tests --> ballerinaService
tests --> asyncapiOutput
expected --> tests

note right of toBallerina
  Handles:
  - Data types
  - Authentication
  - WebSockets
  - Error handling
end note

note left of toAsyncAPI
  Reverse engineers:
  - Service definitions
  - Message schemas
  - Endpoints
end note
@enduml