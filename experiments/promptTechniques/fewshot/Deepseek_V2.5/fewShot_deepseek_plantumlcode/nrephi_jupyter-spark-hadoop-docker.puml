@startuml nrephi_jupyter-spark-hadoop-docker
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Jupyter Spark Cluster" {
  rectangle "JupyterLab" as jupyter #lightblue
  rectangle "Spark Master" as spark_master #orange
  rectangle "Spark Worker 1" as worker1 #orange
  rectangle "Spark Worker 2" as worker2 #orange
  rectangle "MySQL" as mysql #green

  jupyter --> spark_master : submits jobs
  spark_master --> worker1 : assigns tasks
  spark_master --> worker2 : assigns tasks
}

package "Hadoop Ecosystem" {
  rectangle "Hadoop NameNode" as namenode #pink
  rectangle "Hadoop DataNode" as datanode #pink
  rectangle "Hive Server" as hive_server #purple
  rectangle "Hive Metastore" as hive_metastore #purple
  rectangle "PostgreSQL" as postgres #green
  rectangle "Hue" as hue #yellow

  namenode --> datanode : manages HDFS
  hive_server --> hive_metastore : queries metadata
  hive_metastore --> postgres : stores metadata
  hue --> mysql : stores config
  hue --> namenode : interacts with HDFS
  hue --> hive_server : executes queries
}

jupyter --> namenode : reads/writes data
spark_master --> namenode : processes data
worker1 --> datanode : accesses data
worker2 --> datanode : accesses data

note right of jupyter
  Shared workspace volume
end note

note right of namenode
  Custom Docker network
  with fixed IPs
end note
@enduml