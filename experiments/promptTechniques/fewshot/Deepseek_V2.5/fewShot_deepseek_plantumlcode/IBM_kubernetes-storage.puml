@startuml IBM_kubernetes-storage
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Workshop Participant" as Participant

rectangle "Kubernetes Cluster" as K8s {
  rectangle "Guestbook App (Node.js)" as Guestbook
  rectangle "MongoDB" as MongoDB
  rectangle "StatefulSet" as StatefulSet
  rectangle "PersistentVolumeClaim" as PVC
  rectangle "ConfigMap" as ConfigMap
  rectangle "Secret" as Secret
}

rectangle "IBM Cloud Services" as IBMCloud {
  rectangle "IBM Cloud Object Storage" as COS
  rectangle "IBM Cloud Block Storage" as BlockStorage
}

rectangle "Workshop Resources" as Workshop {
  rectangle "MkDocs Documentation" as Docs
  rectangle "Lab Instructions" as Labs
  rectangle "YAML Files" as YAML
  rectangle "Helm Charts" as Helm
}

Participant --> Docs
Participant --> Labs
Participant --> YAML
Participant --> Helm

Guestbook --> MongoDB
Guestbook --> ConfigMap
Guestbook --> Secret
MongoDB --> StatefulSet
StatefulSet --> PVC

PVC --> BlockStorage
Guestbook --> COS : via s3fs

Helm --> K8s : Deploys MongoDB
YAML --> K8s : Applies configurations
@enduml