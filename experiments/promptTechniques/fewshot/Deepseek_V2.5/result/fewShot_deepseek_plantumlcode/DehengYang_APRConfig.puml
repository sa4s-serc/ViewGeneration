@startuml DehengYang_APRConfig
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as User

rectangle "APRConfig Framework" {
  rectangle "Dataset Handler" as DatasetHandler
  rectangle "Fault Localizer" as FaultLocalizer
  rectangle "Patch Generator" as PatchGenerator
  rectangle "Patch Validator" as PatchValidator
}

rectangle "External Tools" {
  rectangle "Gzoltar" as Gzoltar
  rectangle "SimFix" as SimFix
  rectangle "TBar" as TBar
  rectangle "Nopol" as Nopol
  rectangle "DynamoTH" as DynamoTH
}

database "Defects4J Benchmark" as Defects4J

User --> DatasetHandler
DatasetHandler --> Defects4J
DatasetHandler --> FaultLocalizer
FaultLocalizer --> Gzoltar
FaultLocalizer --> PatchGenerator
PatchGenerator --> SimFix
PatchGenerator --> TBar
PatchGenerator --> Nopol
PatchGenerator --> DynamoTH
PatchGenerator --> PatchValidator
PatchValidator --> Defects4J

note right of FaultLocalizer
  Uses Strategy Pattern for
  different localization algorithms
end note

note left of PatchGenerator
  Uses Factory Pattern for
  creating patch generation tools
end note
@enduml