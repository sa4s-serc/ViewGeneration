### Output:
@startuml ibm-hyperknowledge_hklib
left to right direction
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<data>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<utility>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Entity Layer" <<core>> {
  abstract class HKEntity
  class Node
  class Context
  class Link
  class Connector
  class Reference
  class Trail
  class HKGraph
  HKEntity <|-- Node
  HKEntity <|-- Context
  HKEntity <|-- Link
  HKEntity <|-- Connector
  HKEntity <|-- Reference
  HKEntity <|-- Trail
  HKGraph *-- HKEntity
}

package "Data Access Layer" <<data>> {
  class HKDatasource {
    +createRepository()
    +deleteRepository()
    +queryHyQL()
    +querySPARQL()
  }
  class ObserverClient
  class HKObserverFactory {
    +createObserver()
  }
  HKDatasource --> ObserverClient
  HKObserverFactory --> ObserverClient
}

package "Utility Layer" <<utility>> {
  class Hyperify {
    +toHKGraph()
  }
  class Deserializer {
    +fromJSON()
  }
  class GraphBuilder
  class FIHandler
}

package "External Integration" <<integration>> {
  class VirtualNode
  class VirtualContext
  class VirtualLink
  class ExternalSources
  Node <|-- VirtualNode
  Context <|-- VirtualContext
  Link <|-- VirtualLink
  VirtualNode --> ExternalSources
  VirtualContext --> ExternalSources
  VirtualLink --> ExternalSources
}

HKDatasource --> HKGraph
HKDatasource --> HKEntity
ObserverClient --> HKEntity
Hyperify --> HKGraph
Deserializer --> HKEntity
GraphBuilder --> HKEntity
FIHandler --> HKEntity
@enduml