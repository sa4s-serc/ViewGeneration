@startuml lowes_auditor
left to right direction
skinparam rectangle {
  BackgroundColor<<client>> #d9e7fd
  BackgroundColor<<core>> #d8f5d3
  BackgroundColor<<infra>> #fff1c9
  BackgroundColor<<storage>> #fddddd
  Style roundrect
}

package "Client Applications" <<client>> {
  rectangle "Spring Boot App" as springApp
  rectangle "Standalone App" as standaloneApp
  rectangle "Auditor Client API" as clientAPI
  springApp --> clientAPI
  standaloneApp --> clientAPI
}

package "Core Framework" <<core>> {
  rectangle "AuditEvent Mappers" as mappers
  rectangle "Filtering Strategies" as filters
  rectangle "Event Decorators" as decorators
  rectangle "Configuration" as config
}

package "Infrastructure" <<infra>> {
  rectangle "Kafka Producer" as kafkaProd
  rectangle "Kafka Consumer" as kafkaCons
  rectangle "Project Reactor" as reactor
}

package "Storage" <<storage>> {
  database "Elasticsearch" as es
}

clientAPI --> kafkaProd : "publish events"
kafkaProd --> kafkaCons : "event stream"
kafkaCons --> reactor : "async processing"
reactor --> mappers : "transform events"
mappers --> filters : "apply filters"
filters --> decorators : "add metadata"
decorators --> es : "persist events"

config --> clientAPI
config --> filters
config --> decorators
@enduml