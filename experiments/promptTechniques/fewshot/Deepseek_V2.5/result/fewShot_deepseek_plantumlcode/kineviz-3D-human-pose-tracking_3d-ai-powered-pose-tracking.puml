@startuml kineviz-3D-human-pose-tracking_3d-ai-powered-pose-tracking
skinparam backgroundColor #ffffff
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "Webcam Client 1" as WC1
actor "Webcam Client 2" as WC2
rectangle "Node.js Server" as Server {
    rectangle "Express.js" as Express
    rectangle "Socket.IO" as SocketIO
    rectangle "PoseNet/MoveNet" as PoseNet
}
rectangle "Receiver Client" as Receiver
rectangle "Kineviz GraphXR" as GraphXR

WC1 --> SocketIO : 2D Pose Data
WC2 --> SocketIO : 2D Pose Data
SocketIO --> PoseNet : Process 2D poses
PoseNet --> SocketIO : 3D Pose Reconstruction
SocketIO --> Receiver : Broadcast 3D Pose
SocketIO --> GraphXR : 3D Skeleton Visualization

Express -[hidden]-> SocketIO
SocketIO -[hidden]-> PoseNet

note right of Server
    HTTPS enabled
    Real-time bidirectional
    communication
end note
@enduml