### Output:
@startuml 23fa-cpsc490_canyough
left to right direction
skinparam rectangle {
  BackgroundColor<<service>> #d9e7fd
  BackgroundColor<<component>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<ml>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Services" <<service>> {
  rectangle "Product Mixer" as ProductMixer
  rectangle "Cr-Mixer" as CrMixer
  rectangle "Home Mixer" as HomeMixer
  rectangle "FRS" as FRS
}

package "Data Sources" <<data>> {
  rectangle "User Signal Service" as USS
  rectangle "Real Graph" as RealGraph
  rectangle "Earlybird" as Earlybird
  rectangle "TweetyPie" as TweetyPie
  rectangle "Manhattan" as Manhattan
  rectangle "Memcached" as Memcached
  rectangle "Strato" as Strato
}

package "ML Serving" <<ml>> {
  rectangle "Navi Serving" as Navi
}

package "Components" <<component>> {
  rectangle "Candidate Sources" as Sources
  rectangle "Feature Hydrators" as Hydrators
  rectangle "Filters" as Filters
  rectangle "Scorers" as Scorers
  rectangle "Transformers" as Transformers
}

ProductMixer --> CrMixer
ProductMixer --> HomeMixer
ProductMixer --> FRS

CrMixer --> Sources
CrMixer --> Hydrators
CrMixer --> Filters
CrMixer --> Scorers
CrMixer --> Transformers

HomeMixer --> Sources
HomeMixer --> Hydrators
HomeMixer --> Filters
HomeMixer --> Scorers
HomeMixer --> Transformers

FRS --> Sources
FRS --> Hydrators
FRS --> Filters
FRS --> Scorers
FRS --> Transformers

Sources --> USS
Sources --> RealGraph
Sources --> Earlybird
Sources --> TweetyPie

Hydrators --> Manhattan
Hydrators --> Memcached
Hydrators --> Strato

Scorers --> Navi
@enduml