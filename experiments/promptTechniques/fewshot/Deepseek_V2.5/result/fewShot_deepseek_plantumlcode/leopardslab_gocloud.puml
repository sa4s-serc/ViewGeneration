@startuml leopardslab_gocloud
left to right direction
skinparam rectangle {
  BackgroundColor<<interface>> #d9e7fd
  BackgroundColor<<impl>> #d8f5d3
  BackgroundColor<<cloud>> #fff1c9
  BackgroundColor<<client>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Client Applications" <<client>> {
  rectangle "Client Code"
}

package "GoCloud Library" {
  interface "Gocloud\nInterface" <<interface>> as Gocloud
  rectangle "CloudProvider\nFactory" as Factory
  rectangle "Auth\nModules" as Auth
}

package "Cloud Providers" <<cloud>> {
  rectangle "AWS"
  rectangle "Google Cloud"
  rectangle "Azure"
  rectangle "DigitalOcean"
  rectangle "AliCloud"
  rectangle "Vultr"
  rectangle "OpenStack"
  rectangle "Rackspace"
}

package "Service Implementations" <<impl>> {
  rectangle "Compute"
  rectangle "Storage"
  rectangle "Container"
  rectangle "DNS"
  rectangle "LoadBalancer"
  rectangle "Serverless"
  rectangle "Database"
  rectangle "ML"
  rectangle "Analytics"
  rectangle "Notifications"
  rectangle "Streaming"
}

"Client Code" --> Gocloud
Gocloud --> Factory
Factory --> "AWS"
Factory --> "Google Cloud"
Factory --> "Azure"
Factory --> "DigitalOcean"
Factory --> "AliCloud"
Factory --> "Vultr"
Factory --> "OpenStack"
Factory --> "Rackspace"

"Client Code" --> Auth

"AWS" --> "Compute"
"Google Cloud" --> "Container"
"Azure" --> "Storage"
"DigitalOcean" --> "DNS"
"AliCloud" --> "LoadBalancer"
"Vultr" --> "Compute"
"OpenStack" --> "Storage"
"Rackspace" --> "Compute"

note right of Gocloud
  Unified interface for all
  cloud provider operations
end note

note right of Factory
  Implements Factory pattern
  to create provider instances
end note
@enduml