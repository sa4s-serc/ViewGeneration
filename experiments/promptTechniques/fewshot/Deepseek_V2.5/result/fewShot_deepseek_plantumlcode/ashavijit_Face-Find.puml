@startuml
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as user

package "Frontend" <<frontend>> {
  rectangle "Bootstrap CSS/SCSS" as bootstrap
  rectangle "HTML Templates" as templates
  rectangle "Responsive UI" as ui
  bootstrap --> templates
  templates --> ui
}

package "Backend" <<backend>> {
  rectangle "Django Views" as views
  rectangle "Forms" as forms
  rectangle "Models" as models
  rectangle "Azure Face API\nIntegration" as azure
  views --> forms
  views --> models
  views --> azure
}

package "External Services" <<external>> {
  rectangle "Azure Face API" as faceapi
  rectangle "Email Service" as email
}

database "Database" <<db>> as db

user --> ui
ui --> views
models --> db
azure --> faceapi
views --> email
@enduml