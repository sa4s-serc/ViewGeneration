@startuml
skinparam rectangle {
  BackgroundColor<<azure>> #d9e7fd
  BackgroundColor<<onprem>> #d8f5d3
  BackgroundColor<<user>> #fff1c9
  BackgroundColor<<monitor>> #fddddd
  Style roundrect
}
left to right direction

actor "User" as User <<user>>

package "On-Premises" <<onprem>> {
  rectangle "Hyper-V VMs" as HyperV
}

package "Azure Cloud" <<azure>> {
  rectangle "Azure Migrate" as AzureMigrate
  rectangle "Azure VMs" as AzureVM
  rectangle "Azure Functions" as Functions
  rectangle "Cosmos DB" as CosmosDB
  rectangle "Blazor App" as Blazor
  rectangle "Azure Storage" as Storage
  rectangle "Azure Monitor" as Monitor
  rectangle "Log Analytics" as LogAnalytics
  rectangle "Application Insights" as AppInsights
  rectangle "Grafana" as Grafana
}

User --> HyperV : Assess
HyperV --> AzureMigrate : Replicate
AzureMigrate --> AzureVM : Migrate

User --> AzureVM : Configure\nVNet, Availability Sets
AzureVM --> Monitor : Send metrics
Functions --> CosmosDB : Data access
Blazor --> Storage : Deploy
Blazor --> Functions : API calls

Monitor --> LogAnalytics : Query logs
Monitor --> AppInsights : App telemetry
AppInsights --> Grafana : Visualize

note right of AzureMigrate
  Security: RBAC, Encryption
end note

note right of Functions
  Security: Managed Identity
end note

note right of CosmosDB
  Security: Firewall, Encryption
end note
@enduml