@startuml
skinparam rectangle {
  BackgroundColor<<questions>> #d9e7fd
  BackgroundColor<<docs>> #d8f5d3
  BackgroundColor<<principles>> #fff1c9
  BackgroundColor<<patterns>> #fddddd
  Style roundrect
}
left to right direction

rectangle "Flutter Interview\nPreparation" as root #white

package "Core Content" {
  rectangle "Interview Questions" as questions <<questions>> {
    [Software Development &\nArchitecture]
    [Dart Language]
    [Flutter Framework]
  }

  rectangle "Documentation" as docs <<docs>> {
    [flutter_internals.md]
    [dart_internals.md]
  }
}

package "Design Principles" as principles <<principles>> {
  [SOLID]
  [CUPID]
  [Clean Architecture]
}

package "Design Patterns" as patterns <<patterns>> {
  [Creational]
  [Structural]
  [Behavioral]
  [Dependency Injection]
}

root --> questions
root --> docs
questions --> principles
questions --> patterns

note right of questions
  Organized in README.md
  with categorized Q&A
end note

note right of docs
  Detailed technical
  explanations in
  separate markdown files
end note
@enduml