@startuml jquku_Matrix-Chatbot
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<database>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

actor "User" as User

rectangle "Matrix Homeserver" as Matrix <<external>>

package "Chatbot Core" <<backend>> {
  rectangle "Main Module" as Main
  rectangle "Message Evaluation" as MsgEval
  rectangle "Response Management" as ResponseMgmt
  rectangle "NLP Pipeline" as NLP
}

package "Knowledge Acquisition" <<backend>> {
  rectangle "Index Evaluation" as IndexEval
  rectangle "Small Talk Evaluation" as SmallTalkEval
  rectangle "Organisation Evaluation" as OrgEval
}

package "Database Services" <<backend>> {
  rectangle "Database Service" as DBService
}

database "PostgreSQL" as Postgres <<database>>

User -> Matrix : Sends message
Matrix -> Main : Receives event
Main -> MsgEval : Processes message
MsgEval -> NLP : Preprocesses text
NLP --> MsgEval : Cleaned text
MsgEval -> DBService : Queries knowledge
DBService -> Postgres : Executes query
Postgres --> DBService : Returns results
DBService --> MsgEval : Knowledge results
MsgEval -> ResponseMgmt : Prepares response
ResponseMgmt --> Main : Formatted response
Main -> Matrix : Sends response
Matrix -> User : Receives response

IndexEval -> DBService : Stores scraped data
SmallTalkEval -> DBService : Stores small talk
OrgEval -> DBService : Stores org info
@enduml