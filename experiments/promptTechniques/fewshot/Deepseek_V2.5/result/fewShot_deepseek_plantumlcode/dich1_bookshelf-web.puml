@startuml dich1_bookshelf-web
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "HTML/CSS" as HTML
  rectangle "JavaScript/jQuery" as JS
  rectangle "Vue.js (planned)" as Vue
  HTML --> JS
  JS --> Vue
}

package "Backend (Rails)" <<backend>> {
  rectangle "Controllers" as Controllers
  rectangle "Models" as Models
  rectangle "API" as API
  Controllers --> Models
  Controllers --> API
}

package "Integrations" <<integration>> {
  rectangle "Google Books API" as GoogleBooks
  rectangle "ISBN Scanner" as Scanner
  rectangle "Facebook Auth" as Facebook
  API --> GoogleBooks
  JS --> Scanner
  Controllers --> Facebook
}

package "Database" <<db>> {
  database "MySQL" as DB
  Models --> DB
}

package "Infrastructure" <<infra>> {
  rectangle "Docker" as Docker
  rectangle "Nginx" as Nginx
  rectangle "CircleCI" as CI
  Docker --> Nginx
  Docker --> DB
  CI --> Docker
}

HTML --> Controllers
JS --> API
@enduml