@startuml zoolhelmy_ESP8266-Weather-Station
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "ESP8266 NodeMCU" as ESP8266 {
  rectangle "Sensor Data\n(Temp, Humidity, etc.)" as Sensors
  rectangle "MQTT Publisher" as MQTTPub
  rectangle "HTTP Server" as HTTPServer
  Sensors --> MQTTPub
  Sensors --> HTTPServer
}

rectangle "OpenWRT Router" as OpenWRT {
  rectangle "Mosquitto MQTT\nSubscriber" as MQTTSub
  rectangle "Temporary\nData Files" as TempFiles
  rectangle "Collectd" as Collectd
  rectangle "RRDTool" as RRDTool
  rectangle "Cron Job" as Cron
  rectangle "GitHub Publisher" as GitHubPub
  MQTTSub --> TempFiles
  TempFiles --> Collectd
  Collectd --> RRDTool
  RRDTool --> Cron
  Cron --> GitHubPub
}

rectangle "ThingSpeak" as ThingSpeak {
  rectangle "MQTT Subscriber" as ThingSpeakSub
  rectangle "Cloud Storage" as CloudStorage
  ThingSpeakSub --> CloudStorage
}

rectangle "Local Network" as LocalNetwork {
  rectangle "Web Browser" as Browser
  Browser --> HTTPServer
}

ESP8266 --> MQTTSub : MQTT
ESP8266 --> ThingSpeakSub : MQTT
@enduml