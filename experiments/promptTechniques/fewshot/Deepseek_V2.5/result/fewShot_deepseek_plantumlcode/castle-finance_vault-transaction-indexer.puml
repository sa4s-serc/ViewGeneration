@startuml castle-finance_vault-transaction-indexer
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Solscan API" as Solscan

rectangle "AWS CDK" as CDK {
  rectangle "VaultTransactionIndexerStack" as Stack
}

rectangle "AWS Lambda" {
  rectangle "index-transaction-ids" as IndexLambda
  rectangle "download-raw-transaction" as DownloadLambda
  rectangle "normalize-raw-transaction" as NormalizeLambda
}

rectangle "AWS SNS" as SNS
rectangle "AWS SQS" as SQS
rectangle "AWS DynamoDB" {
  rectangle "Raw Transactions" as RawDB
  rectangle "Normalized Transactions" as NormalizedDB
}

rectangle "EventBridge Schedule" as EventBridge

Solscan --> IndexLambda : Fetch transaction IDs
IndexLambda --> SNS : Publish transaction hashes
SNS --> DownloadLambda : Fan-out messages
DownloadLambda --> SQS : Queue messages
SQS --> DownloadLambda : Consume messages
DownloadLambda --> Solscan : Fetch raw transaction
DownloadLambda --> RawDB : Store raw transaction
RawDB --> NormalizeLambda : Stream events
NormalizeLambda --> NormalizedDB : Store normalized data
EventBridge --> IndexLambda : Trigger periodic execution

Stack --> IndexLambda
Stack --> DownloadLambda
Stack --> NormalizeLambda
Stack --> SNS
Stack --> SQS
Stack --> RawDB
Stack --> NormalizedDB
Stack --> EventBridge
@enduml