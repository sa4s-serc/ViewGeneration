### Actual Output:
@startuml gpsnmeajp_VirtualMotionTracker
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core" {
  rectangle "Matrix/Vector\nOperations" as MatrixOps
  rectangle "Expression\nTemplates" as ExprTemplates
  rectangle "SIMD\nVectorization" as SIMD
  rectangle "Memory\nManagement" as Memory
  MatrixOps --> ExprTemplates
  ExprTemplates --> SIMD
  SIMD --> Memory
}

package "Modules" {
  rectangle "Dense" as Dense
  rectangle "Sparse" as Sparse
  rectangle "Geometry" as Geometry
  rectangle "Eigenvalues" as Eigenvalues
  rectangle "IterativeSolvers" as IterativeSolvers
  Dense --> MatrixOps
  Sparse --> MatrixOps
  Geometry --> MatrixOps
  Eigenvalues --> MatrixOps
  IterativeSolvers --> MatrixOps
}

package "External" {
  rectangle "BLAS/LAPACK" as BLAS
  rectangle "MKL/OpenBLAS" as MKL
  BLAS --> MKL
  MatrixOps --> BLAS
}

package "Unsupported" {
  rectangle "Tensor\nOperations" as Tensor
  rectangle "NonLinear\nOptimization" as NonLinear
  rectangle "Matrix\nFunctions" as MatrixFuncs
  Tensor --> MatrixOps
  NonLinear --> MatrixOps
  MatrixFuncs --> MatrixOps
}

package "User" {
  actor "Application"
  Application --> Dense
  Application --> Sparse
  Application --> Geometry
  Application --> Eigenvalues
  Application --> IterativeSolvers
  Application --> Tensor
  Application --> NonLinear
  Application --> MatrixFuncs
}

note right of ExprTemplates
  Enables compile-time
  optimization & operator fusion
end note

note right of SIMD
  SSE/AVX/NEON/AltiVec
  intrinsics for vectorization
end note

note right of Memory
  Aligned allocation
  for SIMD performance
end note
@enduml