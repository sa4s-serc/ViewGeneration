@startuml decentraland_catalyst
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<storage>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Client Applications" <<frontend>> {
  rectangle "DCL Client"
  rectangle "Third-Party Apps"
}

package "Content Server" <<backend>> {
  rectangle "API Endpoints" as API
  rectangle "Deployment Handler" as Deployment
  rectangle "Entity Manager" as EntityManager
  rectangle "Validation Engine" as Validation
  rectangle "Sync Manager" as SyncManager
  rectangle "Cache Manager" as Cache
  rectangle "Rate Limiter" as RateLimit
  rectangle "Metrics Collector" as Metrics

  API --> Deployment
  API --> EntityManager
  Deployment --> Validation
  EntityManager --> Cache
  SyncManager --> EntityManager
  API --> RateLimit
  API --> Metrics
}

package "External Services" <<integration>> {
  rectangle "The Graph" as Graph
  rectangle "Blockchain" as Blockchain
  rectangle "Third-Party Resolvers" as ThirdParty
}

package "Data Storage" <<db>> {
  database "PostgreSQL" as DB
  rectangle "Content Storage" as ContentStorage <<storage>>
}

DCL Client --> API
Third-Party Apps --> API

Deployment --> DB
EntityManager --> DB
SyncManager --> DB

EntityManager --> Graph
EntityManager --> Blockchain
EntityManager --> ThirdParty

Deployment --> ContentStorage
EntityManager --> ContentStorage

Validation --> Blockchain
Validation --> Graph
@enduml