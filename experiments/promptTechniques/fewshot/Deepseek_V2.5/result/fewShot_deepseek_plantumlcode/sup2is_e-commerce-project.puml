@startuml sup2is_e-commerce-project
left to right direction
skinparam rectangle {
  BackgroundColor<<gateway>> #d9e7fd
  BackgroundColor<<service>> #d8f5d3
  BackgroundColor<<infra>> #fff1c9
  BackgroundColor<<db>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "API Gateway\n(Zuul)" <<gateway>> as gateway {
  component "JWT Auth Filter" as jwtFilter
}

rectangle "Service Discovery\n(Eureka)" <<infra>> as eureka

package "Microservices" {
  rectangle "Member Service" <<service>> as memberService {
    component "Member Controller"
    component "Member Service"
  }
  
  rectangle "Order Service" <<service>> as orderService {
    component "Order Controller"
    component "Order Service"
  }
  
  rectangle "Product Service" <<service>> as productService {
    component "Product Controller"
    component "Product Service"
  }
  
  rectangle "Auth Service" <<service>> as authService {
    component "Auth Controller"
    component "Auth Service"
  }
}

package "Data Stores" {
  database "MySQL" <<db>> as mysql
  database "Redis" <<db>> as redis
  queue "Kafka" <<db>> as kafka
}

package "Monitoring" {
  rectangle "Zipkin" <<infra>> as zipkin
  rectangle "Sleuth" <<infra>> as sleuth
}

gateway --> eureka
memberService --> eureka
orderService --> eureka
productService --> eureka
authService --> eureka

gateway --> memberService : /members
gateway --> orderService : /orders
gateway --> productService : /products
gateway --> authService : /auth

orderService --> productService : Feign Client

memberService --> mysql
memberService --> redis
orderService --> mysql
productService --> mysql
productService --> redis
productService --> kafka

authService --> mysql

memberService --> zipkin
orderService --> zipkin
productService --> zipkin
authService --> zipkin

note right of kafka
  Async inventory updates
end note

note right of redis
  Caching for member info\nand product stock
end note
@enduml