@startuml eProsima_Integration-Service
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Middleware Systems" {
  rectangle "Fast DDS" as FastDDS
  rectangle "ROS 1" as ROS1
  rectangle "ROS 2" as ROS2
  rectangle "WebSocket" as WebSocket
  rectangle "FIWARE" as FIWARE
}

package "Integration Service Core" {
  rectangle "Configuration Parser" as ConfigParser
  rectangle "System Handles" as SystemHandles
  rectangle "Message Router" as MessageRouter
  rectangle "Service Mediator" as ServiceMediator
  rectangle "JSON-XTypes Converter" as JSONConverter
}

package "Data Formats" {
  rectangle "JSON" as JSON
  rectangle "DynamicData" as DynamicData
}

ConfigParser --> SystemHandles : creates
SystemHandles --> FastDDS : adapts
SystemHandles --> ROS1 : adapts
SystemHandles --> ROS2 : adapts
SystemHandles --> WebSocket : adapts
SystemHandles --> FIWARE : adapts

MessageRouter --> SystemHandles : routes messages
ServiceMediator --> SystemHandles : mediates services

JSONConverter --> JSON : converts to/from
JSONConverter --> DynamicData : converts to/from

SystemHandles --> JSONConverter : uses for\n data conversion
MessageRouter --> JSONConverter : uses for\n data conversion
ServiceMediator --> JSONConverter : uses for\n data conversion

note right of JSONConverter
  Uses modified nlohmann_json
  for JSON processing
end note
@enduml