```plantuml
@startuml alextanhongpin_node-rest
left to right direction
skinparam rectangle {
  BackgroundColor<<api>> #d9e7fd
  BackgroundColor<<service>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<config>> #fddddd
  BackgroundColor<<schema>> #ffefd5
  BackgroundColor<<helper>> #e0ffff
  Style roundrect
}
skinparam defaultTextAlignment center

package "NodeJS REST API" {
  rectangle "Express App" <<api>> {
    rectangle "Routing Layer" {
      [Route]
    }
    rectangle "Middleware" {
      [Express Middleware]
    }
  }

  rectangle "Food Service" <<service>> {
    rectangle "Model Layer" {
      [Model]
    }
    rectangle "Store Layer" {
      [Store]
    }
  }

  rectangle "Data Access" <<data>> {
    rectangle "MySQL Database" {
      [Database Connection]
    }
  }

  rectangle "Configuration" <<config>> {
    rectangle "Convict Config" {
      [Configuration]
    }
  }

  rectangle "Schema Validation" <<schema>> {
    rectangle "AJV Schemas" {
      [JSON Schemas]
    }
  }

  rectangle "Helper Functions" <<helper>> {
    rectangle "Response Helpers" {
      [Err]
      [Ok]
    }
  }

  rectangle "Testing" {
    [Mocha & Chai]
  }
}

[Route] --> [Model]
[Model] --> [Store]
[Store] --> [Database Connection]
[Configuration] --> [Express App]
[JSON Schemas] --> [Model]
[Err] --> [Express Middleware]
[Ok] --> [Express Middleware]
[Mocha & Chai] --> [Model]
[Mocha & Chai] --> [Store]
@enduml
```