```plantuml
@startuml Crazy0416_KnowledgeGraph

skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}

actor User

package "Knowledge Graph Visualization" {
  rectangle "Graph UI" as GraphUI
  rectangle "Graph Controller" as GraphController
  rectangle "Graph Model" as GraphModel
  rectangle "Graph Helper" as GraphHelper
  rectangle "Graph Router" as GraphRouter
  
  User --> GraphUI
  GraphUI --> GraphController
  GraphController --> GraphModel
  GraphController --> GraphHelper
  GraphRouter --> GraphModel
}

package "Materialize CSS" {
  rectangle "UI Components" as UIComponents
  rectangle "DOM Utilities" as DOMUtils
  rectangle "Animation (Anime.js)" as Animation
  rectangle "Sigma Plugins" as SigmaPlugins
  
  User --> UIComponents
  UIComponents --> DOMUtils
  UIComponents --> Animation
  UIComponents --> SigmaPlugins
}

package "Core Libraries" {
  rectangle "Redux" as Redux
  rectangle "Flatpickr" as Flatpickr
  
  User --> Redux
  User --> Flatpickr
  Redux --> "State Store"
  Flatpickr --> "Date Picker"
}

@enduml
```