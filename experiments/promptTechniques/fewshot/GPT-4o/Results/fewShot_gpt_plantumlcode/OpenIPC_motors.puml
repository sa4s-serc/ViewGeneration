```plantuml
@startuml OpenIPC_motors
skinparam rectangle {
  BackgroundColor #fff8dc
  BorderColor black
  Style roundrect
}
skinparam linetype ortho

actor "Camera Application" as App

package "Application Layer" {
  rectangle "Camera API" as CameraAPI
}

package "Daemon Layer" {
  rectangle "Motors Daemon" as MotorsDaemon
}

package "Driver Wrapper Layer" {
  rectangle "GPIO Driver Wrapper" as GPIOWrapper
  rectangle "I2C Driver Wrapper" as I2CWrapper
  rectangle "SPI Driver Wrapper" as SPIWrapper
  rectangle "UART Driver Wrapper" as UARTWrapper
}

package "Kernel Driver Layer" {
  rectangle "GPIO Kernel Driver" as GPIODriver
  rectangle "I2C Kernel Driver" as I2CDriver
  rectangle "SPI Kernel Driver" as SPIDriver
  rectangle "UART Kernel Driver" as UARTDriver
}

package "Hardware Layer" {
  rectangle "Motor Hardware" as MotorHardware
}

App --> CameraAPI
CameraAPI --> MotorsDaemon
MotorsDaemon --> GPIOWrapper
MotorsDaemon --> I2CWrapper
MotorsDaemon --> SPIWrapper
MotorsDaemon --> UARTWrapper

GPIOWrapper --> GPIODriver
I2CWrapper --> I2CDriver
SPIWrapper --> SPIDriver
UARTWrapper --> UARTDriver

GPIODriver --> MotorHardware
I2CDriver --> MotorHardware
SPIDriver --> MotorHardware
UARTDriver --> MotorHardware
@enduml
```