```plantuml
@startuml teamgram_teamgram-server
left to right direction
skinparam rectangle {
  BackgroundColor #dff0ff
  BorderColor black
  Style roundrect
}
skinparam component {
  BackgroundColor #f5f5f5
  BorderColor black
  Style rectangle
}
skinparam package {
  BackgroundColor #f0f8ff
  BorderColor black
  Style rectangle
}
skinparam ArrowColor Black
skinparam defaultTextAlignment center
skinparam linetype ortho

package "Teamgram Services" {
  rectangle "BFF (Backend for Frontend)" as BFF {
    component "BFF Messages" as BFFMsg
    component "BFF PrivacySettings" as BFFPrivacy
  }

  component "Message Service" as MsgService
  component "Chat Service" as ChatService
  component "User Service" as UserService
  component "AuthSession Service" as AuthService
  component "Code Service" as CodeService
  component "Media Service" as MediaService
  component "DFS Service" as DFSService
  component "Username Service" as UsernameService
  component "Dialog Service" as DialogService
  component "Updates Service" as UpdatesService
  component "ID Generation Service" as IDGenService
}

package "Infrastructure" {
  component "Kafka" as Kafka
  component "Redis" as Redis
  component "MySQL" as MySQL
  component "MinIO" as MinIO
  component "Etcd" as Etcd
}

package "External Libraries" {
  component "FFmpeg" as FFmpeg
}

BFFMsg --> MsgService
BFFPrivacy --> UserService

MsgService --> Kafka
MsgService --> Redis
MsgService --> MySQL

ChatService --> MySQL
ChatService --> Redis

UserService --> MySQL
UserService --> Redis

AuthService --> Redis
CodeService --> Redis

MediaService --> MinIO
MediaService --> FFmpeg

DFSService --> MinIO

UsernameService --> MySQL

DialogService --> MySQL

UpdatesService --> Kafka

IDGenService --> Redis

MsgService --> Etcd
ChatService --> Etcd
UserService --> Etcd
AuthService --> Etcd
MediaService --> Etcd
DFSService --> Etcd
UsernameService --> Etcd
DialogService --> Etcd
UpdatesService --> Etcd
IDGenService --> Etcd
@enduml
```