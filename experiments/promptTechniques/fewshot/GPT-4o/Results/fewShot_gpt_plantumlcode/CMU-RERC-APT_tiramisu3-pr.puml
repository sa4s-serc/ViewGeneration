```plantuml
@startuml CMU-RERC-APT_tiramisu3-pr
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}

actor "User" as user

package "Mobile App (Ionic & Angular)" {
  rectangle "Home Page" as HomePage
  rectangle "Route Page" as RoutePage
  rectangle "Stop Page" as StopPage
  rectangle "Alarm Service" as AlarmService
  rectangle "Fav Routes Service" as FavRoutesService
  rectangle "Fav Stops Service" as FavStopsService
  rectangle "Push Notifications" as PushNotifications
  rectangle "Local Notifications" as LocalNotifications

  user --> HomePage
  HomePage --> RoutePage
  HomePage --> StopPage
  HomePage --> AlarmService
  RoutePage --> FavRoutesService
  StopPage --> FavStopsService
  AlarmService --> PushNotifications
  AlarmService --> LocalNotifications
}

package "Frontend (Java)" {
  rectangle "SchedulesForLocationServlet" as SchedulesServlet
  rectangle "WriteFavRouteServlet" as WriteFavRoute
  rectangle "ReadFavRouteServlet" as ReadFavRoute
  rectangle "StatusLogServlet" as StatusLog
  rectangle "ButtonLogServlet" as ButtonLog
  rectangle "FocusLogServlet" as FocusLog

  MobileApp --> SchedulesServlet
  MobileApp --> WriteFavRoute
  MobileApp --> ReadFavRoute
  MobileApp --> StatusLog
  MobileApp --> ButtonLog
  MobileApp --> FocusLog
}

package "Backend (Java)" {
  rectangle "FeedGrabberPAAC" as FeedGrabberPAAC
  rectangle "FeedGrabberMTA" as FeedGrabberMTA
  rectangle "ObservationProcessor" as ObservationProcessor
  rectangle "DynamoCleaner" as DynamoCleaner
  rectangle "AlarmProcessor" as AlarmProcessor
  rectangle "AWSSendEmail" as AWSSendEmail

  FeedGrabberPAAC --> ObservationProcessor
  FeedGrabberMTA --> ObservationProcessor
  ObservationProcessor --> DynamoCleaner
  AlarmProcessor --> AWSSendEmail
}

package "Prediction Component (Python)" {
  rectangle "Route Prediction" as RoutePrediction

  MobileApp --> RoutePrediction
}

package "AWS Infrastructure" {
  database "DynamoDB" as DynamoDB
  rectangle "SQS" as SQS

  ObservationProcessor --> DynamoDB
  SchedulesServlet --> DynamoDB
  FeedGrabberPAAC --> SQS
  FeedGrabberMTA --> SQS
  SQS --> ObservationProcessor
}

database "Postgres" as Postgres
statusLog --> Postgres
buttonLog --> Postgres
focusLog --> Postgres
writeFavRoute --> Postgres
readFavRoute --> Postgres
@enduml
```