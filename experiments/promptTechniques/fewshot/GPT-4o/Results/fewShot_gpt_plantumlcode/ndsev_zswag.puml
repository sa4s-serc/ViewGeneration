```plantuml
@startuml ndsev_zswag
left to right direction

skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor #333333
  Style roundrect
}

actor User

package "Zswag Project" {
  package "OpenAPI Generation" {
    rectangle "zswag.gen\nCLI Tool" as ZswagGen #lightblue
  }

  package "Python Server" {
    rectangle "OAServer\n(Flask/Connexion)" as PythonServer #orange
  }

  package "Python Client" {
    rectangle "OAClient\nPython" as PythonClient #lightyellow
  }

  package "C++ Client" {
    rectangle "OAClient\nC++ (zswagcl)" as CppClient #lightgreen
    rectangle "HTTP Client Library\n(httpcl)" as HttpClientLib #lightgreen
    rectangle "Python Bindings\n(pyzswagcl)" as PyBindings #lightgreen
  }
}

User --> ZswagGen
ZswagGen --> PythonServer : Generate API Specs
User --> PythonClient
User --> CppClient
PythonClient --> PythonServer : REST API Calls
CppClient --> HttpClientLib : HTTP Requests
CppClient --> PythonServer : REST API Calls
HttpClientLib --> PythonServer : HTTP Communication
CppClient --> PyBindings : Python Integration
@enduml
```