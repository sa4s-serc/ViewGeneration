```plantuml
@startuml ZID-Automat_Controller-ZIDAutomat
left to right direction
skinparam rectangle {
  BackgroundColor #dff0ff
  BorderColor black
  Style roundrect
}

package "Hardware" {
  rectangle "ESP32\nMicrocontroller" as ESP32 #d8f5d3
  rectangle "QR Code Reader" as QRReader #fddddd
  rectangle "Electromagnets/Solenoids" as Solenoids #fddddd
  rectangle "I2C LCD Screen" as LCD #fddddd
  rectangle "NeoPixel LED Strip" as LED #fddddd
}

package "Software" {
  package "Main" {
    rectangle "main.py" as MainPy #fff1c9
    rectangle "Main123 Class" as MainClass #fff1c9
  }
  
  package "Borrow" {
    rectangle "BorrowM Class" as BorrowM #fff1c9
    rectangle "Eject Class" as EjectClass #fff1c9
  }
  
  package "API" {
    rectangle "Requests.py" as Requests #fff1c9
    rectangle "Requestsi Class" as Requestsi #fff1c9
  }
  
  package "Data Collection" {
    rectangle "DataCollect.py" as DataCollect #fff1c9
  }
  
  package "Libraries" {
    rectangle "mp_i2c_lcd1602.py" as I2C_Lib #fff1c9
  }
}

package "Configuration" {
  rectangle "Configuration.json" as ConfigJSON #fddddd
}

ESP32 --> QRReader : Serial Communication
ESP32 --> Solenoids : GPIO Control
ESP32 --> LCD : I2C Protocol
ESP32 --> LED : GPIO Control

MainPy --> MainClass
MainClass --> BorrowM
MainClass --> Requestsi
MainClass --> EjectClass
MainClass --> DataCollect

BorrowM --> QRReader
BorrowM --> EjectClass
BorrowM --> Requests

Requests --> Requestsi
DataCollect --> Requests

LCD --> I2C_Lib

MainClass --> ConfigJSON : Load Configuration
@enduml
```