```plantuml
@startuml gapfish_deployer
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "User" as user
actor "External API" as api

rectangle "Gapfish Deployer" as deployer {
    rectangle "CLI Tool\n(depctl)" as cli
    rectangle "Configuration\nManagement" as config
    rectangle "Deployment\nLogic" as deploy
    rectangle "Event Stream\nLogger" as logger
    rectangle "Plugin\nManagement" as plugins
}

rectangle "Kubernetes Cluster" as k8s {
    rectangle "kubectl" as kubectl
}

user -> cli : Trigger Deployment
cli -> config : Load Configurations
cli -> deploy : Initiate Deployment
deploy -> kubectl : Apply YAML
deploy -> logger : Log Deployment Status
deploy -> plugins : Execute Plugins
plugins -> api : External API Calls

@enduml
```