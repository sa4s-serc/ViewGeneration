```plantuml
@startuml libremfg_getting-started
skinparam backgroundColor #ffffff
skinparam rectangle {
  BackgroundColor #dff0ff
  BorderColor black
  Style roundrect
}
skinparam linetype ortho

package "Libre Core/Platform" {
  
  package "Deployment Environment" {
    rectangle "Docker Compose Setup" {
      rectangle "Dgraph" as Dgraph #orange
      rectangle "InfluxDB" as InfluxDB #orange
      rectangle "EMQX (MQTT Broker)" as EMQX #orange
      rectangle "Libre Platform Microservices" as Microservices #lightgreen
      rectangle "PackML Simulator" as PackML #orange
      rectangle "Grafana" as Grafana #orange
    }
  }
  
  package "Core Functionalities" {
    rectangle "Libre Core" as LibreCore #lightgreen
    rectangle "Libre Administration UI" as AdminUI #lightgreen
    rectangle "GraphQL API" as GraphQLAPI #lightgreen
    rectangle "Grafana Dashboards" as GrafanaDashboards #lightgreen
    rectangle "Workflow Engine" as WorkflowEngine #lightgreen
    rectangle "Data Provider Interface" as DataProvider #lightgreen
  }
  
  LibreCore --> AdminUI
  LibreCore --> GraphQLAPI
  LibreCore --> GrafanaDashboards
  LibreCore --> WorkflowEngine
  LibreCore --> DataProvider
  
  Dgraph --> GraphQLAPI
  InfluxDB --> GrafanaDashboards
  EMQX --> WorkflowEngine
  EMQX --> DataProvider
}

AdminUI <.. Microservices : Event-driven communication
GraphQLAPI <.. Microservices : GraphQL Federation

@enduml
```