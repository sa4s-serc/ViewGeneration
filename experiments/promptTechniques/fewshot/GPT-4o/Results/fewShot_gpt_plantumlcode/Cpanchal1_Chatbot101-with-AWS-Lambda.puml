```plantuml
@startuml Cpanchal1_Chatbot101-with-AWS-Lambda
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Webex User" as User

package "Webex Teams" {
  rectangle "Bot Mention\n(Event)" as Event #lightblue
  rectangle "Webhook" as Webhook #lightblue
}

package "AWS" {
  rectangle "API Gateway" as APIGateway #orange
  rectangle "Lambda Function\n(chatbot.py)" as Lambda #lightgreen
}

package "External APIs" {
  rectangle "icanhazdadjoke.com\nAPI" as JokeAPI #lightyellow
  rectangle "Webex Teams\nAPI" as TeamsAPI #lightyellow
}

User --> Event
Event --> Webhook
Webhook --> APIGateway
APIGateway --> Lambda

Lambda --> JokeAPI : getJoke()
JokeAPI --> Lambda : Joke Response

Lambda --> TeamsAPI : postJoke()
TeamsAPI --> "Webex Teams" : Post Message
@enduml
```