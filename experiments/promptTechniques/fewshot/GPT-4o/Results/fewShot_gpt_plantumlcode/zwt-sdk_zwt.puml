```plantuml
@startuml zwt-sdk_zwt
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}

package "ZWT Framework" {
  rectangle "ZwtComponent" as ZwtComponent #lightyellow
  rectangle "ZwtContainer" as ZwtContainer #lightyellow
  rectangle "ZwtFrame" as ZwtFrame #lightyellow
  rectangle "ZwtPanel" as ZwtPanel #lightyellow
  rectangle "ZwtLabel" as ZwtLabel #lightyellow
  rectangle "ZwtButton" as ZwtButton #lightyellow
  rectangle "ZwtGraphics" as ZwtGraphics #lightblue
  rectangle "ZwtKeyboard" as ZwtKeyboard #lightblue
  rectangle "ZwtLayout" as ZwtLayout #lightgreen
  rectangle "ZwtMenu" as ZwtMenu #lightcoral
  rectangle "ZwtMenuItem" as ZwtMenuItem #lightcoral
  rectangle "ZwtColor" as ZwtColor #lightgrey
  rectangle "ZwtFont" as ZwtFont #lightgrey
  rectangle "ZwtFloor" as ZwtFloor #lightpink
  rectangle "ZwtTransparentFloor" as ZwtTransparentFloor #lightpink
  rectangle "ZwtRoundFloor" as ZwtRoundFloor #lightpink
  rectangle "ZwtDrawing" as ZwtDrawing #lightyellow

  ZwtFrame --|> ZwtContainer
  ZwtPanel --|> ZwtContainer
  ZwtLabel --|> ZwtComponent
  ZwtButton --|> ZwtComponent

  ZwtMenu --|> ZwtContainer
  ZwtMenuItem --|> ZwtComponent

  ZwtFloor <|-- ZwtTransparentFloor
  ZwtFloor <|-- ZwtRoundFloor

  ZwtComponent --> ZwtGraphics
  ZwtComponent --> ZwtKeyboard
  ZwtContainer --> ZwtLayout
  ZwtComponent --> ZwtColor
  ZwtComponent --> ZwtFont
}
@enduml
