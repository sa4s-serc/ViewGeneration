```plantuml
@startuml NeuralDev-io_arclytics_simcct
left to right direction
skinparam rectangle {
  BackgroundColor #d9e7fd
  BorderColor black
  Style roundrect
}
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

package "Arclytics SimCCT" {
  package "Frontend (React)" {
    rectangle "Main App Component" as App
    rectangle "Redux Store" as Redux
    rectangle "Routers & Access Control" as Routers
    rectangle "UI Elements & Charts" as UIElements
    rectangle "API Helpers" as APIHelpers
  }

  package "Backend (Flask)" {
    rectangle "API Endpoints" as Endpoints
    rectangle "Auth Service" as AuthService
    rectangle "Data Models" as DataModels
    rectangle "JWT Middleware" as JWT
    rectangle "Celery Tasks" as CeleryTasks
    rectangle "Logging" as Logging
    rectangle "User Management" as UserManagement
  }

  package "Infrastructure" {
    rectangle "Docker" as Docker
    rectangle "Kubernetes" as Kubernetes
    rectangle "CI/CD (Bitbucket Pipelines)" as CICD
  }

  package "Data Persistence" {
    database "MongoDB" as MongoDB
    rectangle "Redis" as Redis
  }

  package "Analytics & Logging" {
    rectangle "Elastic APM" as ElasticAPM
    rectangle "Fluentd" as Fluentd
    rectangle "Elasticsearch & Kibana" as ESK
  }
}

App --> APIHelpers
App --> Redux
App --> Routers
App --> UIElements

Endpoints --> AuthService
Endpoints --> DataModels
Endpoints --> JWT
Endpoints --> CeleryTasks
Endpoints --> UserManagement
Endpoints --> Logging
AuthService --> JWT
DataModels --> MongoDB
CeleryTasks --> Redis
UserManagement --> MongoDB

Docker --> Kubernetes
Kubernetes --> CICD

Fluentd --> ESK
ElasticAPM --> ESK

@enduml
```