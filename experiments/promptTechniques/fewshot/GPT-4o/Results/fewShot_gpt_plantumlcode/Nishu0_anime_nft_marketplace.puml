```plantuml
@startuml Nishu0_anime_nft_marketplace
skinparam rectangle {
  BackgroundColor #f0f8ff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

actor User

package "Frontend (React/Next.js)" <<Frontend>> {
  rectangle "NFTContext API" as NFTContext #e6e6fa
  rectangle "UI Components" as UIComponents #e6e6fa
  rectangle "Pages" as Pages #e6e6fa
}

package "Blockchain (Ethereum/Polygon)" <<Blockchain>> {
  rectangle "NFT Smart Contract\n(NFTMarketplace.sol)" as SmartContract #d3d3d3
  database "IPFS" as IPFS #f5f5f5
}

package "Wallet Integration" <<Integration>> {
  rectangle "Metamask\n(web3modal, ethers.js)" as Metamask #d3d3d3
}

User --> UIComponents
UIComponents --> Pages
Pages --> NFTContext
NFTContext --> Metamask : Connect Wallet
NFTContext --> SmartContract : Interact with Contract
SmartContract --> IPFS : Store Metadata
@enduml
```