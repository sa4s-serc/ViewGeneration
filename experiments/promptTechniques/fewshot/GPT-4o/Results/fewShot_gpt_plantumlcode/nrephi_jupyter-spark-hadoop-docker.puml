```plantuml
@startuml nrephi_jupyter-spark-hadoop-docker
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Jupyter Spark Standalone Cluster" {
  rectangle "JupyterLab" as JupyterLab #lightblue

  rectangle "Spark Master" as SparkMaster #lightgreen
  rectangle "Spark Worker" as SparkWorker1 #lightgreen
  rectangle "Spark Worker" as SparkWorker2 #lightgreen

  rectangle "Hadoop NameNode" as HadoopNameNode #lightyellow
  rectangle "Hadoop DataNode" as HadoopDataNode #lightyellow

  rectangle "Hive Metastore\n(PostgreSQL)" as HiveMetastore #lightcoral
  rectangle "Hive Server" as HiveServer #lightcoral

  rectangle "Hue" as Hue #lightgray
  rectangle "MySQL (Hue Metadata)" as MySQL #lightgray
}

JupyterLab --> SparkMaster
SparkMaster --> SparkWorker1
SparkMaster --> SparkWorker2

HadoopNameNode --> HadoopDataNode

HiveServer --> HadoopNameNode
HiveMetastore --> HiveServer

Hue --> HadoopNameNode
Hue --> HiveServer
Hue --> MySQL

@enduml
```