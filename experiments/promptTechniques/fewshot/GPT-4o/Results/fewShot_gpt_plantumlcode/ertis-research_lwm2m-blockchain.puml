```plantuml
@startuml ertis-research_lwm2m-blockchain

skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor black
  Style roundrect
}

left to right direction

actor "User"

package "Anomaly Detection App" {
  rectangle "Angular Frontend" as AnomalyUI
  AnomalyUI --> [ClientService]
  AnomalyUI --> [AnomalyService]
  AnomalyUI --> [LoginService]
  AnomalyUI --> [AuthService]
}

package "Main App" {
  package "Spring Boot Backend" {
    rectangle "REST API" as RestAPI
    rectangle "ClientController" as ClientCtrl
    rectangle "AnomalyController" as AnomalyCtrl
    rectangle "LoginController" as LoginCtrl
    rectangle "UserController" as UserCtrl

    ClientCtrl --> RestAPI
    AnomalyCtrl --> RestAPI
    LoginCtrl --> RestAPI
    UserCtrl --> RestAPI

    rectangle "ClientService" as ClientServ
    rectangle "AnomalyService" as AnomalyServ
    rectangle "UserService" as UserServ
    rectangle "BlockchainService" as BlockchainServ

    ClientCtrl --> ClientServ
    AnomalyCtrl --> AnomalyServ
    LoginCtrl --> UserServ
    UserCtrl --> UserServ
    BlockchainServ --> [web3j]

    rectangle "Web3j Wrappers" as Wrappers
    BlockchainServ --> Wrappers
  }

  package "Angular Frontend" {
    rectangle "Management UI" as MgmtUI
    MgmtUI --> RestAPI
  }
}

package "Smart Contracts" {
  rectangle "UserStore.sol" as UserStore
  rectangle "ClientStore.sol" as ClientStore
  rectangle "AnomalyStore.sol" as AnomalyStore
  Wrappers --> UserStore
  Wrappers --> ClientStore
  Wrappers --> AnomalyStore
}

package "LwM2M Components" {
  rectangle "LwM2M Server" as LwM2MServer
  rectangle "Bootstrap Server" as BootstrapServer
  rectangle "LwM2M Client" as LwM2MClient

  LwM2MServer --> [Eclipse Leshan]
  BootstrapServer --> [Eclipse Leshan]
  LwM2MClient --> [Eclipse Leshan]

  [Eclipse Leshan] --> BlockchainServ
  BlockchainServ --> BootstrapServer
}

User --> AnomalyUI
User --> MgmtUI

@enduml
```