```plantuml
@startuml 2WAY_Design
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor black
  Style roundrect
}
left to right direction

package "Trust Network" {
  actor "Trusted Entity A" as EntityA
  actor "Trusted Entity B" as EntityB
  actor "Trusted Entity C" as EntityC
}

package "Data Exchange System" {
  rectangle "Private Data Exchange Service" as DataExchange #lightblue
  rectangle "Authorization Service" as AuthService #lightgreen
  rectangle "Authentication Service" as AuthnService #lightyellow
  rectangle "Trust Management Module" as TrustMgmt #lightcoral
}

EntityA -[#blue]-> DataExchange : Exchange Data
EntityB -[#blue]-> DataExchange : Exchange Data
EntityC -[#blue]-> DataExchange : Exchange Data

DataExchange -[#green]-> AuthService : Check Permissions
DataExchange -[#green]-> AuthnService : Authenticate Requests
DataExchange -[#red]-> TrustMgmt : Verify Trust

note right of DataExchange
  Secure private data exchange
end note
@enduml
```