```plantuml
@startuml geovanegodoi_MicroServicesPOC
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam linetype ortho
left to right direction

actor User

package "Microservices" {
  rectangle "Catalog Service" as Catalog #lightblue
  rectangle "Customer Service" as Customer #lightgreen
  rectangle "Order Service" as Order #lightyellow
}

package "Event Bus" {
  rectangle "RabbitMQ\n(MassTransit)" as RabbitMQ #lightgrey
}

package "Databases" {
  database "MongoDB\nCatalog" as MongoCatalog #ffcc99
  database "MongoDB\nCustomer" as MongoCustomer #ffcc99
  database "MongoDB\nOrder" as MongoOrder #ffcc99
}

User --> Catalog : Manage Items
User --> Customer : Manage Customers
User --> Order : Manage Orders

Catalog --> RabbitMQ : Publish Events
Customer --> RabbitMQ : Publish Events
Order --> RabbitMQ : Publish Events

RabbitMQ --> Catalog : Consume Events
RabbitMQ --> Customer : Consume Events
RabbitMQ --> Order : Consume Events

Catalog --> MongoCatalog : CRUD Operations
Customer --> MongoCustomer : CRUD Operations
Order --> MongoOrder : CRUD Operations
@enduml
```