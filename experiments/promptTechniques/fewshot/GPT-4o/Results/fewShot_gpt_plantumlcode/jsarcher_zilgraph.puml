```plantuml
@startuml jsarcher_zilgraph
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Data Acquisition" {
  rectangle "Zilcrawler\n(zilcrawl.py)" as Zilcrawler #orange
  rectangle "Zilliqa Blockchain" as Zilliqa #lightgrey
}

package "Data Storage" {
  database "Elasticsearch" as ES #lightblue
  database "MongoDB" as MongoDB #lightblue
}

package "Data Aggregation & Processing" {
  rectangle "Zilswap\n(zilswap.py)" as Zilswap #lightgreen
  rectangle "Aggregator Classes" as Aggregator #lightgreen
}

package "Frontend Visualization" {
  rectangle "Bokeh Charts" as Bokeh #lightyellow
  rectangle "Kibana Dashboards" as Kibana #lightyellow
  rectangle "Zilgraph Dashboard\n(main.py)" as ZilgraphDashboard #lightyellow
}

package "Deployment & Proxy" {
  rectangle "Nginx Reverse Proxy" as Nginx #lightcoral
}

Zilliqa --> Zilcrawler : Fetch Data
Zilcrawler --> ES : Store Raw Data
Aggregator --> ES : Query Data
Aggregator --> MongoDB : Store Aggregated Data
Zilswap --> Zilliqa : Interact with Blockchain
Zilswap --> Aggregator
Bokeh --> MongoDB : Fetch Data
Kibana --> ES : Fetch Data
ZilgraphDashboard --> Bokeh
ZilgraphDashboard --> Kibana
ZilgraphDashboard --> Nginx
Nginx --> ZilgraphDashboard : Proxy & SSL
@enduml
```