```plantuml
@startuml bianjieai_tibc
left to right direction
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor black
  Style roundrect
}

package "TIBC Protocol" {
  rectangle "Core Protocol" {
    rectangle "Transport Layer"
    rectangle "Authentication Layer"
    rectangle "Ordering Layer"
  }

  package "Components" {
    rectangle "Client Semantics (TICS-002)"
    rectangle "Port & Packet Semantics (TICS-004)"
    rectangle "Host Environments (TICS-024)"
    rectangle "Packet Routing (TICS-026)"
  }
}

package "Client Implementations" {
  rectangle "Tendermint Client (TICS-007)"
  rectangle "BSC Client (TICS-008)"
  rectangle "Ethereum Client (TICS-009)"
}

package "Relayer Algorithms" {
  rectangle "Packet Relay Logic"
  rectangle "Header Update Mechanisms"
  rectangle "Error Handling"
  rectangle "Incentivization"
}

package "Applications" {
  rectangle "NFT Transfer Application (TICS-030)"
}

rectangle "Routing Module"

' Connections
"Core Protocol" --> "Components"
"Components" --> "Client Implementations"
"Client Implementations" --> "Relayer Algorithms"
"Relayer Algorithms" --> "Routing Module"
"Routing Module" --> "Applications"

@enduml
