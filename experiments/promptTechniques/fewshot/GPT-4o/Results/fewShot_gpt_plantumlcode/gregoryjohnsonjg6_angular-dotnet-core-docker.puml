```plantuml
@startuml gregoryjohnsonjg6_angular-dotnet-core-docker
left to right direction
skinparam rectangle {
  BackgroundColor #d9e7fd
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "User Interaction" {
  actor "User"
  rectangle "Angular Frontend" as Frontend
  Frontend --> "API Gateway (NGINX)"
}

package "API Layer" {
  rectangle "API Gateway (NGINX)" as APIGateway
  rectangle "ASP.NET Core Web API" as WebAPI
  APIGateway --> WebAPI
}

package "Application Logic" {
  rectangle "CQRS & MediatR\n(Application Layer)" as CQRS
  WebAPI --> CQRS
}

package "Domain & Data" {
  rectangle "Domain Entities\n(Domain Layer)" as Domain
  rectangle "Infrastructure.Persistence\n(Repository Pattern)" as Persistence
  rectangle "Infrastructure.Identity\n(Authentication & Authorization)" as Identity
  CQRS --> Domain
  CQRS --> Persistence
  CQRS --> Identity
}

database "PostgreSQL" as PostgreSQL
Persistence --> PostgreSQL

package "Containerization & Orchestration" {
  rectangle "Docker & Docker Compose" as Docker
  Docker -- APIGateway
  Docker -- Frontend
  Docker -- WebAPI
  Docker -- PostgreSQL
}

@enduml
```