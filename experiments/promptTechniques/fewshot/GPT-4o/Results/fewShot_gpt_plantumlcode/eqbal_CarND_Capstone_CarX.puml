```plantuml
@startuml eqbal_CarND_Capstone_CarX
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "Udacity Simulator" as Simulator
actor "CARLA" as RealCar

package "Perception" {
  component "Traffic Light Detection" as TrafficLightDetection
  component "Camera Info Publisher" as CameraInfo
}

package "Planning" {
  component "Waypoint Loader" as WaypointLoader
  component "Waypoint Updater" as WaypointUpdater
  component "Waypoint Follower" as WaypointFollower
}

package "Control" {
  component "DBW Node" as DBWNode
  component "PID Controller" as PIDController
  component "Yaw Controller" as YawController
  component "LowPass Filter" as LowPassFilter
}

package "Infrastructure" {
  component "Bridge Node" as BridgeNode
}

package "Visualization" {
  component "RVIZ" as RVIZ
}

Simulator --> BridgeNode
RealCar --> DBWNode

BridgeNode --> TrafficLightDetection
BridgeNode --> WaypointLoader

TrafficLightDetection --> CameraInfo
WaypointLoader --> WaypointUpdater
WaypointUpdater --> WaypointFollower
WaypointFollower --> DBWNode

DBWNode --> PIDController
DBWNode --> YawController
DBWNode --> LowPassFilter

RVIZ --> TrafficLightDetection
RVIZ --> WaypointUpdater
RVIZ --> DBWNode

note right of TrafficLightDetection
  Classifies traffic light states
end note

note right of WaypointUpdater
  Adjusts waypoint velocities
end note

note right of DBWNode
  Controls actuators based on velocities
end note
@enduml
```