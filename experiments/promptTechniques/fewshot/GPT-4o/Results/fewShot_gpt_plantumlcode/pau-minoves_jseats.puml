```plantuml
@startuml pau-minoves_jseats

skinparam componentStyle rectangle
skinparam ArrowColor #000000

actor User

package "CLI" {
  rectangle "SeatAllocatorLauncher"
}

package "Core" {
  rectangle "SeatAllocatorProcessor" as Processor
  rectangle "ProcessorConfig" as Config
  rectangle "SeatAllocatorResolver" as Resolver
  rectangle "Candidate" as Candidate
  rectangle "Tally" as Tally
  rectangle "Result" as Result
}

package "Model" {
  rectangle "SeatAllocationMethod" as Method
  rectangle "TallyFilter" as Filter
  rectangle "ResultDecorator" as Decorator
  rectangle "TieBreaker" as TieBreaker
}

package "XML Serialization" {
  rectangle "JAXB"
}

package "Logging" {
  rectangle "SLF4J/Logback"
}

User --> "SeatAllocatorLauncher" : Execute CLI

"SeatAllocatorLauncher" -> Processor : Initialize

Processor -> Config : Load Configuration
Config -> JAXB : Deserialize XML

Processor -> Resolver : Resolve Components
Resolver -> Method : Resolve Method
Resolver -> Filter : Resolve Filter
Resolver -> Decorator : Resolve Decorator
Resolver -> TieBreaker : Resolve Tie Breaker

Processor -> Tally : Process Tally
Tally -> Candidate : Aggregate Votes

Processor -> Method : Execute Allocation
Processor -> Filter : Apply Filters
Processor -> Decorator : Apply Decorators
Processor -> TieBreaker : Resolve Ties

Processor -> Result : Generate Result

Processor -> SLF4J/Logback : Log Output

@enduml
```