```plantuml
@startuml dich1_bookshelf-web
left to right direction
skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor #333333
  Style roundrect
}
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

package "Frontend (HTML + JS + jQuery)" {
  rectangle "HTML Templates" as HTML
  rectangle "Static Assets\n(CSS, JS, Images)" as Static
  rectangle "jQuery UI\nComponents" as jQueryUI
  rectangle "Barcode Scanning\nModule" as Barcode
}

package "Backend (Rails)" {
  rectangle "Controllers" as Controllers
  rectangle "Models\n(ActiveRecord)" as Models
  rectangle "Views" as Views
  rectangle "REST API" as API
  rectangle "Devise Auth\n(OmniAuth + Facebook)" as Auth
}

package "Database" {
  database "MySQL" as MySQL
}

package "Deployment & CI/CD" {
  rectangle "Docker +\nDocker Compose" as Docker
  rectangle "Capistrano" as Capistrano
  rectangle "CircleCI" as CircleCI
}

HTML --> jQueryUI
HTML --> Barcode
HTML --> Static

Controllers --> Models
Controllers --> Views
Controllers --> API
Controllers --> Auth

Models --> MySQL
API --> MySQL

Docker --> Capistrano
Docker --> CircleCI

@enduml
```