@startuml inIT-HF_gr-corrsounder
skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
skinparam linetype ortho

package "GNU Radio Integration" {
  rectangle "GRC XML\nBlock Descriptions" as GRC
  rectangle "C++ Signal Processing Blocks" as CPPBlocks
  rectangle "SWIG Python Bindings" as SWIG
  rectangle "Python Module Definitions" as PythonDefs

  GRC --> CPPBlocks : Custom Blocks
  CPPBlocks --> SWIG : Bindings
  SWIG --> PythonDefs : Python Wrappers
}

package "Standalone Utilities" {
  rectangle "pycorrsounder" as PyCorrsounder
  rectangle "Unit Tests" as UnitTests
  rectangle "Example Flowgraphs" as Examples

  PyCorrsounder --> UnitTests : Validate
  PyCorrsounder --> Examples : Demonstrate
}

package "Documentation" {
  rectangle "Doxygen XML\nDocumentation" as DoxyXML
  rectangle "Documentation Parsing" as DocParsing

  DoxyXML --> DocParsing : Parse
}

package "General Architecture" {
  rectangle "Channel Sounding\nBlocks" as SoundingBlocks
  rectangle "Overflow Detection\n& Handling" as OverflowHandling

  SoundingBlocks --> OverflowHandling : Uses
}

rectangle "GNU Radio\nFramework" as GNU_Radio

GNU_Radio --> GRC : Integration
PythonDefs --> GNU_Radio : Integration

@enduml
