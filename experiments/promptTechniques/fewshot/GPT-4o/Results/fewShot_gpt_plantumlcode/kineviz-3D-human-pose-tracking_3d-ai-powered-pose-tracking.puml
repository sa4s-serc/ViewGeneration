```plantuml
@startuml kineviz-3D-human-pose-tracking_3d-ai-powered-pose-tracking
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Webcam Client 1"
actor "Webcam Client 2"

rectangle "Node.js Server" as Server #lightblue {
  rectangle "Express.js\n(Server Setup)" as Express
  rectangle "Socket.IO\n(Real-time Communication)" as SocketIO
  rectangle "Pose Data\nBroadcast" as DataBroadcast
}

rectangle "TensorFlow.js\n(Pose Estimation)" as TensorFlow #lightgreen {
  rectangle "PoseNet / MoveNet\nModel" as Models
}

rectangle "Receiver Application" as Receiver #lightyellow

rectangle "Kineviz GraphXR" as GraphXR #lightcoral {
  rectangle "3D Skeleton\nVisualization" as Visualization
}

' Webcam Clients interact with TensorFlow.js for pose estimation
Webcam Client 1 --> Models : Stream Video
Webcam Client 2 --> Models : Stream Video

' Server setup and real-time communication
Models --> SocketIO : Send 2D Pose Data
SocketIO --> Server
SocketIO --> DataBroadcast

' Broadcasting and visualization
DataBroadcast --> Receiver : Transmit 3D Pose Data
Receiver --> GraphXR : Forward Data
GraphXR --> Visualization : Render 3D Skeleton

' Middleware and server setup
Express --> SocketIO

@enduml
```