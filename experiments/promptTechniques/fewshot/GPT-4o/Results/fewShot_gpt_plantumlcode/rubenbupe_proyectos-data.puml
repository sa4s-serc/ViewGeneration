```plantuml
@startuml rubenbupe_proyectos-data
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Frontend (Next.js)" {
  rectangle "React Components" as React
  rectangle "TensorFlow.js" as TFJS
  React --> TFJS
}

package "API (Python Flask)" {
  rectangle "Image Segmentation" as Segmentation
  rectangle "Location Registration" as Location
  rectangle "Geospatial Search" as GeoSearch
  rectangle "WebSocket Communication" as WebSocket
  Segmentation --> WebSocket
}

package "Metrics API (Node.js)" {
  rectangle "Metrics Collection" as Metrics
  rectangle "Data Aggregation" as Aggregation
}

package "Infrastructure" {
  rectangle "RabbitMQ" as RabbitMQ
  rectangle "MongoDB" as MongoDB
  rectangle "Kubernetes" as Kubernetes
  rectangle "cert-manager" as CertManager
}

actor "User"

User --> React
React --> Segmentation : Upload Image
React --> Location : Register Location
React --> GeoSearch : Search Location

Segmentation --> RabbitMQ : Publish Events
Location --> RabbitMQ : Publish Events
GeoSearch --> RabbitMQ : Publish Events

RabbitMQ --> Metrics : Consume Events
Metrics --> Aggregation : Aggregate Data

Metrics --> MongoDB : Store Metrics
Segmentation --> MongoDB : Store Data
Location --> MongoDB : Store Data
GeoSearch --> MongoDB : Store Data

Kubernetes --> RabbitMQ : Manage Deployment
Kubernetes --> MongoDB : Manage Deployment

CertManager --> Kubernetes : Manage Certificates

CertManager --> Kubernetes : CRD-based Extension
@enduml
```