```plantuml
@startuml danielfm_prometheus-for-developers
skinparam rectangle {
  BackgroundColor #f7f7f7
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Docker Environment" {
  rectangle "Sample Node.js App" as NodeApp #lightblue {
    rectangle "/metrics Endpoint" as MetricsEndpoint
  }

  rectangle "Prometheus" as Prometheus #orange {
    rectangle "Scrape Targets\n(prometheus.yml)" as ScrapeTargets
    rectangle "Rules\n(prometheus.rules.yml)" as Rules
  }

  rectangle "Alertmanager" as Alertmanager #lightcoral {
    rectangle "Alert Rules\n(prometheus.rules.yml)" as AlertRules
  }

  rectangle "Grafana" as Grafana #lightgreen {
    rectangle "Dashboards\n(dashboard-providers.yml)" as Dashboards
    rectangle "Data Source\n(datasource.yml)" as DataSource
  }

  NodeApp --> MetricsEndpoint
  MetricsEndpoint <-- Prometheus : Scrape
  Prometheus --> Alertmanager : Alert Rules
  Prometheus --> Grafana : Data Source
  Alertmanager --> User : Alert Notifications
  Grafana --> User : Visualizations
}

note right of Prometheus
  Pull-based model
  for metric collection
end note

note right of Alertmanager
  Alert deduplication,
  grouping, and routing
end note

note right of Grafana
  Visualization of
  metrics data
end note

@enduml
```