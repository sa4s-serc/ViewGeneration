```plantuml
@startuml laziestcoder_Budget_App_JS
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction
actor User

rectangle "Budget App" {
  rectangle "UIController" as UIController #d9e7fd {
    UIController -> UIController : getInputValues()
    UIController -> UIController : addListItem()
    UIController -> UIController : clearFields()
    UIController -> UIController : displayBudget()
  }

  rectangle "BudgetController" as BudgetController #d8f5d3 {
    BudgetController -> BudgetController : addItem(type, desc, val)
    BudgetController -> BudgetController : calculateBudget()
    BudgetController -> BudgetController : calculatePercentages()
    BudgetController -> BudgetController : getBudget()
  }

  rectangle "Controller" as Controller #fddddd {
    Controller -> UIController : getInputValues()
    Controller -> BudgetController : addItem(type, desc, val)
    Controller -> BudgetController : calculateBudget()
    Controller -> BudgetController : getBudget()
    Controller -> UIController : displayBudget()
    Controller -> UIController : addListItem()
    Controller -> UIController : clearFields()
  }
}

User -> UIController : Input Income/Expense
UIController -> Controller : onAddItem()
@enduml
