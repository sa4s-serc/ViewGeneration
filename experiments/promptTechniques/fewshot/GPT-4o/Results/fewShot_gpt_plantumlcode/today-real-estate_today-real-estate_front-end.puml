```plantuml
@startuml today-real-estate_today-real-estate_front-end
left to right direction

skinparam rectangle {
  BackgroundColor #d9e7fd
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
skinparam linetype ortho

package "Vue.js App" {
  rectangle "Vue Router" as Router
  rectangle "Vuex Store" as Store
  rectangle "Axios" as Axios

  package "Components" {
    rectangle "Header" as Header
    rectangle "Footer" as Footer
    rectangle "LoginForm" as LoginForm
    rectangle "SignupForm" as SignupForm
    rectangle "KakaoMap" as KakaoMap
    rectangle "AptItem" as AptItem
  }

  package "Views" {
    rectangle "MainPage" as MainPage
    rectangle "LoginPage" as LoginPage
    rectangle "SearchPage" as SearchPage
    rectangle "AccountLikedPage" as AccountLikedPage
  }

  package "API" {
    rectangle "Auth API" as AuthAPI
    rectangle "User API" as UserAPI
    rectangle "Search API" as SearchAPI
    rectangle "News API" as NewsAPI
    rectangle "Inquiry API" as InquiryAPI
  }

  package "Utils" {
    rectangle "Cookie Management" as Cookies
    rectangle "Event Bus" as EventBus
    rectangle "Data Formatting" as Filters
  }
}

MainPage --> Router
LoginPage --> Router
SearchPage --> Router
AccountLikedPage --> Router

Router --> Header
Router --> Footer

Header --> EventBus
Footer --> EventBus
LoginForm --> EventBus
SignupForm --> EventBus

LoginForm --> AuthAPI
SignupForm --> AuthAPI
MainPage --> SearchAPI
SearchPage --> SearchAPI
AccountLikedPage --> UserAPI

KakaoMap --> SearchAPI
AptItem --> SearchAPI

Axios --> AuthAPI
Axios --> UserAPI
Axios --> SearchAPI
Axios --> NewsAPI
Axios --> InquiryAPI

Store --> Axios
Store --> Cookies

@enduml
