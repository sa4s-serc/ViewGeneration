```plantuml
@startuml YashwantChauhan_SDL
left to right direction
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor black
  Style roundrect
}

actor User

package "Web Interface" {
  rectangle "Login/Signup Page" as LoginPage
  rectangle "Upload Page" as UploadPage
  rectangle "Results Page" as ResultsPage
  rectangle "Recommendations Page" as RecommendationsPage
}

package "Django Application" {
  rectangle "Views" as Views
  rectangle "Models" as Models
  rectangle "Templates" as Templates
  rectangle "Static Files" as StaticFiles
}

package "IDS Logic" {
  rectangle "Random Forest Classifier" as RFC
  rectangle "Traffic Analysis" as TrafficAnalysis
}

package "CI/CD & Deployment" {
  rectangle "Jenkins Pipeline" as Jenkins
  rectangle "Heroku Deployment" as Heroku
}

User --> LoginPage
User --> UploadPage
User --> ResultsPage
User --> RecommendationsPage

LoginPage --> Views
UploadPage --> Views
ResultsPage --> Views
RecommendationsPage --> Views

Views --> Models
Views --> Templates
Views --> RFC
Views --> TrafficAnalysis

Models --> RFC
Models --> TrafficAnalysis

RFC --> TrafficAnalysis

Views --> StaticFiles
StaticFiles --> Templates

Jenkins --> Heroku
@enduml
```