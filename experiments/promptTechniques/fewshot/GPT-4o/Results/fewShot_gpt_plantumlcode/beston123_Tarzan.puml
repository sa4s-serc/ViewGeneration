```plantuml
@startuml beston123_Tarzan
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Client" as Client

package "Tarzan System" {
  rectangle "Server" as Server <<Server>> {
    rectangle "ConfigManager"
    rectangle "ScheduledServiceManager"
    rectangle "MessageResendService"
    rectangle "ServerController"
  }

  rectangle "Client" as ClientModule <<Client>> {
    rectangle "TransactionLifecycle"
  }

  rectangle "Registry (Zookeeper)" as Registry <<Registry>> {
    rectangle "ServiceDiscovery"
    rectangle "Configuration"
  }

  rectangle "Message Broker (RocketMQ)" as MessageBroker <<Message Broker>> {
    rectangle "MessageNotifier"
    rectangle "TransactionChecker"
  }

  rectangle "RPC (Netty)" as RPC <<RPC>> {
    rectangle "RpcClient"
    rectangle "RpcServer"
  }

  rectangle "Store" as Store <<Store>> {
    rectangle "DataModel"
    rectangle "DataAccess"
    rectangle "ServiceLayer"
  }

  rectangle "Cluster" as Cluster <<Cluster>> {
    rectangle "LoadBalancing"
    rectangle "Clustering"
  }
}

Client --> ClientModule
ClientModule --> MessageBroker : Send/Receive Messages
ClientModule --> Store : Persist/Query
ClientModule --> Registry : Service Discovery

Server --> Registry : Register Services
Server --> MessageBroker : Manage Transactions
Server --> Store : Data Operations
Server <--> RPC : Communication
Server --> Cluster : Load Balancing

Registry --> MessageBroker : Configuration Management
Registry --> Store : Configuration Management

MessageBroker --> Store : Persist Transaction States
MessageBroker --> RPC : Notify Transactions

Store --> RPC : Query Data
Store --> Cluster : Manage Data

Cluster --> MessageBroker : Load Balance

@enduml
```