```plantuml
@startuml mbotarro_unijobs
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}

package "Frontend (React Native)" {
  rectangle "User Authentication" as Auth
  rectangle "Offer/Request Feed" as Feed
  rectangle "Offer/Request Creation" as Creation
  rectangle "User Profiles" as Profiles
  rectangle "Navigation" as Navigation
  rectangle "UI Design" as UI
  rectangle "Interest Matching" as Matching

  Auth --> Feed
  Feed --> Creation
  Creation --> Profiles
  Navigation --> Feed
  UI --> Feed
  Matching --> Feed
}

package "Backend (Go)" {
  rectangle "RESTful API" as API
  database "PostgreSQL" as Postgres
  rectangle "Elasticsearch" as Elastic
  rectangle "Data Abstraction Layer" as DAL
  rectangle "Business Logic" as Business

  API --> DAL
  DAL --> Postgres
  API --> Elastic
  API --> Business
}

rectangle "Docker Compose" as Docker #lightgrey

Frontend --> API
Docker --> Postgres
Docker --> Elastic
@enduml
```