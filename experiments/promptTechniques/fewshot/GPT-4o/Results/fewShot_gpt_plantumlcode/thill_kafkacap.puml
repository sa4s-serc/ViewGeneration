```plantuml
@startuml thill_kafkacap
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "Message Source" as Source

package "KafkaCap" {
    rectangle "Capture Devices" as CaptureDevices {
        rectangle "AeronCaptureDevice" as Aeron
        rectangle "MulticastCaptureDevice" as Multicast
        rectangle "WebsocketCaptureDevice" as Websocket
    }
    
    rectangle "Deduplicator" as Deduplicator {
        rectangle "DedupStrategy" as DedupStrategy
        rectangle "CaptureQueue" as CaptureQueue
        rectangle "RecordPopulator" as RecordPopulator
        rectangle "RecoveryService" as RecoveryService
    }
    
    rectangle "Buffered Publisher" as BufferedPublisher
}

cloud "Kafka" as Kafka {
    rectangle "Capture Topics" as CaptureTopics
    rectangle "Outbound Topic" as OutboundTopic
}

Source --> Aeron
Source --> Multicast
Source --> Websocket

Aeron --> CaptureTopics
Multicast --> CaptureTopics
Websocket --> CaptureTopics

CaptureTopics --> Deduplicator

Deduplicator --> DedupStrategy
Deduplicator --> CaptureQueue
Deduplicator --> RecordPopulator
Deduplicator --> RecoveryService

Deduplicator --> BufferedPublisher
BufferedPublisher --> OutboundTopic
@enduml
```