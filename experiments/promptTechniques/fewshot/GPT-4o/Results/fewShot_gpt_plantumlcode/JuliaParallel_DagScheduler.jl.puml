```plantuml
@startuml JuliaParallel_DagScheduler.jl
skinparam rectangle {
  BackgroundColor #d9e7fd
  BorderColor black
  Style roundrect
}
skinparam componentStyle rectangle
left to right direction

package "DagScheduler.jl" {
  [DagScheduler] as DagScheduler
  [RemoteMonitor Plugin] as RemoteMonitor
  [FoundationDB Plugin] as FoundationDB

  package "Execution Layer" {
    [Execution Engine] as ExecutionEngine
    [Execution Queue] as ExecutionQueue
  }

  package "Scheduling Layer" {
    [Scheduler] as Scheduler
  }

  package "Metadata Stores" {
    [ShmemMetaStore] as ShmemMetaStore
    [SimpleMetaStore] as SimpleMetaStore
    [FDBMetaStore] as FDBMetaStore
  }

  DagScheduler --> ExecutionEngine
  DagScheduler --> Scheduler
  DagScheduler --> ExecutionQueue
  DagScheduler --> ShmemMetaStore
  DagScheduler --> SimpleMetaStore
  DagScheduler --> FDBMetaStore
  DagScheduler --> RemoteMonitor
  DagScheduler --> FoundationDB
}

package "Node Architecture" {
  rectangle "Node" as Node {
    rectangle "Broker" as Broker
    rectangle "Executor" as Executor
  }
}

[Execution Engine] --> Node
[Scheduler] --> Node
[Execution Queue] --> Node

[ShmemMetaStore] --> ExecutionEngine
[SimpleMetaStore] --> ExecutionEngine
[FDBMetaStore] --> ExecutionEngine

Node --> Broker
Node --> Executor

@enduml
```