```plantuml
@startuml andersonkmi_credit-card-bindb-service-aws
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Ingestion" {
  rectangle "S3\nCSV Storage" as s3 #orange
  rectangle "Lambda\nCSV Reader" as csvLambda #orange
  rectangle "SQS" as sqs #orange
  rectangle "Kinesis\nStream" as kinesis #orange
}

package "Processing" {
  rectangle "DynamoDB Consumer" as dynamoConsumer #orange
  database "DynamoDB" as dynamoDB #brown
}

package "API Access" {
  actor "User"
  rectangle "API Gateway\nBinary/JSON" as apiGw #green
  rectangle "Lambda\nAPI Implementation" as apiImpl #green
}

s3 --> csvLambda
csvLambda --> sqs : Batch
csvLambda --> kinesis : Stream
sqs --> dynamoConsumer
kinesis --> dynamoConsumer

dynamoConsumer --> dynamoDB

User --> apiGw
apiGw --> apiImpl
apiImpl --> dynamoDB
@enduml
```