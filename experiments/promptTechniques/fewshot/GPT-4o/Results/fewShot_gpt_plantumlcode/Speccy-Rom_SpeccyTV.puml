```plantuml
@startuml Speccy-Rom_SpeccyTV
left to right direction
skinparam rectangle {
  BackgroundColor #f3f3f3
  BorderColor black
  Style roundrect
}

actor "User" as user

package "Microservices" {
  rectangle "movies_auth" {
    rectangle "JWT\nGoogle OAuth" as auth
  }
  rectangle "movies_billing" {
    rectangle "Stripe Payment" as billing
  }
  rectangle "movies_async_api" {
    rectangle "Elasticsearch\nRedis Cache" as async_api
  }
  rectangle "movies_streaming_converter" {
    rectangle "FFmpeg" as converter
  }
  rectangle "movies_streaming_etl" {
    rectangle "Apache Airflow" as etl
  }
  rectangle "movies_admin" {
    rectangle "Django Admin" as admin
  }
  rectangle "movies_ugc" {
    rectangle "Kafka\nClickHouse" as ugc
  }
}

package "Databases & Storage" {
  database "PostgreSQL" as db
  database "Elasticsearch" as es
  database "Redis" as redis
  database "ClickHouse" as clickhouse
  rectangle "MinIO" as minio
}

package "Message Queue" {
  rectangle "RabbitMQ" as rabbitmq
  rectangle "Kafka" as kafka
}

user --> auth : login/signup
auth --> db : store user data
user --> async_api : browse/search movies
async_api --> es : search movies
async_api --> redis : cache results
user --> billing : manage subscriptions
billing --> db : store billing info
user --> converter : convert video
converter --> minio : store video
etl --> converter : trigger conversion
etl --> db : store ETL results
user --> admin : manage content
admin --> db : manage movie data
user --> ugc : interact with content
ugc --> kafka : stream UGC events
ugc --> clickhouse : analyze UGC data
@enduml
```