```plantuml
@startuml UoA-eResearch_hub-stack
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho

actor User

package "ResearchHub Website (Frontend)" {
  component "Angular App" as AngularApp
  component "SearchService" as SearchService
  component "CerGraphqlService" as CerGraphqlService
  component "BodyMediaService" as BodyMediaService
  component "PageTitleService" as PageTitleService
  component "NotificationService" as NotificationService
}

package "GraphQL API (cer-graphql)" {
  component "Apollo Server" as ApolloServer
}

package "Search Proxy (hub-search-proxy)" {
  component "AWS Lambda" as Lambda
  component "ElasticSearch" as ElasticSearch
}

package "Infrastructure" {
  component "AWS S3" as S3
  component "AWS CloudFront" as CloudFront
  component "AWS ECS/ECR" as ECS
  component "Jenkins" as Jenkins
}

User --> AngularApp
AngularApp --> SearchService
AngularApp --> CerGraphqlService
AngularApp --> BodyMediaService
AngularApp --> PageTitleService
AngularApp --> NotificationService

CerGraphqlService --> ApolloServer
ApolloServer --> "Contentful"

SearchService --> Lambda
Lambda --> ElasticSearch

AngularApp --> S3
S3 --> CloudFront

Jenkins --> ElasticSearch : Deploy
Jenkins --> Lambda : Deploy
Jenkins --> ApolloServer : Deploy
Jenkins --> AngularApp : Deploy
Jenkins --> S3 : Deploy
Jenkins --> ECS : Deploy

@enduml
```