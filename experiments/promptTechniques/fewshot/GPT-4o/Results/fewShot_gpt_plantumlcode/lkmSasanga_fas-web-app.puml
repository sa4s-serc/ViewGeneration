```plantuml
@startuml lkmSasanga_fas-web-app
skinparam rectangle {
  BackgroundColor #E3F2FD
  BorderColor #000000
  Style roundrect
}
skinparam component {
  BackgroundColor #BBDEFB
  BorderColor #000000
}
skinparam package {
  BackgroundColor #FFFFFF
  BorderColor #000000
}
skinparam usecase {
  BackgroundColor #90CAF9
  BorderColor #000000
}

left to right direction

actor User

rectangle "React Application" {
  usecase "Login/Signup" as Auth
  usecase "Search Items" as Search
  usecase "View Sentiment\nAnalysis" as ViewAnalysis
  usecase "Dashboard" as Dashboard
}

rectangle "Reusable UI Components" {
  component "Backdrop"
  component "Spinner"
  component "Modal"
  component "Card"
  component "DonutChart"
  component "ProgressBar"
  component "Navigation"
}

package "Backend API" {
  component "Sentiment API\n(https://malindu-fas.herokuapp.com/sentiment)" as SentimentAPI
}

package "Firebase Hosting" {
  component ".firebaserc"
}

User --> Auth
User --> Search
User --> ViewAnalysis
User --> Dashboard

Auth --> SentimentAPI : "Authenticate User"
Search --> SentimentAPI : "Fetch Sentiment Data"
ViewAnalysis --> SentimentAPI : "Retrieve Analysis Results"

Auth --> Backdrop
Auth --> Spinner
Auth --> Modal

Search --> Card
Search --> DonutChart
Search --> ProgressBar
Search --> Navigation

Dashboard --> DonutChart
Dashboard --> ProgressBar
Dashboard --> Navigation

@enduml
```