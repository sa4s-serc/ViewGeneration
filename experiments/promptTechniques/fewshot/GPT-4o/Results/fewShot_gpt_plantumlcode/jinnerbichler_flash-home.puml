```plantuml
@startuml jinnerbichler_flash-home
left to right direction
skinparam rectangle {
  BackgroundColor #F5F5F5
  BorderColor #000000
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as user

package "Home Automation System" {
  rectangle "Home Assistant" as HA <<microservice>> {
    rectangle "UI & Control Panel" as UI
    rectangle "MQTT Broker" as MQTT
    rectangle "Custom Flash Components" as FlashComponents
  }
}

package "Coffee Machine System" {
  rectangle "Coffee Machine Client" as CoffeeClient <<microservice>> {
    rectangle "client.py" as ClientPy
  }
}

package "IOTA Flash System" {
  rectangle "Flash Server (Machine)" as FlashServerMachine <<microservice>>
  rectangle "Flash Server (Provider)" as FlashServerProvider <<microservice>>
  rectangle "Private IOTA Testnet" as IOTATestnet <<external>>
}

user --> UI : Interact
UI --> MQTT : Send Commands
MQTT --> CoffeeClient : Trigger Coffee Action
CoffeeClient --> FlashServerMachine : Initiate Payment
FlashServerMachine --> FlashServerProvider : Process Payment
FlashServerProvider --> IOTATestnet : Record Transaction
FlashServerMachine --> CoffeeClient : Payment Confirmation
CoffeeClient --> MQTT : Status Update
MQTT --> FlashComponents : Update UI
@enduml
```