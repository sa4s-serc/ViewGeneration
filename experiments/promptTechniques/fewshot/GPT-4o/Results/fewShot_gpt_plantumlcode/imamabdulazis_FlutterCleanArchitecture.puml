```plantuml
@startuml imamabdulazis_FlutterCleanArchitecture
left to right direction

skinparam rectangle {
  BackgroundColor<<core>> #e0f7fa
  BackgroundColor<<data>> #ffecb3
  BackgroundColor<<domain>> #c8e6c9
  BackgroundColor<<presentation>> #d1c4e9
  BackgroundColor<<external>> #ffccbc
  Style roundrect
}

package "Application Structure" {
  rectangle "Main Entry\n(main.dart)" <<core>> {
    rectangle "Initialize Flutter"
    rectangle "Configure DI"
    rectangle "Global Error Handling"
  }

  rectangle "App Setup\n(app.dart)" <<presentation>> {
    rectangle "Theme Setup"
    rectangle "Routing"
    rectangle "Localization"
  }
  
  rectangle "Routes\n(routes.dart)" <<presentation>> {
    rectangle "Define Routes"
    rectangle "GetX Navigation"
  }

  package "Core Layer" <<core>> {
    rectangle "Networking\n(http_client.dart)" 
    rectangle "Device-Specific\n(device.dart)"
    rectangle "Error Handling\n(failure.dart)"
  }

  package "Data Layer" <<data>> {
    rectangle "Data Sources\n(remote/local)"
    rectangle "Models"
    rectangle "Repositories\n(Implementations)"
  }

  package "Domain Layer" <<domain>> {
    rectangle "Entities"
    rectangle "Use Cases"
    rectangle "Repository Interfaces"
  }

  package "Presentation Layer" <<presentation>> {
    rectangle "UI Components"
    rectangle "Screens"
    rectangle "BLoCs"
  }

  package "External Integrations" <<external>> {
    rectangle "Firebase Messaging"
    rectangle "Sentry"
    rectangle "Shared Preferences"
  }
}

"Main Entry\n(main.dart)" --> "App Setup\n(app.dart)"
"App Setup\n(app.dart)" --> "Routes\n(routes.dart)"

"Core Layer" --> "Data Layer"
"Data Layer" --> "Domain Layer"
"Domain Layer" --> "Presentation Layer"

"Presentation Layer" --> "External Integrations"

"External Integrations" -left-> "Core Layer" : Configuration
@enduml
```