```plantuml
@startuml BoraxTheClean_DevelopmentMachine
left to right direction
skinparam rectangle {
  BackgroundColor #f9f9f9
  BorderColor black
  Style roundrect
}
skinparam cloud {
  BackgroundColor #ffffff
  BorderColor black
}
skinparam database {
  BackgroundColor #ffffff
  BorderColor black
}

actor "Developer" as Dev

cloud "AWS" {
  rectangle "CloudFormation\n(template.yaml)" as CF #lightblue
  rectangle "EC2 Instance" as EC2 #orange
  rectangle "IAM Role\n(Admin Access)" as IAM #lightyellow
  rectangle "Security Group\n(SSH Access)" as SG #lightgreen
  rectangle "CloudWatch\n(Inactivity Alarm)" as CW #lightpink
  rectangle "S3 Bucket" as S3 #lightgrey
}

rectangle "GitHub Actions\n(aws.yml)" as GH #lightcoral
rectangle "AWS CLI\n(script.sh)" as CLI #lightsalmon

Dev --> GH : Push Changes
GH --> S3 : Upload Template
GH --> CLI : Trigger Script

CLI --> CF : Deploy Stack
CF --> EC2
CF --> IAM
CF --> SG
CF --> CW

CW --> EC2 : Stop on Inactivity

@enduml
```