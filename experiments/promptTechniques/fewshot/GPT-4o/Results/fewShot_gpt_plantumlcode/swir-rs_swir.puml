```plantuml
@startuml swir-rs_swir
left to right direction
skinparam rectangle {
  BackgroundColor #f8f8f8
  BorderColor black
  Style roundrect
}

package "Frontend Handlers" {
  rectangle "HTTP Handler" as HttpHandler
  rectangle "gRPC Handler" as GrpcHandler
}

package "Service Invocation" {
  rectangle "Service Discovery\n(mDNS / DynamoDB)" as ServiceDiscovery
  rectangle "gRPC Client" as GrpcClient
}

package "Messaging Handlers" {
  rectangle "AWS Kinesis Handler" as KinesisHandler
  rectangle "Kafka Handler" as KafkaHandler
  rectangle "NATS Handler" as NatsHandler
}

package "Persistence Handlers" {
  rectangle "Redis Store" as RedisStore
  rectangle "DynamoDB Store" as DynamoDbStore
}

package "Utilities" {
  rectangle "Config" as Config
  rectangle "Metrics\n(OpenTelemetry)" as Metrics
  rectangle "Tracing" as Tracing
}

HttpHandler --> GrpcClient
GrpcHandler --> GrpcClient

GrpcClient --> ServiceDiscovery
ServiceDiscovery --> GrpcClient : Endpoint Resolution

HttpHandler --> KafkaHandler : PubSub
HttpHandler --> NatsHandler : PubSub
HttpHandler --> KinesisHandler : PubSub

GrpcHandler --> KafkaHandler : PubSub
GrpcHandler --> NatsHandler : PubSub
GrpcHandler --> KinesisHandler : PubSub

HttpHandler --> RedisStore : Persistence
HttpHandler --> DynamoDbStore : Persistence

GrpcHandler --> RedisStore : Persistence
GrpcHandler --> DynamoDbStore : Persistence

Config --> HttpHandler
Config --> GrpcHandler
Config --> ServiceDiscovery
Config --> KafkaHandler
Config --> NatsHandler
Config --> KinesisHandler
Config --> RedisStore
Config --> DynamoDbStore

Metrics --> HttpHandler
Metrics --> GrpcHandler

Tracing --> HttpHandler
Tracing --> GrpcHandler
@enduml
```