```plantuml
@startuml mendhak_gpslogger
skinparam rectangle {
  BackgroundColor #f3f4f6
  BorderColor #2d3e50
  Style roundrect
}

left to right direction

package "Android Application" {
  
  rectangle "UI Layer" as UI {
    rectangle "GpsMainActivity" as GpsMainActivity
    rectangle "MainPreferenceActivity" as MainPreferenceActivity
  }

  rectangle "Business Logic Layer" as BusinessLogic {
    rectangle "GpsLoggingService" as GpsLoggingService
    rectangle "PreferenceHelper" as PreferenceHelper
    rectangle "EventBus" as EventBus
  }

  rectangle "Data Persistence Layer" as DataPersistence {
    rectangle "FileLoggerFactory" as FileLoggerFactory
    rectangle "GPXLogger / KMLLogger" as Loggers
  }

  rectangle "External Service Integration" as ExternalServices {
    rectangle "GoogleDriveManager" as GoogleDriveManager
    rectangle "GoogleDriveWorker" as GoogleDriveWorker
    rectangle "FileSender" as FileSender
  }

  rectangle "Configuration Layer" as Configuration {
    rectangle "AppSettings" as AppSettings
  }
}

package "Background Processing" {
  rectangle "WorkManager" as WorkManager
}

package "Connectivity" {
  rectangle "Network" as Network
}

GpsMainActivity --> GpsLoggingService
MainPreferenceActivity --> PreferenceHelper
GpsLoggingService --> EventBus
GpsLoggingService --> FileLoggerFactory
FileLoggerFactory --> Loggers
GpsLoggingService --> GoogleDriveManager
GoogleDriveManager --> GoogleDriveWorker
GoogleDriveWorker --> WorkManager
FileSender --> ExternalServices
AppSettings --> Configuration
EventBus --> Network
GoogleDriveManager --> Network

@enduml
```