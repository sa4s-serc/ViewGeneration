```plantuml
@startuml AhmedAbdelGawadFarag_Shams-Personal-Assistant
skinparam linetype ortho
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor black
  Style roundrect
}

actor User

package "Android Application" {
  rectangle "MainActivity" as MainActivity
  rectangle "BotManager" as BotManager
  rectangle "DialogManager" as DialogManager
  rectangle "RecordingManager" as RecordingManager
  rectangle "CalendarManager" as CalendarManager
  rectangle "ContactManager" as ContactManager
  rectangle "EmailManager" as EmailManager
  rectangle "WebSearchManager" as WebSearchManager
  rectangle "OpenAppManager" as OpenAppManager
  rectangle "NotificationProvider" as NotificationProvider
  rectangle "ArabicTranslationManager" as ArabicTranslationManager
}

package "Servers" {
  package "NER Server" {
    rectangle "NER Flask App" as NERApp
    rectangle "NER Model" as NERModel
  }

  package "Main Server" {
    rectangle "Main Flask App" as MainApp
    rectangle "Intent Classifier" as IntentClassifier
    rectangle "ASR" as ASR
    rectangle "TTS" as TTS
    rectangle "Translation" as Translation
  }
}

package "Google Cloud" {
  rectangle "Speech-to-Text API" as STT
  rectangle "Text-to-Speech API" as CloudTTS
}

User -> MainActivity : voice/text input
MainActivity -> BotManager : process input
BotManager -> DialogManager : manage dialog
BotManager -> NERApp : NER request
NERApp -> NERModel : extract entities
NERModel -> NERApp : return entities
NERApp -> BotManager : return entities
BotManager -> IntentClassifier : classify intent
IntentClassifier -> MainApp : execute intent
MainApp -> ASR : speech-to-text
ASR -> STT : convert speech
STT -> ASR : return text
MainApp -> TTS : text-to-speech
TTS -> CloudTTS : convert text
CloudTTS -> TTS : return speech
MainApp -> Translation : perform translation
MainApp -> BotManager : return response
BotManager -> MainActivity : display response
@enduml
