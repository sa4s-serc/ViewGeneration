```plantuml
@startuml EOS-Nation_dfuse-docs
left to right direction
skinparam rectangle {
  BackgroundColor #f3f3f3
  BorderColor black
  Style roundrect
}

actor "User" as User

package "Client Interface" {
  rectangle "GraphQL API" as GraphQLAPI #ffcccc
  rectangle "dfuseeos CLI" as CLI #ffcccc
}

package "Microservices" {
  rectangle "mindreader" as Mindreader #cce5ff
  rectangle "relayer" as Relayer #cce5ff
  rectangle "search" as Search #cce5ff
  rectangle "dgraphql" as Dgraphql #cce5ff
}

package "Data Storage" {
  rectangle "BigTable" as BigTable #ffe6cc
  rectangle "TiKV" as TiKV #ffe6cc
  rectangle "Badger" as Badger #ffe6cc
}

package "Blockchain Nodes" {
  rectangle "nodeos" as Nodeos #e6ccff
}

User --> GraphQLAPI
User --> CLI

GraphQLAPI --> Dgraphql
CLI --> Mindreader

Mindreader --> Relayer
Relayer --> Search
Search --> Dgraphql

Mindreader --> Nodeos
Dgraphql --> BigTable
Dgraphql --> TiKV
Dgraphql --> Badger

@enduml
```