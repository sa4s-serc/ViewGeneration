```plantuml
@startuml zoolhelmy_ESP8266-Weather-Station
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "User" as user

rectangle "ESP8266" {
  rectangle "Sensor Data Acquisition" as sensor
  rectangle "MQTT Publisher" as mqtt_publisher
  rectangle "Local HTTP Server" as http_server
}

rectangle "Cloud" {
  rectangle "ThingSpeak" as thingspeak
}

rectangle "OpenWRT Router" {
  rectangle "MQTT Subscriber" as mqtt_subscriber
  rectangle "Data Processing" as data_processing
  rectangle "RRDTool" as rrdtool
  rectangle "GitHub Publisher" as github_publisher
}

rectangle "GitHub" as github

user --> http_server : Access Real-Time Data

sensor --> mqtt_publisher : Collect & Publish Data
mqtt_publisher --> mqtt_subscriber : MQTT Message
mqtt_publisher --> thingspeak : MQTT Message

mqtt_subscriber --> data_processing : Transfer Data
data_processing --> rrdtool : Update DB

rrdtool --> github_publisher : Generate & Publish Graphs
github_publisher --> github : Push Graphs

@enduml
```