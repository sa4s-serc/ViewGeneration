```plantuml
@startuml lowes_auditor
left to right direction
skinparam rectangle {
  BackgroundColor #f8f8f8
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Client Library" {
  rectangle "API for generating\nAudit Events & Logs" as ClientAPI
  rectangle "Spring Boot Starter" as SpringBootStarter
}

package "Application Server" {
  rectangle "Application.kt\nMain Entry" as AppMain
  rectangle "ConsumerService.kt" as ConsumerService
  rectangle "AuditEventRepositoryService.kt" as RepositoryService
}

package "Core Module" {
  rectangle "AuditEventDTOMapper.kt" as DTOMapper
  rectangle "AuditEventMapper.kt" as EventMapper
  rectangle "JsonObject.kt\nSingleton" as JsonObject
}

package "Infrastructure" {
  database "Kafka" as Kafka
  database "Elasticsearch" as Elasticsearch
}

package "Specification" {
  rectangle "OpenAPI Specs" as OpenAPISpecs
}

ClientAPI --> AppMain : Generate Events
SpringBootStarter --> ClientAPI
ConsumerService --> Kafka : Subscribe & Receive Events
RepositoryService --> Elasticsearch : Persist Events
AppMain --> ConsumerService
ConsumerService --> RepositoryService
DTOMapper --> ClientAPI
EventMapper --> ClientAPI
JsonObject --> ClientAPI
OpenAPISpecs --> ClientAPI
@enduml
