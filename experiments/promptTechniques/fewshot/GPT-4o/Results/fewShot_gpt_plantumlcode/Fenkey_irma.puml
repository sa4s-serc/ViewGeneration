```plantuml
@startuml Fenkey_irma
left to right direction
skinparam rectangle {
  BackgroundColor #f7f7f7
  BorderColor #000000
  Style roundrect
}
skinparam defaultTextAlignment center

package "IRMA" {
  package "irmacall (C)" {
    rectangle "Multi-Threaded Engine" as Engine
    rectangle "HTTP Request Handling" as HTTPHandling
    rectangle "HTTP Client (Fetcher)" as HTTPClient
    rectangle "Key-Value Storage" as KVStorage
    rectangle "Logging System" as Logging
    rectangle "SMTP Support" as SMTP
    rectangle "Cryptography" as Crypto
    rectangle "Fuse (Circuit Breaker)" as Fuse
    rectangle "Buffer Management" as Buffer
    rectangle "DNS Resolution" as DNS
  }
  
  package "irmakit (C#)" {
    rectangle "Framework for Web Apps" as Framework
    rectangle "Configuration System" as Config
    rectangle "Session Management" as Session
    rectangle "Request/Response Handling" as RequestResponse
    rectangle "Routing (Attribute-Driven)" as Routing
    rectangle "Template Engine Integration" as TemplateEngine
    rectangle "Utilities" as Utilities
    rectangle "Code Generation" as CodeGen
  }
}

Engine <.. HTTPHandling
Engine <.. HTTPClient
Engine <.. KVStorage
Engine <.. Logging
Engine <.. SMTP
Engine <.. Crypto
Engine <.. Fuse
Engine <.. Buffer
Engine <.. DNS

Framework --> Config
Framework --> Session
Framework --> RequestResponse
Framework --> Routing
Framework --> TemplateEngine
Framework --> Utilities
Framework --> CodeGen

HTTPHandling --> "FastCGI"
HTTPHandling --> Framework

KVStorage --> "Memcached/Redis"
Session --> KVStorage

Utilities --> Crypto

@enduml
```