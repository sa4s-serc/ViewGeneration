```plantuml
@startuml gaiax_fLibra
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}

actor User

package "Frontend (Nuxt.js)" {
  rectangle "SearchFunction.vue" as SearchFunction
  rectangle "ItemList.vue" as ItemList
  rectangle "HeaderBar.vue" as HeaderBar
  rectangle "Vuex State\n(user.js, item.js)" as VuexState
  rectangle "Firebase Plugin" as FirebasePlugin
  rectangle "Firestore Plugin" as FirestorePlugin
  rectangle "IPFS Plugin" as IPFSPlugin
  rectangle "Web3 Plugin" as Web3Plugin
}

package "Blockchain Integration" {
  rectangle "Libra Network" as Libra
  rectangle "Ethereum Network" as Ethereum
  rectangle "Smart Contracts\n(Flibra.sol, ItemDetail.sol)" as SmartContracts
}

package "Data Storage" {
  rectangle "Firestore" as Firestore
  rectangle "IPFS" as IPFS
  rectangle "Elasticsearch" as Elasticsearch
}

package "Elasticsearch Integration (Node.js)" {
  rectangle "app.js" as AppJS
  rectangle "Search.js" as SearchJS
  rectangle "Registration.js" as RegistrationJS
  rectangle "DeleteItem.js" as DeleteItemJS
}

User --> SearchFunction
User --> ItemList
User --> HeaderBar

SearchFunction --> Elasticsearch
ItemList --> Firestore
HeaderBar --> VuexState

VuexState --> FirebasePlugin
VuexState --> FirestorePlugin
VuexState --> IPFSPlugin
VuexState --> Web3Plugin

FirebasePlugin --> Firestore
FirestorePlugin --> Firestore
IPFSPlugin --> IPFS
Web3Plugin --> SmartContracts

SmartContracts --> Ethereum
SmartContracts --> Libra

Firestore --> SearchJS
Firestore --> RegistrationJS
Firestore --> DeleteItemJS

AppJS --> Elasticsearch
SearchJS --> Elasticsearch
RegistrationJS --> Elasticsearch
DeleteItemJS --> Elasticsearch
@enduml
```