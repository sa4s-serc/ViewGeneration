```plantuml
@startuml nasa_cFS
left to right direction
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<submodule>> #fddddd
  BackgroundColor<<tool>> #d8f5d3
  BackgroundColor<<ci>> #fff1c9
  BackgroundColor<<doc>> #ffebc9
  Style roundrect
}

package "NASA cFS Framework" {
  rectangle "Core Flight Executive (cFE)" <<core>> as cFE
  rectangle "Operating System Abstraction Layer (OSAL)" <<core>> as OSAL
  rectangle "Platform Support Package (PSP)" <<core>> as PSP
  rectangle "Event Services (ES)" <<core>> as ES
  
  cFE --> OSAL
  cFE --> PSP
  cFE --> ES
}

package "Components" {
  rectangle "Applications" <<submodule>> as Apps
  rectangle "Tools" <<tool>> as Tools
}

package "CI/CD Pipeline" <<ci>> {
  rectangle "Static Analysis" as Static
  rectangle "Unit Testing" as UnitTests
  rectangle "Functional Testing" as FunctionalTests
  rectangle "Cross-Platform Builds" as CrossPlatform
  rectangle "Code Formatting" as CodeFormatting
}

package "Documentation & Governance" <<doc>> {
  rectangle "README.md" as Readme
  rectangle "CONTRIBUTING.md" as Contributing
  rectangle "SECURITY.md" as Security
  rectangle "ISSUE Templates" as IssueTemplates
}

cFE --> Apps
Tools --> Apps
cFE --> Tools

Static --> cFE
UnitTests --> cFE
FunctionalTests --> cFE
CrossPlatform --> cFE
CodeFormatting --> cFE

Readme --> cFE
Contributing --> cFE
Security --> cFE
IssueTemplates --> cFE

@enduml
