```plantuml
@startuml batatero_arquiteturaPHP00
left to right direction
skinparam rectangle {
  BackgroundColor<<framework>> #d9e7fd
  BackgroundColor<<library>> #fddddd
  BackgroundColor<<orm>> #d8f5d3
  BackgroundColor<<component>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "CodeIgniter Framework" <<framework>> {
  rectangle "Front Controller\n(index.php)" as FrontController
  rectangle "Controllers" as Controllers
  rectangle "Facades" as Facades
  rectangle "Business Logic" as BusinessLogic
  rectangle "DAOs" as DAOs
  rectangle "FactoryBusiness" as FactoryBusiness
  rectangle "FactoryDAO" as FactoryDAO
  rectangle "Config" as Config
  rectangle "Libraries & Helpers" as Libraries
  rectangle ".htaccess" as Htaccess
}

package "Doctrine ORM" <<orm>> {
  rectangle "EntityManager" as EntityManager
  rectangle "UnitOfWork" as UnitOfWork
  rectangle "EntityRepository" as EntityRepository
  rectangle "ClassMetadata" as ClassMetadata
  rectangle "Hydration" as Hydration
  rectangle "Querying" as Querying
  rectangle "Schema Management" as SchemaManagement
  rectangle "Platform Abstraction" as PlatformAbstraction
}

package "Symfony Components" <<component>> {
  rectangle "YAML" as YAML
  rectangle "Console" as Console
}

FrontController --> Controllers
Controllers --> Facades
Facades --> BusinessLogic
BusinessLogic --> DAOs
DAOs --> Database
FactoryBusiness --> BusinessLogic
FactoryDAO --> DAOs
Config --> FrontController
Config --> Libraries
Libraries --> Controllers
Htaccess --> FrontController

EntityManager --> UnitOfWork
UnitOfWork --> EntityRepository
EntityRepository --> ClassMetadata
EntityManager --> Hydration
EntityManager --> Querying
SchemaManagement --> PlatformAbstraction

YAML --> Config
Console --> CommandLineInterface

@enduml
```