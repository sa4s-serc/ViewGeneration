```plantuml
@startuml zeropaper_visual-fiha
left to right direction
skinparam rectangle {
  BackgroundColor<<extension>> #d8f5d3
  BackgroundColor<<webview>> #d9e7fd
  BackgroundColor<<worker>> #fff1c9
  BackgroundColor<<utility>> #fddddd
  BackgroundColor<<component>> #e6e6e6
  Style roundrect
}
skinparam defaultTextAlignment center

package "VS Code Environment" {
  rectangle "VFExtension\n(src/extension/VFExtension.ts)" <<extension>> as VFExtension
  rectangle "WebServer\n(src/extension/WebServer.ts)" <<extension>> as WebServer
  rectangle "Redux Store\n(src/extension/store.ts)" <<extension>> as ReduxStore
  rectangle "Commands\n(src/extension/commands)" <<extension>> as Commands

  VFExtension --> WebServer
  VFExtension --> ReduxStore
  VFExtension --> Commands
}

package "Webviews" <<webview>> {
  rectangle "AudioView\nControlView\nDisplaysView\nTimelineView" as Webviews
  rectangle "Redux Store\n(src/webviews/store.ts)" as WebviewStore

  Webviews --> WebviewStore
  VFExtension --> Webviews
}

package "Display & Rendering" {
  rectangle "DisplayWorker\n(src/display/DisplayWorker.ts)" <<worker>> as DisplayWorker
  rectangle "Canvas2DLayer\nThreeJSLayer\n(src/layers)" <<component>> as Layers
  rectangle "ScriptRunner\n(src/utils/ScriptRunner.ts)" <<utility>> as ScriptRunner
  rectangle "Scriptable\n(src/utils/Scriptable.ts)" <<utility>> as Scriptable

  DisplayWorker --> Layers
  DisplayWorker --> ScriptRunner
  Layers --> Scriptable
}

package "Capture" <<webview>> {
  rectangle "React Components\n(src/capture)" as CaptureComponents
  VFExtension --> CaptureComponents
}

package "Utilities" <<utility>> {
  rectangle "Com\n(src/utils/com.ts)" as Com
  rectangle "MathTools\nMiscTools\n(src/utils)" as Utils

  VFExtension --> Com
  VFExtension --> Utils
}

package "Plugin Management" {
  rectangle "fiha.json\nProject Configuration" as FihaConfig
  VFExtension --> FihaConfig
}

@enduml
