```plantuml
@startuml IBM_cognos-analytics-to-visualize-business-data
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User"

package "Data Generation" {
  rectangle "Node.js\ncreate-product-data.js" as DataGen #lightblue
  rectangle "Node.js\nsave-product-reviews.js" as SaveReviews #lightblue
  rectangle "CSV Files" as CSV #lightgray
}

package "Data Warehouse" {
  rectangle "IBM Db2 Warehouse" as Db2 #lightyellow
  rectangle "Netezza Performance Server" as Netezza #lightyellow
}

package "Cognos Analytics" {
  rectangle "Cognos Analytics" as Cognos #lightgreen
  rectangle "Data Modules" as DataModules #lightgreen
  rectangle "Dashboards/Visualizations" as Dashboards #lightgreen
}

User --> DataGen : Initiate data generation
DataGen --> CSV : Export to CSV
SaveReviews --> CSV : Export review data

CSV --> Db2 : Load data
CSV --> Netezza : Load data

User --> Cognos : Connect to data warehouse
Db2 --> Cognos : Provide data for analysis
Netezza --> Cognos : Provide data for analysis

Cognos --> DataModules : Create data modules
DataModules --> Dashboards : Build visualizations
@enduml
```