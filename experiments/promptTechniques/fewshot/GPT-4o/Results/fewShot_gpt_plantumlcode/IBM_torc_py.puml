```plantuml
@startuml IBM_torc_py
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "User" as user

rectangle "IBM_torc_py" as torc_py {
    rectangle "Task Management" as task_mgmt {
        [submit()]
        [map()]
        [wait()]
        [as_completed()]
    }
    rectangle "Application Setup & Control" as app_control {
        [init()]
        [launch()]
        [start()]
        [shutdown()]
    }
    rectangle "Load Balancing" as load_balancing {
        [Round-Robin]
        [Task Stealing]
    }
    rectangle "SPMD Support" as spmd_support {
        [spmd()]
    }
    rectangle "Callbacks" as callbacks {
        [User-defined Callbacks]
    }
    rectangle "Context Manager" as context_manager {
        [TorcPoolExecutor]
    }
    rectangle "Hybrid MPI and Multithreading" as hybrid_arch {
        [MPI Communication]
        [Thread Pool]
    }
}

cloud "MPI Process" as mpi_process {
    rectangle "Master" as master
    rectangle "Worker" as worker
}

user --> task_mgmt : use
user --> app_control : use
user --> spmd_support : use
user --> callbacks : define
user --> context_manager : wrap

task_mgmt --> master : task distribution
master --> worker : task execution
worker --> task_mgmt : result submission

app_control --> master : application lifecycle
load_balancing --> master : distribute tasks
load_balancing --> worker : redistribute tasks

hybrid_arch --> mpi_process : inter-process comm.
hybrid_arch --> worker : multithreading

@enduml
```