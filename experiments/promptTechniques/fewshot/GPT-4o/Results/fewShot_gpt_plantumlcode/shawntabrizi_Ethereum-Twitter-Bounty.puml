```plantuml
@startuml shawntabrizi_Ethereum-Twitter-Bounty
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (HTML/CSS/JS)" {
  rectangle "User Interface" as UI #lightblue
  rectangle "Web3.js" as Web3js #lightblue
  rectangle "TruffleContract" as TruffleContract #lightblue
}

package "Smart Contracts (Solidity)" {
  rectangle "TwitterBounty.sol" as TwitterBounty #lightgreen
  rectangle "TwitterOracle.sol" as TwitterOracle #lightgreen
}

package "Blockchain" {
  rectangle "Ethereum Network" as Ethereum #lightyellow
}

package "Oracle Service" {
  rectangle "Provable (Oraclize)" as Provable #lightpink
}

actor "User"

User --> UI
UI --> Web3js
Web3js --> TruffleContract
TruffleContract --> TwitterBounty
TwitterBounty --> TwitterOracle
TwitterOracle --> Provable : oraclizeTweet()
Provable --> TwitterOracle : __callback()
TwitterBounty --> Ethereum
TwitterOracle --> Ethereum
@enduml
```