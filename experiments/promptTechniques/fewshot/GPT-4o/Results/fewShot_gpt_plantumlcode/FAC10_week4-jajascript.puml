```plantuml
@startuml

skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center
skinparam linetype ortho
left to right direction

actor User

package "Front-end" <<frontend>> {
  rectangle "index.html" as html
  rectangle "main.css" as css
  rectangle "main.js" as js
}

package "Back-end" <<backend>> {
  rectangle "server.js" as server
  rectangle "router.js" as router
  rectangle "handler.js" as handler
  rectangle "algorithm.js" as algorithm
}

package "Data" <<data>> {
  rectangle "data.json" as data
}

User --> html : "Types in search"
html --> js : "Capture input"
js --> server : "Fetch suggestions"
server --> router : "Route request"
router --> handler : "Static files"
router --> algorithm : "Autocomplete logic"
algorithm --> data : "Read laureates data"
data --> algorithm : "Return matching results"
algorithm --> handler : "Return suggestions"
handler --> js : "Deliver results"
js --> html : "Update suggestions"

@enduml
```