```plantuml
@startuml anjuchamantha_EMonitor
skinparam backgroundColor #ffffff
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "User" as user

package "ESP32 Device" {
  rectangle "main.cpp" as Main <<ESP32>> {
    component "Sensor Data\nAcquisition" as SensorData #a3d3f5
    component "Data Buffering" as DataBuffer #a3d3f5
    component "Data Formatting\n(XML)" as DataFormat #a3d3f5
    component "Network\nCommunication" as NetworkComm #a3d3f5
    component "Local Display" as LocalDisplay #a3d3f5
    component "Alerting" as Alerting #a3d3f5
  }
}

package "Modules" {
  component "WiFi Connection" as WiFiModule #d4a0f5
  component "HTTP Requests" as HTTPModule #d4a0f5
  component "Mail Client" as MailModule #d4a0f5
  component "Sensor Readings" as SensorReadings #d4a0f5
  component "Utils" as UtilsModule #d4a0f5
  component "XML Generation" as XMLModule #d4a0f5
}

package "Configuration" {
  rectangle "config.h" as Config #ffcc99
}

SensorData --> SensorReadings
DataBuffer --> UtilsModule
DataFormat --> XMLModule
NetworkComm --> WiFiModule
NetworkComm --> HTTPModule
LocalDisplay --> "OLED"
Alerting --> MailModule

Main --> SensorData
Main --> DataBuffer
Main --> DataFormat
Main --> NetworkComm
Main --> LocalDisplay
Main --> Alerting

user --> LocalDisplay

Config --> WiFiModule
Config --> HTTPModule
Config --> MailModule

@enduml
