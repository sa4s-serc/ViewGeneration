```plantuml
@startuml YW-Ma_Algorithms-Visualizer
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as User

package "Frontend (React)" {
  rectangle "Map\n(BMap API)" as Map
  rectangle "GraphSVG\n(SVG Animation)" as GraphSVG
  rectangle "GraphTable\n(Data Table View)" as GraphTable
  rectangle "Sidebar\n(User Interaction)" as Sidebar
  rectangle "Panel\n(Integrated View)" as Panel
  rectangle "Header/Body Info\n(Reports)" as Reports
  rectangle "MyRoute\n(Routing)" as MyRoute
  rectangle "Event Proxy\n(Pub/Sub)" as EventProxy
}

package "Backend (Node.js)" {
  rectangle "Express.js API" as ExpressAPI
  rectangle "Authorize\n(Authentication Middleware)" as Authorize
  rectangle "User Module\n(DAO for DB)" as UserModule
  rectangle "MySQL\n(User Data & Sessions)" as MySQL
  rectangle "C++ Executables\n(Algorithm Execution)" as CppExec
}

User --> Sidebar
User --> Panel
User --> Reports
User --> MyRoute

Sidebar --> ExpressAPI : Trigger Visualization
Panel --> GraphSVG
Panel --> GraphTable
GraphSVG --> EventProxy
GraphTable --> EventProxy

ExpressAPI --> CppExec : Execute Algorithms
ExpressAPI --> UserModule : Query User Data
ExpressAPI --> MySQL : Manage Sessions
ExpressAPI --> Authorize : Authenticate Users

@enduml
```