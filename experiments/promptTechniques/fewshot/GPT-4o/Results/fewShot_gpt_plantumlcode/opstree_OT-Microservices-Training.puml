```plantuml
@startuml opstree_OT-Microservices-Training
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend Application\n(ReactJS)" as Frontend #lightblue
rectangle "API Gateway\n(Spring Boot)" as Gateway #lightyellow
rectangle "Attendance Service\n(Golang + Gin)" as Attendance #lightgreen
rectangle "Employee Service\n(Golang + Gin)" as Employee #lightgreen
rectangle "Salary Service\n(Golang + Gin)" as Salary #lightgreen
rectangle "Notification Service\n(Python)" as Notification #lightgreen
rectangle "Nginx Webserver" as Webserver #lightyellow
database "MySQL" as MySQL #lightgrey
database "Elasticsearch" as Elasticsearch #lightgrey

User --> Frontend
Frontend --> Webserver
Webserver --> Gateway
Gateway --> Attendance
Gateway --> Employee
Gateway --> Salary
Gateway --> Notification
Attendance --> MySQL
Employee --> MySQL
Salary --> MySQL
Notification --> Elasticsearch

@enduml
```