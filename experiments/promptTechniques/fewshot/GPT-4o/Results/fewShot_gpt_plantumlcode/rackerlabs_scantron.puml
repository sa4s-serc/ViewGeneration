```plantuml
@startuml
skinparam backgroundColor #000000
skinparam shadowing false
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam ArrowColor White
skinparam FontColor White
skinparam ComponentBorderColor White
skinparam ComponentBackgroundColor #1e90ff

package "CONSOLE" {
    [User Console] as UserConsole <<node>> #white
    component "NGINX\nTCP 22/80/443" as NGINX #green

    [API] as API
    [Static Files\n(/static)] as Static
    [Reverse Web Proxy] as ReverseProxy
    [Scan Results & Target Files\n(./scan_results, ./target_files)] as Files
    [uWSGI] as uWSGI
    [Django] as Django #007acc
    database "PostgreSQL" as Postgres #ffffff

    UserConsole --> NGINX
    API --> NGINX
    Static --> NGINX
    Files --> NGINX
    ReverseProxy --> NGINX
    ReverseProxy --> uWSGI
    uWSGI --> Django
    Django --> Postgres

    note right of Files #black
        NFS Share
    end note
}

package "ENGINE" {
    component "engine.py" as Engine
    [Target 1]
    [Target 2]

    Engine --> [Target 1]
    Engine --> [Target 2]
}

cloud "SSH / SSL\nTunnel" as Tunnel #005555

NGINX --> Tunnel : /api
Tunnel --> Engine

note right of NGINX #darkgreen
  FIREWALL
end note

note left of Engine #darkgreen
  FIREWALL
end note
@enduml
```