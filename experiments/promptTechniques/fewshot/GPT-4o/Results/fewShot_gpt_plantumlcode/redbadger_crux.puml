}
left to right direction

actor User

package "Crux Framework" {
  rectangle "Core (crux_core)" as Core #lightblue {
    rectangle "App Trait" as AppTrait
    rectangle "Core Struct" as CoreStruct
    rectangle "Effect Trait" as EffectTrait
    rectangle "Bridge Struct" as BridgeStruct
    rectangle "Command" as Command
    rectangle "Capabilities" as Capabilities
  }
  
  rectangle "Utilities" as Utilities #lightgreen {
    rectangle "crux_http" as CruxHttp
    rectangle "crux_time" as CruxTime
  }
}

package "Platform-Specific Shells" {
  rectangle "iOS (Swift)" as SwiftShell
  rectangle "Android (Kotlin)" as KotlinShell
  rectangle "Web (TypeScript)" as WebShell
}

package "Examples" {
  rectangle "Counter App" as CounterApp {
    rectangle "Core Logic" as CoreLogic
    rectangle "Platform UIs" as PlatformUIs
  }
}

