```plantuml
@startuml pacmacro_pm-server-spring
skinparam componentStyle rectangle
skinparam linetype ortho

actor "Client" as Client

rectangle "Pac Macro Game Server" as Server {
    package "Controllers" {
        rectangle "PlayerController" as PlayerController
        rectangle "GameStateController" as GameStateController
        rectangle "PacdotController" as PacdotController
        rectangle "TagController" as TagController
    }
    
    package "Managers" {
        rectangle "PlayerManager" as PlayerManager
        rectangle "GameStateManager" as GameStateManager
        rectangle "PacdotManager" as PacdotManager
        rectangle "TagManager" as TagManager
    }
    
    package "Registries" {
        rectangle "PlayerRegistry" as PlayerRegistry
        rectangle "GameStateRegistry" as GameStateRegistry
        rectangle "PacdotRegistry" as PacdotRegistry
        rectangle "TagRegistry" as TagRegistry
    }
    
    package "Repositories" {
        rectangle "PlayerRepository" as PlayerRepository
        rectangle "PacdotRepository" as PacdotRepository
    }
}

Client -> PlayerController : HTTP Request
PlayerController -> PlayerManager : Handle Request
PlayerManager -> PlayerRegistry : Get/Update Player Data
PlayerRegistry -> PlayerRepository : Access In-Memory Data
PlayerRepository --> PlayerRegistry : Return Data
PlayerRegistry --> PlayerManager : Return Data
PlayerManager --> PlayerController : Return Response
PlayerController --> Client : HTTP Response

Client -> GameStateController : HTTP Request
GameStateController -> GameStateManager : Handle Request
GameStateManager -> GameStateRegistry : Get/Update Game State
GameStateRegistry --> GameStateManager : Return Data
GameStateManager --> GameStateController : Return Response
GameStateController --> Client : HTTP Response

Client -> PacdotController : HTTP Request
PacdotController -> PacdotManager : Handle Request
PacdotManager -> PacdotRegistry : Get/Update Pacdots
PacdotRegistry -> PacdotRepository : Access In-Memory Data
PacdotRepository --> PacdotRegistry : Return Data
PacdotRegistry --> PacdotManager : Return Data
PacdotManager --> PacdotController : Return Response
PacdotController --> Client : HTTP Response

Client -> TagController : HTTP Request
TagController -> TagManager : Handle Request
TagManager -> TagRegistry : Register Tag
TagRegistry --> TagManager : Confirm Registration
TagManager --> TagController : Return Response
TagController --> Client : HTTP Response

@enduml
```