```plantuml
@startuml ArnBaudzus_FluxSurfer
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "FluxSurfer" {
  package "Core Components" {
    rectangle "QuantumSystem" as QuantumSystem
    rectangle "Experiment" as Experiment
    rectangle "State" as State
    rectangle "Edge" as Edge
  }

  package "Solvers" {
    rectangle "SingleStepScheme" as SingleStepScheme
    rectangle "Solver" as Solver
    rectangle "EulerForward" as EulerForward
    rectangle "RichardsonSolver" as RichardsonSolver
    rectangle "MonteCarloWanderer" as MonteCarloWanderer
  }

  package "Utilities" {
    rectangle "fileUtility.py" as FileUtility
    rectangle "quantities.py" as Quantities
    rectangle "plotChargeCurve.py" as PlotChargeCurve
    rectangle "menu.py" as Menu
    rectangle "binaryNumberUtility.py" as BinaryNumberUtility
  }

  package "Data Storage" {
    rectangle ".graphml Files" as GraphML
    rectangle "METADATA.json" as MetadataJson
    rectangle "METADATA.csv" as MetadataCsv
  }
}

QuantumSystem --> State
QuantumSystem --> Edge
QuantumSystem --> GraphML
Experiment --> QuantumSystem
Experiment --> Solver
Experiment --> MetadataJson
Experiment --> MetadataCsv

Solver <|-- EulerForward
Solver <|-- RichardsonSolver
Solver <|-- MonteCarloWanderer
SingleStepScheme <|-- EulerForward
SingleStepScheme <|-- RichardsonSolver

FileUtility --> GraphML
Quantities --> MetadataCsv
PlotChargeCurve --> MetadataCsv
Menu --> FileUtility
BinaryNumberUtility --> QuantumSystem
@enduml
