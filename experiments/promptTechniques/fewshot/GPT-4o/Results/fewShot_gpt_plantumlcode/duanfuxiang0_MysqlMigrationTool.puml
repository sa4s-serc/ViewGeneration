```plantuml
@startuml duanfuxiang0_MysqlMigrationTool
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User"

package "MySQL Source" {
  rectangle "Binlog" as binlog #orange
}

package "Incremental Data Migration Tool" {
  rectangle "incremental_data_migration.go" as IncrementalMigration #lightgreen
  rectangle "core/dao.go" as DAO #lightblue
  rectangle "BinlogParser" as BinlogParser #lightcoral
  rectangle "RowEventHandler" as RowEventHandler #lightyellow
}

package "MySQL Target" {
  database "Target Database" as TargetDB #lightgray
}

' ========== Connections ==========
User --> IncrementalMigration : Start Migration

' Binlog interactions
binlog --> IncrementalMigration : Stream Events
IncrementalMigration --> BinlogParser : Parse Events
BinlogParser --> RowEventHandler : Process Events

' Data handling
RowEventHandler --> DAO : Data Operations
DAO --> TargetDB : Apply Changes

@enduml
```