```plantuml
@startuml ingeniala_heybluekata
left to right direction

skinparam rectangle {
  BackgroundColor #f3f4f6
  Style roundrect
}

actor "User" as user

package "HeyBlue Application" {
  package "Frontend" {
    rectangle "Web" as web
    rectangle "Mobile" as mobile
  }

  package "Backend for Frontend (BFF)" {
    rectangle "Omnichannel BFF" as omnichannelBFF
    rectangle "BFF Mobile" as mobileBFF
    rectangle "BFF Web" as webBFF
  }

  package "Core Services" {
    rectangle "User Management" as userMgmt
    rectangle "Interaction & Gamification" as interaction
    rectangle "Commerce" as commerce
    rectangle "Content Management" as contentMgmt
    rectangle "Data Archiving & Analytics" as dataAnalytics
    rectangle "Notification & Messaging" as messaging
  }

  package "AWS Services" {
    rectangle "API Gateway" as apiGateway
    rectangle "Lambda" as lambda
    rectangle "DynamoDB" as dynamoDB
    rectangle "S3" as s3
    rectangle "CloudFront" as cloudFront
    rectangle "Cognito" as cognito
    rectangle "Kinesis" as kinesis
    rectangle "Athena" as athena
    rectangle "Glacier" as glacier
  }
}

user --> web
user --> mobile

web --> webBFF
mobile --> mobileBFF

webBFF --> omnichannelBFF
mobileBFF --> omnichannelBFF

omnichannelBFF --> apiGateway

apiGateway --> userMgmt
apiGateway --> interaction
apiGateway --> commerce
apiGateway --> contentMgmt
apiGateway --> dataAnalytics
apiGateway --> messaging

userMgmt --> cognito
interaction --> kinesis
commerce --> dynamoDB
contentMgmt --> s3
dataAnalytics --> athena
dataAnalytics --> glacier
messaging --> lambda
messaging --> kinesis
s3 --> cloudFront

@enduml
```