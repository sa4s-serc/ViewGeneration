```plantuml
@startuml EMERIC237_Restaurant-reservation-app
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "User" as User
actor "Admin" as Admin

package "Frontend (React)" <<frontend>> {
  rectangle "App.js" as App
  rectangle "Dashboard.js" as Dashboard
  rectangle "Layout.js" as Layout
  rectangle "Routes.js" as Routes
  rectangle "CreateReservation.js" as CreateReservation
  rectangle "ReservationForm.js" as ReservationForm
  rectangle "API Utils" as ApiUtils
  rectangle "DateTime Utils" as DateTimeUtils
  rectangle "ErrorAlert.js" as ErrorAlert

  App --> Layout
  Layout --> Routes
  Routes --> Dashboard
  Routes --> CreateReservation
  CreateReservation --> ReservationForm
  ReservationForm --> ApiUtils
  CreateReservation --> ErrorAlert
  Dashboard --> ApiUtils
  ApiUtils --> DateTimeUtils
}

package "Backend (Node.js/Express)" <<backend>> {
  rectangle "app.js" as AppJs
  rectangle "server.js" as ServerJs
  rectangle "Reservations Router" as ReservationsRouter
  rectangle "Reservations Controller" as ReservationsController
  rectangle "Reservations Service" as ReservationsService
  rectangle "Tables Router" as TablesRouter
  rectangle "Tables Controller" as TablesController
  rectangle "Tables Service" as TablesService
  rectangle "Error Handler" as ErrorHandler
  rectangle "Not Found Handler" as NotFoundHandler
  rectangle "Knex Connection" as KnexConnection
  rectangle "Migrations" as Migrations
  rectangle "Seeds" as Seeds

  AppJs --> ReservationsRouter
  AppJs --> TablesRouter
  ReservationsRouter --> ReservationsController
  ReservationsController --> ReservationsService
  TablesRouter --> TablesController
  TablesController --> TablesService
  AppJs --> ErrorHandler
  AppJs --> NotFoundHandler
  AppJs --> KnexConnection
  KnexConnection --> Migrations
  KnexConnection --> Seeds
}

database "PostgreSQL" <<db>> as PostgreSQL
ReservationsService --> PostgreSQL
TablesService --> PostgreSQL

User --> App
Admin --> App

@enduml
```