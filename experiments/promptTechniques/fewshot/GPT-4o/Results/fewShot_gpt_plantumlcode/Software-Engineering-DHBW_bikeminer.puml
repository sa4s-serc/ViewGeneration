```plantuml
@startuml Software-Engineering-DHBW_bikeminer
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam package {
  BackgroundColor #f5f5f5
  BorderColor black
}

package "Mobile Application" {
  package "Flutter App" {
    rectangle "Map\nPage" as MapPage
    rectangle "Login\nPage" as LoginPage
    rectangle "Wallet\nPage" as WalletPage
    rectangle "Rides\nPage" as RidesPage
    rectangle "API Connector" as ApiConnector
    rectangle "Storage Adapter" as StorageAdapter
  }

  package "Android App (Legacy)" {
    rectangle "MapsActivity"
    rectangle "GPS Tracking"
    rectangle "Reward System"
  }
}

package "Backend" {
  rectangle "FastAPI Server" {
    rectangle "User Management\nAPI" as UserAPI
    rectangle "Ride Management\nAPI" as RideAPI
    rectangle "JWT Authentication"
  }
  rectangle "MariaDB"
}

rectangle "Containerization" as Container {
  rectangle "Docker" as Docker
  rectangle "Docker Compose" as DockerCompose
}

rectangle "Data Flow" {
  [Data Acquisition]
  [Data Transmission]
}

package "Design Patterns" {
  rectangle "UI Theming"
  rectangle "Resource Qualification"
  rectangle "Data Binding"
  rectangle "Model-Schema-CRUD"
  rectangle "Repository Pattern"
  rectangle "DTO / Value Object"
  rectangle "Observer"
  rectangle "Delegate"
  rectangle "Factory"
  rectangle "Bloc / Provider"
}

' Mobile App interactions
MapPage --> ApiConnector : Send/Receive GPS Data
LoginPage --> ApiConnector : Authenticate User
WalletPage --> ApiConnector : Fetch BikeCoin Balance
RidesPage --> ApiConnector : Fetch Ride History
ApiConnector --> StorageAdapter : Store/Retrieve Local Data

' Android App interactions (Legacy)
MapsActivity --> GPS Tracking
GPS Tracking --> Reward System

' Backend interactions
ApiConnector --> FastAPI Server : REST API Calls
FastAPI Server --> UserAPI
FastAPI Server --> RideAPI
UserAPI --> MariaDB : User Data
RideAPI --> MariaDB : Ride Data

' Containerization
FastAPI Server --> Docker
MariaDB --> Docker
DockerCompose --> Docker

' Data Flow
[Data Acquisition] --> [Data Transmission]

@enduml
```