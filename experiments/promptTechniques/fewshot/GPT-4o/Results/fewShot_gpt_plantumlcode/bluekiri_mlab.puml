```plantuml
@startuml bluekiri_mlab
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "MLAB System" {
  
  package "Dashboard Component" {
    rectangle "Flask App (app.py)" as FlaskApp
    rectangle "Flask-Security" as FlaskSecurity
    rectangle "Repositories" as Repositories
    rectangle "Interactors" as Interactors
    rectangle "API Endpoints" as API
    rectangle "ZooKeeper" as ZooKeeper
    rectangle "MongoDB" as MongoDB
    rectangle "Configuration" as Config
    rectangle "Frontend UI" as Frontend

    FlaskApp --> FlaskSecurity
    FlaskApp --> Repositories
    FlaskApp --> Interactors
    FlaskApp --> API
    FlaskApp --> Config
    Interactors --> ZooKeeper
    Interactors --> MongoDB
    Frontend --> FlaskApp
  }

  package "Worker Service Component" {
    rectangle "Model Loading" as ModelLoading
    rectangle "ZooKeeper Integration" as ZKIntegration
    rectangle "Error Handling" as ErrorHandling
    rectangle "Logging" as Logging
    rectangle "HTTP API (Falcon)" as HTTPAPI
    rectangle "Configuration" as WorkerConfig

    ModelLoading --> ZKIntegration
    ModelLoading --> ErrorHandling
    ModelLoading --> Logging
    ZKIntegration --> WorkerConfig
    HTTPAPI --> ModelLoading
  }
  
  package "Docker & Deployment" {
    rectangle "Docker Compose" as DockerCompose
    rectangle "ZooKeeper" as ZK
    rectangle "MongoDB" as MDB
  }
  
  ZooKeeper --> ZKIntegration
  MongoDB --> ModelLoading
  DockerCompose --> FlaskApp
  DockerCompose --> HTTPAPI
  DockerCompose --> ZK
  DockerCompose --> MDB
}

@enduml
```