```plantuml
@startuml i5ting_stuq-koa
skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor black
  Style roundrect
}
left to right direction

actor "User"

package "Koa.js Application" {
  rectangle "Core Concepts" as Core
  rectangle "Asynchronous Operations" as AsyncOps
  rectangle "Middleware System" as Middleware
  rectangle "Database Integration\n(MongoDB + Mongoose)" as DBIntegration
  rectangle "HTTP Request Handling" as HTTPHandling
  rectangle "Session Management" as SessionMgmt
  rectangle "Testing\n(Ava)" as Testing
  rectangle "Deployment\n(PM2, Nginx, Alibaba Cloud)" as Deployment
  rectangle "MVC Architecture\n(Moa2)" as MVC
}

package "Infrastructure" {
  rectangle "Node.js\nRuntime" as NodeRuntime
  rectangle "MongoDB" as MongoDB
  rectangle "Nginx\nReverse Proxy" as Nginx
  rectangle "PM2" as PM2
  rectangle "Cloud Services\n(Alibaba Cloud)" as Cloud
}

' User interactions
User --> Core
User --> AsyncOps
User --> Middleware
User --> DBIntegration
User --> HTTPHandling
User --> SessionMgmt
User --> Testing
User --> Deployment
User --> MVC

' Application interactions
Core --> NodeRuntime
AsyncOps --> NodeRuntime
Middleware --> NodeRuntime
DBIntegration --> MongoDB
HTTPHandling --> NodeRuntime
SessionMgmt --> MongoDB
Testing --> NodeRuntime
Deployment --> PM2
Deployment --> Nginx
Deployment --> Cloud
MVC --> NodeRuntime

' Infrastructure interactions
NodeRuntime --> MongoDB
NodeRuntime --> Nginx
Nginx --> Cloud

@enduml
```