```plantuml
@startuml elloza_Android-Developer-Certification
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam shadowing false

package "Android Application" {
    [BaseApplication] as BaseApp
    [MainActivity] as MainActivity
    [MainPresenter] as MainPresenter
    [RibotsAdapter] as RibotsAdapter

    package "Data" {
        [DataManager] as DataManager
        [SyncService] as SyncService
        [DatabaseHelper] as DatabaseHelper
        [RibotsService] as RibotsService
        [Ribot] as Ribot
        [Profile] as Profile
        [Name] as Name
    }

    package "Dependency Injection" {
        [Dagger 2] as Dagger
        [Timber] as Timber
    }

    package "Testing" {
        [Mockito] as Mockito
        [Robolectric] as Robolectric
        [JUnit] as JUnit
        [Espresso] as Espresso
    }
}

BaseApp --> Dagger
BaseApp --> Timber

MainActivity --> MainPresenter
MainActivity --> RibotsAdapter
MainPresenter --> DataManager
RibotsAdapter --> MainActivity

DataManager --> SyncService
DataManager --> DatabaseHelper
DataManager --> RibotsService

RibotsService --> Ribot : uses
RibotsService --> Profile : uses
RibotsService --> Name : uses

DatabaseHelper --> Ribot
DatabaseHelper --> Profile
DatabaseHelper --> Name

Espresso --> MainActivity : tests
Mockito --> MainPresenter : tests
Robolectric --> MainActivity : tests
JUnit --> DataManager : tests

@enduml
```