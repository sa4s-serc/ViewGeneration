```plantuml
@startuml qnib_qframe

skinparam rectangle {
  BackgroundColor #f8f8f8
  BorderColor black
  Style roundrect
}
left to right direction

package "Core Components" {
  rectangle "Collectors" as Collectors
  rectangle "Filters" as Filters
  rectangle "Handlers" as Handlers
  rectangle "QChan" as QChan
}

package "System Interaction" {
  rectangle "System Call Wrappers" as SysCallWrappers
  rectangle "Syscall Abstraction" as SyscallAbstraction
}

package "Security" {
  rectangle "TLS Config" as TLSConfig
  rectangle "Key Management" as KeyManagement
}

package "Data Structures" {
  rectangle "grok patterns" as Grok
  rectangle "Metrics" as Metrics
  rectangle "ContainerStats" as ContainerStats
}

package "Configuration" {
  rectangle "go-ucfg" as GoUcfg
  rectangle "YAML Config" as YAMLConfig
}

package "Low-level System" {
  rectangle "Cgo" as Cgo
  rectangle "Code Generation" as CodeGen
}

package "API & Standards" {
  rectangle "JWS" as JWS
  rectangle "OCI Image Spec" as OCI
  rectangle "UUID" as UUID
  rectangle "SWAGGER.yaml" as Swagger
}

package "Plugins" {
  Collectors --> Filters
  Filters --> Handlers
}

QChan --> Collectors
QChan --> Filters
QChan --> Handlers

SysCallWrappers --> SyscallAbstraction

TLSConfig --> KeyManagement

GoUcfg --> YAMLConfig

Cgo <--> CodeGen

JWS --> OCI
JWS --> UUID
Swagger --> UUID

@enduml
