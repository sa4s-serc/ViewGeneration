```plantuml
@startuml NatalieLouise91_T3A2-Skemi-FrontEnd
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<services>> #d8f5d3
  BackgroundColor<<backend>> #fddddd
  BackgroundColor<<state>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React.js)" <<frontend>> {
  rectangle "App.js" as App
  rectangle "Navigation Bar" as Nav
  rectangle "Login Component" as Login
  rectangle "Registration Component" as Register
  rectangle "Occasion Components" {
    rectangle "CreateOccasion"
    rectangle "ViewOccasion"
    rectangle "OccasionList"
  }
  rectangle "Roster Components" {
    rectangle "CreateRoster"
    rectangle "ViewRoster"
    rectangle "EditRoster"
  }
}

package "Services Layer" <<services>> {
  rectangle "Auth Services" as AuthService
  rectangle "Occasion Services" as OccasionService
  rectangle "Roster Services" as RosterService
  rectangle "User Services" as UserService
}

package "State Management" <<state>> {
  rectangle "StateContext"
  rectangle "StateReducer"
}

package "Backend API (Rails)" <<backend>> {
  rectangle "Authentication API"
  rectangle "Occasion API"
  rectangle "Roster API"
  rectangle "User API"
}

App --> Nav
App --> Login
App --> Register
App --> "Occasion Components"
App --> "Roster Components"

Nav --> AuthService
Login --> AuthService
Register --> UserService
"Occasion Components" --> OccasionService
"Roster Components" --> RosterService

AuthService --> "Authentication API"
OccasionService --> "Occasion API"
RosterService --> "Roster API"
UserService --> "User API"

App --> StateContext
StateContext --> StateReducer
@enduml
```