```plantuml
@startuml takoko55_LectureLens
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "App.jsx" as App
  rectangle "SyllabusSearch.jsx" as SyllabusSearch
  rectangle "GlassCard.jsx" as GlassCard
  rectangle "LecturePage.jsx" as LecturePage
  rectangle "ReviewItem.jsx" as ReviewItem
  rectangle "Auth.jsx" as Auth
  rectangle "ReviewPost.jsx" as ReviewPost
  rectangle "useQueryReviews.jsx\nuseMutateReview.jsx" as QueryHooks
  rectangle "Zustand Store" as Zustand
  App --> SyllabusSearch
  SyllabusSearch --> GlassCard
  GlassCard --> LecturePage
  LecturePage --> ReviewItem
  LecturePage --> ReviewPost
  App --> Auth
  App --> QueryHooks
  ReviewPost --> Zustand
}

package "Backend (Go)" <<backend>> {
  rectangle "main.go" as Main
  rectangle "router/router.go" as Router
  rectangle "controller/" as Controller
  rectangle "usecase/" as Usecase
  rectangle "repository/" as Repository
  rectangle "model/" as Model
  rectangle "db/db.go" as DB
  rectangle "migrate/migrate.go" as Migrate
  Main --> Router
  Router --> Controller
  Controller --> Usecase
  Usecase --> Repository
  Repository --> Model
  DB --> Model
}

database "PostgreSQL" <<db>> as PostgreSQL
Repository --> PostgreSQL
@enduml
```