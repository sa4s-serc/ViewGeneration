```plantuml
@startuml securesecrets_shadeswap
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "ShadeSwap Ecosystem" {
  rectangle "LP Token Contract" as LPTC #lightblue
  rectangle "Staking Contract" as SC #lightgreen
  rectangle "AMM Pair Contract" as AMMPC #lightyellow
  rectangle "Factory Contract" as FC #lightpink
  rectangle "Router Contract" as RC #lightcoral
  rectangle "Admin Contract" as AC #lavender
  rectangle "Shared Utilities" as SU #lightgray

  LPTC -[dotted]-> SC : Interacts with
  SC -[dotted]-> AMMPC : Uses
  AMMPC -[dotted]-> RC : Calls
  RC -[dotted]-> AMMPC : Multi-hop swaps
  FC -[dotted]-> AMMPC : Deploys/Manages
  AC -[dotted]-> FC : Manages permissions
  SU -[dotted]-> LPTC : Provides utilities
  SU -[dotted]-> SC
  SU -[dotted]-> AMMPC
  SU -[dotted]-> FC
  SU -[dotted]-> RC

  note right of LPTC
    SNIP-20 Token operations
    - Mint/Burn
    - Transfer
    - Allowance
  end note

  note right of SC
    Handles staking operations
    - Multi-rewards
    - Claims
    - Unstaking
  end note

  note right of AMMPC
    Manages liquidity and swaps
    - Token swaps
    - Fee calculation
  end note

  note right of FC
    Deploys AMM Pair Contracts
    - Enforces code hash
    - Security verification
  end note

  note right of RC
    Orchestrates trades
    - Multi-hop swaps
    - Callbacks
  end note

  note right of AC
    Centralizes control
    - Admin permissions
  end note

  note right of SU
    Shared data structures
    - Interfaces
    - Utility functions
  end note
}

@enduml
