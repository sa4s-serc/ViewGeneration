```plantuml
@startuml arkaneshiro_Sound-Zone
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction
skinparam defaultTextAlignment center

actor User

package "Frontend (React/Redux)" {
  rectangle "App.js\n(Routing, Global State)" as App
  rectangle "NavBar.js\n(Navigation & Search)" as NavBar
  rectangle "Home.js\n(Login & Registration)" as Home
  rectangle "Profile.js\n(User Profile & Follow)" as Profile
  rectangle "Dashboard.js\n(Feed of Followed Users)" as Dashboard
  rectangle "SoundDetail.js\n(Sound Information)" as SoundDetail
  rectangle "Sound.js\n(Playback Controls)" as Sound
  rectangle "SoundBar.js\n(Global Audio Player)" as SoundBar
  rectangle "Upload.js\n(Sound Uploads)" as Upload
}

package "Backend (Node.js/Express)" {
  rectangle "Auth API" as AuthAPI
  rectangle "User API" as UserAPI
  rectangle "Sound API" as SoundAPI
}

package "Storage (Cloudinary)" {
  rectangle "Audio & Image Storage" as Cloudinary
}

package "Database (PostgreSQL)" {
  rectangle "User Data" as UserDB
  rectangle "Sound Data" as SoundDB
}

User --> Home : Login/Register
Home --> AuthAPI : Authenticate
AuthAPI --> UserDB : Verify Credentials
User --> NavBar : Search Users
NavBar --> UserAPI : Search Request
User --> Dashboard : View Feed
Dashboard --> SoundAPI : Fetch Sounds
SoundAPI --> SoundDB : Get Sound Data
User --> Profile : View/Follow Users
Profile --> UserAPI : Fetch/Update Profile
User --> SoundDetail : Play Sound
SoundDetail --> SoundAPI : Get Sound Details
User --> Upload : Upload Sound
Upload --> Cloudinary : Upload Files
@enduml
```