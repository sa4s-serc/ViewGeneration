@startuml ndsev_zswag

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

rectangle "zswag.gen" as gen #LightBlue {
  [OpenAPI YAML Generator]
}

rectangle "OAServer" as server #LightGreen {
  [Flask/Connexion Server]
  [Request Parser]
  [Response Serializer]
  [Controller Integration]
}

rectangle "Python OAClient" as pyclient #LightYellow {
  [Generic Python Client]
  [HTTP Configuration]
}

rectangle "C++ OAClient (zswagcl)" as cppclient #LightPink {
  [C++ Client Library]
  [Python Bindings (pyzswagcl)]
}

rectangle "httpcl" as httpcl #LightGray {
  [cpp-httplib Wrapper]
  [Proxy Support]
  [OS Secret Storage]
}

rectangle "Zserio Services" as zserio #LightCyan

rectangle "OpenAPI Specification" as openapi #Orange

gen --> openapi : generates
zserio --> gen : input
openapi --> server : defines endpoints
openapi --> pyclient : defines interface
openapi --> cppclient : defines interface

server --> zserio : hosts
pyclient --> server : interacts with
cppclient --> server : interacts with
cppclient --> httpcl : uses
pyclient ..> httpcl : may use

note right of gen
  CLI tool for generating
  OpenAPI from Zserio
end note

note bottom of server
  Hosts Zserio services
  as OpenAPI endpoints
end note

note bottom of pyclient
  Interacts with Zserio
  services via HTTP/REST
end note

note bottom of cppclient
  C++ client with
  Python bindings
end note

note bottom of httpcl
  Low-level HTTP
  communication
end note

@enduml