@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  ArrowColor #333333
}

actor "User" as user

cloud "Azure" {
  rectangle "Azure Traffic Manager" as traffic_manager
  rectangle "Azure CDN" as cdn
  
  rectangle "Region 1" {
    rectangle "Web App" as webapp1 {
      rectangle ".NET Core Backend" as backend1
      rectangle "Angular Frontend" as frontend1
    }
    database "Azure SQL Server" as sql1
    database "Azure Cosmos DB" as cosmos1
    rectangle "Azure Redis Cache" as redis1
    rectangle "Azure Search" as search1
    rectangle "Azure Service Bus" as servicebus1
    rectangle "WebJob" as webjob1
  }
  
  rectangle "Region 2" {
    rectangle "Web App" as webapp2 {
      rectangle ".NET Core Backend" as backend2
      rectangle "Angular Frontend" as frontend2
    }
    database "Azure SQL Server" as sql2
    database "Azure Cosmos DB" as cosmos2
    rectangle "Azure Redis Cache" as redis2
    rectangle "Azure Search" as search2
    rectangle "Azure Service Bus" as servicebus2
    rectangle "WebJob" as webjob2
  }
}

user --> traffic_manager
traffic_manager --> webapp1
traffic_manager --> webapp2
cdn --> frontend1
cdn --> frontend2

backend1 --> sql1
backend1 --> cosmos1
backend1 --> redis1
backend1 --> search1
backend1 --> servicebus1

backend2 --> sql2
backend2 --> cosmos2
backend2 --> redis2
backend2 --> search2
backend2 --> servicebus2

webjob1 --> servicebus1
webjob2 --> servicebus2

sql1 <--> sql2 : Geo-replication
cosmos1 <--> cosmos2 : Geo-replication

@enduml