@startuml JuliaParallel_DagScheduler.jl

skinparam component {
  BackgroundColor LightSkyBlue
  BorderColor Black
  ArrowColor Black
}

[DagScheduler.jl] as DagScheduler
[Dagger.jl] as Dagger
[RemoteMonitor] as RemoteMonitor
[FoundationDB] as FoundationDB

package "Core Components" {
  [RunEnv] as RunEnv
  [Scheduler] as Scheduler
  [ExecutionEngine] as ExecutionEngine
  [TaskQueue] as TaskQueue
}

package "MetaStore Implementations" {
  [ShmemMetaStore] as ShmemMetaStore
  [SimpleMetaStore] as SimpleMetaStore
  [FDBMetaStore] as FDBMetaStore
}

package "Execution Tiers" {
  [Node] as Node
  [Broker] as Broker
  [Executor] as Executor
}

DagScheduler --> Dagger : integrates with
DagScheduler --> RemoteMonitor : hooks for
DagScheduler --> FoundationDB : optional persistence

DagScheduler --> RunEnv
RunEnv --> Scheduler
RunEnv --> ExecutionEngine
ExecutionEngine --> TaskQueue

Scheduler --> ShmemMetaStore
Scheduler --> SimpleMetaStore
Scheduler --> FDBMetaStore

ExecutionEngine --> Node
Node --> Broker
Broker --> Executor

@enduml