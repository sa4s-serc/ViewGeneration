@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Eigen Core" {
  rectangle "Expression Templates" as ET
  rectangle "Dense Linear Algebra" as DLA
  rectangle "Sparse Linear Algebra" as SLA
  rectangle "Memory Management" as MM
  rectangle "SIMD Vectorization" as SIMD
}

package "Modules" {
  rectangle "Geometry" as GEO
  rectangle "Eigenvalues" as EV
  rectangle "Sparse" as SP
}

package "Decompositions" {
  rectangle "LU" as LU
  rectangle "Cholesky" as CH
  rectangle "QR" as QR
  rectangle "SVD" as SVD
}

package "Solvers" {
  rectangle "Linear Solvers" as LS
  rectangle "Eigensolvers" as ES
  rectangle "Iterative Solvers" as IS
}

package "External Integration" {
  rectangle "BLAS" as BLAS
  rectangle "LAPACK" as LAPACK
}

package "Unsupported" {
  rectangle "Tensor Operations" as TO
  rectangle "Matrix Functions" as MF
  rectangle "NonLinear Optimization" as NLO
}

ET --> DLA
ET --> SLA
MM --> DLA
MM --> SLA
SIMD --> DLA
SIMD --> SLA

DLA --> LU
DLA --> CH
DLA --> QR
DLA --> SVD
SLA --> SP

LU --> LS
CH --> LS
QR --> LS
SVD --> LS
SP --> IS

DLA --> GEO
DLA --> EV
SLA --> EV

EV --> ES

DLA ..> BLAS
DLA ..> LAPACK
SLA ..> BLAS
SLA ..> LAPACK

ET ..> TO
DLA ..> MF
DLA ..> NLO
@enduml