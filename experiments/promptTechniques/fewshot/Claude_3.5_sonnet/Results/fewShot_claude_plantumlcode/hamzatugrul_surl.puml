@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as user
actor "Admin" as admin

rectangle "Nginx Load Balancer" as nginx

rectangle "App Instance 1" as app1 {
  rectangle "ShortURLController" as controller1
  rectangle "UrlShortenerService" as service1
  rectangle "ShortUrlRepository" as repo1
  rectangle "KeyGenerator" as keygen1
}

rectangle "App Instance 2" as app2 {
  rectangle "ShortURLController" as controller2
  rectangle "UrlShortenerService" as service2
  rectangle "ShortUrlRepository" as repo2
  rectangle "KeyGenerator" as keygen2
}

database "MongoDB" as mongodb
database "Redis Cache" as redis

user --> nginx : HTTP Request
admin --> nginx : HTTP Request (Auth)
nginx --> app1
nginx --> app2

controller1 --> service1
service1 --> repo1
service1 --> keygen1
repo1 --> mongodb : Read/Write
repo1 <--> redis : Cache

controller2 --> service2
service2 --> repo2
service2 --> keygen2
repo2 --> mongodb : Read/Write
repo2 <--> redis : Cache

@enduml