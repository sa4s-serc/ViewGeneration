@startuml
skinparam backgroundColor #EEEBDC
skinparam handwritten true
skinparam componentStyle rectangle

!define RECTANGLE class

package "Frontend (Vue.js)" {
  RECTANGLE "App.vue" as App
  RECTANGLE "main.js" as Main
  RECTANGLE "Vue Router" as Router
  RECTANGLE "Vuex Store" as Store {
    RECTANGLE "userStore" as UserStore
    RECTANGLE "searchStore" as SearchStore
  }
  RECTANGLE "Components" as Components
  RECTANGLE "Views" as Views
  RECTANGLE "API Layer" as API {
    RECTANGLE "auth.js" as AuthAPI
    RECTANGLE "user.js" as UserAPI
    RECTANGLE "search.js" as SearchAPI
    RECTANGLE "news.js" as NewsAPI
    RECTANGLE "inquiry.js" as InquiryAPI
  }
  RECTANGLE "Utils" as Utils {
    RECTANGLE "cookies.js" as Cookies
    RECTANGLE "eventBus.js" as EventBus
    RECTANGLE "filters.js" as Filters
  }
}

RECTANGLE "Kakao Maps API" as KakaoMaps
RECTANGLE "Backend API" as BackendAPI

Main --> App
Main --> Router
Main --> Store
Main --> Components
App --> Router
Router --> Views
Views --> Components
Components --> Store
Components --> API
Store --> API
API --> BackendAPI
Components --> KakaoMaps
Components --> Utils

note right of API
  Axios for HTTP requests
end note

note bottom of Store
  Centralized state management
end note

note top of Router
  Navigation management
end note

note left of Components
  Reusable UI elements
end note

note right of Views
  Page components
end note

note bottom of Utils
  Helper functions
end note

@enduml