@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Node.js Data Generation" as NodeGen {
  rectangle "create-product-data.js" as CreateData
  rectangle "data-util.js" as DataUtil
  rectangle "save-product-reviews.js" as SaveReviews
}

rectangle "Database Interaction" as DBInteraction {
  rectangle "database-util.js" as DBUtil
  rectangle "query-constants.js" as QueryConst
}

rectangle "Data Warehouses" as Warehouses {
  database "IBM Db2 Warehouse" as Db2
  database "Netezza Performance Server" as Netezza
}

rectangle "IBM Cognos Analytics" as Cognos {
  rectangle "Data Modules" as DataModules
  rectangle "Dashboards" as Dashboards
}

User --> NodeGen : Initiates data generation
CreateData --> DataUtil : Uses
CreateData --> DBInteraction : Outputs data
SaveReviews --> DBInteraction : Uploads reviews

DBInteraction --> Warehouses : Loads data

Cognos --> Warehouses : Connects and queries
DataModules --> Dashboards : Provides data for

User --> Cognos : Interacts with dashboards

@enduml