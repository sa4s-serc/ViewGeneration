@startuml shawntabrizi_Ethereum-Twitter-Bounty

skinparam rectangle {
  BackgroundColor<<smart_contract>> #CCFFCC
  BackgroundColor<<external>> #FFCCCC
  BackgroundColor<<frontend>> #CCCCFF
  BorderColor black
  Style roundrect
}

rectangle "User Interface" <<frontend>> {
  [HTML/CSS]
  [JavaScript (app.js)]
  [jQuery]
  [Bootstrap]
}

rectangle "Web3 Integration" <<frontend>> {
  [web3.js]
  [TruffleContract]
}

rectangle "Smart Contracts" <<smart_contract>> {
  [TwitterBounty.sol]
  [TwitterOracle.sol]
}

rectangle "External Services" <<external>> {
  [Provable (Oraclize)]
  [Twitter API]
}

rectangle "Development & Testing" {
  [Truffle]
  [Ganache]
}

rectangle "Ethereum Blockchain" {
  [Ethereum Network]
}

[JavaScript (app.js)] --> [web3.js]
[JavaScript (app.js)] --> [TruffleContract]
[web3.js] --> [Ethereum Network]
[TruffleContract] --> [TwitterBounty.sol]
[TruffleContract] --> [TwitterOracle.sol]
[TwitterBounty.sol] --> [TwitterOracle.sol]
[TwitterOracle.sol] --> [Provable (Oraclize)]
[Provable (Oraclize)] --> [Twitter API]
[Truffle] --> [TwitterBounty.sol]
[Truffle] --> [TwitterOracle.sol]
[Truffle] --> [Ganache]

@enduml