@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  ArrowColor #222222
  BorderColor #666666
}

rectangle "Client Application" as Client

package "gocloud" {
  interface "Gocloud" as GocloudInterface
  rectangle "CloudProvider Factory" as CloudProviderFactory
  
  package "Service Interfaces" {
    interface "Compute" as ComputeInterface
    interface "Storage" as StorageInterface
    interface "Container" as ContainerInterface
    interface "DNS" as DNSInterface
    interface "LoadBalancer" as LBInterface
    interface "Serverless" as ServerlessInterface
  }
  
  package "Provider Implementations" {
    rectangle "AWS" as AWS
    rectangle "Google Cloud" as GCP
    rectangle "Azure" as Azure
    rectangle "DigitalOcean" as DO
    rectangle "Alibaba Cloud" as Ali
    rectangle "Vultr" as Vultr
    rectangle "OpenStack" as OpenStack
  }
  
  package "Authentication" {
    rectangle "Auth Modules" as AuthModules
  }
}

Client --> CloudProviderFactory : requests provider
CloudProviderFactory --> GocloudInterface : creates
GocloudInterface --> ComputeInterface
GocloudInterface --> StorageInterface
GocloudInterface --> ContainerInterface
GocloudInterface --> DNSInterface
GocloudInterface --> LBInterface
GocloudInterface --> ServerlessInterface

AWS ..|> GocloudInterface
GCP ..|> GocloudInterface
Azure ..|> GocloudInterface
DO ..|> GocloudInterface
Ali ..|> GocloudInterface
Vultr ..|> GocloudInterface
OpenStack ..|> GocloudInterface

AWS --> AuthModules
GCP --> AuthModules
Azure --> AuthModules
DO --> AuthModules
Ali --> AuthModules
Vultr --> AuthModules
OpenStack --> AuthModules

@enduml