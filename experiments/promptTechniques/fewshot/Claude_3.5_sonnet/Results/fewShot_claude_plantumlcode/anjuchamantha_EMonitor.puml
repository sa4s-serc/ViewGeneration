@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Sensors" as sensors {
  [DHT11\n(Temp/Humidity)] as dht11
  [BMP180/BMP085\n(Pressure)] as bmp
  [LDR\n(Light Intensity)] as ldr
}

rectangle "ESP32 Device" as esp32 {
  [Sensor Reading\nModule] as reading
  [Data Processing\n& Buffering] as processing
  [XML Formatter] as xml
  [WiFi Manager] as wifi
  [HTTP Client] as http
  [Email Client] as email
  [OLED Display\nController] as oled
}

cloud "Internet" as internet {
  [NTP Server] as ntp
  [Backend Server] as server
  [SMTP Server] as smtp
}

dht11 --> reading
bmp --> reading
ldr --> reading

reading --> processing
processing --> xml
xml --> http
processing --> oled

wifi --> internet : Connect
ntp --> wifi : Time Sync
http --> server : Send Data
email --> smtp : Send Alerts

@enduml