@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Client" as client

rectangle "Apigee API Management Platform" {
  rectangle "API Proxies" {
    rectangle "CDS Banking APIs" as cdsApis
    rectangle "OIDC Proxy" as oidcProxy
    rectangle "ConsentMgmtWithKVM Proxy" as consentProxy
    rectangle "Dynamic Client Registration" as clientReg
    rectangle "Admin APIs" as adminApis
  }
  
  rectangle "Shared Flows" as sharedFlows
  
  rectangle "Key Value Maps (KVM)" as kvm
  
  rectangle "Hosted Target" {
    rectangle "Mock OIDC Provider" as mockOidc
  }
}

rectangle "External Systems" {
  rectangle "External OIDC Provider" as extOidc
  rectangle "CDR Register" as cdrRegister
}

rectangle "Additional Solutions" {
  rectangle "Metrics Service" as metricsService
  database "Apigee Analytics" as analytics
}

client --> cdsApis
client --> oidcProxy
client --> consentProxy
client --> clientReg

cdsApis --> sharedFlows
oidcProxy --> sharedFlows
consentProxy --> sharedFlows
clientReg --> sharedFlows
adminApis --> sharedFlows

sharedFlows --> kvm

oidcProxy <--> extOidc
oidcProxy <--> mockOidc

clientReg <--> cdrRegister
adminApis <--> cdrRegister

metricsService --> analytics
adminApis --> metricsService

@enduml