@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

cloud "Google Cloud Platform" {
  rectangle "Google Kubernetes Engine (GKE)" {
    package "Kubernetes Cluster" {
      rectangle "Ingress Controller" as ingress
      
      rectangle "Frontend (Next.js)" as frontend
      rectangle "API (Python Flask)" as api
      rectangle "Metrics API (Node.js)" as metrics
      
      database "MongoDB" as mongodb
      queue "RabbitMQ" as rabbitmq
      
      rectangle "cert-manager" as certmanager
    }
  }
}

actor "User" as user

rectangle "Positionstack API" as positionstack
rectangle "Let's Encrypt" as letsencrypt

user --> ingress : HTTPS
ingress --> frontend
ingress --> api
ingress --> metrics

frontend <--> api : REST/WebSocket
api --> rabbitmq : Publish events
metrics <-- rabbitmq : Consume events

api <--> mongodb : Read/Write
metrics <--> mongodb : Read/Write

api --> positionstack : Geocoding

certmanager <--> letsencrypt : ACME

note right of frontend
  Client-side prediction
  with TensorFlow.js
end note

note right of api
  Server-side prediction
  with OpenCV
end note

note right of metrics
  Aggregates data for
  Grafana visualization
end note

@enduml