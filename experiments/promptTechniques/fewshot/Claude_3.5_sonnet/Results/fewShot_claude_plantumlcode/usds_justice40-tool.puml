@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as user

rectangle "Client (React/Gatsby)" as client {
  [J40Map] as map
  [MapInfoPanel] as panel
  [AreaDetail] as detail
}

rectangle "Data Pipeline" as pipeline {
  [ETL Runner] as etl
  [Score Runner] as score
  [Data Validator] as validator
}

rectangle "Map Tile Generation" as tiles {
  [Tippecanoe] as tippecanoe
}

cloud "Data Sources" as sources {
  [Census]
  [FEMA]
  [EPA]
  [First Street Foundation]
}

database "S3 Data Lake" as s3

user --> client : Interacts

client --> s3 : Fetches tiles\nand data

pipeline --> sources : Extracts data
pipeline --> s3 : Stores processed\ndata and scores

etl --> validator : Validates data
etl --> score : Triggers scoring

score --> s3 : Stores scores

s3 --> tiles : Provides GeoJSON
tiles --> s3 : Stores map tiles

@enduml