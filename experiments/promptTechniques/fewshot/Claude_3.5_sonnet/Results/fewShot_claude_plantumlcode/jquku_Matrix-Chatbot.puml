@startuml jquku_Matrix-Chatbot

skinparam componentStyle rectangle
skinparam linetype ortho

actor User
component "Matrix Homeserver" as MatrixServer

package "Matrix Chatbot" {
  [main.py] as Main
  [config.py] as Config
  [message_evaluation.py] as MessageEval
  [nlp.py] as NLP
  [response_management.py] as ResponseMgmt
  [database_service.py] as DBService
  
  package "Knowledge Acquisition" {
    [index_evaluation.py] as IndexEval
    [small_talk_evaluation.py] as SmallTalkEval
    [organisation_evaluation.py] as OrgEval
  }
}

database "PostgreSQL" as DB

User --> MatrixServer : sends message
MatrixServer --> Main : event
Main --> Config : read config
Main --> MessageEval : process message
MessageEval --> NLP : standardize input
MessageEval --> DBService : query knowledge
ResponseMgmt --> DBService : retrieve/update stats
Main --> ResponseMgmt : generate response
ResponseMgmt --> Main : formatted response
Main --> MatrixServer : send response

IndexEval --> DBService : store scraped data
SmallTalkEval --> DBService : store small talk
OrgEval --> DBService : store org info

DBService --> DB : CRUD operations

note right of IndexEval
  Web scraping
end note

note right of SmallTalkEval
  Parse small_talk.txt
end note

note right of OrgEval
  Parse organisation.txt
end note

@enduml