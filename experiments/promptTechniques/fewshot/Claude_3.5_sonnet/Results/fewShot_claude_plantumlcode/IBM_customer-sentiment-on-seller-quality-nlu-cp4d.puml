@startuml
skinparam backgroundColor #EEEBDC
skinparam handwritten true
skinparam defaultTextAlignment center

actor User

rectangle "Jupyter Notebook" as Notebook {
    (Load Data from Db2) as LoadData
    (Preprocess Data) as Preprocess
    (Sentiment Analysis) as SentimentAnalysis
    (Calculate Seller Ratings) as CalculateRatings
    (Generate Visualization Dataset) as GenerateDataset
}

cloud "Watson NLU" as WatsonNLU
database "Db2 Database" as Db2
rectangle "Embedded Dashboard" as Dashboard

User -> Notebook : Execute
LoadData -> Db2 : Extract Data
LoadData --> Preprocess : Raw Data
Preprocess --> SentimentAnalysis : Cleaned Data
SentimentAnalysis <--> WatsonNLU : API Calls
SentimentAnalysis --> CalculateRatings : Sentiment Scores
CalculateRatings --> GenerateDataset : Seller Ratings
GenerateDataset --> Dashboard : Visualization Data
Dashboard --> User : View Results

@enduml