@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

package "VueFlux" {
  rectangle "Store" as Store
  rectangle "State" as State
  rectangle "Actions" as Actions
  rectangle "Mutations" as Mutations
  rectangle "Computed" as Computed
  rectangle "Executor" as Executor
}

package "VueFluxReactive" {
  rectangle "Variable" as Variable
  rectangle "Constant" as Constant
  rectangle "Sink" as Sink
  rectangle "Signal" as Signal
  rectangle "Binder" as Binder
}

rectangle "UI Components" as UI

Store --> State : manages
Store --> Actions : dispatches
Store --> Mutations : commits
Store --> Computed : derives

Actions --> Mutations : trigger
Mutations --> State : modify
Computed --> State : reads

Variable --> Signal : emits
Constant --> Signal : emits
Sink --> Signal : produces

Signal --> Binder : binds to
Binder --> UI : updates

UI --> Actions : triggers
UI --> Computed : observes

Executor --> Actions : controls execution of

@enduml