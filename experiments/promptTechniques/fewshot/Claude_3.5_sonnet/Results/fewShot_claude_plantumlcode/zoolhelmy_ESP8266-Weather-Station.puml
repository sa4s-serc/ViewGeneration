@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as user

rectangle "ESP8266 NodeMCU" as esp8266 {
  [Sensors] as sensors
  [MQTT Client] as mqttClient
  [HTTP Server] as httpServer
}

cloud "Internet" as internet {
  [ThingSpeak] as thingspeak
  [GitHub] as github
}

rectangle "OpenWRT Router" as openwrt {
  [Mosquitto Broker] as mosquitto
  [Collectd] as collectd
  [RRDTool] as rrdtool
  [Cron Job] as cronjob
}

user --> httpServer : Access real-time readings
sensors --> mqttClient : Collect data
mqttClient --> internet : Publish to ThingSpeak
mqttClient --> mosquitto : Publish locally
mosquitto --> collectd : Subscribe and process
collectd --> rrdtool : Update database
cronjob --> rrdtool : Generate graphs
cronjob --> github : Push graphs

@enduml