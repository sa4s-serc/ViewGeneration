@startuml
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

package "Client" {
    [Qt GUI] as GUI
    [Client Socket] as ClientSocket
    [Pokemon Factory] as PokemonFactory
    [ORM] as ClientORM
}

package "Server" {
    [Server Socket] as ServerSocket
    [Dispatcher] as Dispatcher
    [Game Logic] as GameLogic
    [ORM] as ServerORM
}

database "SQLite" as DB

[JSON] as JSON

GUI --> ClientSocket : uses
GUI --> PokemonFactory : creates Pokemon
ClientSocket --> JSON : serializes/deserializes
ServerSocket --> JSON : serializes/deserializes
ClientSocket <--> ServerSocket : communicates
ServerSocket --> Dispatcher : routes requests
Dispatcher --> GameLogic : executes game actions
GameLogic --> ServerORM : persists data
ClientORM --> DB : reads/writes
ServerORM --> DB : reads/writes

note right of GUI
  Includes:
  - Login (Widget)
  - Game Lobby
  - Battle UI (FightWidget)
  - Bag Management
end note

note right of GameLogic
  Includes:
  - Pokemon classes
  - Battle mechanics
  - User management
end note

note bottom of DB
  Stores:
  - User data
  - Pokemon info
  - Game state
end note

@enduml