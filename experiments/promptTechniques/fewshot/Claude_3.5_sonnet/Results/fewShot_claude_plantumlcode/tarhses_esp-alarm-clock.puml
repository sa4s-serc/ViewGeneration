@startuml tarhses_esp-alarm-clock

skinparam backgroundColor #EEEBDC
skinparam handwritten true
skinparam sequence {
    ArrowColor DeepSkyBlue
    ActorBorderColor DeepSkyBlue
    LifeLineBorderColor blue
    LifeLineBackgroundColor #A9DCDF
    
    ParticipantBorderColor DeepSkyBlue
    ParticipantBackgroundColor DodgerBlue
    ParticipantFontName Impact
    ParticipantFontSize 17
    ParticipantFontColor #A9DCDF
    
    ActorBackgroundColor aqua
    ActorFontColor DeepSkyBlue
    ActorFontSize 17
    ActorFontName Aapex
}

actor User
participant "Main Task" as Main
participant "Alarm Task" as Alarm
participant "Network Task" as Network
participant "Display Task" as Display
participant "Sound Task" as Sound
participant "Potentiometer Task" as Pot
participant "Storage Task" as Storage

User -> Main : Power On
activate Main

Main -> Storage : Initialize
activate Storage
Storage --> Main : SD Card Mounted
deactivate Storage

Main -> Network : Connect WiFi
activate Network
Network --> Main : Connected
Network -> Network : Sync Time (SNTP)
deactivate Network

Main -> Pot : Initialize
activate Pot
Pot -> Storage : Load Calibration
Storage --> Pot : Calibration Data
Pot --> Main : Ready
deactivate Pot

Main -> Sound : Initialize
activate Sound
Sound -> Storage : List Audio Files
Storage --> Sound : Audio Files List
Sound --> Main : Ready
deactivate Sound

Main -> Display : Initialize
activate Display
Display --> Main : Ready
deactivate Display

Main -> Alarm : Initialize
activate Alarm

loop Every Second
    Network -> Alarm : Current Time
    Alarm -> Display : Update Time
    Display -> Display : Refresh Screen
end

User -> Pot : Adjust Alarm Time
Pot -> Alarm : New Alarm Time
Alarm -> Display : Update Alarm Time

User -> Alarm : Toggle Alarm Switch
alt Alarm Activated
    Alarm -> Display : Show Alarm Icon
else Alarm Deactivated
    Alarm -> Display : Hide Alarm Icon
end

loop Check Alarm
    Alarm -> Alarm : Compare Current Time
    alt Alarm Time Reached
        Alarm -> Sound : Play Alarm
        activate Sound
        Sound -> Storage : Get Random Audio
        Storage --> Sound : Audio File
        Sound -> Sound : Play Audio
    end
end

User -> Alarm : Press Snooze/Stop Button
alt Snooze
    Alarm -> Sound : Pause Audio
    Alarm -> Alarm : Set Snooze Timer
else Stop
    Alarm -> Sound : Stop Audio
    deactivate Sound
end

@enduml