@startuml YashwantChauhan_SDL

skinparam rectangle {
  BackgroundColor #EEEBDC
  ArrowColor #222222
  BorderColor #666666
}

actor User
rectangle "Web Browser" as Browser

rectangle "Django Application" {
  rectangle "URL Dispatcher" as URLDispatcher
  rectangle "Views" {
    rectangle "Home View" as HomeView
    rectangle "Signup View" as SignupView
    rectangle "Dashboard View" as DashboardView
    rectangle "Upload View" as UploadView
    rectangle "Result View" as ResultView
  }
  rectangle "Models" {
    database "User Model" as UserModel
    database "History Model" as HistoryModel
    database "Result Model" as ResultModel
  }
  rectangle "ML Classifier" as MLClassifier
}

database "SQLite Database" as DB

User -> Browser : Interacts
Browser -> URLDispatcher : HTTP Request

URLDispatcher -> HomeView : Route to Home
URLDispatcher -> SignupView : Route to Signup
URLDispatcher -> DashboardView : Route to Dashboard
URLDispatcher -> UploadView : Route to Upload
URLDispatcher -> ResultView : Route to Results

HomeView --> Browser : Render Home Page
SignupView --> UserModel : Create User
SignupView --> Browser : Render Signup Page
DashboardView --> HistoryModel : Fetch History
DashboardView --> Browser : Render Dashboard
UploadView --> MLClassifier : Process Upload
UploadView --> ResultModel : Save Results
UploadView --> Browser : Render Upload Page
ResultView --> ResultModel : Fetch Results
ResultView --> Browser : Render Results Page

UserModel <--> DB : CRUD Operations
HistoryModel <--> DB : CRUD Operations
ResultModel <--> DB : CRUD Operations

MLClassifier --> ResultModel : Classification Results

@enduml