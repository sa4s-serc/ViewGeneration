@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Client" as client

package "Product Mixer" {
  rectangle "ProductPipeline" as productPipeline
  rectangle "MixerPipeline" as mixerPipeline
  rectangle "RecommendationPipeline" as recPipeline
  rectangle "CandidatePipeline" as candidatePipeline
}

package "Components" {
  rectangle "Candidate Sources" as candidateSources
  rectangle "Feature Hydrators" as featureHydrators
  rectangle "Filters" as filters
  rectangle "Gates" as gates
  rectangle "Scorers" as scorers
  rectangle "Transformers" as transformers
  rectangle "Cursors" as cursors
}

rectangle "Navi Serving Server" as naviServer

package "Data Structures" {
  rectangle "Candidates" as candidates
  rectangle "Features" as features
  rectangle "Queries" as queries
  rectangle "Presentation Models" as presentationModels
}

rectangle "Cr-Mixer" as crMixer
rectangle "Follow Recommendations Service (FRS)" as frs
rectangle "Home Mixer" as homeMixer

database "Data Sources" {
  [User Signal Service (USS)]
  [Real Graph]
  [Earlybird]
  [TweetyPie]
  [Manhattan]
  [Memcached]
  [Strato]
}

client --> productPipeline

productPipeline --> mixerPipeline
productPipeline --> recPipeline
productPipeline --> candidatePipeline

mixerPipeline --> candidateSources
mixerPipeline --> featureHydrators
mixerPipeline --> filters
mixerPipeline --> gates
mixerPipeline --> scorers
mixerPipeline --> transformers
mixerPipeline --> cursors

candidateSources --> crMixer
candidateSources --> frs
candidateSources --> homeMixer

crMixer --> [Earlybird]
crMixer --> [Real Graph]
frs --> [Real Graph]
homeMixer --> [TweetyPie]

featureHydrators --> [User Signal Service (USS)]
featureHydrators --> [Manhattan]
featureHydrators --> [Memcached]
featureHydrators --> [Strato]

scorers --> naviServer

candidates --> presentationModels
features --> presentationModels
queries --> presentationModels

@enduml