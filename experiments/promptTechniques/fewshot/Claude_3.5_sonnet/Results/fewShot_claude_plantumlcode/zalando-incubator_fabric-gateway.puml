@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "API Client" as client

rectangle "Kubernetes Cluster" {
  rectangle "Fabric Gateway Operator" as operator {
    [FabricGateway CRD Controller] as crdController
    [Ingress Derivation Chain] as derivationChain
    [Webhook Handler] as webhook
    [StackSet Operations] as stacksetOps
  }
  
  rectangle "Skipper" as skipper
  
  database "Kubernetes API" as k8sAPI
  
  rectangle "Backend Services" as backends {
    [Service 1]
    [Service 2]
    [Service N]
  }
}

rectangle "Zalando IAM" as iam

client --> skipper : API Request
skipper --> backends : Route Request

crdController --> k8sAPI : Watch FabricGateway Resources
crdController --> derivationChain : Process FabricGateway
derivationChain --> k8sAPI : Create/Update Ingress
webhook --> k8sAPI : Validate FabricGateway
stacksetOps --> k8sAPI : Watch StackSet Changes

skipper --> iam : Authenticate/Authorize
@enduml