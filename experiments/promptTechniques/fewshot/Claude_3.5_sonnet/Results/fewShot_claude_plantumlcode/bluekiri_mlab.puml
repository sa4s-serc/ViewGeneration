@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam component {
  BackgroundColor #e6f3ff
  BorderColor #3c7fc0
}
skinparam database {
  BackgroundColor #ffe6cc
  BorderColor #ff9900
}
skinparam queue {
  BackgroundColor #f2e6ff
  BorderColor #9966cc
}

left to right direction

rectangle "MLAB Framework" {
  component "Dashboard (Flask)" as Dashboard {
    [Flask App]
    [Flask-Security]
    [Flask-Admin]
    [API Endpoints]
    [Interactors]
    [Repositories]
  }

  component "Worker Service" as Worker {
    [Falcon API]
    [Model Management]
    [ZooKeeper Integration]
    [Error Handling]
  }

  database "MongoDB" as MongoDB {
    [Model Metadata]
    [Logs]
    [Messages]
  }

  queue "ZooKeeper" as ZooKeeper

  [Dashboard] --> MongoDB : Stores/Retrieves
  [Dashboard] --> ZooKeeper : Monitors/Updates
  [Worker] --> MongoDB : Loads Models
  [Worker] --> ZooKeeper : Registers/Monitors

  component "Frontend" as Frontend {
    [HTML Templates]
    [CSS (AdminLTE)]
    [JavaScript]
  }

  [Dashboard] --> Frontend : Serves

  component "External Services" as External {
    [LDAP]
    [Email Server]
  }

  [Dashboard] --> [LDAP] : Authenticates
  [Worker] --> [Email Server] : Sends Alerts
}

@enduml