@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User/GitHub" as user

rectangle "API Service" as api {
  [Upload Handler]
  [Badge Generator]
  [Webhook Handler]
}

rectangle "Orchestrator Service" as orchestrator {
  [Event Processor]
  [Event Store Service]
}

rectangle "Analyse Service" as analyse {
  [Coverage Analyser]
}

rectangle "Publish Service" as publish {
  [Report Publisher]
}

rectangle "Ingest Service" as ingest {
  [Data Ingester]
}

cloud "AWS" {
  database "S3" as s3
  queue "SQS" as sqs
  database "DynamoDB" as dynamodb
  [EventBridge] as eventbridge
}

cloud "GCP" {
  database "BigQuery" as bigquery
}

user --> api : Upload coverage\nFetch badge\nSend webhook

api --> s3 : Store raw data
api --> sqs : Enqueue events
api --> dynamodb : Fetch config

sqs --> orchestrator : Consume events
orchestrator --> eventbridge : Publish events
orchestrator --> dynamodb : Update event store

eventbridge --> analyse : Trigger analysis
analyse --> s3 : Fetch coverage data
analyse --> bigquery : Store aggregated data

eventbridge --> publish : Trigger publishing
publish --> [GitHub] : Post coverage report

eventbridge --> ingest : Trigger ingestion
ingest --> s3 : Fetch raw data
ingest --> bigquery : Store processed data

@enduml