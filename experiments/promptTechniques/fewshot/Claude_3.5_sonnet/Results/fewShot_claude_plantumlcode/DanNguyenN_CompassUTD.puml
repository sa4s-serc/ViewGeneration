@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  ArrowColor #222222
  BorderColor #666666
}

rectangle "User Interface" as UI

package "FastAPI Application" {
  [FastAPI App] as FAPI
  [MongoDB Interface] as MongoDB
}

package "CompassUTD Core" {
  [CompassInference] as CI
  [Langchain Agent] as LA
  [Content Filter] as CF
}

package "NLP Services" {
  [Google PaLM 2 / Vertex AI] as PALM2
}

package "Tools" {
  [CompassToolkit] as CT
  [Search Course] as SC
  [Search Degree] as SD
  [Search General] as SG
  [Definition Lookup] as DL
  [RateMyProfessor] as RMP
}

package "Web Scraping" {
  [Text Extractor] as TE
}

database "MongoDB" as DB

UI --> FAPI
FAPI --> CI
FAPI <--> MongoDB
MongoDB <--> DB

CI --> LA
CI --> CF
LA --> CT
CT --> SC
CT --> SD
CT --> SG
CT --> DL
CT --> RMP

SC --> TE
SD --> TE
SG --> TE

CI --> PALM2
CF --> PALM2

@enduml