@startuml staples-sparx_Wonko

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

actor "SparX Services" as Services
queue "Kafka" as Kafka
rectangle "Wonko" {
  [Kafka Consumer] as Consumer
  [Event Processor] as Processor
  [Alert Manager] as AlertManager
  [Prometheus Exporter] as PrometheusExporter
  [Web Server] as WebServer
}
cloud "PagerDuty" as PagerDuty
rectangle "Prometheus" as Prometheus

Services -> Kafka : Publish events
Kafka <- Consumer : Consume events
Consumer -> Processor : Process events
Processor -> AlertManager : Generate alerts
AlertManager -> PagerDuty : Send notifications
Processor -> PrometheusExporter : Update metrics
WebServer <- PrometheusExporter : Expose metrics
Prometheus <- WebServer : Scrape metrics

@enduml