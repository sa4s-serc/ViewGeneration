@startuml zwt-sdk_zwt

skinparam componentStyle rectangle
skinparam defaultTextAlignment center

package "ZWT Framework" {
  [Common API] as CommonAPI
  
  package "Platform-Specific Implementations" {
    [Java SE/EE] as JavaSE
    [Java ME Embedded] as JavaME
    [Android] as Android
  }

  package "Core Components" {
    [ZwtComponent]
    [ZwtContainer]
    [ZwtFrame]
    [ZwtPanel]
    [ZwtLabel]
    [ZwtButton]
  }

  package "Graphics and Input" {
    [ZwtGraphics]
    [ZwtKeyboard]
  }

  package "Layout" {
    [ZwtLayout]
  }

  package "Menus" {
    [ZwtMenu]
    [ZwtMenuItem]
    [ZwtMenuContainer]
  }

  package "Styling" {
    [ZwtColor]
    [ZwtFont]
  }

  package "Backgrounds" {
    [ZwtFloor]
    [ZwtTransparentFloor]
    [ZwtRoundFloor]
  }

  package "Utility" {
    [ZwtDrawing]
  }
}

CommonAPI --> JavaSE
CommonAPI --> JavaME
CommonAPI --> Android

CommonAPI --> "Core Components"
CommonAPI --> "Graphics and Input"
CommonAPI --> "Layout"
CommonAPI --> "Menus"
CommonAPI --> "Styling"
CommonAPI --> "Backgrounds"
CommonAPI --> "Utility"

note right of CommonAPI
  Unified API for
  cross-platform
  GUI development
end note

note bottom of "Platform-Specific Implementations"
  Adapts ZWT to
  platform-specific
  UI libraries
end note

@enduml