@startuml Resurgence-VM-Development_Resurgence

component "Resurgence VM" {
    [Virtual Machine Core] as VMCore
    [Bytecode Handler] as BytecodeHandler
    [FFI (Foreign Function Interface)] as FFI
    [Instruction Set] as InstructionSet
    [Error Handler] as ErrorHandler
    [Code Generator] as CodeGenerator
    [Execution Engine] as ExecutionEngine
    [Interpreter] as Interpreter
    [Memory Manager] as MemoryManager
    [External Functions] as ExternalFunctions
    [ResurgenceState] as ResurgenceState
    [Instruction Modules] as InstructionModules
    [CodeHolder] as CodeHolder

    VMCore --> BytecodeHandler
    VMCore --> FFI
    VMCore --> InstructionSet
    VMCore --> ErrorHandler
    VMCore --> CodeGenerator
    VMCore --> ExecutionEngine
    ExecutionEngine <|-- Interpreter
    Interpreter --> MemoryManager
    FFI --> ExternalFunctions
    ExternalFunctions --> ResurgenceState
    Interpreter --> InstructionModules
    BytecodeHandler --> CodeHolder
}

cloud "Host Application" as HostApp
HostApp --> FFI : embeds

@enduml