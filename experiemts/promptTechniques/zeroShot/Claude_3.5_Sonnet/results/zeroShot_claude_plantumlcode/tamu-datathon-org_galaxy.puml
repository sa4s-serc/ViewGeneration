@startuml tamu-datathon-org_galaxy

!define RECTANGLE component

rectangle "Galaxy" as galaxy {
    RECTANGLE "Router (Nginx)" as router
    RECTANGLE "Configuration" as config
}

RECTANGLE "Gatekeeper" as gatekeeper
RECTANGLE "OBOS" as obos
RECTANGLE "Gigabowser" as gigabowser

cloud "User Requests" as users

users --> galaxy : HTTP requests

galaxy --> gatekeeper : Authentication
galaxy --> obos : Event Management
galaxy --> gigabowser : Static Website

router -[hidden]-> config

note right of galaxy
  Central entrypoint and
  routing for TAMU Datathon
end note

note bottom of router
  Routes requests based on URL paths
end note

note bottom of config
  Environment variables
  for flexible configuration
end note

@enduml