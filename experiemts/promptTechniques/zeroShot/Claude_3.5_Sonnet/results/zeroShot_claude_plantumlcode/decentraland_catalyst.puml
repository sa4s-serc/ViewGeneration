@startuml decentraland_catalyst

!define RECTANGLE class

skinparam component {
  BackgroundColor<<external>> LightGray
  BorderColor<<external>> Gray
}

[Content Server] as CS
[The Graph] as TG <<external>>
[Blockchain] as BC <<external>>
[Third-Party Services] as TPS <<external>>
[Content Storage] as CST
[PostgreSQL] as DB
[Snapshots Fetcher] as SF
[Rate Limiter] as RL
[Metrics Collector] as MC

cloud "Decentraland Network" {
  [Other Catalyst Servers] as OCS
}

CS -- TG : Queries
CS -- BC : Validates
CS -- TPS : Resolves assets
CS -- CST : Stores/Retrieves
CS -- DB : Persists/Retrieves
CS -- SF : Synchronizes
CS -- RL : Limits requests
CS -- MC : Monitors

CS -- OCS : Synchronizes

@enduml