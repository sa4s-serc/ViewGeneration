@startuml

node "Client Browser" {
    component "Vue.js Application" as VueApp
}

cloud "Internet" {
    [Kakao Maps API] as KakaoMaps
    [External News API] as NewsAPI
}

node "Web Server" {
    folder "Static Files" as StaticFiles {
        file "index.html" as IndexHTML
    }
}

node "API Server" {
    [Backend API] as BackendAPI
}

database "Database" as DB

VueApp --> KakaoMaps : Uses for map visualization
VueApp --> NewsAPI : Fetches news data
VueApp --> StaticFiles : Loads static assets
VueApp --> IndexHTML : Loads initial HTML
VueApp --> BackendAPI : Makes API requests

BackendAPI --> DB : Queries/Updates

@enduml