@startuml FudanOCR_FudanOCR

!define RECTANGLE class

RECTANGLE "Main Entry Point" as Main
RECTANGLE "Configuration" as Config
RECTANGLE "Data Handling" as Data
RECTANGLE "Text Detection" as Detection
RECTANGLE "Text Recognition" as Recognition
RECTANGLE "Super-Resolution" as SuperRes
RECTANGLE "Training Engine" as TrainingEngine
RECTANGLE "Evaluation" as Evaluation
RECTANGLE "Post-processing" as PostProcessing
RECTANGLE "Custom Layers" as CustomLayers

Main --> Config : uses
Main --> TrainingEngine : initializes

TrainingEngine --> Data : loads
TrainingEngine --> Detection : trains/uses
TrainingEngine --> Recognition : trains/uses
TrainingEngine --> SuperRes : trains/uses
TrainingEngine --> Evaluation : performs
TrainingEngine --> PostProcessing : applies

Data --> CustomLayers : uses

Detection --> CustomLayers : uses
Detection --> PostProcessing : uses

Recognition --> CustomLayers : uses
Recognition --> PostProcessing : uses

SuperRes --> CustomLayers : uses

Config ..> Detection : configures
Config ..> Recognition : configures
Config ..> SuperRes : configures
Config ..> Data : configures
Config ..> TrainingEngine : configures

@enduml