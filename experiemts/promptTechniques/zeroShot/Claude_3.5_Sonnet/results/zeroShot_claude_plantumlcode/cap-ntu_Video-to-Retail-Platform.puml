@startuml cap-ntu_Video-to-Retail-Platform

package "Hysia Platform" {
  [Video Decoding Module] as VDM
  [Multimodal Data Processor] as MDP
  [System Monitor] as SM
  [Data Handler] as DH
  [API Layer] as API
  [Machine Learning Models] as MLM
  [Frontend Dashboard] as FD
}

package "Video Decoding" {
  [HysiaDecode] as HD
  [CPUDecoder] as CPUD
  [GPUDecoder] as GPUD
  [DecodeQueue] as DQ
}

package "Backend Services" {
  [Django Backend] as DB
  [gRPC Services] as GRPC
}

package "ML Models" {
  [Object Detection] as OD
  [Face Recognition] as FR
  [Scene Recognition] as SR
  [Sentence Embedding] as SE
}

package "Frontend" {
  [React UI] as RUI
  [Redux State Management] as RSM
}

database "SQLite DB" as SQLDB
database "Pickle Files" as PF

VDM --> HD
HD --> CPUD
HD --> GPUD
HD --> DQ

MDP --> VDM
MDP --> DH

SM --> CPUD
SM --> GPUD

DH --> SQLDB
DH --> PF

API --> DB
API --> GRPC

MLM --> OD
MLM --> FR
MLM --> SR
MLM --> SE

FD --> RUI
FD --> RSM

API --> MLM
API --> DH
API --> SM

FD --> API

@enduml