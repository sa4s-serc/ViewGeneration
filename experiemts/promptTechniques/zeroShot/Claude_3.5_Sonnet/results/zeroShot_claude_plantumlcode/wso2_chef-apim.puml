@startuml wso2_chef-apim

component "Chef Cookbook" {
  [Recipes]
  [Templates]
  [Attributes]
}

component "WSO2 API Manager" {
  [Key Manager]
  [Publisher]
  [Store]
  [Traffic Manager]
  [Gateway Manager]
  [Gateway Worker]
}

database "MySQL Database"
component "Java Runtime"

[Recipes] --> [Templates] : uses
[Recipes] --> [Attributes] : reads
[Recipes] --> [WSO2 API Manager] : deploys and configures
[Recipes] --> MySQL Database : configures connection
[Recipes] --> Java Runtime : installs and configures

[WSO2 API Manager] --> MySQL Database : connects to
[WSO2 API Manager] --> Java Runtime : runs on

note right of [Recipes]
  Manages connectivity between
  components and external systems
end note

@enduml