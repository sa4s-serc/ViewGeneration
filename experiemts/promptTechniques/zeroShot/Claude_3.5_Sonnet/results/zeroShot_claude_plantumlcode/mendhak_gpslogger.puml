@startuml mendhak_gpslogger

[GpsLoggingService] as GLS
[LocationProviders] as LP
[FileLoggerFactory] as FLF
[FileSenderFactory] as FSF
[PreferenceHelper] as PH
[AppSettings] as AS
[EventBus] as EB
[WorkManager] as WM
[ContentProvider] as CP

interface "GPS Data" as GPS
interface "Network" as NET
interface "External Storage" as ES
interface "Cloud Services" as CS

LP -- GPS
LP -- NET

GLS --> LP : uses
GLS --> FLF : creates loggers
GLS --> FSF : creates senders
GLS --> PH : reads preferences
GLS --> AS : configures
GLS --> EB : publishes events

FLF --> ES : writes logs
FSF --> CS : uploads data
FSF --> WM : schedules uploads

PH --> AS : configures

CP --> ES : provides data access

EB --> GLS : notifies
EB --> FLF : notifies
EB --> FSF : notifies

@enduml