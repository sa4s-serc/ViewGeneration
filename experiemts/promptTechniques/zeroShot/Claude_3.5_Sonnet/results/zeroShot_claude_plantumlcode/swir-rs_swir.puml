```plantuml
@startuml swir-rs_swir

[SWIR Sidecar Service] as SWIR

package "Frontend Handlers" {
  [HTTP Handler] as HTTP
  [gRPC Handler] as GRPC
}

package "Core Services" {
  [PubSub Service] as PubSub
  [Persistence Service] as Persistence
  [Service Invocation] as SI
}

package "Messaging Handlers" {
  [Kafka Handler] as Kafka
  [NATS Handler] as NATS
  [AWS Kinesis Handler] as Kinesis
}

package "Persistence Handlers" {
  [Redis Store] as Redis
  [DynamoDB Store] as DynamoDB
}

package "Service Discovery" {
  [mDNS Discovery] as mDNS
  [DynamoDB Discovery] as DynamoDBDiscovery
}

package "Observability" {
  [Metrics] as Metrics
  [Tracing] as Tracing
}

[Configuration] as Config

