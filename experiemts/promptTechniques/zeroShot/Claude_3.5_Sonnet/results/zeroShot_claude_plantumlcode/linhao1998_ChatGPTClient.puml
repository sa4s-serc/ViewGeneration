@startuml linhao1998_ChatGPTClient

!define RECTANGLE class

skinparam component {
    BackgroundColor<<UI>> LightBlue
    BackgroundColor<<ViewModel>> LightGreen
    BackgroundColor<<Data>> LightYellow
    BackgroundColor<<External>> LightGray
}

component "Chat Interface" as ChatUI <<UI>>
component "Settings Screen" as SettingsUI <<UI>>
component "ChatViewModel" as ChatVM <<ViewModel>>
component "ChatListViewModel" as ChatListVM <<ViewModel>>
component "MsgListViewModel" as MsgListVM <<ViewModel>>
component "Repository" as Repo
component "Room Database" as RoomDB <<Data>>
component "SharedPreferences" as SharedPrefs <<Data>>
component "Markwon Library" as Markwon <<External>>
component "OpenAI API" as OpenAI <<External>>

ChatUI --> ChatVM
ChatUI --> ChatListVM
ChatUI --> MsgListVM
SettingsUI --> SharedPrefs
ChatVM --> Repo
ChatListVM --> Repo
MsgListVM --> Repo
Repo --> RoomDB
Repo --> SharedPrefs
Repo --> OpenAI
ChatUI --> Markwon

@enduml