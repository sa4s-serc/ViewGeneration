```plantuml
@startuml EMERIC237_Restaurant-reservation-app

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<Database>> LightYellow
}

cloud "Client" {
  [Web Browser]
}

package "Frontend" <<Frontend>> {
  [React App]
  [API Client]
}

package "Backend" <<Backend>> {
  [Express Server]
  [Reservation Controller]
  [Table Controller]
  [Knex ORM]
}

database "PostgreSQL" <<Database>> {
  [Reservations Table]
  [Tables Table]
}

[Web Browser] --> [React App] : HTTP
[React App] --> [API Client] : uses
[API Client] --> [Express Server] : HTTP/REST
[Express Server] --> [Reservation Controller] : routes
[Express Server] --> [Table Controller] : routes
[Reservation Controller] --> [Knex ORM] : queries
[Table Controller] --> [Knex ORM] : queries
[Knex ORM] --> [PostgreSQL] : SQL

note right of [Express Server]
  Handles CORS, JSON parsing,
  and error handling
end note

note right of [Knex ORM]
  Manages database migrations
  and data access
end note

@enduml
```