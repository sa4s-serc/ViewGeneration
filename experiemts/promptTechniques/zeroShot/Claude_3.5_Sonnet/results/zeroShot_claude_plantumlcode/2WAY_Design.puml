@startuml 2WAY_Design

component "Trust Network" as TN
component "Data Exchange Service" as DES
component "Authentication Module" as AM
component "Authorization Module" as AUM
component "Privacy Layer" as PL
component "Secure Communication" as SC
component "User Interface" as UI

actor "Trusted Party 1" as TP1
actor "Trusted Party 2" as TP2

TN --> DES : manages
DES --> AM : uses
DES --> AUM : uses
DES --> PL : applies
DES --> SC : utilizes

UI --> DES : interacts with

TP1 --> TN : part of
TP2 --> TN : part of

TP1 <--> SC : communicates
TP2 <--> SC : communicates

@enduml