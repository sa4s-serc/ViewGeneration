```plantuml
@startuml NodleCode_n1

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Device>> LightBlue
  BackgroundColor<<Mobile>> LightGreen
  BackgroundColor<<Cloud>> LightYellow
  BackgroundColor<<Manufacturing>> LightGray
}

rectangle "Device Tier" {
  [Dialog DA14531 Dev Kit] <<Device>> as DevKit
  [iBeacon Firmware] <<Device>> as Firmware
}

rectangle "Application Tier" {
  [Nodle Mobile App] <<Mobile>> as MobileApp
}

rectangle "Data Tier" {
  [Nodle Cloud] <<Cloud>> as Cloud
  [API] <<Cloud>> as API
}

rectangle "Manufacturing" {
  [PCB Design Files] <<Manufacturing>> as PCB
}

DevKit -- Firmware
Firmware --> MobileApp : Broadcasts iBeacon data
MobileApp --> API : Sends beacon data
API -- Cloud : Stores/retrieves data
Cloud <-- [Python Script] : Retrieves beacon information

PCB ..> DevKit : Supports

@enduml
```