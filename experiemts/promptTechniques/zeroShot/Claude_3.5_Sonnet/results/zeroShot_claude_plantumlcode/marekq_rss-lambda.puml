@startuml

participant "CloudWatch Event" as CWE
participant "Step Function" as SF
participant "Lambda: rsscrawl" as LC
participant "S3" as S3
participant "Lambda: rssgetfeed" as LG
participant "DynamoDB" as DDB
participant "AWS Comprehend" as AC
participant "SES" as SES
participant "Algolia" as ALG

CWE -> SF : Trigger (scheduled)
SF -> LC : Invoke
LC -> S3 : Check for existing data
S3 --> LC : Return data status
LC -> SF : Return feed list

loop For each feed
    SF -> LG : Invoke with feed URL
    LG -> LG : Fetch and parse RSS feed
    LG -> LG : Extract content using readability-lxml
    LG -> AC : Perform entity recognition
    AC --> LG : Return entities (tags)
    LG -> DDB : Store blog post data
    
    alt SendEmails is true
        LG -> SES : Send notification email
    end
    
    alt EnableAlgolia is true
        LG -> ALG : Index blog post
    end
    
    LG --> SF : Return processing status
end

alt StorePublicS3 is true
    SF -> S3 : Store JSON object of blog posts
end

@enduml