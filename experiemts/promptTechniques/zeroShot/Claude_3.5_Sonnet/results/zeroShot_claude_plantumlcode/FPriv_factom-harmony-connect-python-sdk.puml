@startuml FPriv_factom-harmony-connect-python-sdk

component "Factom Harmony Connect API Python SDK" {
    [FactomClient]
    [ChainsClient]
    [EntriesClient]
    [IdentitiesClient]
    [ApiInfoClient]
    [ReceiptsClient]
    [AnchorsClient]
    
    package "Utilities" {
        [Utils]
        [KeyCommon]
        [ValidateSignatureUtil]
        [CommonUtil]
    }
    
    [RequestHandler]
}

cloud "Factom Harmony Connect API" as API

FactomClient --> ChainsClient
FactomClient --> EntriesClient
FactomClient --> IdentitiesClient
FactomClient --> ApiInfoClient
FactomClient --> ReceiptsClient
FactomClient --> AnchorsClient

ChainsClient --> RequestHandler
EntriesClient --> RequestHandler
IdentitiesClient --> RequestHandler
ApiInfoClient --> RequestHandler
ReceiptsClient --> RequestHandler
AnchorsClient --> RequestHandler

RequestHandler --> API

ChainsClient ..> Utils
EntriesClient ..> Utils
IdentitiesClient ..> Utils
ChainsClient ..> KeyCommon
EntriesClient ..> KeyCommon
IdentitiesClient ..> KeyCommon
ChainsClient ..> ValidateSignatureUtil
EntriesClient ..> ValidateSignatureUtil
RequestHandler ..> CommonUtil

@enduml