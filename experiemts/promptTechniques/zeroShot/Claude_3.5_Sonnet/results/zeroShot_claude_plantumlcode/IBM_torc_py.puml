@startuml IBM_torc_py

participant "Main Application" as Main
participant "TorcPoolExecutor" as Executor
participant "Task Queue" as Queue
participant "Worker Threads" as Workers
participant "Server Thread" as Server
participant "MPI" as MPI

Main -> Executor : start()
activate Executor

Executor -> Queue : init()
Executor -> Workers : create
Executor -> Server : create

Main -> Executor : submit(task)
Executor -> Queue : enqueue(task)

loop Task Scheduling
    Server -> MPI : receive tasks/requests
    alt New Task Received
        Server -> Queue : enqueue(task)
    else Idle Worker Available
        Queue -> Workers : assign task
        activate Workers
        Workers -> Workers : execute task
        Workers --> Queue : task completed
        deactivate Workers
        Queue --> Executor : result
        Executor --> Main : return result
    else Task Stealing Request
        Server -> Queue : steal task
        Server -> MPI : send stolen task
    end
end

Main -> Executor : wait()
Executor -> Queue : wait for all tasks

Main -> Executor : shutdown()
Executor -> Workers : terminate
Executor -> Server : terminate
Executor -> MPI : finalize

deactivate Executor

@enduml