@startuml
participant "ESP32" as ESP
participant "BLE Scanner" as BLE
participant "WiFi" as WIFI
participant "MQTT Broker" as MQTT

ESP -> BLE : Initialize BLE scanner
ESP -> WIFI : Connect to WiFi network
activate WIFI

loop Main program loop
    ESP -> BLE : Scan for BLE devices
    activate BLE
    BLE --> ESP : Return scanned device data
    deactivate BLE
    
    ESP -> ESP : Format data as JSON
    
    alt WiFi connected
        ESP -> MQTT : Publish BLE data
        activate MQTT
        MQTT --> ESP : Acknowledge publication
        deactivate MQTT
    else WiFi disconnected
        ESP -> WIFI : Reconnect to WiFi
        activate WIFI
        WIFI --> ESP : Connection established
        deactivate WIFI
    end
    
    alt MQTT disconnected
        ESP -> MQTT : Reconnect to MQTT broker
        activate MQTT
        MQTT --> ESP : Connection established
        deactivate MQTT
    end
    
    MQTT -> ESP : Receive potential commands
    activate MQTT
    ESP -> ESP : Process received commands
    deactivate MQTT
end

@enduml