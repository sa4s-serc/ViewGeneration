@startuml ut-ims-robotics_robotont

component "robotont_driver" as driver {
    [Serial Communication]
    [Hardware Interface]
    [Odometry Calculation]
}

component "robotont_teleop" as teleop {
    [Joystick Control]
    [Keyboard Control]
    [Safety Timer]
}

component "robotont_training" as training {
    [Training Exercises]
    [AR Tag Tracking]
}

component "robotont_description" as description {
    [URDF Models]
    [Meshes]
    [Materials]
}

component "robotont_sensors" as sensors {
    [LaserScan Processing]
}

component "Navigation Stack" as nav_stack
component "Gazebo Simulation" as gazebo
component "ROS Core" as ros_core
component "TF Library" as tf

driver -down-> ros_core : "Publishes to/\nSubscribes from"
teleop -down-> ros_core : "Publishes to/\nSubscribes from"
training -down-> ros_core : "Uses"
sensors -down-> ros_core : "Publishes to/\nSubscribes from"
description -right-> gazebo : "Provides models"
nav_stack -up-> ros_core : "Uses"
gazebo -up-> ros_core : "Integrates with"
tf -up-> ros_core : "Manages transformations"

@enduml