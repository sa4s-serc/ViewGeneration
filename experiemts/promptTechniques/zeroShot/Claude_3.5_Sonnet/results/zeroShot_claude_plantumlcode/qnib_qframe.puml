@startuml qnib_qframe

' Components
[Collectors] as COL
[Filters] as FIL
[Handlers] as HAN
[QChan] as QCHAN
[Configuration] as CONF
[Metric] as MET
[ContainerStats] as CS

' External components
[Docker API] as DOCK
[InfluxDB] as INFL
[Elasticsearch] as ES
[File System] as FS

' Data flow
COL -> QCHAN : Raw data
QCHAN -> FIL : Broadcast data
FIL -> QCHAN : Processed data
QCHAN -> HAN : Broadcast data

' Configuration and data structures
CONF ..> COL : Configure
CONF ..> FIL : Configure
CONF ..> HAN : Configure
MET -- COL : Use
MET -- FIL : Use
MET -- HAN : Use
CS -- COL : Use
CS -- FIL : Use

' External interactions
DOCK --> COL : Container events
FS --> COL : Log files
HAN --> INFL : Store metrics
HAN --> ES : Store logs
HAN --> FS : Write logs

@enduml