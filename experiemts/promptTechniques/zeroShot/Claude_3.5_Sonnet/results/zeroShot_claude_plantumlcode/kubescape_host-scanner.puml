```plantuml
@startuml kubescape_host-scanner

[HTTP API Server] as API
[Logger] as Log
[OpenTelemetry] as OTel

package "Sensors" {
    [OS Sensor] as OS
    [Network Sensor] as Net
    [Container Runtime Sensor] as CRT
    [Kubelet Sensor] as Kub
    [Control Plane Sensor] as CP
    [Security Sensor] as Sec
    [Cloud Provider Sensor] as Cloud
    [Version Sensor] as Ver
}

package "Utilities" {
    [Container Runtime Utils] as CRU
    [File System Utils] as FSU
}

[HTTP Handlers] as Handler
[Configuration] as Config

API --> Handler
Handler --> Sensors
Sensors --> Utilities
API --> Log
API --> OTel
API --> Config

Handler ..> OS
Handler ..> Net
Handler ..> CRT
Handler ..> Kub
Handler ..> CP
Handler ..> Sec
Handler ..> Cloud
Handler ..> Ver

CRT ..> CRU
Sensors ..> FSU

note right of API
  Exposes host information
  via HTTP endpoints
end note

note bottom of Sensors
  Gather specific host
  information
end note

note left of Utilities
  Helper functions for
  accessing host resources
end note

note top of Config
  Environment variables
  and file-based configs
end note

@enduml
```