@startuml azuregomez_SecurePaaS

!define AZURE_SYMBOL https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

!include AZURE_SYMBOL

LAYOUT_WITH_LEGEND()

Person(user, "User")

System_Boundary(azure, "Azure Cloud") {
    Container(waf, "Web Application Firewall", "Azure Application Gateway", "Threat Protection, OWASP Top 10")
    
    Boundary(vnet, "Virtual Network") {
        Container(webapp, "Web Application", "Azure App Service", ".NET application")
        Container(sqldb, "SQL Database", "Azure SQL", "Private Endpoint")
        Container(firewall, "Azure Firewall", "", "Outbound Traffic Inspection")
    }
    
    Container(keyvault, "Key Vault", "Azure Key Vault", "Secret Management")
}

Rel(user, waf, "HTTPS")
Rel(waf, webapp, "Filtered Traffic")
Rel(webapp, firewall, "Outbound Traffic")
Rel(firewall, sqldb, "Inspected Traffic")
Rel_U(webapp, keyvault, "Secure Access")

@enduml