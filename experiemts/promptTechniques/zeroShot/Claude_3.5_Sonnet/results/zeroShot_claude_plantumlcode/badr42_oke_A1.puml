```plantuml
@startuml badr42_oke_A1

!define RECTANGLE class

skinparam component {
  BackgroundColor<<OCI>> LightBlue
  BackgroundColor<<K8s>> LightGreen
}

rectangle "Oracle Cloud Infrastructure" {
  [Virtual Cloud Network] <<OCI>> as VCN
  [Internet Gateway] <<OCI>> as IGW
  [NAT Gateway] <<OCI>> as NGW
  [Service Gateway] <<OCI>> as SGW
  [OKE Cluster] <<OCI>> as OKE
  [Node Pool] <<OCI>> as NodePool
  [Load Balancer] <<OCI>> as LB

  VCN -- IGW
  VCN -- NGW
  VCN -- SGW
  OKE -- NodePool
  OKE -- LB
}

rectangle "Kubernetes Cluster" {
  [Nginx Deployment] <<K8s>> as NginxDeploy
  [Nginx Service] <<K8s>> as NginxService
}

[Terraform Configuration] as TerraformConfig
[Kubeconfig] as Kubeconfig

TerraformConfig --> VCN : provisions
TerraformConfig --> OKE : creates
TerraformConfig --> NodePool : manages
TerraformConfig --> Kubeconfig : retrieves

OKE --> NginxDeploy : hosts
OKE --> NginxService : exposes
LB --> NginxService : routes traffic

[External Users] as Users
Users --> LB : access

@enduml
```