@startuml emreturgutce_stock-management

node "Application Server" {
    [Express.js App] as App
    [Controllers] as Controllers
    [Middleware] as Middleware
    [Utility Functions] as Utils
    [Database Queries] as Queries
}

database "PostgreSQL" as Postgres
database "Redis" as Redis
cloud "AWS S3" as S3
cloud "Amazon RDS" as RDS

App --> Controllers
App --> Middleware
Controllers --> Utils
Controllers --> Queries
Queries --> Postgres
Middleware --> Redis : Session Management
Utils --> S3 : Image Upload

note right of App
  Containerized deployment
  using Docker
end note

note bottom of Postgres
  Can be hosted on
  Amazon RDS
end note

@enduml