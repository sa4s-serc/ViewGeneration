@startuml kaleidot725_Draft

package "Emomemo App" {
    [ComposeMainActivity] as CMA
    [EmomemoApp] as EA
    [Navigation] as NAV
    
    package "Presentation Layer" {
        [ViewModels] as VM
        [Composables] as COMP
        [TextEditor] as TE
    }
    
    package "Domain Layer" {
        [UseCases] as UC
    }
    
    package "Data Layer" {
        [Repositories] as REPO
        [Room Database] as DB
    }
    
    package "Common" {
        [Koin DI] as KOIN
        [Coroutines & Flows] as CF
    }
}

CMA --> NAV
CMA --> COMP
EA --> KOIN

VM --> UC
VM <-- CF
COMP --> VM
COMP --> TE

UC --> REPO
REPO --> DB
REPO <-- CF

KOIN ..> VM
KOIN ..> UC
KOIN ..> REPO
KOIN ..> DB

@enduml