@startuml fdrennan_ndexr-platform

component "Data Ingestion" {
    [PRAW Python Library]
}

component "Data Storage" {
    [PostgreSQL]
}

component "API" {
    [R Plumber API]
}

component "User Interface" {
    [Shiny Application]
}

component "Workflow Orchestration" {
    [Airflow]
}

component "AWS Infrastructure" {
    [EC2 Instances]
    [S3 Storage]
    [RDS PostgreSQL]
    [SNS Messaging]
}

component "Search" {
    [Elasticsearch]
}

component "Monitoring" {
    [Glances]
}

component "Docker Containers" {
    [API Container]
    [R/Python Container]
    [Shiny Container]
}

[PRAW Python Library] --> [PostgreSQL]
[R Plumber API] --> [PostgreSQL]
[Shiny Application] --> [R Plumber API]
[Airflow] --> [PRAW Python Library]
[Airflow] --> [PostgreSQL]
[Airflow] --> [EC2 Instances]
[Airflow] --> [S3 Storage]
[R Plumber API] --> [EC2 Instances]
[R Plumber API] --> [S3 Storage]
[R Plumber API] --> [SNS Messaging]
[PostgreSQL] --> [RDS PostgreSQL]
[Elasticsearch] --> [PostgreSQL]
[Glances] --> [EC2 Instances]

[API Container] --> [R Plumber API]
[R/Python Container] --> [Airflow]
[Shiny Container] --> [Shiny Application]

@enduml