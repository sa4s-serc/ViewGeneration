@startuml
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v15.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/InternetOfThings/IoTCore.puml
!include AWSPuml/Compute/Lambda.puml
!include AWSPuml/ApplicationIntegration/StepFunctions.puml
!include AWSPuml/Storage/SimpleStorageService.puml
!include AWSPuml/Database/DynamoDB.puml

actor User
participant "Web UI" as UI
participant "API Gateway" as API
participant "Microservices Lambda" as Microservices
participant "Simulator Lambda" as Simulator
participant "Step Functions" as StepFunctions
participant "DynamoDB" as DynamoDB
participant "S3" as S3
participant "IoT Core" as IoTCore

User -> UI : Configure simulation
UI -> API : Create simulation request
API -> Microservices : Route request
Microservices -> DynamoDB : Store simulation config
Microservices --> API : Confirm creation
API --> UI : Display confirmation

User -> UI : Start simulation
UI -> API : Start simulation request
API -> Microservices : Route request
Microservices -> StepFunctions : Initiate simulation workflow
StepFunctions -> Simulator : Execute simulation
Simulator -> S3 : Fetch device type definitions
Simulator -> IoTCore : Send simulated device data
IoTCore --> Simulator : Acknowledge data
Simulator --> StepFunctions : Report simulation progress
StepFunctions --> Microservices : Update simulation status
Microservices -> DynamoDB : Update simulation record
Microservices --> API : Return status
API --> UI : Display simulation status

User -> UI : Stop simulation
UI -> API : Stop simulation request
API -> Microservices : Route request
Microservices -> StepFunctions : Stop simulation workflow
StepFunctions -> Simulator : Terminate simulation
Simulator --> StepFunctions : Confirm termination
StepFunctions --> Microservices : Report simulation stopped
Microservices -> DynamoDB : Update simulation record
Microservices --> API : Confirm stop
API --> UI : Display stop confirmation

@enduml