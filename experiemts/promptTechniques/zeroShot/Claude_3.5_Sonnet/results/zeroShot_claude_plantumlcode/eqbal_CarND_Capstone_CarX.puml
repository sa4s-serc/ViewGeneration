@startuml eqbal_CarND_Capstone_CarX

!define RECTANGLE class

RECTANGLE "Traffic Light Detection" as TLD
RECTANGLE "Waypoint Loader" as WL
RECTANGLE "Waypoint Updater" as WU
RECTANGLE "Waypoint Follower" as WF
RECTANGLE "Twist Controller (DBW)" as TC
RECTANGLE "PID Controller" as PID
RECTANGLE "Yaw Controller" as YC
RECTANGLE "LowPass Filter" as LPF
RECTANGLE "Bridge Node" as BN

TLD --> WU : Traffic light status
WL --> WU : Waypoint data
WU --> WF : Updated waypoints
WF --> TC : Target velocities
TC --> PID : Throttle control
TC --> YC : Steering control
TC --> LPF : Signal filtering
BN <--> TLD : Camera images
BN <--> TC : Vehicle state
BN <--> WU : Vehicle position

@enduml