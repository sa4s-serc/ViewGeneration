@startuml unnmdnwb3_dora

participant "Kubernetes" as K
participant "API Gateway" as AG
participant "DORA Backend" as DB
participant "MongoDB" as M
participant "GitLab" as GL
participant "Prometheus" as P

K -> AG : Deploy application
AG -> DB : Route requests
DB -> M : Initialize connection
DB -> GL : Authenticate
DB -> P : Configure scraping

loop Periodic data collection
    DB -> GL : Fetch repositories, commits, pipelines
    GL --> DB : Return data
    DB -> M : Store raw data
end

loop Metrics calculation
    DB -> M : Retrieve raw data
    M --> DB : Return data
    DB -> DB : Calculate DORA metrics
    DB -> M : Store calculated metrics
end

loop Alert monitoring
    P -> DB : Send alert
    DB -> DB : Update MTTR calculation
    DB -> M : Store updated metrics
end

AG -> DB : Request metrics
DB -> M : Retrieve metrics
M --> DB : Return metrics
DB --> AG : Return metrics response

@enduml