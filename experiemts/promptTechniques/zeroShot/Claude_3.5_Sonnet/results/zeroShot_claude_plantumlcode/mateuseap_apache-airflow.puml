@startuml mateuseap_apache-airflow

component "Apache Airflow" {
  [DAGs]
  [Operators]
  [Scheduler]
  [Web Server]
  [Workers]
}

component "Docker" {
  [Docker Compose]
  [Dockerfiles]
}

component "Hadoop Ecosystem" {
  [HDFS]
  [Hive]
  [Spark]
  [Livy]
}

component "Monitoring Stack" {
  [Telegraf]
  [InfluxDB]
  [Grafana]
}

component "Logging Stack" {
  [Elasticsearch]
  [Logstash]
  [Kibana]
}

component "Kubernetes" {
  [K8s Manifests]
}

database "PostgreSQL"
queue "Redis"

[Apache Airflow] --> [Docker] : deployed with
[Apache Airflow] --> [Hadoop Ecosystem] : integrates with
[Apache Airflow] --> [Monitoring Stack] : monitored by
[Apache Airflow] --> [Logging Stack] : logs to
[Apache Airflow] --> [Kubernetes] : can be deployed on
[Apache Airflow] --> PostgreSQL : uses as metadata store
[Apache Airflow] --> Redis : uses as message broker

[DAGs] --> [Operators]
[Scheduler] --> [DAGs]
[Web Server] --> [DAGs]
[Workers] --> [DAGs]

@enduml