@startuml allegroai_clearml-agent

!define RECTANGLE class

skinparam component {
  BackgroundColor<<External>> LightGray
  BorderColor<<External>> Gray
}

cloud "Kubernetes Cluster" {
    [ClearML Agent] as Agent
    [ResourceMonitor]
    [RequirementsManager]
    [Docker Integration]
    [K8s Integration]
    [Configuration System]
}

[ClearML Server]<<External>>
[SLURM]<<External>>
database "Docker Registry"<<External>>

Agent --> ResourceMonitor : monitors resources
Agent --> RequirementsManager : manages dependencies
Agent --> [Docker Integration] : builds and runs containers
Agent --> [K8s Integration] : interacts with K8s
Agent --> [Configuration System] : reads configuration

[Docker Integration] --> "Docker Registry" : pulls/pushes images

Agent --> ClearML Server : reports status & fetches tasks
Agent --> SLURM : submits jobs (optional)

@enduml