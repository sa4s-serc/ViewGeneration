@startuml icoxfog417_karura

actor User
participant "Kintone Plugin" as Plugin
participant "Karura Master App" as MasterApp
participant "Karura Server" as Server
participant "Model Manager" as ModelManager
participant "Dataset" as Dataset
participant "Field Manager" as FieldManager
participant "Model Builder" as ModelBuilder
database "Model Store" as Store

User -> Plugin : Initiate ML task
Plugin -> MasterApp : Configure ML task
MasterApp -> Server : POST /train
Server -> ModelManager : Build model
ModelManager -> Dataset : Load data
Dataset -> FieldManager : Get field definitions
FieldManager --> Dataset : Field definitions
Dataset --> ModelManager : Processed data
ModelManager -> ModelBuilder : Train model
ModelBuilder -> ModelBuilder : Select algorithm
ModelBuilder -> ModelBuilder : Tune hyperparameters
ModelBuilder --> ModelManager : Trained model
ModelManager -> Store : Save model
Store --> ModelManager : Confirmation
ModelManager --> Server : Training complete
Server --> MasterApp : Training results
MasterApp --> Plugin : Update UI
Plugin --> User : Display results

User -> Plugin : Request prediction
Plugin -> Server : POST /predict
Server -> ModelManager : Get prediction
ModelManager -> Store : Load model
Store --> ModelManager : Loaded model
ModelManager -> ModelBuilder : Make prediction
ModelBuilder --> ModelManager : Prediction result
ModelManager --> Server : Prediction
Server --> Plugin : Prediction result
Plugin --> User : Display prediction

@enduml