Here's a PlantUML component diagram capturing the static architecture of the HTTP proxy system, focusing on the general architectural concern:

```plantuml
@startuml lvyahui8_http-proxy

[Client] as client
[Backend Server] as backend

package "HTTP Proxy Service" {
  [HttpProxyServer] as proxyServer
  [ClientToProxyHandler] as clientHandler
  [ProxyToServerInboundHandler] as serverHandler
  [EntitysManager] as entityManager
  [GlobalExceptionHandler] as exceptionHandler
  
  package "Filters" {
    [ProxyRequestFilter] as requestFilter
    [ProxyResponseFilter] as responseFilter
  }
  
  [MsgTranslater] as msgTranslater
}

database "entitys.json" as config

client -right-> proxyServer : HTTP Request
proxyServer -right-> backend : Forwarded Request
backend -left-> proxyServer : HTTP Response
proxyServer -left-> client : Forwarded Response

proxyServer --> clientHandler
proxyServer --> serverHandler
proxyServer --> exceptionHandler

clientHandler --> entityManager
serverHandler --> entityManager

clientHandler --> requestFilter
serverHandler --> responseFilter

entityManager --> config : Reads

exceptionHandler --> msgTranslater

@enduml
```