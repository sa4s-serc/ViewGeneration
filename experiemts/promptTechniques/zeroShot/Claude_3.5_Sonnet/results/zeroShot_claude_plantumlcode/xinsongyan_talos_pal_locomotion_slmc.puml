@startuml xinsongyan_talos_pal_locomotion_slmc

participant "ROS Node" as ROS
participant "Locomotion Controller" as LC
participant "DCM Controller" as DCM
participant "Whole-Body Controller" as WBC
participant "State Estimator" as SE
participant "Safety Layer" as SL

activate ROS
ROS -> LC : Initialize controller
activate LC

LC -> DCM : Load configuration
activate DCM
LC -> WBC : Load plugin
activate WBC
LC -> SE : Initialize
activate SE
LC -> SL : Initialize
activate SL

loop Control Loop
    ROS -> LC : Update command
    LC -> SE : Get robot state
    SE --> LC : Current state
    LC -> DCM : Generate walking pattern
    DCM --> LC : Desired trajectory
    LC -> WBC : Compute control commands
    WBC -> SL : Check safety constraints
    SL --> WBC : Safety status
    WBC --> LC : Joint commands
    LC -> SL : Validate commands
    SL --> LC : Validated commands
    LC --> ROS : Execute commands
end

@enduml