```plantuml
@startuml qnib_qframe

package "qnib_qframe" {
    component "Core" as Core
    component "QChan" as QChan
    component "Collector" as Collector
    component "Filter" as Filter
    component "Handler" as Handler
    component "Config" as Config
    component "System" as System

    Core --> QChan : "uses"
    Core --> Config : "configures"
    Collector --> QChan : "sends data"
    Filter --> QChan : "receives & sends data"
    Handler --> QChan : "receives data"
    QChan --> Core : "broadcasts data"
    Config --> Collector : "configures"
    Config --> Filter : "configures"
    Config --> Handler : "configures"
    System --> Core : "provides system calls"
    
    component "fsouza/go-dockerclient" as DockerClient
    component "vjeantet/grok" as Grok
    component "InfluxDB" as InfluxDB
    component "Elasticsearch" as Elasticsearch

    Collector --> DockerClient : "collects from"
    Filter --> Grok : "parses with"
    Handler --> InfluxDB : "outputs to"
    Handler --> Elasticsearch : "outputs to"
}

@enduml
```