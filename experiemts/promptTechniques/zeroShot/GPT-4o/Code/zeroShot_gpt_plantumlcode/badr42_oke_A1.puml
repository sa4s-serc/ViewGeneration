```plantuml
@startuml badr42_oke_A1

!define ICONURL https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/v2.1.0/common

skinparam componentStyle rectangle

' Components
component "Terraform Configuration" as Terraform {
    [main.tf]
    [variables.tf]
    [nginx_deployment.yaml]
    [setup_nginx.sh]
}

component "OCI" {
    [VCN] as vcn
    [Subnets] as subnets
    [Internet Gateway] as igw
    [NAT Gateway] as ngw
    [Service Gateway] as sgw
    [Route Tables] as routeTables
    [Security Lists] as securityLists
}

component "OKE Cluster" {
    [Control Plane] as controlPlane
    [Worker Nodes] as workerNodes
    [Node Pools] as nodePools
}

component "Nginx Deployment" {
    [Nginx Pods] as nginxPods
    [Load Balancer] as loadBalancer
}

' Connectivity
Terraform -up-> vcn : Provision
Terraform --> controlPlane : Create
Terraform -up-> workerNodes : Deploy
Terraform --> nodePools : Manage
Terraform --> nginxPods : Deploy

' Networking
vcn --> subnets
vcn --> igw
vcn --> ngw
vcn --> sgw
vcn --> routeTables
vcn --> securityLists

' OKE Cluster
controlPlane --> workerNodes
workerNodes --> nodePools

' Application
nginxPods --> loadBalancer

' Performance and Optimization
controlPlane --> nodePools : Ampere A1
nodePools --> workerNodes : Optimize

@enduml
```