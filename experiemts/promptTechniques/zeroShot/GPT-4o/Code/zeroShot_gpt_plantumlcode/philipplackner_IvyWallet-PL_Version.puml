@startuml philipplackner_IvyWallet-PL_Version

package "Ivy Wallet Application" {
    component "Transaction Management" as TM
    component "Account Management" as AM
    component "Category Management" as CM
    component "Data Synchronization" as DS
    component "Backup and Restore" as BR
    component "Exchange Rates" as ER
    component "Formula Module" as FM
    component "UI Design System" as UI
    component "MVVM Architecture" as MVVM
