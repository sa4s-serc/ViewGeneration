    TM -> AM : uses
    TM -> CM : uses
    DS -> BR : uses
    DS -down-> ER : syncs
    FM -> TM : queries
    UI --> MVVM : renders
    MVVM -> TM : controls
    MVVM -> AM : controls
    MVVM -> CM : controls
    DI -> MVVM : injects dependencies
    RP -> MVVM : manages data streams

