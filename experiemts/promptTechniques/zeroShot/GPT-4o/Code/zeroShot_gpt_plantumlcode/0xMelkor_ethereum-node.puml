```plantuml
@startuml 0xMelkor_ethereum-node

package "Google Kubernetes Engine (GKE)" {
    [Geth Pod] --> [Kubernetes Cluster]
    [Lighthouse Pod] --> [Kubernetes Cluster]
    [InfluxDB Pod] --> [Kubernetes Cluster]
    [Nginx Pod] --> [Kubernetes Cluster]
    
    [Geth Pod] -up-> [Persistent Volume Claim] : 2000Gi
    [Lighthouse Pod] -up-> [Persistent Volume Claim] : 500Gi
    [InfluxDB Pod] -up-> [Persistent Volume Claim] : Data Directory
    
    [Geth Pod] --> [InfluxDB Service]
    [Lighthouse Pod] --> [InfluxDB Service]
    [Geth Pod] <-- [Nginx Service]
    [InfluxDB Pod] <-- [Nginx Service]
    
    [InfluxDB Pod] --> [Headless Service]

    [Kubernetes Cluster] --> [Service Discovery]
}

package "Google Cloud" {
    [Google Cloud Build] --> [Kubernetes Cluster]
    [Google Cloud Secret Manager] --> [Kubernetes Cluster]
}

cloud {
    [External User]
    [External User] --> [Nginx Reverse Proxy]
    [Nginx Reverse Proxy] --> [Geth Pod] : RPC/HTTP
    [Nginx Reverse Proxy] --> [Geth Pod] : WebSocket
    [Nginx Reverse Proxy] --> [InfluxDB Pod]
}

@enduml
```