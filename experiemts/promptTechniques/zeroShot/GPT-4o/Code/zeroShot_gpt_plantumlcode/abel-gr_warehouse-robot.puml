```plantuml
@startuml abel-gr_warehouse-robot

package "abel-gr_warehouse-robot" {
    [Unity Environment] as Unity
    [CoppeliaSim Simulation] as CoppeliaSim
    [Web Interface] as WebInterface
    [Speech-to-Text Cloud Function] as SpeechToText
    [Python Scripts] as PythonScripts
    
    Unity -[#green]-> CoppeliaSim : Remote API
    Unity --> WebInterface : User Interaction
    WebInterface -[#blue]-> SpeechToText : Speech Processing
    CoppeliaSim -[#red]-> PythonScripts : Robot Control
    SpeechToText --> WebInterface : Text Response
    PythonScripts --> CoppeliaSim : Control Commands
}

@enduml
```