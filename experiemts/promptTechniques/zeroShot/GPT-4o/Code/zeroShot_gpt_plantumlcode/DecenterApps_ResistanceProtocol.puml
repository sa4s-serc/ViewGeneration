```plantuml
@startuml DecenterApps_ResistanceProtocol

package "NOI Stablecoin" {
  
  component "Smart Contracts" as SC {
    [ERC20 Stablecoin]
    [CDP Management]
    [Liquidation Mechanisms]
  }
  
  component "Price Stabilization" as PS {
    [PID Controller 1]
    [PID Controller 2]
  }
  
  package "Simulation Engine" {
    component "Python Simulations" as Sim
    component "Agent Modeling" as Agents
  }
  
  package "Frontend" {
    component "React Application" as Frontend {
      [CDP Management UI]
    }
  }
  
  package "Backend" {
    component "Deployment Scripts" as Deploy
    component "Monitoring Bots" as Bots
  }
  
  package "Hardhat Environment" {
    [Contract Development]
    [Testing]
    [Deployment]
  }
}

[ERC20 Stablecoin] --> SC
[CDP Management] --> SC
[Liquidation Mechanisms] --> SC

PS --> SC

Sim --> Agents
Sim .down..> [Contract Development] : uses

Frontend --> [CDP Management UI]
Frontend .up..> [Testing] : interacts

Deploy --> SC
Deploy --> Bots
Deploy --> Sim

SC --> Frontend

@enduml
```