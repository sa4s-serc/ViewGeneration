```plantuml
@startuml aurelien-m_raspberrypi-rustpy

actor User
participant "Web Browser" as WB
participant "Web Server (Rocket)" as WS
participant "Python Controller" as PC
participant "Rust Library" as RL
participant "Raspberry Pi Hardware" as RPi

User -> WB: Access Web Interface
WB -> WS: HTTP Request (Access LED Control)
WS -> WS: Authenticate User
alt Authenticated
    WS -> WB: HTTP Response (Control Page)
    WB -> WS: WebSocket Connection
    WS -> PC: Command via Script Controller
    PC -> RL: Call Rust Functions
    RL -> RPi: GPIO Control (e.g., blink_led)
    RPi -> RL: Hardware Status
    RL -> PC: Return Status
    PC -> WS: LED Status Update
    WS -> WB: WebSocket Message (Update UI)
else Not Authenticated
    WS -> WB: HTTP Response (Login Page)
end

loop Real-time Updates
    WB -> WS: WebSocket Message (User Command)
    WS -> PC: Send Command to Python Controller
    PC -> RL: Execute Command
    RL -> RPi: Perform Action
    RPi -> RL: Action Result
    RL -> PC: Result Status
    PC -> WS: Update Status
    WS -> WB: WebSocket Message (Update UI)
end

@enduml
```