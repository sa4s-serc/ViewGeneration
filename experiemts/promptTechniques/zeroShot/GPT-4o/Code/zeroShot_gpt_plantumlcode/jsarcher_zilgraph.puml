```plantuml
@startuml jsarcher_zilgraph

package "Zilgraph System" {
    [Zilcrawler] --> [Zilliqa Blockchain]
    [Zilcrawler] --> [Elasticsearch] : Store Raw Data
    [Elasticsearch] --> [MongoDB] : Aggregate Data
    [MongoDB] --> [Frontend Visualization] : Serve Aggregated Data

    [Frontend Visualization] --> [User] : Display Charts & Tables

    [Nginx] --> [Bokeh Server] : Reverse Proxy
    [Nginx] --> [Kibana] : Reverse Proxy

    [Elasticsearch] --> [Kibana] : Query & Visualization
    [Frontend Visualization] --> [Kibana] : Embed Dashboards

    component "Frontend Visualization" {
        [Bokeh Server]
        [Custom CSS]
        [HTML Templates]
    }

    component "Zilgraph Oracle" {
        [Scilla Smart Contract]
        note right
            Early Stage
        end note
    }

    [Zilswap] --> [Zilliqa Blockchain] : Interact
    [Zilswap] --> [Zilswap Smart Contract] : Retrieve Data

    [Nginx] - [User]
}

@enduml
```