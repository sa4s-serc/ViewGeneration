```plantuml
@startuml kaleidot725_Draft

package "Emomemo App" {
    component "App Module" {
        [ComposeMainActivity] --> [EmomemoApp]
        [EmomemoApp] --> [Koin]
        [EmomemoApp] --> [Timber]
        [ComposeMainActivity] --> [Jetpack Compose UI]
        [Jetpack Compose UI] --> [Navigation Compose]
        [Jetpack Compose UI] --> [TextEditor Compose]
    }

    component "Domain Module" {
        [CreateMemoUseCase] --> [NotebookRepository]
        [GetNotebooksUseCase] --> [MemoRepository]
    }

    component "Data Module" {
        [AppDatabase] --> [Room]
        [NotebookRepository] --> [AppDatabase]
        [MemoRepository] --> [AppDatabase]
    }

    [Jetpack Compose UI] --> [Domain Module]
    [Domain Module] --> [Data Module]

    [Koin] ..> [Dependency Injection] : injects
    [Room] ..> [Data Persistence] : persists
    [Kotlin Coroutines] ..> [Asynchronous Programming] : enables
    [Flows] ..> [Observer Pattern] : observes
    [Navigation Compose] ..> [Navigation Pattern] : implements
    [orbit-mvi] ..> [MVI Pattern] : supports
}

@enduml
