```plantuml
@startuml EMERIC237_Restaurant-reservation-app

package "Front-end (React)" {
    [App.js] --> [Dashboard.js]
    [App.js] --> [Layout.js]
    [Layout.js] --> [Routes.js]
    [Routes.js] --> [CreateReservation.js]
    [CreateReservation.js] --> [ReservationForm.js]
    [Dashboard.js] --> [ErrorAlert.js]
}

package "Back-end (Node.js/Express)" {
    [app.js] --> [reservations.router.js]
    [app.js] --> [tables.router.js]
    [reservations.router.js] --> [reservations.controller.js]
    [reservations.controller.js] --> [reservations.service.js]
    [tables.router.js] --> [tables.controller.js]
    [tables.controller.js] --> [tables.service.js]
    [reservations.service.js] --> [connection.js]
    [tables.service.js] --> [connection.js]
    [server.js] --> [app.js]
}

package "Database (PostgreSQL)" {
    [connection.js] --> [Database]
    [migrations] --> [Database]
    [seeds] --> [Database]
}

package "Deployment" {
    [Vercel] --> [Front-end (React)]
    [Heroku] --> [Back-end (Node.js/Express)]
}

package "API" {
    [Reservations API] --> [Back-end (Node.js/Express)]
    [Tables API] --> [Back-end (Node.js/Express)]
    [api.js] --> [Reservations API]
    [api.js] --> [Tables API]
}

' Data Flow
[Front-end (React)] --> [API] : RESTful API Calls
[API] --> [Back-end (Node.js/Express)] : Handle Requests
[Back-end (Node.js/Express)] --> [Database] : CRUD Operations

@enduml
