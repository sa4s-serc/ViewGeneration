```plantuml
@startuml CMUChimpsLab_Peekaboo

actor User
participant "Node-RED UI" as UI
participant "Provider Node" as Provider
participant "Inference Node" as Inference
participant "Filter Node" as Filter
participant "Network Node" as Network
participant "PeekabooService" as Service

User -> UI: Configure Nodes
activate UI

UI -> Provider: Initialize
activate Provider
Provider -> Provider: Retrieve Data
Provider -> Inference: Send Data
deactivate Provider

activate Inference
Inference -> Service: Request Analysis
activate Service
Service -> Inference: Return Results
deactivate Service
Inference -> Filter: Send Processed Data
deactivate Inference

activate Filter
Filter -> Filter: Apply Modifications
Filter -> Network: Forward Data
deactivate Filter

activate Network
Network -> Network: Transmit Data
deactivate Network

UI <- User: Receive Feedback
deactivate UI

@enduml
```