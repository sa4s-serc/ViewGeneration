```plantuml
@startuml WeBankFinTech_DeFiBus

package "DeFiBus System" {
    component "DeFiBrokerController" {
        [DeFiAdminBrokerProcessor]
        [DeFiSendMessageProcessor]
        [DeFiReplyMessageProcessor]
        [DeFiPullMessageProcessor]
    }
    component "Client Management" {
        [DeFiProducerManager]
        [DeFiConsumerManager]
        [ClientRebalanceResultManager]
    }
    component "Queue Management" {
        [ConsumeQueueManager]
        [QueueListeningMonitor]
        [AdjustQueueNumStrategy]
    }
    component "Message Management" {
        [DeFiPluginMessageStore]
        [MessageRedirectManager]
        [DeFiTopicConfigManager]
        [DeFiBusBroker2Client]
    }
}

package "Connectivity" {
    interface "RocketMQ Core"
    [DeFiBrokerController] --> "RocketMQ Core" : uses
}

package "Deployment" {
    node "Broker Node" {
        [DeFiBrokerController]
        [Client Management]
        [Queue Management]
        [Message Management]
    }
}

[DeFiBrokerController] --> [DeFiProducerManager] : manages
[DeFiBrokerController] --> [DeFiConsumerManager] : manages
[DeFiBrokerController] --> [ConsumeQueueManager] : manages
[DeFiBrokerController] --> [DeFiPluginMessageStore] : uses
[DeFiBrokerController] --> [DeFiAdminBrokerProcessor] : processes
[DeFiBrokerController] --> [DeFiSendMessageProcessor] : processes
[DeFiBrokerController] --> [DeFiReplyMessageProcessor] : processes
[DeFiBrokerController] --> [DeFiPullMessageProcessor] : processes

[DeFiProducerManager] --> [ClientRebalanceResultManager] : updates
[DeFiConsumerManager] --> [AdjustQueueNumStrategy] : utilizes
[ConsumeQueueManager] --> [QueueListeningMonitor] : monitors
[MessageRedirectManager] --> [DeFiBusBroker2Client] : redirects

@enduml
```