```plantuml
@startuml turkcellcloud_jupyter-openshift

package "OpenShift Cluster" {
    component "JupyterHub" as JH {
        [JupyterHub]
        [KubeSpawner]
        [LDAPAuthenticator]
    }

    component "JupyterLab" as JL {
        [JupyterLab UI]
        [Git Extension]
    }

    component "Notebook Server" as NS {
        [CPU-Based Image]
        [GPU-Based Image]
        [Persistent Storage]
    }

    component "Security" as SEC {
        [Network Policies]
        [RBAC]
    }

    component "Storage" as STORAGE {
        [Persistent Volume]
    }

    [JH] <-- [JL]
    [JH] --> [NS]
    [NS] --> [STORAGE]
    [JH] --> [SEC]
}

package "External Services" {
    component "Active Directory/LDAP" as AD
    [JH] --> [AD]
}

package "Deployment" {
    component "OpenShift Templates" as OT
    [OT] --> [JH]
    [OT] --> [JL]
    [OT] --> [NS]
}

package "Automation" {
    component "Idle Server Culling" as ISC
    [ISC] --> [JH]
}

@enduml
```