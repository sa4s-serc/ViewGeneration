```plantuml
@startuml madderle_Capstone-Realtime-Streaming-Analytics

actor User

participant "Twitter Service" as Twitter
participant "IEX Service" as IEX
participant "Manager Service" as Manager
participant "AWS Kinesis" as Kinesis
participant "Redis Pub/Sub" as Redis
participant "MongoDB" as MongoDB
participant "S3 Storage" as S3
participant "SKLearn Model Development" as ModelDev
participant "SKLearn Model Deployment" as ModelDeploy
participant "Data Service" as DataService

User -> Manager : Start System
Manager -> Twitter : Collect Tweets
Twitter -> Redis : Publish Tweets
Manager -> IEX : Retrieve Stock Data
IEX -> Redis : Publish Stock Data
Redis -> Kinesis : Stream Data
Kinesis -> MongoDB : Store Tweets and Stock Data

User -> ModelDev : Train Model
ModelDev -> S3 : Upload Model
ModelDev -> MongoDB : Log Training Metrics

User -> ModelDeploy : Deploy Model
ModelDeploy -> S3 : Load Model
ModelDeploy -> MongoDB : Fetch Data
ModelDeploy -> MongoDB : Log Predictions

User -> DataService : Request Data
DataService -> MongoDB : Query Data
DataService -> User : Return Data

@enduml
```