```plantuml
@startuml ut-ims-robotics_robotont

package "robotont" {
    [robotont_driver] --> [robotont_teleop]
    [robotont_teleop] --> [robotont_training]
    [robotont_driver] --> [robotont_sensors]
    [robotont_driver] --> [robotont_description]
    [robotont_teleop] --> [robotont_description]
    [robotont_training] --> [robotont_description]
    [robotont_sensors] --> [robotont_description]
}

database "ROS Parameter Server" as param_server
cloud "ROS Topics" as ros_topics
cloud "ROS Services" as ros_services

[robotont_driver] --> ros_topics
[robotont_driver] --> ros_services
[robotont_teleop] --> ros_topics
[robotont_training] --> ros_topics
[robotont_sensors] --> ros_topics

[robotont_driver] --> param_server
[robotont_teleop] --> param_server
[robotont_training] --> param_server
[robotont_sensors] --> param_server

@enduml
