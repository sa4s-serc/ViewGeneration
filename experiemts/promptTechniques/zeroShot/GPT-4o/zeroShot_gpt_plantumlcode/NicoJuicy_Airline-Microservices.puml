```plantuml
@startuml NicoJuicy_Airline-Microservices

package "Api Gateway" {
  component "Airline.ApiGateway" <<Gateway>> {
    [Routing]
  }
}

package "Microservices" {
  component "Identity Service" {
    [IdentityServer]
    [JWT Authentication]
  }
  component "Flight Service" {
    [Flight Management]
    [Seat Availability]
  }
  component "Passenger Service" {
    [Passenger Management]
  }
  component "Reservation Service" {
    [Reservation Management]
  }
}

package "Building Blocks" {
  [Exception Handling]
  [Logging (Serilog)]
  [Swagger Configuration]
  [Data Access Interfaces]
  [Messaging]
  [Security]
}

package "Infrastructure" {
  [Docker]
  [Kubernetes]
  [MassTransit]
  [RabbitMQ]
}

package "Architecture Patterns" {
  [DDD]
  [CQRS]
  [MediatR]
  [Event-Driven Architecture]
  [Hexagonal Architecture]
}

[Airline.ApiGateway] --> [Identity Service]
[Airline.ApiGateway] --> [Flight Service]
[Airline.ApiGateway] --> [Passenger Service]
[Airline.ApiGateway] --> [Reservation Service]

[Identity Service] -[HIDDEN]-> [Building Blocks]
[Flight Service] -[HIDDEN]-> [Building Blocks]
[Passenger Service] -[HIDDEN]-> [Building Blocks]
[Reservation Service] -[HIDDEN]-> [Building Blocks]

[Identity Service] --> [Infrastructure]
[Flight Service] --> [Infrastructure]
[Passenger Service] --> [Infrastructure]
[Reservation Service] --> [Infrastructure]

@enduml
```