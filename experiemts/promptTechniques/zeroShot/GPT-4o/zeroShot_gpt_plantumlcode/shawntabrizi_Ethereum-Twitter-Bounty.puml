```plantuml
@startuml shawntabrizi_Ethereum-Twitter-Bounty

package "Ethereum-Twitter-Bounty" {
    [Frontend Interface]
    [Web3.js Library]
    [Smart Contracts]
    [Oracle Service]
    [Truffle Framework]
}

package "Smart Contracts" {
    component [TwitterBounty.sol] {
        [createBounty()]
        [contribute()]
        [fulfillBounty()]
        [oraclizeTweet()]
    }
    
    component [TwitterOracle.sol] {
        [oraclizeTweet()]
        [__callback()]
    }
}

package "Development & Deployment" {
    component [Truffle Framework] {
        [truffle-config.js]
        [migrations/2_deploy_contracts.js]
        [test/TestTwitterBounty.js]
        [test/TestTwitterOracle.js]
        [TwitterBounty.json]
    }
}

[Frontend Interface] --> [Web3.js Library]
[Frontend Interface] --> [Smart Contracts]
[Web3.js Library] --> [Ethereum Blockchain]
[TwitterBounty.sol] --> [TwitterOracle.sol]
[TwitterOracle.sol] --> [Oracle Service]
[Truffle Framework] --> [Smart Contracts]
[Frontend Interface] --> [Oracle Service] : "via Web3.js"

@enduml
```