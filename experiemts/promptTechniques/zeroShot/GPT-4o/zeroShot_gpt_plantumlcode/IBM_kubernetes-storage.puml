```plantuml
@startuml IBM_kubernetes-storage

actor User as user
participant "Web Browser" as browser
participant "GitHub" as github
participant "IBM Cloud" as ibmCloud
participant "Kubernetes Cluster" as k8sCluster
participant "Guestbook Application" as guestbookApp
participant "IBM Cloud Storage" as ibmStorage

user -> browser : Access GitHub Repository
browser -> github : Clone repository

user -> browser : Open Documentation
browser -> github : Fetch documentation pages

user -> browser : Start Lab 5 - Object Storage
browser -> k8sCluster : Deploy Guestbook Application
k8sCluster -> guestbookApp : Initialize with default settings

user -> browser : Configure IBM Cloud Services
browser -> ibmCloud : Authenticate and provision services

user -> browser : Deploy Object Storage
browser -> k8sCluster : Apply cos-with-s3fs Configuration
k8sCluster -> ibmStorage : Request Object Storage provisioning

user -> browser : Deploy Block Storage
browser -> k8sCluster : Apply Block Storage Configuration
k8sCluster -> ibmStorage : Request Block Storage provisioning

user -> browser : Validate Application
browser -> guestbookApp : Access application UI
guestbookApp -> ibmStorage : Store and retrieve data

user -> browser : Complete Lab
browser -> github : Update lab progress

@enduml
```