```plantuml
@startuml liyangbing_rocketmq-http-gateway

package "RocketMQ HTTP Gateway" {
    component "Launcher" <<Spring>> {
        [Launcher] --> [Gateway Server]
    }

    package "Transport Layer" {
        component "Netty Connection" {
            [RequestDecoder] --> [NettyConnectionManageHandler]
            [RequestValidator] --> [NettyConnectionManageHandler]
            [ResponseEncoder] --> [NettyConnectionManageHandler]
            [NettyConnectionManageHandler] --> [GatewayLoggingHandler]
        }
    }

    package "Processor Layer" {
        component "Message Processing" {
            [ProduceMessageProcessor] --> [ProducerManager]
            [SubscriptionChangeWatcher] --> [ProducerManager]
            [SubscriptionChangeWatcher] --> [ConsumerManager]
            [HttpExecutor] --> [HttpMessageListenerConcurrently]
        }
    }

    package "Common Layer" {
        [Service] --> [ProducerManager]
        [Service] --> [ConsumerManager]
    }

    package "Management" {
        component "ProducerManager" {
            [ProducerManager] --> [RocketMQ Producer]
        }

        component "ConsumerManager" {
            [ConsumerManager] --> [RocketMQ Consumer]
        }
    }

    [Gateway Server] --> [Netty Connection]
    [Gateway Server] --> [Message Processing]
    [Gateway Server] --> [ProducerManager]
    [Gateway Server] --> [ConsumerManager]

    [ProduceMessageProcessor] --> [RocketMQ Producer]
    [HttpMessageListenerConcurrently] --> [HTTP Endpoint]
}

@enduml
```