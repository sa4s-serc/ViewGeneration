```plantuml
@startuml minism_hotel

package "minism_hotel Deployment" {

    node "Docker Host" <<docker-compose>> {
        component "hotel-master" {
            [REST API]
            [RPC Server]
            [Session Management]
            [Reaper]
        }
        component "SQLite Database" {
            [Database]
        }
    }

    node "Docker Host Spawner" <<docker-compose>> {
        component "hotel-spawner" {
            [RPC Server]
            [Game Server Management]
        }
    }

    package "Shared Libraries" {
        [Configuration Loading]
        [Environment Variable Handling]
        [Logging]
        [Crypto]
    }

    package "Protobuf Communication" {
        [gRPC Messages]
    }

    [Docker Host] --> [hotel-master]
    [Docker Host] --> [SQLite Database]
    [Docker Host Spawner] --> [hotel-spawner]

    [hotel-master] --> [SQLite Database]
    [hotel-spawner] --> [hotel-master] : gRPC
    [hotel-master] --> [hotel-spawner] : gRPC

    [Shared Libraries] -- [hotel-master]
    [Shared Libraries] -- [hotel-spawner]

    [Protobuf Communication] ..> [hotel-master]
    [Protobuf Communication] ..> [hotel-spawner]

    [Makefile] --> [Docker Host]
    [docker-compose.yml] --> [Docker Host]
    [Makefile] --> [Docker Host Spawner]
    [docker-compose.yml] --> [Docker Host Spawner]

}

@enduml
