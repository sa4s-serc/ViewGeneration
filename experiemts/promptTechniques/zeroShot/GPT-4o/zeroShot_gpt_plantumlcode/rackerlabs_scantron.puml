```plantuml
@startuml rackerlabs_scantron

package "Scantron Architecture" {

    [Console] <<Django Application>> {
        [REST API] <<Django REST Framework>>
        [Scan Scheduler] <<Python Script>>
        [Result Processor] <<Scripts>>
        [Web Front-End] <<HTML/JS/CSS>>
    }

    [Engine] <<Scanning Node>> {
        [Engine Script] <<Python Script>>
        [Nmap]
        [Masscan]
        [NFS Watcher] <<Shell Script>>
    }

    [Nginx] <<API Gateway/Proxy>>
    [Redis Queue] <<Asynchronous Processing>>
    [Shared NFS Volume] <<Storage>>
    [Ansible Playbooks] <<Automation>>
    [External Systems] <<Client>>

    ' Relationships for performance and deployment
    [External Systems] --> [Nginx] : "API Requests"
    [Nginx] --> [Console] : "Routes Requests"
    [Console] --> [REST API] : "Communicates via"
    [Console] --> [Scan Scheduler] : "Schedules Scans"
    [Console] --> [Result Processor] : "Processes Results"
    [REST API] --> [Engine] : "Distributes Tasks"
    [Engine] --> [Nmap] : "Executes Scan"
    [Engine] --> [Masscan] : "Executes Scan"
    [Engine] --> [NFS Watcher] : "Monitors"
    [Engine] --> [Shared NFS Volume] : "Stores Results"
    [Console] --> [Shared NFS Volume] : "Accesses Results"
    [Ansible Playbooks] --> [Console] : "Deploys"
    [Ansible Playbooks] --> [Engine] : "Deploys"
    [Console] --> [Redis Queue] : "Schedules Tasks"
    [Redis Queue] --> [Engine] : "Distributes Tasks Asynchronously"

    ' Performance and Deployment Highlights
    [Nginx] - [Shared NFS Volume] : "Efficient Data Handling"
    [Ansible Playbooks] ..> [Console] : "Automated Deployment"
    [Ansible Playbooks] ..> [Engine] : "Automated Deployment"
}

@enduml
```