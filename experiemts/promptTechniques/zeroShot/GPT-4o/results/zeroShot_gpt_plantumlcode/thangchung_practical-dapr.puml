```plantuml
@startuml thangchung_practical-dapr

package "CoolStore Application" {
    [Blazor WebAssembly (WebUI)]
    [IdentityServer4 (CoolStore.IdentityServer)]
    [ProductCatalogApi]
    [InventoryApi]
    [N8T Building Blocks]
}

package "N8T Building Blocks" {
    [N8T.Domain]
    [N8T.Infrastructure]
}

package "APIs" {
    [REST]
    [gRPC]
    [GraphQL]
}

package "Dapr Components" {
    [State Management (Redis)]
    [Pub/Sub Messaging (Redis)]
}

package "Observability Tools" {
    [Zipkin]
    [Seq]
}

package "CI/CD" {
    [GitHub Actions]
}

package "Deployment" {
    [Kubernetes]
    [Tye]
}

package "Security" {
    [OpenID Connect]
    [OAuth 2.0]
    [Security Headers]
}

[WebUI] --> [ProductCatalogApi] : uses GraphQL
[WebUI] --> [IdentityServer4] : for authentication
[IdentityServer4] --> [Security] : handles authentication & authorization
[ProductCatalogApi] --> [InventoryApi] : uses gRPC, REST, GraphQL
[ProductCatalogApi] --> [N8T.Domain] : uses domain events
[ProductCatalogApi] --> [N8T.Infrastructure] : for infrastructure services
[InventoryApi] --> [N8T.Domain] : uses domain events
[InventoryApi] --> [N8T.Infrastructure] : for infrastructure services

[ProductCatalogApi] --> [Dapr Components] : pub/sub, state management
[InventoryApi] --> [Dapr Components] : pub/sub, state management

[Kubernetes] --> [Deployment] : deploys microservices
[Tye] --> [Deployment] : local orchestration

[GitHub Actions] --> [CI/CD] : automates build and deploy

[Zipkin] --> [Observability Tools] : for distributed tracing
[Seq] --> [Observability Tools] : for structured logging

@enduml
```