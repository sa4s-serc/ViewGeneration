```plantuml
@startuml AhmedAbdelGawadFarag_Shams-Personal-Assistant

actor User
participant "Shams_Android: MainActivity" as MainActivity
participant "Shams_Android: BotManager" as BotManager
participant "Main Server: app.py" as MainServer
participant "NER Server: app.py" as NERServer
participant "Google Cloud STT" as GoogleSTT
participant "Google Cloud TTS" as GoogleTTS

User -> MainActivity: Voice Command
MainActivity -> MainActivity: Record Voice (RecordingManager)
MainActivity -> BotManager: Process Command

BotManager -> MainServer: Send Voice Data

MainServer -> GoogleSTT: Convert Speech-to-Text
GoogleSTT --> MainServer: Text

MainServer -> MainServer: Classify Intent (intent_classifier)
MainServer -> NERServer: Extract Entities
NERServer --> MainServer: Entities

MainServer -> MainServer: Execute Intent (intents.py)

alt Intent Requires TTS
    MainServer -> GoogleTTS: Convert Text-to-Speech
    GoogleTTS --> MainServer: Audio Response
end

MainServer --> BotManager: Response (Text/Audio)
BotManager --> MainActivity: Display/Play Response
MainActivity --> User: Response

@enduml
```