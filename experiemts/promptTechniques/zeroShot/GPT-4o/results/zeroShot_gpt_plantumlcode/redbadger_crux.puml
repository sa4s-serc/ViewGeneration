```plantuml
@startuml redbadger_crux

package "Core Framework" {
    [crux_core] as core
}

package "Key Utilities" {
    [crux_http] as http
    [crux_time] as time
}

package "Examples" {
    [Multi-Platform UI Shells] as shells
    [Core Counter Logic] as counter
}

core -[hidden]-> http
core -[hidden]-> time
core -[hidden]-> shells
core -[hidden]-> counter

component "App" as app
component "Core" as core_struct
component "Effect" as effect
component "Bridge" as bridge
component "Http" as http_capability
component "Time" as time_capability

app --> core_struct : control flow
core_struct --> effect : requests side effects
effect --> bridge : FFI communication
app --> http_capability : uses Http Capability
app --> time_capability : uses Time Capability

shells .down.> bridge : uses
counter --> app : uses

@enduml
```