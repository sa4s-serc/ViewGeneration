```plantuml
@startuml IBM_spectrum-protect-sppmon

package "SPPMon Core" {
    component "sppmon.py" as SPPMonCore
    component "sppmonMethods/*" as SPPMonMethods
    SPPMonCore --> SPPMonMethods : control_flow
}

package "SPPCheck" {
    component "sppcheck.py" as SPPCheckCore
    component "sppCheck/excel" as SPPCheckExcel
    component "sppCheck/generator" as SPPCheckGenerator
    component "sppCheck/report" as SPPCheckReport
    component "sppCheck/predictor" as SPPCheckPredictor
    SPPCheckCore --> SPPCheckExcel : control_flow
    SPPCheckCore --> SPPCheckGenerator : control_flow
    SPPCheckCore --> SPPCheckReport : control_flow
    SPPCheckCore --> SPPCheckPredictor : control_flow
}

package "SPP Connection" {
    component "rest_client.py" as RestClient
    component "ssh_client.py" as SSHClient
    component "api_queries.py" as APIQueries
    SPPMonMethods --> RestClient : connectivity
    SPPMonMethods --> SSHClient : connectivity
    APIQueries --> RestClient : control_flow
}

package "Data Storage" {
    component "influx/influx_client.py" as InfluxClient
    SPPMonMethods --> InfluxClient : control_flow
}

package "Installation & Configuration" {
    component "installer.sh" as InstallerScript
    component "addConfigFile.py" as AddConfigFile
    component "addCrontabConfig.py" as AddCrontabConfig
    InstallerScript --> AddConfigFile : control_flow
    InstallerScript --> AddCrontabConfig : control_flow
}

package "Data Visualization" {
    component "grafana" as Grafana
    component "generifyDashboard.py" as GenerifyDashboard
    GenerifyDashboard --> Grafana : control_flow
}

SPPMonCore --> APIQueries : control_flow
SPPMonCore --> SSHClient : control_flow
SPPMonCore --> InfluxClient : control_flow
SPPCheckCore --> InfluxClient : control_flow

@enduml
```