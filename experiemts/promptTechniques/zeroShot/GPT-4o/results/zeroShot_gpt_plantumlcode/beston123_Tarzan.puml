```plantuml
@startuml beston123_Tarzan

package "Tarzan Distributed Transaction System" {
    
    [Server] --> [Client] : manages
    [Client] --> [Message Broker] : sends messages
    [Server] --> [Registry] : service discovery
    [Registry] --> [tarzan-registry] : Zookeeper
    [Server] --> [tarzan-mq] : manage transactions
    [tarzan-mq] --> [Message Broker] : RocketMQ integration
    [Server] --> [tarzan-rpc] : remote communication
    [Server] --> [tarzan-store] : data persistence
    [tarzan-store] --> [Database] : MySQL
    [Server] --> [tarzan-cluster] : clustering strategies
    [tarzan-store] --> [Redis] : Distributed Locks

    component "Server" {
        [ServerStartup]
        [ConfigManager]
        [ScheduledServiceManager]
        [MessageResendService]
        [ServerController]
    }

    component "Client" {
        [MessageSender]
        [TransactionHandler]
    }

    component "Registry" {
        [ServerRegistry]
        [Address]
        [Discovery]
    }

    component "Message Broker" {
        [RocketMQ]
    }

    component "tarzan-mq" {
        [RocketMQMessageNotifier]
        [RocketMQTransactionChecker]
    }

    component "tarzan-registry" {
        [ZookeeperIntegration]
    }

    component "tarzan-rpc" {
        [RpcClient]
        [RpcServer]
        [InvokeCallback]
    }

    component "tarzan-store" {
        [RocketMQStoreService]
        [ToSendMessage]
        [MessageConsume]
        [ToCheckMessage]
        [MessageAggregatePlan]
    }

    component "tarzan-cluster" {
        [LoadBalancer]
    }
}

@enduml
