```plantuml
@startuml zmyzheng_TweetMap

package "zmyzheng_TweetMap" {

    [Tweet Collector] --> [Kafka Message Queue]
    [Kafka Message Queue] --> [Flink Processor]
    [Flink Processor] --> [Elasticsearch Data Store]
    [REST API Server] --> [Elasticsearch Data Store]
    [Frontend Visualization] --> [REST API Server]

    [Tweet Collector] -up-> [Docker]
    [Flink Processor] -up-> [Docker]
    [REST API Server] -up-> [Docker]
    [Frontend Visualization] -up-> [Docker]

    [Docker] --> [Kubernetes]

    component "Tweet Collector" {
        [SocialMediaCollector] --> [KafkaSink]
        [Sinkable] --> [KafkaSink]
    }

    component "Flink Processor" {
        [StreamProcessor] --> [StreamProcessingDriver]
        [KafkaEsProcessor] --> [TweetKafkaEsProcessor]
    }

    component "REST API Server" {
        package Controllers {
            [TweetController]
            [TopicController]
        }
        package Services {
            [TweetService]
            [TopicService]
        }
        package Repositories {
            [TweetRepository]
            [EsOperationRepository]
        }
        package DomainObjects {
            [Tweet]
            [TopicStatistic]
            [TopicTrend]
            [HotTopicsTrend]
        }
        package DTOs {
            [TweetDTO]
            [TopicStatisticDTO]
            [TopicTrendDTO]
            [HotTopicsTrendDTO]
        }
        package Mappers {
            [TweetMapper]
            [TopicStatisticMapper]
            [TopicTrendMapper]
            [HotTopicsTrendMapper]
        }
    }

    component "Frontend Visualization" {
        package src {
            [index_html]
            [main_ts]
            package app {
                [Components]
            }
        }
    }
}

@enduml
