```plantuml
@startuml mrubash1_trainspotting

actor User
participant "Video_Camera" as Camera
participant "Video_Sensor" as Sensor
participant "Video_Detector" as Detector
participant "TensorFlow Model" as TFModel
participant "Data Storage" as Storage

User -> Camera: Start Capture
activate Camera

Camera -> Sensor: Frame Stream (via input_deque)
activate Sensor

Sensor -> Sensor: Background Subtraction
Sensor -> Sensor: Noise Reduction
Sensor -> Sensor: ROI Extraction

Sensor -> Detector: Processed Frame
activate Detector

Detector -> Detector: Motion Analysis
Detector -> Detector: Train Detection

alt Train Detected
    Detector -> TFModel: Classification Request
    activate TFModel
    TFModel --> Detector: Classification Result
    deactivate TFModel
    
    Detector -> Detector: Direction Determination
    Detector -> Storage: Store Detection Event
    activate Storage
    Storage --> Detector: Confirmation
    deactivate Storage
    
    Detector -> Camera: Adjust Settings (Day/Night)
    Camera --> Detector: Settings Updated
end

Detector --> Sensor: Processed Result
deactivate Detector

Sensor --> Camera: Feedback
deactivate Sensor

Camera --> User: Live Feed/Status
deactivate Camera

@enduml
```