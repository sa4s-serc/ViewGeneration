```plantuml
@startuml today-real-estate_today-real-estate_front-end

!define DEVICE <<device>>
!define CONTAINER <<container>>
!define COMPONENT <<component>>

title Deployment View - Today Real Estate Frontend

node "Client Browser" as browser {
  component "Vue.js Application" as vue_app {
    component "App.vue" as app
    component "Router" as router
    component "Vuex Store" as store {
      component "userStore" as user_store
      component "searchStore" as search_store
    }
    
    component "API Client" as api {
      component "Axios" as axios
      component "Auth API" as auth_api
      component "User API" as user_api
      component "Search API" as search_api
      component "News API" as news_api
      component "Inquiry API" as inquiry_api
    }
    
    component "UI Components" as ui {
      component "Header" as header
      component "Footer" as footer
      component "LoginForm" as login_form
      component "KakaoMap" as kakao_map
    }
    
    component "Views" as views {
      component "MainPage" as main_page
      component "LoginPage" as login_page
      component "SearchPage" as search_page
    }
  }
}

node "External Services" as external {
  component "Backend API" as backend_api
  component "Kakao Maps API" as kakao_api
  component "News API" as external_news_api
}

' Internal connections
app --> router
app --> store
app --> ui
router --> views
store --> user_store
store --> search_store
api --> axios
auth_api --> axios
user_api --> axios
search_api --> axios
news_api --> axios
inquiry_api --> axios
kakao_map --> kakao_api

' External connections
auth_api --> backend_api
user_api --> backend_api
search_api --> backend_api
news_api --> external_news_api
inquiry_api --> backend_api

@enduml
```