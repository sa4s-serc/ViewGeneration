```plantuml
@startuml turkcellcloud_jupyter-openshift

skinparam monochrome true
skinparam shadowing false
skinparam nodesep 10
skinparam ranksep 20

rectangle "OpenShift Cluster" {
    component "JupyterHub" {
        component "LDAP Authenticator" as ldap
        component "KubeSpawner" as spawner
        component "Culling Service" as cull
    }

    database "PostgreSQL" as db {
        component "User Sessions"
    }

    node "Notebook Pods" {
        component "JupyterLab" as jupyterlab {
            component "Git Extension"
            component "TensorFlow"
            component "Oracle Client"
        }
    }

    component "Persistent Volumes" as storage
    component "Network Policies" as netpol
}

cloud "LDAP/AD Server" as ldap_server
cloud "User Devices" as clients

ldap_server --> ldap : LDAP Auth (TLS)
clients --> JupyterHub : HTTPS (443)
JupyterHub --> db : Session Storage
JupyterHub --> spawner : Spawn Pods
spawner --> "Notebook Pods" : Creates Pods
"Notebook Pods" --> storage : Persistent Storage
netpol --> "Notebook Pods" : Ingress/Egress Control
cull --> "Notebook Pods" : Idle Termination

@enduml
```