```plantuml
@startuml exmgr_GatewayXM

package "IoT Devices" {
    [ModBus Smart Meters] as modbus
    [ESP8266/ESP32 Sensor Nodes] as esp_nodes
}

package "GatewayXM" {
    [Eclipse Kura] as kura {
        [Kura-Tb-Bundle] as kura_tb
        [ModBus Driver] as modbus_driver
    }
    [Artemis MQTT Broker] as mqtt
    [Agile-Stack] as agile_stack
    [Docker Container] as docker
}

package "Cloud Platform" {
    [Thingsboard IoT] as thingsboard
    [Resin.io (Balena)] as resin
}

modbus --> modbus_driver : ModBus protocol
esp_nodes --> mqtt : MQTT telemetry
modbus_driver --> kura_tb : Data forwarding
kura_tb --> thingsboard : REST/MQTT
kura_tb --> mqtt : Subscribes
agile_stack --> kura : Provides stack
docker --> kura : Hosts
resin --> docker : Manages deployment
thingsboard --> resin : OTA updates

@enduml
```