```plantuml
@startuml itays123_partydeck

skinparam componentStyle uml2
skinparam monochrome true

package "Partydeck System" {
    [Panel Frontend] as panel
    [Game Frontend] as game
    [Server Backend] as server
    [Google Cloud Run] as cloud

    panel - [Authentication]
    panel - [Deck Management]
    panel - [Game Library]

    game - [Game Connection]
    game - [Player Actions]
    game - [Game Display]

    server - [WebSocket Handler]
    server - [Game Logic]
    server - [REST API]
    server - [State Builder]

    panel --> server : REST API calls
    game --> server : WebSocket connection
    server --> cloud : Deploys to
    panel --> cloud : Deploys to
    game --> cloud : Deploys to
}

@enduml
```