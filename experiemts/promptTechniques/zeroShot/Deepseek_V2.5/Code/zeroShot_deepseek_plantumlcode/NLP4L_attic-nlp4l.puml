```plantuml
@startuml NLP4L_attic-nlp4l

package "NLP4L Library" {
    [Core Indexing] as CoreIndexing
    [Schema Management] as SchemaMgmt
    [Text Analysis] as TextAnalysis
    [NLP Algorithms] as NLPAlgos
    [Corpus Handling] as CorpusHandling
    [REPL Interface] as REPL
    [Synonym Management] as SynonymMgmt
    [Feature Selection] as FeatureSelection
    [Transliteration] as Transliteration
    [FST Support] as FSTSupport
}

[Apache Lucene] as Lucene

CoreIndexing --> Lucene : "uses"
SchemaMgmt --> Lucene : "uses"
TextAnalysis --> Lucene : "uses"
NLPAlgos --> Lucene : "uses"
CorpusHandling --> Lucene : "uses"
REPL --> CoreIndexing : "interacts with"
REPL --> SchemaMgmt : "interacts with"
REPL --> TextAnalysis : "interacts with"
REPL --> NLPAlgos : "interacts with"
SynonymMgmt --> CoreIndexing : "uses"
FeatureSelection --> CoreIndexing : "uses"
Transliteration --> CoreIndexing : "uses"
FSTSupport --> CoreIndexing : "uses"

note right of NLPAlgos
  Includes HMM and
  Collocational Analysis
end note

note right of TextAnalysis
  Supports Japanese text
  analysis via specialized
  analyzers
end note

note right of REPL
  Provides interactive shell
  with Zeppelin visualization
end note

@enduml
```