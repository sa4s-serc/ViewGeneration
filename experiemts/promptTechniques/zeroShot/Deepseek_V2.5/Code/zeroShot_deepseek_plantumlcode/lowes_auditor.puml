```plantuml
@startuml lowes_auditor

component "Client Application" {
    [Spring Boot Starter]
    [Auditor API]
}

component "Kafka" as kafka {
    [Audit Events Topic]
}

component "Application Server" {
    [ConsumerService]
    [AuditEventRepositoryService]
}

component "Elasticsearch" as elasticsearch {
    [Audit Index]
}

[Spring Boot Starter] --> [Auditor API]
[Auditor API] --> kafka : "publishes audit events"
kafka --> [ConsumerService] : "consumes events"
[ConsumerService] --> [AuditEventRepositoryService] : "processes events"
[AuditEventRepositoryService] --> elasticsearch : "stores audit data"

@enduml
```