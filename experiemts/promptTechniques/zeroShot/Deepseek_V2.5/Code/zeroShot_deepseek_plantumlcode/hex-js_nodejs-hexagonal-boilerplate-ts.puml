}

package "AWS Services" {
    [AWS DynamoDB] as aws_dynamo
    [AWS SQS] as aws_sqs
    [AWS Lambda] as aws_lambda
}

package "Local Development" {
    [Localstack] as localstack
    [Terraform] as terraform
    [Docker Compose] as docker
}

