```plantuml
@startuml wso2_chef-apim

component "Chef Server" as chef_server {
    component "Cookbook Repository" as cookbook_repo
    component "Node Attributes" as node_attrs
}

component "Target Node" as target_node {
    component "Chef Client" as chef_client
    component "WSO2 API Manager" as wso2_apim {
        component "Key Manager" as key_manager
        component "Publisher" as publisher
        component "Store" as store
        component "Traffic Manager" as traffic_manager
        component "Gateway Manager" as gateway_manager
        component "Gateway Worker" as gateway_worker
    }
    component "MySQL Database" as mysql_db
    component "Java Runtime" as java_runtime
}

chef_server --> target_node : "Push cookbooks &\nconfiguration"
cookbook_repo --> chef_client : "Deploy recipes &\ntemplates"
node_attrs --> chef_client : "Provide configuration\nparameters"

chef_client --> wso2_apim : "Install & configure"
chef_client --> java_runtime : "Install & configure"
chef_client --> mysql_db : "Configure connection"

wso2_apim --> mysql_db : "Database operations"
key_manager --> traffic_manager : "Token validation"
publisher --> store : "API synchronization"
gateway_manager --> gateway_worker : "Deployment sync"

@enduml
```