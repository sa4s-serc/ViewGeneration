```plantuml
@startuml matrix-io_matrix-malos-zwave

package "MATRIX Platform" {
    component "MATRIX Core (MALOS)" {
        [MALOS Core Service]
    }

    component "Z-Wave Driver" {
        [DriverZwave]
        [DriverManager]
    }

    component "Protocol Buffers" as protobuf {
        [*.proto files]
    }

    component "0MQ" as zmq {
        [ZMQ Publisher]
        [ZMQ Subscriber]
    }
}

component "Z/IP Gateway" {
    [Z/IP Gateway Service]
}

component "Z-Wave Module" {
    [Serial Interface]
}

component "Systemd" {
    [matrixio-malos-zwave.service]
}

component "JavaScript Tools" {
    [addnode.js]
    [list.js]
    [removenode.js]
    [test_*.js]
}

[MALOS Core Service] --> [DriverManager] : manages
[DriverManager] --> [DriverZwave] : controls
[DriverZwave] --> [Z/IP Gateway Service] : communicates via\nZ-Wave protocol
[Z/IP Gateway Service] --> [Serial Interface] : connects via\n/dev/ttyMATRIX0
[DriverZwave] --> [ZMQ Publisher] : publishes events
[ZMQ Subscriber] --> [JavaScript Tools] : receives events
[JavaScript Tools] --> [ZMQ Publisher] : sends commands
[*.proto files] --> [DriverZwave] : defines message formats
[matrixio-malos-zwave.service] --> [MALOS Core Service] : starts/manages

@enduml
```