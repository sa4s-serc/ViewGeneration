```plantuml
@startuml DevOps-Represent_devopsgirls-bootcamp-cn-2

component "User" as user #lightblue

component "S3 Bucket" as s3 {
    component "Static Website" as website
    component "React UI" as react
}

component "API Gateway" as apigw

component "Lambda Function" as lambda {
    component "Todo Logic" as logic
}

component "DynamoDB" as dynamodb {
    component "Todo Data" as data
}

user --> website : "Accesses"
website --> react : "Renders"
react --> apigw : "API Calls"
apigw --> lambda : "Proxies Requests"
lambda --> dynamodb : "CRUD Operations"
logic --> data : "Reads/Writes"

note right of apigw
    Uses {proxy+} pattern
    for request routing
end note

note left of lambda
    Handles GET/PUT/DELETE
    for todo operations
end note

@enduml
```