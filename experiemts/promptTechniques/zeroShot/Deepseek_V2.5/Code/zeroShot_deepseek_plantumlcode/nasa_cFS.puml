```plantuml
@startuml nasa_cFS

package "NASA cFS" {
    [cFE (Core Flight Executive)] as cfe
    [OSAL (Operating System Abstraction Layer)] as osal
    [PSP (Platform Support Package)] as psp
    [Applications] as apps
    [Tools] as tools

    component "Event Services (ES)" as es
    component "Software Bus (SB)" as sb
    component "Table Services (TBL)" as tbl
    component "Time Services (TIME)" as time

    component "Lab Applications" as lab_apps {
        [Sample App] as sample
        [CI Lab] as ci_lab
        [TO Lab] as to_lab
        [SCH Lab] as sch_lab
    }
}

package "External" {
    [Operating System] as os
    [Hardware] as hw
}

cfe --> osal : depends on
cfe --> psp : depends on
cfe --> es : includes
cfe --> sb : includes
cfe --> tbl : includes
cfe --> time : includes

apps --> cfe : depends on
lab_apps --> cfe : depends on
tools --> cfe : depends on

osal --> os : abstracts
psp --> hw : interfaces with

@enduml
