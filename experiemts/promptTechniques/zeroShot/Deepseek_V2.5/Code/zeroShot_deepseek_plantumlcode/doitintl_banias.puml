```plantuml
@startuml doitintl_banias

!define PUBSUB_COMPONENT #FFD700
!define FRONTEND_COMPONENT #ADD8E6
!define BACKEND_COMPONENT #90EE90
!define STORAGE_COMPONENT #FFA07A
!define MONITORING_COMPONENT #FFB6C1

component "Frontend (Go)" as frontend <<FRONTEND_COMPONENT>> {
    component "HTTP API (/track)" as http_api
    component "Event Collector" as collector
    component "Event Publisher" as publisher
    component "GoPool" as gopool
    component "Configuration" as config
}

component "Google Pub/Sub" as pubsub <<PUBSUB_COMPONENT>> {
    interface "Event Topic" as pubsub_topic
}

component "Backend (Java Dataflow)" as backend <<BACKEND_COMPONENT>> {
    component "Dataflow Pipeline" as dataflow
    component "Schema Manager" as schema_manager
    component "Error Handler" as error_handler
}

component "BigQuery" as bigquery <<STORAGE_COMPONENT>> {
    component "Event Tables" as event_tables
    component "Error Table" as error_table
}

component "Google Cloud Storage" as gcs <<STORAGE_COMPONENT>> {
    component "Schema Bucket" as schema_bucket
}

component "Monitoring" as monitoring <<MONITORING_COMPONENT>> {
    component "Prometheus (/metrics)" as prometheus
    component "Stackdriver" as stackdriver
}

frontend --> pubsub_topic : Publishes batched\nevents
pubsub_topic --> dataflow : Subscribes to events
dataflow --> event_tables : Writes valid events
dataflow --> error_table : Writes malformed events
dataflow --> schema_bucket : Loads schemas\n(dynamically)
http_api --> collector : Receives events
collector --> publisher : Validates & batches
publisher --> gopool : Uses goroutine pool
config --> frontend : Provides configuration
frontend --> prometheus : Exposes metrics
prometheus --> stackdriver : Integrates with

@enduml
```