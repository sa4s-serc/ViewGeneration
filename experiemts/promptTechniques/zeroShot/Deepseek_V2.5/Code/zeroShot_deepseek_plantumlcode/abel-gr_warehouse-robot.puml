```plantuml
@startuml abel-gr_warehouse-robot

package "Warehouse Robot Simulation" {
    [Unity Environment] as Unity
    [CoppeliaSim] as Coppelia
    [Web Interface] as Web
    [Cloud Functions] as Cloud
}

component "Unity" as UnityComponent {
    [Warehouse Prefabs] as Prefabs
    [Robot Controller] as UnityRobot
}

component "CoppeliaSim" as CoppeliaComponent {
    [Robot Control API] as CoppeliaAPI
    [Inverse Kinematics] as Kinematics
    [OCR Pipeline] as OCR
}

component "Web Interface" as WebComponent {
    [User Controls] as Controls
    [Speech-to-Text] as Speech
}

component "Cloud Functions" as CloudComponent {
    [Speech Processing] as SpeechProcessing
}

Unity -- Coppelia : Remote API
Web -- Unity : Control Commands
Web -- Cloud : Speech Data
Cloud -- Web : Text Commands
Coppelia -- Unity : Sensor Data

UnityComponent ..> Unity
CoppeliaComponent ..> Coppelia
WebComponent ..> Web
CloudComponent ..> Cloud

@enduml
```