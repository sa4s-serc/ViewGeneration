```plantuml
@startuml zwt-sdk_zwt

package "ZWT Framework" {
    [Core Abstraction] as core
    [UI Components] as ui
    [Graphics and Input] as graphics
    [Layout Management] as layout
    [Menus] as menus
    [Styling] as styling
    [Backgrounds] as backgrounds
    [Utility] as utility
}

package "Platform Implementations" {
    [SE] as se
    [ME] as me
    [Android] as android
}

core --> ui
core --> graphics
core --> layout
core --> menus
core --> styling
core --> backgrounds
core --> utility

ui --> graphics
ui --> layout
ui --> styling
ui --> backgrounds

menus --> ui
menus --> graphics

graphics --> utility

se --> core
me --> core
android --> core

@enduml
```