```plantuml
@startuml balajich_resilience4j-helloworld

actor User
participant "Service A" as ServiceA
participant "Service B" as ServiceB
participant "Resilience4j" as Resilience4j
participant "Prometheus" as Prometheus
participant "Grafana" as Grafana

User -> ServiceA : HTTP Request
activate ServiceA

ServiceA -> Resilience4j : Apply resilience patterns
activate Resilience4j

alt Circuit Breaker closed
    Resilience4j -> ServiceB : Forward request
    activate ServiceB
    
    ServiceB --> Resilience4j : Response
    deactivate ServiceB
    
    Resilience4j --> ServiceA : Return response
else Circuit Breaker open
    Resilience4j --> ServiceA : Fallback response
end

Resilience4j -> Prometheus : Export metrics
activate Prometheus
Prometheus --> Resilience4j : ACK
deactivate Prometheus

ServiceA --> User : HTTP Response
deactivate ServiceA

Prometheus -> Grafana : Provide metrics
activate Grafana
Grafana --> Prometheus : ACK
deactivate Grafana

@enduml
```