```plantuml
@startuml blockchain-signaling-system_bloss-core

actor Attacker as attacker
participant "Stalk (Ryu Controller)" as stalk
participant "BloSS API" as bloss_api
participant "Pollen (Blockchain)" as pollen
participant "Smart Contracts" as contracts
participant "InfluxDB" as influxdb
participant "IPFS" as ipfs

attacker -> stalk: Sends malicious traffic
stalk -> stalk: Monitors traffic flows
stalk -> influxdb: Stores flow statistics
stalk -> stalk: Detects threshold violation
stalk -> bloss_api: Reports potential attack
bloss_api -> pollen: Requests attack reporting
pollen -> contracts: Submits attack report (transact)
contracts -> contracts: Validates and stores report
pollen -> ipfs: Stores encrypted attack details
pollen -> bloss_api: Returns report confirmation
bloss_api -> stalk: Confirms report submission
stalk -> stalk: Implements mitigation (blocking)

@enduml
```