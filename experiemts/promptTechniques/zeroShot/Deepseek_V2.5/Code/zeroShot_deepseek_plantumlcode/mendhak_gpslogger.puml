```plantuml
@startuml mendhak_gpslogger

package "GPSLogger" {
    [GpsMainActivity] as MainActivity
    [MainPreferenceActivity] as Preferences
    [GpsLoggingService] as LoggingService
    [GeneralLocationListener] as LocationListener
    [FileLoggerFactory] as LoggerFactory
    [PreferenceHelper] as Settings
    [AppSettings] as AppConfig

    component "File Loggers" as Loggers {
        [GPXLogger]
        [KMLLogger]
        [CSVLogger]
        [GeoJSONLogger]
        [NMEALogger]
    }

    component "File Senders" as Senders {
        [GoogleDriveWorker]
        [DropboxWorker]
        [OpenStreetMapWorker]
        [SFTPWorker]
        [FTPWorker]
        [OwnCloudWorker]
        [EmailWorker]
        [CustomURLWorker]
    }

    component "External Services" as External {
        [Google Drive]
        [Dropbox]
        [OpenStreetMap]
        [SFTP Server]
        [FTP Server]
        [OwnCloud]
        [Email Client]
        [Custom HTTP Service]
    }
}

MainActivity --> LoggingService : controls
MainActivity --> Preferences : launches
Preferences --> Settings : reads/writes
LoggingService --> LocationListener : uses
LoggingService --> LoggerFactory : creates
LoggerFactory --> Loggers : instantiates
LoggingService --> Senders : triggers
Senders --> External : uploads to
LoggingService --> Settings : reads config
LoggingService --> AppConfig : accesses
Settings --> AppConfig : manages

@enduml
```