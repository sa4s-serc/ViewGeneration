```plantuml
@startuml blentle_hikarikeeper

component "Client Applications" as clients {
    component "HikariKeeper Client" as client
}

component "HikariKeeper Server Cluster" as cluster {
    component "Server Node 1" as server1 {
        component "Raft Consensus" as raft1
        component "Metadata Storage" as storage1
        component "Discovery Service" as discovery1
    }
    
    component "Server Node 2" as server2 {
        component "Raft Consensus" as raft2
        component "Metadata Storage" as storage2
        component "Discovery Service" as discovery2
    }
    
    component "Server Node 3" as server3 {
        component "Raft Consensus" as raft3
        component "Metadata Storage" as storage3
        component "Discovery Service" as discovery3
    }
}

component "Spring Boot Applications" as spring {
    component "Spring Boot Starter" as starter
}

clients --> cluster : "RPC (gRPC/Thrift)"
client --> cluster : "Client API"

spring --> cluster : "Spring Integration"
starter --> cluster

server1 --> server2 : "Raft RPC"
server1 --> server3 : "Raft RPC"
server2 --> server3 : "Raft RPC"

raft1 --> storage1
raft2 --> storage2
raft3 --> storage3

discovery1 --> discovery2 : "Gossip Protocol"
discovery1 --> discovery3 : "Gossip Protocol"
discovery2 --> discovery3 : "Gossip Protocol"

@enduml
```