```plantuml
@startuml meshery_meshery

component "Meshery Server" {
    [GraphQL API]
    [gRPC Interface]
    [Configuration Manager]
    [Adapter Manager]
}

component "Meshery UI" {
    [React/Next.js Frontend]
    [MeshMap]
    [Performance Testing UI]
}

component "mesheryctl" {
    [CLI Commands]
    [Configuration]
}

component "Meshery Operator" {
    [MeshSync Controller]
    [Broker Controller]
}

component "Event Broker" as Broker {
    [NATS]
}

component "MeshKit" {
    [Error Handling]
    [Logging]
}

component "Adapters" {
    [Istio Adapter]
    [Linkerd Adapter]
    [Consul Adapter]
    [Other Adapters]
}

component "Providers" {
    [Local Provider]
    [Remote Providers]
}

[GraphQL API] --> [React/Next.js Frontend]
[gRPC Interface] --> [Adapters]
[Configuration Manager] --> [mesheryctl]
[MeshSync Controller] --> [Broker]
[Broker] --> [Meshery Server]
[MeshKit] --> [Meshery Server]
[MeshKit] --> [Meshery UI]
[MeshKit] --> [mesheryctl]
[Providers] --> [Meshery Server]
[Providers] --> [Meshery UI]

@enduml
```