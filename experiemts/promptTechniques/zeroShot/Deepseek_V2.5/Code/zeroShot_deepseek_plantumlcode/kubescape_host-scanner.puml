```plantuml
@startuml kubescape_host-scanner

package "Kubescape Host Scanner" {
    component "HTTP Server" {
        [HTTP Router]
        [Negroni Middleware]
        [API Handlers]
    }

    component "Sensor Package" {
        [OS Sensor]
        [Network Sensor]
        [Container Runtime Sensor]
        [Kubelet Sensor]
        [Control Plane Sensor]
        [Security Sensor]
        [Cloud Provider Sensor]
    }

    component "Utilities" {
        [Container Runtime Utils]
        [File System Utils]
    }

    component "Logging & Tracing" {
        [go-logger]
        [zap]
        [OpenTelemetry]
    }

    component "Configuration" {
        [Environment Variables]
        [File Configs]
    }

    component "K8s Deployment" {
        [DaemonSet]
        [Privileged Pod]
    }

    component "E2E Testing" {
        [Kind Cluster]
        [Ginkgo/Gomega]
        [Test Fixtures]
    }
}

[HTTP Router] --> [Negroni Middleware]
[Negroni Middleware] --> [API Handlers]
[API Handlers] --> [OS Sensor]
[API Handlers] --> [Network Sensor]
[API Handlers] --> [Container Runtime Sensor]
[API Handlers] --> [Kubelet Sensor]
[API Handlers] --> [Control Plane Sensor]
[API Handlers] --> [Security Sensor]
[API Handlers] --> [Cloud Provider Sensor]

[Container Runtime Sensor] --> [Container Runtime Utils]
[Kubelet Sensor] --> [File System Utils]
[Control Plane Sensor] --> [File System Utils]

[HTTP Server] --> [Logging & Tracing]
[Sensor Package] --> [Logging & Tracing]

[HTTP Server] --> [Configuration]
[Sensor Package] --> [Configuration]

[K8s Deployment] --> [HTTP Server]
[K8s Deployment] --> [Sensor Package]

[E2E Testing] --> [HTTP Server]
[E2E Testing] --> [Sensor Package]

@enduml
