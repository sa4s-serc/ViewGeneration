```plantuml
@startuml Bytom-Community_Bytom-Server

actor Client
participant "gRPC API" as API
participant "TxPool" as TxPool
participant "Blockchain Core" as Core
participant "P2P Network" as P2P
participant "Mining Module" as Mining
participant "Database" as DB

Client -> API: SubmitTransaction(request)
API -> TxPool: AddTransaction(tx)
TxPool -> Core: ValidateTransaction(tx)
Core -> DB: GetUTXOs()
DB --> Core: UTXO data
Core --> TxPool: Validation result
TxPool --> API: Transaction status
API --> Client: Response

P2P -> Core: BlockRequest(height)
Core -> DB: GetBlock(height)
DB --> Core: Block data
Core --> P2P: BlockResponse(block)

Mining -> Core: GetBlockTemplate()
Core -> DB: GetChainState()
DB --> Core: State data
Core --> Mining: BlockTemplate
Mining -> Core: SubmitBlock(block)
Core -> DB: StoreBlock(block)
DB --> Core: Storage confirmation
Core --> Mining: Block acceptance

P2P <-> P2P: Gossip blocks/transactions

@enduml
```