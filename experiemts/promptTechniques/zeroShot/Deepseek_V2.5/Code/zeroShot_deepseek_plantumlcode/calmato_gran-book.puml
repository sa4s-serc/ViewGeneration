```plantuml
@startuml calmato_gran-book

package "Web Admin Panel" {
    [Nuxt.js Framework] as nuxt
    [Vue.js Components] as vue
    [Vuex Store] as vuex
    [Axios Client] as axios
    [Firebase Auth] as firebase
}

package "API Gateway" {
    [Admin Gateway] as admin_gw
    [Native Gateway] as native_gw
    [gRPC Services] as grpc
}

package "Microservices" {
    [Auth Service] as auth
    [User Service] as user
    [Book Service] as book
    [Chat Service] as chat
}

package "Infrastructure" {
    [Firebase] as firebase_infra
    [Database] as db
    [Image Storage] as storage
}

' Web Admin Panel connections
nuxt --> vue : "renders"
nuxt --> vuex : "manages state"
vuex --> axios : "API calls"
axios --> admin_gw : "REST API"
nuxt --> firebase : "authentication"

' API Gateway connections
admin_gw --> grpc : "gRPC calls"
native_gw --> grpc : "gRPC calls"
grpc --> auth : "service calls"
grpc --> user : "service calls"
grpc --> book : "service calls"
grpc --> chat : "service calls"

' Microservice connections
auth --> firebase_infra : "auth provider"
book --> db : "persistence"
user --> db : "persistence"
chat --> db : "persistence"
book --> storage : "image uploads"

' External systems
firebase_infra -[hidden]--> firebase
storage -[hidden]--> db

note top of nuxt: Handles routing, SSR,\nand admin UI rendering
note right of vuex: Manages application state\n(admin, auth, books)
note left of grpc: Protocol Buffers for\ninternal service communication
note bottom of book: Core domain logic for\nbooks, reviews, bookshelves

@enduml
```