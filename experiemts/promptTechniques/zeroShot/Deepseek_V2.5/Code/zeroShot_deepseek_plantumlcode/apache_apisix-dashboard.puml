```plantuml
@startuml apache_apisix-dashboard

component "User Browser" as browser {
  [React App]
}

component "APISIX Dashboard Frontend" as frontend {
  [React Components]
  [Mantine UI]
  [Ant Design Pro]
  [TanStack Router]
  [TanStack Query]
  [MobX Stores]
}

component "APISIX Admin API" as api {
  [Routes API]
  [Services API]
  [Upstreams API]
  [Consumers API]
  [SSL API]
}

component "APISIX Gateway" as gateway {
  [Routes]
  [Services]
  [Upstreams]
  [Plugins]
}

database "APISIX Data Store" as datastore {
  [ETCD]
  [PostgreSQL]
}

browser --> frontend : HTTP/HTTPS
frontend --> api : REST API\n(Admin Key)
api --> gateway : Configuration\nManagement
gateway --> datastore : Persist\nConfiguration

@enduml
```