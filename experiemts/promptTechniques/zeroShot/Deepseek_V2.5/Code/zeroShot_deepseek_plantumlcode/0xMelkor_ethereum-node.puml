```plantuml
@startuml 0xMelkor_ethereum-node

!define K8sPods #FFD700
!define External #87CEEB
!define Storage #90EE90
!define Service #FFA07A

node "Google Kubernetes Engine" as gke {
    component "Geth" as geth <<K8sPods>> {
        [Execution Layer]
    }

    component "Lighthouse" as lighthouse <<K8sPods>> {
        [Consensus Layer]
    }

    component "InfluxDB" as influxdb <<K8sPods>> {
        [Metrics Database]
    }

    component "Nginx" as nginx <<K8sPods>> {
        [Reverse Proxy]
    }

    component "Cloud Build" as cloudbuild <<Service>> {
        [CI/CD Pipeline]
    }
}

database "Persistent Storage" as storage <<Storage>> {
    [Geth Data]
    [Lighthouse Data]
    [InfluxDB Data]
}

cloud "External Network" as external <<External>> {
    [RPC Clients]
    [WebSocket Clients]
    [Monitoring Tools]
}

geth --> storage : Chain data
lighthouse --> storage : Beacon chain data
influxdb --> storage : Metrics data

nginx --> geth : Proxies RPC/WS
nginx --> influxdb : Proxies API

cloudbuild --> geth : Deploys
cloudbuild --> lighthouse : Deploys
cloudbuild --> influxdb : Deploys
cloudbuild --> nginx : Deploys

external --> nginx : Accesses services

@enduml
```