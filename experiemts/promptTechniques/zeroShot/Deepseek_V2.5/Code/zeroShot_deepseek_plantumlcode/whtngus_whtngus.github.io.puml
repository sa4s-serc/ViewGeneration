```plantuml
@startuml whtngus_whtngus.github.io

component "GitHub Pages" as github_pages {
    component "Static Site Generator" as static_gen
    component "HTML/CSS/JS Assets" as assets
}

component "Local Development" as local_dev {
    component "Jekyll" as jekyll
    component "Markdown Files" as md
    component "Git Client" as git
}

github_pages --> local_dev : "Deploys via\nGit push"
local_dev --> github_pages : "Commits changes"

note right of github_pages
  Automatic deployment
  triggered by git push
  to main branch
end note

@enduml
