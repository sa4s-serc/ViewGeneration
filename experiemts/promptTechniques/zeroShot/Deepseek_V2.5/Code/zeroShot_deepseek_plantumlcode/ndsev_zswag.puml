```plantuml
@startuml ndsev_zswag

package "Zserio Services" {
    [Zserio Service Definitions]
    [Zserio Generated Code]
}

package "OpenAPI Bridge" {
    [zswag.gen] as zswag_gen
    [OAServer] as oa_server
    [OAClient (Python)] as oa_client_py
    [OAClient (C++)] as oa_client_cpp
    [httpcl] as http_client
}

package "External Components" {
    [Flask/Connexion] as flask
    [cpp-httplib] as httplib
    [Zserio Runtime] as zserio_runtime
}

[Zserio Service Definitions] --> zswag_gen : "generates"
zswag_gen --> [OpenAPI Specification] : "produces"

[Zserio Generated Code] --> oa_server : "implements"
[Zserio Generated Code] --> oa_client_py : "uses"
[Zserio Generated Code] --> oa_client_cpp : "uses"

oa_server --> flask : "hosts on"
oa_server --> [OpenAPI Specification] : "consumes"

oa_client_py --> [OpenAPI Specification] : "consumes"
oa_client_cpp --> [OpenAPI Specification] : "consumes"

oa_client_cpp --> http_client : "uses"
http_client --> httplib : "wraps"

[OAClient (Python)] --> [Zserio Runtime] : "depends on"
[OAClient (C++)] --> [Zserio Runtime] : "depends on"
[OAServer] --> [Zserio Runtime] : "depends on"

@enduml
```