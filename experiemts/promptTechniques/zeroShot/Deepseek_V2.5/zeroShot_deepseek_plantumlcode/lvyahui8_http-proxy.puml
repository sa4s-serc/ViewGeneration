```plantuml
@startuml lvyahui8_http-proxy

package "HTTP Proxy System" {
    [Proxy Server] as proxy_server
    [ClientToProxyHandler] as client_handler
    [ProxyToServerInboundHandler] as server_handler
    [EntitysManager] as entity_manager
    [GlobalExceptionHandler] as exception_handler

    component "Filters" {
        [ProxyRequestFilter] as request_filter
        [ProxyResponseFilter] as response_filter
        [AttackRequestFilter] as attack_filter
        [DefaultProxyResponseFilter] as default_response_filter
    }

    component "Test Modules" {
        [TestClientApp] as test_client
        [TestServerMain] as test_server
    }

    component "Configuration" {
        [entitys.json] as config_file
        [log4j2.xml] as log_config
    }

    component "Netty Framework" {
        [EventLoopGroup] as event_loop
        [ChannelHandler] as channel_handler
        [Bootstrap] as bootstrap
    }
}

proxy_server --> client_handler : handles\nrequests
proxy_server --> server_handler : handles\nresponses
proxy_server --> exception_handler : error\nhandling
proxy_server --> Netty_Framework : uses

client_handler --> entity_manager : gets\nproxy rules
client_handler --> request_filter : applies\nfilters
server_handler --> response_filter : applies\nfilters

entity_manager --> config_file : reads\nconfiguration

request_filter <|-- attack_filter : implements
response_filter <|-- default_response_filter : implements

test_client --> proxy_server : sends\ntest requests
test_server --> proxy_server : serves as\nbackend

@enduml
```