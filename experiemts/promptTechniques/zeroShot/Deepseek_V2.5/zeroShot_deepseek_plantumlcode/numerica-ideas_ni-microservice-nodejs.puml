```plantuml
@startuml numerical-ideas_ni-microservice-nodejs

actor Client
participant "API Gateway" as Gateway
participant "Lambda Handler" as Lambda
participant "Express App" as Express
participant "Article Controller" as Controller
participant "Article Service" as Service
participant "Cache Service" as Cache
participant "MongoDB" as DB
participant "Redis" as Redis
participant "SNS" as SNS

alt Lambda Deployment
    Client -> Gateway: HTTP Request
    Gateway -> Lambda: Invoke
    Lambda -> Express: Process Request
else Server Deployment
    Client -> Express: HTTP Request
end

Express -> Controller: Route Request
Controller -> Service: Business Logic

group Database Operations
    Service -> DB: Query/Update
    DB --> Service: Data
end

group Caching Operations
    Service -> Cache: Get/Set Cache
    alt Cache Hit
        Cache --> Service: Cached Data
    else Cache Miss
        Cache -> DB: Query
        DB --> Cache: Data
        Cache --> Service: Data
    end
end

alt Lambda Deployment
    Service -> SNS: Publish Event
    SNS --> Lambda: Trigger Event
    Lambda -> Express: Process Event
    Express -> Controller: Route Event
    Controller -> Service: Handle Event
else Server Deployment
    Service -> Redis: Publish Event
    Redis --> Express: Subscribe Event
    Express -> Controller: Route Event
    Controller -> Service: Handle Event
end

@enduml
```