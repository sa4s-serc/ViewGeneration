```plantuml
@startuml openshift_configuration-anomaly-detection

!define security #FFAAAA
!define control_flow #AAFFAA

skinparam component {
    BackgroundColor<<security>> security
    BackgroundColor<<control_flow>> control_flow
}

package "External Systems" {
    [PagerDuty] <<security>> as pd
    [OCM] <<security>> as ocm
    [AWS] <<security>> as aws
    [Kubernetes] <<security>> as k8s
}

component "Tekton Interceptor" <<control_flow>> as interceptor {
    [Signature Verification] <<security>>
    [Alert Handler Check] <<control_flow>>
}

component "cadctl CLI" <<control_flow>> as cadctl {
    [investigate command] <<control_flow>>
    [Remediation Logic] <<control_flow>>
}

component "Investigation Framework" <<control_flow>> as framework {
    [Investigation Interface] <<control_flow>>
    [Resources Container] <<control_flow>>
    [NoteWriter] <<control_flow>>
}

database "Investigation Plugins" <<control_flow>> as plugins {
    [chgm]
    [apierrorbudgetburn]
    [insightsoperatordown]
    [ccam]
    [Other Investigations]
}

pd --> interceptor : Webhook (HTTPS)
interceptor --> cadctl : Triggers\nPipelineRun
cadctl --> framework : Uses
framework --> plugins : Executes
cadctl --> ocm : Cluster Info\nSupport Reasons
cadctl --> aws : Instance Info\nCloudTrail
cadctl --> k8s : Cluster Resources
cadctl --> pd : Updates Notes\nIncidents

@enduml
```