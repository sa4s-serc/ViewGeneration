```plantuml
@startuml pau-minoves_jseats

package "jseats System" {
    [SeatAllocatorLauncher] as Launcher
    [SeatAllocatorProcessor] as Processor
    [ProcessorConfig] as Config
    [SeatAllocatorResolver] as Resolver

    package "Model" {
        [Tally] as Tally
        [Candidate] as Candidate
        [Result] as Result
    }

    package "Methods" {
        [SeatAllocationMethod] as Method
        [MajorityBased] as Majority
        [LargestRemainder] as LR
        [HighestAverages] as HA
        [EqualProportions] as EP
    }

    package "Filters" {
        [TallyFilter] as Filter
    }

    package "Decorators" {
        [ResultDecorator] as Decorator
    }

    package "Tie Breakers" {
        [TieBreaker] as TieBreaker
    }
}

Launcher --> Processor : executes
Launcher --> Config : loads
Processor --> Config : uses
Processor --> Resolver : resolves components
Processor --> Tally : processes
Processor --> Result : generates

Resolver --> Method : resolves
Resolver --> Filter : resolves
Resolver --> Decorator : resolves
Resolver --> TieBreaker : resolves

Method <|-- Majority
Method <|-- LR
Method <|-- HA
Method <|-- EP

Tally "1" *-- "*" Candidate : contains

@enduml
```