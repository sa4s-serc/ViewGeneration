```plantuml
@startuml mateuseap_apache-airflow

component "Apache Airflow Core" {
    component "Web Server" as webserver
    component "Scheduler" as scheduler
    component "Metadata DB (Postgres)" as metadatadb
    component "Executor" as executor {
        component "SequentialExecutor"
        component "LocalExecutor"
        component "CeleryExecutor"
        component "KubernetesExecutor"
    }
}

component "External Services" {
    component "Redis (Broker)" as redis
    component "Hadoop Ecosystem" as hadoop {
        component "HDFS" as hdfs
        component "Hive" as hive
        component "Spark" as spark
    }
    component "Monitoring" as monitoring {
        component "TIG Stack" as tig
        component "ELK Stack" as elk
    }
}

component "User DAGs" {
    component "Forex Data Pipeline" as forex_pipeline {
        component "HttpSensor"
        component "FileSensor"
        component "PythonOperator"
        component "BashOperator"
        component "HiveOperator"
        component "SparkSubmitOperator"
        component "EmailOperator"
        component "SlackWebhookOperator"
    }
}

component "Docker/K8s Infrastructure" {
    component "Docker Compose" as docker_compose
    component "Kubernetes Manifests" as k8s
}

webserver --> metadatadb : Reads/Writes
scheduler --> metadatadb : Reads/Writes
scheduler --> executor : Dispatches tasks
executor --> redis : Celery tasks
forex_pipeline --> hdfs : Stores data
forex_pipeline --> hive : Processes data
forex_pipeline --> spark : Processes data
docker_compose --> webserver : Deploys
docker_compose --> scheduler : Deploys
docker_compose --> executor : Deploys
docker_compose --> redis : Deploys
docker_compose --> metadatadb : Deploys
k8s --> webserver : Deploys (scalable)
k8s --> scheduler : Deploys (scalable)
k8s --> executor : Deploys (scalable)
monitoring --> webserver : Monitors
monitoring --> scheduler : Monitors
monitoring --> executor : Monitors

@enduml
```