```plantuml
@startuml hamzatugrul_surl
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam linetype ortho

actor User

package "Frontend" {
  rectangle "Nginx Load Balancer" as Nginx #f0e68c
}

package "Backend (Spring Boot)" {
  rectangle "ShortURLController" as Controller #add8e6
  rectangle "UrlShortenerService" as Service #add8e6
  rectangle "ShortUrlRepository" as Repository #add8e6
  rectangle "RedisCacheConfig" as RedisConfig #add8e6
  rectangle "SecurityConfiguration" as SecurityConfig #add8e6
}

package "Data Storage" {
  database "MongoDB" as MongoDB #f5f5dc
  rectangle "Redis Cache" as Redis #f5f5dc
}

User --> Nginx : Access Short URL
Nginx --> Controller : Forward Request
Controller --> SecurityConfig : Authenticate User
Controller --> Service : Shorten URL/Redirect
Service --> Repository : Access Data
Repository --> MongoDB : Read/Write URLs
Service --> Redis : Cache URL Data
RedisConfig --> Redis : Configure Cache

@enduml
