```plantuml
@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}

actor User

rectangle "System" {
  rectangle "API Gateway" 
  rectangle "Rate Limiting Service" as RateLimiter
  rectangle "Error Handling Module" as ErrorHandler
  rectangle "Quota Monitoring Service" as QuotaMonitor
  rectangle "Retry Logic" as RetryLogic
  rectangle "Documentation Portal" as Documentation
}

User --> "API Gateway"
"API Gateway" --> RateLimiter
RateLimiter --> ErrorHandler : Trigger on Limit Exceeded
ErrorHandler --> User : Return Error 429
ErrorHandler --> QuotaMonitor : Log Quota Violation
ErrorHandler --> RetryLogic : Initiate Retry Delay
User --> Documentation : Access Rate Limit Docs

@enduml
```