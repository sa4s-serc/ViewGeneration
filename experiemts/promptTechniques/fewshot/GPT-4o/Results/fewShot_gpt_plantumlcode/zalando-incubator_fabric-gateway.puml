```plantuml
@startuml zalando-incubator_fabric-gateway
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}

actor "User"

package "Kubernetes Cluster" {
  rectangle "FabricGateway CRD" as CRD #orange
  rectangle "Skipper" as Skipper #lightblue
  rectangle "Ingress Controller" as IngressCtrl #green
  rectangle "Webhook Server" as Webhook #lightyellow
  rectangle "StackSets" as StackSets #lightpink
}

package "Authentication & Authorization" {
  rectangle "Zalando IAM" as IAM #lightgrey
}

package "Search System" {
  rectangle "Web Worker" as WebWorker #aliceblue
  rectangle "Search Index" as SearchIndex #aliceblue
}

User --> CRD : Define API Gateway
CRD --> Webhook : Validate Configuration
Webhook --> CRD : Sync & Validate
CRD --> Skipper : Generate Routes
Skipper --> IngressCtrl : Manage Traffic
IngressCtrl --> StackSets : Discover Services
Skipper --> IAM : Authenticate Requests

User --> "Search System" : Query Search
WebWorker --> SearchIndex : Indexing & Query
@enduml
```