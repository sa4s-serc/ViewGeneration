@startuml inovex_scrumlr.io
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User"

package "Frontend (TypeScript/React)" {
  rectangle "Board.tsx" as Board
  rectangle "Column.tsx" as Column
  rectangle "Note.tsx" as Note
  rectangle "SettingsDialog.tsx" as SettingsDialog
  rectangle "BoardUsers.tsx" as BoardUsers
  rectangle "Infobar.tsx" as Infobar
  rectangle "Routes" as Routes
  rectangle "Redux Store" as Store
}

package "Backend (Go)" {
  rectangle "API Layer" as API
  rectangle "Authentication" as Auth
  rectangle "Real-time Communication" as Realtime
  rectangle "Business Logic" as Services
  rectangle "Data Access Layer" as Database
}

package "Infrastructure" {
  rectangle "NATS" as NATS
  rectangle "Redis" as Redis
  rectangle "Database" as DB
  rectangle "Docker" as Docker
}

User --> Board
Board --> Column
Board --> Note
Board --> SettingsDialog
Board --> BoardUsers
Board --> Infobar
Board --> Routes
Board --> Store

Store --> API
Store --> Realtime

API --> Auth
