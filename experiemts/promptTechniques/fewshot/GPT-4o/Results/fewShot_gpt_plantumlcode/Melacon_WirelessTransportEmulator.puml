```plantuml
@startuml Melacon_WirelessTransportEmulator
left to right direction
skinparam componentStyle rectangle
skinparam rectangle {
  BackgroundColor #eeeeee
  BorderColor #333333
  Style roundrect
}

actor "User"

package "OpenYuma Wireless Transport Emulator" {
  package "NETCONF Server" {
    rectangle "NETCONF Interface" as netconf
    rectangle "YANG Models" as yang
    rectangle "Configuration Management" as config
  }

  package "Emulation Layer" {
    rectangle "Network Element (NE) Emulator" as ne
    rectangle "Link Emulator" as link
  }

  package "Data Management" {
    rectangle "Data Validation" as dataValidation
    rectangle "Data Conversion" as dataConversion
  }

  package "Notification & SNMP" {
    rectangle "Notification Handling" as notify
    rectangle "SNMP Management" as snmp
  }

  package "Testing Infrastructure" {
    rectangle "Test Harness" as testHarness
    rectangle "Test Cases" as testCases
  }

  package "Scripting & CLI" {
    rectangle "Script Engine" as scriptEngine
    rectangle "CLI Interface" as cli
  }
}

User --> netconf : Manage
netconf --> yang : Uses
netconf --> config : Configure
config --> ne : Drives
ne --> link : Connects
ne --> notify : Triggers
notify --> netconf : Sends
ne --> snmp : Supports
snmp --> testHarness : Tests
dataValidation --> dataConversion : Uses
scriptEngine --> cli : Executes
@enduml
```