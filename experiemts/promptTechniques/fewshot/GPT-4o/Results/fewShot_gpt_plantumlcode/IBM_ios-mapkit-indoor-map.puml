```plantuml
@startuml IBM_ios-mapkit-indoor-map
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

package "iOS Application" {
  rectangle "ViewController.swift" as ViewController
  rectangle "FloorplanOverlay.swift" as FloorplanOverlay
  rectangle "FloorplanOverlayRenderer.swift" as FloorplanRenderer
  rectangle "CoordinateConverter.swift" as CoordinateConverter
  rectangle "VisibleMapRegionDelegate.swift" as MapRegionDelegate
  rectangle "CustomPolygons.swift" as CustomPolygons
}

package "Backend Application" {
  rectangle "app.js" as AppJS
  rectangle "routes/*.js" as Routes
  rectangle "models/*.js" as Models
  rectangle "random.js" as Random
  database "MongoDB" as MongoDB
}

cloud "Cloud Foundry" as CloudFoundry

User --> ViewController : Interacts

ViewController --> FloorplanOverlay : Initialize Floorplan
ViewController --> FloorplanRenderer : Render Overlay
ViewController --> CoordinateConverter : Convert Coordinates
ViewController --> MapRegionDelegate : Manage Map Camera
ViewController --> CustomPolygons : Render Heatmap

ViewController --> AppJS : Fetch Map & Event Data
AppJS --> Routes : API Requests
Routes --> Models : Access Data
Models --> MongoDB : Store & Retrieve Data

AppJS --> Random : Simulate Events

AppJS --> CloudFoundry : Deployed On
@enduml
```