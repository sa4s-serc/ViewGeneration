```plantuml
@startuml McOrts_taller-iot-sensor_radiactividad
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "User" as User
rectangle "ESP8266\\n(WEMOS D1 mini Pro)" as ESP8266
queue "MQTT Broker" as MQTTBroker
rectangle "Geiger Counter\\nModule" as GeigerCounter
rectangle "Node-RED" as NodeRED
rectangle "GMC.MAP" as GMCMAP

User --> ESP8266 : "Control Command\\n(via MQTT)"
GeigerCounter --> ESP8266 : "Radiation Pulse"
ESP8266 --> MQTTBroker : "Publish CPM Data"
MQTTBroker --> NodeRED : "Forward Data"
NodeRED --> GMCMAP : "Integrate Data"
MQTTBroker --> ESP8266 : "Control Command"
@enduml
