```plantuml
@startuml calmato_gran-book
left to right direction
skinparam rectangle {
  BackgroundColor #f3f4f5
  BorderColor black
  Style roundrect
}
skinparam ArrowColor Black
skinparam defaultTextAlignment center

package "Frontend (Nuxt.js)" {
  rectangle "Web Admin Panel" as AdminPanel
  rectangle "Vuex Store" as VuexStore
  rectangle "Vue Components" as VueComponents
  rectangle "Plugins (Axios, Firebase)" as NuxtPlugins
}

package "API Gateway" {
  rectangle "Routing\n& Authentication" as APIGateway
}

package "Backend Microservices" {
  rectangle "User Service" as UserService
  rectangle "Book Service" as BookService
  rectangle "Auth Service" as AuthService
  rectangle "Chat Service" as ChatService
}

package "Data Storage" {
  database "MySQL Database" as MySQLDB
}

package "External Services" {
  rectangle "Firebase\n(Authentication)" as Firebase
  rectangle "Cloud Storage\n(Images)" as CloudStorage
}

package "gRPC Services" {
  rectangle "gRPC\n(Protobuf Definitions)" as gRPC
}

AdminPanel --> APIGateway : HTTP(s)
VuexStore --> AdminPanel
VueComponents --> AdminPanel
NuxtPlugins --> AdminPanel

APIGateway --> UserService : HTTP(s)
APIGateway --> BookService : HTTP(s)
APIGateway --> AuthService : HTTP(s)
APIGateway --> ChatService : HTTP(s)

UserService --> MySQLDB
BookService --> MySQLDB
AuthService --> Firebase
ChatService --> CloudStorage

UserService --> gRPC
BookService --> gRPC
AuthService --> gRPC
ChatService --> gRPC
@enduml
```