```plantuml
@startuml avarghesein_ActiveX.NET
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "User" as user

rectangle "ActiveX.NET.Server" as Server {
    component "Program.cs" as Program
    component "ActiveXServerContext.cs" as ServerContext
    component "ActiveXServers.cs" as ActiveXServers
    component "App.config" as AppConfig
    component "DefaultActiveXFactory" as ActiveXFactory
}

rectangle "ActiveX.NET.Plugin" as Plugin {
    component "CoClass.cs" as CoClass
}

rectangle "ActiveX.NET.Common" as Common {
    component "ActiveXServerBase.cs" as ServerBase
    component "ActiveXServerMTABase.cs" as ServerMTABase
    component "ActiveXServerControlBase.cs" as ServerControlBase
    component "ActiveXServerAttribute.cs" as ServerAttribute
    interface "IActiveXServer" as IActiveXServer
}

user --> Program : start
Program --> ServerContext : initialize
ServerContext --> ActiveXServers : manage lifecycle
ActiveXServers --> ActiveXFactory : create instances
ActiveXServers --> Plugin : load via MEF
CoClass --> IActiveXServer
ServerBase <|-- ServerControlBase
ServerMTABase <|-- ServerControlBase
@enduml
```