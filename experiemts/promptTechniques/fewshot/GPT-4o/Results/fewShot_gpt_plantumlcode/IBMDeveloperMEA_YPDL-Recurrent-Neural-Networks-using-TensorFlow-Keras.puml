```plantuml
@startuml IBMDeveloperMEA_YPDL-Recurrent-Neural-Networks-using-TensorFlow-Keras
skinparam rectangle {
  BackgroundColor #f0f0f0
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Jupyter Notebook" as Notebook {
  rectangle "Recurrent Neural Network\n(LSTM)" as RNN
  rectangle "Word Embedding Layer" as Embedding
  rectangle "Dense Layer\n(Softmax)" as DenseLayer
  rectangle "Training Loop" as Training
  rectangle "Evaluation\n(Perplexity)" as Evaluation
}

rectangle "Penn Treebank Dataset" as Dataset #lightyellow
rectangle "Scripts (reader.py)" as Reader #lightblue

rectangle "IBM Cloud Pak for Data" as IBMCloud #lightgreen {
  rectangle "IBM Watson Studio" as WatsonStudio
}

User --> Notebook : interact
Notebook --> RNN
RNN --> Embedding
RNN --> DenseLayer
RNN --> Training
Training --> Evaluation
Notebook --> Dataset
Dataset --> Reader
Notebook --> WatsonStudio : execute
@enduml
