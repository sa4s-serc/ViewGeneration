```plantuml
@startuml 0xMelkor_ethereum-node
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Google Kubernetes Engine (GKE)" {
  package "Ethereum Node" {
    rectangle "Geth (Execution Layer)" as Geth #lightblue
    rectangle "Lighthouse (Consensus Layer)" as Lighthouse #lightgreen
  }

  package "Metrics & Monitoring" {
    rectangle "InfluxDB" as InfluxDB #lightyellow
  }

  package "Networking" {
    rectangle "Nginx Reverse Proxy" as Nginx #lightcoral
  }
}

package "CI/CD Pipeline" {
  rectangle "Google Cloud Build" as CloudBuild #d9e7fd
}

actor "User"

User --> Nginx : Access Geth RPC/WebSocket\nAccess InfluxDB
CloudBuild --> Geth : Deploy & Configure
CloudBuild --> Lighthouse : Deploy & Configure
CloudBuild --> InfluxDB : Deploy & Configure
CloudBuild --> Nginx : Deploy & Configure

Geth --> InfluxDB : Send Metrics
Nginx --> Geth : Proxy RPC/WebSocket Requests
Nginx --> InfluxDB : Proxy Monitoring Requests
@enduml
```