```plantuml
@startuml kpantos_Azure-How-To
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho

package "Azure Cloud" {
  rectangle "Azure Application Gateway\nWAF" as WAF
  rectangle "Azure App Service\n(Bot Application)" as BotApp
  rectangle "Azure API Management\n(APIM)" as APIM
  rectangle "Azure AD Application Proxy" as ADProxy
  rectangle "Azure AD Connect" as ADConnect
  rectangle "Azure AD" as AzureAD
}

package "On-Premises" {
  rectangle "Kerberos-Secured API\n(Simulated in Azure)" as OnPremAPI
  rectangle "Active Directory\n(On-Premises)" as OnPremAD
}

cloud "Let's Encrypt\nSSL/TLS Certificates" as LetsEncrypt

' Connections for Bot Application scenario
LetsEncrypt --> WAF : SSL/TLS
WAF --> BotApp : HTTPS

' Connections for Kerberos-Secured API scenario
ADProxy --> OnPremAPI : Kerberos-secured communication
APIM --> ADProxy : HTTPS
APIM --> AzureAD : Authentication
ADConnect --> OnPremAD : Sync
ADConnect --> AzureAD : Sync

' Labels for external interactions
User --> WAF : Access Bot
User --> APIM : Access API

@enduml
```