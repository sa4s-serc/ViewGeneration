```plantuml
@startuml davidlandry93_glo4001
left to right direction
skinparam rectangle {
  BackgroundColor<<rendering>> #d9e7fd
  BackgroundColor<<robotic>> #d8f5d3
  BackgroundColor<<geometric>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "3D Rendering and Visualization" <<rendering>> {
  rectangle "Three.js" as ThreeJS
  rectangle "Potree" as Potree
  rectangle "WebGLRenderer" as WebGLRenderer
  rectangle "Shaders and Materials" as Shaders
  rectangle "LAS/LAZ Decoders" as Decoders

  ThreeJS --> WebGLRenderer
  WebGLRenderer --> Shaders
  ThreeJS --> Potree
  Potree --> Decoders
}

package "Robotic Control and Sensing" <<robotic>> {
  rectangle "Robot Control" as RobotControl
  rectangle "Sensors" as Sensors
  rectangle "Point Cloud Processing" as PointCloud
  rectangle "ICP Algorithm" as ICP

  RobotControl --> Sensors
  Sensors --> PointCloud
  PointCloud --> ICP
}

package "Geometric Data Handling" <<geometric>> {
  rectangle "CZML Processing" as CZML
  rectangle "Time-Dynamic Animation" as Animation
  rectangle "Appearance System" as Appearance

  CZML --> Animation
  CZML --> Appearance
}

package "Design Patterns and Architecture" {
  rectangle "Component-Based Architecture" as ComponentArch
  rectangle "Plugin Architecture" as PluginArch
  rectangle "Observer Pattern" as ObserverPattern
  rectangle "Factory Pattern" as FactoryPattern
  rectangle "Command Pattern" as CommandPattern
  rectangle "Flyweight Pattern" as FlyweightPattern

  ComponentArch --> PluginArch
  PluginArch --> ObserverPattern
  ObserverPattern --> FactoryPattern
  FactoryPattern --> CommandPattern
  CommandPattern --> FlyweightPattern
}

rectangle "Utilities and Important Files" as Utilities {
  note right: robmob/icp.py, robmob/point_cloud.py, \nrobmob/sensors.py, robmob/robot.py,\npoint_cloud/js/potree.min.js,\nsrc/renderers/WebGLRenderer.js\nand src/math/*
}

@enduml
```