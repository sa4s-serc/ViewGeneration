```plantuml
@startuml IBM_kubernetes-storage
skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor #000000
  Style roundrect
}

actor "Workshop Participant"

package "Documentation" {
  rectangle "MkDocs\nmkdocs.yml\nSUMMARY.md\nREADME.md" as Docs #d9e7fd
}

package "Kubernetes Environment" {
  rectangle "Kubernetes Cluster" as Cluster {
    rectangle "Guestbook\nApplication" as Guestbook #d8f5d3
    rectangle "Persistent Volume\nClaims" as PVC #fff1c9
    rectangle "Services & Deployments\n(src/yaml/*)" as Services #fff1c9
  }
}

package "IBM Cloud Services" {
  rectangle "IBM Cloud Object\nStorage" as COS #fddddd
  rectangle "IBM Cloud Block\nStorage" as BlockStorage #fddddd
  rectangle "IBM Cloud Operator" as Operator #fddddd
}

rectangle "CI/CD\nTravis CI\nGitHub Actions" as CICD #e8e8e8

WorkshopParticipant --> Docs : Access
Docs --> Cluster : Guide Deployment
Guestbook --> PVC : Uses
PVC --> COS : Connects
PVC --> BlockStorage : Connects
Services --> Guestbook : Manage

Operator --> Cluster : Manage Resources

CICD --> Docs : Build & Deploy
@enduml
```