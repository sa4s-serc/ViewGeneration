  rectangle "EC2 Instances" as EC2
}

rectangle "Terraform" as TF
rectangle "VSCode Environment" as VSCode

package "Terraform Configurations" {
  component "main.tf" as MainTF
  component "network.tf" as NetworkTF
  component "variables.tf" as VariablesTF
  component "dev.tfvars" as DevTFVars
  component "prd.tfvars" as PrdTFVars
  component "output.tf" as OutputTF
  component "_providers.tf" as ProvidersTF
  component "_backend.tf" as BackendTF
}

package "Bootstrap" {
  component "main.tf" as BootstrapMainTF
  component "output.tf" as BootstrapOutputTF
  component "env.tfvars.tpl" as EnvTFVarsTpl
}

package "Solution Examples" {
  component "step_*/" as SolutionSteps
}

package "VSCode Environment Setup" {
  component "vscode-box/" as VSCodeBox
}

