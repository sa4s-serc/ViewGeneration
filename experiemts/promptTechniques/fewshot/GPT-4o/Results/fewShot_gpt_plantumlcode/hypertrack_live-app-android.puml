```plantuml
@startuml hypertrack_live-app-android
skinparam linetype ortho

actor User
rectangle "Android App" as App {
    rectangle "UI Layer" {
        [MainActivity]
        [MapActivity]
        [TripActivity]
    }
    rectangle "Business Logic Layer" {
        [CognitoClient]
        [TripManager]
        [GeofenceApiAdapter]
        [AccessTokenRepository]
    }
    rectangle "Data Layer" {
        [BackendClientFactory]
        [HyperTrackSDK]
    }
}

package "Backend Module" {
    [HyperTrack Trips API]
    [AWS Cognito]
    [Geofence API]
}

User --> App
App --> [MainActivity]
App --> [MapActivity]
App --> [TripActivity]

[MainActivity] --> [CognitoClient]
[MainActivity] --> [TripManager]
[MapActivity] --> [GeofenceApiAdapter]
[TripActivity] --> [AccessTokenRepository]

[CognitoClient] --> [AWS Cognito]
[TripManager] --> [HyperTrack Trips API]
[GeofenceApiAdapter] --> [Geofence API]

[BackendClientFactory] --> [HyperTrack Trips API]
[BackendClientFactory] --> [AWS Cognito]
[BackendClientFactory] --> [Geofence API]

[HyperTrackSDK] --> [HyperTrack Trips API]
@enduml
```