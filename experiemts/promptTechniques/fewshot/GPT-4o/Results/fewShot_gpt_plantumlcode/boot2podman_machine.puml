```plantuml
@startuml boot2podman_machine
skinparam rectangle {
  BackgroundColor #dff0ff
  BorderColor black
  Style roundrect
}
skinparam linetype ortho
left to right direction

actor "User"

package "Podman Machine CLI" {
  rectangle "Command: create/start/stop/rm/env/ssh" as CLI
}

package "Driver Plugins" {
  rectangle "VirtualBox Driver" as VBoxDriver
  rectangle "QEMU Driver" as QEMUDriver
  rectangle "Generic Driver" as GenericDriver
  rectangle "Serialized Driver" as SerialDriver
}

package "Libmachine" {
  rectangle "VM Management" as VMMgmt
  rectangle "Host Management" as HostMgmt
}

package "Provisioners" {
  rectangle "RedHat Provisioner" as RHProvisioner
  rectangle "Fedora Provisioner" as FedoraProvisioner
  rectangle "Boot2Podman Provisioner" as B2PProvisioner
}

package "Networking" {
  rectangle "Netfilter" as Netfilter
  rectangle "NFTables" as NFTables
}

package "Configuration" {
  rectangle "Config Files" as ConfigFiles
  rectangle "TLS Certificates" as TLSCerts
}

User --> CLI
CLI --> VMMgmt
CLI --> HostMgmt
VMMgmt --> VBoxDriver
VMMgmt --> QEMUDriver
VMMgmt --> GenericDriver
VMMgmt --> SerialDriver
HostMgmt --> RHProvisioner
HostMgmt --> FedoraProvisioner
HostMgmt --> B2PProvisioner
VMMgmt --> ConfigFiles
HostMgmt --> TLSCerts
VBoxDriver --> Netfilter
QEMUDriver --> NFTables
@enduml
```