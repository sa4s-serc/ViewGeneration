```plantuml
@startuml apigee_consumer-data-standards-au
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction
skinparam defaultTextAlignment center

actor "Client Application"

package "Apigee Platform" {
  rectangle "CDS Banking API Proxies" as ApiProxies #lightblue
  rectangle "OIDC Proxy" as OIDCProxy #lightblue
  rectangle "ConsentMgmtWithKVM Proxy" as ConsentMgmt #lightblue
  rectangle "Dynamic Client Registration" as ClientReg #lightblue
  rectangle "Shared Flows" as SharedFlows #lightblue
  rectangle "Metrics Service" as MetricsService #lightblue
  rectangle "Mock OIDC Provider" as MockOIDC #lightblue

  ApiProxies --> SharedFlows
  OIDCProxy --> SharedFlows
  ConsentMgmt --> SharedFlows
  ClientReg --> SharedFlows
}

package "External Services" {
  rectangle "OpenID Connect Provider" as OIDCProvider #lightyellow
  rectangle "Consent Management Solution" as ConsentSolution #lightyellow
  rectangle "Apigee Analytics" as Analytics #lightyellow
}

Client Application --> ApiProxies : REST API Calls
ApiProxies --> OIDCProxy : Auth Requests
OIDCProxy --> OIDCProvider : Token Exchange
OIDCProxy --> ConsentMgmt : Consent Handling
ConsentMgmt --> ConsentSolution : Consent Operations
ApiProxies --> MetricsService : Performance Metrics
MetricsService --> Analytics : Analytics Data
MockOIDC --> "Apigee Platform" : Hosted Target

@enduml
```