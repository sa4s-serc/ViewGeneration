```plantuml
@startuml aws-solutions_iot-device-simulator
skinparam rectangle {
  BackgroundColor #eeeeee
  BorderColor black
  Style roundrect
}
skinparam shadowing false
left to right direction

actor "User" as user

package "AWS IoT Device Simulator" {
  rectangle "Web GUI" as gui #lightblue

  package "Microservices" {
    rectangle "DeviceType Manager" as deviceTypeManager #lightgreen
    rectangle "Simulation Manager" as simulationManager #lightgreen
    rectangle "Response Manager" as responseManager #lightgreen
  }

  package "Simulator" {
    rectangle "Simulator Engine" as simulatorEngine #lightyellow
    rectangle "Data Generators" as dataGenerators #lightyellow
  }

  package "Infrastructure" {
    rectangle "AWS Lambda" as awsLambda #lightpink
    rectangle "AWS Step Functions" as awsStepFunctions #lightpink
    rectangle "AWS CDK" as awsCdk #lightpink
  }
}

package "AWS Services" {
  rectangle "AWS IoT Core" as awsIoTCore #lightgrey
  rectangle "AWS S3" as awsS3 #lightgrey
  rectangle "AWS CloudFormation" as awsCloudFormation #lightgrey
}

user --> gui : Interact

gui --> deviceTypeManager : Manage Device Types
gui --> simulationManager : Manage Simulations

deviceTypeManager --> awsLambda : CRUD Operations
simulationManager --> awsLambda : CRUD Operations

responseManager --> awsLambda : API Handling

simulatorEngine --> dataGenerators : Create Data

simulatorEngine --> awsStepFunctions : Orchestrate Events

awsStepFunctions --> awsLambda : Trigger

awsLambda --> awsIoTCore : Send Simulated Data
awsLambda --> awsS3 : Store Data
awsLambda --> awsCloudFormation : Deploy Infrastructure

awsCdk --> awsCloudFormation : Define Infrastructure
@enduml
```