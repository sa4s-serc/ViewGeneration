```plantuml
@startuml qaware_cloud-native-weather-javaee

left to right direction
skinparam rectangle {
  BackgroundColor #f8f8f8
  BorderColor black
  Style roundrect
}
skinparam componentStyle rectangle

package "Frontend" {
  [User Interface] <<component>> #d9e7fd
}

package "JavaEE Service" {
  [PayaraMicroWeatherResource] <<component>> as Resource
  [PayaraMicroWeatherService] <<component>> as Service
  [PayaraMicroWeatherRepository] <<component>> as Repository
  [OpenWeatherMap] <<component>> as ExternalAPI
  [OpenWeatherMapConnector] <<component>> as Connector
  [PayaraMicroWeatherLivenessCheck] <<component>> as LivenessCheck
  [PayaraMicroWeatherReadinessCheck] <<component>> as ReadinessCheck
  [PayaraMicroWeather] <<component>> as Entity
}

package "Database" {
  [PostgreSQL] <<database>> #fff1c9
}

package "Kubernetes" {
  [Deployment] <<component>> #e0ffe0
  [Service] <<component>> #e0ffe0
  [ConfigMap] <<component>> #e0ffe0
  [Secret] <<component>> #e0ffe0
}

package "CI/CD" {
  [GitHub Actions] <<component>> #fddddd
  [Tilt] <<component>> #fddddd
  [Skaffold] <<component>> #fddddd
  [FluxCD] <<component>> #fddddd
}

Frontend --> Resource
Resource --> Service
Service --> Repository
Service --> Connector
Connector --> ExternalAPI
Repository --> Entity
Repository --> PostgreSQL

Kubernetes --> Resource
Kubernetes --> Service
Kubernetes --> ConfigMap
Kubernetes --> Secret

CI/CD --> Kubernetes
CI/CD --> GitHub Actions
CI/CD --> Tilt
CI/CD --> Skaffold
CI/CD --> FluxCD

Service --> LivenessCheck
Service --> ReadinessCheck

@enduml
