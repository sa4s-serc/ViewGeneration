```plantuml
@startuml yuwen123441_NVMeAutomation
left to right direction
skinparam rectangle {
  BackgroundColor<<driver>> #dfe7fd
  BackgroundColor<<logic>> #e7fddf
  BackgroundColor<<test>> #fde7fd
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<utils>> #f5f5dc
  Style roundrect
}
skinparam defaultTextAlignment center

package "NVMe Test Framework" {
  
  package "Driver Layer" <<driver>> {
    rectangle "nvme.py\n(Python Wrapper)" as nvme_py
    rectangle "nvme-ioctl.c\n(C Implementation)" as nvme_ioctl
    rectangle "nvme.h\n(C Header)" as nvme_h
  }

  package "Logic Layer" <<logic>> {
    rectangle "Admin Interface"
    rectangle "IO Interface"
    rectangle "Buffer Management"
  }

  package "Test Cases" <<test>> {
    rectangle "Admin Tests"
    rectangle "IO Tests"
  }

  package "Data Structures" <<data>> {
    rectangle "NVMe Commands"
    rectangle "Queues"
    rectangle "Log Pages"
  }

  package "Utilities" <<utils>> {
    rectangle "Buffer.py"
  }
}

nvme_py --> nvme_ioctl : FFI using ctypes
nvme_ioctl --> nvme_h
"Admin Interface" --> nvme_py
"IO Interface" --> nvme_py
"Buffer Management" --> nvme_py
"Admin Tests" --> "Admin Interface"
"IO Tests" --> "IO Interface"
"Admin Interface" --> "NVMe Commands"
"IO Interface" --> "NVMe Commands"
"Buffer Management" --> "Buffer.py"
"Buffer.py" --> "NVMe Commands"
@enduml
