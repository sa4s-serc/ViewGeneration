```plantuml
@startuml elpapi42_deep-deblurring
left to right direction
skinparam rectangle {
  BackgroundColor #f8f9fa
  BorderColor #333
  Style roundrect
}

package "Frontend (Vue.js)" as Frontend {
  rectangle "User Interface\nfor Deblurring Service"
}

package "Backend (Flask)" as Backend {
  rectangle "API Gateway" as APIGateway
}

package "Model Serving" as ModelServing {
  rectangle "TensorFlow Serving" as TFS
}

package "Model Repository" as ModelRepo {
  rectangle "DeblurGAN-V2 Model\n& Training Scripts"
}

package "Data Storage (Cloudinary)" as DataStorage {
  rectangle "Static Assets"
}

package "Cache & Session Management" {
  rectangle "Redis"
}

package "Database" {
  rectangle "PostgreSQL"
}

Frontend --> Backend : User Requests
Backend --> ModelServing : Model Inference
ModelServing --> ModelRepo : Fetch Model
Backend --> DataStorage : Store/Retrieve Assets
Backend --> "Redis" : Cache Management
Backend --> "PostgreSQL" : Database Operations
@enduml
```