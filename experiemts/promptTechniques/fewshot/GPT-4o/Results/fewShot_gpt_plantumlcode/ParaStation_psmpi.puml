```plantuml
@startuml ParaStation_psmpi
left to right direction
skinparam rectangle {
  BackgroundColor #f3f4f6
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "ParaStation MPI (PSMPI)" {
  rectangle "MPI Standard Implementation" {
    rectangle "MPI-4 Features" as MPI4
    rectangle "MPI Sessions" as MPISessions
  }
  
  rectangle "Communication Subsystem" {
    rectangle "pscom" as PSCOM {
      rectangle "CUDA Awareness" as CUDA
      rectangle "Shared Memory" as SharedMemory
    }
    rectangle "Networking Module" as Networking {
      rectangle "TCP Transport" as TCP
      rectangle "RDMA & InfiniBand" as RDMA
    }
  }

  rectangle "Process Management" {
    rectangle "Hydra" as Hydra
    rectangle "ParaStation Management" as PSMgmt
    rectangle "PMIx" as PMIx
  }

  rectangle "Build System" {
    rectangle "Autotools-Based Build" as Autotools
    rectangle "Customizable Build" as CustomBuild
  }

  rectangle "Data Type Handling" {
    rectangle "Derived Datatypes" as DerivedTypes
    rectangle "C & Fortran Interoperability" as Interoperability
  }
  
  rectangle "Performance Optimizations" {
    rectangle "Shared Memory Transfers" as SharedMemoryTransfers
    rectangle "RDMA Support" as RDMASupport
    rectangle "Zero Copy" as ZeroCopy
  }

  rectangle "Error Handling & Fault Tolerance" {
    rectangle "Comprehensive Testing" as Testing
    rectangle "ULFM Support" as ULFM
  }
  
  rectangle "Key Components & Libraries" {
    rectangle "HCOLL & HWLOC Integration" as HCOLL_HWLOC
    rectangle "ROMIO" as ROMIO
    rectangle "Yaksa" as Yaksa
  }

  rectangle "Testing & Documentation" {
    rectangle "MPICH Test Suite" as MPICHTest
    rectangle "Jenkins CI/CD" as Jenkins
  }
  
  rectangle "Third-party Components" {
    rectangle "Hwloc" as Hwloc
    rectangle "PMIx" as PMIxThirdParty
    rectangle "UCX" as UCX
    rectangle "RoCE" as RoCE
  }
}

MPI4 --> PSCOM
MPISessions --> PSCOM

PSCOM --> CUDA
PSCOM --> SharedMemory
Networking --> TCP
Networking --> RDMA

Hydra --> PSMgmt
PSMgmt --> PMIx

Autotools --> CustomBuild

DerivedTypes --> Interoperability

SharedMemoryTransfers --> RDMASupport
RDMASupport --> ZeroCopy

Testing --> ULFM

HCOLL_HWLOC --> ROMIO
ROMIO --> Yaksa

MPICHTest --> Jenkins

Hwloc --> PMIxThirdParty
UCX --> RoCE
@enduml
```