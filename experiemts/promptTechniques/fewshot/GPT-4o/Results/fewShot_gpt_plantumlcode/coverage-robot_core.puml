```plantuml
@startuml coverage-robot_core
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

actor "GitHub" as github
actor "User" as user

package "Coverage Robot System" {

  rectangle "GitHub App" as githubApp
  rectangle "AWS EventBridge" as eventBridge
  rectangle "AWS S3" as s3
  rectangle "AWS DynamoDB" as dynamoDB
  rectangle "AWS Cognito" as cognito
  rectangle "AWS Lambda" as lambda #lightblue
  rectangle "AWS SQS" as sqs
  rectangle "CloudWatch" as cloudWatch
  rectangle "GCP BigQuery" as bigQuery
  rectangle "Terraform" as terraform

  package "API Service" {
    rectangle "Webhook Handler" as webhookHandler
    rectangle "Badge Generation" as badgeGen
    rectangle "Upload Handling" as uploadHandling
  }

  package "Orchestrator Service" {
    rectangle "Event Processors" as eventProcessors
    rectangle "Event Store Service" as eventStoreService
  }

  package "Analyse Service" {
    rectangle "Coverage Analyser" as coverageAnalyser
  }

  package "Publish Service" {
    rectangle "Publish to GitHub" as publishGitHub
  }

  package "Packages" {
    rectangle "Clients" as clients
    rectangle "Message" as message
    rectangle "Configuration" as configuration
    rectangle "Event" as event
    rectangle "Telemetry" as telemetry
    rectangle "Local" as local
  }
}

github --> githubApp : Authenticate & Interact
user --> cognito : Auth & AuthZ
webhookHandler --> sqs : Queue Webhook
badgeGen --> dynamoDB : Fetch Data
uploadHandling --> s3 : Pre-signed URLs
eventProcessors --> eventBridge : Trigger Events
eventStoreService --> dynamoDB : Update Event Store
coverageAnalyser --> bigQuery : Query & Analyse
publishGitHub --> github : Post Results
telemetry --> cloudWatch : Metrics Reporting
terraform --> s3 : Provision Infra
terraform --> bigQuery : Provision Infra
@enduml
```