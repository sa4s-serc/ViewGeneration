```plantuml
@startuml leekoko_Java-Web
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam linetype ortho

actor "User" as user

package "Frontend" {
  rectangle "HTML/CSS/JavaScript" as frontend
  rectangle "jQuery Library" as jquery
}

package "Backend" {
  rectangle "Java Servlets" as servlets
  rectangle "Spring Boot" as spring
  rectangle "Baidu Translate API" as translateAPI
}

package "Data" {
  rectangle "MySQL" as mysql
  rectangle "Redis" as redis
}

package "Security" {
  rectangle "Shiro" as shiro
  rectangle "OAuth2" as oauth2
}

package "Dubbo Framework" {
  rectangle "Service Registry" as registry
  rectangle "RPC Mechanism" as rpc
}

package "Tomcat Server" {
  rectangle "Connectors" as connectors
  rectangle "Containers" as containers
}

user --> frontend
frontend --> jquery
frontend --> servlets
servlets --> spring
servlets --> translateAPI
spring --> mysql
spring --> redis
spring --> shiro
spring --> oauth2
spring --> registry
registry --> rpc
rpc --> connectors
connectors --> containers
@enduml
```