```plantuml
@startuml jes_autopatzer
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

package "User Interface (React/Electron)" as UI {
  rectangle "Home\nPlayGame\nPawnPromotion\nConfirmMove\nBoardChanges\nTimer\nMoves\nResult\nApp.js" as ReactComponents
  rectangle "Lichess API Client\n(lichess.js)" as LichessAPI
  rectangle "WebSocket Client\n(useBoardEventStream, useLichessEventStream)" as WebSocketClient
}

package "Hardware Interface" as HW {
  rectangle "Teensy 3.2\nArduino Control" as Teensy
  rectangle "Stepper Motors\nAccelStepper Library" as Motors
  rectangle "Hall Effect Sensors" as Sensors
  rectangle "A4988 Motor Drivers" as MotorDrivers
  rectangle "IRF540N MOSFET" as MOSFET
  rectangle "CD4051B Multiplexers" as Multiplexers
}

package "Communication Layer" as Comm {
  rectangle "Perl Script" as Perl
  rectangle "autopatzerd\nWebSocket Server" as Autopatzerd
}

package "Chess Server" as ChessServer {
  rectangle "Lichess\nAPI" as Lichess
}

User --> UI
UI --> WebSocketClient
WebSocketClient --> Autopatzerd
UI --> LichessAPI
LichessAPI --> Lichess

Autopatzerd --> Perl
Perl --> Teensy
Teensy --> Motors
Teensy --> Sensors
Teensy --> MotorDrivers
Teensy --> MOSFET
Teensy --> Multiplexers
@enduml
```