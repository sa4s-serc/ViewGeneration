```plantuml
@startuml clemgbld_blog_back_office
left to right direction
skinparam rectangleStyle roundrect
skinparam shadowing false

package "Frontend (React)" {
    rectangle "Redux Store" as ReduxStore
    rectangle "React Router" as ReactRouter
    rectangle "RichTextEditor\n(@udecode/plate)" as RichTextEditor
    rectangle "UI Components" as UIComponents
    rectangle "Notification HOC" as NotificationHOC
}

package "Business Logic" {
    rectangle "Articles Management" as ArticlesManagement
    rectangle "Email Management" as EmailManagement
    rectangle "Authentication" as Authentication
    rectangle "Theming" as Theming
    rectangle "Search & Pagination" as SearchPagination
}

package "Infrastructure" {
    rectangle "API Services" as APIServices
    rectangle "Local Storage" as LocalStorage
}

rectangle "Environment Config" as EnvConfig

' Connections
ReduxStore --> ArticlesManagement
ReduxStore --> EmailManagement
ReduxStore --> Authentication
ReduxStore --> Theming
ReduxStore --> SearchPagination

ReactRouter --> ArticlesManagement
ReactRouter --> EmailManagement
ReactRouter --> Authentication

RichTextEditor --> ArticlesManagement
UIComponents --> ArticlesManagement
UIComponents --> EmailManagement
UIComponents --> Theming
UIComponents --> SearchPagination

NotificationHOC --> UIComponents

APIServices --> ArticlesManagement
APIServices --> EmailManagement
APIServices --> Authentication

LocalStorage --> Authentication
Authentication --> EnvConfig

@enduml
```