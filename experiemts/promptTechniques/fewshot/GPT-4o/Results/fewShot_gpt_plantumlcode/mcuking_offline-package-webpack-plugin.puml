```plantuml
@startuml mcuking_offline-package-webpack-plugin
skinparam rectangle {
  BackgroundColor #f9f9f9
  BorderColor black
  Style roundrect
}
left to right direction

actor "Developer" as dev

rectangle "Webpack Build Process" {
  rectangle "OfflinePackagePlugin" as plugin {
    rectangle "Configuration" as config
    rectangle "JSZip" as jszip
    rectangle "mime-types" as mime
  }

  rectangle "Emit Stage" as emit {
    rectangle "Zip Archive Creation" as zip
    rectangle "Index.json Manifest" as manifest
  }
}

dev --> config : Configure Plugin
config --> plugin : Pass Options
plugin --> emit : Hook into Emit
emit --> zip : Create Zip Archive
emit --> manifest : Generate Manifest
manifest --> mime : Detect MIME Types
zip --> jszip : Use JSZip Library

@enduml
```