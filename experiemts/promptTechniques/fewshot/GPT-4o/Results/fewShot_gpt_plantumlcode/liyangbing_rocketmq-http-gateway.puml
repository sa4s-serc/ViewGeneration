```plantuml
@startuml liyangbing_rocketmq-http-gateway
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "HTTP Gateway" {

  rectangle "Transport Layer" {
    rectangle "Netty" as Netty
    rectangle "RequestDecoder" as ReqDecoder
    rectangle "RequestValidator" as ReqValidator
    rectangle "ResponseEncoder" as RespEncoder
    rectangle "NettyConnectionManageHandler" as ConnManager
    rectangle "GatewayLoggingHandler" as LoggingHandler
  }

  rectangle "Processor Layer" {
    rectangle "ProduceMessageProcessor" as ProdMsgProcessor
    rectangle "ConsumerManager" as ConsumerManager
    rectangle "ProducerManager" as ProducerManager
    rectangle "HttpExecutor" as HttpExecutor
    rectangle "HttpMessageListenerConcurrently" as MsgListener
    rectangle "SubscriptionChangeWatcher" as SubChangeWatcher
  }

  rectangle "Common Layer" {
    rectangle "Service" as Service
    rectangle "HttpClients" as HttpClients
  }
}

package "RocketMQ" {
  rectangle "RocketMQ Broker" as RocketMQBroker
  rectangle "Producers" as RocketMQProducers
  rectangle "Consumers" as RocketMQConsumers
}

package "HTTP Clients" {
  actor "HTTP Client" as HttpClient
  rectangle "HTTP Endpoints" as HttpEndpoints
}

HttpClient --> ReqDecoder
ReqDecoder --> ReqValidator
ReqValidator --> ProdMsgProcessor
ProdMsgProcessor --> ProducerManager
ProducerManager --> RocketMQProducers

RocketMQProducers --> RocketMQBroker
RocketMQBroker --> RocketMQConsumers
RocketMQConsumers --> MsgListener
MsgListener --> HttpExecutor
HttpExecutor --> HttpEndpoints

SubChangeWatcher --> ProducerManager
SubChangeWatcher --> ConsumerManager

ConsumerManager --> RocketMQConsumers

MsgListener --> HttpClients

Netty --> ReqDecoder
Netty --> ReqValidator
Netty --> RespEncoder
Netty --> ConnManager
Netty --> LoggingHandler

@enduml
```