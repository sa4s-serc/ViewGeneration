```plantuml
@startuml decentraland_catalyst
skinparam linetype ortho
skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor black
  Style roundrect
}

package "Decentraland Catalyst Content Server" {
  rectangle "Server" {
    [Server.ts] 
    [Environment.ts] 
  }

  rectangle "API" {
    [Profiles API] 
    [Content API] 
    [Collections API] 
  }

  rectangle "Logic" {
    [Deployments] 
    [Entity Parser] 
    [Synchronization] 
    [Snapshots] 
    [Database Queries] 
  }

  rectangle "Service" {
    [Service.ts] 
    [Components] 
    [Types] 
  }

  rectangle "Controller" {
    [Routes] 
    [Handlers] 
  }

  rectangle "Validation" {
    [Entity Validations] 
  }

  rectangle "Database" {
    [Migrations] 
    [PostgreSQL] 
  }

  rectangle "Ports" {
    [The Graph] 
    [Third Party] 
  }

  rectangle "Utils" {
    [Utility Classes] 
  }

  rectangle "Metrics" {
    [Monitoring] 
  }

  rectangle "Cache" {
    [LRU Cache] 
    [Bloom Filter] 
  }

  rectangle "Security" {
    [Authentication] 
    [Authorization] 
  }
}

actor "User"

' API Interactions
User --> Profiles API : Fetch Profiles
User --> Content API : Retrieve Content
User --> Collections API : Access Collections

' Server and Logic Interactions
Server.ts --> Deployments : Manage Deployments
Server.ts --> Synchronization : Sync State
Service.ts --> Components : Setup & Init
Components --> Entity Parser : Parse & Validate
Entity Parser --> Entity Validations : Validate Entities

' Ports and External Services
Deployments --> The Graph : Query
Collections API --> The Graph : Query
Ports --> Third Party : Asset Retrieval

' Database Interactions
Deployments --> PostgreSQL : Store Data
Synchronization --> Snapshots : Manage Snapshots
Migrations --> PostgreSQL : Schema Changes

' Caching and Security
Entity Parser --> LRU Cache : Cache Active Entities
Entity Parser --> Bloom Filter : Check Non-existent Entities
Security --> Authentication : Validate Users
Security --> Authorization : Check Permissions

' Monitoring and Utilities
Service.ts --> Monitoring : Collect Metrics
Utility Classes --> Deployments : Fetch Data
@enduml
```