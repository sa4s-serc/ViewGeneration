```plantuml
@startuml afonsocastro_larcc_interface
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
skinparam linetype ortho

package "LARCC Workcell Control System" {

  package "UR10e Robot Control" {
    rectangle "UR10e\nConfiguration" as URConfig
    rectangle "ROBOTIQ 2F-140\nGripper Control" as GripperControl
    rectangle "URCap Files" as URCap
    rectangle "RS485 Communication" as RS485
  }

  package "MoveIt! Integration" {
    rectangle "UR10e MoveIt!\nConfiguration" as MoveItConfig
    rectangle "Path Planning\nand Execution" as PathPlanning
    rectangle "RViz Visualization" as RViz
  }

  package "Kinematics" {
    rectangle "Analytical IK/FK\nSolvers" as IKFK
    rectangle "C++ and Python\nAccess" as CPPPython
  }

  package "LARCC Workcell Description" {
    rectangle "URDF and Xacro\nModels" as URDFXacro
    rectangle "Environment Elements\n(Tables, Gantries)" as Environment
    rectangle "Sensor Configurations" as SensorConfig
  }

  package "RealSense Camera Support" {
    rectangle "RealSense\nLaunch Files" as RealSenseLaunch
    rectangle "Point Cloud\nand Images" as PointCloud
  }

  package "3D Model Definitions" {
    rectangle ".DAE Files" as DAEFiles
  }
  
  URConfig --> GripperControl
  URConfig --> URCap
  GripperControl --> RS485
  
  MoveItConfig --> PathPlanning
  PathPlanning --> RViz

  IKFK --> CPPPython

  URDFXacro --> Environment
  URDFXacro --> SensorConfig

  RealSenseLaunch --> PointCloud

  DAEFiles --> URDFXacro
}

@enduml
