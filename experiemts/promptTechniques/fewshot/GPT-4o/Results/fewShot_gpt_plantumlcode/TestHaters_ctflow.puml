```plantuml
@startuml TestHaters_ctflow
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

actor User

package "VS Code" {
  rectangle "VS Code\nExtension" as Extension #d9e7fd
  rectangle "React-based\nWebview UI" as Webview #d9e7fd
}

rectangle "Cypress\nTesting Framework" as Cypress #d8f5d3

package "CTFLOW Components" {
  rectangle "Custom Nodes" as CustomNodes
  rectangle "Default Nodes" as DefaultNodes
  rectangle "Node Menu Panel" as NodeMenu
  rectangle "Compile Panel" as CompilePanel
}

package "Communication" {
  rectangle "Firebase\n(WebSockets)" as Firebase #fddddd
}

package "File System" {
  rectangle ".ctflow\n(YAML)" as CtFlowFile #fff1c9
}

User --> Webview : Interact with UI
Webview <--> Extension : VS Code API
Webview --> CustomNodes : Create/Modify
Webview --> DefaultNodes : Use
Webview --> NodeMenu : Add Nodes
Webview --> CompilePanel : Compile to Code
Webview <--> Firebase : Real-time Updates
CompilePanel --> Cypress : Execute Tests
Webview --> CtFlowFile : Import/Export

@enduml
```