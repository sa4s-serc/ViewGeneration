```plantuml
@startuml david3107_squatm3gator
skinparam rectangle {
  BackgroundColor #f6faff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

package "Frontend" {
  rectangle "index.html" as index_html
  rectangle "static/css" as css
}

package "Backend" {
  rectangle "server.py" as server
  rectangle "squatme.py" as squatme
  rectangle "modules" {
    rectangle "HomoglyphAttack.py" as HomoglyphAttack
    rectangle "Flipper.py" as Flipper
    rectangle "RemoveOneLetter.py" as RemoveOneLetter
    rectangle "GoDaddy.py" as GoDaddy
    rectangle "TldSelector.py" as TldSelector
    rectangle "Whoiser.py" as Whoiser
    rectangle "Domain.py" as Domain
    rectangle "Result.py" as Result
  }
  rectangle "configuration/config.py" as config
  rectangle "wrapper" {
    rectangle "job.py" as job
    rectangle "producer/producer.py" as producer
    rectangle "consumer/consumer.py" as consumer
    rectangle "comm.py" as comm
  }
}

package "Infrastructure" {
  rectangle "Dockerfile" as dockerfile
  rectangle "docker-compose.yml" as docker_compose
  database "Redis" as redis
}

User --> index_html
index_html --> css
index_html --> server
server --> squatme
squatme --> HomoglyphAttack
squatme --> Flipper
squatme --> RemoveOneLetter
squatme --> GoDaddy
squatme --> TldSelector
squatme --> Whoiser
squatme --> Domain
squatme --> Result
server --> redis
squatme --> redis
redis --> consumer
redis --> producer
squatme --> config
consumer --> comm
producer --> comm
job --> consumer
job --> producer

@enduml
```