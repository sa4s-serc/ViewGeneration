```plantuml
@startuml dowjones_hammer
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center
skinparam linetype ortho

actor "Admin"

package "AWS" {
  rectangle "S3" as S3
  rectangle "IAM" as IAM
  rectangle "EBS" as EBS
  rectangle "RDS" as RDS
  rectangle "SQS" as SQS
  rectangle "EC2" as EC2
  rectangle "Lambda" as Lambda
  rectangle "DynamoDB" as DynamoDB
  rectangle "SNS" as SNS
  rectangle "CloudWatch Logs" as CloudWatch
  rectangle "API Gateway" as APIGW
  rectangle "CloudFormation" as CF
}

package "Dow Jones Hammer" {
  rectangle "Initiation Lambda" as InitLambda
  rectangle "Identification Lambdas" as IdLambda
  rectangle "Reporting/Remediation" as RepRemLogic
  rectangle "Configuration Files" as ConfigFiles
  rectangle "REST API" as RestAPI
}

package "External Integrations" {
  rectangle "JIRA" as JIRA
  rectangle "Slack" as Slack
}

Admin --> ConfigFiles
Admin --> RestAPI
RestAPI --> APIGW
APIGW --> InitLambda
InitLambda --> SNS
SNS --> IdLambda
IdLambda --> [AWS Services]
IdLambda --> DynamoDB
IdLambda --> CloudWatch
DynamoDB --> RepRemLogic
RepRemLogic --> JIRA
RepRemLogic --> Slack
RepRemLogic --> EC2
RepRemLogic --> S3
@enduml
```