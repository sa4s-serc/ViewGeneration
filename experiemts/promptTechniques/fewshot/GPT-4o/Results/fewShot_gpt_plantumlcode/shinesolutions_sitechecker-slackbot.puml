```plantuml
@startuml shinesolutions_sitechecker-slackbot
skinparam componentStyle rectangle
skinparam linetype ortho

package "Slack" {
  [Slack User] as SlackUser
  [Slack Outgoing Webhook] as SlackWebhook
}

package "AWS" {
  [API Gateway] as APIGateway

  rectangle "Lambda Functions" {
    [Master Lambda] as MasterLambda
    [Worker Lambda - Region 1] as WorkerLambda1
    [Worker Lambda - Region 2] as WorkerLambda2
    [Worker Lambda - Region N] as WorkerLambdaN
  }
}

package "SiteChecker Services" {
  [SiteChecker Logic] as SiteCheckerLogic
  [Slack Formatter] as SlackFormatter
}

SlackUser --> SlackWebhook : Send command
SlackWebhook --> APIGateway : Trigger Event
APIGateway --> MasterLambda : Invoke

MasterLambda --> SiteCheckerLogic : Parse URL
MasterLambda --> SlackFormatter : Format response
MasterLambda --> WorkerLambda1 : Distribute task
MasterLambda --> WorkerLambda2 : Distribute task
MasterLambda --> WorkerLambdaN : Distribute task

WorkerLambda1 --> SiteCheckerLogic : Check site
WorkerLambda2 --> SiteCheckerLogic : Check site
WorkerLambdaN --> SiteCheckerLogic : Check site

MasterLambda <-- WorkerLambda1 : Return result
MasterLambda <-- WorkerLambda2 : Return result
MasterLambda <-- WorkerLambdaN : Return result

MasterLambda --> SlackFormatter : Aggregate results
SlackFormatter --> SlackWebhook : Send summary

@enduml
```