```plantuml
@startuml brightzheng100_instana-handson-labs
skinparam rectangle {
  BackgroundColor #f9f9f9
  BorderColor #333333
  Style roundrect
}
left to right direction
skinparam defaultTextAlignment center

package "Instana Hands-on Labs" {
  package "Part 1: Installation" {
    rectangle "Instana Backend\nInstallation" as InstanaInstall
    rectangle "Agent Configuration" as AgentConfig
  }

  package "Part 2: Core Features" {
    rectangle "Application Monitoring" as AppMonitoring
    rectangle "Infrastructure Monitoring" as InfraMonitoring
    rectangle "Website Monitoring" as WebMonitoring
  }

  package "Part 3: Advanced Topics" {
    rectangle "SLO Monitoring" as SLOMonitoring
    rectangle "RBAC" as RBAC
    rectangle "Custom Metrics" as CustomMetrics
    rectangle "OpenTelemetry Integration" as OpenTelemetry
    rectangle "Language-Specific Monitoring" as LangMonitoring
  }

  package "Scripts" {
    rectangle "K8s Bootstrap" as K8sBootstrap
    rectangle "OS-Specific Config" as OSConfig
    rectangle "Utility Functions" as Utils
  }

  package "Kubernetes Integration" {
    rectangle "Resource Deployments" as ResourceDeploy
    rectangle "Microservices\n(Robot Shop)" as Microservices
  }

  package "Documentation" {
    rectangle "README.md" as Readme
    rectangle "Lab Instructions" as LabInstructions
  }
}

InstanaInstall --> AgentConfig
AgentConfig --> AppMonitoring
AgentConfig --> InfraMonitoring
AgentConfig --> WebMonitoring
AppMonitoring --> SLOMonitoring
AppMonitoring --> RBAC
AppMonitoring --> CustomMetrics
AppMonitoring --> OpenTelemetry
InfraMonitoring --> LangMonitoring
WebMonitoring --> LangMonitoring
K8sBootstrap --> ResourceDeploy
K8sBootstrap --> Microservices
OSConfig --> K8sBootstrap
Utils --> K8sBootstrap
Microservices --> InstanaInstall
Microservices --> AgentConfig
Readme --> LabInstructions
@enduml
