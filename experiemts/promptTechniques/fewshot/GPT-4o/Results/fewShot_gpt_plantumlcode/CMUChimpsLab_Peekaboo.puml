```plantuml
@startuml CMUChimpsLab_Peekaboo
skinparam rectangle {
  BackgroundColor #f2f2f2
  BorderColor black
  Style roundrect
}
left to right direction

package "Node-RED Nodes" {
  rectangle "Provider Nodes" as Provider {
    rectangle "Push\\nNode" as PushNode
    rectangle "Pull\\nNode" as PullNode
  }
  
  rectangle "Inference Nodes" as Inference {
    rectangle "Classify\\nNode" as ClassifyNode
    rectangle "Detect\\nNode" as DetectNode
    rectangle "Extract\\nNode" as ExtractNode
  }
  
  rectangle "Filter Nodes" as Filter {
    rectangle "Select\\nNode" as SelectNode
    rectangle "Noisify\\nNode" as NoisifyNode
    rectangle "Spoof\\nNode" as SpoofNode
  }

  rectangle "Network Nodes" as Network {
    rectangle "Post\\nNode" as PostNode
  }

  rectangle "Utility Nodes" as Utility {
    rectangle "Aggregate\\nNode" as AggregateNode
    rectangle "pkbInject\\nNode" as PkbInjectNode
    rectangle "pkbJoin\\nNode" as PkbJoinNode
  }
}

actor "User" as User

package "Dynamic UI" {
  rectangle "UI Generator" as UIGenerator
  rectangle "Select2\\nIntegration" as Select2
}

package "Service Abstraction" {
  rectangle "PeekabooService" as PeekabooService
  rectangle "AsyncPeekabooService" as AsyncPeekabooService
}

package "Sensor Management" {
  rectangle "WiFiConfig" as WiFiConfig
}

package "State Management" {
  rectangle "StateIO" as StateIO
}

