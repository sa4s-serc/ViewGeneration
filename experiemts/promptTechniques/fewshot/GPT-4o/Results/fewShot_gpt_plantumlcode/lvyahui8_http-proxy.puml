```plantuml
@startuml lvyahui8_http-proxy
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho

package "HTTP Proxy Service" {
    [proxy-server] <<Module>> {
        [HttpProxyServer] as HttpProxyServer
        [ClientToProxyHandler] as ClientToProxyHandler
        [ProxyToServerInboundHandler] as ProxyToServerInboundHandler
        [EntitysManager] as EntitysManager
        [GlobalExceptionHandler] as GlobalExceptionHandler
        [EventLoopGroupManager] as EventLoopGroupManager
    }
    [test-client] <<Module>> {
        [TestClientApp] as TestClientApp
    }
    [test-server] <<Module>> {
        [TestServerMain] as TestServerMain
        [TestResource] as TestResource
    }
    [proxy-sdk] <<Module>>
}

package "Filters" {
    [ProxyRequestFilter] as ProxyRequestFilter
    [ProxyResponseFilter] as ProxyResponseFilter
    [AttackRequestFilter] as AttackRequestFilter
    [DefaultProxyResponseFilter] as DefaultProxyResponseFilter
}

package "Messaging" {
    [MsgCode] as MsgCode
    [MsgTranslater] as MsgTranslater
    [StandardResponse] as StandardResponse
}

package "Configuration" {
    [entitys.json] as EntitysJson
    [log4j2.xml] as Log4j2Xml
}

HttpProxyServer --> ClientToProxyHandler
ClientToProxyHandler --> ProxyToServerInboundHandler
ClientToProxyHandler --> EntitysManager
ProxyToServerInboundHandler --> ProxyResponseFilter
EntitysManager --> EntitysJson
GlobalExceptionHandler --> MsgTranslater
GlobalExceptionHandler --> StandardResponse
TestClientApp --> HttpProxyServer
TestServerMain --> TestResource

ProxyRequestFilter <|-- AttackRequestFilter
ProxyResponseFilter <|-- DefaultProxyResponseFilter

@enduml
```