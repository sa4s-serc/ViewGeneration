```plantuml
@startuml rinkako_CStoreDBMS
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho

package "DBInterface Layer" {
    rectangle "DBController" as DBController
    rectangle "DBConnectionPool" as DBConnectionPool
}

package "DBCompiler Layer" {
    rectangle "LexicalAnalyzer" as LexicalAnalyzer
    rectangle "ISyntaxParser" as SyntaxParser
    rectangle "Pile" as Pile
    rectangle "CSDatabase" as CSDatabase
    rectangle "DBBridge" as DBBridge
}

package "DBEngine Layer" {
    rectangle "FileManager" as FileManager
    rectangle "TableManager" as TableManager
    rectangle "DBAllocator" as DBAllocator
    rectangle "DBLock" as DBLock
    rectangle "DBTransaction" as DBTransaction
}

DBController --> DBConnectionPool
DBConnectionPool --> DBBridge

DBBridge --> LexicalAnalyzer
DBBridge --> SyntaxParser
DBBridge --> Pile
DBBridge --> CSDatabase

CSDatabase --> FileManager
CSDatabase --> TableManager
CSDatabase --> DBAllocator
CSDatabase --> DBLock
CSDatabase --> DBTransaction

FileManager --> TableManager

note right of FileManager
  Handles file I/O, sorting, compression
end note

note right of TableManager
  Manages tables, metadata, locks
end note

note right of DBAllocator
  Custom memory allocation
end note

note right of DBLock
  Lock management for concurrency
end note

note right of DBTransaction
  Encapsulates database transactions
end note

@enduml
```