  rectangle "HikariClient" as Client
  rectangle "DefaultHikariClient" as DefaultClient
}

package "Server" {
  rectangle "BootstrapServer" as Bootstrap
  rectangle "HikariKeeperServer" as KeeperServer
}

package "Core" {
  rectangle "Rnode" as Rnode
  rectangle "RnodeRole" as RnodeRole
  rectangle "LeaderNode" as LeaderNode
  rectangle "FollowerNode" as FollowerNode
  rectangle "CandidateNode" as CandidateNode
  rectangle "RnodeRepository" as RnodeRepository
  rectangle "Rpc" as Rpc
  rectangle "RaftLog" as RaftLog
  rectangle "VoteRequestRpcContext" as VoteContext
  rectangle "RocksDB Storage" as RocksDB
}

package "Discovery Service" {
  rectangle "DiscoveryClient" as DiscoveryClient
  rectangle "ServiceInstance" as ServiceInstance
}

package "Spring Boot Integration" {
  rectangle "HikariServerConfig" as ServerConfig
  rectangle "HikariServerProperties" as ServerProperties
  rectangle "HikariServerAutoConfiguration" as ServerAutoConfig
}

package "Benchmarking" {
  rectangle "Benchmark Module" as Benchmark
}

ClientFactory --> Client
Client --> DefaultClient

Bootstrap --> KeeperServer
KeeperServer --> Rnode

Rnode --> RnodeRole
RnodeRole --> LeaderNode
RnodeRole --> FollowerNode
RnodeRole --> CandidateNode
Rnode --> RnodeRepository
Rnode --> Rpc
Rnode --> RaftLog
Rnode --> VoteContext
RocksDB --> Rnode

DiscoveryClient --> ServiceInstance

ServerConfig --> ServerProperties
ServerConfig --> ServerAutoConfig

@enduml
