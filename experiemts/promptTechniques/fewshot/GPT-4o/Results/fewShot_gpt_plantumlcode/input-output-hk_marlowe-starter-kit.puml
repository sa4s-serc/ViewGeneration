```plantuml
@startuml input-output-hk_marlowe-starter-kit
skinparam defaultTextAlignment center
skinparam linetype ortho

actor Developer
actor User

rectangle "Frontend" {
    rectangle "HTML/CSS/JS" as FrontendUI
    rectangle "dApp Interaction\\n(CIP30 / CIP45)" as dAppInteraction
    rectangle "UI Controller\\n(controller.js)" as UIController
}

rectangle "Backend" {
    rectangle "Marlowe Runtime" {
        rectangle "Transaction Construction" as TxConstruction
        rectangle "Querying" as Querying
        rectangle "UTxO Management" as UTxOManagement
    }
    rectangle "Command-Line Tools" {
        rectangle "marlowe-cli"
        rectangle "marlowe-runtime-cli"
        rectangle "Wallet Scripts" as WalletScripts
    }
    rectangle "Jupyter Notebooks" as Jupyter
}

rectangle "Deployment" {
    rectangle "Docker Compose" as Docker
    rectangle "Nix Flake" as Nix
    rectangle "Demeter Run" as Demeter
}

Developer --> Jupyter : Learn & Experiment
Developer --> Docker : Deploy Environment
Developer --> Nix : Deploy Environment
Developer --> Demeter : Deploy Environment

User --> FrontendUI : Access dApp
FrontendUI --> UIController : Handle Events
UIController --> dAppInteraction : Interact with Wallets
dAppInteraction --> TxConstruction
dAppInteraction --> Querying
dAppInteraction --> UTxOManagement

WalletScripts --> marlowe-cli
WalletScripts --> marlowe-runtime-cli

@enduml
```