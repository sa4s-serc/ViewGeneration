```plantuml
@startuml tarhses_esp-alarm-clock
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "ESP32" {
  rectangle "FreeRTOS Tasks" {
    rectangle "Main Task" as MainTask
    rectangle "Alarm Task" as AlarmTask
    rectangle "Network Task" as NetworkTask
    rectangle "Display Task" as DisplayTask
    rectangle "Sound Task" as SoundTask
    rectangle "Potentiometer Task" as PotTask
  }

  rectangle "Modules" {
    rectangle "Alarm Module" as AlarmModule
    rectangle "Network Module" as NetworkModule
    rectangle "Display Module" as DisplayModule
    rectangle "Sound Module" as SoundModule
    rectangle "Potentiometer Module" as PotModule
    rectangle "Storage Module" as StorageModule
  }
}

rectangle "Peripherals" {
  rectangle "E-Paper Display" as EPD
  rectangle "WiFi"
  rectangle "SD Card"
  rectangle "Speaker"
  rectangle "Potentiometers"
  rectangle "Buttons"
  rectangle "Switch"
}

User --> Buttons : Press
User --> Switch : Toggle

MainTask --> AlarmModule : Initialize
MainTask --> NetworkModule : Initialize
MainTask --> DisplayModule : Initialize
MainTask --> SoundModule : Initialize
MainTask --> PotModule : Initialize
MainTask --> StorageModule : Initialize

AlarmTask --> AlarmModule : Manage Alarms
NetworkTask --> NetworkModule : Sync Time
DisplayTask --> DisplayModule : Update Display
SoundTask --> SoundModule : Play Sound
PotTask --> PotModule : Read Values

AlarmModule --> EPD : Show Alarm Time
NetworkModule --> WiFi : Connect
NetworkModule --> SD Card : Read Config
DisplayModule --> EPD : Show Time
SoundModule --> Speaker : Output Sound
PotModule --> Potentiometers : Read Values
StorageModule --> SD Card : Mount
StorageModule --> SD Card : Access Files
StorageModule --> [Non-Volatile Storage] : Store Calibration

AlarmModule --> SoundTask : Trigger Alarm Sound
AlarmModule --> DisplayTask : Update Status
SoundModule --> StorageModule : Read Audio Files

@enduml
```