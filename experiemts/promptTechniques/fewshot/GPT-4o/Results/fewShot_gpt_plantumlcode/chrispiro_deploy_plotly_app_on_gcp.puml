```plantuml
@startuml chrispiro_deploy_plotly_app_on_gcp
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "User Interaction" {
  actor "User"
}

package "Data Visualization App" {
  rectangle "Dash App\n(dash_app.py)" as DashApp
  rectangle "Create Charts\n(create_charts.py)" as CreateCharts
  rectangle "Load Data\n(load_data.py)" as LoadData
  rectangle "Jupyter Notebook\n(test_plotly_charts.ipynb)" as Notebook
}

package "Google Cloud Platform" {
  cloud "GCP App Engine" as AppEngine {
    rectangle "App Engine Service\n(app.yaml)" as AppService
  }
  cloud "BigQuery" as BigQuery
  cloud "Cloud Storage" as CloudStorage
}

package "Local Environment" {
  rectangle "Python Environment\n(requirements.txt)" as PythonEnv
}

User --> Notebook : Experiment with charts
Notebook --> CreateCharts : Copy chart code

DashApp --> LoadData : Load data
DashApp --> CreateCharts : Generate visualizations

CreateCharts --> DashApp
LoadData --> BigQuery
LoadData --> CloudStorage

DashApp --> AppService : Deploy app
AppService --> DashApp : Run app
AppService -> DashApp : User access

PythonEnv --> Notebook
PythonEnv --> DashApp
@enduml
```