```plantuml
@startuml ev2900_OpenSearch_Dashboard_Nginx_Proxy
skinparam rectangle {
  Style roundrect
  BackgroundColor #f5f5f5
  BorderColor black
}
skinparam linetype ortho

cloud "Internet" as Internet

rectangle "AWS Cloud" {
  rectangle "VPC" {
    rectangle "Public Subnet" {
      rectangle "Nginx Proxy\nEC2 Instance" as Nginx #lightblue
    }
  
    rectangle "Private Subnet" {
      rectangle "OpenSearch\nDashboard" as OpenSearch #lightyellow
    }
  }
}

Internet --> Nginx : HTTPS
Nginx --> OpenSearch : Forward HTTP
@enduml
```