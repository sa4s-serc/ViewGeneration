```plantuml
@startuml matryx_MatryxPlatform
left to right direction
skinparam rectangle {
  BackgroundColor #F5F5F5
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

package "Matryx Platform" {
  rectangle "MatryxPlatform\n(Proxy)" as MatryxPlatform #B0C4DE
  rectangle "MatryxSystem" as MatryxSystem #B0E0E6
  rectangle "MatryxToken\n(ERC20)" as MatryxToken #FFD700

  rectangle "LibPlatform" as LibPlatform #ADD8E6
  rectangle "LibCommit" as LibCommit #ADD8E6
  rectangle "LibTournament" as LibTournament #ADD8E6

  MatryxPlatform -[#000000]> LibPlatform : delegatecall
  MatryxPlatform -[#000000]> LibCommit : delegatecall
  MatryxPlatform -[#000000]> LibTournament : delegatecall
  MatryxPlatform -[#000000]> MatryxSystem : check version
  MatryxPlatform -[#000000]> MatryxToken

  MatryxSystem -[#000000]> MatryxPlatform
}

package "Frontend Interaction" {
  rectangle "JavaScript Layer\n(truffle/utils.js)" as JSLayer #E0FFFF
  rectangle "Testing/Deployment\n(truffle/test.js)" as TestLayer #E0FFFF

  JSLayer -[#000000]> MatryxPlatform : interact
  TestLayer -[#000000]> JSLayer : test/deploy
}

User --> JSLayer

@enduml
```