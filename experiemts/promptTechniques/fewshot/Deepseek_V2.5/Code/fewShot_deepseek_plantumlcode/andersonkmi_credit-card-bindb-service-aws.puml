@startuml andersonkmi_credit-card-bindb-service-aws
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Data Ingestion" {
  rectangle "S3\nCSV Files" as s3 #orange
  rectangle "Lambda\nCSV Parser" as csvParser #orange
  rectangle "SQS" as sqs #orange
  rectangle "Kinesis\nStream" as kinesis #orange
}

package "Data Processing" {
  rectangle "Lambda\nMessage Processor" as msgProcessor #orange
  database "DynamoDB\nBIN Data" as dynamoDB #brown
}

package "API Layer" {
  rectangle "API Gateway" as apiGw #green
  rectangle "Lambda\nAPI Handler" as apiHandler #green
  rectangle "Custom Auth\nLambda" as authLambda #green
  database "DynamoDB\nAuth Table" as authDB #green
}

actor "Client" as client

s3 --> csvParser : Triggers
csvParser --> sqs : Pushes messages
csvParser --> kinesis : Streams records
sqs --> msgProcessor : Polls messages
kinesis --> msgProcessor : Consumes stream
msgProcessor --> dynamoDB : Stores processed data

client --> apiGw : HTTP Requests
apiGw --> apiHandler : Routes requests
apiGw --> authLambda : Authorizes
authLambda --> authDB : Validates credentials
apiHandler --> dynamoDB : Queries data
@enduml