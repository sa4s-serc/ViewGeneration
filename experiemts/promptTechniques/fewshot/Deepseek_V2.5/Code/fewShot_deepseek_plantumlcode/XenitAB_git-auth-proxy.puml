@startuml XenitAB_git-auth-proxy
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Git Client" as Client

rectangle "Kubernetes Cluster" as K8s {
  rectangle "git-auth-proxy" as Proxy {
    rectangle "Gin Web Server" as Gin
    rectangle "Authorizer" as Auth
    rectangle "Token Writer" as TokenWriter
    rectangle "Metrics Endpoint" as Metrics
  }

  database "Kubernetes Secrets" as Secrets
}

cloud "Git Providers" as Git {
  rectangle "GitHub" as GitHub
  rectangle "Azure DevOps" as AzureDevOps
}

Client --> Gin : Git requests (HTTPS)
Gin --> Auth : Validate token
Auth --> TokenWriter : Check token validity
TokenWriter --> Secrets : Read/Write tokens
Auth --> GitHub : Forward request (if GitHub)
Auth --> AzureDevOps : Forward request (if Azure DevOps)
GitHub --> Gin : Response
AzureDevOps --> Gin : Response
Gin --> Client : Response

Proxy --> Metrics : Expose metrics
@enduml