@startuml avarghesein_ActiveX.NET
skinparam rectangle {
  BackgroundColor<<server>> #d9e7fd
  BackgroundColor<<plugin>> #d8f5d3
  BackgroundColor<<common>> #fff1c9
  BackgroundColor<<com>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

package "COM Client" <<com>> {
  rectangle "COM Client App" as Client
}

package "ActiveX.NET.Server" <<server>> {
  rectangle "Program.cs" as Program
  rectangle "ActiveXServerContext" as Context
  rectangle "ActiveXServers (MEF)" as MEF
  rectangle "DefaultActiveXFactory" as Factory
  rectangle "App.config" as Config
  Program --> Context
  Context --> MEF
  MEF --> Factory
  MEF --> Config
}

package "ActiveX.NET.Plugin" <<plugin>> {
  rectangle "CoClass.cs" as CoClass
  rectangle "SimpleObject" as SimpleObject
  CoClass --> SimpleObject
}

package "ActiveX.NET.Common" <<common>> {
  rectangle "IActiveXServer" as Interface
  rectangle "ActiveXServerBase" as Base
  rectangle "ActiveXServerMTABase" as MTABase
  rectangle "ActiveXServerControlBase" as ControlBase
  rectangle "ActiveXServerAttribute" as Attribute
}

Client --> Factory : COM calls
Factory --> SimpleObject : creates
SimpleObject --> Interface : implements
SimpleObject --> Base : inherits
SimpleObject --> MTABase : inherits
SimpleObject --> ControlBase : inherits
SimpleObject --> Attribute : uses
MEF --> Interface : discovers
MEF --> Attribute : scans for
@enduml