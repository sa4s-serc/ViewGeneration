### Output:
@startuml SimonLdj_hypnolog-server
left to right direction
skinparam rectangle {
  BackgroundColor<<server>> #d8f5d3
  BackgroundColor<<client>> #d9e7fd
  BackgroundColor<<visualization>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Server" <<server>> {
  rectangle "Express Server" as Express
  rectangle "Socket.IO" as SocketIO
  rectangle "Logger Route" as LoggerRoute
  rectangle "Ajv Validator" as Ajv
}

package "Client Applications" <<external>> {
  rectangle "App 1" as App1
  rectangle "App 2" as App2
  rectangle "CLI Tools" as CLI
}

package "Web UI" <<client>> {
  rectangle "Browser Client" as Browser
  rectangle "Windows Dispatcher" as WinDispatcher
  rectangle "Visualizer Dispatcher" as VizDispatcher
  rectangle "Config Factory" as ConfigFactory
}

package "Visualization" <<visualization>> {
  rectangle "Text Visualizer" as TextViz
  rectangle "Number Visualizer" as NumViz
  rectangle "Image Visualizer" as ImgViz
  rectangle "Heatmap Visualizer" as HeatViz
  rectangle "Code Visualizer" as CodeViz
}

App1 --> Express : HTTP POST (JSON)
App2 --> Express : HTTP POST (JSON)
CLI --> Express : HTTP POST (JSON)

Express --> LoggerRoute
LoggerRoute --> Ajv : Validate
LoggerRoute --> SocketIO : Broadcast

SocketIO --> Browser : Real-time data
Browser --> WinDispatcher
WinDispatcher --> VizDispatcher
VizDispatcher --> TextViz
VizDispatcher --> NumViz
VizDispatcher --> ImgViz
VizDispatcher --> HeatViz
VizDispatcher --> CodeViz

Browser --> ConfigFactory : Load config
ConfigFactory --> VizDispatcher : Configure
@enduml