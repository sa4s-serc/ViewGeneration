@startuml IBM_ios-mapkit-indoor-map
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as User

rectangle "iOS App" as iOS {
  rectangle "ViewController" as ViewController
  rectangle "FloorplanOverlay" as FloorplanOverlay
  rectangle "FloorplanOverlayRenderer" as FloorplanRenderer
  rectangle "CoordinateConverter" as CoordinateConverter
  rectangle "VisibleMapRegionDelegate" as MapDelegate
  rectangle "CustomPolygons" as CustomPolygons
  rectangle "Utilities" as Utilities
}

rectangle "Node.js Backend" as Backend {
  rectangle "Express Server" as Express
  rectangle "Routes" as Routes
  rectangle "Mongoose Models" as Models
  rectangle "PDF Generator" as PDFGenerator
}

database "MongoDB" as MongoDB

cloud "Cloud Foundry" as CF

User --> ViewController

ViewController --> FloorplanOverlay
ViewController --> FloorplanRenderer
ViewController --> CoordinateConverter
ViewController --> MapDelegate
ViewController --> CustomPolygons
ViewController --> Utilities

FloorplanOverlay --> FloorplanRenderer
FloorplanRenderer --> CoordinateConverter

ViewController --> Express : GET/POST API calls
Express --> Routes
Routes --> Models
Models --> MongoDB
Routes --> PDFGenerator
PDFGenerator --> Models

Express --> CF : Deployed on
MongoDB --> CF : Bound service

note right of Express
  RESTful API:
  - GET map data
  - GET heatmap data
  - POST trigger events
end note
@enduml