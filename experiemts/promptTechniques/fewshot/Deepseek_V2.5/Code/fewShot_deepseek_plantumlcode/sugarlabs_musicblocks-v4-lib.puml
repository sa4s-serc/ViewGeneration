### Output:
@startuml sugarlabs_musicblocks-v4-lib
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Syntax Representation" {
  rectangle "Element API\n(IElementSpecification)" as ElementAPI
  rectangle "Specification" as Spec
  rectangle "Warehouse" as Warehouse
  rectangle "Syntax Tree" as SyntaxTree
  ElementAPI --> Spec
  Spec --> Warehouse
  Warehouse --> SyntaxTree
}

package "Execution Engine" {
  rectangle "Symbol Table" as SymbolTable
  rectangle "Parser" as Parser
  rectangle "Interpreter" as Interpreter
  rectangle "Scheduler" as Scheduler
  SymbolTable --> Parser
  Parser --> Interpreter
  Interpreter --> Scheduler
}

package "Library" {
  rectangle "Values\n(Boolean, Number, String)" as Values
  rectangle "Variables\n(Boxes, Identifiers)" as Variables
  rectangle "Operators\n(Math, Logic)" as Operators
  rectangle "Control Flow\n(If, Repeat)" as ControlFlow
  rectangle "Program Structures\n(Process, Routine)" as Structures
  rectangle "Miscellaneous\n(Print)" as Misc
}

SyntaxTree --> Parser
Library --> ElementAPI
@enduml