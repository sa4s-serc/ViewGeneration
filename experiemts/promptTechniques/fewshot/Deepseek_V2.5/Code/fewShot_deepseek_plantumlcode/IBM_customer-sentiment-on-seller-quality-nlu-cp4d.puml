@startuml IBM_customer-sentiment-on-seller-quality-nlu-cp4d
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as user

rectangle "Jupyter Notebook" as notebook {
  rectangle "Data Processing Pipeline" as pipeline
  rectangle "Sentiment Analysis" as sentiment
  rectangle "Rating Calculation" as rating
}

rectangle "Watson NLU" as nlu #lightblue
database "Db2 Database" as db2 #lightgreen
rectangle "Embedded Dashboard" as dashboard #lightyellow

user --> notebook : Executes
notebook --> db2 : Extracts review data
notebook --> nlu : Calls for sentiment analysis
notebook --> dashboard : Pushes results

pipeline --> sentiment : Processes
sentiment --> rating : Computes
rating --> dashboard : Generates visualization

note right of nlu
  Analyzes emotions:
  joy, sadness, anger
end note

note right of db2
  Contains refined
  customer review data
end note
@enduml