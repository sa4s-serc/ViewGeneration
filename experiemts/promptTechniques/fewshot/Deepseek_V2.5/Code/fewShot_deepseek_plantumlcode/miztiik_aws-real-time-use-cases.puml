@startuml miztiik_aws-real-time-use-cases
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Developer" as Dev
actor "Solution Architect" as SA
actor "Operations Engineer" as Ops

rectangle "AWS Services" as AWS {
  rectangle "Security" as Sec
  rectangle "Storage" as Stor
  rectangle "Compute" as Comp
  rectangle "Management" as Mgmt
  rectangle "Messaging" as Msg
}

rectangle "Repository" as Repo {
  rectangle "Use Case Catalog" as Catalog
  rectangle "Templates" as Templates
  rectangle "Metadata" as Meta
  rectangle "Images" as Imgs
}

rectangle "External Resources" as Ext {
  rectangle "AWS Docs" as Docs
  rectangle "Udemy Courses" as Udemy
  rectangle "Blog Posts" as Blogs
}

Dev --> Repo
SA --> Repo
Ops --> Repo

Repo --> AWS : "References"
Repo --> Ext : "Links to"

Catalog --> Templates : "Uses"
Catalog --> Meta : "Contains"
Catalog --> Imgs : "Includes"

Templates --> Meta : "Defines structure"
@enduml