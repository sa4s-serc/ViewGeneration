@startuml arkaneshiro_Sound-Zone
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<auth>> #fddddd
  Style roundrect
}

package "Frontend (React/Redux)" <<frontend>> {
  [App Component] as App
  [Sound Component] as Sound
  [SoundBar Component] as SoundBar
  [Upload Component] as Upload
  [Auth Components] as Auth
  [Redux Store] as Store

  App --> Sound : manages playback
  App --> SoundBar : persistent player
  App --> Upload : handles uploads
  App --> Auth : auth flow
  Auth --> Store : dispatch actions
  Sound --> Store : state updates
}

package "Backend (Node.js/Express)" <<backend>> {
  [API Routes] as API
  [Auth Controller] as AuthCtrl
  [Sound Controller] as SoundCtrl
  [User Controller] as UserCtrl

  API --> AuthCtrl : /auth
  API --> SoundCtrl : /sounds
  API --> UserCtrl : /users
}

package "Authentication" <<auth>> {
  [JWT] as JWT
  [ProtectedRoute] as Protected
  [AuthRoute] as AuthRoute

  App --> Protected : route guard
  App --> AuthRoute : auth-only routes
  Protected --> JWT : verifies token
}

package "Storage" <<storage>> {
  database "PostgreSQL" as PG
  [Cloudinary] as Cloudinary

  SoundCtrl --> Cloudinary : audio/images
  UserCtrl --> PG : user data
  SoundCtrl --> PG : sound metadata
}

App --> API : HTTP requests
API --> PG : queries
@enduml