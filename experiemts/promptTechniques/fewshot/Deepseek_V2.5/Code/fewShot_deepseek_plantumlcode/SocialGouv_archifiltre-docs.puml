@startuml SocialGouv_archifiltre-docs
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<process>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "User Interface" <<frontend>> {
  rectangle "Electron Renderer\n(React)" as Renderer
  rectangle "Redux/Zustand\nState" as State
  rectangle "i18n\nTranslations" as I18n
  Renderer --> State
  Renderer --> I18n
}

package "Core Processing" <<backend>> {
  rectangle "File System\nLoader" as FSLoader
  rectangle "Metadata\nExtractor" as Metadata
  rectangle "Virtual File\nSystem (VFS)" as VFS
  rectangle "Hash\nCalculator" as Hasher
  rectangle "Duplicate\nDetector" as Duplicates
  FSLoader --> VFS
  FSLoader --> Metadata
  VFS --> Hasher
  VFS --> Duplicates
}

package "Export Services" <<backend>> {
  rectangle "CSV/Excel\nExporter" as CSVExport
  rectangle "RESIP/METS\nExporter" as RESIPExport
  rectangle "JSON\nExporter" as JSONExport
  rectangle "DOCX Report\nGenerator" as ReportGen
  rectangle "Deletion\nScripts" as DeleteScripts
  VFS --> CSVExport
  VFS --> RESIPExport
  VFS --> JSONExport
  VFS --> ReportGen
  VFS --> DeleteScripts
}

package "Async Workers" <<process>> {
  rectangle "Child Process\nController" as ChildProcess
  rectangle "Worker Pool" as Workers
  ChildProcess --> Workers
}

package "Integrations" <<integration>> {
  rectangle "Sentry\nError Logging" as Sentry
  rectangle "Matomo/Posthog\nAnalytics" as Analytics
  rectangle "Electron-Updater" as Updater
  rectangle "Redis\nMessage Queue" as Redis
}

Renderer --> FSLoader
Renderer --> ExportServices
State --> FSLoader
State --> ExportServices

FSLoader --> ChildProcess
Hasher --> ChildProcess
RESIPExport --> ChildProcess

Renderer --> Sentry
Renderer --> Analytics
Renderer --> Updater

ExportServices --> Redis
@enduml