@startuml
skinparam rectangle {
  BackgroundColor<<presentation>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
skinparam linetype ortho
left to right direction

package "Presentation Layer" <<presentation>> {
  [ComposeMainActivity] as Activity
  [Navigation Graph] as NavGraph
  [NotebookScreen] as NotebookUI
  [MemoScreen] as MemoUI
  [AddEditScreen] as AddEditUI
  [DetailScreen] as DetailUI

  Activity --> NavGraph
  NavGraph --> NotebookUI
  NavGraph --> MemoUI
  NavGraph --> AddEditUI
  NavGraph --> DetailUI

  [NotebookViewModel] as NotebookVM
  [MemoViewModel] as MemoVM
  [AddEditViewModel] as AddEditVM
  [DetailViewModel] as DetailVM

  NotebookUI --> NotebookVM
  MemoUI --> MemoVM
  AddEditUI --> AddEditVM
  DetailUI --> DetailVM
}

package "Domain Layer" <<domain>> {
  [GetNotebooksUseCase] as GetNotebooks
  [CreateMemoUseCase] as CreateMemo
  [UpdateMemoUseCase] as UpdateMemo
  [DeleteMemoUseCase] as DeleteMemo

  NotebookVM --> GetNotebooks
  MemoVM --> GetNotebooks
  AddEditVM --> CreateMemo
  AddEditVM --> UpdateMemo
  DetailVM --> DeleteMemo
}

package "Data Layer" <<data>> {
  [NotebookRepository] as NotebookRepo
  [MemoRepository] as MemoRepo

  GetNotebooks --> NotebookRepo
  CreateMemo --> MemoRepo
  UpdateMemo --> MemoRepo
  DeleteMemo --> MemoRepo

  [NotebookDao] as NotebookDao
  [MemoDao] as MemoDao

  NotebookRepo --> NotebookDao
  MemoRepo --> MemoDao
}

package "External" <<external>> {
  database "Room Database" as RoomDB
  NotebookDao --> RoomDB
  MemoDao --> RoomDB

  component "Koin DI" as Koin
  component "Coroutines/Flow" as Coroutines
}

note right of Koin
  Dependency Injection
  throughout all layers
end note

note right of Coroutines
  Async operations and
  state management
end note
@enduml