@startuml anvasquezre_sabiduria_asegurada_experiments
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User"

rectangle "Chainlit UI" as UI #lightblue
rectangle "Langchain Agent" as Agent #lightgreen
rectangle "Qdrant Vector DB" as Qdrant #pink
rectangle "Google Search API" as Google #orange
rectangle "S3 Bucket" as S3 #lightgrey

package "Data Preloader" {
  rectangle "PDF Downloader" as Downloader #palegreen
  rectangle "Text Splitter" as Splitter #palegreen
  rectangle "Embedding Generator" as Embedder #palegreen
}

UI --> Agent : User Query
Agent --> Qdrant : Policy Search
Agent --> Google : Web Search
Agent --> UI : Response

Downloader --> S3 : Fetch PDFs
Splitter --> Downloader : Process PDFs
Embedder --> Splitter : Generate Chunks
Qdrant --> Embedder : Store Embeddings

note right of UI
  Collects user feedback
end note

note left of Agent
  Uses Chain of Responsibility
  for tool selection
end note

note right of Qdrant
  Vector similarity search
  for policy info
end note

note left of Downloader
  Runs as separate microservice
  via Docker Compose
end note
@enduml