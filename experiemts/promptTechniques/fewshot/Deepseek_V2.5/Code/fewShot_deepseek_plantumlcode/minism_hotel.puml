@startuml minism_hotel
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Game Clients" {
  actor "Game Client" as Client
}

package "Master Server" {
  rectangle "REST API" as REST
  rectangle "RPC Server" as RPC
  rectangle "Session Store" as Session
  rectangle "Database (SQLite)" as DB
  rectangle "Reaper" as Reaper
}

package "Spawner" {
  rectangle "RPC Server" as SpawnerRPC
  rectangle "Game Server\nManagement" as GameMgmt
}

package "Shared Libraries" {
  rectangle "Configuration" as Config
  rectangle "Logging" as Logging
  rectangle "Crypto" as Crypto
  rectangle "Protobuf" as Proto
}

Client --> REST : HTTP
REST --> Session
REST --> DB
RPC --> Session
RPC --> DB
Reaper --> Session
Reaper --> DB

SpawnerRPC --> RPC : gRPC
SpawnerRPC --> GameMgmt
GameMgmt --> SpawnerRPC

Config --> REST
Config --> RPC
Config --> SpawnerRPC
Logging --> REST
Logging --> RPC
Logging --> SpawnerRPC
Crypto --> Session
Proto --> RPC
Proto --> SpawnerRPC

note right of DB
  SQLite
end note

note right of GameMgmt
  Executes & monitors
  game server processes
end note
@enduml