@startuml IBM_torc_py
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User Application" as User

rectangle "Master Process (Rank 0)" as Master {
  rectangle "Task Queue" as MasterQueue
  rectangle "Server Thread" as MasterServer
  rectangle "Worker Threads" as MasterWorkers
}

rectangle "Worker Process (Rank 1..N)" as Worker {
  rectangle "Task Queue" as WorkerQueue
  rectangle "Server Thread" as WorkerServer
  rectangle "Worker Threads" as WorkerWorkers
}

rectangle "MPI Communication" as MPI {
}

User --> Master : submit()/map()
Master --> MasterQueue : Enqueue tasks
MasterQueue --> MasterWorkers : Dequeue tasks
MasterWorkers --> MasterServer : Task results
MasterServer --> MPI : Send results

MPI --> WorkerServer : Receive tasks
WorkerServer --> WorkerQueue : Enqueue tasks
WorkerQueue --> WorkerWorkers : Dequeue tasks
WorkerWorkers --> WorkerServer : Task results
WorkerServer --> MPI : Send results

MPI --> MasterServer : Receive results
MasterServer --> User : Return results

WorkerServer <--> MasterServer : Task stealing
@enduml