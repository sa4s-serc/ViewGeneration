@startuml
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<state>> #fff1c9
  BackgroundColor<<ui>> #fddddd
  BackgroundColor<<form>> #ffcccc
  Style roundrect
}
left to right direction

package "Frontend (React)" <<frontend>> {
  rectangle "Main.tsx" as Main
  rectangle "Index.html" as Index
  rectangle "Vite Config" as Vite
  Main --> Index
  Main --> Vite
}

package "Routing" <<frontend>> {
  rectangle "TanStack Router" as Router
  rectangle "RouteTree.gen.ts" as RouteTree
  rectangle "Route Components" as Routes
  Router --> RouteTree
  RouteTree --> Routes
}

package "UI Components" <<ui>> {
  rectangle "Mantine UI" as Mantine
  rectangle "Ant Design Pro" as AntDesign
  rectangle "Custom Components" as Custom
  Mantine --> Custom
  AntDesign --> Custom
}

package "State Management" <<state>> {
  rectangle "MobX Stores" as MobX
  rectangle "TanStack Query" as Query
  rectangle "React Context" as Context
  Query --> MobX
  MobX --> Context
}

package "API Layer" <<api>> {
  rectangle "Axios Instance" as Axios
  rectangle "API Hooks" as Hooks
  rectangle "API Functions" as API
  Axios --> API
  API --> Hooks
}

package "Forms" <<form>> {
  rectangle "React Hook Form" as RHF
  rectangle "Zod Schemas" as Zod
  rectangle "Form Components" as FormComp
  RHF --> FormComp
  Zod --> FormComp
}

Main --> Router
Main --> Mantine
Main --> AntDesign
Main --> MobX
Main --> Query
Main --> RHF

Router --> Routes
Routes --> Custom
Routes --> FormComp

Custom --> Query
Query --> Hooks
Hooks --> API

FormComp --> Zod
FormComp --> Context

Context --> MobX

API --> Axios
Axios --> "APISIX Admin API" as Backend

note right of Backend
  Apache APISIX
end note
@enduml