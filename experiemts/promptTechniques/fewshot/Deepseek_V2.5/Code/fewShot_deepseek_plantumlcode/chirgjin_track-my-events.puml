@startuml
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<gateway>> #d8f5d3
  BackgroundColor<<service>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<messaging>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

actor "User" as User
actor "Client Application" as ClientApp

rectangle "Frontend (React)" <<frontend>> {
  [Dashboard] as Dashboard
  [Login/Register] as AuthUI
}

rectangle "API Gateway" <<gateway>> {
  [Gateway Service] as Gateway
}

rectangle "Backend Services" <<service>> {
  [User Service] as UserService
  [Tracking Service] as TrackingService
}

database "PostgreSQL" <<db>> as Postgres
queue "Redis Pub/Sub" <<messaging>> as Redis

User --> AuthUI
User --> Dashboard
AuthUI --> Gateway : login/register
Dashboard --> Gateway : fetch data

Gateway --> UserService : /users/*
Gateway --> TrackingService : /events/*

ClientApp --> TrackingService : POST /events (SDK)
TrackingService --> Redis : publish events
TrackingService --> Postgres : store events

UserService --> Postgres : user data
TrackingService --> Postgres : event data

Redis <-- TrackingService : subscribe events
@enduml