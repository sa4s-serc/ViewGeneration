@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as user

rectangle "Browser" as browser {
  rectangle "jQuery" as jquery
  rectangle "Bootstrap" as bootstrap
  rectangle "jQuery Validation" as jquery_val
  rectangle "Respond.js" as respond
  rectangle "Modernizr" as modernizr
}

rectangle "Azure AD" as azure_ad

rectangle "ASP.NET MVC App" as mvc_app {
  rectangle "Controllers" as controllers
  rectangle "Models" as models
  rectangle "Views" as views
  rectangle "OWIN Middleware" as owin
}

rectangle "Node.js App" as node_app {
  rectangle "Express" as express
  rectangle "Jade Templates" as jade
}

rectangle "ModSecurity WAF" as waf {
  rectangle "Core Rule Set" as crs
  rectangle "Lua Scripts" as lua
}

rectangle "Azure Resources" as azure {
  rectangle "Load Balancer" as lb
  rectangle "Virtual Machines" as vms
  rectangle "Storage" as storage
  rectangle "VNet" as vnet
}

rectangle "ARM Templates" as arm
rectangle "PowerShell Scripts" as ps

user --> browser
browser --> mvc_app
browser --> node_app

jquery --> jquery_val
bootstrap --> respond
modernizr --> browser

mvc_app --> azure_ad
owin --> azure_ad
controllers --> models
models --> views

node_app --> express
express --> jade

mvc_app --> waf
node_app --> waf

waf --> crs
crs --> lua

waf --> azure
azure --> lb
lb --> vms
vms --> storage
storage --> vnet

arm --> azure
ps --> arm
@enduml