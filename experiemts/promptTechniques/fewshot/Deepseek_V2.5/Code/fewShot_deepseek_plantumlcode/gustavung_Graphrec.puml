@startuml gustavung_Graphrec
left to right direction
skinparam rectangle {
  BackgroundColor<<client>> #d9e7fd
  BackgroundColor<<server>> #d8f5d3
  BackgroundColor<<ml>> #fff1c9
  BackgroundColor<<data>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Mobile Client (Android)" <<client>> {
  rectangle "MainActivity" as MainActivity
  rectangle "CameraActivity" as CameraActivity
  rectangle "ResultActivity" as ResultActivity
  rectangle "ImageUploadTask" as ImageUploadTask
  rectangle "CameraPreview" as CameraPreview
  rectangle "SurfaceOverlay" as SurfaceOverlay

  MainActivity --> CameraActivity
  CameraActivity --> CameraPreview
  CameraActivity --> SurfaceOverlay
  CameraActivity --> ImageUploadTask
  ImageUploadTask --> ResultActivity
}

package "Flask Server" <<server>> {
  rectangle "server.py" as Server
  rectangle "graph_classifier.py" as Classifier
  rectangle "graph_images.py" as GraphImages
  rectangle "generate_data.py" as DataGenerator

  Server --> Classifier
  Classifier --> GraphImages
  DataGenerator --> GraphImages
}

package "Machine Learning" <<ml>> {
  rectangle "CNN Model" as CNN
  rectangle "TensorFlow" as TF

  Classifier --> CNN
  CNN --> TF
}

package "Data" <<data>> {
  rectangle "Synthetic Graph Images" as SynthData
  rectangle "Trained Model" as Model

  DataGenerator --> SynthData
  SynthData --> CNN
  CNN --> Model
}

ImageUploadTask -[#blue]-> Server : HTTP POST
Server -[#blue]-> ImageUploadTask : JSON Response
@enduml