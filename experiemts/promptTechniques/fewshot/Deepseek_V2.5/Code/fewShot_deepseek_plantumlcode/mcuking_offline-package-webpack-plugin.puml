@startuml mcuking_offline-package-webpack-plugin
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "Webpack Build Process" {
  rectangle "Webpack Compiler" as WebpackCompiler
  rectangle "Emit Phase" as EmitPhase
}

rectangle "OfflinePackagePlugin" as Plugin {
  rectangle "Configuration" as Config
  rectangle "File Filtering" as Filter
  rectangle "Zip Generation" as ZipGen
  rectangle "Manifest Generation" as ManifestGen
}

package "Dependencies" {
  rectangle "jszip" as JSZip
  rectangle "mime-types" as MimeTypes
  rectangle "lodash" as Lodash
}

database "Output" {
  rectangle "offline-package.zip" as ZipOutput
  rectangle "index.json" as JsonOutput
}

WebpackCompiler --> EmitPhase
EmitPhase --> Plugin : triggers
Plugin --> Config : reads
Plugin --> Filter : applies
Filter --> ZipGen : filtered files
ZipGen --> JSZip : uses
ZipGen --> ZipOutput : creates
Plugin --> ManifestGen : generates
ManifestGen --> MimeTypes : uses
ManifestGen --> Lodash : uses
ManifestGen --> JsonOutput : creates
@enduml