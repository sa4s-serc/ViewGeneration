@startuml IBMDeveloperMEA_YPDL-Recurrent-Neural-Networks-using-TensorFlow-Keras
skinparam backgroundColor #ffffff
skinparam defaultTextAlignment center
left to right direction

actor "User" as User

rectangle "Jupyter Notebook" as Notebook {
    rectangle "Data Preprocessing" as Preprocess
    rectangle "Model Definition" as ModelDef
    rectangle "Training Loop" as Train
    rectangle "Evaluation" as Eval
    rectangle "Visualization" as Viz
}

rectangle "TensorFlow Keras" as TF {
    rectangle "Embedding Layer" as Embed
    rectangle "LSTM Layer(s)" as LSTM
    rectangle "Dense Layer" as Dense
}

database "Penn Treebank Dataset" as PTB

rectangle "Output" as Output {
    rectangle "Trained Model" as TrainedModel
    rectangle "Metrics" as Metrics
    rectangle "Plots" as Plots
}

User --> Notebook
Notebook --> PTB : Loads data
Preprocess --> PTB : Reads & processes
ModelDef --> Embed : Defines
ModelDef --> LSTM : Defines
ModelDef --> Dense : Defines
Train --> TF : Trains model
Eval --> TF : Evaluates model
Viz --> Output : Generates
Train --> Output : Saves
Eval --> Output : Stores
Viz --> Plots : Creates
@enduml