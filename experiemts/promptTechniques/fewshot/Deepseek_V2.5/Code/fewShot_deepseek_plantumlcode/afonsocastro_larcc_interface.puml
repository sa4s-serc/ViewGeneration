@startuml
skinparam rectangle {
  BackgroundColor<<ros>> #d9e7fd
  BackgroundColor<<robot>> #d8f5d3
  BackgroundColor<<sensor>> #fff1c9
  BackgroundColor<<sim>> #fddddd
  BackgroundColor<<control>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "ROS Ecosystem" <<ros>> {
  rectangle "ROS Core" as ROS
  rectangle "MoveIt!" as MoveIt
  rectangle "RViz" as RViz
  rectangle "UR Robot Driver" as URDriver
  rectangle "RealSense ROS" as RealsenseROS
}

package "Robot System" <<robot>> {
  rectangle "UR10e Arm" as UR10e
  rectangle "ROBOTIQ 2F-140 Gripper" as Gripper
  rectangle "URCap Interface" as URCap
}

package "Sensors" <<sensor>> {
  rectangle "RealSense Camera" as Realsense
}

package "Simulation/Visualization" <<sim>> {
  rectangle "URDF/Xacro Models" as URDF
  rectangle "3D Models (.DAE)" as DAE
}

package "Control & Kinematics" <<control>> {
  rectangle "ur_kinematics" as Kinematics
  rectangle "IK/FK Solvers" as Solvers
  rectangle "Boost.Python Wrapper" as Boost
}

ROS --> MoveIt
MoveIt --> URDriver
URDriver --> URCap
URCap --> UR10e
UR10e --> Gripper
Realsense --> RealsenseROS
RealsenseROS --> ROS
URDF --> RViz
DAE --> URDF
Kinematics --> Solvers
Solvers --> Boost
Boost --> MoveIt
MoveIt --> RViz
@enduml