@startuml kryptokrauts_ae-prediction-cards
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (React)" as Frontend {
  rectangle "Wallet Client" as WalletClient
  rectangle "PredictionCards API" as PredictionAPI
  rectangle "State Management" as State
}

rectangle "Aeternity Blockchain" as Blockchain {
  rectangle "PredictionCards\nSmart Contract" as Contract
  rectangle "Oracle" as Oracle
}

rectangle "Backend Services" as Backend {
  rectangle "Process Prediction\nService" as PredictionService
  rectangle "Oracle Service" as OracleService
}

rectangle "External Services" as External {
  rectangle "CoinGecko API" as CoinGecko
  rectangle "IPFS" as IPFS
}

' Frontend connections
User --> Frontend
Frontend --> WalletClient
Frontend --> PredictionAPI
PredictionAPI --> Contract
WalletClient --> Blockchain
State --> WalletClient

' Backend services
PredictionService --> Contract : poll for CLOSED predictions
PredictionService --> OracleService : trigger oracle query
OracleService --> Oracle : register/extend oracle
OracleService --> CoinGecko : fetch price data
OracleService --> Oracle : respond to query
Oracle --> Contract : process_oracle_response

' External services
Frontend --> IPFS : load NFT images
Contract --> IPFS : store NFT metadata

note right of OracleService
  Periodically extends oracle TTL
end note

note right of PredictionService
  Monitors blockchain for\nCLOSED predictions
end note
@enduml