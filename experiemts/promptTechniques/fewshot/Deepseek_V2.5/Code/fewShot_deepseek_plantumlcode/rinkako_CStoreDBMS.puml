@startuml rinkako_CStoreDBMS
left to right direction
skinparam rectangle {
  BackgroundColor<<interface>> #d9e7fd
  BackgroundColor<<compiler>> #d8f5d3
  BackgroundColor<<engine>> #fff1c9
  BackgroundColor<<storage>> #fddddd
  Style roundrect
}

package "DBInterface Layer" <<interface>> {
  [DBController] as Controller
  [DBConnectionPool] as ConnectionPool
  [DBBridge] as Bridge
  Controller --> ConnectionPool
  ConnectionPool --> Bridge
}

package "DBCompiler Layer" <<compiler>> {
  [LexicalAnalyzer] as Lexer
  [ISyntaxParser] as Parser
  [Pile] as IntermediateCode
  [CSDatabase] as Engine
  Lexer --> Parser
  Parser --> IntermediateCode
  IntermediateCode --> Engine
  Bridge --> Engine
}

package "DBEngine Layer" <<engine>> {
  [FileManager] as FileMgr
  [TableManager] as TableMgr
  [DBAllocator] as Allocator
  [DBLock] as LockMgr
  [DBTransaction] as TransactionMgr
  Engine --> FileMgr
  Engine --> TableMgr
  Engine --> Allocator
  Engine --> LockMgr
  Engine --> TransactionMgr
}

package "Storage Layer" <<storage>> {
  [Columnar Storage] as ColumnStore
  [RLE Compression] as Compression
  [External Sort] as Sort
  FileMgr --> ColumnStore
  FileMgr --> Compression
  FileMgr --> Sort
}

note right of ColumnStore
  Implements C-Store principles:
  - Column-oriented storage
  - Optimized for analytics
end note
@enduml