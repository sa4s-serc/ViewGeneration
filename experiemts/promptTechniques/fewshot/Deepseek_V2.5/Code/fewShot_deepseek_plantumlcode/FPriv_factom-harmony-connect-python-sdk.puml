@startuml FPriv_factom-harmony-connect-python-sdk
left to right direction
skinparam rectangle {
  BackgroundColor<<client>> #d9e7fd
  BackgroundColor<<utility>> #d8f5d3
  BackgroundColor<<handler>> #fff1c9
  BackgroundColor<<api>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "SDK Clients" <<client>> {
  [FactomClient] as FactomClient
  [ChainsClient] as ChainsClient
  [EntriesClient] as EntriesClient
  [IdentitiesClient] as IdentitiesClient
  [ApiInfoClient] as ApiInfoClient
  [ReceiptsClient] as ReceiptsClient
  [AnchorsClient] as AnchorsClient

  FactomClient --> ChainsClient
  FactomClient --> EntriesClient
  FactomClient --> IdentitiesClient
  FactomClient --> ApiInfoClient
  FactomClient --> ReceiptsClient
  FactomClient --> AnchorsClient
}

package "Utilities" <<utility>> {
  [Utils] as Utils
  [KeyCommon] as KeyCommon
  [ValidateSignatureUtil] as ValidateSig
  [CommonUtil] as CommonUtil

  ChainsClient --> ValidateSig
  EntriesClient --> ValidateSig
  ChainsClient --> CommonUtil
  EntriesClient --> CommonUtil
  IdentitiesClient --> KeyCommon
}

package "Request Handler" <<handler>> {
  [RequestHandler] as RequestHandler
}

package "Factom Harmony Connect API" <<api>> {
  [Factom API] as FactomAPI
}

FactomClient --> RequestHandler
RequestHandler --> FactomAPI

package "Sample Application" {
  [NotaryService] as NotaryService
}

NotaryService --> FactomClient
NotaryService --> KeyCommon
@enduml