@startuml Crazy0416_KnowledgeGraph
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as User

rectangle "Frontend" {
  rectangle "Materialize CSS" as Materialize
  rectangle "Redux" as Redux
  rectangle "Flatpickr" as Flatpickr
  rectangle "Sigma.js" as Sigma
}

rectangle "Knowledge Graph App" {
  rectangle "Graph Controller" as Controller
  rectangle "Graph Model" as Model
  rectangle "Graph Helpers" as Helpers
  rectangle "Routes" as Routes
}

rectangle "Backend Services" {
  rectangle "Elasticsearch" as Elasticsearch
  rectangle "CayleyGraph" as CayleyGraph
}

rectangle "Algorithms" {
  rectangle "A* Pathfinding" as AStar
  rectangle "Noverlap Layout" as Noverlap
  rectangle "ForceAtlas2" as ForceAtlas2
}

User --> Materialize
User --> Flatpickr
User --> Sigma

Materialize --> Redux
Sigma --> Controller

Controller --> Model
Controller --> Helpers
Controller --> Routes
Model --> Elasticsearch
Model --> CayleyGraph

Helpers --> AStar
Helpers --> Noverlap
Helpers --> ForceAtlas2

Routes --> Elasticsearch
Routes --> CayleyGraph

Redux --> Controller
@enduml