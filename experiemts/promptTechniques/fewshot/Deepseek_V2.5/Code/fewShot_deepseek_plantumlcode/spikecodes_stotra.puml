@startuml spikecodes_stotra
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "UI Components" as UI
  rectangle "Pages" as Pages
  rectangle "Services" as FrontendServices
  rectangle "State Management" as State
  UI --> Pages
  Pages --> FrontendServices
  FrontendServices --> State
}

package "Backend (Node.js/Express)" <<backend>> {
  rectangle "API Routes" as Routes
  rectangle "Controllers" as Controllers
  rectangle "Middleware" as Middleware
  rectangle "Services" as BackendServices
  rectangle "Utils" as Utils
  Routes --> Controllers
  Controllers --> Middleware
  Controllers --> BackendServices
  BackendServices --> Utils
}

package "External Services" <<external>> {
  rectangle "Yahoo Finance API" as Yahoo
  rectangle "Alpha Vantage API" as Alpha
  rectangle "News API" as News
  rectangle "Cloudflare Turnstile" as Cloudflare
}

package "Database" <<db>> {
  database "MongoDB Atlas" as MongoDB
}

package "Infrastructure" <<infra>> {
  rectangle "AWS Amplify" as Amplify
  rectangle "AWS EC2" as EC2
}

FrontendServices --> Routes : REST API
Routes --> Controllers
Controllers --> BackendServices
BackendServices --> Yahoo : Fetch stock data
BackendServices --> Alpha : Fetch stock data
BackendServices --> News : Fetch news
BackendServices --> Cloudflare : Verify captcha
BackendServices --> MongoDB : CRUD operations

UI --> Amplify : Hosting
Controllers --> EC2 : Deployment
@enduml