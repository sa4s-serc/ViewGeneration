@startuml madderle_Capstone-Realtime-Streaming-Analytics
skinparam rectangle {
  BackgroundColor<<ingestion>> #d9e7fd
  BackgroundColor<<processing>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<analysis>> #fddddd
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}
left to right direction

package "Data Ingestion" <<ingestion>> {
  rectangle "Twitter API" as Twitter
  rectangle "IEX API" as IEX
  component "Twitter Service" as TwitterService
  component "IEX Service" as IEXService
  component "Manager Service" as Manager
  Twitter --> TwitterService
  IEX --> IEXService
  TwitterService --> Manager
  IEXService --> Manager
}

package "Data Processing" <<processing>> {
  component "Data Service" as DataService
  Manager --> DataService
}

package "Data Storage" <<storage>> {
  database "MongoDB" as MongoDB
  database "Redis" as Redis
  database "S3" as S3
  DataService --> MongoDB
  Manager --> Redis
}

package "Data Analysis" <<analysis>> {
  component "Model Development" as ModelDev
  component "Model Deployment" as ModelDeploy
  component "EDA Notebooks" as EDA
  MongoDB --> ModelDev
  ModelDev --> S3
  S3 --> ModelDeploy
  MongoDB --> EDA
}

package "Infrastructure" <<infra>> {
  component "AWS Kinesis" as Kinesis
  component "Docker" as Docker
  component "Docker Compose" as Compose
  TwitterService --> Kinesis
  IEXService --> Kinesis
  Kinesis --> DataService
}

note right of Redis: Used for:\n- Pub/Sub communication\n- Feature flags\n- Market status
note right of S3: Stores:\n- Serialized models\n- Model versions
note left of Manager: Controls:\n- Data ingestion\n- Feature flags\n- Market hours
@enduml