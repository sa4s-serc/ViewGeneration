@startuml marklogic_cloud-enablement-aws
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "AWS Infrastructure" {
  rectangle "CloudFormation\nTemplates" as CFN #orange
  rectangle "VPC" as VPC #orange
  rectangle "Subnets" as Subnets #orange
  rectangle "Security Groups" as SGs #orange
  rectangle "IAM Roles" as IAM #orange
  rectangle "Auto Scaling Groups" as ASG #orange
  rectangle "ALB" as ALB #orange
  rectangle "EC2 Instances" as EC2 #orange
  rectangle "EBS Volumes" as EBS #orange
}

package "MarkLogic Cluster" {
  rectangle "MarkLogic Nodes" as MLNodes #lightblue
  rectangle "DynamoDB\nCluster State" as DDB #lightblue
}

package "Lambda Functions" {
  rectangle "managedeni.py" as ENI #green
  rectangle "nodemanager.py" as NodeMgr #green
  rectangle "utils.py" as Utils #green
}

CFN --> VPC
CFN --> Subnets
CFN --> SGs
CFN --> IAM
CFN --> ASG
CFN --> ALB
CFN --> EC2
CFN --> EBS

ASG --> EC2
ALB --> EC2
EC2 --> MLNodes
EC2 --> EBS

ENI --> EC2 : Manages ENIs
NodeMgr --> ASG : Handles lifecycle
NodeMgr --> ENI
NodeMgr --> DDB : Updates state
Utils --> ENI
Utils --> NodeMgr

MLNodes --> DDB : Cluster coordination

note right of CFN
  mlcluster.template\nmlcluster-vpc.template
end note

note right of ENI
  templates/ml-managedeni.template
end note

note right of NodeMgr
  templates/ml-nodemanager.template
end note
@enduml