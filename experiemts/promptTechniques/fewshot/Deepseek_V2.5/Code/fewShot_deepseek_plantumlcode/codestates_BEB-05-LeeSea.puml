@startuml codestates_BEB-05-LeeSea
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<contract>> #d8f5d3
  BackgroundColor<<blockchain>> #fff1c9
  BackgroundColor<<redux>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "UI Components" as UI
  rectangle "Web3.js" as Web3
  rectangle "Wallet Connection" as Wallet
  UI --> Web3
  Web3 --> Wallet
}

package "Redux State" <<redux>> {
  rectangle "Account Slice" as Account
  rectangle "Token Slice" as Token
  rectangle "Async Thunks" as Thunks
  UI --> Account
  UI --> Token
  Thunks --> Web3
}

package "Smart Contracts" <<contract>> {
  rectangle "LeeSeaNFT" as NFT
  rectangle "LeeSeaMarket" as Market
  rectangle "Utility Yul" as Yul
  NFT --> Yul
  Market --> Yul
}

package "Blockchain" <<blockchain>> {
  rectangle "Ethereum Network" as Eth
  rectangle "MetaMask" as MM
  Web3 --> MM
  MM --> Eth
  NFT --> Eth
  Market --> Eth
}

package "External" {
  rectangle "IPFS" as IPFS
  NFT --> IPFS
  Market --> IPFS
}

@enduml