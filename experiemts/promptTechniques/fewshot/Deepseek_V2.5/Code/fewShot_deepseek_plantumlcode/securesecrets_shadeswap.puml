@startuml securesecrets_shadeswap
left to right direction
skinparam rectangle {
  BackgroundColor<<contract>> #d9e7fd
  BackgroundColor<<shared>> #d8f5d3
  BackgroundColor<<test>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Contracts" <<contract>> {
  [LP Token\n(SNIP-20)] as LPToken
  [Staking] as Staking
  [AMM Pair] as AMMPair
  [Factory] as Factory
  [Router] as Router
  [Admin] as Admin
}

package "Shared Utilities" <<shared>> {
  [shadeswap-shared] as Shared
}

package "Testing" <<test>> {
  [multi_test] as MultiTest
  [network_integration] as NetworkTest
}

package "External" <<external>> {
  [secret-toolkit] as SecretToolkit
  [Secret Network] as SecretNetwork
}

LPToken --> Shared
Staking --> Shared
AMMPair --> Shared
Factory --> Shared
Router --> Shared
Admin --> Shared

Factory --> AMMPair : creates
Factory --> LPToken : creates
Router --> AMMPair : interacts
Staking --> LPToken : stakes

Admin --> LPToken : manages
Admin --> Staking : manages
Admin --> AMMPair : manages
Admin --> Factory : manages
Admin --> Router : manages

MultiTest --> LPToken : tests
MultiTest --> Staking : tests
NetworkTest --> LPToken : tests
NetworkTest --> Staking : tests

LPToken --> SecretToolkit
Staking --> SecretToolkit
AMMPair --> SecretToolkit
Factory --> SecretToolkit
Router --> SecretToolkit

LPToken --> SecretNetwork
Staking --> SecretNetwork
AMMPair --> SecretNetwork
Factory --> SecretNetwork
Router --> SecretNetwork
Admin --> SecretNetwork
@enduml