@startuml aws-solutions_automated-security-response-on-aws
skinparam rectangle {
  BackgroundColor<<event>> #FFF2CC
  BackgroundColor<<orchestration>> #D5E8D4
  BackgroundColor<<remediation>> #F8CECC
  BackgroundColor<<monitoring>> #DAE8FC
  BackgroundColor<<integration>> #E1D5E7
}

left to right direction

rectangle "AWS Security Hub" as SecurityHub <<event>> {
  component "Security Findings"
  component "Custom Actions"
}

rectangle "EventBridge" as EventBridge <<orchestration>> {
  component "Rules"
}

rectangle "Step Functions" as StepFunctions <<orchestration>> {
  component "Orchestrator"
}

rectangle "SSM Automation" as SSM <<remediation>> {
  component "Runbooks"
  component "Documents"
}

rectangle "Lambda" as Lambda <<remediation>> {
  component "Remediation Logic"
  component "Custom Resources"
}

rectangle "CloudWatch" as CloudWatch <<monitoring>> {
  component "Logs"
  component "Metrics"
  component "Alarms"
}

rectangle "External Systems" as External <<integration>> {
  component "Ticketing (Jira/ServiceNow)"
  component "SIEM"
}

database "IAM Roles/Policies" as IAM

SecurityHub --> EventBridge : "Findings Events"
EventBridge --> StepFunctions : "Triggers Remediation"
StepFunctions --> SSM : "Executes Runbook"
SSM --> Lambda : "Calls Remediation"
Lambda --> IAM : "Assumes Role"
Lambda --> SecurityHub : "Updates Findings"
SSM --> CloudWatch : "Sends Metrics"
CloudWatch --> External : "Alerts/Notifications"
StepFunctions --> External : "Creates Tickets"

note right of SecurityHub
  Detects security issues
  across AWS accounts
end note

note right of SSM
  Predefined remediation playbooks
  for CIS, PCI DSS, NIST, etc.
end note

note left of Lambda
  Custom logic for complex
  remediation scenarios
end note

note bottom of CloudWatch
  Centralized logging and
  performance monitoring
end note
@enduml