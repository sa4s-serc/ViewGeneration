@startuml llvm_torch-mlir
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<dialect>> #d8f5d3
  BackgroundColor<<backend>> #fddddd
  BackgroundColor<<tooling>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontends" <<frontend>> {
  rectangle "PyTorch (Python)"
  rectangle "TorchScript"
  rectangle "FX Graph"
  rectangle "ONNX"
}

package "Torch-MLIR Core" {
  rectangle "Torch Dialect" <<dialect>> {
    rectangle "Value Tensors"
    rectangle "Non-Value Tensors"
    rectangle "Shape/Dtype Ops"
  }
  
  rectangle "TMTensor Dialect" <<dialect>>
  rectangle "TorchConversion Dialect" <<dialect>>
  
  rectangle "Pass Pipeline" {
    rectangle "Reify Shape/Dtype"
    rectangle "Adjust Calling Conventions"
    rectangle "Globalize Object Graph"
    rectangle "Lower to Backend Contract"
  }
}

package "Backends" <<backend>> {
  rectangle "Linalg-on-Tensors"
  rectangle "TOSA"
  rectangle "StableHLO"
  rectangle "Lazy Tensor Core"
}

package "Tooling & Testing" <<tooling>> {
  rectangle "TableGen"
  rectangle "Python Bindings"
  rectangle "C-API"
  rectangle "E2E Tests"
  rectangle "LIT Tests"
}

"PyTorch (Python)" --> "Torch Dialect"
"TorchScript" --> "Torch Dialect"
"FX Graph" --> "Torch Dialect"
"ONNX" --> "Torch Dialect"

"Torch Dialect" --> "Pass Pipeline"
"Pass Pipeline" --> "TMTensor Dialect"
"Pass Pipeline" --> "TorchConversion Dialect"

"TMTensor Dialect" --> "Linalg-on-Tensors"
"TorchConversion Dialect" --> "TOSA"
"TorchConversion Dialect" --> "StableHLO"
"Torch Dialect" --> "Lazy Tensor Core"

"TableGen" --> "Torch Dialect"
"TableGen" --> "TMTensor Dialect"
"Python Bindings" --> "Torch Dialect"
"C-API" --> "Torch Dialect"

"E2E Tests" --> "Torch Dialect"
"E2E Tests" --> "Backends"
"LIT Tests" --> "Pass Pipeline"
@enduml