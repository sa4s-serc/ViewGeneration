@startuml mbotarro_unijobs
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React Native)" <<frontend>> {
  rectangle "App.js" as App
  rectangle "Navigation" as Navigation
  rectangle "Screens" as Screens
  rectangle "Components" as Components
  rectangle "Actions" as Actions
  
  App --> Navigation
  Navigation --> Screens
  Screens --> Components
  Screens --> Actions
}

package "Backend (Go)" <<backend>> {
  rectangle "Handlers" as Handlers
  rectangle "Use Cases" as UseCases
  rectangle "DAL" as DAL
  rectangle "Models" as Models
  
  Handlers --> UseCases
  UseCases --> DAL
  DAL --> Models
}

package "Integrations" <<integration>> {
  rectangle "Elasticsearch" as Elasticsearch
  rectangle "Social Logins" as SocialLogins
}

database "PostgreSQL" <<db>> as Postgres

Actions --> Handlers : REST API
Handlers --> Postgres
DAL --> Postgres
UseCases --> Elasticsearch : Search
Components --> SocialLogins : Auth
@enduml