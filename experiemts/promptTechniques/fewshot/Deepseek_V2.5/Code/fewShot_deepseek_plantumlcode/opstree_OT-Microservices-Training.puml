@startuml
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<gateway>> #d8f5d3
  BackgroundColor<<service>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<proxy>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

actor "User" as user

rectangle "Frontend (ReactJS)" <<frontend>> as frontend
rectangle "Webserver (Nginx)" <<proxy>> as nginx
rectangle "API Gateway (Spring Boot)" <<gateway>> as gateway

package "Microservices" {
  rectangle "Attendance Service (Golang)" <<service>> as attendance
  rectangle "Employee Service (Golang)" <<service>> as employee
  rectangle "Salary Service (Golang)" <<service>> as salary
  rectangle "Notification Service (Python)" <<service>> as notification
}

package "Databases" {
  database "MySQL" <<db>> as mysql
  database "Elasticsearch" <<db>> as elasticsearch
}

user --> nginx
nginx --> frontend
frontend --> gateway

gateway --> attendance
gateway --> employee
gateway --> salary
gateway --> notification

attendance --> mysql
employee --> elasticsearch
salary --> elasticsearch
notification --> elasticsearch

notification --> notification : "Send Email Notifications"
@enduml