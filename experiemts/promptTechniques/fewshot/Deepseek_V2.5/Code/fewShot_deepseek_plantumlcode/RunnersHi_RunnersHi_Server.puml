@startuml
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<database>> #fff1c9
  BackgroundColor<<realtime>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

left to right direction

actor "Mobile Client" as Client

package "Frontend" <<frontend>> {
  rectangle "UI Components" as UI
  rectangle "API Client" as APIClient
  rectangle "Socket.IO Client" as SocketClient
}

package "Backend" <<backend>> {
  rectangle "Express Server" as Express
  rectangle "Routes" as Routes
  rectangle "Controllers" as Controllers
  rectangle "Models" as Models
  rectangle "Middleware" as Middleware
}

package "Real-time" <<realtime>> {
  rectangle "Socket.IO Server" as SocketServer
  rectangle "Matching Algorithm" as Matching
}

database "MySQL" <<database>> as MySQL

Client --> APIClient
Client --> SocketClient

APIClient --> Express
Express --> Routes
Routes --> Controllers
Controllers --> Models
Models --> MySQL

SocketClient --> SocketServer
SocketServer --> Matching
Matching --> Models

Middleware --> Express
Middleware --> Controllers
Middleware --> Models

Models --> MySQL
Controllers --> SocketServer

note right of SocketServer
  Real-time matching\nand run tracking
end note

note right of Models
  User, Record,\nRanking, Matching data
end note

note right of Middleware
  Auth, Error Handling,\nResponse Formatting
end note
@enduml