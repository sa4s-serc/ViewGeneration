@startuml hotshot07_distributed_systems
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<infra>> #fff1c9
  BackgroundColor<<db>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  [React UI] as Frontend
}

package "Backend Services" <<backend>> {
  [Auth Service] as Auth
  [Account Service] as Account
  [Athlete Service] as Athlete
  [Test Service] as Test
}

package "Infrastructure" <<infra>> {
  [Kubernetes Cluster] as K8s
  [Docker Registry] as Docker
  [GitHub Actions] as CI
}

package "Data Storage" <<db>> {
  [DynamoDB] as DB
}

Frontend --> Auth : JWT Auth
Frontend --> Account : HTTP
Frontend --> Athlete : HTTP
Frontend --> Test : HTTP

Auth --> DB
Account --> DB
Athlete --> DB
Test --> DB

CI --> Docker : Build/Push
Docker --> K8s : Deploy
K8s --> Auth : Hosts
K8s --> Account : Hosts
K8s --> Athlete : Hosts
K8s --> Test : Hosts

note right of K8s
  Service Discovery
  Load Balancing
  Auto-scaling
end note
@enduml