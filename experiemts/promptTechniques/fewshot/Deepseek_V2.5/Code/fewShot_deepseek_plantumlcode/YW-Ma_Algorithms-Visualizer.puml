### Actual Output:
@startuml YW-Ma_Algorithms-Visualizer
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

package "Frontend (React)" <<frontend>> {
  rectangle "MainInterface" as MainInterface
  rectangle "Sidebar" as Sidebar
  rectangle "GraphSVG" as GraphSVG
  rectangle "GraphTable" as GraphTable
  rectangle "Map (BMap API)" as Map
  rectangle "eventProxy" as EventProxy

  MainInterface --> Sidebar
  MainInterface --> GraphSVG
  MainInterface --> GraphTable
  MainInterface --> Map
  Sidebar -[hidden]-> GraphSVG
  GraphSVG --> EventProxy
  GraphTable --> EventProxy
}

package "Backend (Node.js)" <<backend>> {
  rectangle "API Routes" as APIRoutes
  rectangle "Algorithm Executor" as AlgoExecutor
  rectangle "Cluster Manager" as ClusterManager

  APIRoutes --> AlgoExecutor
  AlgoExecutor --> ClusterManager
}

package "External Services" <<external>> {
  rectangle "C++ Executables" as CppExec
  rectangle "Baidu Maps API" as BaiduAPI
}

database "MySQL" <<db>> as MySQL

User --> MainInterface
MainInterface --> APIRoutes
APIRoutes --> MySQL
AlgoExecutor --> CppExec
Map --> BaiduAPI
@enduml