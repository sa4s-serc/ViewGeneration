@startuml meshery_meshery
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<adapter>> #fddddd
  BackgroundColor<<k8s>> #f0e6ff
  BackgroundColor<<cli>> #ffd8d8
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "Meshery UI\n(React/Next.js)" as UI
  rectangle "MeshMap" as MeshMap
  rectangle "Performance\nTesting" as PerfTest
  rectangle "Notification\nCenter" as NotifCenter
}

package "Backend" <<backend>> {
  rectangle "Meshery Server" as Server
  rectangle "GraphQL API" as GraphQL
  rectangle "REST API" as REST
  rectangle "Provider\nArchitecture" as Provider
}

package "Adapters" <<adapter>> {
  rectangle "Istio" as Istio
  rectangle "Linkerd" as Linkerd
  rectangle "Consul" as Consul
  rectangle "Kuma" as Kuma
  rectangle "AWS App Mesh" as AWS
  rectangle "NGINX SM" as NGINX
}

package "Kubernetes" <<k8s>> {
  rectangle "Meshery Operator" as Operator
  rectangle "MeshSync" as MeshSync
  rectangle "NATS Broker" as NATS
}

package "CLI" <<cli>> {
  rectangle "mesheryctl" as CLI
}

package "Data" <<data>> {
  rectangle "Local Provider" as Local
  rectangle "Remote Providers" as Remote
  database "Database" as DB
}

' Frontend connections
UI --> GraphQL
UI --> REST
UI --> MeshMap
UI --> PerfTest
UI --> NotifCenter

' Backend connections
Server --> GraphQL
Server --> REST
Server --> Provider
Server --> Operator
Server --> NATS

' Adapter connections
Server --> Istio : gRPC
Server --> Linkerd : gRPC
Server --> Consul : gRPC
Server --> Kuma : gRPC
Server --> AWS : gRPC
Server --> NGINX : gRPC

' Kubernetes connections
Operator --> MeshSync
MeshSync --> NATS

' CLI connections
CLI --> Server

' Data connections
Provider --> Local
Provider --> Remote
Local --> DB
Remote --> DB
@enduml