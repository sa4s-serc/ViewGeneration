@startuml coverage-robot_core
skinparam rectangle {
  BackgroundColor<<api>> #d9e7fd
  BackgroundColor<<orchestrator>> #d8f5d3
  BackgroundColor<<analyse>> #fff1c9
  BackgroundColor<<publish>> #fddddd
  BackgroundColor<<storage>> #d4f0f0
  BackgroundColor<<external>> #e6e6fa
}

left to right direction

actor "Developer" as dev
actor "GitHub" as github

rectangle "API Service" <<api>> {
  [Webhook Handler]
  [Badge Generator]
  [Upload Handler]
}

rectangle "Orchestrator Service" <<orchestrator>> {
  [Event Processor]
  [Event Store]
}

rectangle "Analyse Service" <<analyse>> {
  [Coverage Analyser]
  [Report Generator]
}

rectangle "Publish Service" <<publish>> {
  [GitHub Publisher]
}

rectangle "Storage" <<storage>> {
  database "DynamoDB\n(Config/Events)" as dynamo
  database "S3\n(Raw Reports)" as s3
  database "BigQuery\n(Aggregated Data)" as bigquery
}

rectangle "External Services" <<external>> {
  [AWS EventBridge] as eventbridge
  [AWS Cognito] as cognito
}

dev --> [Upload Handler] : Uploads\ncoverage report
[Upload Handler] --> s3 : Stores raw data
[Upload Handler] --> dynamo : Records event

github --> [Webhook Handler] : Sends\nwebhook
[Webhook Handler] --> eventbridge : Publishes event

eventbridge --> [Event Processor] : Triggers\nprocessing
[Event Processor] --> [Coverage Analyser] : Requests analysis
[Coverage Analyser] --> s3 : Gets raw data
[Coverage Analyser] --> bigquery : Queries history
[Coverage Analyser] --> [Report Generator] : Generates report
[Report Generator] --> dynamo : Stores results
[Report Generator] --> [GitHub Publisher] : Sends report
[GitHub Publisher] --> github : Posts comment

[Badge Generator] --> dynamo : Reads coverage data
[Badge Generator] --> dev : Returns SVG badge

[Event Processor] --> [Event Store] : Records state
[Event Store] --> dynamo : Persists events

[Webhook Handler] --> cognito : Validates auth
[Upload Handler] --> cognito : Validates auth
@enduml