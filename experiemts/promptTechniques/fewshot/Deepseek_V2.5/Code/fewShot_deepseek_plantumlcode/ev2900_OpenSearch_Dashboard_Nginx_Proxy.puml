@startuml ev2900_OpenSearch_Dashboard_Nginx_Proxy
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Public Internet" {
  actor "User"
}

package "AWS VPC" {
  rectangle "Public Subnet" as publicSubnet {
    rectangle "Nginx Proxy\n(EC2 Instance)" as nginx #orange
    rectangle "Elastic IP" as eip #lightblue
  }

  rectangle "Private Subnet" as privateSubnet {
    rectangle "OpenSearch\nDashboard" as opensearch #lightgreen
  }

  rectangle "Security Groups" as sg #pink
  rectangle "Internet Gateway" as igw #lightblue
}

package "AWS Services" {
  rectangle "CloudFormation" as cf #lightblue
  rectangle "IAM Role" as iam #lightblue
}

User --> eip
eip --> nginx
nginx --> opensearch

cf --> iam
cf --> publicSubnet
cf --> privateSubnet
cf --> igw
cf --> sg

igw --> publicSubnet

sg --> nginx
sg --> opensearch

note right of nginx
  Reverse Proxy
  SSL/TLS Termination
end note

note right of opensearch
  Private Access Only
end note
@enduml