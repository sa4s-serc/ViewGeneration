@startuml shawntabrizi_Ethereum-Twitter-Bounty
left to right direction
skinparam rectangle {
  BackgroundColor<<contract>> #d8f5d3
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<infra>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}

package "User Interface" <<ui>> {
  [HTML/CSS/JS Frontend] as Frontend
  [web3.js] as Web3JS
  [TruffleContract] as TruffleContract
}

package "Smart Contracts" <<contract>> {
  [TwitterBounty.sol] as TwitterBounty
  [TwitterOracle.sol] as TwitterOracle
  [OpenZeppelin\nOwnable/Pausable] as OZ
}

package "Blockchain" <<infra>> {
  [Ethereum Network] as Ethereum
  [Ganache (local)] as Ganache
}

package "External Services" <<external>> {
  [Provable Oracle] as Provable
  [Twitter API] as TwitterAPI
}

Frontend --> Web3JS
Web3JS --> TruffleContract
TruffleContract --> TwitterBounty
TruffleContract --> TwitterOracle

TwitterBounty --> TwitterOracle
TwitterOracle --> Provable
Provable --> TwitterAPI

TwitterBounty --> OZ
TwitterOracle --> OZ

Web3JS --> Ethereum
Web3JS --> Ganache

note right of TwitterBounty
  Manages bounty lifecycle:
  - create/contribute
  - fulfill/close
  - verify tweets
end note

note right of TwitterOracle
  Fetches tweet content
  via oracle service
end note

note right of Provable
  Formerly Oraclize
end note
@enduml