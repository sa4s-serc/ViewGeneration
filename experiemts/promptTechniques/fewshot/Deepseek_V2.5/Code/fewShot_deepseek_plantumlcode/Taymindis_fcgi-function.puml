@startuml Taymindis_fcgi-function
left to right direction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

package "Web Server" {
  rectangle "Nginx/Apache" as WebServer
}

package "FastCGI Server" {
  rectangle "fcgiapp Library" as FCGI
  rectangle "ffunc.c" as FFuncCore
  rectangle "ffunc.h" as FFuncAPI
}

package "Application Logic" {
  rectangle "User-Defined\nFunction Handlers" as Handlers
  rectangle "profile_service.c" as Example
}

package "Configuration" {
  rectangle "ffunc_config_t" as Config
  rectangle "Environment\nVariables" as EnvVars
}

package "Memory Management" {
  rectangle "ffunc_pool" as MemoryPool
}

WebServer --> FCGI : FastCGI Protocol
FCGI --> FFuncCore : Request/Response
FFuncCore --> Handlers : Calls via FN_HANDLER
FFuncCore --> MemoryPool : Allocation/Deallocation
FFuncAPI --> FFuncCore : Defines Interface
Config --> FFuncCore : Initialization
EnvVars --> Config : Parameter Overrides
Example --> Handlers : Implements
@enduml