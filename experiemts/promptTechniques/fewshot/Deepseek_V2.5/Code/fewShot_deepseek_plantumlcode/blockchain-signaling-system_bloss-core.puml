### Actual Output:
@startuml blockchain-signaling-system_bloss-core
skinparam rectangle {
  BackgroundColor<<monitoring>> #d9e7fd
  BackgroundColor<<blockchain>> #d8f5d3
  BackgroundColor<<mitigation>> #fddddd
  BackgroundColor<<storage>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

package "Network Layer" <<monitoring>> {
  rectangle "Ryu SDN Controller" as Ryu
  rectangle "Flow Statistics" as FlowStats
  rectangle "Traffic Monitoring" as TrafficMonitor
  rectangle "Attack Detection" as AttackDetect
  rectangle "Simple Router" as Router

  Ryu --> TrafficMonitor
  TrafficMonitor --> FlowStats
  TrafficMonitor --> AttackDetect
  AttackDetect --> Router
}

package "Blockchain Layer" <<blockchain>> {
  rectangle "Ethereum Node" as Ethereum
  rectangle "Smart Contracts" as Contracts
  rectangle "Blockchain Interface" as BlockchainAPI
  rectangle "Encryption (RSA)" as Encryption

  Ethereum --> Contracts
  BlockchainAPI --> Ethereum
  BlockchainAPI --> Encryption
}

package "Storage Layer" <<storage>> {
  database "InfluxDB" as Influx
  database "IPFS" as IPFS
  rectangle "Data Store" as DataStore

  DataStore --> Influx
  DataStore --> IPFS
}

package "API Layer" <<mitigation>> {
  rectangle "REST API" as REST
  rectangle "Mitigation Manager" as Mitigation
  rectangle "Attack Reporting" as Reporting

  REST --> Mitigation
  REST --> Reporting
}

TrafficMonitor --> FlowStats : Collects
AttackDetect --> BlockchainAPI : Reports attacks
BlockchainAPI --> DataStore : Stores reports
Mitigation --> BlockchainAPI : Queries attacks
Reporting --> BlockchainAPI : Submits reports
DataStore --> Encryption : Encrypts/decrypts
@enduml