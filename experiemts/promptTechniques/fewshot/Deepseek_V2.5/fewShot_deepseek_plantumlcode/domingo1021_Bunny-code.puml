### Actual Output:
@startuml domingo1021_Bunny-code
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<database>> #fff1c9
  BackgroundColor<<infra>> #fddddd
  BackgroundColor<<cloud>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "Web App" as WebApp
  rectangle "Mobile App" as MobileApp
}

package "Backend" <<backend>> {
  rectangle "Express API" as API
  rectangle "Socket.IO" as SocketIO
  rectangle "Controllers" as Controllers
  rectangle "Services" as Services
  rectangle "Sandbox Factory" as SandboxFactory
  rectangle "JWT Auth" as JWTAuth
  
  API --> Controllers
  Controllers --> Services
  Services --> SandboxFactory
  Services --> JWTAuth
  SocketIO --> Controllers
}

package "Databases" <<database>> {
  database "MySQL" as MySQL
  database "InfluxDB" as InfluxDB
  database "Redis" as Redis
  
  Services --> MySQL
  Services --> InfluxDB
  Services --> Redis
}

package "Infrastructure" <<infra>> {
  rectangle "Nginx" as Nginx
  rectangle "Docker" as Docker
  
  Nginx --> API
  Nginx --> SocketIO
  SandboxFactory --> Docker
}

package "Cloud Services" <<cloud>> {
  rectangle "S3" as S3
  rectangle "CloudFront" as CloudFront
  rectangle "CloudWatch" as CloudWatch
  
  Services --> S3
  Services --> CloudFront
  Services --> CloudWatch
}

WebApp --> Nginx
MobileApp --> Nginx
@enduml