@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as user
rectangle "Web Browser" as browser
rectangle "REST API Client" as apiClient

rectangle "youtube-dl-nas" as server {
  rectangle "Bottle Web Server" as bottle
  rectangle "WebSocket Handler" as ws
  rectangle "Download Queue" as queue
  rectangle "Download Worker" as worker
  rectangle "Auth Manager" as auth
  rectangle "Update Scheduler" as scheduler
}

database "Auth.json" as authDB
database "downfolder" as downloads
cloud "YouTube" as youtube

user --> browser : Accesses UI
apiClient --> bottle : REST API calls
browser --> bottle : HTTP requests
bottle --> auth : Authenticates
auth --> authDB : Reads credentials

bottle --> queue : Enqueues requests
queue --> worker : Processes next item
worker --> youtube : Downloads video
worker --> downloads : Saves files

bottle --> ws : Registers connection
worker --> ws : Sends progress updates
ws --> browser : Real-time updates

scheduler --> worker : Updates yt-dlp
@enduml