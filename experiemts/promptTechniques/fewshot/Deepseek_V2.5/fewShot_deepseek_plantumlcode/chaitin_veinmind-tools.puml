@startuml chaitin_veinmind-tools
left to right direction
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<plugin>> #d8f5d3
  BackgroundColor<<lib>> #fff1c9
  BackgroundColor<<ci>> #fddddd
  Style roundrect
}

package "Core Components" <<core>> {
  rectangle "veinmind-runner" as runner {
    component "Service Manager"
    component "Plugin Orchestrator"
    component "TOML Config Parser"
  }
  database "service.toml" as config
}

package "Plugins" <<plugin>> {
  rectangle "Weakpass Scanner" as weakpass {
    component "Password Cracker"
    component "Service Detectors"
    database "Password Dictionaries"
  }
  
  rectangle "Sensitive Data Scanner" as sensitive {
    component "Rule Engine"
    database "rules.toml"
  }
  
  rectangle "CVE Scanner" as cve
  rectangle "Malware Scanner" as malware
}

package "Libraries" <<lib>> {
  rectangle "libveinmind" as lib {
    component "Container Runtime"
    component "Filesystem Access"
  }
  
  rectangle "veinmind-common-go" as common {
    component "Report Generator"
  }
}

package "CI/CD" <<ci>> {
  rectangle "GitHub Actions" as github {
    component "Build"
    component "Test"
    component "Release"
  }
}

runner --> lib : uses
runner --> config : reads
runner --> weakpass : orchestrates
runner --> sensitive : orchestrates
runner --> cve : orchestrates
runner --> malware : orchestrates

weakpass --> lib : uses
sensitive --> lib : uses
cve --> lib : uses
malware --> lib : uses

weakpass --> common : generates reports
sensitive --> common : generates reports
cve --> common : generates reports
malware --> common : generates reports

github --> runner : builds
github --> weakpass : builds/tests
github --> sensitive : builds/tests
github --> cve : builds/tests
github --> malware : builds/tests
@enduml