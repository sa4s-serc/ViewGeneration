@startuml NeuralDev-io_arclytics_simcct
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<monitoring>> #fddddd
  BackgroundColor<<infra>> #d4f0f0
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  [React App] as React
  [Redux Store] as Redux
  [Plotly Charts] as Plotly
  React --> Redux
  React --> Plotly
}

package "Backend Services" <<backend>> {
  [Flask API] as Flask
  [Celery Worker] as Celery
  [User Management] as UserMgmt
  [Simulation Logic] as Simulation
  Flask --> UserMgmt
  Flask --> Simulation
  Flask --> Celery
}

package "Data Layer" <<data>> {
  [MongoDB] as MongoDB
  [Redis] as Redis
  Flask --> MongoDB
  Flask --> Redis
  Celery --> Redis
}

package "Monitoring" <<monitoring>> {
  [Fluentd] as Fluentd
  [Elasticsearch] as ES
  [Kibana] as Kibana
  [Elastic APM] as APM
  Fluentd --> ES
  ES --> Kibana
  Flask --> APM
  Flask --> Fluentd
}

package "Infrastructure" <<infra>> {
  [Docker] as Docker
  [Kubernetes] as K8s
  [Skaffold] as Skaffold
  Docker --> K8s
  Skaffold --> K8s
}

React --> Flask : REST API
UserMgmt --> MongoDB : Users
Simulation --> MongoDB : Simulation Data
@enduml