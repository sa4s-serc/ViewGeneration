@startuml jes_autopatzer
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "User" as User

rectangle "React UI (Electron)" as UI {
  [Home]
  [PlayGame]
  [PawnPromotion]
  [ConfirmMove]
}

rectangle "Lichess API" as LichessAPI #lightblue

rectangle "Teensy 3.2 Microcontroller" as Teensy {
  [Stepper Motor Control]
  [Electromagnet Control]
  [Hall Effect Sensors]
}

rectangle "Hardware Components" as Hardware {
  [NEMA17 Stepper Motors]
  [Linear Rods]
  [Electromagnet]
  [Hall Effect Sensors]
}

rectangle "Perl Communication Layer" as PerlLayer #lightgreen

User --> UI
UI --> LichessAPI : WebSocket
UI --> PerlLayer : WebSocket
PerlLayer --> Teensy : Serial
Teensy --> Hardware

note right of UI
  Uses useBoardEventStream and
  useLichessEventStream hooks
  for WebSocket connections
end note

note right of PerlLayer
  Handles communication between
  UI and microcontroller
end note

note left of Teensy
  Uses CD4051B multiplexers
  for sensor input
end note
@enduml