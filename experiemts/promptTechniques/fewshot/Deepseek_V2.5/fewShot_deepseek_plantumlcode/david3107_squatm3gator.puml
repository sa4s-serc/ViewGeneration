### Actual Output:
@startuml david3107_squatm3gator
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<queue>> #fff1c9
  BackgroundColor<<db>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "HTML/CSS (Bootstrap/MDB)" as UI
  rectangle "JavaScript (jQuery)" as JS
  rectangle "Socket.IO Client" as SocketClient
  UI --> JS
  JS --> SocketClient
}

package "Backend" <<backend>> {
  rectangle "Flask API" as Flask
  rectangle "Attack Modules" as AttackModules
  rectangle "GoDaddy API" as GoDaddy
  rectangle "WHOIS Lookup" as WHOIS
  Flask --> AttackModules
  AttackModules --> GoDaddy
  AttackModules --> WHOIS
}

package "Message Queue" <<queue>> {
  rectangle "Redis" as Redis
  rectangle "Producer" as Producer
  rectangle "Consumer" as Consumer
  Flask --> Producer
  Producer --> Redis
  Redis --> Consumer
  Consumer --> AttackModules
}

database "Session Data" <<db>> as SessionData
Flask --> SessionData

SocketClient --> Flask
Flask --> SocketClient

note right of Redis
  Used for job queuing
  and session management
end note

note right of GoDaddy
  Requires API keys
end note

note right of WHOIS
  Domain registration
  information
end note
@enduml