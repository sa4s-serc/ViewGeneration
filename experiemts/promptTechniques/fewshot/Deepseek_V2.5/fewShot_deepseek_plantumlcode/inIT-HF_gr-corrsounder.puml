### Actual Output:
@startuml IT-HF_gr-corrsounder
left to right direction
skinparam rectangle {
  BackgroundColor<<cpp>> #d9e7fd
  BackgroundColor<<python>> #d8f5d3
  BackgroundColor<<grc>> #fff1c9
  BackgroundColor<<doc>> #fddddd
  Style roundrect
}

package "C++ Core" <<cpp>> {
  component "Sequence Generation\n(FZC/MLS)" as SeqGen
  component "Correlation Blocks" as Corr
  component "Error Correction" as ErrorCorr
  component "Moving Average" as MAvg
  component "Sequence Gate" as SeqGate
  component "Ramdisk File Sink" as Ramdisk
  component "IR SNR Detection" as IRSNR
}

package "Python Layer" <<python>> {
  component "SWIG Bindings" as SWIG
  component "pycorrsounder\nStandalone" as PyCorr
  component "Unit Tests" as Tests
}

package "GNU Radio" {
  component "GRC Blocks" <<grc>> as GRC
  component "Flowgraphs" as Flow
}

package "Documentation" <<doc>> {
  component "Doxygen XML" as Doxy
  component "generateDS.py" as GenDS
}

SeqGen --> Corr
Corr --> ErrorCorr
ErrorCorr --> MAvg
MAvg --> SeqGate
SeqGate --> Ramdisk
Ramdisk --> IRSNR

SWIG --> SeqGen
SWIG --> Corr
SWIG --> ErrorCorr
SWIG --> MAvg
SWIG --> SeqGate
SWIG --> Ramdisk
SWIG --> IRSNR

PyCorr --> SeqGen
PyCorr --> Corr

Tests --> PyCorr
Tests --> SWIG

GRC --> SWIG
Flow --> GRC

Doxy --> GenDS
GenDS --> PyCorr
@enduml