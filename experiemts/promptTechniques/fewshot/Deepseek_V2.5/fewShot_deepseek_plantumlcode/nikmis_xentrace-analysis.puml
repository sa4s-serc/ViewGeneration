@startuml
skinparam rectangle {
  BackgroundColor<<capture>> #d9e7fd
  BackgroundColor<<parsing>> #d8f5d3
  BackgroundColor<<analysis>> #fff1c9
  BackgroundColor<<handler>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center
left to right direction

package "Data Capture" <<capture>> {
  rectangle "xentrace" as xentrace
  rectangle "Trace File" as tracefile
  xentrace --> tracefile
}

package "Event Parsing" <<parsing>> {
  rectangle "Reader" as reader
  rectangle "Event List" as eventlist
  rectangle "Event Sorting" as eventsort
  tracefile --> reader
  reader --> eventlist
  eventlist --> eventsort
}

package "Event Handling" <<handler>> {
  rectangle "Event Dispatcher" as dispatcher
  rectangle "Handler Registry" as registry
  eventsort --> dispatcher
  dispatcher --> registry
}

package "Analysis Tools" <<analysis>> {
  rectangle "CPU Utilization" as cpuutil
  rectangle "Scheduling Latency" as schedlat
  rectangle "Hypervisor Time" as hypervtime
  rectangle "Disk I/O" as diskio
  rectangle "Xen Stats" as xenstats
  rectangle "Trap Counting" as trap
  registry --> cpuutil
  registry --> schedlat
  registry --> hypervtime
  registry --> diskio
  registry --> xenstats
  registry --> trap
}

rectangle "Xentrace-analysis" as main {
  [Argument Parsing] as args
  [Process Management] as proc
  [Signal Handling] as sig
  args --> proc
  proc --> sig
  proc --> xentrace
}

main --> reader
main --> dispatcher
@enduml