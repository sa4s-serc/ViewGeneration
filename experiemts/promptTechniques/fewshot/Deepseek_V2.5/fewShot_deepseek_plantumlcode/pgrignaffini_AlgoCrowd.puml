### Actual Output:
@startuml pgrignaffini_AlgoCrowd
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<blockchain>> #fff1c9
  BackgroundColor<<db>> #fddddd
  Style roundrect
}

package "Frontend (Next.js)" <<frontend>> {
  rectangle "Pages" as Pages
  rectangle "Components" as Components
  rectangle "API.js" as API
  rectangle "AppContext.js" as Context
  rectangle "Utils" as Utils
  rectangle "Constants" as Constants
}

package "Backend (Express.js)" <<backend>> {
  rectangle "server.js" as Server
  rectangle "REST API" as REST
  rectangle "DAO" as DAO
}

package "Database" <<db>> {
  database "SQLite" as SQLite
}

package "Algorand Blockchain" <<blockchain>> {
  rectangle "Smart Contracts" as Contracts
  rectangle "AlgoSigner" as AlgoSigner
  rectangle "Algod Client" as Algod
}

Pages --> Components
Components --> API
API --> REST
Context --> Algod
Utils --> Algod
Constants --> Contracts

Server --> REST
REST --> DAO
DAO --> SQLite

REST --> Contracts
Contracts --> Algod
AlgoSigner --> Contracts
@enduml