@startuml Elkinmt19_feature-hero-ml
left to right direction
skinparam rectangle {
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<processing>> #d8f5d3
  BackgroundColor<<storage>> #d9e7fd
  BackgroundColor<<serving>> #fddddd
  Style roundrect
}

package "Data Sources" <<data>> {
  rectangle "Credit Card\nTransaction Data" as cc_data
}

package "Data Processing" <<processing>> {
  rectangle "fetch_card_transdata.py" as fetch
  rectangle "get_train_val_card_transdata.py" as split
  rectangle "fetch_train_val_dataset_card_transdata.py" as feast_ingest
}

package "Feature Store" <<storage>> {
  rectangle "Feast Core" as feast
  rectangle "Redis\n(Online Store)" as redis
  rectangle "Parquet Files\n(Offline Store)" as parquet
}

package "Serving" <<serving>> {
  rectangle "Model Training" as training
  rectangle "Real-time\nPrediction" as realtime
}

cc_data --> fetch
fetch --> split
split --> feast_ingest
feast_ingest --> feast
feast --> redis : online features
feast --> parquet : offline features

redis --> realtime
parquet --> training

note right of feast
  Configured via\nfeature_store.yaml
end note

note right of redis
  Low-latency access
end note

note right of parquet
  Batch processing
end note
@enduml