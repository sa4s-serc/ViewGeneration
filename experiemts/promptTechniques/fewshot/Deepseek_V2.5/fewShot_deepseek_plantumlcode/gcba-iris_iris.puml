### Actual Output:
@startuml gcba-iris_iris
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "IoT Device" as Device

rectangle "Dock" as Dock {
  [Protocol Listener]
  [Message Parser]
  [Response Encoder]
}

rectangle "Dispatcher" as Dispatcher {
  [Flow Compiler]
  [Job Executor]
}

rectangle "Thread Pool" as ThreadPool {
  [Worker 1]
  [Worker 2]
  [Worker N]
}

rectangle "Handler" as Handler {
  [Data Processor]
  [Response Generator]
}

rectangle "Hook" as Hook {
  [Pre-Processor]
  [Post-Processor]
}

rectangle "Logger" as Logger {
  [Winston]
}

rectangle "Validator" as Validator {
  [propchecker]
}

rectangle "CLI" as CLI {
  [bin/iris.js]
}

Device --> Dock : Messages
Dock --> Dispatcher : Parsed Data
Dispatcher --> ThreadPool : Jobs
ThreadPool --> Handler : Process Data
Handler --> Dispatcher : Responses
Dispatcher --> Dock : Responses
Dock --> Device : Encoded Responses

Dispatcher --> Hook : Pre/Post Processing
Hook --> Dispatcher : Processed Data

Dispatcher --> Logger : Log Events
Dispatcher --> Validator : Validate Configs
CLI --> Dispatcher : Commands
@enduml