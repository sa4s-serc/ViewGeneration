@startuml
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<external>> #fddddd
  Style roundrect
}
left to right direction

actor User

package "Frontend (React + A-Frame)" <<frontend>> {
  rectangle "VR Scene Explorer" as VRScene
  rectangle "Image Upload" as Upload
  rectangle "User Profile" as Profile
  rectangle "Bookmark Manager" as Bookmarks
  rectangle "Comment/Like System" as Social
}

package "Backend (Node.js + Express)" <<backend>> {
  rectangle "Auth Controller" as Auth
  rectangle "Image Controller" as ImageCtrl
  rectangle "Bookmark Controller" as BookmarkCtrl
  rectangle "Social Controller" as SocialCtrl
}

package "Data Storage" <<storage>> {
  database "MariaDB" as DB
  rectangle "AWS S3" as S3
}

package "External Services" <<external>> {
  rectangle "Wikipedia API" as Wiki
}

User --> VRScene
User --> Upload
User --> Profile
User --> Bookmarks
User --> Social

VRScene --> ImageCtrl : fetch scenes
Upload --> ImageCtrl : upload image
Profile --> Auth : user data
Bookmarks --> BookmarkCtrl : manage bookmarks
Social --> SocialCtrl : post comments/likes

Auth --> DB : user auth
ImageCtrl --> DB : photo metadata
ImageCtrl --> S3 : store images
BookmarkCtrl --> DB : bookmark data
BookmarkCtrl --> Wiki : fetch articles
SocialCtrl --> DB : comments/likes
@enduml