@startuml
skinparam rectangle {
  BackgroundColor<<presentation>> #d9e7fd
  BackgroundColor<<business>> #d8f5d3
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<external>> #fddddd
  BackgroundColor<<db>> #d4f0f0
  Style roundrect
}
skinparam linetype ortho
left to right direction

package "Presentation Layer" <<presentation>> {
  [Express Router] as Router
  [Rate Limiter Middleware] as RateLimiter
  [Auth Middleware] as AuthMiddleware
}

package "Business Layer" <<business>> {
  [User Services] as UserServices
  [AppError] as AppError
}

package "Data Layer" <<data>> {
  [User Repository] as UserRepo
  [Cache Provider] as CacheProvider
  [Hash Provider] as HashProvider
}

package "External Services" <<external>> {
  [Redis] as Redis
  [PostgreSQL] as Postgres
}

package "Infrastructure" {
  [TypeORM] as TypeORM
  [Tsyringe DI] as Tsyringe
}

Router --> UserServices
RateLimiter --> Router
AuthMiddleware --> Router

UserServices --> UserRepo
UserServices --> CacheProvider
UserServices --> HashProvider
UserServices --> AppError

UserRepo --> TypeORM
TypeORM --> Postgres

CacheProvider --> Redis
HashProvider --> bcryptjs

Tsyringe --> UserServices
Tsyringe --> UserRepo
Tsyringe --> CacheProvider
Tsyringe --> HashProvider

note right of Redis
  Caching user data
end note

note right of Postgres
  User data storage
end note

note right of Tsyringe
  Dependency Injection
end note
@enduml