@startuml Speccy-Rom_SpeccyTV
left to right direction
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<queue>> #f0e6ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "Web UI" as WebUI
  rectangle "Mobile App" as MobileApp
}

package "API Gateway" <<backend>> {
  rectangle "Async API (FastAPI)" as AsyncAPI
  rectangle "Auth Service" as AuthService
}

package "Core Services" <<backend>> {
  rectangle "Streaming Service" as StreamingService
  rectangle "ETL Pipeline" as ETLPipeline
  rectangle "Billing Service" as BillingService
  rectangle "Admin Service" as AdminService
  rectangle "UGC Service" as UGCService
}

package "Data Stores" <<db>> {
  database "PostgreSQL" as Postgres
  database "Elasticsearch" as Elastic
  database "Redis" as Redis
  database "ClickHouse" as ClickHouse
  database "MinIO" as MinIO
}

package "Message Queues" <<queue>> {
  rectangle "Kafka" as Kafka
  rectangle "RabbitMQ" as RabbitMQ
}

WebUI --> AsyncAPI
MobileApp --> AsyncAPI

AsyncAPI --> StreamingService
AsyncAPI --> AuthService
AsyncAPI --> BillingService
AsyncAPI --> AdminService
AsyncAPI --> UGCService

AuthService --> Postgres
BillingService --> Postgres
AdminService --> Postgres
StreamingService --> MinIO
StreamingService --> Elastic
StreamingService --> Redis

ETLPipeline --> StreamingService
ETLPipeline --> RabbitMQ
ETLPipeline --> MinIO

UGCService --> Kafka
UGCService --> ClickHouse

Kafka --> UGCService
RabbitMQ --> ETLPipeline
@enduml