@startuml gaiax_fLibra

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  ArrowColor #333333
}

actor User

rectangle "Frontend (Nuxt.js)" {
  [Vue Components]
  [Vuex Store]
  [IPFS Plugin]
  [Web3 Plugin]
  [Firebase Plugin]
}

rectangle "Blockchain" {
  [Libra Network]
  [Ethereum Network]
}

rectangle "Backend Services" {
  [Elasticsearch Service]
  [Firebase/Firestore]
}

database "IPFS" as IPFS

User --> [Vue Components] : Interacts
[Vue Components] <--> [Vuex Store] : State Management
[Vue Components] --> [IPFS Plugin] : Store/Retrieve Images
[Vue Components] --> [Web3 Plugin] : Ethereum Interactions
[Vue Components] --> [Firebase Plugin] : Data Operations

[Web3 Plugin] --> [Ethereum Network] : Smart Contract Calls
[Firebase Plugin] --> [Firebase/Firestore] : Read/Write Data
[IPFS Plugin] --> IPFS : Store/Retrieve

[Ethereum Network] --> [Flibra.sol] : Manage Items & Users
[Libra Network] <-- [Vue Components] : Currency Transactions

[Firebase/Firestore] --> [Elasticsearch Service] : Sync Data
[Elasticsearch Service] <-- [Vue Components] : Search Requests

@enduml