@startuml eProsima_Integration-Service

skinparam backgroundColor #EEEBDC
skinparam handwritten true

actor "User" as user
participant "Integration Service" as is
participant "JSON Library" as json
participant "System Handle A" as sha
participant "System Handle B" as shb
database "Middleware A" as mwa
database "Middleware B" as mwb

user -> is : Configure (YAML)
activate is

is -> is : Parse Configuration

loop for each route
    is -> sha : Create & Initialize
    is -> shb : Create & Initialize
end

is --> user : Ready

user -> mwa : Publish/Request
activate mwa

mwa -> sha : Receive Data
activate sha

sha -> is : Convert to DynamicData
activate is

is -> json : Convert to JSON
activate json
json --> is : JSON Data
deactivate json

is -> json : Parse JSON
activate json
json --> is : Parsed Data
deactivate json

is -> shb : Convert to Target Format
activate shb

shb -> mwb : Publish/Request
activate mwb

mwb --> shb : Response (if applicable)
deactivate mwb

shb --> is : Response Data
deactivate shb

is -> json : Convert to JSON
activate json
json --> is : JSON Data
deactivate json

is -> sha : Convert to Source Format
deactivate is

sha -> mwa : Publish/Respond
deactivate sha

mwa --> user : Data/Response
deactivate mwa

@enduml