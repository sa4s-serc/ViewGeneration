@startuml terrenjpeterson_javawatch

skinparam sequenceArrowThickness 2
skinparam roundcorner 20
skinparam maxMessageSize 100
skinparam sequenceParticipantBorderThickness 2

actor User
participant "Raspberry Pi\n(photo.py)" as RaspberryPi
participant "S3 Bucket" as S3
participant "Lambda\n(checkImage.py)" as LambdaCheck
participant "Amazon\nRekognition" as Rekognition
participant "Lambda\n(labelCheck.js)" as LambdaLabel
participant "Amazon DRS" as DRS
participant "Website" as Website

User -> RaspberryPi : Initiate image capture
activate RaspberryPi
RaspberryPi -> RaspberryPi : Capture image and add timestamp
RaspberryPi -> S3 : Upload image
deactivate RaspberryPi

S3 -> LambdaCheck : Trigger checkImage.py
activate LambdaCheck
LambdaCheck -> Rekognition : detect_labels()
activate Rekognition
Rekognition --> LambdaCheck : Return labels
deactivate Rekognition
LambdaCheck -> LambdaLabel : Trigger labelCheck.js
deactivate LambdaCheck

activate LambdaLabel
LambdaLabel -> LambdaLabel : Check for "Bean" label
alt Bean level low
    LambdaLabel -> DRS : Place order
    activate DRS
    DRS --> LambdaLabel : Order confirmation
    deactivate DRS
end
deactivate LambdaLabel

User -> Website : Access registration page
activate Website
Website -> DRS : Link device to Amazon account
DRS --> Website : Confirmation
Website --> User : Display registration confirmation
deactivate Website

@enduml