@startuml
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

actor "Developer" as dev
component "Webpack" as webpack
component "OfflinePackagePlugin" as plugin {
  [Configuration Options]
  [File Filtering]
  [Zip Creation]
  [Manifest Generation]
}
database "Output" {
  [Zip Archive]
  [index.json]
}
component "External Libraries" {
  [jszip]
  [mime-types]
  [lodash]
}

dev -> webpack : Configures
webpack -> plugin : Invokes during 'emit' phase
plugin -> [Configuration Options] : Uses
plugin -> [File Filtering] : Applies
plugin -> [Zip Creation] : Performs
plugin -> [Manifest Generation] : Generates
[Zip Creation] --> [Zip Archive] : Produces
[Manifest Generation] --> [index.json] : Produces
plugin --> [jszip] : Uses for zip creation
plugin --> [mime-types] : Uses for MIME type detection
plugin --> [lodash] : Uses for utility functions

@enduml