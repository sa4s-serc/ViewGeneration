@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  Style roundrect
}

actor "Data Scientist" as user
actor "Admin" as admin

rectangle "OpenShift Cluster" {
  rectangle "JupyterHub Pod" as hub {
    [JupyterHub]
    [KubeSpawner]
    [LDAPAuthenticator]
  }
  
  database "PostgreSQL" as db
  
  rectangle "User Notebook Pod" as notebook {
    [JupyterLab]
    [Jupyter Notebook]
    [Git Extension]
  }
  
  rectangle "Persistent Volume" as pv
  
  rectangle "Network Policy" as netpol
  
  rectangle "Idle Server Culler" as culler
}

rectangle "Active Directory/LDAP" as ldap

user --> hub : Authenticates
admin --> hub : Manages
hub --> ldap : Authenticates users
hub --> notebook : Spawns
notebook --> pv : Stores data
netpol -[dotted]-> notebook : Restricts traffic
culler -[dotted]-> notebook : Terminates idle
hub --> db : Stores state

@enduml