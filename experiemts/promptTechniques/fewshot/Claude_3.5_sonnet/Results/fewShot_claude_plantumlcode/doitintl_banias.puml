@startuml
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

cloud "Client Applications" as clients

package "Frontend (Go)" {
  [HTTP API (/track)] as api
  [Event Validator] as validator
  [Event Batcher] as batcher
  [Pub/Sub Publisher] as publisher
  [Prometheus Metrics (/metrics)] as metrics
}

cloud "Google Cloud Platform" {
  queue "Pub/Sub" as pubsub
  [Cloud Storage (Schema Bucket)] as gcs
  
  package "Backend (Java Dataflow)" {
    [Dataflow Pipeline] as pipeline
    [Schema Loader] as schemaLoader
    [Event Mapper] as mapper
  }
  
  database "BigQuery" {
    [Event Tables] as eventTables
    [Error Table] as errorTable
  }
}

[Stackdriver] as stackdriver

clients --> api
api --> validator
validator --> batcher
batcher --> publisher
publisher --> pubsub
metrics --> stackdriver

pubsub --> pipeline
gcs --> schemaLoader
schemaLoader --> pipeline
pipeline --> mapper
mapper --> eventTables
mapper --> errorTable

@enduml