@startuml NatalieLouise91_T3A2-Skemi-FrontEnd

skinparam component {
  BackgroundColor LightSkyBlue
  BorderColor Black
  ArrowColor Black
}

[App] as App
[StateContext] as StateContext
[StateReducer] as StateReducer

package "Components" {
  [Nav] as Nav
  [Login] as Login
  [NewUser] as NewUser
  
  package "Occasion" {
    [CreateOccasion] as CreateOccasion
    [ViewOccasion] as ViewOccasion
    [OccasionList] as OccasionList
  }
  
  package "Roster" {
    [CreateRoster] as CreateRoster
    [ViewRoster] as ViewRoster
    [EditRoster] as EditRoster
  }
}

package "Services" {
  [occasionServices] as occasionServices
  [rosterServices] as rosterServices
  [authServices] as authServices
  [userServices] as userServices
}

[API Configuration] as APIConfig

database "Rails API Backend" as Backend

App --> StateContext
App --> StateReducer
App --> Nav
App --> Login
App --> NewUser
App --> CreateOccasion
App --> ViewOccasion
App --> OccasionList
App --> CreateRoster
App --> ViewRoster
App --> EditRoster

Nav --> authServices
Login --> authServices
NewUser --> authServices

CreateOccasion --> occasionServices
ViewOccasion --> occasionServices
OccasionList --> occasionServices

CreateRoster --> rosterServices
ViewRoster --> rosterServices
EditRoster --> rosterServices

occasionServices --> APIConfig
rosterServices --> APIConfig
authServices --> APIConfig
userServices --> APIConfig

APIConfig --> Backend

@enduml