@startuml dich1_bookshelf-web

skinparam component {
  BackgroundColor LightBlue
  BorderColor Black
  ArrowColor Black
}

cloud "Internet" {
  [Web Browser]
}

node "Docker Environment" {
  [NGINX] as nginx
  
  node "Rails Application Container" {
    [Ruby on Rails App] as rails
    database "MySQL" as mysql
    
    component "Models" as models
    component "Controllers" as controllers
    component "Views" as views
    
    rails --> models
    rails --> controllers
    rails --> views
    
    controllers --> models
  }
  
  nginx --> rails : Reverse Proxy
  rails --> mysql : ActiveRecord
}

cloud "External Services" {
  [Google Books API]
  [Facebook OAuth]
}

[Web Browser] --> nginx : HTTP/HTTPS

rails --> [Google Books API] : Book Info Lookup
rails --> [Facebook OAuth] : User Authentication

node "CI/CD Pipeline" {
  [CircleCI]
}

[CircleCI] --> [Docker Environment] : Deploy

@enduml