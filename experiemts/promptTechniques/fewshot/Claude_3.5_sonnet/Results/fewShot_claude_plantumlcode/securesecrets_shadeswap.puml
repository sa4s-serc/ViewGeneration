@startuml securesecrets_shadeswap

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

rectangle "ShadeSwap Ecosystem" {
  rectangle "Factory Contract" as Factory
  rectangle "Router Contract" as Router
  rectangle "AMM Pair Contract" as AMMPair
  rectangle "LP Token Contract" as LPToken
  rectangle "Staking Contract" as Staking
  rectangle "Admin Contract" as Admin
}

rectangle "Shared Components" {
  rectangle "shadeswap-shared" as Shared
  rectangle "secret-toolkit" as SecretToolkit
}

rectangle "External Interactions" {
  actor "Users" as Users
  database "Secret Network" as SecretNetwork
}

Users --> Router : Initiates swaps
Users --> AMMPair : Provides liquidity
Users --> Staking : Stakes LP tokens
Users --> LPToken : Manages tokens

Factory --> AMMPair : Deploys
Factory --> LPToken : Deploys

Router --> AMMPair : Executes swaps
AMMPair --> LPToken : Mints/Burns

Staking --> LPToken : Stakes/Unstakes

Admin --> Factory : Manages
Admin --> Router : Manages
Admin --> AMMPair : Manages
Admin --> Staking : Manages

Factory ..> Shared : Uses
Router ..> Shared : Uses
AMMPair ..> Shared : Uses
LPToken ..> Shared : Uses
Staking ..> Shared : Uses

Factory ..> SecretToolkit : Uses
Router ..> SecretToolkit : Uses
AMMPair ..> SecretToolkit : Uses
LPToken ..> SecretToolkit : Uses
Staking ..> SecretToolkit : Uses

Factory --> SecretNetwork : Interacts
Router --> SecretNetwork : Interacts
AMMPair --> SecretNetwork : Interacts
LPToken --> SecretNetwork : Interacts
Staking --> SecretNetwork : Interacts

@enduml