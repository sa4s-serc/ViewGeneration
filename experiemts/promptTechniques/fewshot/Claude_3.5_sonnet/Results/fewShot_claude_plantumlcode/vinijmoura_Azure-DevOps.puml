@startuml vinijmoura_Azure-DevOps

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

rectangle "Azure DevOps" as AzDO #LightBlue
rectangle "PowerShell Scripts" as PS #LightGreen
database "Azure SQL Database" as SQL #Orange
rectangle "Power BI" as PBI #Pink

cloud "GitHub Repository" {
  folder "PowerShell Scripts" as PSFolder
  folder "Power BI Files (.pbix)" as PBIFolder
  folder "Custom Visuals" as CV
  file "README.md" as README
  file "powershell-analysis.yml" as CICD
}

AzDO <-- PS : Extract Data
PS --> SQL : Load Data
SQL <-- PBI : Query Data

PSFolder ..> PS : Defines
PBIFolder ..> PBI : Defines
CV ..> PBI : Enhances

note right of PS
  Extracts:
  - User & Access Data
  - Project Data
  - Repos & Pipelines
  - Team Configs
  - Artifacts & Extensions
end note

note right of PBI
  Visualizes:
  - Management Reports
  - Custom Dashboards
end note

note bottom of GitHub Repository
  Version Control &
  Collaboration
end note

@enduml