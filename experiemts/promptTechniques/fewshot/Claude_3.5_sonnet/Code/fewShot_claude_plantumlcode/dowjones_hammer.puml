@startuml dowjones_hammer

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

actor "AWS Administrator" as admin
rectangle "Configuration Files" as config #LightBlue

rectangle "Initiation Lambda" as initLambda
cloud "SNS" as sns

rectangle "Identification Layer" {
  rectangle "IAM Lambda" as iamLambda
  rectangle "S3 Lambda" as s3Lambda
  rectangle "EC2 Lambda" as ec2Lambda
  rectangle "RDS Lambda" as rdsLambda
  rectangle "SQS Lambda" as sqsLambda
}

database "DynamoDB" as dynamo
rectangle "EC2 Instance" as ec2 {
  rectangle "Reporting Module" as reporting
  rectangle "Remediation Module" as remediation
}

cloud "AWS Accounts" as awsAccounts
rectangle "JIRA" as jira
rectangle "Slack" as slack
rectangle "S3 Bucket" as s3

admin -> config : Configures
config -> initLambda : Triggers

initLambda -> sns : Publishes event
sns -> iamLambda : Triggers
sns -> s3Lambda : Triggers
sns -> ec2Lambda : Triggers
sns -> rdsLambda : Triggers
sns -> sqsLambda : Triggers

iamLambda -> dynamo : Stores issues
s3Lambda -> dynamo : Stores issues
ec2Lambda -> dynamo : Stores issues
rdsLambda -> dynamo : Stores issues
sqsLambda -> dynamo : Stores issues

dynamo -> ec2 : Retrieves issues
ec2 -> reporting : Processes issues
ec2 -> remediation : Applies fixes

reporting -> jira : Creates tickets
reporting -> slack : Sends notifications
reporting -> s3 : Stores reports

remediation -> awsAccounts : Applies fixes

@enduml