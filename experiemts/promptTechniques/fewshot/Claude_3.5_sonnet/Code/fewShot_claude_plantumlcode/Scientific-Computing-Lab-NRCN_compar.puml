@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  Style roundrect
}

rectangle "CodeMirror" {
  [Core Editor] as CE
  [Language Modes] as LM
  [Keymaps] as KM
  [Addons] as AD
  [Document Management] as DM
  [History Management] as HM
  [Input Methods] as IM
  [Event System] as ES

  CE --> LM : uses
  CE --> KM : configures
  CE --> AD : extends with
  CE --> DM : manages
  CE --> HM : tracks changes
  CE --> IM : handles input
  CE <--> ES : communicates via
}

rectangle "ComPar" {
  [GUI] as GUI
  [Compiler Abstraction] as CA
  [Parallelization Tools] as PT
  [Code Instrumentation] as CI
  [Runtime Analysis] as RA
  [Slurm Job Management] as SJM
  [Database (MongoDB)] as DB
  [Combination Validator] as CV

  GUI --> CA : configures
  GUI --> PT : selects
  CA --> PT : uses
  CA --> CI : applies
  CA --> RA : triggers
  RA --> SJM : submits jobs
  RA --> DB : stores results
  CA --> CV : validates params
}

[User] --> GUI : interacts
GUI --> CE : embeds

@enduml