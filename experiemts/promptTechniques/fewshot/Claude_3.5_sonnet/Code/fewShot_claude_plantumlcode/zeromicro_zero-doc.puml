@startuml zeromicro_zero-doc

skinparam component {
  BackgroundColor LightBlue
  BorderColor Black
  ArrowColor Black
}

package "Go-Zero Framework" {
  [goctl] as CodeGen
  [zRPC] as RPC
  [API Gateway]
  [Caching]
  [Load Shedding]
  [Service Discovery]
  [Rate Limiting]
  [go-queue]
  [Concurrency Utilities]
  [Metrics & Monitoring]
  [Distributed Tracing]
  [Middleware]
}

cloud "External Services" {
  [Redis]
  [etcd]
  [Prometheus]
  [Grafana]
  [Jaeger/Zipkin]
}

database "Database" {
  [SQL Server/MySQL]
}

[Developer] --> CodeGen : uses
CodeGen --> [API Services] : generates
CodeGen --> [RPC Services] : generates
CodeGen --> [Model Code] : generates
CodeGen --> [Deployment Manifests] : generates

[API Gateway] --> [API Services] : routes
[API Services] --> RPC : calls
[RPC Services] --> RPC : implements

RPC --> [Service Discovery] : uses
[Service Discovery] --> [etcd] : uses

[API Services] --> [Caching] : uses
[RPC Services] --> [Caching] : uses
[Caching] --> [Redis] : uses

[API Services] --> [Load Shedding] : implements
[RPC Services] --> [Load Shedding] : implements

[API Services] --> [Rate Limiting] : uses
[Rate Limiting] --> [Redis] : uses

[API Services] --> [go-queue] : uses
[RPC Services] --> [go-queue] : uses

[API Services] --> [Concurrency Utilities] : uses
[RPC Services] --> [Concurrency Utilities] : uses

[Metrics & Monitoring] --> [Prometheus] : exports to
[Prometheus] --> [Grafana] : visualized in

[Distributed Tracing] --> [Jaeger/Zipkin] : exports to

[API Services] --> [Middleware] : uses
[RPC Services] --> [Middleware] : uses

[Model Code] --> [SQL Server/MySQL] : interacts with

note right of CodeGen
  Generates boilerplate code,
  reducing development time
end note

note right of [Caching]
  Implements read-through/write-back
  caching with stampede prevention
end note

note right of [Load Shedding]
  Adaptive request acceptance
  based on system resources
end note

note right of [Service Discovery]
  Supports direct, etcd-based,
  and Kubernetes-based discovery
end note

@enduml