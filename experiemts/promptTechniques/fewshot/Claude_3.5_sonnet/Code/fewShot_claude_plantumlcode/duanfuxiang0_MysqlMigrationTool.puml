@startuml duanfuxiang0_MysqlMigrationTool

skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  RoundCorner 20
}

actor "User" as user

rectangle "Main Application" {
  [incremental_data_migration.go] as idm
  [full_data_migration.go] as fdm
}

rectangle "Core" {
  [dao.go] as dao
  [conf.go] as conf
}

database "Source MySQL DB" as sourceDB
database "Target DB" as targetDB

rectangle "go-mysql/canal" as canal

user --> idm : Initiates
user --> fdm : Initiates (optional)

idm --> canal : Uses
canal --> sourceDB : Reads binlog

idm --> dao : Uses
fdm --> dao : Uses

dao --> targetDB : Applies changes

idm ..> conf : Should use (future)
fdm ..> conf : Should use (future)

note right of idm
  1. Initialize canal
  2. Parse binlog events
  3. Map to structs
  4. Apply changes
end note

note right of fdm
  Perform full data migration
end note

note right of dao
  - Define data models
  - Handle DB operations
  - Type conversions
end note

note right of conf
  Future: Centralized configuration
end note

@enduml