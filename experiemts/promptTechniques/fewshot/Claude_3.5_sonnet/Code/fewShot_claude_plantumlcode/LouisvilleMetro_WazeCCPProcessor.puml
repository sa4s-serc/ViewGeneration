@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Waze CCP" as WazeCCP
actor "API User" as APIUser

rectangle "AWS Cloud" {
  rectangle "Lambda Functions" {
    rectangle "waze-data-download" as Download
    rectangle "waze-data-process" as Process
    rectangle "waze-data-alerts-processing" as AlertsProcess
    rectangle "waze-data-jams-processing" as JamsProcess
    rectangle "waze-data-irregularities-processing" as IrregularitiesProcess
    rectangle "waze-db-initialize" as DBInit
    rectangle "waze-data-api" as API
  }

  rectangle "S3" as S3
  queue "SQS" as SQS
  rectangle "SNS" as SNS
  database "Aurora PostgreSQL" as DB
  rectangle "API Gateway" as APIGateway
}

WazeCCP --> Download : Fetch data
Download --> S3 : Store JSON
S3 --> Process : Trigger
Process --> SQS : Distribute tasks
SQS --> AlertsProcess
SQS --> JamsProcess
SQS --> IrregularitiesProcess
AlertsProcess --> DB : Store processed data
JamsProcess --> DB : Store processed data
IrregularitiesProcess --> DB : Store processed data
Process --> SNS : Notify status
DBInit --> DB : Initialize/Update schema
APIUser --> APIGateway : Request data
APIGateway --> API : Route request
API --> DB : Query data
API --> APIGateway : Return response
APIGateway --> APIUser : Deliver data

@enduml