@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  Style roundrect
}
skinparam component {
  BackgroundColor #EEEBDC
  BorderColor #333333
}
skinparam database {
  BackgroundColor #EEEBDC
  BorderColor #333333
}
skinparam arrow {
  Color #333333
  FontColor #333333
}

rectangle "SPP Environment" {
  [SPP Server]
  [vSnap]
  [VADP]
  [Microsoft 365 Proxies]
}

rectangle "SPPMon" {
  component "sppmon.py" as SPPMon
  component "REST API Client" as RestClient
  component "SSH Client" as SshClient
  component "Data Collection Modules" as DataCollection
  component "InfluxDB Client" as InfluxClient
}

rectangle "SPPCheck" {
  component "sppcheck.py" as SPPCheck
  component "Excel Processor" as ExcelProcessor
  component "Data Generator" as DataGenerator
  component "Report Generator" as ReportGenerator
  component "Predictor" as Predictor
}

database "InfluxDB" as InfluxDB

[Grafana]

rectangle "Automation" {
  [Installer Script]
  [Configuration Scripts]
}

SPPMon --> RestClient : uses
SPPMon --> SshClient : uses
SPPMon --> DataCollection : uses
SPPMon --> InfluxClient : uses

RestClient --> [SPP Server] : queries
SshClient --> [vSnap] : executes commands
SshClient --> [VADP] : executes commands
SshClient --> [Microsoft 365 Proxies] : executes commands

DataCollection --> RestClient : uses
DataCollection --> SshClient : uses

InfluxClient --> InfluxDB : writes/queries

SPPCheck --> ExcelProcessor : uses
SPPCheck --> DataGenerator : uses
SPPCheck --> ReportGenerator : uses
SPPCheck --> Predictor : uses
SPPCheck --> InfluxClient : uses

Grafana --> InfluxDB : reads

[Installer Script] ..> SPPMon : installs
[Installer Script] ..> SPPCheck : installs
[Installer Script] ..> InfluxDB : installs
[Installer Script] ..> Grafana : installs

[Configuration Scripts] ..> SPPMon : configures
[Configuration Scripts] ..> SPPCheck : configures
@enduml