@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Client" as client

package "Foundry" {
  rectangle "gRPC Server" as grpc
  rectangle "Furnace" as furnace {
    rectangle "Build Queue" as queue
    rectangle "pkgMap" as pkgmap
    rectangle "Builder Interface" as builder
  }
  rectangle "Metrics (Prometheus)" as metrics
  rectangle "Health Checks" as health
  rectangle "Internal HTTP Server" as internal_http
}

rectangle "Object Storage" as storage
rectangle "AUR" as aur

client --> grpc : Build requests
grpc --> furnace : Forward requests
furnace --> queue : Enqueue builds
furnace --> pkgmap : Manage package states
furnace --> builder : Execute builds
builder --> aur : Fetch package info
builder --> storage : Upload built packages
furnace --> metrics : Report metrics
furnace --> health : Report health
internal_http --> metrics : Expose metrics
internal_http --> health : Expose health checks

note right of furnace
  Stateless design
  for horizontal scaling
end note

note bottom of builder
  Implementations:
  - MakepkgBuilder
  - NoOpBuilder
  - BuilderWithMetrics
end note

@enduml