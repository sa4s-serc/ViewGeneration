@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam ArrowColor Black
skinparam defaultTextAlignment center

actor "User" as user

rectangle "Vagrant VM" {
  rectangle "Nomad" as nomad #LightBlue
  rectangle "Consul" as consul #LightGreen
  
  rectangle "MinIO" as minio #Orange
  rectangle "Hive Metastore" as hive #Yellow
  rectangle "Presto" as presto #Pink
  rectangle "SQLPad" as sqlpad #LightCyan
  rectangle "Example CSV Service" as csv #LightGray
  
  user --> sqlpad : SQL Queries
  
  sqlpad --> consul : Service Discovery
  sqlpad --> presto : Execute Queries
  
  presto --> consul : Service Discovery
  presto --> hive : Metadata Lookup
  presto --> minio : Data Access
  
  hive --> consul : Service Discovery
  hive --> minio : Data Access
  
  minio --> consul : Service Discovery
  
  csv --> consul : Service Discovery
  csv --> minio : Data Upload
  
  nomad -[dashed]-> minio : Manage
  nomad -[dashed]-> hive : Manage
  nomad -[dashed]-> presto : Manage
  nomad -[dashed]-> sqlpad : Manage
  nomad -[dashed]-> csv : Manage
  
  consul -[dotted]-> minio : Sidecar Proxy
  consul -[dotted]-> hive : Sidecar Proxy
  consul -[dotted]-> presto : Sidecar Proxy
  consul -[dotted]-> sqlpad : Sidecar Proxy
  consul -[dotted]-> csv : Sidecar Proxy
}

rectangle "Terraform" as terraform #LightPink
rectangle "Ansible" as ansible #LightYellow

ansible --> terraform : Execute
terraform --> nomad : Define Jobs

@enduml