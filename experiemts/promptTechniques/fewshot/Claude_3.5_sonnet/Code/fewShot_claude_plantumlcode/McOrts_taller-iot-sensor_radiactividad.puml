@startuml McOrts_taller-iot-sensor_radiactividad

skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #000000
  RoundCorner 20
}

actor "User" as user
cloud "Internet" as internet

rectangle "ESP8266 (WEMOS D1 mini Pro)" as esp8266 {
  rectangle "Geiger Counter Module" as geiger
  rectangle "Wi-Fi Module" as wifi
  rectangle "Main Application\n(IoT_nuclear_radiation_sensor.ino)" as app
  rectangle "Configuration\n(settings.h)" as config
}

rectangle "MQTT Broker" as mqtt
rectangle "Node-RED" as nodered
rectangle "GMC.MAP Platform" as gmcmap

user --> esp8266 : Configures
geiger --> app : Sends pulses
app --> wifi : Connects
wifi <--> internet : Transmits data
internet <--> mqtt : Publishes/Subscribes
mqtt <--> nodered : Processes data
nodered --> gmcmap : Integrates data

app <-- config : Reads

note right of esp8266
  1. Detects radiation
  2. Calculates CPM
  3. Publishes to MQTT
  4. Receives LED commands
end note

note right of mqtt
  Topics:
  - Radiation data
  - LED control
end note

note right of nodered
  - Data processing
  - Visualization
  - GMC.MAP integration
end note

@enduml