@startuml unnmdnwb3_dora

skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #000000
  RoundCorner 10
}

actor "User/Client" as user

rectangle "Kubernetes Cluster" {
  rectangle "DORA Metrics Service" as dora {
    [API (Gin-Gonic)] as api
    [Metrics Calculation Service] as metrics
    [GitLab Connector] as gitlab
    [Prometheus Connector] as prom
    [MongoDB Service] as mongo_svc
  }
  
  database "MongoDB" as mongodb
  
  rectangle "Prometheus" as prometheus
}

rectangle "GitLab" as gitlab_ext
rectangle "CI/CD Pipelines" as cicd

user -> api : HTTP Requests
api -> metrics : Calculate Metrics
metrics -> gitlab : Fetch Data
metrics -> prom : Query Alerts
metrics <-> mongo_svc : CRUD Operations
mongo_svc <-> mongodb : Persist/Retrieve Data

gitlab -> gitlab_ext : API Calls
prom -> prometheus : Query Metrics

gitlab_ext <-- cicd : Trigger Events
prometheus <-- cicd : Monitor

@enduml