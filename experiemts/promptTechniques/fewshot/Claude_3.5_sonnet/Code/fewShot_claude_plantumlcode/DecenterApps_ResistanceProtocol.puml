@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Frontend (React)" as Frontend {
  [Dashboard]
  [CDP Management]
  [Web3 Connector]
}

rectangle "Smart Contracts (Solidity)" as Contracts {
  [NOI Token]
  [CDP Manager]
  [Price Stabilization]
  [MultiSig Wallet]
}

rectangle "Simulation Engine (Python)" as Simulation {
  [Agent Models]
  [PID Controllers]
  [Market Simulator]
}

rectangle "Backend Services" as Backend {
  [Deployment Scripts]
  [Event Monitors]
  [Liquidation Bot]
}

cloud "External Data" as ExternalData {
  [ETH/USD Oracle]
  [CPI Data Feed]
}

database "Blockchain" as Blockchain

Frontend --> Contracts : Interacts
Contracts --> Blockchain : Deployed on
Backend --> Contracts : Monitors/Interacts
Simulation --> Contracts : Models
Contracts --> ExternalData : Depends on
Backend --> Blockchain : Monitors
@enduml