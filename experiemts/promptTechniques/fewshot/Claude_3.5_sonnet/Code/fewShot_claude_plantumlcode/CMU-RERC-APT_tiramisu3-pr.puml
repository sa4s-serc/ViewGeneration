@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  Style roundrect
}
skinparam arrow {
  Color #666666
  FontColor #333333
}

rectangle "Mobile Client (Ionic/Angular)" as Client {
  [Home Page]
  [Route Page]
  [Stop Page]
  [FavRoutesService]
  [FavStopsService]
  [AlarmService]
  [HandleSettingsService]
  [LocationService]
}

rectangle "Java Frontend" as Frontend {
  [SchedulesForLocationServlet]
  [WriteFavRouteServlet]
  [ReadFavRouteServlet]
  [StatusLogServlet]
  [ButtonLogServlet]
  [FocusLogServlet]
  [AlarmProcessor]
}

rectangle "Backend Data Processing" as Backend {
  [FeedGrabberPAAC]
  [FeedGrabberMTA]
  [ObservationProcessor]
  [DynamoCleaner]
}

rectangle "Python Prediction" as Predictor {
  [Random Forest Model]
}

cloud "AWS Infrastructure" as AWS {
  database "DynamoDB" as DynamoDB
  queue "SQS" as SQS
  [S3]
}

database "PostgreSQL" as Postgres

Client --> Frontend : HTTP Requests
Frontend --> Backend : Fetch Real-time Data
Frontend --> Predictor : Request Predictions
Frontend --> DynamoDB : Read/Write Transit Data
Frontend --> Postgres : Log User Interactions
Backend --> SQS : Push GTFS Data
Backend <-- SQS : Pull GTFS Data
Backend --> DynamoDB : Store Processed Data
Predictor --> Postgres : Read Historical Data
Client ..> AWS : Push Notifications

@enduml