@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

package "HikariKeeper Cluster" {
  rectangle "HikariKeeper Server" as Server1 #lightgreen
  rectangle "HikariKeeper Server" as Server2 #lightgreen
  rectangle "HikariKeeper Server" as Server3 #lightgreen
}

package "Core Components" {
  rectangle "Raft Consensus" as Raft #lightblue
  rectangle "RocksDB Storage" as RocksDB #yellow
  rectangle "Discovery Service" as Discovery #orange
}

package "Client Integration" {
  rectangle "HikariKeeper Client" as Client #pink
  rectangle "Spring Boot Starter" as SpringBoot #lightgrey
}

rectangle "External Applications" as ExternalApps #white

Server1 <--> Server2 : Raft Communication
Server2 <--> Server3 : Raft Communication
Server3 <--> Server1 : Raft Communication

Server1 --> Raft
Server2 --> Raft
Server3 --> Raft

Raft --> RocksDB : Persist State

Server1 --> Discovery
Server2 --> Discovery
Server3 --> Discovery

Client --> Discovery : Locate Servers
SpringBoot --> Client : Integrates

ExternalApps --> Client : API Calls
ExternalApps --> SpringBoot : Spring Integration

@enduml