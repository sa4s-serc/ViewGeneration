@startuml
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam ArrowColor #0000FF
skinparam defaultTextAlignment center

actor "User" as user

rectangle "Angular Frontend" as frontend {
  [Anomaly Detection App] as anomalyApp
  [Management App] as managementApp
}

rectangle "Spring Boot Backend" as backend {
  [REST API Controllers] as controllers
  [Services] as services
  [Web3j Wrappers] as web3j
}

rectangle "Blockchain (Ethereum)" as blockchain {
  [UserStore Contract] as userStore
  [ClientStore Contract] as clientStore
  [AnomalyStore Contract] as anomalyStore
}

rectangle "LwM2M Components" as lwm2m {
  [LwM2M Server] as lwm2mServer
  [Bootstrap Server] as bootstrapServer
  [LwM2M Client] as lwm2mClient
}

database "Database" as db

user --> frontend : interacts
frontend --> backend : HTTP/REST
backend --> blockchain : Web3j
backend --> lwm2m : CoAP
backend <--> db : JDBC

lwm2mServer --> blockchain : reads security info
bootstrapServer --> blockchain : reads security info
lwm2mClient --> lwm2mServer : CoAP
lwm2mClient --> bootstrapServer : CoAP

note right of frontend
  Anomaly Detection
  User Management
  Client Management
end note

note right of backend
  Business Logic
  Blockchain Interaction
  LwM2M Integration
end note

note right of blockchain
  Stores Users
  Stores Clients
  Stores Anomalies
end note

note right of lwm2m
  Device Management
  Data Collection
  Security
end note

@enduml