@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Thingsboard IoT Platform" as Thingsboard

package "GatewayXM" {
  rectangle "Eclipse Kura" as Kura {
    rectangle "Kura-Tb-Bundle" as KuraTbBundle
    rectangle "Asset Service" as AssetService
    rectangle "Modbus Driver" as ModbusDriver
  }
  rectangle "Artemis MQTT Broker" as ArtemisMQTT
  rectangle "Resin.io (Balena)" as Resin
}

rectangle "ModBus Smart Meters" as ModbusMeter
rectangle "ESP8266/ESP32 Sensor Nodes" as SensorNodes {
  rectangle "Arduino Firmware" as ArduinoFirmware
}

Thingsboard <--> KuraTbBundle : Data & OTA Updates
KuraTbBundle --> AssetService
AssetService --> ModbusDriver
ModbusDriver --> ModbusMeter : Read Data

ArtemisMQTT <--> KuraTbBundle : Subscribe
SensorNodes --> ArtemisMQTT : Publish Data
SensorNodes <--> KuraTbBundle : OTA Updates

Resin --> GatewayXM : Manage & Update

note right of SensorNodes
  Mesh Network
end note

note bottom of Resin
  Docker Containers
end note

@enduml