@startuml
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #000000
  FontColor #000000
}

actor "User" as user
rectangle "tap.py" as tap
rectangle "config_vpc.py" as config_vpc
rectangle "blacklist.py" as blacklist
rectangle "whitelist.py" as whitelist
rectangle "ec2_api_client.py" as ec2_api
rectangle "spile_tapper.py" as spile_tapper
rectangle "spile.py" as spile
rectangle "tag_config.py" as tag_config
rectangle "nlb_factory.py" as nlb_factory
rectangle "nlb_target_factory.py" as nlb_target_factory

cloud "AWS EC2 API" as aws_ec2

user --> tap : Initiates
tap --> config_vpc : Configure VPCs
tap --> blacklist : Manage blacklist
tap --> whitelist : Manage whitelist
tap --> spile_tapper : Manage sessions

config_vpc --> tag_config : Store configuration
blacklist --> tag_config : Update instance tags
whitelist --> tag_config : Update instance tags

spile_tapper --> ec2_api : Discover instances
spile_tapper --> spile : Create/manage sessions

spile --> nlb_factory : Create NLB if needed
spile --> nlb_target_factory : Create mirror target
spile --> ec2_api : Create/update mirroring session

ec2_api --> aws_ec2 : Interact with AWS

@enduml