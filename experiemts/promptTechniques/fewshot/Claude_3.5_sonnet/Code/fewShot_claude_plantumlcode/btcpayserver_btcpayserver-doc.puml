@startuml
skinparam rectangle {
  BackgroundColor #EEEBDC
  BorderColor #333333
  FontColor #333333
}
skinparam linetype ortho

rectangle "BTCPay Server Documentation" as docs {
  rectangle "User Guides" as user_guides
  rectangle "Deployment Docs" as deployment
  rectangle "Development Docs" as dev_docs
  rectangle "API Integration" as api
  rectangle "Troubleshooting & FAQ" as faq
  rectangle "Theming" as theming
}

rectangle "VuePress" as vuepress {
  rectangle "Config" as config
  rectangle "Custom Theme" as custom_theme
  rectangle "Markdown Processing" as md_process
}

rectangle "Build & Deployment" as build {
  rectangle "GitHub Actions" as gh_actions
  rectangle "Setup Scripts" as setup_scripts
}

rectangle "External Services" as external {
  rectangle "Bitcoin Core" as btc_core
  rectangle "NBXplorer" as nbxplorer
  rectangle "LND" as lnd
}

rectangle "Deployment Methods" as deploy_methods {
  rectangle "Docker" as docker
  rectangle "Azure" as azure
  rectangle "Manual Install" as manual
}

docs --> vuepress : uses
vuepress --> build : triggers
docs --> deploy_methods : describes
deploy_methods --> external : integrates with
dev_docs --> api : documents
api --> external : interacts with

@enduml