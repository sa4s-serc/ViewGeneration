@startuml nrephi_jupyter-spark-hadoop-docker

skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #000000
  RoundCorner 10
}

rectangle "Docker Environment" {
  rectangle "JupyterLab" as jupyter #LightBlue
  rectangle "Spark Master" as sparkmaster #Orange
  rectangle "Spark Worker 1" as sparkworker1 #Yellow
  rectangle "Spark Worker 2" as sparkworker2 #Yellow
  rectangle "Hadoop NameNode" as namenode #LightGreen
  rectangle "Hadoop DataNode" as datanode #LightGreen
  rectangle "Hive Server" as hiveserver #Pink
  rectangle "Hive Metastore" as hivemetastore #Pink
  database "PostgreSQL\n(Hive Metastore DB)" as postgres #LightGray
  rectangle "Hue" as hue #Purple
  database "MySQL\n(Hue DB)" as mysql #LightGray
}

cloud "Docker Hub" as dockerhub

file "docker-compose.yml" as compose
file "docker-compose-hadoop.yml" as composehadoop
file "Dockerfiles" as dockerfiles
file "build.sh" as buildscript

jupyter -[hidden]-> sparkmaster
sparkmaster --> sparkworker1 : manages
sparkmaster --> sparkworker2 : manages
namenode --> datanode : manages
hiveserver --> hivemetastore : uses
hivemetastore --> postgres : stores metadata
hue --> mysql : stores data
hue --> namenode : interacts
hue --> hiveserver : interacts

compose ..> jupyter : defines
compose ..> sparkmaster : defines
compose ..> sparkworker1 : defines
compose ..> sparkworker2 : defines

composehadoop ..> namenode : defines
composehadoop ..> datanode : defines
composehadoop ..> hiveserver : defines
composehadoop ..> hivemetastore : defines
composehadoop ..> hue : defines
composehadoop ..> mysql : defines
composehadoop ..> postgres : defines

dockerfiles ..> dockerhub : builds or pulls
buildscript ..> dockerfiles : uses

note bottom of jupyter
  Supports Scala, Python (PySpark),
  and R (SparkR) APIs
end note

note bottom of compose
  Defines Spark cluster
  and JupyterLab services
end note

note bottom of composehadoop
  Defines Hadoop ecosystem
  services
end note

@enduml