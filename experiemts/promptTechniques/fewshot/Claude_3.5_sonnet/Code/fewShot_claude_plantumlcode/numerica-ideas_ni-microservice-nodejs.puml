@startuml numerica-ideas_ni-microservice-nodejs

skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
skinparam arrow {
  Color #000000
}

actor "Client" as client

rectangle "API Gateway" as gateway

rectangle "Article Microservice" as article_service {
  rectangle "Express App" as express
  rectangle "Controllers" as controllers
  rectangle "Services" as services
  rectangle "Models" as models
}

database "MongoDB" as mongodb
database "Redis" as redis

cloud "AWS" {
  rectangle "Lambda" as lambda
  queue "SNS" as sns
}

client --> gateway : HTTP Request
gateway --> express : Route Request
express --> controllers : Handle Request
controllers --> services : Process Data
services --> models : CRUD Operations
models --> mongodb : Persist Data
services <--> redis : Cache / Pub-Sub
services <--> sns : Pub-Sub (Lambda)

lambda --> express : Trigger (Lambda)
sns --> lambda : Event (Lambda)

@enduml