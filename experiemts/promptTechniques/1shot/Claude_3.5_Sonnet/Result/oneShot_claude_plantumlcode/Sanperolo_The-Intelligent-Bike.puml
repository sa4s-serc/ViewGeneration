@startuml Sanperolo_The-Intelligent-Bike

actor "User" as user
participant "Angular Frontend" as frontend
participant "Heroku" as heroku
participant "Django Backend" as backend
database "PostgreSQL" as postgres
participant "MQTT Broker" as mqtt
participant "Bike Hardware" as hardware

user -> frontend : Access dashboard
activate frontend

frontend -> heroku : Request data
activate heroku

heroku -> backend : Forward request
activate backend

backend -> postgres : Query sensor data
activate postgres
postgres --> backend : Return data
deactivate postgres

backend --> heroku : Send response
deactivate backend

heroku --> frontend : Return data
deactivate heroku

frontend --> user : Display sensor data
deactivate frontend

hardware -> mqtt : Publish sensor data
activate mqtt

mqtt -> backend : Forward sensor data
activate backend

backend -> postgres : Store sensor data
activate postgres
postgres --> backend : Confirm storage
deactivate postgres

backend --> mqtt : Acknowledge receipt
deactivate backend

mqtt --> hardware : Confirm delivery
deactivate mqtt

@enduml