@startuml caraml-dev_turing

actor User
participant "Python SDK" as SDK
participant "Turing API" as API
participant "Router Engine" as Router
participant "Experiment Engine" as Experiment
participant "Ensembler Engine" as Ensembler
participant "Batch Job Manager" as BatchJob
database "Kubernetes" as K8s
database "Logging Backend" as LoggingBackend

User -> SDK : Create/manage project
SDK -> API : Send API request
API -> Router : Create/update router

User -> SDK : Deploy experiment
SDK -> API : Send API request
API -> Experiment : Configure experiment
Experiment -> Router : Register experiment

User -> SDK : Create ensembler
SDK -> API : Send API request
API -> Ensembler : Configure ensembler

User -> SDK : Submit batch job
SDK -> API : Send API request
API -> BatchJob : Submit Spark job
BatchJob -> K8s : Deploy Spark on K8s

Router -> Experiment : Route traffic
Experiment -> Ensembler : Get model predictions
Ensembler -> LoggingBackend : Log results

API -> K8s : Manage resources
K8s --> API : Resource status

@enduml