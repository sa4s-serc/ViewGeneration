@startuml xydo1990_mlops_zoomcamp_homework

actor User
participant "GitHub Actions" as GH
participant "MLflow" as MLflow
participant "Prefect" as Prefect
participant "Batch Prediction Service" as BatchService
participant "Stream Prediction Service" as StreamService
participant "Evidently Monitoring" as Evidently
database "MongoDB" as MongoDB
database "S3" as S3

User -> GH : Push code
GH -> GH : Run CI tests

User -> MLflow : Train model
MLflow -> S3 : Store model artifacts
MLflow -> MLflow : Register model

User -> Prefect : Deploy batch flow
Prefect -> BatchService : Trigger batch prediction
BatchService -> MLflow : Load model
BatchService -> S3 : Get input data
BatchService -> MongoDB : Store predictions
BatchService -> Evidently : Send metrics

User -> StreamService : Send streaming data
StreamService -> MLflow : Load model
StreamService -> StreamService : Make predictions
StreamService -> Evidently : Send metrics

Evidently -> MongoDB : Store monitoring results
Evidently -> Evidently : Generate reports

User -> Evidently : View monitoring dashboard

@enduml