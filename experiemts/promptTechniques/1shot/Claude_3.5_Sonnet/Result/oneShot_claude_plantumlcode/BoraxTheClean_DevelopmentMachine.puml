@startuml BoraxTheClean_DevelopmentMachine

actor Developer
participant "GitHub Actions" as GHA
participant "AWS CloudFormation" as CF
participant "EC2 Instance" as EC2
participant "CloudWatch" as CW
participant "IAM" as IAM
participant "Security Group" as SG

Developer -> GHA : Push changes
activate GHA

GHA -> CF : Deploy stack
activate CF

CF -> IAM : Create IAM role with\nAdministratorAccess
activate IAM
IAM --> CF : Role created
deactivate IAM

CF -> SG : Create security group\nallowing all IPs
activate SG
SG --> CF : Security group created
deactivate SG

CF -> EC2 : Launch instance with\nIAM role and security group
activate EC2
EC2 --> CF : Instance launched
deactivate EC2

CF -> CW : Create inactivity alarm
activate CW
CW --> CF : Alarm created
deactivate CW

CF --> GHA : Stack deployed
deactivate CF

GHA --> Developer : Deployment complete
deactivate GHA

Developer -> EC2 : SSH access (from any IP)
activate EC2
EC2 --> Developer : Access granted
deactivate EC2

CW -> EC2 : Monitor inactivity
activate CW
CW -> EC2 : Stop instance after 1 hour inactivity
deactivate CW
destroy EC2

@enduml