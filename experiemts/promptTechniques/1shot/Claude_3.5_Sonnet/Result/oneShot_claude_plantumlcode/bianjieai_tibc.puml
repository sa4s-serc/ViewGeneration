@startuml
skinparam component {
  BackgroundColor<<core>> #CCFFCC
  BackgroundColor<<client>> #FFFFCC
  BackgroundColor<<app>> #CCCCFF
  BackgroundColor<<relayer>> #FFCCCC
}

package "TIBC Core" <<core>> {
  [Client Semantics] as CS
  [Port & Packet Semantics] as PPS
  [Host Environments] as HE
  [Packet Routing] as PR
}

package "Client Implementations" <<client>> {
  [Tendermint Client] as TC
  [BSC Client] as BSCC
  [Ethereum Client] as EC
}

package "Applications" <<app>> {
  [NFT Transfer] as NFT
}

package "Relayer" <<relayer>> {
  [Relayer Algorithms] as RA
}

[Routing Module] as RM

CS --> TC
CS --> BSCC
CS --> EC
PPS --> RA
HE --> RA
PR --> RM
RM --> NFT
RA --> RM

@enduml