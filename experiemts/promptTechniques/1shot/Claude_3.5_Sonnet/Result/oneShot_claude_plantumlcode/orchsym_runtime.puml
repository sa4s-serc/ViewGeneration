@startuml orchsym_runtime

skinparam component {
  BackgroundColor<<core>> #DDFFDD
  BackgroundColor<<infrastructure>> #DDDDFF
  BackgroundColor<<security>> #FFDDDD
  BackgroundColor<<integration>> #FFFFDD
  BackgroundColor<<orchsym>> #FFDDFF
}

package "Core Framework" {
  [FlowController] <<core>>
  [ProcessSession] <<core>>
  [FlowFile] <<core>>
  [Connection] <<core>>
  [ProcessScheduler] <<core>>
  [FlowSynchronizer] <<core>>
  [FlowFileQueue] <<core>>
  [StateManagerProvider] <<core>>
}

package "Infrastructure" {
  [FlowFile Repository] <<infrastructure>>
  [Content Repository] <<infrastructure>>
  [Provenance Repository] <<infrastructure>>
  [ControllerServiceProvider] <<infrastructure>>
  [REST API] <<infrastructure>>
  [Site-to-Site] <<infrastructure>>
  [Web UI] <<infrastructure>>
}

package "Security" {
  [Login Identity Provider] <<security>>
  [Authorizer] <<security>>
  [SSLContextService] <<security>>
  [Sensitive Property Encryption] <<security>>
}

package "Integration" {
  [NAR Bundles] <<integration>>
  [Scripting Support] <<integration>>
  [External System Connectors] <<integration>>
  [Schema Registry] <<integration>>
}

package "Cluster Management" {
  [ClusterCoordinator] <<core>>
  [ZooKeeper] <<infrastructure>>
}

package "Orchsym Runtime" {
  [Branding Extension] <<orchsym>>
  [Custom Login Provider] <<orchsym>>
  [Usage Data Collection] <<orchsym>>
}

[FlowController] --> [ProcessSession]
[FlowController] --> [FlowFile]
[FlowController] --> [Connection]
[FlowController] --> [ProcessScheduler]
[FlowController] --> [FlowSynchronizer]
[FlowController] --> [FlowFileQueue]
[FlowController] --> [StateManagerProvider]

[ControllerServiceProvider] --> [FlowController]
[REST API] --> [FlowController]
[Site-to-Site] --> [FlowController]
[Web UI] --> [REST API]

[Login Identity Provider] --> [FlowController]
[Authorizer] --> [FlowController]
[SSLContextService] --> [FlowController]

[NAR Bundles] --> [FlowController]
[Scripting Support] --> [FlowController]
[External System Connectors] --> [FlowController]
[Schema Registry] --> [FlowController]

[ClusterCoordinator] --> [FlowController]
[ZooKeeper] --> [ClusterCoordinator]

[Branding Extension] --> [FlowController]
[Custom Login Provider] --> [Login Identity Provider]
[Usage Data Collection] --> [FlowController]

@enduml