@startuml afonsocastro_larcc_interface

skinparam component {
  BackgroundColor<<ROS>> LightSkyBlue
  BackgroundColor<<Hardware>> LightGreen
  BackgroundColor<<Software>> LightYellow
}

[UR10e Robot] <<Hardware>>
[RealSense Camera] <<Hardware>>
[ROBOTIQ 2F-140 Gripper] <<Hardware>>

package "ROS Environment" <<ROS>> {
  [MoveIt!]
  [RViz]
  [ur_robot_driver]
  [realsense2_camera]
  [ur10e_moveit_config]
}

package "LARCC Control System" <<Software>> {
  [UR10e Control Interface]
  [Robot Kinematics]
  [LARCC Workcell Description]
  [3D Model Definitions]
}

[UR10e Control Interface] --> [UR10e Robot]
[UR10e Control Interface] --> [ROBOTIQ 2F-140 Gripper]
[Robot Kinematics] --> [MoveIt!]
[LARCC Workcell Description] --> [RViz]
[3D Model Definitions] --> [RViz]

[realsense2_camera] --> [RealSense Camera]
[ur_robot_driver] --> [UR10e Robot]

[MoveIt!] --> [ur10e_moveit_config]
[RViz] --> [ur10e_moveit_config]

@enduml