@startuml bluekiri_mlab

skinparam component {
  BackgroundColor<<Dashboard>> #CCFFCC
  BackgroundColor<<Worker>> #CCCCFF
  BackgroundColor<<External>> #FFCCCC
}

package "MLAB System" {
  component "Dashboard" <<Dashboard>> {
    [Flask App]
    [Data Access Layer]
    [Interactors]
    [API Endpoints]
    [Frontend]
    [Model Publisher]
  }

  component "Worker Service" <<Worker>> {
    [Model Loader]
    [ZooKeeper Integration]
    [Error Handler]
    [HTTP API]
  }

  database "MongoDB" <<External>>
  component "ZooKeeper" <<External>>

  [Flask App] --> [Data Access Layer]
  [Flask App] --> [Interactors]
  [Flask App] --> [API Endpoints]
  [Flask App] --> [Frontend]
  [Flask App] --> [Model Publisher]

  [Data Access Layer] --> MongoDB
  [Data Access Layer] --> ZooKeeper

  [Model Loader] --> MongoDB
  [ZooKeeper Integration] --> ZooKeeper
  [HTTP API] --> [Model Loader]

  [Interactors] ..> [ZooKeeper Integration] : communicates
  [Model Publisher] ..> [ZooKeeper Integration] : publishes models
}

@enduml