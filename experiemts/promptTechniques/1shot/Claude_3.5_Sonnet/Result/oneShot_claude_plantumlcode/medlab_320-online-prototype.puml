@startuml medlab_320-online-prototype

skinparam componentStyle uml2

[React Frontend] as Frontend
[.NET 5 Backend] as Backend
[Authentication Service] as AuthService
[Logging Service] as LogService
[Tracing Service] as TraceService
[MinIO Object Storage] as ObjectStorage
database "Database" as DB

cloud "External Services" {
  [OAuth/OIDC Provider] as OAuthProvider
  [Elasticsearch] as ES
  [Fluentd] as Fluentd
  [Kibana] as Kibana
  [Zipkin] as Zipkin
}

Frontend --> Backend : HTTP/REST
Backend --> DB : Entity Framework Core
Backend --> ObjectStorage : S3 API
Backend --> AuthService : JWT/OAuth
Backend --> LogService : Logging
Backend --> TraceService : Distributed Tracing

AuthService --> OAuthProvider : Authenticate
LogService --> Fluentd : Send Logs
Fluentd --> ES : Index Logs
ES <-- Kibana : Visualize

TraceService --> Zipkin : Report Traces

note right of Frontend
  - React Router
  - Redux
  - Ant Design
  - Mock.js
end note

note right of Backend
  - ASP.NET Core Identity
  - Entity Framework Core
  - Serilog
  - Custom Middleware
end note

note bottom of AuthService
  Handles JWT, OAuth, OIDC
end note

note bottom of LogService
  EFK Stack (Elasticsearch, 
  Fluentd, Kibana)
end note

note bottom of TraceService
  OpenTelemetry
  SkyWalking
end note

@enduml