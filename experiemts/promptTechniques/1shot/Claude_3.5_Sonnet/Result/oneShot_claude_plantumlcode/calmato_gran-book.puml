@startuml calmato_gran-book

skinparam component {
  BackgroundColor<<UI>> LightBlue
  BackgroundColor<<API>> LightGreen
  BackgroundColor<<Service>> LightYellow
  BackgroundColor<<Database>> LightGray
}

[Web Admin Panel] <<UI>> as WebAdmin
[Native App] <<UI>> as NativeApp
[API Gateway] <<API>> as Gateway
[Auth Service] <<Service>> as AuthService
[User Service] <<Service>> as UserService
[Book Service] <<Service>> as BookService
[Chat Service] <<Service>> as ChatService
[Image Service] <<Service>> as ImageService
database "SQL Database" <<Database>> as DB
[Firebase] <<Service>> as Firebase

WebAdmin --> Gateway : HTTP/REST
NativeApp --> Gateway : HTTP/REST
Gateway --> AuthService : gRPC
Gateway --> UserService : gRPC
Gateway --> BookService : gRPC
Gateway --> ChatService : gRPC
Gateway --> ImageService : gRPC

AuthService --> Firebase : Authenticate
AuthService --> DB : Read/Write
UserService --> DB : Read/Write
BookService --> DB : Read/Write
ChatService --> DB : Read/Write
ImageService --> DB : Read/Write

@enduml