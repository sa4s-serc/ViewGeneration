@startuml nrephi_jupyter-spark-hadoop-docker

!define RECTANGLE class

skinparam component {
  BackgroundColor<<Core>> LightBlue
  BackgroundColor<<Hadoop>> LightGreen
  BorderColor Black
  ArrowColor Black
}

rectangle "Docker Environment" {
  component "JupyterLab" as jupyter <<Core>>
  component "Spark Master" as sparkmaster <<Core>>
  component "Spark Worker" as sparkworker <<Core>>
  component "MySQL" as mysql <<Core>>

  component "Hadoop NameNode" as namenode <<Hadoop>>
  component "Hadoop DataNode" as datanode <<Hadoop>>
  component "Hive Metastore" as hivemeta <<Hadoop>>
  component "Hive Server" as hiveserver <<Hadoop>>
  component "Hue" as hue <<Hadoop>>
  component "PostgreSQL" as postgres <<Hadoop>>

  [Shared Workspace] as workspace
}

jupyter --> sparkmaster : submits jobs
sparkmaster --> sparkworker : assigns tasks
jupyter --> workspace : reads/writes data
sparkworker --> workspace : reads/writes data

namenode --> datanode : manages
hiveserver --> hivemeta : uses
hivemeta --> postgres : stores metadata
hue --> mysql : stores metadata
hue --> namenode : interacts
hue --> hiveserver : interacts

@enduml