@startuml FPriv_factom-harmony-connect-python-sdk

skinparam component {
  BackgroundColor<<SDK>> LightBlue
  BackgroundColor<<API>> LightGreen
  BackgroundColor<<Utility>> LightYellow
}

package "Factom Harmony Connect API Python SDK" {
  [FactomClient] <<SDK>>
  
  package "Client Components" {
    [ChainsClient] <<SDK>>
    [EntriesClient] <<SDK>>
    [IdentitiesClient] <<SDK>>
    [ApiInfoClient] <<SDK>>
    [ReceiptsClient] <<SDK>>
    [AnchorsClient] <<SDK>>
  }
  
  package "Utilities" {
    [Utils] <<Utility>>
    [KeyCommon] <<Utility>>
    [ValidateSignatureUtil] <<Utility>>
    [CommonUtil] <<Utility>>
  }
  
  [RequestHandler] <<SDK>>
}

[Factom Harmony Connect API] <<API>>

FactomClient --> ChainsClient
FactomClient --> EntriesClient
FactomClient --> IdentitiesClient
FactomClient --> ApiInfoClient
FactomClient --> ReceiptsClient
FactomClient --> AnchorsClient

FactomClient --> RequestHandler
RequestHandler --> [Factom Harmony Connect API]

ChainsClient --> Utils
ChainsClient --> KeyCommon
ChainsClient --> ValidateSignatureUtil
ChainsClient --> CommonUtil

EntriesClient --> Utils
EntriesClient --> KeyCommon
EntriesClient --> ValidateSignatureUtil
EntriesClient --> CommonUtil

IdentitiesClient --> Utils
IdentitiesClient --> KeyCommon

[Sample Notary Application] ..> FactomClient : uses

@enduml