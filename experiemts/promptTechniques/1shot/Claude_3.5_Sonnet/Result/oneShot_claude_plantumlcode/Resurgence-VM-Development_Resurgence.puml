@startuml Resurgence-VM-Development_Resurgence

skinparam component {
  BackgroundColor<<core>> #DDEBF7
  BackgroundColor<<bytecode>> #E2EFDA
  BackgroundColor<<ffi>> #FFF2CC
  BackgroundColor<<instruction>> #FCE4D6
  BackgroundColor<<error>> #F2F2F2
  BackgroundColor<<codegen>> #EDEDED
}

package "Resurgence VM" {
  [Virtual Machine Core] <<core>>
  [Bytecode Handler] <<bytecode>>
  [FFI (Foreign Function Interface)] <<ffi>>
  [Instruction Set] <<instruction>>
  [Error Handler] <<error>>
  [Code Generator] <<codegen>>
}

[Virtual Machine Core] --> [Bytecode Handler]
[Virtual Machine Core] --> [Instruction Set]
[Virtual Machine Core] --> [FFI (Foreign Function Interface)]
[Virtual Machine Core] --> [Error Handler]

[Bytecode Handler] ..> [Code Generator] : uses
[FFI (Foreign Function Interface)] ..> [Error Handler] : uses

component "External Applications" as ExtApps

ExtApps ..> [FFI (Foreign Function Interface)] : embeds

note right of [Virtual Machine Core]
  Manages interpreter, execution engine,
  memory, and instruction processing
end note

note bottom of [Bytecode Handler]
  Reads and writes bytecode files
end note

note bottom of [FFI (Foreign Function Interface)]
  Enables interaction with external code (C)
end note

note bottom of [Instruction Set]
  Defines VM operations
end note

note bottom of [Error Handler]
  Provides detailed error reporting
end note

note bottom of [Code Generator]
  Supports programmatic bytecode generation
end note

@enduml