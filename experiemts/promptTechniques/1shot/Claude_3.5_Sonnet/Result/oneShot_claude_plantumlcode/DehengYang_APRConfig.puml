@startuml DehengYang_APRConfig

actor User
participant "Run_d4j_1.py" as Main
participant "Config.py" as Config
participant "Dataset/Defects4j.py" as Dataset
participant "Localization/Gzoltar.py" as Localizer
participant "Apr/SimFix.py" as SimFix
participant "Apr/TBar.py" as TBar
participant "Apr/Nopol.py" as Nopol
participant "Apr/DynamoTH.py" as DynamoTH
participant "Main_parse.py" as Parser

User -> Main : Execute
activate Main

Main -> Config : Load configuration
activate Config
Config --> Main : Configuration loaded
deactivate Config

Main -> Dataset : Initialize dataset
activate Dataset
Dataset --> Main : Dataset ready
deactivate Dataset

loop For each bug in dataset
    Main -> Localizer : Localize fault
    activate Localizer
    Localizer --> Main : Fault locations
    deactivate Localizer
    
    Main -> SimFix : Generate patch
    activate SimFix
    SimFix --> Main : Patch generated
    deactivate SimFix
    
    Main -> TBar : Generate patch
    activate TBar
    TBar --> Main : Patch generated
    deactivate TBar
    
    Main -> Nopol : Generate patch
    activate Nopol
    Nopol --> Main : Patch generated
    deactivate Nopol
    
    Main -> DynamoTH : Generate patch
    activate DynamoTH
    DynamoTH --> Main : Patch generated
    deactivate DynamoTH
    
    Main -> Main : Validate patches
end

Main -> Parser : Parse repair data
activate Parser
Parser --> Main : Results in CSV
deactivate Parser

Main --> User : Execution complete
deactivate Main

@enduml