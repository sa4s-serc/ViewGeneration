@startuml itselavia_edge-computing-platform-for-deep-learning-apps

actor User
participant "React Frontend" as Frontend
participant "Flask Backend" as Backend
participant "Model Manager" as ModelManager
participant "Kubernetes/KubeEdge" as K8s
participant "Google Cloud Storage" as GCS
participant "Cloud SQL" as SQL
participant "TFLite Converter" as TFLiteConverter
participant "Edge Device" as Edge

User -> Frontend : Upload model
Frontend -> Backend : POST /upload
Backend -> GCS : Store model
Backend -> SQL : Store metadata
Backend -> ModelManager : Deploy model request

ModelManager -> TFLiteConverter : Convert to TFLite
TFLiteConverter --> ModelManager : TFLite model

ModelManager -> K8s : Create deployment
K8s -> Edge : Deploy TFLite model

User -> Frontend : Request inference
Frontend -> Backend : POST /inference
Backend -> K8s : Forward request
K8s -> Edge : Perform inference
Edge --> K8s : Inference result
K8s --> Backend : Return result
Backend --> Frontend : Display result
Frontend --> User : Show inference output

@enduml