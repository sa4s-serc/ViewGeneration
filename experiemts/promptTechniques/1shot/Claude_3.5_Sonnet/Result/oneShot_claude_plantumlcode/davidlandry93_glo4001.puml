@startuml davidlandry93_glo4001

skinparam component {
  BackgroundColor<<3D>> LightBlue
  BackgroundColor<<Robotic>> LightGreen
  BackgroundColor<<Data>> LightYellow
}

[3D Rendering Core] <<3D>> as 3DCore
[Potree] <<3D>> as Potree
[Three.js] <<3D>> as ThreeJS
[WebGL Renderer] <<3D>> as WebGL
[Shader System] <<3D>> as ShaderSystem

[Robot Control] <<Robotic>> as RobotControl
[Sensor Data Acquisition] <<Robotic>> as SensorData
[ROS Integration] <<Robotic>> as ROS

[Point Cloud Processing] <<Data>> as PointCloud
[CZML Processing] <<Data>> as CZML
[Geometric Data Handling] <<Data>> as GeometricData

database "LAS/LAZ Files" as LASLAZ

3DCore --> Potree
3DCore --> ThreeJS
3DCore --> WebGL
3DCore --> ShaderSystem

RobotControl --> ROS
SensorData --> ROS

PointCloud --> 3DCore
CZML --> 3DCore
GeometricData --> 3DCore

SensorData --> PointCloud
LASLAZ --> PointCloud

RobotControl <--> SensorData

@enduml