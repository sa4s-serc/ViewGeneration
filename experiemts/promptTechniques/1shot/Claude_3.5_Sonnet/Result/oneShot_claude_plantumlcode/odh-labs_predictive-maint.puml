@startuml odh-labs_predictive-maint

actor "DevOps Engineer" as DevOps
participant "ocp_deploy.py" as DeployScript
participant "OpenShift CLI (oc)" as OC
participant "Kubernetes API" as K8sAPI
participant "OpenShift Cluster" as Cluster
participant "Seldon Core" as Seldon
participant "Kafka" as Kafka
participant "MinIO" as MinIO
participant "Consumer App" as Consumer
participant "Model Server" as ModelServer

DevOps -> DeployScript : Run deployment script
activate DeployScript

DeployScript -> OC : Build Docker image
activate OC
OC -> Cluster : Push image to registry
Cluster --> OC : Image pushed
OC --> DeployScript : Image build complete
deactivate OC

DeployScript -> K8sAPI : Apply Seldon Deployment YAML
activate K8sAPI
K8sAPI -> Seldon : Create SeldonDeployment
Seldon -> ModelServer : Deploy model
ModelServer --> Seldon : Model deployed
Seldon --> K8sAPI : Deployment created
K8sAPI --> DeployScript : Seldon deployment complete
deactivate K8sAPI

DeployScript -> K8sAPI : Apply Kafka YAML
activate K8sAPI
K8sAPI -> Kafka : Deploy Kafka cluster
Kafka --> K8sAPI : Kafka deployed
K8sAPI --> DeployScript : Kafka deployment complete
deactivate K8sAPI

DeployScript -> K8sAPI : Apply MinIO YAML
activate K8sAPI
K8sAPI -> MinIO : Deploy MinIO instance
MinIO --> K8sAPI : MinIO deployed
K8sAPI --> DeployScript : MinIO deployment complete
deactivate K8sAPI

DeployScript -> K8sAPI : Apply Consumer Deployment YAML
activate K8sAPI
K8sAPI -> Consumer : Deploy Consumer app
Consumer --> K8sAPI : Consumer deployed
K8sAPI --> DeployScript : Consumer deployment complete
deactivate K8sAPI

DeployScript -> OC : Create OpenShift Route
activate OC
OC -> Cluster : Expose model service
Cluster --> OC : Route created
OC --> DeployScript : Route creation complete
deactivate OC

DeployScript --> DevOps : Deployment completed

deactivate DeployScript

@enduml