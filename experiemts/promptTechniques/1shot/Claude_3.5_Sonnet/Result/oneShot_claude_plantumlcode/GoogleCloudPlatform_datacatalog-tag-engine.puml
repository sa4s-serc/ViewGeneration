@startuml GoogleCloudPlatform_datacatalog-tag-engine

!define GCPPuml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

!includeurl GCPPuml/C4_Container.puml

skinparam component {
  BackgroundColor<<API>> LightBlue
  BackgroundColor<<UI>> LightGreen
}

cloud "Google Cloud Platform" {
  Container(cloudRunAPI, "Cloud Run API", "API Service", "Handles API requests")
  Container(cloudRunUI, "Cloud Run UI", "UI Service", "Serves web interface")
  ContainerDb(firestore, "Firestore", "NoSQL Database", "Stores configurations")
  ContainerDb(gcs, "Cloud Storage", "Object Storage", "Stores CSV files for import")
  ContainerDb(bigquery, "BigQuery", "Data Warehouse", "Stores exported tags and history")
  Container(cloudTasks, "Cloud Tasks", "Task Queue", "Manages async jobs")
  Container(dataCatalog, "Data Catalog", "Metadata Service", "Manages tags")
  Container(dataplex, "Dataplex", "Data Management", "Manages aspects")

  Component(apiService, "API Service", "Python/Flask", "Handles API requests")
  Component(uiService, "UI Service", "Python/Jinja2", "Serves web interface")

  Rel(cloudRunAPI, apiService, "Hosts")
  Rel(cloudRunUI, uiService, "Hosts")
  
  Rel(apiService, firestore, "Stores/retrieves configs")
  Rel(apiService, gcs, "Imports CSV")
  Rel(apiService, bigquery, "Exports tags")
  Rel(apiService, cloudTasks, "Creates jobs")
  Rel(apiService, dataCatalog, "Manages tags")
  Rel(apiService, dataplex, "Manages aspects")
  
  Rel(uiService, apiService, "Makes API calls")
}

@enduml