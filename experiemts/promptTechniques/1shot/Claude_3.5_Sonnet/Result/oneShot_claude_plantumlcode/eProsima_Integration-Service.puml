@startuml eProsima_Integration-Service

actor User
participant "Configuration Parser" as ConfigParser
participant "Integration Service Core" as ISCore
participant "System Handle A" as SHA
participant "System Handle B" as SHB
database "Middleware A" as MWA
database "Middleware B" as MWB

User -> ConfigParser : Load YAML config
activate ConfigParser
ConfigParser -> ISCore : Parse and create routes
deactivate ConfigParser

activate ISCore
ISCore -> SHA : Create and initialize
ISCore -> SHB : Create and initialize
activate SHA
activate SHB

loop For each configured route
    alt Publish-Subscribe Route
        SHA -> MWA : Subscribe to topic
        MWA --> SHA : Receive data
        SHA -> ISCore : Convert data (JSON <-> xtypes)
        ISCore -> SHB : Forward converted data
        SHB -> MWB : Publish data
    else Service Route
        MWA -> SHA : Receive service request
        SHA -> ISCore : Convert request (JSON <-> xtypes)
        ISCore -> SHB : Forward converted request
        SHB -> MWB : Call service
        MWB --> SHB : Service response
        SHB -> ISCore : Convert response (JSON <-> xtypes)
        ISCore -> SHA : Forward converted response
        SHA -> MWA : Send service response
    end
end

@enduml