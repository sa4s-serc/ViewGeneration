@startuml xinsongyan_talos_pal_locomotion_slmc

actor User
participant "ROS Node" as ROS
participant "DCM Controller" as DCM
participant "WBC Plugin" as WBC
participant "State Estimator" as StateEst
participant "Safety Layer" as Safety
participant "TALOS Robot" as Robot

User -> ROS : Start locomotion controller
activate ROS

ROS -> DCM : Initialize
activate DCM

ROS -> WBC : Load plugin
activate WBC

ROS -> StateEst : Initialize
activate StateEst

ROS -> Safety : Initialize
activate Safety

loop Control Loop
    StateEst -> Robot : Get sensor data
    StateEst --> ROS : Provide state estimate
    
    ROS -> DCM : Generate walking pattern
    DCM --> ROS : Provide reference trajectory
    
    ROS -> WBC : Execute whole-body control
    WBC -> Safety : Check safety constraints
    Safety --> WBC : Approve/modify commands
    
    WBC -> Robot : Send joint commands
    
    Robot --> StateEst : Update state
end

User -> ROS : Stop locomotion controller
ROS -> DCM : Terminate
deactivate DCM
ROS -> WBC : Unload plugin
deactivate WBC
ROS -> StateEst : Terminate
deactivate StateEst
ROS -> Safety : Terminate
deactivate Safety
ROS -> Robot : Stop movement

deactivate ROS

@enduml