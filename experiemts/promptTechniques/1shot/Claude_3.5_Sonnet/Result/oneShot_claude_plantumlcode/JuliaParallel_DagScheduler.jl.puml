@startuml JuliaParallel_DagScheduler.jl

skinparam component {
  BackgroundColor<<core>> LightBlue
  BackgroundColor<<scheduling>> LightGreen
  BackgroundColor<<execution>> LightSalmon
  BackgroundColor<<metadata>> LightYellow
  BackgroundColor<<plugin>> LightGray
}

[DagScheduler.jl] <<core>> as main
[Scheduler] <<scheduling>> as scheduler
[Execution Engine] <<execution>> as engine
[Queue Manager] <<execution>> as queue
[Metadata Store] <<metadata>> as metastore
[Dagger.jl Plugin] <<plugin>> as plugin

interface "Data Locality" as locality
interface "Async Execution" as async
interface "Fault Tolerance" as fault

main --> scheduler : uses
main --> engine : coordinates
main --> queue : manages
main --> metastore : tracks state
main --> plugin : integrates

scheduler ..> locality : considers
engine ..> async : implements
engine ..> fault : handles

queue --> engine : feeds tasks

database "ShmemMetaStore" as shmem
database "SimpleMetaStore" as simple
database "FDBMetaStore" as fdb

metastore --> shmem : implements
metastore --> simple : implements
metastore --> fdb : implements

node "Node" {
  [Broker] as broker
  [Executor] as executor
  broker --> executor : coordinates
}

main --> broker : manages
broker --> queue : steals tasks

@enduml