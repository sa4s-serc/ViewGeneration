@startuml ra1028_VueFlux

skinparam component {
  BackgroundColor<<core>> #DDEBF7
  BackgroundColor<<reactive>> #E2F0D9
  BorderColor Black
  ArrowColor Black
}

package "VueFlux" {
  component "Store" <<core>> {
    [State]
    [Mutations]
    [Actions]
    [Computed]
  }
  
  component "Executor" <<core>>
  component "AtomicReference" <<core>>
}

package "VueFluxReactive" {
  component "Variable" <<reactive>>
  component "Constant" <<reactive>>
  component "Sink" <<reactive>>
  component "Signal" <<reactive>>
  component "Binder" <<reactive>>
}

component "UI Components" as UI

[Actions] --> [Mutations]
[Mutations] --> [State]
[State] --> [Computed]
[Computed] --> UI

[Store] --> [Executor]
[Store] --> [AtomicReference]

UI --> [Binder]
[Binder] --> [Signal]
[Signal] --> [Sink]
[Variable] --> [Signal]
[Constant] --> [Signal]

@enduml