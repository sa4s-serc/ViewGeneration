@startuml gaiax_fLibra

actor User

participant "Frontend (Nuxt.js)" as Frontend
participant "Vuex Store" as Vuex
participant "Web3.js" as Web3
participant "Firebase/Firestore" as Firebase
participant "IPFS" as IPFS
participant "Ethereum Smart Contract" as EthContract
participant "Libra Network" as Libra
participant "Elasticsearch" as Elastic
participant "Elasticsearch Integration (Node.js)" as ElasticIntegration

User -> Frontend : Interacts with UI

Frontend -> Vuex : Manage state
Frontend <-> Web3 : Interact with blockchain

Frontend -> Firebase : Store/retrieve data
Frontend -> IPFS : Store/retrieve images

Web3 <-> EthContract : Execute contract functions

Frontend -> Libra : Transfer Libra coins

Frontend -> Elastic : Search items

Firebase --> ElasticIntegration : Trigger onSnapshot
ElasticIntegration -> Elastic : Update index

EthContract --> Frontend : Emit events
Libra --> Frontend : Confirm transactions

Frontend --> User : Update UI

@enduml