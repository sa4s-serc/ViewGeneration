@startuml david3107_squatm3gator

skinparam component {
  BackgroundColor<<frontend>> LightBlue
  BackgroundColor<<backend>> LightGreen
  BackgroundColor<<infrastructure>> LightYellow
}

cloud "User's Browser" {
  [Web UI] <<frontend>>
}

package "SquatM3gator Application" {
  component "Frontend" <<frontend>> {
    [HTML/CSS/JS]
    [Socket.IO Client]
  }

  component "Backend" <<backend>> {
    [Flask App]
    [Socket.IO Server]
    [API Endpoints]
    [Job Queue Producer]
    [Domain Generation Modules]
    [GoDaddy API Checker]
    [WHOIS Lookup]
  }

  component "Worker" <<backend>> {
    [Job Queue Consumer]
    [Squatm3 Core]
  }

  database "Redis" {
    [Message Queue]
    [Session Store]
  }

  component "Infrastructure" <<infrastructure>> {
    [Docker]
    [Docker Compose]
  }
}

[Web UI] --> [HTML/CSS/JS] : HTTPS
[HTML/CSS/JS] --> [Socket.IO Client] : Real-time updates
[Socket.IO Client] <--> [Socket.IO Server] : Bidirectional
[Flask App] --> [API Endpoints]
[Flask App] --> [Job Queue Producer]
[Job Queue Producer] --> [Message Queue] : Enqueue jobs
[Job Queue Consumer] <-- [Message Queue] : Dequeue jobs
[Job Queue Consumer] --> [Squatm3 Core]
[Squatm3 Core] --> [Domain Generation Modules]
[Squatm3 Core] --> [GoDaddy API Checker]
[Squatm3 Core] --> [WHOIS Lookup]
[Flask App] --> [Session Store]

note right of [GoDaddy API Checker]
  Requires API keys
  Implement rate limiting
end note

note right of [API Endpoints]
  Input validation
  Error handling
end note

note bottom of [Docker]
  Containerized deployment
end note

@enduml