@startuml

actor "User" as user
participant "GitHub Repository" as repo
participant "Use Case README" as usecase
participant "AWS Services" as aws
participant "External Resources" as external

user -> repo : Access repository
repo -> user : Display overview and categories

user -> repo : Select use case
repo -> usecase : Retrieve use case details

usecase -> user : Display problem statement
usecase -> user : Show proposed solution
usecase -> user : Provide implementation steps

user -> aws : Deploy solution
aws -> user : Provide runtime feedback

user -> usecase : Access metadata
usecase -> external : Link to documentation/courses
external -> user : Provide additional learning

user -> repo : Contribute new use case
repo -> user : Provide contribution template
user -> repo : Submit new use case
repo -> user : Review and merge contribution

@enduml