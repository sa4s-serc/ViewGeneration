@startuml Crazy0416_KnowledgeGraph

actor User
participant "UI Components" as UI
participant "Graph Visualization" as GraphViz
participant "Search Engine" as Search
participant "Graph Manipulation" as GraphManip
participant "Pathfinding" as Path
participant "Layout Management" as Layout
database "Elasticsearch" as ES
database "CayleyGraph" as CG

User -> UI : Interact
activate UI

UI -> Search : Enter keywords
activate Search
Search -> ES : Query data
ES --> Search : Return results
Search -> GraphViz : Visualize results
deactivate Search

UI -> GraphManip : Manipulate graph
activate GraphManip
GraphManip -> GraphViz : Update visualization
deactivate GraphManip

UI -> Path : Find path between nodes
activate Path
Path -> CG : Query graph data
CG --> Path : Return graph data
Path -> Path : Apply A* algorithm
Path -> GraphViz : Highlight path
deactivate Path

UI -> Layout : Adjust layout
activate Layout
Layout -> Layout : Apply Noverlap algorithm
Layout -> GraphViz : Update node positions
deactivate Layout

GraphViz -> UI : Render updated graph
deactivate UI

@enduml