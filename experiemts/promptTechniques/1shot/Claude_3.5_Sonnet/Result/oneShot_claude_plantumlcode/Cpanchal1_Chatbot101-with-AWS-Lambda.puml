@startuml Cpanchal1_Chatbot101-with-AWS-Lambda

actor "User" as user
participant "Webex Teams Room" as webex
participant "Webex Webhook" as webhook
participant "API Gateway" as apigateway
participant "AWS Lambda" as lambda
participant "icanhazdadjoke API" as jokeapi
participant "Webex Teams API" as webexapi

user -> webex : Mentions bot
webex -> webhook : Triggers webhook
webhook -> apigateway : HTTP POST
apigateway -> lambda : Invokes Lambda function

activate lambda
lambda -> jokeapi : GET request
jokeapi --> lambda : JSON response with joke
lambda -> lambda : Parse joke from response
lambda -> webexapi : POST joke to room
webexapi --> lambda : Confirmation
lambda --> apigateway : Success response
deactivate lambda

apigateway --> webhook : HTTP 200 OK
webhook --> webex : Webhook processed
webex -> user : Displays joke in room

@enduml