@startuml UoA-eResearch_hub-stack

actor Developer
participant "Git Repository" as Git
participant "Jenkins CI/CD" as Jenkins
participant "Terraform" as Terraform
participant AWS
participant "Contentful" as Contentful

Developer -> Git : Push code
Git -> Jenkins : Trigger pipeline

Jenkins -> Jenkins : Build and test

alt Frontend (research-hub-web)
    Jenkins -> Jenkins : Build Angular app
    Jenkins -> AWS : Deploy to S3
    Jenkins -> AWS : Invalidate CloudFront cache
end

alt GraphQL API (cer-graphql)
    Jenkins -> Jenkins : Build Docker image
    Jenkins -> AWS : Deploy to ECS
end

alt Search Proxy (hub-search-proxy)
    Jenkins -> AWS : Deploy Lambda function
end

Jenkins -> Terraform : Apply infrastructure changes
Terraform -> AWS : Provision/update resources

Jenkins -> Contentful : Update content (if needed)

@enduml