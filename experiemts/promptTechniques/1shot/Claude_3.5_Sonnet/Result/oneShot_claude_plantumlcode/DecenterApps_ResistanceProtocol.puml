@startuml DecenterApps_ResistanceProtocol

skinparam component {
  BackgroundColor<<Smart Contract>> LightYellow
  BackgroundColor<<Simulation>> LightBlue
  BackgroundColor<<Frontend>> LightGreen
  BackgroundColor<<Backend>> LightPink
}

package "Smart Contracts" {
  [NOI Stablecoin] <<Smart Contract>>
  [CDP Manager] <<Smart Contract>>
  [Price Stabilization] <<Smart Contract>>
  [MultiSigWallet] <<Smart Contract>>
}

package "Simulation Engine" {
  [Python Simulator] <<Simulation>>
  [Agent Models] <<Simulation>>
  [PID Controllers] <<Simulation>>
}

package "Frontend" {
  [React App] <<Frontend>>
  [Web3 Connector] <<Frontend>>
  [CDP Management UI] <<Frontend>>
}

package "Backend" {
  [Contract Deployer] <<Backend>>
  [Event Monitor] <<Backend>>
  [Liquidation Bot] <<Backend>>
  [Update Bot] <<Backend>>
}

database "External Data" {
  [ETH/USD Oracle]
  [CPI Data Feed]
}

[NOI Stablecoin] --> [CDP Manager]
[NOI Stablecoin] --> [Price Stabilization]
[MultiSigWallet] --> [NOI Stablecoin] : controls

[Python Simulator] --> [Agent Models]
[Python Simulator] --> [PID Controllers]

[React App] --> [Web3 Connector]
[React App] --> [CDP Management UI]

[Contract Deployer] --> [NOI Stablecoin]
[Event Monitor] --> [NOI Stablecoin]
[Liquidation Bot] --> [CDP Manager]
[Update Bot] --> [Price Stabilization]

[NOI Stablecoin] --> [ETH/USD Oracle] : reads
[Price Stabilization] --> [CPI Data Feed] : reads

[Web3 Connector] --> [NOI Stablecoin] : interacts
[CDP Management UI] --> [CDP Manager] : interacts

@enduml