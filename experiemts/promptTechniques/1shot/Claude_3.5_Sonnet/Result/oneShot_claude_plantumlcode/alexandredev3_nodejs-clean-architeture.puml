@startuml alexandredev3_nodejs-clean-architeture

skinparam component {
  BackgroundColor<<API>> LightBlue
  BackgroundColor<<Infrastructure>> LightGreen
  BackgroundColor<<Module>> LightYellow
  BackgroundColor<<Provider>> LightPink
}

package "API" <<API>> {
  [Express Server]
  [Routes]
  [Middlewares]
}

package "Infrastructure" <<Infrastructure>> {
  [TypeORM]
  [Redis]
  [Tsyringe]
}

package "Users Module" <<Module>> {
  [User Repository]
  [User Services]
  [User Controllers]
}

package "Shared" <<Module>> {
  [Error Handling]
  [Utils]
}

package "Providers" <<Provider>> {
  [CacheProvider]
  [HashProvider]
}

database "PostgreSQL" {
}

[Express Server] --> [Routes]
[Routes] --> [Middlewares]
[Routes] --> [User Controllers]
[User Controllers] --> [User Services]
[User Services] --> [User Repository]
[User Services] --> [CacheProvider]
[User Services] --> [HashProvider]
[User Repository] --> [TypeORM]
[TypeORM] --> PostgreSQL
[CacheProvider] --> [Redis]
[Express Server] --> [Tsyringe]
[User Services] --> [Error Handling]
[User Services] --> [Utils]

@enduml