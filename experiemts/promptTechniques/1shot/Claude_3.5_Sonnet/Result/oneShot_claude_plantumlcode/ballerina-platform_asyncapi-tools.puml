@startuml ballerina-platform_asyncapi-tools

skinparam component {
  BackgroundColor<<Core>> LightBlue
  BackgroundColor<<CLI>> LightGreen
  BackgroundColor<<Generator>> LightYellow
  BackgroundColor<<Input>> LightGray
  BackgroundColor<<Output>> LightPink
}

[AsyncAPI CLI] <<CLI>> as CLI
[AsyncAPI to Ballerina Generator] <<Generator>> as A2B
[Ballerina to AsyncAPI Generator] <<Generator>> as B2A
[WebSocket Support] <<Core>> as WS
[Authentication Handler] <<Core>> as Auth
[Data Structure Handler] <<Core>> as DSH
[Error Handler] <<Core>> as EH

[AsyncAPI/OpenAPI Definitions] <<Input>> as Input
[Ballerina Code] <<Output>> as Output

CLI --> A2B : Uses
CLI --> B2A : Uses
A2B --> WS : Utilizes
A2B --> Auth : Incorporates
A2B --> DSH : Uses
A2B --> EH : Implements
B2A --> WS : Utilizes
B2A --> Auth : Incorporates
B2A --> DSH : Uses
B2A --> EH : Implements

Input --> A2B : Inputs to
B2A --> Input : Generates
A2B --> Output : Generates
Output --> B2A : Inputs to

@enduml