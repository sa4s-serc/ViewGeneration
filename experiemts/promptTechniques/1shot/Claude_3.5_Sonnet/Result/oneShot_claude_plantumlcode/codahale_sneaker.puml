@startuml codahale_sneaker

actor User
participant "CLI" as CLI
participant "Manager" as Manager
participant "Envelope" as Envelope
participant "ObjectStorage" as S3
participant "KeyManagement" as KMS

User -> CLI : Execute command
activate CLI

CLI -> Manager : Create manager
activate Manager

alt Upload Secret
    CLI -> Manager : Upload(key, data)
    Manager -> KMS : GenerateDataKey()
    KMS --> Manager : DataKey
    Manager -> Envelope : Encrypt(data, DataKey)
    Envelope --> Manager : EncryptedData
    Manager -> S3 : PutObject(key, EncryptedData)
    S3 --> Manager : Confirmation
    Manager --> CLI : Success
else Download Secret
    CLI -> Manager : Download(key)
    Manager -> S3 : GetObject(key)
    S3 --> Manager : EncryptedData
    Manager -> KMS : Decrypt(EncryptedKey)
    KMS --> Manager : DataKey
    Manager -> Envelope : Decrypt(EncryptedData, DataKey)
    Envelope --> Manager : PlainData
    Manager --> CLI : PlainData
else List Secrets
    CLI -> Manager : List(pattern)
    Manager -> S3 : ListObjects(pattern)
    S3 --> Manager : ObjectList
    Manager --> CLI : SecretList
else Remove Secret
    CLI -> Manager : Rm(key)
    Manager -> S3 : DeleteObject(key)
    S3 --> Manager : Confirmation
    Manager --> CLI : Success
else Rotate Keys
    CLI -> Manager : Rotate()
    loop for each secret
        Manager -> S3 : GetObject(key)
        S3 --> Manager : EncryptedData
        Manager -> KMS : Decrypt(EncryptedKey)
        KMS --> Manager : OldDataKey
        Manager -> Envelope : Decrypt(EncryptedData, OldDataKey)
        Envelope --> Manager : PlainData
        Manager -> KMS : GenerateDataKey()
        KMS --> Manager : NewDataKey
        Manager -> Envelope : Encrypt(PlainData, NewDataKey)
        Envelope --> Manager : NewEncryptedData
        Manager -> S3 : PutObject(key, NewEncryptedData)
        S3 --> Manager : Confirmation
    end
    Manager --> CLI : Success
end

CLI --> User : Command result

deactivate Manager
deactivate CLI

@enduml