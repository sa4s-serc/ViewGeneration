@startuml
skinparam component {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<util>> #d8f5d3
  BackgroundColor<<manipulator>> #fddddd
  BackgroundColor<<detector>> #fff1c9
  BackgroundColor<<emitter>> #e6e6fa
  BackgroundColor<<logger>> #ffefd5
}

[CLI Entry Point] as CLI <<core>>
[Runner] as Runner <<core>>
[Parser] as Parser <<core>>
[Types] as Types <<core>>

package "Manipulators" {
  [NoImplicitReturnsManipulator] as NoImplicitReturns <<manipulator>>
  [StrictNullChecksManipulator] as StrictNullChecks <<manipulator>>
  [StrictPropertyInitializationManipulator] as StrictPropertyInit <<manipulator>>
  [NoImplicitAnyManipulator] as NoImplicitAny <<manipulator>>
}

package "Error Detectors" {
  [ProdErrorDetector] as ProdErrorDetector <<detector>>
  [BaseErrorDetector] as BaseErrorDetector <<detector>>
}

package "Emitters" {
  [InPlaceEmitter] as InPlaceEmitter <<emitter>>
  [OutOfPlaceEmitter] as OutOfPlaceEmitter <<emitter>>
}

package "Loggers" {
  [ConsoleLogger] as ConsoleLogger <<logger>>
  [StubLogger] as StubLogger <<logger>>
}

[Utilities] as Utilities <<util>>

CLI --> Runner
Runner --> Parser
Runner --> ProdErrorDetector
Runner --> NoImplicitReturns
Runner --> StrictNullChecks
Runner --> StrictPropertyInit
Runner --> NoImplicitAny
Runner --> InPlaceEmitter
Runner --> OutOfPlaceEmitter
Runner --> ConsoleLogger
Runner --> StubLogger

ProdErrorDetector --|> BaseErrorDetector

Parser --> Types
NoImplicitReturns --> Types
StrictNullChecks --> Types
StrictPropertyInit --> Types
NoImplicitAny --> Types

NoImplicitReturns --> Utilities
StrictNullChecks --> Utilities
StrictPropertyInit --> Utilities
NoImplicitAny --> Utilities

ProdErrorDetector --> Types
InPlaceEmitter --> Types
OutOfPlaceEmitter --> Types
ConsoleLogger --> Types
StubLogger --> Types

@enduml