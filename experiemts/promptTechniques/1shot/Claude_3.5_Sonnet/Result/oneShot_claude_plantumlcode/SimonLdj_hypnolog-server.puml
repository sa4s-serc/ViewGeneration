@startuml SimonLdj_hypnolog-server

skinparam component {
  BackgroundColor<<server>> LightGreen
  BackgroundColor<<client>> LightBlue
}

[HypnoLog Server] <<server>> as Server {
  [Express Web Server] as Express
  [Socket.IO Server] as SocketIO
  [Logger Route] as LoggerRoute
  [Data Processor] as DataProcessor
}

[Web UI Client] <<client>> as Client {
  [Socket.IO Client] as SocketIOClient
  [WindowsDispatcher] as WinDispatcher
  [VisualizerDispatcher] as VisDispatcher
  [ConfigFactory] as ConfigFactory
}

cloud "External Applications" as ExternalApps

database "Configuration Files" as ConfigFiles

ExternalApps -right-> Server : HTTP JSON Requests
Server -right-> Client : Real-time Data (Socket.IO)
Client ..> ConfigFiles : Read

Express -- LoggerRoute
Express -- SocketIO
LoggerRoute -- DataProcessor
DataProcessor -- SocketIO

SocketIOClient -- WinDispatcher
WinDispatcher -- VisDispatcher
VisDispatcher -- ConfigFactory

@enduml