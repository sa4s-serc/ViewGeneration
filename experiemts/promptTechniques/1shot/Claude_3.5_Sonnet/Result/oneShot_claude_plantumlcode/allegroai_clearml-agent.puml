@startuml allegroai_clearml-agent

skinparam component {
  BackgroundColor<<agent>> LightBlue
  BackgroundColor<<server>> LightGreen
  BackgroundColor<<integration>> LightYellow
}

cloud "Kubernetes / SLURM Cluster" {
  [ClearML Agent] <<agent>> as Agent
  [ResourceMonitor] <<agent>>
  [RequirementsManager] <<agent>>
  [Docker Integration] <<integration>>
  [K8s/SLURM Integration] <<integration>>
}

[ClearML Server] <<server>> as Server

database "Task Queues"
database "Experiment Data"

Agent -down-> ResourceMonitor : monitors
Agent -down-> RequirementsManager : manages dependencies
Agent -down-> [Docker Integration] : uses
Agent -down-> [K8s/SLURM Integration] : integrates with

Agent -up-> Server : reports to
Server -down-> [Task Queues] : manages
Server -down-> [Experiment Data] : stores

note right of Agent
  Modes:
  - Daemon
  - Services
  - K8s Glue
end note

note right of Server
  API Services:
  - Tasks
  - Models
  - Events
  - Workers
  - Auth
  - Queues
end note

@enduml