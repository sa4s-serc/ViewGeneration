@startuml balajich_resilience4j-helloworld

actor Client

participant "Service A" as ServiceA
participant "Service B" as ServiceB
participant "Fallback Method" as Fallback
participant "Circuit Breaker" as CircuitBreaker
participant "Rate Limiter" as RateLimiter
participant "Bulkhead" as Bulkhead
participant "Retry" as Retry
participant "Time Limiter" as TimeLimiter

Client -> ServiceA: Request
activate ServiceA

ServiceA -> RateLimiter: Check rate limit
alt Rate limit exceeded
    RateLimiter --> ServiceA: Reject request
    ServiceA --> Client: Rate limit exceeded error
else Rate limit ok
    RateLimiter --> ServiceA: Allow request
    
    ServiceA -> CircuitBreaker: Check circuit state
    alt Circuit open
        CircuitBreaker --> ServiceA: Circuit open
        ServiceA -> Fallback: Execute fallback
        Fallback --> ServiceA: Fallback response
    else Circuit closed or half-open
        CircuitBreaker --> ServiceA: Allow request
        
        ServiceA -> Bulkhead: Check concurrent calls
        alt Bulkhead full
            Bulkhead --> ServiceA: Reject request
            ServiceA -> Fallback: Execute fallback
            Fallback --> ServiceA: Fallback response
        else Bulkhead available
            Bulkhead --> ServiceA: Allow request
            
            ServiceA -> TimeLimiter: Start timer
            
            loop Max retry attempts
                ServiceA -> ServiceB: Call Service B
                
                alt Service B responds successfully
                    ServiceB --> ServiceA: Success response
                    break
                else Service B fails or times out
                    ServiceB --> ServiceA: Error or timeout
                    ServiceA -> Retry: Retry?
                    alt Retry available
                        Retry --> ServiceA: Retry
                    else Max retries reached
                        Retry --> ServiceA: Stop retrying
                        ServiceA -> Fallback: Execute fallback
                        Fallback --> ServiceA: Fallback response
                        break
                    end
                end
            end
            
            TimeLimiter -> ServiceA: Time limit check
            alt Time limit exceeded
                ServiceA -> Fallback: Execute fallback
                Fallback --> ServiceA: Fallback response
            end
        end
    end
end

ServiceA --> Client: Response

deactivate ServiceA

@enduml