@startuml btcpayserver_btcpayserver-doc

skinparam component {
  BackgroundColor<<Documentation>> LightBlue
  BackgroundColor<<Deployment>> LightGreen
  BackgroundColor<<Build>> LightYellow
}

[VuePress Site] as VuePress

package "Documentation" <<Documentation>> {
  [User Guides]
  [API Documentation]
  [Developer Resources]
  [Troubleshooting & FAQ]
}

package "Deployment Methods" <<Deployment>> {
  [Docker]
  [Azure]
  [LunaNode]
  [Manual Installation]
  [Web Deployment]
  [Hardware Deployment]
  [Third-Party Hosting]
}

package "Build & Configuration" <<Build>> {
  [setup-deps.sh]
  [create-redirects.js]
  [.vuepress/config.js]
  [Github Actions Workflow]
}

cloud "Hosting Platforms" {
  [Web Servers]
}

database "BTCPay Server Instance" {
  [Bitcoin Core]
  [NBXplorer]
  [LND]
}

VuePress --> Documentation
VuePress --> [.vuepress/config.js]
[setup-deps.sh] --> VuePress : Prepares
[create-redirects.js] --> VuePress : Generates redirects
[Github Actions Workflow] --> VuePress : Builds and deploys

Deployment Methods --> [Web Servers] : Deploys to
[Web Servers] --> [BTCPay Server Instance] : Hosts

@enduml