@startuml alanchn31_Movalytics-Data-Warehouse

actor "Data Engineer" as DE

participant "Airflow DAG" as DAG
participant "Bash Scripts" as Bash
participant "Python Scripts" as Python
participant "Apache Spark" as Spark
database "S3" as S3
database "Redshift Staging" as Staging
database "Redshift DWH" as DWH

DE -> DAG : Trigger DAG

DAG -> Bash : Execute data extraction
Bash -> S3 : Download MovieLens dataset
Bash -> S3 : Download CPI dataset

DAG -> Python : Execute transformation
Python -> Spark : Process data
Spark -> S3 : Read raw data
Spark -> Staging : Load transformed data

DAG -> Python : Execute data quality checks
Python -> Staging : Verify data integrity

DAG -> Python : Execute dimension loads
Python -> Staging : Read staged data
Python -> DWH : Upsert into dimension tables

DAG -> Python : Execute fact table load
Python -> Staging : Read staged data
Python -> DWH : Load fact table

DAG -> DE : Pipeline complete

@enduml