@startuml blockchain-signaling-system_bloss-core

actor "Network Admin" as admin
participant "BloSS API" as blossapi
participant "Stalk" as stalk
participant "Pollen" as pollen
database "InfluxDB" as influxdb
database "IPFS" as ipfs
participant "Ethereum Blockchain" as blockchain

admin -> blossapi : Report attack
activate blossapi

blossapi -> stalk : Detect attack
activate stalk
stalk -> stalk : Analyze traffic
stalk -> influxdb : Store flow statistics
stalk --> blossapi : Confirm attack detection
deactivate stalk

blossapi -> pollen : Report attack
activate pollen
pollen -> pollen : Encrypt attack data
pollen -> ipfs : Store encrypted attack report
pollen -> blockchain : Submit attack report hash
blockchain --> pollen : Confirm transaction
pollen --> blossapi : Confirm attack reported
deactivate pollen

blossapi --> admin : Attack reported successfully

admin -> blossapi : Request mitigation
activate blossapi

blossapi -> pollen : Retrieve attack data
activate pollen
pollen -> blockchain : Get attack report hash
blockchain --> pollen : Return hash
pollen -> ipfs : Retrieve encrypted report
ipfs --> pollen : Return encrypted data
pollen -> pollen : Decrypt attack data
pollen --> blossapi : Return attack details
deactivate pollen

blossapi -> stalk : Initiate mitigation
activate stalk
stalk -> stalk : Apply mitigation rules
stalk --> blossapi : Confirm mitigation
deactivate stalk

blossapi --> admin : Mitigation applied

deactivate blossapi

@enduml