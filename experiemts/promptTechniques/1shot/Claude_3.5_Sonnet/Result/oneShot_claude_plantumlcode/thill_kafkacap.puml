@startuml thill_kafkacap

participant "Source System" as Source
participant "CaptureDevice 1" as CD1
participant "CaptureDevice 2" as CD2
participant "CaptureQueue" as CQ
participant "Kafka Topic 1" as KT1
participant "Kafka Topic 2" as KT2
participant "Deduplicator" as Dedup
participant "DedupStrategy" as DS
participant "RecordPopulator" as RP
participant "BufferedPublisher" as BP
participant "Outbound Kafka Topic" as OKT

Source -> CD1 : Send message
Source -> CD2 : Send message (redundant)

CD1 -> CQ : Buffer message
CD2 -> CQ : Buffer message

CQ -> KT1 : Publish to topic
CQ -> KT2 : Publish to topic

KT1 -> Dedup : Consume message
KT2 -> Dedup : Consume message

Dedup -> DS : Check for duplicate
DS --> Dedup : Deduplication result

alt Is unique message
    Dedup -> RP : Populate record
    RP --> Dedup : Populated record
    Dedup -> BP : Send unique message
    BP -> OKT : Publish to outbound topic
else Is duplicate
    Dedup -> Dedup : Discard duplicate
end

@enduml