@startuml securesecrets_shadeswap

skinparam component {
  BackgroundColor<<contract>> LightBlue
  BackgroundColor<<package>> LightGreen
}

package "ShadeSwap Ecosystem" {
  component "LP Token Contract" as LPToken <<contract>>
  component "Staking Contract" as Staking <<contract>>
  component "AMM Pair Contract" as AMMPair <<contract>>
  component "Factory Contract" as Factory <<contract>>
  component "Router Contract" as Router <<contract>>
  component "Admin Contract" as Admin <<contract>>

  package "shadeswap-shared" <<package>> {
    [Shared Data Structures]
    [Interfaces]
    [Utility Functions]
  }

  LPToken --> [Shared Data Structures]
  Staking --> [Shared Data Structures]
  AMMPair --> [Shared Data Structures]
  Factory --> [Shared Data Structures]
  Router --> [Shared Data Structures]
  Admin --> [Shared Data Structures]

  Factory ..> LPToken : deploys
  Factory ..> AMMPair : deploys
  Router --> AMMPair : interacts
  Staking --> LPToken : stakes
  Admin --> Factory : manages
  Admin --> Router : manages
  Admin --> Staking : manages
}

package "External Dependencies" {
  [secret-toolkit]
  [cosmwasm-storage]
}

LPToken --> [secret-toolkit]
Staking --> [secret-toolkit]
AMMPair --> [secret-toolkit]
Factory --> [secret-toolkit]
Router --> [secret-toolkit]

LPToken --> [cosmwasm-storage]
Staking --> [cosmwasm-storage]
AMMPair --> [cosmwasm-storage]
Factory --> [cosmwasm-storage]
Router --> [cosmwasm-storage]

@enduml