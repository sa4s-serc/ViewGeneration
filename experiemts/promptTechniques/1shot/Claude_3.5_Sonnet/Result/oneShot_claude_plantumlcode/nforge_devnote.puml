@startuml nforge_devnote

skinparam component {
  BackgroundColor<<Frontend>> LightBlue
  BackgroundColor<<Backend>> LightGreen
  BackgroundColor<<Storage>> LightYellow
}

package "Frontend" <<Frontend>> {
  [CodeMirror Editor]
  [jQuery]
  [Bootstrap]
  [Socket.IO Client]
  [Markdown Preview]
  [Syntax Highlighting]
  [Form Validation]
  [Draft Management]
}

package "Backend (Node.js/Express)" <<Backend>> {
  [Express Server]
  [Socket.IO Server]
  [Wiki App]
  [User Management]
  [File Attachment]
  [Admin Tasks]
  [Localization]
  [Markdown Renderer]
}

package "Core Libraries" <<Backend>> {
  [GitFS]
  [FileUtils]
  [Graph]
  [Renderer]
  [i18n]
  [Delta]
}

package "Storage" <<Storage>> {
  [Git Repository]
}

database "User Data" {
  [User Credentials]
}

[Express Server] --> [Wiki App]
[Express Server] --> [User Management]
[Express Server] --> [File Attachment]
[Express Server] --> [Admin Tasks]

[Wiki App] --> [GitFS]
[Wiki App] --> [Markdown Renderer]
[User Management] --> [User Data]
[File Attachment] --> [Git Repository]

[Socket.IO Server] <--> [Socket.IO Client]

[CodeMirror Editor] --> [Markdown Preview]
[CodeMirror Editor] --> [Syntax Highlighting]
[CodeMirror Editor] --> [Draft Management]

[Express Server] --> [Localization]
[Express Server] --> [Core Libraries]

@enduml