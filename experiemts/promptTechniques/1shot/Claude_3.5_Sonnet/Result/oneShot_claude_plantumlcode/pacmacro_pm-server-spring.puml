@startuml pacmacro_pm-server-spring

actor Client
participant "REST API\n(Controllers)" as API
participant "Managers" as Managers
participant "Registries" as Registries
participant "Repositories" as Repositories
database "In-Memory Storage" as Storage

Client -> API : HTTP Request
activate API

API -> Managers : Delegate request
activate Managers

Managers -> Registries : Get/Update game state
activate Registries
Registries -> Storage : Read/Write data
Registries --> Managers : Return state
deactivate Registries

Managers -> Repositories : Fetch/Store data
activate Repositories
Repositories -> Storage : Read/Write data
Repositories --> Managers : Return data
deactivate Repositories

Managers --> API : Process and return result
deactivate Managers

API --> Client : HTTP Response
deactivate API

@enduml