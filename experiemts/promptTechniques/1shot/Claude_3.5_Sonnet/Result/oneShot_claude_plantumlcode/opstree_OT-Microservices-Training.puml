@startuml opstree_OT-Microservices-Training

actor User
participant "Frontend\n(ReactJS)" as Frontend
participant "API Gateway\n(Spring Boot)" as Gateway
participant "Attendance Service\n(Golang)" as AttendanceService
participant "Employee Service\n(Golang)" as EmployeeService
participant "Salary Service\n(Golang)" as SalaryService
participant "Notification Service\n(Python)" as NotificationService
database "MySQL" as MySQL
database "Elasticsearch" as Elasticsearch

User -> Frontend : Interacts with UI
Frontend -> Gateway : Sends API request

alt Attendance-related request
    Gateway -> AttendanceService : Routes request
    AttendanceService -> MySQL : Queries/Updates data
    MySQL --> AttendanceService : Returns data
    AttendanceService --> Gateway : Sends response
else Employee-related request
    Gateway -> EmployeeService : Routes request
    EmployeeService -> Elasticsearch : Queries/Updates data
    Elasticsearch --> EmployeeService : Returns data
    EmployeeService --> Gateway : Sends response
else Salary-related request
    Gateway -> SalaryService : Routes request
    SalaryService -> Elasticsearch : Queries data
    Elasticsearch --> SalaryService : Returns data
    SalaryService --> Gateway : Sends response
end

Gateway --> Frontend : Aggregates and returns response
Frontend --> User : Updates UI

loop Periodic notification check
    NotificationService -> Elasticsearch : Retrieves employee data
    Elasticsearch --> NotificationService : Returns data
    NotificationService -> NotificationService : Processes data and generates notifications
    NotificationService -> User : Sends email notification
end

@enduml