@startuml AmnisIO_AmnisIO

skinparam component {
  BackgroundColor<<TypeScript>> #87CEFA
  BackgroundColor<<C>> #90EE90
  BackgroundColor<<CLI>> #FFB6C1
  BackgroundColor<<Config>> #FAFAD2
}

[AmnisIO CLI] <<CLI>> as CLI
[typewriter] <<TypeScript>> as Typewriter
[rivulet] <<C>> as Rivulet
[gyrus] <<C>> as Gyrus
[PlatformIO] as PlatformIO
[TypeScript Code] <<TypeScript>> as TSCode
[C Code] <<C>> as CCode
[Hardware] as Hardware
[Configs] <<Config>> as Configs

CLI --> Typewriter : uses
CLI --> PlatformIO : integrates
CLI --> Configs : reads

TSCode --> Typewriter : input
Typewriter --> CCode : transpiles to

CCode --> Rivulet : uses
CCode --> Gyrus : uses
Gyrus --> Hardware : abstracts

Configs --> Typewriter : configures
Configs --> PlatformIO : configures

@enduml