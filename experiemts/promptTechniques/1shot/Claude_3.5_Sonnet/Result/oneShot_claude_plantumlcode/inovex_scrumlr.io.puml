@startuml inovex_scrumlr.io

actor User
participant "Frontend\n(React)" as Frontend
participant "API Layer" as API
participant "WebSocket" as WS
participant "Services" as Services
database "Database" as DB
queue "NATS/Redis" as Queue

User -> Frontend : Interact with UI
activate Frontend

Frontend -> API : HTTP Request
activate API

API -> Services : Call Service Method
activate Services

Services -> DB : Query/Update Data
activate DB
DB --> Services : Return Data
deactivate DB

Services --> API : Return Result
deactivate Services

API --> Frontend : HTTP Response
deactivate API

Frontend --> User : Update UI
deactivate Frontend

User -> Frontend : Perform Real-time Action
activate Frontend

Frontend -> WS : Send WebSocket Message
activate WS

WS -> Services : Process Message
activate Services

Services -> Queue : Publish Event
activate Queue

Queue --> Services : Confirm Publication
deactivate Queue

Services --> WS : Return Result
deactivate Services

WS -> Queue : Subscribe to Events
activate Queue

Queue --> WS : Broadcast Event
deactivate Queue

WS --> Frontend : Update Real-time Data
deactivate WS

Frontend --> User : Update UI in Real-time
deactivate Frontend

@enduml