@startuml solenya-group_solenya

actor User
participant "App" as App
participant "Component" as Component
participant "Router" as Router
participant "Virtual DOM" as VDOM
participant "Storage" as Storage
participant "Validator" as Validator
participant "TimeTravel" as TimeTravel

User -> App : Interact
activate App

App -> Component : Create/Update
activate Component

Component -> Component : Update State
Component -> VDOM : Render View
VDOM --> Component : DOM Updates

Component -> Validator : Validate Input
Validator --> Component : Validation Result

Component -> Router : Navigate
Router --> Component : Route Change

Component -> Storage : Serialize State
Storage --> Component : Deserialized State

App -> TimeTravel : Record State
TimeTravel --> App : Previous/Next State

Component --> App : Component Updated
deactivate Component

App --> User : Update UI
deactivate App

@enduml