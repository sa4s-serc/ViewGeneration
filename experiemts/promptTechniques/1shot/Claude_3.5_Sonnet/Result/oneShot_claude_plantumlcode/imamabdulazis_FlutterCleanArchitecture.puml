@startuml imamabdulazis_FlutterCleanArchitecture

skinparam component {
  BackgroundColor<<core>> #FFCCCB
  BackgroundColor<<feature>> #CCFFCC
  BackgroundColor<<external>> #CCCCFF
}

package "Flutter Application" {
  [main.dart] as Main
  [app.dart] as App
  [routes.dart] as Routes

  package "Core" <<core>> {
    [Networking]
    [Device Management]
    [Error Handling]
    [Use Case Abstractions]
  }

  package "Features" <<feature>> {
    package "Data Layer" {
      [Data Sources]
      [Models]
      [Repository Implementations]
    }

    package "Domain Layer" {
      [Entities]
      [Use Cases]
      [Repository Interfaces]
    }

    package "Presentation Layer" {
      [UI Components]
      [Screens]
      [BLoCs]
    }

    [Dependency Injection]
  }

  package "External Dependencies" <<external>> {
    [dio]
    [flutter_bloc]
    [get_it]
    [shared_preferences]
    [Firebase Messaging]
    [Sentry]
  }
}

Main --> App
App --> Routes
App --> [Presentation Layer]
[Presentation Layer] --> [Domain Layer]
[Domain Layer] --> [Data Layer]
[Data Layer] --> Core
[Presentation Layer] --> [flutter_bloc]
[Data Layer] --> [dio]
[Dependency Injection] --> [get_it]
Core --> [shared_preferences]
Core --> [Firebase Messaging]
Core --> [Sentry]

@enduml