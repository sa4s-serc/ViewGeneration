@startuml intel_edge-insights-vision

skinparam component {
  BackgroundColor<<script>> LightGreen
  BackgroundColor<<config>> LightBlue
  BackgroundColor<<doc>> LightYellow
}

[eiv_install.sh] <<script>> as install
[eiv_setup.py] <<script>> as setup
[eiv_callbacks.sh] <<script>> as callbacks
[launch_notebooks.sh] <<script>> as launch
[adl_*.sh] <<script>> as adl_scripts

[README.md] <<doc>> as readme
[docs/] <<doc>> as docs
[CODE_OF_CONDUCT.md] <<doc>> as coc
[LICENSE] <<doc>> as license
[CONTRIBUTING.md] <<doc>> as contributing
[security.md] <<doc>> as security

[requirements.txt] <<config>> as requirements
[Dockerfile] <<config>> as dockerfile

component "OpenVINO Toolkit" as openvino
component "Docker" as docker
component "Intel Graphics Drivers" as intel_drivers
component "Jupyter Notebooks" as jupyter

install --> setup
install --> callbacks
install --> launch
install ..> adl_scripts : "if Alder Lake N"

setup --> callbacks : "calls functions"
setup --> requirements : "reads"

callbacks --> docker : "manages"
callbacks --> intel_drivers : "installs"
callbacks --> openvino : "configures"

launch --> jupyter : "starts"
launch --> docker : "uses"

adl_scripts --> intel_drivers : "custom build"

docker --> openvino : "contains"
docker --> jupyter : "hosts"

readme ..> install : "describes"
docs ..> install : "explains"
docs ..> openvino : "guides"

@enduml