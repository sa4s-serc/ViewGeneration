@startuml
!define RECTANGLE class

actor User
participant "Kubeflow Pipeline" as KFP
participant "BigQuery ML" as BQML
participant "Cloud Storage" as GCS
participant "AI Platform / Vertex AI" as CAIP
participant "ScaNN Service" as ScaNN
participant "Google Ads API" as AdsAPI
participant "Data Studio" as DataStudio

User -> KFP : Initiate ML workflow
activate KFP

KFP -> BQML : Prepare training data
activate BQML
BQML --> KFP : Data prepared
deactivate BQML

KFP -> BQML : Train model (e.g. Matrix Factorization)
activate BQML
BQML --> KFP : Model trained
deactivate BQML

KFP -> BQML : Evaluate model
activate BQML
BQML --> KFP : Evaluation metrics
deactivate BQML

KFP -> GCS : Export model artifacts
activate GCS
GCS --> KFP : Artifacts stored
deactivate GCS

alt Deploy to AI Platform / Vertex AI
    KFP -> CAIP : Deploy model
    activate CAIP
    CAIP --> KFP : Model deployed
    deactivate CAIP
else Deploy to ScaNN Service
    KFP -> ScaNN : Build ScaNN index
    activate ScaNN
    ScaNN --> KFP : Index built
    KFP -> ScaNN : Deploy index
    ScaNN --> KFP : Index deployed
    deactivate ScaNN
end

KFP -> AdsAPI : Create lookalike audience
activate AdsAPI
AdsAPI --> KFP : Audience created
deactivate AdsAPI

KFP -> DataStudio : Update dashboards
activate DataStudio
DataStudio --> KFP : Dashboards updated
deactivate DataStudio

KFP --> User : ML workflow completed
deactivate KFP

User -> CAIP : Make real-time predictions
activate CAIP
CAIP --> User : Predictions returned
deactivate CAIP

User -> ScaNN : Request item recommendations
activate ScaNN
ScaNN --> User : Recommendations returned
deactivate ScaNN

@enduml