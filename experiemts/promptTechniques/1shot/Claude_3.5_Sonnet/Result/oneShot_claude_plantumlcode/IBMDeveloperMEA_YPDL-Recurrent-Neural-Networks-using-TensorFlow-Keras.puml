@startuml IBMDeveloperMEA_YPDL-Recurrent-Neural-Networks-using-TensorFlow-Keras

actor User

participant "Jupyter Notebook" as Notebook
participant "TensorFlow Keras" as TF
participant "Data Processing" as DataProc
database "Penn Treebank Dataset" as Dataset

User -> Notebook : Open notebook
activate Notebook

Notebook -> DataProc : Load and preprocess data
activate DataProc
DataProc -> Dataset : Fetch data
Dataset --> DataProc : Raw data
DataProc --> Notebook : Processed data
deactivate DataProc

Notebook -> TF : Create LSTM model
activate TF
TF --> Notebook : Model instance
deactivate TF

loop Training epochs
    Notebook -> TF : Train model
    activate TF
    TF -> TF : Forward pass
    TF -> TF : Backward pass
    TF -> TF : Update weights
    TF --> Notebook : Training metrics
    deactivate TF
end

Notebook -> TF : Evaluate model
activate TF
TF --> Notebook : Evaluation metrics
deactivate TF

Notebook -> Notebook : Calculate perplexity

Notebook -> User : Display results

deactivate Notebook

@enduml