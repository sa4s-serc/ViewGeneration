@startuml gustavung_Graphrec

skinparam component {
  BackgroundColor<<mobile>> LightSkyBlue
  BackgroundColor<<server>> PaleGreen
  BackgroundColor<<model>> LightSalmon
}

package "Android Application" <<mobile>> {
  [MainActivity]
  [CameraActivity]
  [ResultActivity]
  [ImageUploadTask]
  [CameraPreview]
  [SurfaceOverlay]
}

package "Flask Server" <<server>> {
  [server.py]
  [graph_classifier.py]
  [graph_images.py]
  [generate_data.py]
  [cn.py]
}

package "Neural Network" <<model>> {
  [CNN Model]
}

cloud "Internet" {
  [HTTP Communication]
}

[MainActivity] --> [CameraActivity]
[CameraActivity] --> [ResultActivity]
[CameraActivity] --> [CameraPreview]
[CameraActivity] --> [SurfaceOverlay]
[ResultActivity] --> [ImageUploadTask]
[ImageUploadTask] --> [HTTP Communication]
[HTTP Communication] --> [server.py]
[server.py] --> [graph_classifier.py]
[graph_classifier.py] --> [CNN Model]
[graph_images.py] --> [CNN Model]
[generate_data.py] --> [graph_images.py]
[cn.py] --> [CNN Model]

@enduml