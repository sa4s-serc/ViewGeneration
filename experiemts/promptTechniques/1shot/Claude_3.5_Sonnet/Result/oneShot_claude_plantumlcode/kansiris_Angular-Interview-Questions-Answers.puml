@startuml

skinparam component {
  BackgroundColor<<content>> #EEEEEE
  BorderColor<<content>> #999999
  BackgroundColor<<navigation>> #D9EAD3
  BorderColor<<navigation>> #6AA84F
  BackgroundColor<<auxiliary>> #D0E0E3
  BorderColor<<auxiliary>> #45818E
}

[Angular Interview Q&A Collection] as QA <<content>>
[Code Examples] as Code <<content>>
[Table of Contents] as TOC <<navigation>>
[README.md] as Readme <<navigation>>
[LICENSE] as License <<auxiliary>>

cloud "External Resources" {
  [YouTube Content]
  [Websites]
}

Readme --> TOC
Readme --> [YouTube Content]
Readme --> [Websites]
TOC --> QA
QA --> Code

note right of QA
  Covers:
  - Components
  - Directives
  - Modules
  - Data Binding
  - Services
  - Routing
  - AOT Compilation
  - Security
  - RxJS
  - Angular CLI
  - Angular Material
end note

note bottom of License
  Apache 2.0
end note

@enduml