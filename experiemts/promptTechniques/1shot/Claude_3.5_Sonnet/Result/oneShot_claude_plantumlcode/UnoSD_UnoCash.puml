@startuml UnoSD_UnoCash

actor User
participant "Blazor SPA" as Blazor
participant "Azure API Management" as APIM
participant "Azure Functions" as Functions
participant "Azure AD" as AAD
database "Azure Table Storage" as Storage
participant "Azure Form Recognizer" as FormRecognizer
participant "Azure Blob Storage" as BlobStorage

User -> Blazor : Access application
Blazor -> AAD : Authenticate
AAD --> Blazor : Token

User -> Blazor : Manage expenses
activate Blazor

Blazor -> APIM : API request
activate APIM

APIM -> AAD : Validate token
AAD --> APIM : Token valid

APIM -> Functions : Forward request
activate Functions

alt Get Expenses
    Functions -> Storage : Fetch expenses
    Storage --> Functions : Return expenses
    Functions --> APIM : Return expenses
    APIM --> Blazor : Return expenses
    Blazor --> User : Display expenses

else Add/Update Expense
    User -> Blazor : Upload receipt
    Blazor -> BlobStorage : Store receipt
    BlobStorage --> Blazor : Receipt URL
    Blazor -> APIM : Add/Update expense with receipt URL
    APIM -> Functions : Forward request
    Functions -> FormRecognizer : Parse receipt
    FormRecognizer --> Functions : Receipt data
    Functions -> Storage : Store expense and receipt data
    Storage --> Functions : Confirmation
    Functions --> APIM : Confirmation
    APIM --> Blazor : Confirmation
    Blazor --> User : Display confirmation

else Delete Expense
    Functions -> Storage : Delete expense
    Storage --> Functions : Confirmation
    Functions --> APIM : Confirmation
    APIM --> Blazor : Confirmation
    Blazor --> User : Display confirmation
end

deactivate Functions
deactivate APIM
deactivate Blazor

@enduml