@startuml arkaneshiro_Sound-Zone

actor User
participant "App" as App
participant "NavBar" as NavBar
participant "Home" as Home
participant "Dashboard" as Dashboard
participant "Profile" as Profile
participant "SoundDetail" as SoundDetail
participant "Upload" as Upload
participant "Sound" as Sound
participant "SoundBar" as SoundBar
participant "Redux Store" as Store
participant "API" as API
participant "Cloudinary" as Cloudinary

User -> App : Access application
activate App

App -> Store : Initialize store
App -> NavBar : Render navigation

alt Not authenticated
    App -> Home : Render home page
    User -> Home : Login/Register
    Home -> API : Authenticate
    API --> Home : Return JWT
    Home -> Store : Update auth state
else Authenticated
    App -> Dashboard : Render dashboard
    Dashboard -> Store : Fetch followed users' sounds
    Store -> API : Request sounds
    API --> Store : Return sounds data
    Store --> Dashboard : Update with sounds
    
    User -> NavBar : Search for users
    NavBar -> API : Send search query
    API --> NavBar : Return search results
    
    User -> Profile : View user profile
    Profile -> Store : Fetch user data
    Store -> API : Request user data
    API --> Store : Return user data
    Store --> Profile : Update with user data
    
    User -> SoundDetail : View sound details
    SoundDetail -> Store : Fetch sound data
    Store -> API : Request sound data
    API --> Store : Return sound data
    Store --> SoundDetail : Update with sound data
    
    User -> Upload : Upload new sound
    Upload -> Cloudinary : Upload audio file
    Cloudinary --> Upload : Return audio URL
    Upload -> API : Save sound data
    API --> Upload : Confirm save
    Upload -> Store : Update sounds list
    
    User -> Sound : Play sound
    Sound -> SoundBar : Update current playing sound
    SoundBar -> Store : Update playback state
end

App -> SoundBar : Render persistent player

deactivate App

@enduml