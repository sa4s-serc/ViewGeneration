@startuml EMERIC237_Restaurant-reservation-app

!define RECTANGLE class

skinparam class {
    BackgroundColor<<Frontend>> LightBlue
    BackgroundColor<<Backend>> LightGreen
    BackgroundColor<<Database>> Yellow
    BackgroundColor<<Deployment>> Orange
}

RECTANGLE "React Frontend" <<Frontend>> {
    [App.js]
    [Dashboard.js]
    [CreateReservation.js]
    [ReservationForm.js]
    [api.js]
}

RECTANGLE "Node.js/Express Backend" <<Backend>> {
    [app.js]
    [server.js]
    [reservations.router.js]
    [reservations.controller.js]
    [reservations.service.js]
    [tables.router.js]
    [tables.controller.js]
    [tables.service.js]
}

database "PostgreSQL" <<Database>> {
    [Reservations Table]
    [Tables Table]
}

cloud "Vercel" <<Deployment>> {
    [Frontend Hosting]
    [Backend API]
}

[React Frontend] --> [api.js] : API calls
[api.js] --> [Node.js/Express Backend] : HTTP requests
[Node.js/Express Backend] --> [PostgreSQL] : Knex.js queries
[Vercel] --> [React Frontend] : Hosts
[Vercel] --> [Node.js/Express Backend] : Hosts

note right of [PostgreSQL]
  Data persisted using
  Knex.js migrations
end note

note left of [React Frontend]
  User interactions and
  state management
end note

note right of [Node.js/Express Backend]
  RESTful API endpoints
  Business logic
  Data validation
end note

@enduml