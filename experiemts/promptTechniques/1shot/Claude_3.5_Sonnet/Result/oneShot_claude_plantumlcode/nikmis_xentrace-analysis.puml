@startuml nikmis_xentrace-analysis

skinparam componentStyle uml2

actor User

component "Xentrace-analysis" {
  [Main Program] as Main
  [Event Reader] as Reader
  [Event Handler] as Handler
  [Event Sorter] as Sorter
  
  database "Event Buffer" as Buffer
}

component "Analysis Modules" {
  [CPU Utilization] as CPUUtil
  [CPU Scheduling Latency] as CPULat
  [Time in Hypervisor] as HyperTime
  [Disk I/O] as DiskIO
  [Xen Event Statistics] as XenStats
  [Trap Counting] as TrapCount
}

[Xentrace] as Xentrace

User -> Main : Run analysis
Main -> Xentrace : Spawn process
Xentrace --> Reader : Generate trace data
Reader -> Sorter : Sort events
Sorter -> Buffer : Store sorted events
Reader <- Buffer : Retrieve events
Reader -> Handler : Dispatch events
Handler --> CPUUtil : Handle event
Handler --> CPULat : Handle event
Handler --> HyperTime : Handle event
Handler --> DiskIO : Handle event
Handler --> XenStats : Handle event
Handler --> TrapCount : Handle event

@enduml