@startuml Spiderpig86_SmoresUnderflow

actor User

node "Load Balancer (Nginx)" as LoadBalancer

cloud "Microservices" {
  [su-frontend] as Frontend
  [su-users] as Users
  [su-accounts] as Accounts
  [su-questions] as Questions
  [su-answers] as Answers
  [su-search] as Search
  [su-media] as Media
}

queue "Message Queues (RabbitMQ)" {
  [qu-questions] as QueueQuestions
  [qu-answers] as QueueAnswers
  [qu-delete-questions] as QueueDeleteQuestions
}

database "MongoDB" as MongoDB
database "Redis" as Redis
database "ElasticSearch" as ElasticSearch

User -> LoadBalancer : HTTP Request

LoadBalancer -> Frontend : Route Request
Frontend -> Users : Authenticate
Frontend -> Questions : Get/Post Questions
Frontend -> Answers : Get/Post Answers
Frontend -> Search : Search
Frontend -> Media : Upload/Retrieve Media

Users -> Redis : Cache User Data
Questions -> Redis : Cache Question Data
Answers -> Redis : Cache Answer Data

Questions -> QueueQuestions : Enqueue Question
Answers -> QueueAnswers : Enqueue Answer
Questions -> QueueDeleteQuestions : Enqueue Delete

QueueQuestions --> MongoDB : Store Question
QueueAnswers --> MongoDB : Store Answer
QueueDeleteQuestions --> MongoDB : Delete Question

QueueQuestions --> ElasticSearch : Index Question
QueueAnswers --> ElasticSearch : Index Answer
QueueDeleteQuestions --> ElasticSearch : Remove from Index

Search -> ElasticSearch : Query

note right of LoadBalancer
  Ansible and PM2 used for
  automated deployment
  and management
end note

@enduml