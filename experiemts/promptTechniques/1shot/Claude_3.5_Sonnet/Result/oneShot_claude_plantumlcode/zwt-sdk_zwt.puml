@startuml zwt-sdk_zwt

skinparam component {
  BackgroundColor<<API>> LightBlue
  BackgroundColor<<Implementation>> LightGreen
}

package "ZWT Framework" {
  [Core API] <<API>> as core
  [Graphics API] <<API>> as graphics
  [Input API] <<API>> as input
  [Layout API] <<API>> as layout
  [Menu API] <<API>> as menu
  [Styling API] <<API>> as styling
  [Floor API] <<API>> as floor
  
  package "Platform-Specific Implementations" {
    [Java SE Implementation] <<Implementation>> as se
    [Java ME Implementation] <<Implementation>> as me
    [Android Implementation] <<Implementation>> as android
  }
  
  package "Common Components" {
    [ZwtComponent]
    [ZwtContainer]
    [ZwtFrame]
    [ZwtPanel]
    [ZwtLabel]
    [ZwtButton]
  }
  
  package "Utility" {
    [ZwtDrawing]
  }
}

core --> [Common Components]
graphics --> [ZwtGraphics]
input --> [ZwtKeyboard]
layout --> [ZwtLayout]
menu --> [ZwtMenu]
menu --> [ZwtMenuItem]
styling --> [ZwtColor]
styling --> [ZwtFont]
floor --> [ZwtFloor]
floor --> [ZwtTransparentFloor]
floor --> [ZwtRoundFloor]

se ..> core : implements
me ..> core : implements
android ..> core : implements

se ..> graphics : implements
me ..> graphics : implements
android ..> graphics : implements

se ..> input : implements
me ..> input : implements
android ..> input : implements

se ..> layout : implements
me ..> layout : implements
android ..> layout : implements

se ..> menu : implements
me ..> menu : implements
android ..> menu : implements

se ..> styling : implements
me ..> styling : implements
android ..> styling : implements

se ..> floor : implements
me ..> floor : implements
android ..> floor : implements

@enduml