@startuml MyEMS_myems

skinparam component {
  BackgroundColor<<UI>> LightBlue
  BackgroundColor<<API>> LightGreen
  BackgroundColor<<Service>> LightYellow
  BackgroundColor<<Database>> LightPink
}

[MyEMS Admin UI] as AdminUI <<UI>>
[MyEMS Web UI] as WebUI <<UI>>
[MyEMS API] as API <<API>>
[Data Acquisition Service] as DataAcq <<Service>>
[Data Cleaning Service] as DataClean <<Service>>
[Data Normalization Service] as DataNorm <<Service>>
[Data Aggregation Service] as DataAgg <<Service>>
[Fault Detection Service] as FDD <<Service>>
[Reporting Service] as Report <<Service>>
[Billing Service] as Billing <<Service>>

database "System DB" as SystemDB <<Database>>
database "Energy DB" as EnergyDB <<Database>>
database "Billing DB" as BillingDB <<Database>>
database "Historical DB" as HistoricalDB <<Database>>
database "Carbon DB" as CarbonDB <<Database>>

AdminUI --> API
WebUI --> API

API --> SystemDB
API --> EnergyDB
API --> BillingDB
API --> HistoricalDB
API --> CarbonDB

API --> DataAcq
API --> DataClean
API --> DataNorm
API --> DataAgg
API --> FDD
API --> Report
API --> Billing

DataAcq --> EnergyDB
DataClean --> EnergyDB
DataNorm --> EnergyDB
DataAgg --> EnergyDB
FDD --> EnergyDB
Report --> EnergyDB
Billing --> BillingDB

@enduml