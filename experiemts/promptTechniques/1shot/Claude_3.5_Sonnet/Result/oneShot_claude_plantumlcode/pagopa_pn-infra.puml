@startuml pagopa_pn-infra

actor User
participant "API Gateway" as APIGateway
participant "Lambda Functions" as Lambda
participant "EventBridge" as EventBridge
participant "ECS Services" as ECS
participant "SQS Queues" as SQS
participant "SNS Topics" as SNS
participant "DynamoDB" as DynamoDB
participant "S3" as S3
participant "Kinesis" as Kinesis
participant "CloudWatch" as CloudWatch
participant "Cognito" as Cognito

User -> APIGateway : Request
APIGateway -> Cognito : Authenticate
Cognito --> APIGateway : Token
APIGateway -> Lambda : Route request

alt Direct Lambda processing
    Lambda -> DynamoDB : Read/Write data
    Lambda --> APIGateway : Response
else Microservice processing
    Lambda -> SQS : Enqueue task
    ECS <- SQS : Dequeue task
    ECS -> DynamoDB : Process data
    ECS -> SNS : Publish event
    SNS -> EventBridge : Route event
    EventBridge -> Lambda : Trigger function
end

Lambda -> S3 : Store/Retrieve files
Lambda -> Kinesis : Stream data

CloudWatch -> SNS : Send alarm
SNS -> Lambda : Trigger alert handling

@enduml