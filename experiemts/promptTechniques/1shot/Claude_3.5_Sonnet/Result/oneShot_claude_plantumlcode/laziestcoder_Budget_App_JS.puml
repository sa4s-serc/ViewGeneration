@startuml laziestcoder_Budget_App_JS

actor User
participant "UIController" as UI
participant "controller" as Controller
participant "budgetController" as Budget

User -> UI : Input income/expense
activate UI
UI -> Controller : ctrlAddItem()
activate Controller
Controller -> Budget : addItem()
activate Budget
Budget --> Controller : return updated data
deactivate Budget
Controller -> UI : addListItem()
Controller -> Budget : calculateBudget()
activate Budget
Budget --> Controller : return budget data
deactivate Budget
Controller -> UI : displayBudget()
Controller -> Budget : calculatePercentages()
activate Budget
Budget --> Controller : return percentages
deactivate Budget
Controller -> UI : displayPercentages()
deactivate Controller
UI --> User : Display updated budget
deactivate UI

User -> UI : Delete item
activate UI
UI -> Controller : ctrlDeleteItem()
activate Controller
Controller -> Budget : deleteItem()
activate Budget
Budget --> Controller : return updated data
deactivate Budget
Controller -> UI : deleteListItem()
Controller -> Budget : calculateBudget()
activate Budget
Budget --> Controller : return budget data
deactivate Budget
Controller -> UI : displayBudget()
Controller -> Budget : calculatePercentages()
activate Budget
Budget --> Controller : return percentages
deactivate Budget
Controller -> UI : displayPercentages()
deactivate Controller
UI --> User : Display updated budget
deactivate UI

@enduml