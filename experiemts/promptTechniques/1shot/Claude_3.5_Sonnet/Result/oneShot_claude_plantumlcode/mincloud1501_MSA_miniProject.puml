@startuml mincloud1501_MSA_miniProject

skinparam component {
  BackgroundColor<<Docker>> LightBlue
  BackgroundColor<<Kubernetes>> LightGreen
  BackgroundColor<<Istio>> LightPink
}

cloud "Docker Hub" as DockerHub

package "Docker" <<Docker>> {
  [Dockerfile] as Dockerfile
  [build.sh] as BuildScript
  [push.sh] as PushScript
  [index.html] as IndexHTML
}

package "Kubernetes" <<Kubernetes>> {
  [kubProvisioning.sh] as KubScript
  [Deployment YAML] as DeploymentYAML
  [Service YAML] as ServiceYAML
}

package "Istio" <<Istio>> {
  [Traffic Management] as TrafficMgmt
  [Fault Injection] as FaultInjection
}

node "Kubernetes Cluster" {
  [Nginx Pod] as NginxPod
  [Istio Sidecar] as IstioSidecar
}

Dockerfile --> BuildScript
IndexHTML --> Dockerfile
BuildScript --> PushScript
PushScript --> DockerHub

DockerHub --> KubScript
KubScript --> DeploymentYAML
KubScript --> ServiceYAML
DeploymentYAML --> NginxPod
ServiceYAML --> NginxPod

TrafficMgmt --> IstioSidecar
FaultInjection --> IstioSidecar
IstioSidecar --> NginxPod

@enduml