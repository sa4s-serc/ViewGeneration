@startuml XenitAB_git-auth-proxy

actor "Git Client" as client
participant "git-auth-proxy" as proxy
participant "Kubernetes API" as k8s
participant "GitHub/Azure DevOps" as gitprovider

client -> proxy: Git request
activate proxy

proxy -> k8s: Fetch Secret (token)
activate k8s
k8s --> proxy: Return token
deactivate k8s

proxy -> proxy: Validate token

alt Token valid
    proxy -> gitprovider: Forward request with provider-specific auth
    activate gitprovider
    gitprovider --> proxy: Response
    deactivate gitprovider
    proxy --> client: Forward response
else Token invalid
    proxy --> client: 401 Unauthorized
end

deactivate proxy

@enduml