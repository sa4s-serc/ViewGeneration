@startuml IBM_logdna-cos
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "IBM CIS" as CIS

rectangle "IBM Cloud Object Storage (Source)" as COS_Source #lightblue

rectangle "Serverless Function" as Function #palegreen {
  rectangle "handler.js" as Handler
}

rectangle "IBM LogDNA" as LogDNA #mistyrose

rectangle "IBM Cloud Object Storage (Archive)" as COS_Archive #lightblue

' ========== Connections ==========
CIS --> COS_Source : Push logs (zipped)

COS_Source -> Function : Object creation event triggers\nfunction execution

Function -> COS_Source : Download zipped log file
Function -> Function : Unzip and parse JSON logs
Function -> LogDNA : Send logs in batches (5000)\nwith retry mechanism
Function -> COS_Archive : Archive processed logs
Function -> COS_Source : Delete processed file

LogDNA --> Function : API response (success/error)
@enduml