@startuml jzyong_GameServer4g
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Game Client" as Client

rectangle "Gate Server" as Gate {
  rectangle "UserManager" as UserManager
  rectangle "GameManager" as GameManager
  rectangle "ClientManager" as ClientManager
}

rectangle "Hall Server" as Hall {
  rectangle "HallManager" as HallManager
}

rectangle "World Server" as World {
  rectangle "WorldManager" as WorldManager
}

rectangle "Resource Server" as Resource

rectangle "ZooKeeper" as ZK

rectangle "API (Login/Charge)" as API

' ========== Connections ==========
Client -> Gate : TCP (custom protocol)
Gate -> ClientManager : handle connections
Gate -> UserManager : manage sessions
Gate -> GameManager : manage backend connections

Gate <--> ZK : register/discover services
Hall <--> ZK : register/discover services
World <--> ZK : register/discover services

GameManager -> Hall : gRPC
HallManager -> World : gRPC
WorldManager -> WorldManager : manage world logic

HallManager -> ClientManager : watch services
WorldManager -> ClientManager : watch services

Resource --> Gate : service support
Resource --> Hall : service support
Resource --> World : service support

API --> Gate : login/charge (not detailed)
@enduml