@startuml jinnerbichler_flash-home
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Home Assistant" as HA {
}

rectangle "Coffee Machine Client" as Client #lightblue

rectangle "MQTT Broker" as MQTT #aliceblue

rectangle "Flash Servers" as Flash {
  rectangle "Coffee Machine\nFlash Server" as CMFlash #palegreen
  rectangle "Provider\nFlash Server" as ProviderFlash #lightyellow
}

rectangle "IOTA Tangle\n(Private Testnet)" as IOTA #mistyrose

' ========== Connections ==========
User --> HA : Interacts with UI\n(initiate coffee,\nmanage channels)

HA <--> MQTT : Publish/subscribe\nto coffee machine\ncommands/state
Client <--> MQTT : Subscribe to commands\nPublish state updates

Client --> CMFlash : Initialize/fund/close\nchannel\nSign transactions
CMFlash <--> ProviderFlash : Flash channel\noperations
ProviderFlash --> IOTA : Anchor channel\nstate to Tangle

Client --> Client : Brew coffee\nProcess payment
@enduml