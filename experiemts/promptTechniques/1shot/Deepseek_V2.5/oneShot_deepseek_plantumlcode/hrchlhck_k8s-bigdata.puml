@startuml hrchlhck_k8s-bigdata
skinparam rectangle {
  BackgroundColor<<k8s>> #d9e7fd
  BackgroundColor<<hadoop>> #d8f5d3
  BackgroundColor<<spark>> #fddddd
  BackgroundColor<<benchmark>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Kubernetes Cluster" <<k8s>> {
  rectangle "Master Node" as MasterNode
  rectangle "Worker Nodes" as WorkerNodes
  MasterNode --> WorkerNodes
}

package "Hadoop Components" <<hadoop>> {
  rectangle "NameNode" as NameNode
  rectangle "ResourceManager" as ResourceManager
  rectangle "HistoryServer" as HistoryServer
  rectangle "DataNode" as DataNode
  NameNode --> DataNode
  ResourceManager --> DataNode
  HistoryServer --> DataNode
}

package "Spark Components" <<spark>> {
  rectangle "Spark Master" as SparkMaster
  rectangle "Spark Workers" as SparkWorkers
  SparkMaster --> SparkWorkers
}

package "Benchmark Suite" <<benchmark>> {
  rectangle "HiBench" as HiBench
  rectangle "Workloads" as Workloads
  HiBench --> Workloads
}

MasterNode --> NameNode
MasterNode --> ResourceManager
MasterNode --> HistoryServer
MasterNode --> SparkMaster
WorkerNodes --> DataNode
WorkerNodes --> SparkWorkers
NameNode --> HiBench
SparkMaster --> HiBench
@enduml