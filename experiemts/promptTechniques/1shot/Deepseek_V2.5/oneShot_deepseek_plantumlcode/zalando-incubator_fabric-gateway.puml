@startuml zalando-incubator_fabric-gateway
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "API Consumer" as Consumer

rectangle "Kubernetes Cluster" as K8s {
  rectangle "Fabric Gateway\nOperator" as Operator #palegreen
  rectangle "FabricGateway\nCRD" as CRD #lightyellow
  rectangle "Skipper\nIngress" as Skipper #lightsteelblue
  rectangle "StackSet" as StackSet #aliceblue
}

rectangle "IAM Service" as IAM #mistyrose

' ========== Connections ==========
Consumer --> Skipper : API Requests

' Operator interactions
Operator --> CRD : Watches for changes
Operator --> Skipper : Generates/manages\nIngress resources
Operator --> StackSet : Discovers services
Operator --> IAM : Validates tokens

' Skipper interactions
Skipper --> StackSet : Routes traffic\nto backend services
Skipper --> IAM : Validates auth tokens

' Validation flow
CRD --> Operator : Triggers validation\nvia webhook
Operator --> CRD : Approves/rejects\nCRD changes

' StackSet interactions
StackSet --> Operator : Notifies about\nservice changes
@enduml