@startuml DevOps-Represent_devopsgirls-bootcamp-cn-2
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<api>> #d8f5d3
  BackgroundColor<<compute>> #fddddd
  BackgroundColor<<storage>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "User" as User

package "Frontend (React)" <<frontend>> {
  rectangle "App.js" as App
  rectangle "TodoList.js" as TodoList
  rectangle "NewTodoForm.js" as Form
  rectangle "config.js" as Config
  App --> TodoList
  App --> Form
  App --> Config
}

package "API Gateway" <<api>> {
  rectangle "REST API" as API
  rectangle "/{proxy+}" as Proxy
  API --> Proxy
}

package "Lambda Function" <<compute>> {
  rectangle "index.js" as Lambda
  rectangle "CRUD Handler" as Handler
  Lambda --> Handler
}

package "Storage" <<storage>> {
  database "DynamoDB" as DynamoDB
  rectangle "S3 Bucket" as S3
}

User --> App
App --> API
Proxy --> Lambda
Handler --> DynamoDB
S3 --> App

@enduml