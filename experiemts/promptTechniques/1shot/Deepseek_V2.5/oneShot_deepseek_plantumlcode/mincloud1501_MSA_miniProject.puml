@startuml mincloud1501_MSA_miniProject
skinparam rectangle {
  BackgroundColor<<docker>> #d9e7fd
  BackgroundColor<<kubernetes>> #d8f5d3
  BackgroundColor<<istio>> #fddddd
  BackgroundColor<<cloud>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Docker" <<docker>> {
  rectangle "Dockerfile" as Dockerfile
  rectangle "Nginx Image" as NginxImage
  rectangle "build.sh" as BuildScript
  rectangle "push.sh" as PushScript
  Dockerfile --> NginxImage
  BuildScript --> NginxImage
  NginxImage --> PushScript
}

package "Kubernetes" <<kubernetes>> {
  rectangle "kubProvisioning.sh" as KubScript
  rectangle "Deployment" as Deployment
  rectangle "Service" as Service
  rectangle "Pods" as Pods
  KubScript --> Deployment
  Deployment --> Pods
  Deployment --> Service
}

package "Istio" <<istio>> {
  rectangle "Envoy Sidecar" as Envoy
  rectangle "Traffic Management" as TrafficMgmt
  rectangle "Fault Injection" as FaultInjection
  Envoy --> TrafficMgmt
  TrafficMgmt --> FaultInjection
}

package "Cloud Providers" <<cloud>> {
  rectangle "GKE" as GKE
  rectangle "AWS" as AWS
  rectangle "Azure" as Azure
}

NginxImage --> Deployment
Service --> Envoy
Envoy --> GKE
Envoy --> AWS
Envoy --> Azure
@enduml