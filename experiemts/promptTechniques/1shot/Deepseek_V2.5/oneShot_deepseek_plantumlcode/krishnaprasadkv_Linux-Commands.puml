@startuml krishnaprasadkv_Linux-Commands
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<docs>> #d8f5d3
  BackgroundColor<<config>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Documentation" <<core>> {
  rectangle "README.md" as readme
  rectangle "Command Tutorials" as commands
  rectangle "Concept Explanations" as concepts
  rectangle "Examples" as examples
  readme --> commands
  readme --> concepts
  commands --> examples
  concepts --> examples
}

package "Markdown Files" <<docs>> {
  rectangle "Basic Commands" as basic
  rectangle "Filter Commands" as filter
  rectangle "File Permissions" as permissions
  rectangle "Process Management" as process
  rectangle "User/Group Admin" as useradmin
  rectangle "VI Editor" as vi
  commands --> basic
  commands --> filter
  commands --> permissions
  commands --> process
  commands --> useradmin
  commands --> vi
}

rectangle "_config.yml" <<config>> as config
readme --> config
@enduml