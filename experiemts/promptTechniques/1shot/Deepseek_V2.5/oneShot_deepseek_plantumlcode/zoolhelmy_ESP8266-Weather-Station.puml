@startuml zoolhelmy_ESP8266-Weather-Station
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "ESP8266 NodeMCU" as ESP8266 {
  rectangle "Weather Station Firmware" as Firmware
}

rectangle "OpenWRT Router" as Router {
  rectangle "Mosquitto Subscriber" as Mosquitto
  rectangle "Collectd" as Collectd
  rectangle "RRDTool" as RRDTool
  rectangle "Cron Jobs" as Cron
}

rectangle "ThingSpeak IoT" as ThingSpeak #lightblue
rectangle "GitHub Repository" as GitHub #aliceblue

' ========== Connections ==========
Firmware --> ThingSpeak : MQTT publish\n(sensor data)
Firmware --> Mosquitto : MQTT publish\n(sensor data)

Mosquitto --> Collectd : Write to\ntemp files
Collectd --> RRDTool : Update\ndatabase
RRDTool --> Cron : Generate\ngraphs
Cron --> GitHub : Push graphs\nvia git

ESP8266 --> Router : HTTP requests\n(local interface)
@enduml