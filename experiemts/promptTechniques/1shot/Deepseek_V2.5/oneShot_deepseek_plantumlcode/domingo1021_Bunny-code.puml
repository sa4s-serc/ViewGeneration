```plantuml
@startuml domingo1021_Bunny-code
rectangle "Client" as CLIENT
rectangle "Nginx\\nReverse Proxy" as NGINX
rectangle "Express\\nBackend" as EXPRESS
rectangle "Socket.IO" as SOCKET
rectangle "MySQL" as MYSQL
rectangle "InfluxDB" as INFLUX
rectangle "Redis" as REDIS
rectangle "Docker\\nSandbox" as DOCKER
rectangle "S3" as S3
rectangle "CloudFront" as CLOUDFRONT
rectangle "CloudWatch" as CLOUDWATCH

CLIENT -> NGINX : HTTPS Requests
NGINX -> EXPRESS : Proxy Requests
EXPRESS -> MYSQL : CRUD Operations
EXPRESS -> INFLUX : Time-Series Data
EXPRESS -> REDIS : Caching/State
EXPRESS -> SOCKET : Real-time Events
SOCKET --> CLIENT : Push Updates
EXPRESS -> DOCKER : Execute Code
DOCKER --> EXPRESS : Execution Results
EXPRESS -> S3 : Store Files
S3 -> CLOUDFRONT : CDN Delivery
EXPRESS -> CLOUDWATCH : Logs/Metrics
CLIENT -> CLOUDFRONT : Static Assets

note right of NGINX
  SSL Termination
  Load Balancing
end note

note right of EXPRESS
  JWT Authentication
  API Routing
end note

note right of DOCKER
  Isolated Execution
  Resource Limits
end note
@enduml
