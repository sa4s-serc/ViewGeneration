@startuml hyper-prog_hasses
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Web Server\n(Apache/Nginx)" as WS
rectangle "FIFO File\nor TCP Socket" as FIFO
rectangle "hasses SSE Server" as HASSES {
  rectangle "epoll Event Loop" as EPOLL
  rectangle "Client Manager\n(cdata)" as CDATA
  rectangle "SSE Handler\n(chat)" as CHAT
  rectangle "I/O Manager\n(cio)" as CIO
}

rectangle "Client Browser" as CLIENT

' ========== Connections ==========
WS --> FIFO : Push messages\n(SSE events)
FIFO --> HASSES : Read messages

HASSES --> CLIENT : SSE stream\n(HTTP/HTTPS)
CLIENT --> HASSES : SSE subscription\nrequests

' Internal components flow
EPOLL --> CIO : Monitor I/O events
CIO --> CHAT : Handle HTTP requests\nand SSE framing
CHAT --> CDATA : Manage client\nsubscriptions
CDATA --> CHAT : Route messages\nto clients
CIO --> EPOLL : Register/update\nsocket events

' SSL and logging
CIO --> CIO : SSL encryption\nif configured
HASSES --> HASSES : Log events\n(configurable levels)
@enduml