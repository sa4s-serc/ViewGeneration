@startuml 23fa-cpsc490_canyough
skinparam rectangle {
  BackgroundColor<<service>> #d9e7fd
  BackgroundColor<<pipeline>> #d8f5d3
  BackgroundColor<<component>> #fddddd
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Services" <<service>> {
  rectangle "Product Mixer" as ProductMixer
  rectangle "Cr-Mixer" as CrMixer
  rectangle "Home Mixer" as HomeMixer
  rectangle "Follow Recommendations Service" as FRS
  rectangle "Navi Serving Server" as Navi
}

package "Pipelines" <<pipeline>> {
  rectangle "ProductPipelines" as ProductPipelines
  rectangle "MixerPipelines" as MixerPipelines
  rectangle "RecommendationPipelines" as RecPipelines
  rectangle "CandidatePipelines" as CandidatePipelines
  ProductMixer --> ProductPipelines
  CrMixer --> MixerPipelines
  HomeMixer --> RecPipelines
  FRS --> CandidatePipelines
}

package "Components" <<component>> {
  rectangle "Candidate Sources" as CandidateSources
  rectangle "Feature Hydrators" as FeatureHydrators
  rectangle "Filters" as Filters
  rectangle "Scorers" as Scorers
  rectangle "Transformers" as Transformers
  rectangle "Gates" as Gates
  rectangle "Cursors" as Cursors
  ProductPipelines --> CandidateSources
  ProductPipelines --> FeatureHydrators
  ProductPipelines --> Filters
  ProductPipelines --> Scorers
  ProductPipelines --> Transformers
  ProductPipelines --> Gates
  ProductPipelines --> Cursors
}

package "Data Sources" <<data>> {
  rectangle "User Signal Service" as USS
  rectangle "Real Graph" as RealGraph
  rectangle "Earlybird" as Earlybird
  rectangle "TweetyPie" as TweetyPie
  rectangle "Manhattan" as Manhattan
  rectangle "Memcached" as Memcached
  rectangle "Strato" as Strato
  CandidateSources --> USS
  CandidateSources --> RealGraph
  CandidateSources --> Earlybird
  FeatureHydrators --> TweetyPie
  FeatureHydrators --> Manhattan
  FeatureHydrators --> Memcached
  Scorers --> Navi
  Gates --> Strato
}

package "Data Structures" <<data>> {
  rectangle "Candidates" as Candidates
  rectangle "Features" as Features
  rectangle "Queries" as Queries
  rectangle "Presentation Models" as PresentationModels
  CandidateSources --> Candidates
  FeatureHydrators --> Features
  ProductMixer --> Queries
  Scorers --> PresentationModels
}

ProductMixer -[hidden]-> CrMixer
CrMixer -[hidden]-> HomeMixer
HomeMixer -[hidden]-> FRS
@enduml