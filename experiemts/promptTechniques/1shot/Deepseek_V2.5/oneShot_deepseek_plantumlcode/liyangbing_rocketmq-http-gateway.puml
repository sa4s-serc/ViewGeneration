@startuml liyangbing_rocketmq-http-gateway
skinparam rectangle {
  BackgroundColor<<transport>> #d9e7fd
  BackgroundColor<<processor>> #d8f5d3
  BackgroundColor<<common>> #fddddd
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Transport Layer (Netty)" <<transport>> {
  rectangle "RequestDecoder" as Decoder
  rectangle "RequestValidator" as Validator
  rectangle "ResponseEncoder" as Encoder
  rectangle "NettyConnectionManageHandler" as ConnectionHandler
  rectangle "GatewayLoggingHandler" as Logger
  Decoder --> Validator
  Validator --> Encoder
  Validator --> ConnectionHandler
  ConnectionHandler --> Logger
}

package "Processor Layer" <<processor>> {
  rectangle "ProduceMessageProcessor" as MessageProcessor
  rectangle "ProducerManager" as ProducerMgr
  rectangle "ConsumerManager" as ConsumerMgr
  rectangle "HttpMessageListenerConcurrently" as Listener
  rectangle "HttpExecutor" as Executor
  rectangle "SubscriptionChangeWatcher" as Watcher
  
  MessageProcessor --> ProducerMgr
  ConsumerMgr --> Listener
  Listener --> Executor
  Watcher --> ProducerMgr
  Watcher --> ConsumerMgr
}

package "Common Layer" <<common>> {
  rectangle "Service" as Service
  rectangle "HttpClients" as HttpClientFactory
  rectangle "Subscription" as Subscription
  Service --> HttpClientFactory
  HttpClientFactory --> Executor
  Subscription --> Watcher
}

package "External Systems" <<external>> {
  rectangle "HTTP Clients" as HTTP
  rectangle "RocketMQ" as MQ
}

HTTP --> Decoder
Encoder --> HTTP
ProducerMgr --> MQ
MQ --> Listener
@enduml