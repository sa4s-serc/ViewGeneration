@startuml hypertrack_live-app-android
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Android App" as App {
  rectangle "UI Layer" as UI
  rectangle "CognitoClient" as Cognito
  rectangle "BackendClientFactory" as Factory
  rectangle "GeofenceApiAdapter" as Geofence
}

rectangle "HyperTrack SDK" as HyperTrack #mistyrose

rectangle "Backend Module" as Backend #lightsteelblue {
  rectangle "Trips API Client" as TripsAPI
}

rectangle "AWS Cognito" as AWS #lightyellow
rectangle "Google Maps" as Maps #aliceblue
rectangle "Branch.io" as Branch #lavender

' ========== Connections ==========
User --> UI : Interacts with\nlocation sharing UI

' Authentication flow
UI -> Cognito : login/signup
Cognito -> AWS : authenticate
AWS --> Cognito : auth tokens
Cognito --> UI : auth status

' Location tracking flow
UI -> HyperTrack : start/stop tracking
HyperTrack --> UI : location updates
UI -> Maps : display location

' Backend interactions
UI -> Factory : request backend operation
Factory -> Backend : create client
Backend -> TripsAPI : call HyperTrack API
TripsAPI --> Backend : trip data
Backend --> UI : operation result

' Geofencing flow
UI -> Geofence : manage home location
Geofence --> UI : geofence events

' Deep linking
Branch --> UI : handle deep links
@enduml