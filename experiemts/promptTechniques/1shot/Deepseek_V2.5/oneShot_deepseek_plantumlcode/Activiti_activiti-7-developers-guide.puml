@startuml Activiti_activiti-7-developers-guide
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<runtime>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<services>> #fff1c9
  BackgroundColor<<infra>> #e6d9ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Components" <<core>> {
  rectangle "Activiti Core\n(BPMN Engine)" as Core
  rectangle "BPMN Modeling App" as Modeler
}

package "Runtime Services" <<runtime>> {
  rectangle "Runtime Bundle" as Runtime
  rectangle "Cloud Connectors" as Connectors
  Core --> Runtime
  Runtime --> Connectors
}

package "Supporting Services" <<services>> {
  rectangle "Query Service" as Query
  rectangle "Audit Service" as Audit
  rectangle "Notification Service" as Notification
  Runtime --> Query
  Runtime --> Audit
  Runtime --> Notification
}

package "Integration" <<integration>> {
  rectangle "Spring Cloud Stream" as Stream
  rectangle "Spring Cloud Gateway" as Gateway
  rectangle "Keycloak (SSO)" as Keycloak
  Connectors --> Stream
  Gateway --> Runtime
  Gateway --> Query
  Gateway --> Audit
  Gateway --> Notification
  Keycloak --> Gateway
}

package "Infrastructure" <<infra>> {
  rectangle "Kubernetes" as K8s
  rectangle "Helm Charts" as Helm
  rectangle "Jenkins X" as Jenkins
  K8s --> Helm
  Helm --> Jenkins
  Core -[hidden]-> K8s
  Runtime -[hidden]-> K8s
  Query -[hidden]-> K8s
  Audit -[hidden]-> K8s
  Notification -[hidden]-> K8s
  Gateway -[hidden]-> K8s
  Keycloak -[hidden]-> K8s
}

Modeler --> Core
@enduml