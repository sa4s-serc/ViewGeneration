@startuml today-real-estate_today-real-estate_front-end
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<state>> #d8f5d3
  BackgroundColor<<api>> #fddddd
  BackgroundColor<<utils>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Vue.js)" <<frontend>> {
  rectangle "App.vue" as App
  rectangle "Views" as Views
  rectangle "Components" as Components
  rectangle "Vue Router" as Router
  App --> Views
  Views --> Components
  Views --> Router
}

package "State Management" <<state>> {
  rectangle "Vuex Store" as Store
  rectangle "userStore" as UserStore
  rectangle "searchStore" as SearchStore
  Store --> UserStore
  Store --> SearchStore
}

package "API Layer" <<api>> {
  rectangle "Axios Client" as Axios
  rectangle "API Modules" as APIModules
  rectangle "Interceptors" as Interceptors
  Axios --> APIModules
  Axios --> Interceptors
}

package "Utilities" <<utils>> {
  rectangle "Cookies" as Cookies
  rectangle "EventBus" as EventBus
  rectangle "Filters" as Filters
}

Components --> Store
Views --> Store
APIModules --> Axios
Axios --> Store
Components --> APIModules
Views --> APIModules
Components --> EventBus
Components --> Filters
Store --> Cookies

rectangle "Kakao Maps API" as KakaoMaps
Components --> KakaoMaps

rectangle "Backend API" as Backend
Axios --> Backend
@enduml