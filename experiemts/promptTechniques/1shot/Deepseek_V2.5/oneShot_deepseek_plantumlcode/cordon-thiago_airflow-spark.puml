@startuml cordon-thiago_airflow-spark
skinparam rectangle {
  BackgroundColor<<spark>> #d9e7fd
  BackgroundColor<<orchestration>> #d8f5d3
  BackgroundColor<<storage>> #fddddd
  BackgroundColor<<container>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Apache Spark Core" <<spark>> {
  rectangle "Spark Core\n(RDDs)" as RDD
  rectangle "Spark SQL\n(DataFrames)" as SQL
  rectangle "Spark MLlib" as MLlib
  rectangle "Spark Streaming" as Streaming
  rectangle "GraphX" as GraphX
  rectangle "SparkR" as SparkR
  RDD --> SQL
  RDD --> MLlib
  RDD --> Streaming
  RDD --> GraphX
  RDD --> SparkR
}

package "Orchestration" <<orchestration>> {
  rectangle "Apache Airflow" as Airflow
  rectangle "Kubernetes" as K8s
  Airflow --> K8s
}

package "Storage" <<storage>> {
  rectangle "PostgreSQL" as Postgres
  rectangle "HDFS" as HDFS
  rectangle "Kafka" as Kafka
}

package "Containerization" <<container>> {
  rectangle "Docker" as Docker
  rectangle "K8s Manifests" as Manifests
  Docker --> Manifests
}

RDD --> HDFS
SQL --> Postgres
Streaming --> Kafka
MLlib --> Postgres
Airflow --> RDD
K8s --> Docker
@enduml