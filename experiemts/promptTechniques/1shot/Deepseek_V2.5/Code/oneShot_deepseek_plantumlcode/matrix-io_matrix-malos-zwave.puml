@startuml matrix-io_matrix-malos-zwave
skinparam rectangle {
  BackgroundColor<<driver>> #d9e7fd
  BackgroundColor<<service>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<tools>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Z-Wave Driver" <<driver>> {
  rectangle "DriverZwave" as DriverZwave
  rectangle "Z/IP Gateway" as ZIpGateway
  rectangle "Command Classes" as CommandClasses
  DriverZwave --> ZIpGateway
  DriverZwave --> CommandClasses
}

package "Core Service" <<service>> {
  rectangle "malos_zwave" as MalosZwave
  rectangle "DriverManager" as DriverManager
  rectangle "Protocol Buffers" as Protobuf
  MalosZwave --> DriverManager
  DriverManager --> DriverZwave
  MalosZwave --> Protobuf
}

package "External Integrations" <<integration>> {
  rectangle "MALOS Core" as MalosCore
  rectangle "0MQ" as ZeroMQ
  rectangle "Z-Wave Devices" as ZWaveDevices
  MalosZwave --> MalosCore
  MalosZwave --> ZeroMQ
  DriverZwave --> ZWaveDevices
}

package "Tools & Utilities" <<tools>> {
  rectangle "JavaScript Tools" as JSTools
  rectangle "CMake Build" as CMake
  rectangle "Drone CI" as DroneCI
  JSTools --> ZeroMQ
  CMake --> MalosZwave
  DroneCI --> CMake
}

database "Systemd Service" <<service>> as Systemd
Systemd --> MalosZwave
@enduml