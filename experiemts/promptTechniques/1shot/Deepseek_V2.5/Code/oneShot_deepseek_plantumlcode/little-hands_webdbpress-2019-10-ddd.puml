@startuml little-hands_webdbpress-2019-10-ddd
skinparam rectangle {
  BackgroundColor<<application>> #d9e7fd
  BackgroundColor<<domain>> #d8f5d3
  BackgroundColor<<infra>> #fddddd
  BackgroundColor<<shared>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Application Layer" <<application>> {
  rectangle "ScreeningApplicationService\n(V1-V4)" as AppService
  rectangle "Controllers" as Controllers
}

package "Domain Layer" <<domain>> {
  rectangle "Screening\n(V1-V4)" as Screening
  rectangle "Interview\n(V1-V4)" as Interview
  rectangle "Value Objects\n(EmailAddress, ScreeningId)" as VOs
  rectangle "ScreeningStatus\n(V1-V4)" as Status
  rectangle "ScreeningStepResult" as StepResult
}

package "Infrastructure Layer" <<infra>> {
  rectangle "ScreeningRepository" as Repo
  rectangle "ScreeningDao" as Dao
  rectangle "InterviewDao" as InterviewDao
}

package "Shared" <<shared>> {
  rectangle "ApplicationException" as Exception
  rectangle "Const" as Const
}

AppService --> Screening
AppService --> Interview
AppService --> Status
Screening --> VOs
Screening --> Status
Screening --> StepResult
Status --> StepResult
Interview --> Screening

AppService --> Repo
Repo --> Dao
Repo --> InterviewDao

AppService --> Exception
AppService --> Const
@enduml