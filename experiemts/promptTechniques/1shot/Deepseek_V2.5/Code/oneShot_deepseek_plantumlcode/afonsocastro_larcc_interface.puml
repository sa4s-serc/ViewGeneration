@startuml afonsocastro_larcc_interface
skinparam rectangle {
  BackgroundColor<<robot>> #d9e7fd
  BackgroundColor<<ros>> #d8f5d3
  BackgroundColor<<kinematics>> #fddddd
  BackgroundColor<<vision>> #fff1c9
  BackgroundColor<<modeling>> #e6d9ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "Robot Control" <<robot>> {
  rectangle "UR10e Controller" as UR10e
  rectangle "ROBOTIQ 2F-140 Gripper" as Gripper
  rectangle "URCap Configuration" as URCap
  UR10e --> Gripper : RS485
  UR10e --> URCap
}

package "ROS Ecosystem" <<ros>> {
  rectangle "ur_robot_driver" as RobotDriver
  rectangle "MoveIt!" as MoveIt
  rectangle "RViz Visualization" as RViz
  rectangle "realsense2_camera" as RealSense
  RobotDriver --> MoveIt
  MoveIt --> RViz
}

package "Kinematics" <<kinematics>> {
  rectangle "ur_kinematics" as Kinematics
  rectangle "IK/FK Solvers" as Solvers
  rectangle "MoveIt! Plugins" as Plugins
  Kinematics --> Solvers
  Solvers --> Plugins
  Plugins --> MoveIt
}

package "Vision System" <<vision>> {
  rectangle "RealSense Camera" as Camera
  rectangle "Point Cloud Processing" as PointCloud
  rectangle "RGB-D Tracking" as Tracking
  Camera --> PointCloud
  PointCloud --> Tracking
  Tracking --> MoveIt
}

package "Modeling" <<modeling>> {
  rectangle "URDF/Xacro Models" as URDF
  rectangle "3D Mesh Files (.dae)" as Meshes
  rectangle "Workcell Description" as Workcell
  URDF --> Meshes
  URDF --> Workcell
  Workcell --> RViz
}

UR10e --> RobotDriver
RealSense --> Camera
@enduml