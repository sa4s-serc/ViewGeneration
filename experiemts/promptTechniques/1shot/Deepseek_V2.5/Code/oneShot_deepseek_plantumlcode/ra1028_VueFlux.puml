@startuml ra1028_VueFlux
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<reactive>> #d8f5d3
  BackgroundColor<<internal>> #fddddd
  BackgroundColor<<utils>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "VueFlux Core" <<core>> {
  rectangle "Store" as Store
  rectangle "State" as State
  rectangle "Mutations" as Mutations
  rectangle "Actions" as Actions
  rectangle "Computed" as Computed
  Actions --> Mutations
  Mutations --> State
  State --> Computed
  Store --> State
  Store --> Mutations
  Store --> Actions
  Store --> Computed
}

package "VueFluxReactive" <<reactive>> {
  rectangle "Signal" as Signal
  rectangle "Variable" as Variable
  rectangle "Constant" as Constant
  rectangle "Sink" as Sink
  rectangle "Binder" as Binder
  Variable --> Signal
  Constant --> Signal
  Sink --> Signal
  Signal --> Binder
}

package "VueFluxInternal" <<internal>> {
  rectangle "Storage" as Storage
  rectangle "CancelableProcedure" as Cancelable
  rectangle "Executor" as Executor
  rectangle "AtomicReference" as AtomicRef
  Executor --> AtomicRef
}

package "Utilities" <<utils>> {
  rectangle "Disposable" as Disposable
  rectangle "DisposableScope" as DisposableScope
  Disposable --> DisposableScope
}

Store --> Signal
State --> Variable
Computed --> Constant
Actions --> Executor
@enduml