@startuml KMuthumala_ESP32-BLE-Beaconing
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "ESP32 Device" as ESP32 {
  rectangle "WiFi Module" as WiFi
  rectangle "BLE Scanner" as BLE
  rectangle "MQTT Client" as MQTT
}

rectangle "WiFi Network" as Network #lightblue
rectangle "MQTT Broker" as Broker #palegreen

' ========== Connections ==========
BLE --> BLE : Scan for devices
BLE --> MQTT : Send MAC/RSSI data
WiFi --> Network : Connect
MQTT --> Broker : Publish beacon data
MQTT <-- Broker : Subscribe to commands

' Error handling flows
WiFi --> WiFi : Reconnect if lost
MQTT --> MQTT : Reconnect if lost

note right of BLE
  Extracts MAC addresses
  and RSSI values
end note

note right of MQTT
  Formats data as JSON
  before publishing
end note
@enduml