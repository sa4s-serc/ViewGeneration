@startuml kineviz-3D-human-pose-tracking_3d-ai-powered-pose-tracking
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Webcam Client" as WC
actor "Receiver Client" as RC

rectangle "Node.js Server" as Server {
  rectangle "Express.js" as Express
  rectangle "Socket.IO" as SocketIO
}

rectangle "TensorFlow Models" as TF {
  rectangle "PoseNet/MoveNet" as Models
}

rectangle "Kineviz GraphXR" as GraphXR

' ========== Connections ==========
WC --> Server : Connect via Socket.IO
WC --> Models : Get 2D pose estimation
Models --> WC : Return 2D keypoints
WC --> Server : Send skeleton data (2D poses)

Server --> SocketIO : Broadcast pose data
SocketIO --> RC : Receive 3D pose data

RC --> GraphXR : Visualize 3D skeleton
GraphXR --> RC : Display rendered skeleton

Server --> Express : Handle HTTP requests
Express --> Server : Serve static files

note right of Models
  2D pose estimation from
  multiple webcam feeds
end note

note right of SocketIO
  Real-time bidirectional
  communication
end note
@enduml