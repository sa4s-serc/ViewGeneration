@startuml odh-labs_predictive-maint
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Edge Device/Webcam" as Webcam

rectangle "Kafka Cluster" as Kafka {
  rectangle "Image Topic" as ImageTopic
  rectangle "Results Topic" as ResultsTopic
}

rectangle "Seldon Core" as Seldon {
  rectangle "Model Deployment" as Model
}

rectangle "MinIO" as MinIO

rectangle "Consumer App" as Consumer

rectangle "Web Interface" as WebUI

rectangle "OpenShift" as OCP {
  rectangle "Deployment Automation" as Deploy
}

' ========== Connections ==========
Webcam --> ImageTopic : Streams images
ImageTopic --> Consumer : Subscribes
Consumer --> Model : Calls inference API
Model --> Consumer : Returns predictions
Consumer --> MinIO : Stores results
Consumer --> ResultsTopic : Publishes results
ResultsTopic --> WebUI : Displays predictions
Deploy --> Seldon : Deploys model
Deploy --> Kafka : Configures topics
Deploy --> MinIO : Sets up storage
Deploy --> Consumer : Deploys app
@enduml