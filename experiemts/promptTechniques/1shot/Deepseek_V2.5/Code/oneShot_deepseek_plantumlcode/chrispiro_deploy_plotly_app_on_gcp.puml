@startuml chrispiro_deploy_plotly_app_on_gcp
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor Developer

rectangle "Local Development" as Local {
  rectangle "Jupyter Notebook" as Notebook #palegreen
  rectangle "Python Scripts" as Scripts #lightsteelblue {
    rectangle "dash_app.py" as DashApp
    rectangle "load_data.py" as LoadData
    rectangle "create_charts.py" as CreateCharts
  }
}

rectangle "GCP Services" as GCP #mistyrose {
  rectangle "App Engine" as AppEngine #lightyellow
  rectangle "BigQuery" as BigQuery #aliceblue
  rectangle "Cloud Storage" as CloudStorage #lightblue
}

' ========== Connections ==========
Developer --> Notebook : Develop/test\nvisualizations
Notebook --> CreateCharts : Copy chart code
Developer --> Scripts : Complete TODOs\nin scripts

Scripts --> BigQuery : Load data
Scripts --> CloudStorage : Load data

Developer --> AppEngine : Deploy via\ngcloud CLI
Scripts --> AppEngine : Deployed code
AppEngine --> BigQuery : Runtime data access
AppEngine --> CloudStorage : Runtime data access

@enduml