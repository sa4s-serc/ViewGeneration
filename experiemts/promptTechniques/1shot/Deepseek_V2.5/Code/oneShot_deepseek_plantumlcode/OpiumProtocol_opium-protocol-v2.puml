@startuml OpiumProtocol_opium-protocol-v2
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
}

rectangle "Ethereum Blockchain" as Blockchain #mistyrose {
  rectangle "Registry" as Registry #palegreen
  rectangle "Core" as Core #palegreen
  rectangle "OpiumProxyFactory" as Factory #palegreen
  rectangle "OracleAggregator" as OracleAgg #palegreen
  rectangle "SyntheticAggregator" as SyntheticAgg #palegreen
  rectangle "TokenSpender" as TokenSpender #palegreen
  rectangle "Position Tokens" as Tokens #palegreen
}

rectangle "External Oracles" as Oracles #aliceblue

' ========== Connections ==========
User --> FE

' Frontend interactions
FE <--> Blockchain : create derivative\n trade positions\n settle positions\n manage reserves

' Core contract interactions
Core --> Registry : get configuration\n check roles
Core --> Factory : create position tokens
Core --> SyntheticAgg : validate derivatives\n get payout data
Core --> OracleAgg : get price data for settlement
Core --> TokenSpender : execute token transfers

' Factory interactions
Factory --> Tokens : deploy ERC20 position tokens

' Aggregator interactions
SyntheticAgg --> SyntheticAgg : cache synthetic data
OracleAgg --> Oracles : fetch price data
OracleAgg --> OracleAgg : cache oracle data

' TokenSpender interactions
TokenSpender --> Tokens : manage allowances\n execute transfers
@enduml