@startuml icoxfog417_karura
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Kintone" as Kintone {
  rectangle "Karura Master App" as MasterApp #lightblue
  rectangle "Karura Client Plugin" as ClientPlugin #lightblue
}

rectangle "Karura Server" as Server {
  rectangle "REST API" as API #palegreen
  rectangle "Model Manager" as ModelManager #lightyellow
  rectangle "Model Builder" as ModelBuilder #lightsteelblue
  rectangle "Dataset Handler" as Dataset #aliceblue
  rectangle "Feature Builder" as FeatureBuilder #mistyrose
}

' ========== Connections ==========
User --> Kintone : Interacts with\nKintone UI
Kintone --> MasterApp : Configures ML tasks
Kintone --> ClientPlugin : Triggers training/displays predictions

MasterApp --> API : POST /train\n(initiates training)
ClientPlugin --> API : POST /predict\n(get predictions)

API --> ModelManager : handle training/prediction
ModelManager --> Dataset : load data from Kintone
ModelManager --> FeatureBuilder : build features
ModelManager --> ModelBuilder : train model
ModelBuilder --> ModelManager : trained model
ModelManager --> API : return results

API --> Kintone : training results/predictions
@enduml