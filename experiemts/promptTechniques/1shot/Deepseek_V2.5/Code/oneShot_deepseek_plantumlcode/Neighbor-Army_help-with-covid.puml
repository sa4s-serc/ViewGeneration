@startuml Neighbor-Army_help-with-covid
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Next.js Frontend" as Frontend {
  rectangle "AddressInput" as AddressInput #lightblue
  rectangle "Auth Components" as Auth #lightblue
}

rectangle "Firebase Backend" as Firebase {
  rectangle "Firebase Auth" as FBAuth #palegreen
  rectangle "Firestore" as Firestore #palegreen
  rectangle "Functions" as Functions #palegreen
}

rectangle "External Services" as External {
  rectangle "Onfleet" as Onfleet #lightyellow
  rectangle "Sendgrid" as Sendgrid #lightyellow
  rectangle "Twilio" as Twilio #lightyellow
  rectangle "Google Maps API" as GoogleMaps #lightyellow
}

' ========== Connections ==========
User -> Frontend : Interacts with UI
Frontend -> FBAuth : Authenticates user
Frontend -> GoogleMaps : Address autocomplete

Frontend -> Functions : API calls
Functions -> Firestore : CRUD operations
Functions -> Onfleet : Task management
Functions -> Sendgrid : Email communication
Functions -> Twilio : Phone verification

Onfleet -> Firestore : Syncs task data
@enduml