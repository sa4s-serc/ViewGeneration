@startuml vinijmoura_Azure-DevOps
skinparam rectangle {
  BackgroundColor<<extract>> #d9e7fd
  BackgroundColor<<transform>> #d8f5d3
  BackgroundColor<<load>> #fddddd
  BackgroundColor<<visualize>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Extract (PowerShell)" <<extract>> {
  rectangle "Azure DevOps CLI" as AzCLI
  rectangle "REST API Calls" as REST
  rectangle "Data Collection Scripts" as Scripts
  AzCLI --> Scripts
  REST --> Scripts
}

package "Transform (PowerShell)" <<transform>> {
  rectangle "JSON Parsing" as JSON
  rectangle "Data Filtering" as Filter
  rectangle "PSObject Creation" as PSObj
  Scripts --> JSON
  JSON --> Filter
  Filter --> PSObj
}

package "Load (Azure SQL DB)" <<load>> {
  rectangle "Table Truncation" as Truncate
  rectangle "Data Insertion" as Insert
  rectangle "SQL Tables" as Tables
  PSObj --> Truncate
  Truncate --> Insert
  Insert --> Tables
}

package "Visualize (Power BI)" <<visualize>> {
  rectangle "Data Model" as Model
  rectangle "Custom Visuals" as Visuals
  rectangle "Reports" as Reports
  Tables --> Model
  Model --> Visuals
  Visuals --> Reports
}

database "Azure DevOps" <<external>> as ADO
AzCLI --> ADO
REST --> ADO
@enduml