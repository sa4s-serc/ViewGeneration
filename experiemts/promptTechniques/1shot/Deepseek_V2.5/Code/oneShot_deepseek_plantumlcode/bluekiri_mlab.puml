@startuml bluekiri_mlab
skinparam rectangle {
  BackgroundColor<<dashboard>> #d9e7fd
  BackgroundColor<<worker>> #d8f5d3
  BackgroundColor<<storage>> #fff1c9
  BackgroundColor<<integration>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "MLAB Dashboard" <<dashboard>> {
  rectangle "Flask App" as FlaskApp
  rectangle "API Endpoints" as API
  rectangle "Interactors" as Interactors
  rectangle "Repositories" as DashboardRepos
  rectangle "Frontend" as Frontend

  FlaskApp --> API
  API --> Interactors
  Interactors --> DashboardRepos
  FlaskApp --> Frontend
}

package "Worker Service" <<worker>> {
  rectangle "Falcon API" as FalconAPI
  rectangle "Worker Interactors" as WorkerInteractors
  rectangle "Worker Repositories" as WorkerRepos
  rectangle "Model Loader" as ModelLoader

  FalconAPI --> WorkerInteractors
  WorkerInteractors --> WorkerRepos
  WorkerRepos --> ModelLoader
}

package "Storage" <<storage>> {
  database "MongoDB" as MongoDB
  database "ZooKeeper" as ZooKeeper
}

package "Integrations" <<integration>> {
  rectangle "Email Service" as Email
  rectangle "LDAP Auth" as LDAP
}

DashboardRepos --> MongoDB
DashboardRepos --> ZooKeeper
WorkerRepos --> ZooKeeper
WorkerRepos --> MongoDB
WorkerInteractors --> Email
FlaskApp --> LDAP
@enduml