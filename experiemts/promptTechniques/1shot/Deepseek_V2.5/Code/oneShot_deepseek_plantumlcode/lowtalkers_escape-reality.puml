@startuml lowtalkers_escape-reality
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "React Client" as Client {
  rectangle "App Component" as App
  rectangle "VR Scene Components" as VR
  rectangle "Auth Components" as Auth
}

rectangle "Node.js Server" as Server {
  rectangle "API Endpoints" as API
  rectangle "Controllers" as Controllers
  rectangle "Sequelize ORM" as ORM
}

rectangle "AWS S3" as S3
rectangle "MariaDB" as DB
rectangle "Wikipedia API" as Wiki

' ========== Connections ==========
User --> Client : Interacts with UI

' Client internal flow
App --> Auth : Handle authentication
App --> VR : Render VR scenes
VR --> App : Update scene state

' Client to Server communication
Client --> API : HTTP requests (GET/POST)
API --> Controllers : Route requests
Controllers --> ORM : Database operations
ORM --> DB : SQL queries
DB --> ORM : Query results
ORM --> Controllers : Data objects
Controllers --> API : JSON responses
API --> Client : JSON responses

' External services
Controllers --> S3 : Upload/download images
Controllers --> Wiki : Fetch articles

' User actions flow
User -> Client : Upload image
Client -> API : POST image
API -> Controllers : Process upload
Controllers -> S3 : Store image
Controllers -> ORM : Save metadata
ORM -> DB : Insert record

User -> Client : Bookmark article
Client -> API : POST bookmark
API -> Controllers : Handle bookmark
Controllers -> Wiki : Fetch article
Controllers -> ORM : Save bookmark
ORM -> DB : Insert record

User -> Client : Add comment/like
Client -> API : POST comment/like
API -> Controllers : Process interaction
Controllers -> ORM : Update records
ORM -> DB : Update tables
@enduml