@startuml ut-ims-robotics_robotont
skinparam rectangle {
  BackgroundColor<<driver>> #d9e7fd
  BackgroundColor<<teleop>> #d8f5d3
  BackgroundColor<<training>> #fddddd
  BackgroundColor<<description>> #fff1c9
  BackgroundColor<<sensors>> #e6d9ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "robotont_driver" <<driver>> {
  rectangle "Serial Communication" as Serial
  rectangle "Hardware Interface" as Hardware
  rectangle "Odometry Calculation" as Odometry
  rectangle "robotont_params.yaml" as Params
  Serial --> Hardware
  Hardware --> Odometry
  Hardware --> Params
}

package "robotont_teleop" <<teleop>> {
  rectangle "Teleop Nodes" as TeleopNodes
  rectangle "Navigation Config" as NavConfig
  rectangle "Launch Files" as TeleopLaunch
  TeleopNodes --> NavConfig
  TeleopNodes --> TeleopLaunch
}

package "robotont_training" <<training>> {
  rectangle "Training Scripts" as TrainingScripts
  rectangle "AR Tag Launch" as ARLaunch
  TrainingScripts --> ARLaunch
}

package "robotont_description" <<description>> {
  rectangle "URDF Models" as URDF
  rectangle "Meshes" as Meshes
  rectangle "Materials" as Materials
  URDF --> Meshes
  Meshes --> Materials
}

package "robotont_sensors" <<sensors>> {
  rectangle "LaserScan Processing" as LaserScan
  rectangle "LaserScanSplit Message" as LaserMsg
  LaserScan --> LaserMsg
}

Hardware --> TeleopNodes
TeleopNodes --> TrainingScripts
URDF --> TeleopLaunch
LaserScan --> Hardware
@enduml