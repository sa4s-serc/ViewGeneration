@startuml alfredcs_immersion_day_labs
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Data Scientist" as DS

rectangle "Local Environment" as Local {
  rectangle "Jupyter Notebook" as Notebook #lightblue
  rectangle "Training Scripts" as Scripts #palegreen
}

rectangle "AWS S3" as S3 #aliceblue

rectangle "Amazon SageMaker" as SageMaker #mistyrose {
  rectangle "Training Job" as Training #lightyellow
  rectangle "Model Registry" as Registry #palegoldenrod
  rectangle "Endpoint" as Endpoint #lightsteelblue
}

rectangle "Hugging Face Hub" as HF #peachpuff

' ========== Connections ==========
DS --> Notebook : Develop/Test\nTraining Code
Notebook --> Scripts : Export\nTraining Code
Scripts --> SageMaker : Submit\nTraining Job
S3 --> Training : Input Data
Training --> S3 : Save Model Artifacts
Training --> Registry : Register Model
Registry --> Endpoint : Deploy Model
HF --> Training : Download\nPre-trained Model
Endpoint --> DS : Serve Predictions
DS --> HF : Push Fine-tuned\nModel
@enduml