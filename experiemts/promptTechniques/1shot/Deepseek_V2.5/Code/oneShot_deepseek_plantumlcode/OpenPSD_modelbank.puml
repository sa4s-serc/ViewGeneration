@startuml OpenPSD_modelbank
skinparam rectangle {
  BackgroundColor<<entities>> #d9e7fd
  BackgroundColor<<usecases>> #d8f5d3
  BackgroundColor<<providers>> #fddddd
  BackgroundColor<<presentation>> #fff1c9
  BackgroundColor<<external>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Entities (Domain Layer)" <<entities>> {
  rectangle "FinancialInstitution" as FI
  rectangle "AccountHolder" as AH
  rectangle "Account" as Account
  rectangle "Consent" as Consent
  rectangle "PaymentInstruction" as Payment
  rectangle "LedgerEntry" as Ledger
}

package "Use Cases" <<usecases>> {
  rectangle "ModelBankUsecase" as UseCase
  rectangle "Input/Output Ports" as Ports
  UseCase --> Ports
}

package "Providers (Infrastructure)" <<providers>> {
  rectangle "ModelBankEntityGateway" as Gateway
  rectangle "DbProvider (go-pg)" as DBProvider
  rectangle "gRPC Server" as GRPCServer
  rectangle "Proto Definitions" as Proto
  DBProvider --> Gateway
  GRPCServer --> Proto
}

package "Presentation" <<presentation>> {
  rectangle "ModelBankController" as Controller
  rectangle "gRPC Client" as GRPCClient
  Controller --> GRPCClient
}

database "PostgreSQL" <<external>> as PG
DBProvider --> PG

UseCase --> Gateway
UseCase --> FI
UseCase --> AH
UseCase --> Account
UseCase --> Consent
UseCase --> Payment
UseCase --> Ledger

Controller --> UseCase
GRPCServer --> Controller

Proto --> GRPCClient
@enduml