@startuml lowes_auditor
skinparam rectangle {
  BackgroundColor<<client>> #d9e7fd
  BackgroundColor<<app>> #d8f5d3
  BackgroundColor<<core>> #fddddd
  BackgroundColor<<infra>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Client Library" <<client>> {
  rectangle "Spring Boot Starter" as Starter
  rectangle "Auditor API" as API
  rectangle "Example Apps" as Examples
  Starter --> API
  API --> Examples
}

package "Application Server" <<app>> {
  rectangle "Application.kt" as App
  rectangle "ConsumerService.kt" as Consumer
  rectangle "AuditEventRepositoryService.kt" as Repository
  App --> Consumer
  Consumer --> Repository
}

package "Core Module" <<core>> {
  rectangle "DTO Mappers" as Mappers
  rectangle "JsonObject.kt" as JsonObject
  rectangle "OpenAPI Specs" as Specs
  Mappers --> JsonObject
  Specs --> Mappers
}

package "Infrastructure" <<infra>> {
  rectangle "Kafka" as Kafka
  rectangle "Elasticsearch" as ES
}

API --> Kafka
Consumer --> Kafka
Repository --> ES
Mappers --> Repository
@enduml