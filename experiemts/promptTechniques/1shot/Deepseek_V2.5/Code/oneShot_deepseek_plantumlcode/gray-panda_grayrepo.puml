@startuml gray-panda_grayrepo
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor "Attacker" as Attacker
actor "Victim" as Victim

rectangle "Malware" as Malware #mistyrose {
  rectangle "Anti-Debugging" as AntiDebug #palegreen
  rectangle "Persistence" as Persistence #palegreen
  rectangle "Network Comms" as Network #palegreen
  rectangle "Custom VM" as VM #palegreen
}

rectangle "C2 Server" as C2 #lightsteelblue
rectangle "Victim System" as System #lightyellow {
  rectangle "Documents" as Docs #aliceblue
  rectangle "Crontab" as Crontab #aliceblue
}

rectangle "SSHD Exploit" as SSHD #mistyrose {
  rectangle "Core Dump" as Core #palegreen
  rectangle "ECC Key Recovery" as ECC #palegreen
  rectangle "Shellcode" as Shellcode #palegreen
}

rectangle "Mobile App" as Mobile #lightsteelblue {
  rectangle "Gesture Handler" as Gesture #aliceblue
  rectangle "XOR Encryption" as XOR #aliceblue
}

' ========== Connections ==========
Attacker --> Malware : Deploys
Victim --> Malware : Executes

' Malware interactions
Malware --> System : Encrypts files
Malware --> Crontab : Adds persistence
Malware --> C2 : Communicates via UDP/IRC
VM --> Docs : Processes encryption

' SSHD Exploit interactions
Attacker --> SSHD : Triggers exploit
SSHD --> Core : Analyzes dump
SSHD --> ECC : Recovers keys
SSHD --> Shellcode : Executes payload

' Mobile App interactions
Victim --> Mobile : Interacts
Mobile --> Gesture : Handles swipes
Mobile --> XOR : Decrypts flag
@enduml