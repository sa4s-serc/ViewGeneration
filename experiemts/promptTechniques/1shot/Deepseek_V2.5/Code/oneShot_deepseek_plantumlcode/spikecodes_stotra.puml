@startuml spikecodes_stotra
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "AWS Amplify" as Amplify {
  rectangle "React Frontend" as Frontend #lightblue
}

rectangle "AWS EC2" as EC2 {
  rectangle "Node.js/Express Backend" as Backend #palegreen
}

rectangle "MongoDB Atlas" as MongoDB #aliceblue

rectangle "External APIs" as APIs {
  rectangle "Yahoo Finance" as Yahoo #lightyellow
  rectangle "Alpha Vantage" as Alpha #lightyellow
  rectangle "NewsFilter" as News #lightyellow
}

' ========== Connections ==========
User --> Frontend : Interacts with UI

Frontend --> Backend : REST API calls\n(authentication, stock data,\nportfolio, watchlist)
Backend --> Frontend : JSON responses

Backend --> MongoDB : CRUD operations\n(user data, transactions,\npositions)
MongoDB --> Backend : Query results

Backend --> Yahoo : Fetch stock data
Yahoo --> Backend : Market data

Backend --> Alpha : Fetch historical data
Alpha --> Backend : Time series data

Backend --> News : Fetch news articles
News --> Backend : News feed

' Deployment flow
Frontend -[hidden]-> Amplify : Hosted on\nAWS Amplify
Backend -[hidden]-> EC2 : Deployed on\nAWS EC2
@enduml