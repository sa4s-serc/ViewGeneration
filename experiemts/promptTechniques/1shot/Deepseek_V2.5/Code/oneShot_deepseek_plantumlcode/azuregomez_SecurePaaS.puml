@startuml azuregomez_SecurePaaS
skinparam rectangle {
  BackgroundColor<<web>> #d9e7fd
  BackgroundColor<<db>> #d8f5d3
  BackgroundColor<<security>> #fddddd
  BackgroundColor<<network>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "Azure App Service" <<web>> as AppService {
  rectangle "Web Application" as WebApp
}

rectangle "Azure SQL Database" <<db>> as SQLDB {
  rectangle "Private Endpoint" as PrivateEndpoint
}

rectangle "Azure Firewall" <<security>> as Firewall {
  rectangle "Outbound Inspection" as Inspection
}

rectangle "Web Application Firewall" <<security>> as WAF {
  rectangle "OWASP Protection" as OWASP
}

rectangle "Virtual Network" <<network>> as VNet {
  rectangle "Subnet" as Subnet
}

rectangle "Secret Management" <<security>> as Secrets {
  rectangle "Key Vault" as KeyVault
}

AppService --> WAF : "Protected by"
AppService --> VNet : "Injected into"
VNet --> Subnet : "Contains"
Subnet --> Firewall : "Routes through"
Firewall --> SQLDB : "Inspects traffic to"
SQLDB --> PrivateEndpoint : "Access via"
WebApp --> Secrets : "Retrieves credentials from"
WAF --> OWASP : "Implements"
Firewall --> Inspection : "Performs"
@enduml