@startuml NatalieLouise91_T3A2-Skemi-FrontEnd
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<components>> #d8f5d3
  BackgroundColor<<utils>> #fddddd
  BackgroundColor<<services>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core" <<core>> {
  rectangle "App.js" as App
  rectangle "index.js" as Index
  rectangle "README.md" as Readme
  Index --> App
}

package "Components" <<components>> {
  rectangle "Nav.js" as Nav
  rectangle "Login.js" as Login
  rectangle "NewUser.js" as NewUser
  rectangle "Occasion/\nCreateViewList.js" as Occasion
  rectangle "Roster/\nCreateViewEdit.js" as Roster
}

package "Utils" <<utils>> {
  rectangle "stateContext.js" as Context
  rectangle "stateReducer.js" as Reducer
  Context --> Reducer
}

package "Services" <<services>> {
  rectangle "api.js" as API
  rectangle "authServices.js" as Auth
  rectangle "occasionServices.js" as OccasionService
  rectangle "rosterServices.js" as RosterService
  rectangle "userServices.js" as UserService
  API --> Auth
  API --> OccasionService
  API --> RosterService
  API --> UserService
}

App --> Nav
App --> Login
App --> NewUser
App --> Occasion
App --> Roster
App --> Context

Occasion --> OccasionService
Roster --> RosterService
Login --> Auth
NewUser --> UserService
@enduml