@startuml IceFireDB_IceFireDB
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<proxy>> #d8f5d3
  BackgroundColor<<protocol>> #fddddd
  BackgroundColor<<security>> #fff1c9
  BackgroundColor<<telemetry>> #e6d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Database" <<core>> {
  rectangle "LevelDB Storage" as LevelDB
  rectangle "Redis Protocol Layer" as Redis
  rectangle "Raft Consensus (Uhaha)" as Raft
  rectangle "Data Structures" as DataStructs
  rectangle "Transaction Manager" as TxManager
  Redis --> LevelDB
  Raft --> Redis
  DataStructs --> Redis
  TxManager --> Raft
}

package "SQL Proxy" <<proxy>> {
  rectangle "MySQL Proxy" as MySQLProxy
  rectangle "P2P Network (libp2p)" as P2P
  rectangle "Storage Engines" as StorageEngines
  rectangle "Connection Pool" as ConnPool
  rectangle "Query Cache" as QueryCache
  MySQLProxy --> P2P
  MySQLProxy --> StorageEngines
  MySQLProxy --> ConnPool
  MySQLProxy --> QueryCache
}

package "Protocol & Communication" <<protocol>> {
  rectangle "gRPC Server" as GRPCServer
  rectangle "Protocol Buffers" as Protobuf
  rectangle "HTTP/2 Transport" as HTTP2
  GRPCServer --> Protobuf
  GRPCServer --> HTTP2
}

package "Security" <<security>> {
  rectangle "Crypto Library" as Crypto
  rectangle "Key Management" as KeyMgmt
  rectangle "Random Generator" as RandomGen
  Crypto --> KeyMgmt
  Crypto --> RandomGen
}

package "Telemetry" <<telemetry>> {
  rectangle "OpenTelemetry API" as OTEL
  rectangle "Metrics & Tracing" as Metrics
  rectangle "Exporters" as Exporters
  OTEL --> Metrics
  Metrics --> Exporters
}

Redis --> GRPCServer
MySQLProxy --> GRPCServer
GRPCServer --> Crypto
OTEL --> GRPCServer
OTEL --> MySQLProxy
@enduml