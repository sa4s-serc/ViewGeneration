@startuml JessNah_BeeGreen
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Chrome Extension" as Extension {
  rectangle "background.ts" as Background
  rectangle "contentScript.tsx" as ContentScript
  rectangle "popup.tsx" as Popup
}

rectangle "Client Website" as Client {
  rectangle "App.js" as App
  rectangle "DashBoard.js" as Dashboard
  rectangle "Contribute.js" as Contribute
}

rectangle "Server" as Server {
  rectangle "application.ts" as Application
  rectangle "controllers" as Controllers
  rectangle "dataprocessing.ts" as DataProcessing
}

database "IBM Cloudant" as Cloudant

' ========== Connections ==========
User --> Extension : interacts with\nshopping sites
User --> Client : views dashboard\ncontributes data

' Extension internal flow
Background -> ContentScript : tab update event
ContentScript -> Popup : injects side tab
Popup -> ContentScript : gets cart data

' Extension to Server
ContentScript -> Server : POST cart data\nGET sustainability scores
Popup -> Server : POST reviews\nGET alternatives

' Client to Server
App -> Server : GET/POST user data
Dashboard -> Server : GET purchase history\nGET impact metrics
Contribute -> Server : POST sustainability data

' Server to Database
Controllers -> Cloudant : CRUD operations
DataProcessing -> Cloudant : read/write\nprocessed data

' Server internal flow
Application -> Controllers : routes requests
Controllers -> DataProcessing : process data
DataProcessing -> Controllers : return results
@enduml