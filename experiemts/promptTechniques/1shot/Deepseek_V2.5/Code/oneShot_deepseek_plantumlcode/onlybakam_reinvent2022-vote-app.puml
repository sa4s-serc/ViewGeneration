@startuml onlybakam_reinvent2022-vote-app
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Next.js Frontend" as Frontend {
}

rectangle "AWS AppSync" as AppSync #lightblue

rectangle "DynamoDB" as DynamoDB #lightgreen

rectangle "SNS" as SNS #lightyellow

rectangle "AWS Translate" as Translate #mistyrose

' ========== Connections ==========
User -> Frontend : Votes (BR/CM)\nSelects message

Frontend -> AppSync : AddVote mutation
AppSync -> DynamoDB : saveToDynamodb\n(resolver)
AppSync -> SNS : publishToSNS\n(resolver)
AppSync -> Translate : translateMessage\n(resolver)

AppSync --> Frontend : OnPlusOne subscription\n(real-time updates)
DynamoDB --> AppSync : Vote data
SNS --> AppSync : Vote event
Translate --> AppSync : Translated message

Frontend <--> AppSync : getTotals query\n(initial load)
@enduml