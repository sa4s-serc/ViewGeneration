@startuml yoshixmk_remarks
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Chrome Extension" as Extension #lightblue {
  rectangle "popup.html" as Popup
  rectangle "record.js" as RecordJS
}

rectangle "Deno Web Server" as Server #palegreen {
  rectangle "server.ts" as MainServer
  rectangle "handlers/" as Handlers
  rectangle "queryFauna.ts" as QueryFauna
}

rectangle "FaunaDB" as FaunaDB #mistyrose

rectangle "GitPress Blog" as GitPress #aliceblue

' ========== Connections ==========
User --> Popup : Interacts with\nmeeting buttons
Popup --> RecordJS : Triggers remark\nrecording
RecordJS --> MainServer : POST /remarks\n(remark data)

MainServer --> Handlers : Routes requests
Handlers --> QueryFauna : Executes\nFaunaDB queries
QueryFauna --> FaunaDB : GraphQL\nrequests
FaunaDB --> QueryFauna : Query results

MainServer --> GitPress : Fetches RSS feed\nfor travelogue
GitPress --> MainServer : Returns blog content

Handlers --> User : Renders homepage\nwith remark count\nand travelogue
@enduml