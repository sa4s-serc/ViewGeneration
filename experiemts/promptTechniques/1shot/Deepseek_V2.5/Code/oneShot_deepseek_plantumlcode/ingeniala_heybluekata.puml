@startuml ingeniala_heybluekata
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  BackgroundColor<<aws>> #ffd8d8
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend" <<frontend>> {
  rectangle "Web Interface" as Web
  rectangle "Mobile Interface" as Mobile
}

package "Backend for Frontend" <<backend>> {
  rectangle "Omnichannel BFF" as OmniBFF
  rectangle "HeyBlue BFF Mobile" as MobileBFF
  rectangle "BFF Web Container" as WebBFF
  Web --> WebBFF
  Mobile --> MobileBFF
  WebBFF --> OmniBFF
  MobileBFF --> OmniBFF
}

package "Core Services" <<backend>> {
  rectangle "User Management\n(AWS Cognito)" as UserMgmt
  rectangle "Interaction & Gamification" as Gamification
  rectangle "Commerce Service" as Commerce
  rectangle "Content Management" as Content
  rectangle "Notification Service" as Notification
  OmniBFF --> UserMgmt
  OmniBFF --> Gamification
  OmniBFF --> Commerce
  OmniBFF --> Content
  OmniBFF --> Notification
}

package "AWS Services" <<aws>> {
  rectangle "API Gateway" as APIGateway
  rectangle "Lambda" as Lambda
  rectangle "DynamoDB" as DynamoDB
  rectangle "S3/CloudFront" as S3
  rectangle "Kinesis" as Kinesis
  rectangle "Athena" as Athena
  rectangle "Glacier" as Glacier
  rectangle "EventBridge" as EventBridge
  
  UserMgmt --> APIGateway
  Gamification --> Lambda
  Commerce --> DynamoDB
  Content --> S3
  Notification --> Kinesis
  Kinesis --> EventBridge
  DynamoDB --> Athena
  DynamoDB --> Glacier
}

package "Data & Analytics" <<db>> {
  rectangle "Data Lake (S3)" as DataLake
  rectangle "Metabase" as Metabase
  Athena --> DataLake
  DataLake --> Glacier
  Athena --> Metabase
}

@enduml