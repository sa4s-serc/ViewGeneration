@startuml calmato_gran-book
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (Nuxt.js)" <<frontend>> {
  rectangle "Pages" as Pages
  rectangle "Components" as Components
  rectangle "Vuex Store" as Vuex
  rectangle "Layouts" as Layouts
  rectangle "Plugins" as Plugins
  Pages --> Components
  Components --> Vuex
  Components --> Layouts
  Plugins --> Pages
  Plugins --> Components
}

package "Backend (Go)" <<backend>> {
  rectangle "API Gateway" as Gateway
  rectangle "Domain Layer" as Domain
  rectangle "Application Layer" as App
  rectangle "Infrastructure Layer" as Infra
  Gateway --> App
  App --> Domain
  App --> Infra
  Infra --> Domain
}

package "Integrations" <<integration>> {
  rectangle "Firebase Auth" as Firebase
  rectangle "gRPC Services" as gRPC
  rectangle "Image Storage" as Images
  rectangle "Swagger API Docs" as Swagger
  Gateway --> Firebase
  Gateway --> gRPC
  Infra --> Images
  App --> Swagger
}

database "Relational DB" <<db>> as DB
Infra --> DB

Frontend --> Backend : REST API
@enduml