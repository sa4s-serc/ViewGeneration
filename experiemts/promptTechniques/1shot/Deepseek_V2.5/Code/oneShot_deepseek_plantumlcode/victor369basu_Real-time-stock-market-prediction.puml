@startuml victor369basu_Real-time-stock-market-prediction
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
}

rectangle "Kafka" as Kafka #mistyrose {
  rectangle "Stock Data Topic" as DataTopic #palegreen
  rectangle "Predictions Topic" as PredictTopic #palegreen
}

rectangle "producer.js" as Producer #lightsteelblue
rectangle "consumer.js" as Consumer #lightsteelblue
rectangle "ml_consumer.js" as MLConsumer #lightsteelblue
rectangle "tf_train.js" as Trainer #lightyellow
rectangle "tf_validate.js" as Validator #lightyellow
rectangle "tf_model.js" as Model #lightyellow
rectangle "pre_process.js" as Preprocessor #aliceblue
rectangle "MongoDB" as MongoDB #aliceblue

' ========== Connections ==========
User --> FE : Requests predictions
FE --> Kafka : Subscribes to predictions

' Data flow
Producer --> DataTopic : Publishes stock data
DataTopic --> Consumer : Streams raw data
Consumer --> MongoDB : Stores raw data
DataTopic --> MLConsumer : Streams data for prediction
MLConsumer --> Preprocessor : Preprocesses data
Preprocessor --> Model : Feeds processed data
Model --> MLConsumer : Returns predictions
MLConsumer --> PredictTopic : Publishes predictions
PredictTopic --> FE : Delivers predictions

' Training flow
Trainer --> Model : Trains model
Model --> Trainer : Returns weights
Trainer --> MongoDB : Stores model weights
Validator --> Model : Loads model
Validator --> MongoDB : Gets test data
Validator --> Model : Validates model
Validator --> MongoDB : Stores metrics

' Preprocessing
Preprocessor --> MongoDB : Gets scaling params
@enduml