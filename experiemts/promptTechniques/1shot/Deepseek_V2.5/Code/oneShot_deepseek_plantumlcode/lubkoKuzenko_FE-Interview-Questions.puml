@startuml lubkoKuzenko_FE-Interview-Questions
skinparam rectangle {
  BackgroundColor<<content>> #d9e7fd
  BackgroundColor<<structure>> #d8f5d3
  BackgroundColor<<examples>> #fddddd
  BackgroundColor<<metadata>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Content" <<content>> {
  rectangle "Interview Questions" as Questions
  rectangle "Detailed Answers" as Answers
  rectangle "Code Snippets" as Snippets
  rectangle "External Resources" as Resources
  Questions --> Answers
  Answers --> Snippets
  Answers --> Resources
}

package "Structure" <<structure>> {
  rectangle "Topic Folders" as Folders
  rectangle "README Files" as Readmes
  rectangle "Table of Contents" as TOC
  Folders --> Readmes
  Readmes --> TOC
}

package "Examples" <<examples>> {
  rectangle "React Components" as ReactComps
  rectangle "Redux Actions" as Actions
  rectangle "Redux Reducers" as Reducers
  ReactComps --> Actions
  Actions --> Reducers
}

package "Metadata" <<metadata>> {
  rectangle "LICENSE" as License
  rectangle "Root README" as RootReadme
  RootReadme --> License
}

Questions --> Folders
Snippets --> ReactComps
@enduml