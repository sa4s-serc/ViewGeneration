@startuml eProsima_Integration-Service
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Integration Service" as IS {
  rectangle "Configuration Parser" as ConfigParser #lightyellow
  rectangle "Core Library" as CoreLib #palegreen
  rectangle "JSON-XTypes Converter" as Converter #lightsteelblue
}

rectangle "Middleware Systems" as Middleware {
  rectangle "Fast DDS" as FastDDS #mistyrose
  rectangle "ROS 1/2" as ROS #aliceblue
  rectangle "WebSocket" as WS #lightcoral
  rectangle "FIWARE" as FIWARE #lightblue
}

rectangle "External Data" as External {
  rectangle "YAML Config" as YAML #palegoldenrod
  rectangle "JSON Data" as JSON #wheat
}

' ========== Connections ==========
User --> ConfigParser : Loads\nconfiguration

ConfigParser --> YAML : Reads\nconfiguration
ConfigParser --> CoreLib : Provides\nconfig

CoreLib --> Converter : Converts\ndata formats
CoreLib --> Middleware : Routes\nmessages/services

Converter --> JSON : Reads/Writes\nJSON data

Middleware --> FastDDS : Publishes/Subscribes\nServices
Middleware --> ROS : Publishes/Subscribes\nServices
Middleware --> WS : Publishes/Subscribes\nServices
Middleware --> FIWARE : Publishes/Subscribes\nServices
@enduml