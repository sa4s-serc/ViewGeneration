@startuml qnib_qframe
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<plugins>> #d8f5d3
  BackgroundColor<<system>> #fddddd
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Framework" <<core>> {
  rectangle "QChan\n(Broadcast Channel)" as QChan
  rectangle "Configuration\n(YAML/JSON/ENV)" as Config
  rectangle "Pipeline Engine" as Engine
  rectangle "Code Generation" as CodeGen
  Config --> Engine
  Engine --> QChan
  Engine --> CodeGen
}

package "Plugins" <<plugins>> {
  rectangle "Collectors\n(File, TCP, Docker)" as Collectors
  rectangle "Filters\n(Grok, Enrichment)" as Filters
  rectangle "Handlers\n(Logs, InfluxDB, ES)" as Handlers
  Collectors --> QChan
  QChan --> Filters
  QChan --> Handlers
}

package "System Interaction" <<system>> {
  rectangle "System Calls\n(golang.org/x/sys)" as Syscalls
  rectangle "Cgo Interface" as Cgo
  rectangle "Security\n(TLS, SIDs)" as Security
  rectangle "Memory Management" as Memory
  Syscalls --> Cgo
  Cgo --> Security
  Security --> Memory
}

package "Data Structures" <<data>> {
  rectangle "Metrics\n(qframe-types)" as Metrics
  rectangle "Container Stats" as ContainerStats
  rectangle "OCI Specs" as OCI
  rectangle "JWS" as JWS
  Metrics --> ContainerStats
  ContainerStats --> OCI
  OCI --> JWS
}

Engine --> Collectors
Engine --> Filters
Engine --> Handlers
CodeGen --> Syscalls
Config --> Security
@enduml