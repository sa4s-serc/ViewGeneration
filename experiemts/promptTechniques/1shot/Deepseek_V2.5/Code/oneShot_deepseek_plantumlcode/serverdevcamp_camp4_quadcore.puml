@startuml serverdevcamp_camp4_quadcore
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<gateway>> #d8f5d3
  BackgroundColor<<auth>> #fddddd
  BackgroundColor<<data>> #fff1c9
  BackgroundColor<<storage>> #e9d9fd
  Style roundrect
}
skinparam defaultTextAlignment center

rectangle "React Frontend" <<frontend>> as Frontend {
  rectangle "Auth Components" as AuthComp
  rectangle "Infinite Scroll" as Scroll
  rectangle "Column Views" as Columns
}

rectangle "API Gateway" <<gateway>> as Gateway {
  rectangle "JWT Validation" as JWT
  rectangle "Request Routing" as Routing
}

rectangle "Auth Services" <<auth>> as Auth {
  rectangle "Auth Server" as AuthServer
  rectangle "Auth Front" as AuthFront
}

rectangle "Data Services" <<data>> as Data {
  rectangle "Data Pipeline" as Pipeline
  rectangle "Data Processing" as Processing
  rectangle "Data Sending" as Sending
  rectangle "User Activity" as UserActivity
}

rectangle "Storage" <<storage>> as Storage {
  database "Cassandra" as Cassandra
  database "Redis" as Redis
  database "Kafka" as Kafka
}

Frontend --> Gateway : HTTP Requests
Gateway --> Auth : Auth Requests
Gateway --> Data : Data Requests
AuthServer --> Redis : Refresh Tokens
AuthFront --> AuthServer : Auth Logic
Pipeline --> Kafka : Ingest Data
Processing --> Kafka : Consume Data
Processing --> Cassandra : Store/Read
Sending --> Cassandra : Read/Write
UserActivity --> Cassandra : User Data
Sending --> Frontend : WebSocket
@enduml