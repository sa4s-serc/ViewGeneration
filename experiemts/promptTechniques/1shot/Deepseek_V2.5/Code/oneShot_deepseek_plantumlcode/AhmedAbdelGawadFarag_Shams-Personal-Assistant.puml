@startuml AhmedAbdelGawadFarag_Shams-Personal-Assistant
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Android App" as Android {
  rectangle "MainActivity" as MainActivity #palegreen
  rectangle "BotManager" as BotManager #lightsteelblue
  rectangle "RecordingManager" as RecordingManager #lightyellow
}

rectangle "Main Server" as MainServer {
  rectangle "Speech-to-Text" as STT #mistyrose
  rectangle "Intent Classifier" as IntentClassifier #aliceblue
  rectangle "Text-to-Speech" as TTS #lavender
}

rectangle "NER Server" as NER {
  rectangle "NER Model" as NERModel #peachpuff
}

rectangle "Google Cloud" as Google {
  rectangle "Speech API" as SpeechAPI #wheat
  rectangle "TTS API" as TTSAPI #thistle
}

' ========== Connections ==========
User -> MainActivity : Voice Command
MainActivity -> RecordingManager : Record Audio
RecordingManager -> MainActivity : Audio Data
MainActivity -> BotManager : Process Command
BotManager -> MainServer : Send Audio (HTTP)
MainServer -> STT : Convert Speech
STT -> SpeechAPI : API Call
SpeechAPI -> STT : Text Response
STT -> IntentClassifier : Process Text
IntentClassifier -> NER : Extract Entities (HTTP)
NER -> NERModel : Run NER
NERModel -> NER : Entities
NER -> IntentClassifier : Entities
IntentClassifier -> MainServer : Intent + Entities
MainServer -> TTS : Generate Response
TTS -> TTSAPI : API Call
TTSAPI -> TTS : Audio Response
TTS -> MainServer : Audio
MainServer -> BotManager : Response (HTTP)
BotManager -> MainActivity : Display Response
MainActivity -> User : Play Audio/Show Text
@enduml