@startuml elavia_edge-computing-platform-for-deep-learning-apps
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "React Frontend" as Frontend #lightblue

rectangle "Flask Backend" as Backend #palegreen {
  rectangle "Model Management API" as API
  rectangle "Authentication" as Auth
}

rectangle "GCP Infrastructure" as GCP #mistyrose {
  rectangle "Cloud SQL (MySQL)" as DB
  rectangle "Google Cloud Storage" as GCS
  rectangle "Cloud Functions" as CF
}

rectangle "Kubernetes/KubeEdge" as K8s #lightyellow {
  rectangle "Model Manager" as ModelManager
  rectangle "Inference Service" as Inference
}

' ========== Connections ==========
User -> Frontend : Interacts with UI
Frontend -> Backend : API calls (REST)
Backend -> DB : CRUD operations
Backend -> GCS : Upload/download models
Backend -> CF : Trigger TFLite conversion
Backend -> K8s : Deploy models

API -> Auth : Validate credentials
Auth -> DB : Verify user

ModelManager -> Inference : Deploy model
Inference -> GCS : Load model
Inference -> Inference : Run optimized inference\n(TensorRT/TFLite)

CF -> GCS : Store converted model
@enduml