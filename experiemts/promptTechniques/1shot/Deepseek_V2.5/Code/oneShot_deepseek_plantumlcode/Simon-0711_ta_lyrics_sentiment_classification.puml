@startuml Simon-0711_ta_lyrics_sentiment_classification
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (React)" as Frontend #lightblue

rectangle "Backend (FastAPI)" as Backend #palegreen {
  rectangle "CNN Model" as CNN #lightyellow
}

rectangle "Elasticsearch" as Elasticsearch #mistyrose

rectangle "LyricsGenius API" as GeniusAPI #aliceblue

' ========== Deployment Flow ==========
User -> Frontend : Input song/artist
Frontend -> Backend : API request (song details)
Backend -> Elasticsearch : Check if lyrics exist
alt lyrics exist
  Elasticsearch -> Backend : Return lyrics
else lyrics not found
  Backend -> GeniusAPI : Fetch lyrics
  GeniusAPI -> Backend : Return lyrics
  Backend -> Elasticsearch : Store lyrics
end

Backend -> Backend : Preprocess lyrics\n(normalize, tokenize)
Backend -> CNN : Classify sentiment
CNN -> Backend : Return mood classification
Backend -> Elasticsearch : Store mood classification
Backend -> Elasticsearch : Query similar songs
Elasticsearch -> Backend : Return similar songs
Backend -> Frontend : Return classification & recommendations
Frontend -> User : Display results
@enduml