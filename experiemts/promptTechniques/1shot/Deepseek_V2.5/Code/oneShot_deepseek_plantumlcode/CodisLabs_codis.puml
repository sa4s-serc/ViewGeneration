@startuml CodisLabs_codis
skinparam rectangle {
  BackgroundColor<<redis>> #d9e7fd
  BackgroundColor<<codis>> #d8f5d3
  BackgroundColor<<libraries>> #fddddd
  BackgroundColor<<persistence>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Redis Core" <<redis>> {
  rectangle "Data Structures\n(SDS, Hash Tables, Skip Lists)" as DataStructures
  rectangle "Command Processor" as CommandProcessor
  rectangle "Event Loop (ae)" as EventLoop
  rectangle "Memory Manager\n(jemalloc)" as MemoryManager
  rectangle "Networking" as Networking
  DataStructures --> CommandProcessor
  CommandProcessor --> EventLoop
  EventLoop --> Networking
  MemoryManager --> DataStructures
}

package "Codis Proxy" <<codis>> {
  rectangle "Slot Management" as SlotManager
  rectangle "Proxy Layer" as ProxyLayer
  rectangle "Cluster Management" as ClusterManager
  ProxyLayer --> SlotManager
  ProxyLayer --> ClusterManager
}

package "Client Libraries" <<libraries>> {
  rectangle "hiredis" as Hiredis
  rectangle "redigo" as Redigo
  rectangle "Lua Scripting" as Lua
}

package "Persistence" <<persistence>> {
  rectangle "RDB Snapshots" as RDB
  rectangle "AOF Logging" as AOF
}

ProxyLayer --> RedisCore
Hiredis --> RedisCore
Redigo --> RedisCore
Lua --> RedisCore
RedisCore --> RDB
RedisCore --> AOF

rectangle "Redis Cluster" as RedisCluster {
  rectangle "Node 1" as Node1
  rectangle "Node 2" as Node2
  rectangle "Node N" as NodeN
}

ClusterManager --> RedisCluster
@enduml