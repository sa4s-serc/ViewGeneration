@startuml argrecsys_argael
skinparam rectangle {
  BackgroundColor<<gui>> #d9e7fd
  BackgroundColor<<core>> #d8f5d3
  BackgroundColor<<data>> #fddddd
  BackgroundColor<<utils>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "GUI Layer" <<gui>> {
  rectangle "ArgaelForm" as GUI
  rectangle "ReportFormatter" as Report
  rectangle "InitParams" as Config
  GUI --> Report
  GUI --> Config
}

package "Core Functionality" <<core>> {
  rectangle "DataManager" as DataManager
  rectangle "ArgumentModel" as ArgumentModel
  rectangle "TreeNode" as TreeNode
  rectangle "SelectedItems" as SelectedItems
  DataManager --> ArgumentModel
  DataManager --> TreeNode
  DataManager --> SelectedItems
}

package "Data Layer" <<data>> {
  rectangle "IOManager" as IO
  rectangle "users.txt" as Users
  rectangle "params.json" as Params
  rectangle "JSONL Files" as DataFiles
  IO --> Users
  IO --> Params
  IO --> DataFiles
}

package "Utilities" <<utils>> {
  rectangle "FileUtils" as FileUtils
  rectangle "StringUtils" as StringUtils
  IO --> FileUtils
  IO --> StringUtils
}

GUI --> DataManager
DataManager --> IO
Config --> Params
Report --> DataFiles
@enduml