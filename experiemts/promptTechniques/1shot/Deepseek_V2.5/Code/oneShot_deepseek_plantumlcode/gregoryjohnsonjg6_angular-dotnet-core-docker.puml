@startuml gregoryjohnsonjg6_angular-dotnet-core-docker
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (Angular)" as Frontend {
}

rectangle "Load Balancer (NGINX)" as Nginx {
}

rectangle "Backend (.NET Core API)" as Backend {
  rectangle "Web API" as WebAPI
  rectangle "Application (CQRS)" as AppLayer
  rectangle "Domain" as Domain
  rectangle "Infrastructure" as Infrastructure
}

rectangle "Database (PostgreSQL)" as Database

' ========== Connections ==========
User -> Frontend : Interacts with UI
Frontend -> Nginx : HTTP Requests
Nginx -> WebAPI : Routes API calls
WebAPI -> AppLayer : Processes commands/queries
AppLayer -> Domain : Business logic
AppLayer -> Infrastructure : Data access
Infrastructure -> Database : CRUD operations

' Deployment flow
note right of Frontend
  Containerized with Docker
  SSR enabled
end note

note right of Nginx
  API Gateway
  Traffic distribution
end note

note right of Backend
  Clean Architecture
  JWT Authentication
end note

note right of Database
  EF Core Migrations
  Containerized
end note

@enduml