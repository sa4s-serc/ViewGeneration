@startuml becloudway_serverless-data-pipeline
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

rectangle "Traffic Data API" as TrafficAPI #aliceblue

rectangle "S3 Buckets" as S3 #lightblue {
  rectangle "Raw XML" as RawXML
  rectangle "Processed JSON" as ProcessedJSON
  rectangle "Analytics Data" as AnalyticsData
}

rectangle "Lambda Functions" as Lambda #palegreen {
  rectangle "RetrieveXMLTrafficData" as RetrieveXML
  rectangle "TransformTrafficDataToJson" as TransformToJSON
  rectangle "PublishTrafficData" as PublishData
  rectangle "StreamProcessor" as StreamProcessor
  rectangle "StoreAnalyticsResults" as StoreAnalytics
  rectangle "AlertSaver" as AlertSaver
  rectangle "AlertSender" as AlertSender
  rectangle "PowerBiForwarder" as PowerBIForwarder
}

rectangle "Kinesis" as Kinesis #mistyrose {
  rectangle "Firehose" as Firehose
  rectangle "Data Stream" as DataStream
  rectangle "Data Analytics" as DataAnalytics
}

rectangle "DynamoDB" as DynamoDB #lightyellow {
  rectangle "RealTimeAnalytics" as AnalyticsTable
  rectangle "TrafficJamAlerts" as AlertsTable
}

rectangle "External Services" as External #peachpuff {
  rectangle "Slack" as Slack
  rectangle "Power BI" as PowerBI
  rectangle "REST Clients" as REST
}

' ========== Data Flow ==========
TrafficAPI --> RetrieveXML : GET XML data
RetrieveXML --> RawXML : Store raw XML

RawXML --> TransformToJSON : S3 event
TransformToJSON --> ProcessedJSON : Store JSON

ProcessedJSON --> PublishData : S3 event
PublishData --> Firehose : Publish events
Firehose --> AnalyticsData : Store analytics

PublishData --> DataStream : Publish events
DataStream --> StreamProcessor : Process stream
StreamProcessor --> DataAnalytics : Filtered data

DataAnalytics --> StoreAnalytics : Analytics results
StoreAnalytics --> AnalyticsTable : Store results

AnalyticsTable --> AlertSaver : DynamoDB stream
AlertSaver --> AlertsTable : Store alerts

AlertsTable --> AlertSender : DynamoDB stream
AlertSender --> Slack : Send alerts

DataStream --> PowerBIForwarder : Forward data
PowerBIForwarder --> PowerBI : Push to dataset

AnalyticsTable --> REST : Current conditions
AlertsTable --> REST : Current alerts
@enduml