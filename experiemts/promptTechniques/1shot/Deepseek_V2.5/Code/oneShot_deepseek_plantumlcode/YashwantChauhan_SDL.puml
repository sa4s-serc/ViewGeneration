@startuml YashwantChauhan_SDL
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Web Browser" as Browser {
}

rectangle "Django Application" as Django {
  rectangle "Views" as Views
  rectangle "Models" as Models
  rectangle "Templates" as Templates
}

rectangle "Database" as DB {
}

rectangle "Machine Learning Model" as ML {
}

' ========== Connections ==========
User -> Browser : Accesses website\nSubmits traffic data\nViews results

Browser -> Views : HTTP Requests\n(Login/Upload/Results)
Views -> Models : Query data\nSave results
Models -> DB : CRUD operations
Views -> Templates : Render response
Templates -> Browser : HTML/CSS/JS

Views -> ML : Classify traffic data
ML -> Views : Return attack classification

Browser -> Browser : Client-side validation\n(JavaScript)
@enduml