@startuml IBMDeveloperMEA_YPDL-Recurrent-Neural-Networks-using-TensorFlow-Keras
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Jupyter Notebook" as Notebook #lightblue {
  rectangle "Controller Logic" as Controller
  rectangle "Visualizations" as Viz
}

rectangle "TensorFlow Keras" as TF #palegreen {
  rectangle "LSTM Model" as Model
  rectangle "Embedding Layer" as Embedding
  rectangle "Dense Layer" as Dense
}

rectangle "Data Processing" as Data #lightyellow {
  rectangle "reader.py" as Reader
  rectangle "Penn Treebank\nDataset" as Dataset
}

' ========== Connections ==========
User --> Notebook : Executes cells\nViews results

Notebook --> Data : Loads and preprocesses\ndata
Data --> Notebook : Returns processed\ndata batches

Notebook --> TF : Builds model\nTrains model\nEvaluates model
TF --> Notebook : Returns predictions\nand metrics

Notebook --> Viz : Generates plots\nand visualizations
Viz --> User : Displays results

Data --> Reader : Reads and batches\ndata
Reader --> Dataset : Accesses raw\ndata files
@enduml