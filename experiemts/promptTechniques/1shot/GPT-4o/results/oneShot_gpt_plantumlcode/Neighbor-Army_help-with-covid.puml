```plantuml
@startuml Neighbor-Army_help-with-covid
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend (Next.js)" as FE {
  rectangle "HomeContent" as HomeContent
  rectangle "OfferHelp" as OfferHelp
  rectangle "RequestHelp" as RequestHelp
  rectangle "FirebaseAuth" as FirebaseAuth
  rectangle "Nav" as Nav
  rectangle "VolunteerConfirmation" as VolunteerConfirmation
  rectangle "AddressInput" as AddressInput
}

rectangle "Backend (Firebase Functions)" as BE {
  rectangle "API Endpoints" as API
  rectangle "Routes" as Routes
  rectangle "Express App" as Express
}

rectangle "Onfleet API" as Onfleet #lightyellow
rectangle "Sendgrid API" as Sendgrid #lightblue
rectangle "Google Maps API" as GoogleMaps #lightgreen
rectangle "Twilio API" as Twilio #lightcoral

' ========== Connections ==========
User --> FE

' Frontend interactions
FE <--> BE : API calls for volunteer\n and task management
FE <--> GoogleMaps : Address auto-completion\nvia AddressInput

' Backend interactions
BE <--> Onfleet : Manage tasks and\nvolunteers
BE <--> Sendgrid : Manage email communication
BE <--> Twilio : Phone/zipcode verification

' Express app interactions
Express --> Routes : Define API endpoints

' API interactions
API --> Onfleet : CRUD task operations
API --> Sendgrid : Add to mailing list
API --> Twilio : Verify phone/zipcode

@enduml
```