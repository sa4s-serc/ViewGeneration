```plantuml
@startuml EMERIC237_Restaurant-reservation-app

skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<database>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React)" <<frontend>> {
  rectangle "App Component" as App
  rectangle "Dashboard" as Dashboard
  rectangle "Layout" as Layout
  rectangle "Routes" as Routes
  rectangle "CreateReservation" as CreateReservation
  rectangle "ReservationForm" as ReservationForm
  rectangle "API Utilities" as ApiUtils
  rectangle "Date-Time Utilities" as DateTimeUtils
  App --> Layout
  Layout --> Routes
  Routes --> Dashboard
  Routes --> CreateReservation
  CreateReservation --> ReservationForm
  ReservationForm --> ApiUtils
  Dashboard --> ApiUtils
  ApiUtils --> DateTimeUtils
}

package "Backend (Node.js/Express)" <<backend>> {
  rectangle "Express App" as ExpressApp
  rectangle "Server" as Server
  rectangle "Reservation Router" as ReservationRouter
  rectangle "Reservation Controller" as ReservationController
  rectangle "Reservation Service" as ReservationService
  rectangle "Table Router" as TableRouter
  rectangle "Table Controller" as TableController
  rectangle "Table Service" as TableService
  rectangle "Error Handler" as ErrorHandler
  rectangle "Not Found Handler" as NotFoundHandler
  rectangle "Database Connection" as DbConnection
  rectangle "Migrations" as Migrations
  rectangle "Seeds" as Seeds

  ExpressApp --> ReservationRouter
  ReservationRouter --> ReservationController
  ReservationController --> ReservationService
  ReservationService --> DbConnection
  ExpressApp --> TableRouter
  TableRouter --> TableController
  TableController --> TableService
  TableService --> DbConnection
  ExpressApp --> ErrorHandler
  ExpressApp --> NotFoundHandler
  DbConnection --> Migrations
  DbConnection --> Seeds
  Server --> ExpressApp
}

database "PostgreSQL" <<database>> as PostgreSQL
DbConnection --> PostgreSQL

@enduml
```