@startuml 23fa-cpsc490_canyough
skinparam rectangle {
  BackgroundColor<<service>> #d9e7fd
  BackgroundColor<<component>> #d8f5d3
  BackgroundColor<<datastore>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Recommendation System" {
  package "Services" <<service>> {
    rectangle "Product Mixer" as ProductMixer
    rectangle "CR-Mixer" as CRMixer
    rectangle "Follow Recommendations Service (FRS)" as FRS
    rectangle "Home Mixer" as HomeMixer
  }

  package "Components" <<component>> {
    rectangle "Candidate Sources" as CandidateSources
    rectangle "Feature Hydrators" as FeatureHydrators
    rectangle "Filters" as Filters
    rectangle "Scorers" as Scorers
    rectangle "Transformers" as Transformers
    rectangle "Gates" as Gates
    rectangle "Cursors" as Cursors
  }

  package "Data Structures" <<component>> {
    rectangle "Candidates" as Candidates
    rectangle "Features" as Features
    rectangle "Queries" as Queries
    rectangle "Presentation Models" as PresentationModels
  }

  database "Data Stores" <<datastore>> {
    rectangle "User Signal Service" as USS
    rectangle "Real Graph" as RealGraph
    rectangle "Earlybird" as Earlybird
    rectangle "TweetyPie" as TweetyPie
    rectangle "Manhattan" as Manhattan
    rectangle "Memcached" as Memcached
    rectangle "Strato" as Strato
  }
}

