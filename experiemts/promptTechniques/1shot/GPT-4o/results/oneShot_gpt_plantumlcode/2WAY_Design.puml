```plantuml
@startuml 2WAY_Design
skinparam rectangle {
  BackgroundColor<<core>> #e0f7fa
  BackgroundColor<<docs>> #fce4ec
  BackgroundColor<<images>> #f3e5f5
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Functionality" <<core>> {
  rectangle "Secure Private\nData Exchange" as DataExchange
  rectangle "Trust Network" as TrustNetwork
  DataExchange --> TrustNetwork
}

package "Documentation" <<docs>> {
  rectangle "LICENSE" as License
  rectangle "README.md" as Readme
  rectangle "Wiki" as Wiki
  Readme --> Wiki
}

package "Images" <<images>> {
  rectangle "Architecture Image\n(6_2wayd_architecture.jpg)" as ArchImage
  rectangle "Legend Image\n(7_2wayd_legend.jpg)" as LegendImage
  Readme --> ArchImage
  Readme --> LegendImage
}

Wiki --> License
@enduml
```