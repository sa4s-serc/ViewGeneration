```plantuml
@startuml NicoJuicy_Airline-Microservices
skinparam rectangle {
  BackgroundColor<<microservice>> #f3fafe
  BackgroundColor<<gateway>> #fde9d9
  BackgroundColor<<buildingblock>> #f1f1f1
  BackgroundColor<<broker>> #e8e8f8
  Style roundrect
}
skinparam defaultTextAlignment center

package "Microservices" <<microservice>> {
  rectangle "Identity Service\n(IdentityServer, JWT)" as Identity
  rectangle "Flight Service" as Flight
  rectangle "Passenger Service" as Passenger
  rectangle "Reservation Service" as Reservation
}

package "Api Gateway" <<gateway>> {
  rectangle "YARP-based\nAPI Gateway" as ApiGateway
}

package "Building Blocks" <<buildingblock>> {
  rectangle "Shared Library\n(Exception Handling, Logging,\nSwagger, Security, etc.)" as SharedLibrary
}

package "Message Broker" <<broker>> {
  rectangle "MassTransit\n(RabbitMQ)" as RabbitMQ
}

Identity --> ApiGateway
Flight --> ApiGateway
Passenger --> ApiGateway
Reservation --> ApiGateway

ApiGateway --> SharedLibrary

Identity -[#blue,dashed]-> RabbitMQ : "Publish/Subscribe\nIntegration Events"
Flight -[#blue,dashed]-> RabbitMQ : "Publish/Subscribe\nIntegration Events"
Passenger -[#blue,dashed]-> RabbitMQ : "Publish/Subscribe\nIntegration Events"
Reservation -[#blue,dashed]-> RabbitMQ : "Publish/Subscribe\nIntegration Events"

@enduml
```