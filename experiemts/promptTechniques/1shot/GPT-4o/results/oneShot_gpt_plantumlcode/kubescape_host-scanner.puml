```plantuml
@startuml kubescape_host-scanner
skinparam rectangle {
  BackgroundColor<<api>> #d9e7fd
  BackgroundColor<<sensor>> #d8f5d3
  BackgroundColor<<utility>> #fddddd
  BackgroundColor<<deployment>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "HTTP API" <<api>> {
  rectangle "HTTP Handlers\n(httphandlers.go)" as HTTPHandlers
  rectangle "Middleware\n(negroni)" as Middleware
  rectangle "Logging\n(go-logger, zap)" as Logging
  rectangle "Tracing\n(OpenTelemetry)" as Tracing
  HTTPHandlers -- Middleware
  HTTPHandlers -- Logging
  HTTPHandlers -- Tracing
}

package "Sensors" <<sensor>> {
  rectangle "OS Release\n(sensor/osrelease.go)" as OSRelease
  rectangle "Kubelet Info\n(sensor/kubelet.go)" as Kubelet
  rectangle "Control Plane\n(sensor/controlplane.go)" as ControlPlane
  rectangle "CNI Info\n(sensor/CNI.go)" as CNI
  HTTPHandlers --> OSRelease
  HTTPHandlers --> Kubelet
  HTTPHandlers --> ControlPlane
  HTTPHandlers --> CNI
}

package "Utilities" <<utility>> {
  rectangle "Container Runtime Utils\n(sensor/internal/utils/containerruntime.go)" as ContainerRuntime
  CNI --> ContainerRuntime
}

package "Deployment" <<deployment>> {
  rectangle "K8s DaemonSet\n(deployment/k8s-deployment.yaml)" as DaemonSet
  rectangle "Dockerfile\n(build/Dockerfile)" as Dockerfile
  DaemonSet -- Dockerfile
}

@enduml
```