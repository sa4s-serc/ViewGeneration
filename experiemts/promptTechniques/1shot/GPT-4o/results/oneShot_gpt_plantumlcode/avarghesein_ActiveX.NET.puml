```plantuml
@startuml avarghesein_ActiveX.NET
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "ActiveX.NET.Server" as Server {
  rectangle "Program.cs" as Program #lightblue
  rectangle "ActiveXServerContext.cs" as Context #lightyellow
  rectangle "ActiveXServers.cs" as Servers #lightpink
}

rectangle "MEF" as MEF #aliceblue

rectangle "ActiveX.NET.Plugin" as Plugin {
  rectangle "CoClass.cs" as CoClass #lightgreen
}

rectangle "ActiveX.NET.Common" as Common {
  rectangle "ActiveXServerBase.cs" as ServerBase #lightcoral
  rectangle "ActiveXServerMTABase.cs" as MTABase #lightcoral
  rectangle "ActiveXServerControlBase.cs" as ControlBase #lightcoral
}

' ========== Connections ==========
User --> Program : Start COM Server

' Program interactions
Program --> Context : Initialize\n Manage lifecycle
Program --> Servers : Discover COM objects via MEF

' MEF interactions
Servers <--> MEF : Discover and load\n IActiveXServer implementations

' Plugin interactions
Servers --> CoClass : Load and manage\n COM object

' Common base class usage
CoClass --> ServerBase : Inherits
CoClass --> MTABase : Inherits (for MTA objects)
CoClass --> ControlBase : Inherits (for STA UserControl objects)

@enduml
```