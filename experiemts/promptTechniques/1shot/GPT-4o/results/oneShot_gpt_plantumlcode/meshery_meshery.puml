```plantuml
@startuml meshery_meshery
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<ui>> #d8f5d3
  BackgroundColor<<cli>> #fddddd
  BackgroundColor<<operator>> #fff1c9
  BackgroundColor<<library>> #f0e68c
  BackgroundColor<<broker>> #ffd700
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Components" <<core>> {
  rectangle "Meshery Server" as Server
  rectangle "GraphQL API" as GraphQL
  rectangle "Adapters" as Adapters
  rectangle "Remote Providers" as Providers
  rectangle "MeshSync" as MeshSync
  Server --> GraphQL
  Server --> Adapters
  Server --> Providers
  Server --> MeshSync
}

package "User Interface" <<ui>> {
  rectangle "Meshery UI" as UI
  UI --> Server
}

package "Command Line Interface" <<cli>> {
  rectangle "mesheryctl" as CLI
  CLI --> Server
}

package "Operator" <<operator>> {
  rectangle "Meshery Operator" as Operator
  rectangle "MeshSync" as MeshSync_Operator
  Operator --> MeshSync_Operator
  Operator --> Server
}

package "Library" <<library>> {
  rectangle "MeshKit" as MeshKit
  MeshKit --> Server
  MeshKit --> Adapters
}

package "Event Broker" <<broker>> {
  rectangle "NATS" as NATS
  NATS --> Server
  NATS --> MeshSync
  NATS --> Operator
}

database "Data Models" as DataModels
Server --> DataModels
@enduml
```