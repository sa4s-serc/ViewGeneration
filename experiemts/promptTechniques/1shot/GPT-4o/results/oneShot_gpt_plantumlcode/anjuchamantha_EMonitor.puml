```plantuml
@startuml anjuchamantha_EMonitor
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<network>> #d8f5d3
  BackgroundColor<<display>> #fddddd
  BackgroundColor<<alerts>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Functionality" <<core>> {
  rectangle "main.cpp/.ino" as Main
  rectangle "config.h" as Config
  rectangle "readings.cpp/readings.h" as Readings
  rectangle "utils.cpp/utils.h" as Utils
  rectangle "xml.cpp/xml.h" as XML
  Main --> Config
  Main --> Readings
  Main --> Utils
  Main --> XML
}

package "Network Communication" <<network>> {
  rectangle "wifi_con.cpp/wifi_con.h" as WiFiCon
  rectangle "http.cpp/http.h" as HTTP
  Main --> WiFiCon
  Main --> HTTP
}

package "Local Display" <<display>> {
  rectangle "OLED Display (Adafruit Library)" as OLED
  Main --> OLED
}

package "Email Alerts" <<alerts>> {
  rectangle "mail_client.cpp/mail_client.h" as MailClient
  Main --> MailClient
}

@enduml
```