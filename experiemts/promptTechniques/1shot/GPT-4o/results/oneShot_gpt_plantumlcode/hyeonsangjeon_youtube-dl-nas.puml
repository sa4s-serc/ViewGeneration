```plantuml
@startuml hyeonsangjeon_youtube-dl-nas
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Web Interface" as WebInterface #lightyellow {
  rectangle "HTML Template" as HTMLTemplate #aliceblue
  rectangle "WebSocket" as WebSocket #aliceblue
}

rectangle "REST API" as RestAPI #lightsteelblue

rectangle "youtube-dl-server.py" as MainApp #palegreen {
  rectangle "Download Queue" as DownloadQueue #mistyrose
  rectangle "Download Worker" as DownloadWorker #mistyrose
}

rectangle "Auth.json" as AuthJSON #lightgrey

rectangle "yt-dlp/youtube-dl" as Downloader #thistle

rectangle "Docker Container" as Docker #lightcoral {
  rectangle "run.sh" as RunSh #lightgoldenrodyellow
  rectangle "upd_schedule.py" as UpdSchedule #lightgoldenrodyellow
}

' ========== Connections ==========
User --> WebInterface : access web interface
User --> RestAPI : send download requests

' Web Interface Interactions
WebInterface --> MainApp : authenticate with credentials
WebInterface --> WebSocket : receive real-time updates

' REST API Interactions
RestAPI --> MainApp : authenticate with ID & password
RestAPI --> MainApp : submit download requests

' Main Application Interactions
MainApp --> DownloadQueue : enqueue download request
MainApp --> DownloadWorker : start download task
DownloadWorker --> Downloader : execute download command
MainApp --> WebSocket : send status updates

' Docker Container Interactions
Docker --> RunSh : execute initialization script
Docker --> UpdSchedule : schedule daily updates

@enduml
```