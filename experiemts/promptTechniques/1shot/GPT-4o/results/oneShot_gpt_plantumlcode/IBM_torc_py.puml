```plantuml
@startuml IBM_torc_py
skinparam sequence {
  ArrowColor black
  ActorBorderColor black
  LifeLineBorderColor black
  ParticipantBorderColor black
  BoxBorderColor black
}

actor User

box "torcpy" #lightgrey
  participant "Master Process" as Master
  participant "Worker Process" as Worker
  participant "torc_server_thread" as ServerThread
  participant "torc_q Task Queue" as TaskQueue
end box

participant "MPI" as MPI

' ========== Interactions ==========
User -> Master: start()
Master -> Master: init()
Master -> Master: launch()
Master -> Worker: submit(task)
Worker -> TaskQueue: enqueue task
ServerThread -> TaskQueue: dequeue task
TaskQueue -> Worker: execute task
Worker -> ServerThread: send result
ServerThread -> Master: notify task completion
Master -> User: as_completed()

' Load Balancing
Worker -> Worker: task stealing (if idle)
Worker -> ServerThread: request tasks from other workers
ServerThread -> Worker: redistribute tasks

' SPMD Support
User -> Master: spmd()
Master -> MPI: execute function on all processes

User -> Master: shutdown()
Master -> Worker: send shutdown signal
Worker -> Worker: cleanup resources
@enduml
```