```plantuml
@startuml NatalieLouise91_T3A2-Skemi-FrontEnd
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<service>> #fddddd
  BackgroundColor<<utils>> #f8f8f8
  Style roundrect
}
skinparam defaultTextAlignment center

package "React.js Frontend" <<frontend>> {
  rectangle "Entry Point\n(src/index.js)" as EntryPoint
  rectangle "Main App Component\n(src/App.js)" as MainApp
  rectangle "Navigation Bar\n(src/components/UI/Nav.js)" as NavBar
  rectangle "Login Component\n(src/components/User/Login.js)" as LoginComponent
  rectangle "New User Component\n(src/components/User/NewUser.js)" as NewUserComponent
  rectangle "Occasion Components\n(src/components/Occasion/...)" as OccasionComponents
  rectangle "Roster Components\n(src/components/Roster/...)" as RosterComponents
  rectangle "State Management\n(src/utils/stateContext.js & stateReducer.js)" as StateManagement <<utils>>
  rectangle "API Configuration\n(src/config/api.js)" as ApiConfig <<utils>>
}

package "Service Layer" <<service>> {
  rectangle "Occasion Services\n(src/services/occasionServices.js)" as OccasionServices
  rectangle "Roster Services\n(src/services/rosterServices.js)" as RosterServices
  rectangle "Auth Services\n(src/services/authServices.js)" as AuthServices
  rectangle "User Services\n(src/services/userServices.js)" as UserServices
}

EntryPoint --> MainApp
MainApp --> NavBar
MainApp --> OccasionComponents
MainApp --> RosterComponents
MainApp --> StateManagement
MainApp --> ApiConfig
NavBar --> LoginComponent
NavBar --> NewUserComponent
OccasionComponents --> OccasionServices
RosterComponents --> RosterServices
LoginComponent --> AuthServices
NewUserComponent --> UserServices
@enduml
