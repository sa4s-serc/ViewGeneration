```plantuml
@startuml OpenPSD_modelbank
skinparam rectangle {
  BackgroundColor<<entities>> #d9e7fd
  BackgroundColor<<usecases>> #d8f5d3
  BackgroundColor<<providers>> #fddddd
  BackgroundColor<<controller>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Entities Layer" <<entities>> {
  rectangle "Ledger\n(LedgerEntry)" as Ledger
  rectangle "Financial Institution\n(FinancialInstitution)" as FinancialInstitution
  rectangle "Account Holder\n(AccountHolder, Account,\nConsent)" as AccountEntities
  rectangle "Payment\n(PaymentInstruction,\nPaymentTransaction)" as Payment
}

package "Use Cases Layer" <<usecases>> {
  rectangle "Model Bank Use Case\n(Usecase Interfaces,\nCore Business Logic)" as ModelBankUsecase
  ModelBankUsecase --> Ledger
  ModelBankUsecase --> FinancialInstitution
  ModelBankUsecase --> AccountEntities
  ModelBankUsecase --> Payment
}

package "Providers Layer" <<providers>> {
  rectangle "Controller\n(modelbankController.go)" as Controller
  rectangle "gRPC Service\n(modelbank.proto)" as gRPCProto
  rectangle "gRPC Implementation\n(modelbank.pb.go)" as gRPCImpl
  rectangle "Database Provider\n(dbProvider.go)" as DbProvider
  rectangle "gRPC Server\n(modelbank_server.go)" as gRPCServer
  Controller --> ModelBankUsecase
  gRPCProto --> gRPCImpl
  gRPCServer --> Controller
  gRPCImpl --> gRPCServer
  DbProvider --> ModelBankUsecase
}

package "Controller Layer" <<controller>> {
  rectangle "ModelBankController" as ModelBankController
  ModelBankController --> gRPCProto
}

@enduml
```