```plantuml
@startuml nforge_devnote

skinparam rectangle {
  BackgroundColor<<server-side>> #d9e7fd
  BackgroundColor<<client-side>> #d8f5d3
  BackgroundColor<<lib>> #fddddd
  BackgroundColor<<data>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Server-Side (Node.js/Express)" <<server-side>> {
  rectangle "app.coffee\nMain Application" as App
  rectangle "Express Routes\n(routes/index.js)" as Routes
  rectangle "Socket.IO\nReal-time Updates" as SocketIO
  App --> Routes
  App --> SocketIO
}

package "Client-Side (JavaScript)" <<client-side>> {
  rectangle "jQuery\nDOM Manipulation" as jQuery
  rectangle "Bootstrap\nStyling & Layout" as Bootstrap
  rectangle "CodeMirror 2\nEditor Component" as CodeMirror
  rectangle "Markdown Rendering\n(showdown.js)" as MarkdownRender
  jQuery --> CodeMirror
  CodeMirror --> MarkdownRender
}

package "Core Logic & Utilities" <<lib>> {
  rectangle "Git Interactions\n(lib/gitfs.js)" as GitFS
  rectangle "User Management\n(lib/users.js)" as Users
  rectangle "File Handling\n(lib/fileutils.js)" as FileUtils
  rectangle "Markdown Renderer\n(lib/renderer.js)" as Renderer
  rectangle "Dependency Graph\n(lib/graph.js)" as Graph
  rectangle "Internationalization\n(lib/i18n.js)" as I18n
  rectangle "Delta Utilities\n(lib/delta.js)" as Delta
  Routes --> GitFS
  Routes --> Users
  Routes --> FileUtils
  Routes --> Renderer
  Routes --> I18n
}

package "Data Storage" <<data>> {
  rectangle "Git Repository\nVersion Control & Persistence" as GitRepo
  GitFS --> GitRepo
}

package "Views (Jade Templates)" <<client-side>> {
  rectangle "edit.jade" as Edit
  rectangle "history.jade" as History
  rectangle "new.jade" as New
  rectangle "pages.jade" as Pages
  rectangle "login.jade" as Login
  MarkdownRender --> Edit
  MarkdownRender --> History
  MarkdownRender --> New
  MarkdownRender --> Pages
  MarkdownRender --> Login
}

@enduml
```