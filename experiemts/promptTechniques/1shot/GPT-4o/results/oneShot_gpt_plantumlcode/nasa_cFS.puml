```plantuml
@startuml nasa_cFS
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<osal>> #d8f5d3
  BackgroundColor<<psp>> #fddddd
  BackgroundColor<<apps>> #fff1c9
  BackgroundColor<<tools>> #f5e6c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Flight System (cFS)" <<core>> {
  rectangle "cFE\n(Core Flight Executive)" as cFE
  rectangle "Event Services" as ES
  cFE --> ES
}

package "Operating System\nAbstraction Layer (OSAL)" <<osal>> {
  rectangle "OS Abstraction" as OSAbstraction
}

package "Platform Support Package (PSP)" <<psp>> {
  rectangle "Platform Specific Code" as PlatformCode
}

package "Applications" <<apps>> {
  rectangle "Lab Applications" as LabApps
}

package "Tools" <<tools>> {
  rectangle "Host-side Tools" as HostTools
  rectangle "CMake Configuration" as CMakeConfig
  HostTools --> CMakeConfig
}

cFE --> OSAbstraction
cFE --> PlatformCode
cFE --> LabApps
cFE --> HostTools
@enduml
