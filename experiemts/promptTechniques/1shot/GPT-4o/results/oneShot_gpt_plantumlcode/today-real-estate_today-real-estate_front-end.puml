```plantuml
@startuml today-real-estate_today-real-estate_front-end
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<state>> #d8f5d3
  BackgroundColor<<api>> #fddddd
  BackgroundColor<<component>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Vue.js Frontend" <<frontend>> {
  rectangle "Main.js (Entry Point)" as Main
  rectangle "App.vue (Root Component)" as App
  rectangle "Vue Router" as Router
  rectangle "Vuex Store" as Vuex
  Main --> App
  App --> Router
  App --> Vuex
}

package "State Management" <<state>> {
  rectangle "User Store" as UserStore
  rectangle "Search Store" as SearchStore
  Vuex --> UserStore
  Vuex --> SearchStore
}

package "API Layer" <<api>> {
  rectangle "Auth API" as AuthAPI
  rectangle "User API" as UserAPI
  rectangle "Search API" as SearchAPI
  rectangle "News API" as NewsAPI
  rectangle "Inquiry API" as InquiryAPI
  AuthAPI -[hidden]--> UserAPI
  UserAPI -[hidden]--> SearchAPI
  SearchAPI -[hidden]--> NewsAPI
  NewsAPI -[hidden]--> InquiryAPI
}

package "Components" <<component>> {
  rectangle "Header" as Header
  rectangle "Footer" as Footer
  rectangle "Login Form" as LoginForm
  rectangle "Signup Form" as SignupForm
  rectangle "Kakao Map" as KakaoMap
  rectangle "Apt Item" as AptItem
}

package "Views" <<component>> {
  rectangle "Main Page" as MainPage
  rectangle "Login Page" as LoginPage
  rectangle "Search Page" as SearchPage
  rectangle "Account Liked Page" as AccountLikedPage
  MainPage --> Header
  MainPage --> Footer
  LoginPage --> LoginForm
  SearchPage --> KakaoMap
  SearchPage --> AptItem
  AccountLikedPage --> AptItem
}

Main --> AuthAPI
Main --> UserAPI
Main --> SearchAPI
Main --> NewsAPI
Main --> InquiryAPI
@enduml
```