@startuml securesecrets_shadeswap
skinparam rectangle {
  BackgroundColor<<contract>> #d9e7fd
  BackgroundColor<<shared>> #d8f5d3
  BackgroundColor<<test>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "ShadeSwap Ecosystem" {
  package "Contracts" {
    rectangle "SNIP-20 Token\n(lp_token)" <<contract>> as lp_token
    rectangle "Staking Contract" <<contract>> as staking
    rectangle "AMM Pair Contract" <<contract>> as amm_pair
    rectangle "Factory Contract" <<contract>> as factory
    rectangle "Router Contract" <<contract>> as router
    rectangle "Admin Contract" <<contract>> as admin

    lp_token --> staking
    staking --> amm_pair
    amm_pair --> router
    factory --> amm_pair
    router --> amm_pair
    admin --> factory
  }

  package "Shared Utilities" <<shared>> {
    rectangle "shadeswap-shared" as shared_utils
    rectangle "secret-toolkit" as secret_toolkit

    lp_token --> shared_utils
    staking --> shared_utils
    amm_pair --> shared_utils
    factory --> shared_utils
    router --> shared_utils
    admin --> shared_utils
    shared_utils --> secret_toolkit
  }

  package "Testing & Deployment" <<test>> {
    rectangle "Multi-Test Environment" as multi_test
    rectangle "Network Integration" as network_integration

    lp_token --> multi_test
    staking --> multi_test
    amm_pair --> multi_test
    factory --> multi_test
    router --> multi_test
    admin --> multi_test
    multi_test --> network_integration
  }
}
@enduml
