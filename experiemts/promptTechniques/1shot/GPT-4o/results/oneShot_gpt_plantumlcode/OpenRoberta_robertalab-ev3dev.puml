```plantuml
@startuml OpenRoberta_robertalab-ev3dev
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<service>> #d8f5d3
  BackgroundColor<<network>> #fddddd
  BackgroundColor<<execution>> #fff1c9
  BackgroundColor<<hal>> #e0efff
  BackgroundColor<<ev3dev>> #f5e3ff
  Style roundrect
}
skinparam defaultTextAlignment center

package "UI Layer" <<ui>> {
  rectangle "Brickman UI\n(DBus)" as BrickmanUI
}

package "Service Layer" <<service>> {
  rectangle "roberta.lab.Service" as Service
}

package "Network Layer" <<network>> {
  rectangle "roberta.lab.Connector" as Connector
}

package "Execution Layer" <<execution>> {
  rectangle "Python Code\nExecution" as Execution
}

package "HAL Layer" <<hal>> {
  rectangle "roberta.ev3.Hal" as Hal
}

package "ev3dev Layer" <<ev3dev>> {
  rectangle "ev3dev.auto\nInteraction" as EV3Dev
}

BrickmanUI --> Service : communicates via DBus
Service --> Connector : manages connection
Connector --> Execution : initiates code execution
Execution --> Hal : interacts with hardware
Hal --> EV3Dev : executes commands
@enduml
```