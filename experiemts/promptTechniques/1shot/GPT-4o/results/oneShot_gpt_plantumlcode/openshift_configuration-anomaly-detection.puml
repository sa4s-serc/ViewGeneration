```plantuml
@startuml openshift_configuration-anomaly-detection

actor PagerDuty
actor AWS
actor Kubernetes
actor OCM

package "OpenShift Configuration Anomaly Detection" {
  package "cadctl Command-Line Tool" {
    [cadctl]
    [cadctl investigate]
  }

  package "Tekton Interceptor" {
    [Interceptor]
  }

  package "Tekton PipelineRuns" {
    [PipelineRun]
  }
}

PagerDuty -> [Interceptor] : Trigger Alert Webhook
[Interceptor] -> [cadctl investigate] : Validate & Determine Handler
[cadctl investigate] -> [PipelineRun] : Initiate Investigation
[PipelineRun] -> [cadctl] : Execute Investigation

[PipelineRun] -> [OCM] : Update Support Reasons
[PipelineRun] -> [AWS] : Validate Network Configurations
[PipelineRun] -> [Kubernetes] : Inspect Cluster Resources

[Interceptor] -> [PagerDuty] : Filter & Validate Signatures

note right of [cadctl investigate]
  - Handles alert remediation
  - Ready made investigations
end note

note right of [Interceptor]
  - Filters webhooks
  - Validates signatures
end note

note right of [PipelineRun]
  - Executes cadctl
  - Manages resource dependencies
end note

@enduml
```