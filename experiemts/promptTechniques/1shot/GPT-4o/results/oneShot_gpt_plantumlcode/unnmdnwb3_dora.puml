left to right direction

actor User

rectangle "Frontend" as FE {
}

rectangle "Backend API" as Backend #lightgoldenrodyellow {
  rectangle "Gin-Gonic\nRouter" as Router
  rectangle "Metrics\nCalculation\nServices" as MetricsService
  rectangle "GitLab\nConnector" as GitLabConnector
  rectangle "Prometheus\nConnector" as PrometheusConnector
  rectangle "MongoDB\nService" as MongoDBService
}

rectangle "GitLab\nAPI" as GitLabAPI #lightcoral
rectangle "Prometheus\nAPI" as PrometheusAPI #lightblue
rectangle "MongoDB" as MongoDB #khaki

' ========== Connections ==========
User --> FE

' Frontend interactions
FE --> Backend : API Request

' Backend API interactions
Backend --> Router : Route API Request
Router --> MetricsService : Calculate DORA Metrics
MetricsService --> GitLabConnector : Fetch Data from GitLab
GitLabConnector --> GitLabAPI : API Calls to GitLab
MetricsService --> PrometheusConnector : Fetch Alerts from Prometheus
PrometheusConnector --> PrometheusAPI : API Calls to Prometheus
MetricsService --> MongoDBService : Store/Retrieve Data
MongoDBService --> MongoDB : CRUD Operations

@enduml
