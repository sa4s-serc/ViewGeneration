```plantuml
@startuml eqbal_CarND_Capstone_CarX
actor "Simulator" as Simulator
actor "Real Car (CARLA)" as CARLA

skinparam rectangle {
  BackgroundColor<<perception>> #d9f7be
  BackgroundColor<<planning>> #f0f4c3
  BackgroundColor<<control>> #ffe0b2
  BackgroundColor<<infrastructure>> #c5cae9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Perception" <<perception>> {
  rectangle "Traffic Light Detection\n(tl_classifier.py)" as TrafficLightDetection
  rectangle "Camera Info Publisher\n(camera_info_publisher)" as CameraInfoPublisher
  TrafficLightDetection --> CameraInfoPublisher
}

package "Planning" <<planning>> {
  rectangle "Waypoint Loader\n(waypoint_loader.py)" as WaypointLoader
  rectangle "Waypoint Updater\n(waypoint_updater.py)" as WaypointUpdater
  rectangle "Waypoint Follower\n(libwaypoint_follower.cpp)" as WaypointFollower
  WaypointLoader --> WaypointUpdater
  WaypointUpdater --> WaypointFollower
}

package "Control" <<control>> {
  rectangle "Twist Controller\n(dbw_node.py)" as TwistController
  rectangle "PID Controller\n(pid.py)" as PIDController
  rectangle "Yaw Controller\n(yaw_controller.py)" as YawController
  rectangle "LowPass Filter\n(lowpass.py)" as LowPassFilter
  TwistController --> PIDController
  TwistController --> YawController
  TwistController --> LowPassFilter
}

package "Infrastructure" <<infrastructure>> {
  rectangle "Bridge Node\n(bridge.py)" as BridgeNode
  rectangle "Flask Server\n(server.py)" as FlaskServer
  BridgeNode --> FlaskServer
}

Simulator --> BridgeNode
CARLA --> BridgeNode

note left of TrafficLightDetection
  Detects traffic lights and 
  classifies their states using
  HSV color space.
end note

note right of WaypointFollower
  Follows waypoints using
  pure pursuit algorithm.
end note

note left of TwistController
  Controls vehicle actuators
  based on velocity targets.
end note

note right of BridgeNode
  Connects ROS environment
  to Unity simulator.
end note

@enduml
```