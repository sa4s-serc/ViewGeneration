```plantuml
@startuml apache_apisix-dashboard

skinparam rectangle {
  BackgroundColor<<frontend>> LightBlue
  BackgroundColor<<data_flow>> LightYellow
  BackgroundColor<<state_management>> LightGreen
  BackgroundColor<<ui_components>> LightCoral
  BackgroundColor<<api_interaction>> LightCyan
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React & TypeScript)" <<frontend>> {
  rectangle "Routing\n(TanStack Router)" as Routing <<data_flow>>
  rectangle "Data Fetching\n(TanStack Query)" as DataFetching <<data_flow>>
  rectangle "State Management\n(MobX)" as StateManagement <<state_management>>
  rectangle "Form Handling\n(react-hook-form, Zod)" as FormHandling <<ui_components>>
  rectangle "UI Components\n(Mantine, Ant Design Pro)" as UIComponents <<ui_components>>
}

package "API Interaction" <<api_interaction>> {
  rectangle "API Requests\n(Axios)" as APIRequests
  rectangle "APISIX Admin API" as APISIXAPI
}

Routing --> DataFetching
DataFetching --> StateManagement
StateManagement --> FormHandling
FormHandling --> UIComponents
UIComponents --> APIRequests
APIRequests --> APISIXAPI

@enduml
```