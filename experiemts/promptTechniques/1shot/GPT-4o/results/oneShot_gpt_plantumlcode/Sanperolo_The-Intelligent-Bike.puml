```plantuml
@startuml Sanperolo_The-Intelligent-Bike
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend Dashboard" as FE {
  rectangle "Angular App" as Angular #lightyellow
}

rectangle "Backend Server" as Backend #lightsteelblue {
  rectangle "Django REST API" as DjangoAPI
  rectangle "MQTT Subscriber" as MQTTSubscriber
  rectangle "SQL Database\n(PostgreSQL/SQLite)" as SQLDatabase
}

rectangle "Hardware Interface" as Hardware #palegreen {
  rectangle "Sensors" as Sensors
  rectangle "Data Publisher\n(MQTT)" as DataPublisher
}

rectangle "Deployment\n(Heroku)" as Deployment #aliceblue

' ========== Connections ==========
User --> Angular : interact

' Frontend interactions
Angular --> DjangoAPI : fetch sensor data

' Backend interactions
MQTTSubscriber --> SQLDatabase : store sensor data
DjangoAPI --> SQLDatabase : retrieve sensor data

' Hardware interactions
Sensors --> DataPublisher : capture and send data
DataPublisher --> MQTTSubscriber : publish data

' Deployment interactions
DjangoAPI --> Deployment : deploy application
Angular --> Deployment : deploy application

@enduml
```