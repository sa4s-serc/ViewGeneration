```plantuml
@startuml nrephi_jupyter-spark-hadoop-docker
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<hadoop>> #d8f5d3
  BackgroundColor<<hive>> #fddddd
  BackgroundColor<<hue>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Services" <<core>> {
  rectangle "JupyterLab" as JupyterLab
  rectangle "Spark Master" as SparkMaster
  rectangle "Spark Worker" as SparkWorker
  rectangle "MySQL (for Hue)" as MySQL
  JupyterLab --> SparkMaster
  SparkMaster --> SparkWorker
}

package "Hadoop Ecosystem" <<hadoop>> {
  rectangle "Hadoop NameNode" as NameNode
  rectangle "Hadoop DataNode" as DataNode
  NameNode --> DataNode
}

package "Hive Services" <<hive>> {
  rectangle "Hive Metastore\n(PostgreSQL)" as Metastore
  rectangle "Hive Server" as HiveServer
  HiveServer --> Metastore
}

package "Hue Interface" <<hue>> {
  rectangle "Hue" as Hue
  Hue --> MySQL
}

JupyterLab --> Hue
SparkWorker --> DataNode
HiveServer --> DataNode
@enduml
```