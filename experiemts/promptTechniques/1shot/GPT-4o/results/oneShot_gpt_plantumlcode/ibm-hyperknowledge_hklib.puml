```plantuml
@startuml ibm-hyperknowledge_hklib

skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<datasource>> #d8f5d3
  BackgroundColor<<utility>> #fddddd
  BackgroundColor<<external>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Entity Layer" <<core>> {
  rectangle "Node" as Node
  rectangle "Context" as Context
  rectangle "Link" as Link
  rectangle "Connector" as Connector
  rectangle "Reference" as Reference
  rectangle "Trail" as Trail
  rectangle "HKEntity\n(Base Class)" as HKEntity
  Node --> HKEntity
  Context --> HKEntity
  Link --> HKEntity
  Connector --> HKEntity
  Reference --> HKEntity
  Trail --> HKEntity
}

package "Data Access Layer" <<datasource>> {
  rectangle "HKDatasource" as HKDatasource
  rectangle "HKObserverFactory" as HKObserverFactory
  rectangle "ObserverClient" as ObserverClient
  HKDatasource --> HKObserverFactory
  HKObserverFactory --> ObserverClient
}

package "Utility Layer" <<utility>> {
  rectangle "Fragment Identifiers" as FI
  rectangle "hyperify.js" as Hyperify
  rectangle "Deserialize" as Deserialize
  FI --> HKEntity
  Hyperify --> HKEntity
  Deserialize --> HKEntity
}

package "External Data Integration" <<external>> {
  rectangle "Virtual Node" as VirtualNode
  rectangle "Virtual Context" as VirtualContext
  rectangle "Virtual Link" as VirtualLink
  VirtualNode --> Node
  VirtualContext --> Context
  VirtualLink --> Link
}

@enduml
```