```plantuml
@startuml YW-Ma_Algorithms-Visualizer
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Frontend" as FE {
  rectangle "Map.js" as Map
  rectangle "Sidebar.js" as Sidebar
  rectangle "GraphSVG.js" as GraphSVG
  rectangle "GraphTable.js" as GraphTable
  rectangle "MainInterface.js" as MainInterface
  rectangle "Reports.js" as Reports
  rectangle "eventProxy.js" as EventProxy
}

rectangle "Backend" as BE {
  rectangle "Node.js Express" as Express
  rectangle "Authorize.js" as Authorize
  rectangle "User.js" as UserModule
  rectangle "MySQL Database" as Database
  rectangle "C++ Algorithms" as Algorithms {
    rectangle "DFS" as DFS
    rectangle "Dijkstra" as Dijkstra
  }
}

' Connections
User --> FE

' Frontend interactions
FE --> Map : Interact with Baidu Maps
Sidebar --> GraphSVG : Trigger visualization
Sidebar --> GraphTable : Update table data
MainInterface <--> Sidebar : User interactions
MainInterface --> GraphSVG : Render visualization
MainInterface --> GraphTable : Render data
Reports <--> EventProxy : Communicate events

' Backend interactions
FE --> Express : HTTP Requests (e.g., execute algorithms, authenticate)
Express --> Authorize : Validate authentication
Express --> UserModule : Manage user data
Express --> Algorithms : Call C++ executables
Express <--> Database : Persist and retrieve data
Algorithms --> Express : Return algorithm results
@enduml
```