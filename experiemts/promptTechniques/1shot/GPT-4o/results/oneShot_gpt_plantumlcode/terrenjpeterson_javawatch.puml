```plantuml
@startuml terrenjpeterson_javawatch
skinparam rectangle {
  BackgroundColor #ffffff
  BorderColor black
  Style roundrect
}
left to right direction

actor User

rectangle "Raspberry Pi" as RP {
}

rectangle "AWS S3" as S3 #aliceblue {
}

rectangle "AWS Lambda" as Lambda #lightsteelblue {
  rectangle "checkImage.py" as CheckImage
  rectangle "labelCheck.js" as LabelCheck
}

rectangle "Amazon Rekognition" as Rekognition #palegreen {
}

rectangle "Amazon DRS" as DRS #lightyellow {
}

rectangle "Website" as Website {
  rectangle "registration.html" as Registration
}

' ========== Connections ==========
User --> RP : capture image

' Raspberry Pi interactions
RP --> S3 : upload image with timestamp

' S3 interactions
S3 --> Lambda : trigger checkImage.py

' Lambda interactions
CheckImage --> Rekognition : detect_labels (Bean)
Rekognition --> CheckImage : return label data
CheckImage --> LabelCheck : confirm Bean label
LabelCheck --> CheckImage : return confirmation
CheckImage --> DRS : place order if bean level low

' Website interactions
User --> Website : register device
Website --> DRS : link to Amazon account via registration.html

@enduml
