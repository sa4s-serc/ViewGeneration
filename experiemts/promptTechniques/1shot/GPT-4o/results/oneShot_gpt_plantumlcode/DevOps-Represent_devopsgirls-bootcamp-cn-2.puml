```plantuml
@startuml DevOps-Represent_devopsgirls-bootcamp-cn-2
skinparam rectangle {
  BackgroundColor<<ui>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<aws>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

actor User

package "UI (React)" <<ui>> {
  rectangle "App.js" as App
  rectangle "TodoList.js" as TodoList
  rectangle "NewTodoForm.js" as NewTodoForm
  rectangle "config.js" as Config
  rectangle "client.js" as Client
  rectangle "render.js" as Render
  User --> App
  App --> TodoList
  App --> NewTodoForm
  App --> Config
}

package "Backend (AWS)" <<backend>> {
  rectangle "API Gateway" as APIGateway
  rectangle "Lambda Function" as Lambda
  rectangle "S3 Bucket\n(Static Hosting)" as S3 <<aws>>
  App --> APIGateway
  App --> S3
  APIGateway --> Lambda
}

package "Data Storage" <<db>> {
  rectangle "DynamoDB" as DynamoDB
  Lambda --> DynamoDB
}

@enduml
```