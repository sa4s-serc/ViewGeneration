```plantuml
@startuml doitintl_banias
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<gcp>> #fddddd
  Style roundrect
}
skinparam defaultTextAlignment center

package "Event Reception (Frontend - Go)" <<frontend>> {
  rectangle "HTTP API\n(/track)" as HTTPAPI
  rectangle "Event Validation\n(Collector)" as Collector
  rectangle "Asynchronous\nPublishing\n(Publisher)" as Publisher
  rectangle "Prometheus Metrics\n(/metrics)" as Metrics
  HTTPAPI --> Collector
  Collector --> Publisher
  Publisher --> Metrics
}

package "Event Publishing (Frontend - Go)" <<frontend>> {
  rectangle "Google Pub/Sub\nPublisher\n(GoPool)" as GoPool
  Publisher --> GoPool
}

package "Data Processing (Backend - Java)" <<backend>> {
  rectangle "Google Cloud\nDataflow Pipeline" as Dataflow
  rectangle "BigQuery Tables" as BigQuery
  rectangle "Error Table" as ErrorTable
  Dataflow --> BigQuery
  Dataflow --> ErrorTable
}

package "Schema Management (Backend - Java)" <<backend>> {
  rectangle "Dynamic Schema\nLoading from\nGCS" as SchemaLoading
  SchemaLoading --> Dataflow
}

cloud "Google Cloud Platform" <<gcp>> {
  queue "Google Pub/Sub" as PubSub
  storage "Google Cloud Storage" as GCS
  PubSub --> Dataflow
  SchemaLoading --> GCS
}

@enduml
```