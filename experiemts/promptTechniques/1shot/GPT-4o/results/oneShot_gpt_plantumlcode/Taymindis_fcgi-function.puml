```plantuml
@startuml Taymindis_fcgi-function
skinparam rectangle {
  BackgroundColor<<core>> #d9e7fd
  BackgroundColor<<integration>> #d8f5d3
  BackgroundColor<<example>> #fddddd
  BackgroundColor<<build>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Core Framework" <<core>> {
  rectangle "ffunc.h" as FFuncHeader
  rectangle "ffunc.c" as FFuncImpl
  FFuncHeader --> FFuncImpl
}

package "FastCGI Integration" <<integration>> {
  rectangle "fcgiapp Library" as FCGILib
  FFuncImpl --> FCGILib
}

package "Example Applications" <<example>> {
  rectangle "profile_service.c" as ProfileC
  rectangle "profile_service.cpp" as ProfileCpp
  FFuncImpl --> ProfileC
  FFuncImpl --> ProfileCpp
}

package "Build and Deployment" <<build>> {
  rectangle "CMakeLists.txt" as CMake
  rectangle "DockerExample" as Docker
  FFuncImpl --> CMake
  FFuncImpl --> Docker
}

rectangle "Nginx/Apache\nFastCGI Server" as WebServer
WebServer --> FCGILib

@enduml
```