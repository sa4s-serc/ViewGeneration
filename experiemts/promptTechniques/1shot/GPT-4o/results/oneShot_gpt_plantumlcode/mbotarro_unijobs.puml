```plantuml
@startuml mbotarro_unijobs
skinparam rectangle {
  BackgroundColor<<frontend>> #d9e7fd
  BackgroundColor<<backend>> #d8f5d3
  BackgroundColor<<integration>> #fddddd
  BackgroundColor<<db>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Frontend (React Native)" <<frontend>> {
  rectangle "User Authentication" as Auth
  rectangle "Offer/Request Feed" as Feed
  rectangle "Offer/Request Creation" as Creation
  rectangle "User Profiles" as Profiles
  rectangle "Navigation" as Navigation
  rectangle "UI Design" as UIDesign
  rectangle "Interest Matching" as InterestMatching
  Auth -[hidden]-> Feed
  Feed -[hidden]-> Creation
  Creation -[hidden]-> Profiles
  Profiles -[hidden]-> Navigation
  Navigation -[hidden]-> UIDesign
  UIDesign -[hidden]-> InterestMatching
}

package "Backend (Go)" <<backend>> {
  rectangle "RESTful API" as API
  rectangle "Data Abstraction Layer" as DAL
  rectangle "Business Logic\nUse Cases" as UseCases
  rectangle "HTTP Handlers" as Handlers
  rectangle "Models" as Models
  API --> Handlers
  Handlers --> UseCases
  UseCases --> Models
  DAL --> Models
}

package "Integrations" <<integration>> {
  rectangle "Elasticsearch" as Elasticsearch
  UseCases --> Elasticsearch
}

database "PostgreSQL" <<db>> as PostgreSQL
DAL --> PostgreSQL
@enduml
```