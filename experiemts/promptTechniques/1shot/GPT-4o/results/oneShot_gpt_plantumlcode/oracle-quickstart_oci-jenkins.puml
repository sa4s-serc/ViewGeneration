```plantuml
@startuml oracle-quickstart_oci-jenkins
skinparam rectangle {
  BackgroundColor<<module>> #d9e7fd
  BackgroundColor<<file>> #d8f5d3
  BackgroundColor<<script>> #fddddd
  BackgroundColor<<example>> #fff1c9
  Style roundrect
}
skinparam defaultTextAlignment center

package "Terraform Modules" <<module>> {
  package "Jenkins Controller Module" <<module>> {
    rectangle "main.tf" <<file>> as ControllerMain
    rectangle "setup.sh" <<script>> as ControllerSetup
  }
  
  package "Jenkins Agent Module" <<module>> {
    rectangle "main.tf" <<file>> as AgentMain
    rectangle "config.sh" <<script>> as AgentConfig
  }
}

package "Main Configuration" <<file>> {
  rectangle "main.tf" as MainTF
  rectangle "variables.tf" as VariablesTF
  rectangle "outputs.tf" as OutputsTF
  rectangle "versions.tf" as VersionsTF
}

package "Example Configurations" <<example>> {
  rectangle "single_instance_public" as SingleInstance
  rectangle "quick_start" as QuickStart
  rectangle "bastion_service" as BastionService
}

rectangle "README.md" <<file>> as Readme
rectangle "LICENSE" <<file>> as License

MainTF --> ControllerMain
MainTF --> AgentMain
ControllerMain --> ControllerSetup
AgentMain --> AgentConfig

MainTF --> VariablesTF
MainTF --> OutputsTF
MainTF --> VersionsTF

MainTF --> SingleInstance
MainTF --> QuickStart
MainTF --> BastionService

@enduml
```