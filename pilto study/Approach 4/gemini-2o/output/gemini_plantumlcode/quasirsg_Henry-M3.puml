}

package "02-Promises & 04-AdvancePromises" {
    component "ejemplos.js\n(Promise Examples)" as promiseExamples
    component "exercise-one.js, exercise-two.js\n(Promise Exercises)" as promiseExercises
    component "utils.js\n(Promise Utilities)" as promiseUtils
    component "demo/encadenandoPromesas.js\n(Promise Chaining)" as promiseChaining
    component "pledge.js (Custom Promise Implementation)" as pledge
}

package "06-Testing" {
    component "index.js\n(Application Export)" as appExport
    component "tests/index.spec.js\n(Mini Application Tests)" as appTests
}

package "Web Server (http module)" {
    component "http Server" as httpServer
}

package "Express.js Framework" {
    component "Express Application" as expressApp
    interface "Middleware" as middleware
}

component "Package Manifests\n(package.json)" as packageJson

